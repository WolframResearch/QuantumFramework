 RowBox[{"{", 
  RowBox[{
   RowBox[{"Head", "[", 
    RowBox[{"qs", "[", "\"\<DensityMatrix\>\"", "]"}], "]"}], ",", " ", 
   RowBox[{"Head", "[", 
    RowBox[{"qs", "[", "\"\<NormalizedState\>\"", "]"}], "]"}], ",", " ", 
   RowBox[{"Head", "[", 
    RowBox[{"qs", "[", "\"\<VonNeumannEntropy\>\"", "]"}], "]"}]}], 
  "}"}]}], "Input",
 CellLabel->"In[23]:=",ExpressionUUID->"0ba0f7ea-2117-40ca-abe7-78e7cc7f773e"],

