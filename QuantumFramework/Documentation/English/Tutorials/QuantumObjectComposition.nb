Cell[CellGroupData[{

Cell["Type-changing: distance returns a Real", "Subsection",
 CellID->211,ExpressionUUID->"7c865fd7-73cc-4e39-8354-90efc2af21b9"],

Cell[CellGroupData[{

Cell[TextData[{
 "A ",
 Cell[BoxData[
  FormBox["Distance", TraditionalForm]], "InlineFormula",ExpressionUUID->
  "4664f2ab-2ae9-4751-893f-a67bf1c95e7c"],
 "-kind head consumes objects and produces a scalar. The composition is \
type-changing \[LongDash] from ",
 Cell[BoxData[
  FormBox["QuantumState", TraditionalForm]], "InlineFormula",ExpressionUUID->
  "db50a8ea-9916-483d-9bc6-c0b57e93abbe"],
 "s out to ",
 Cell[BoxData[
  FormBox["Real", TraditionalForm]], "InlineFormula",ExpressionUUID->
  "0078e6f4-9165-405b-b6c7-41810f1e2631"],
 ". Because the graph drops scalars (Real / Integer / Boolean) from the node \
set, a Distance head appears as a vertex with only incoming edges (a sink):"
}], "Text",ExpressionUUID->"c47979ce-2b8a-4323-9208-a98005a95646"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"d", " ", "=", " ", 
   RowBox[{"QuantumDistance", "[", 
    RowBox[{
     RowBox[{"QuantumState", "[", "\"\<0\>\"", "]"}], ",", " ", 
     RowBox[{"QuantumState", "[", "\"\<Plus\>\"", "]"}], ",", 
     " ", "\"\<Fidelity\>\""}], "]"}]}], ";"}], "\n", 
 RowBox[{"Head", "[", 
  RowBox[{"N", "[", "d", "]"}], "]"}]}], "Input",
 CellLabel->"In[20]:=",ExpressionUUID->"30070fa3-2543-419b-ac02-ea2fc4e7ba0b"],

Cell[BoxData["Real"], "Output",
