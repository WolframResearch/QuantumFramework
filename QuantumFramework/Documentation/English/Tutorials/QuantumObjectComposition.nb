Cell[CellGroupData[{

Cell["Querying the graph", "Section",
 CellID->205,ExpressionUUID->"f5b14caf-c6d8-47d2-a6c0-13e23765873d"],

Cell["\<\
The graph is data \[LongDash] queryable with standard Association/list \
patterns.\
\>", "Text",ExpressionUUID->"8d7fc534-53d4-4c71-9ed8-565bcf88e97a"],

Cell[CellGroupData[{

Cell["What produces a QuantumState?", "Subsection",
 CellID->220,ExpressionUUID->"fe7bcf09-e17e-45ca-a5bc-40efe1452f12"],

Cell[CellGroupData[{

Cell[TextData[{
 "Find the symbols with an outgoing edge into ",
 Cell[BoxData[
  FormBox["QuantumState", TraditionalForm]], "InlineFormula",ExpressionUUID->
  "131850a3-9523-4fdc-aa9f-66d43f76309b"],
 ":"
}], "Text",ExpressionUUID->"7dcc8128-eb88-4145-9c75-4c70fdb320f9"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"producers", " ", "=", " ", 
  RowBox[{"Cases", "[", 
   RowBox[{
    RowBox[{"PacletFlowEdges", "[", "graphData", "]"}], ",", " ", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"f_", ",", " ", "\"\<QuantumState\>\""}], "}"}], " ", ":>", " ",
      "f"}]}], "]"}]}]], "Input",
 CellLabel->"In[29]:=",ExpressionUUID->"f8d8ffce-efd7-4ef4-9427-650a957e12f0"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"\<\"QuantumCircuitOperator\"\>", 
   ",", "\<\"QuantumMeasurementOperator\"\>", ",", "\<\"QuantumOperator\"\>", 
   ",", "\<\"QuantumMeasurement\"\>", ",", "\<\"QuantumChannel\"\>", 
   ",", "\<\"QuditBasis\"\>", ",", "\<\"QuantumBasis\"\>", 
   ",", "\<\"QuantumState\"\>"}], "}"}]], "Output",
 CellChangeTimes->{3.987618435291315*^9, 3.987618491450563*^9},
 CellLabel->"Out[29]=",
 CellID->1062921584,ExpressionUUID->"999cdb2e-912f-422f-8e92-49d47142a7d6"]
}, Open  ]]
}, Open  ]]
