Cell[CellGroupData[{

Cell[TextData[{
 "If you only want the raw edge data, ",
 StyleBox["PacletFlowEdges", "Input",
  FontFamily->"Source Code Pro"],
 " returns a deduplicated list of ",
 StyleBox["{from, to}", "Input",
  FontFamily->"Source Code Pro"],
 " pairs. This is useful when feeding the graph into other tooling (e.g. \
computing centrality or partitioning):"
}], "Text",ExpressionUUID->"1f434d29-64c0-49c7-b11a-15c72231bb26"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"edges", " ", "=", " ", 
   RowBox[{"PacletFlowEdges", "[", "graphData", "]"}]}], ";"}], "\n", 
 RowBox[{"{", 
  RowBox[{
   RowBox[{"Length", "[", "edges", "]"}], ",", " ", 
   RowBox[{"Take", "[", 
    RowBox[{"edges", ",", " ", "5"}], "]"}]}], "}"}]}], "Input",
 CellLabel->"In[27]:=",ExpressionUUID->"1aea8221-b97b-444e-a409-2534e9e7606c"],

