 Cell[BoxData[
  FormBox["None", TraditionalForm]], "InlineFormula",ExpressionUUID->
  "aa1ab95c-c7cf-4fb6-934c-c78a85ae8c41"],
 " only for heads whose application has been recorded as ",
 StyleBox["F[args][target]", "Input",
