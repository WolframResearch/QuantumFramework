Cell[TextData[{
 "The Kind tag drives vertex coloring in the rendered graphs (next section) \
and is the first filter when querying for symbols of a given role. A ",
 StyleBox["\"Predicate\"", "Input",
  FontFamily->"Source Code Pro"],
 " head is, for example, never a source of any outgoing flow edge \[LongDash] \
it returns a scalar, not a paclet object."
}], "Text",ExpressionUUID->"8c4fa58f-0901-43c9-a4f6-210baf479f79"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Reading an entry", "Section",
 CellID->202,ExpressionUUID->"7bdfb560-0d0b-41d0-8686-74e1bf17caa2"],

Cell[CellGroupData[{

Cell[TextData[{
 "Each symbol's entry records four fields: ",
 StyleBox["Kind", "Input",
  FontFamily->"Source Code Pro"],
 ", ",
 StyleBox["Accepts", "Input",
  FontFamily->"Source Code Pro"],
 ", ",
 StyleBox["OperatesOn", "Input",
  FontFamily->"Source Code Pro"],
 ", and ",
 StyleBox["ConsumedBy", "Input",
  FontFamily->"Source Code Pro"],
 ". Inspect QuantumState as an example:"
}], "Text",ExpressionUUID->"c9891a34-306d-44bb-94b7-c9b9435851d6"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"entry", " ", "=", " ", 
   RowBox[{"graphData", "[", "\"\<QuantumState\>\"", "]"}]}], ";"}], "\n", 
 RowBox[{"Keys", "[", "entry", "]"}]}], "Input",
 CellLabel->"In[9]:=",ExpressionUUID->"77fbda39-123d-4771-bc54-3c7d97af6b79"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"\<\"Kind\"\>", ",", "\<\"Accepts\"\>", ",", "\<\"OperatesOn\"\>", 
   ",", "\<\"ConsumedBy\"\>"}], "}"}]], "Output",
 CellChangeTimes->{3.987618434755457*^9, 3.987618490867585*^9},
 CellLabel->"Out[10]=",
 CellID->1825043042,ExpressionUUID->"446a5389-9d9d-4d54-a6e4-a93bb1f77370"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell[TextData[{
 StyleBox["Accepts",
  FontWeight->"Bold"],
 " is a list of input forms the head's constructor recognizes, classified by \
the WL ",
 Cell[BoxData[
  FormBox["Head", TraditionalForm]], "InlineFormula",ExpressionUUID->
  "620cb080-4417-45ed-bf61-ddc6337e4582"],
 " of the user-typed argument and tagged with a Role: ",
 StyleBox["\"Primary\"", "Input",
  FontFamily->"Source Code Pro"],
 " (the canonical input), ",
 StyleBox["\"Mutation\"", "Input",
  FontFamily->"Source Code Pro"],
 " (constructor takes its own head to re-wrap), ",
 StyleBox["\"Conversion\"", "Input",
  FontFamily->"Source Code Pro"],
 " (takes another paclet head and reroutes), ",
 StyleBox["\"NamedInstance\"", "Input",
  FontFamily->"Source Code Pro"],
 " (a String like ",
 StyleBox["\"Bell\"", "Input",
  FontFamily->"Source Code Pro"],
 " selecting a catalog entry), ",
 StyleBox["\"NamedArg\"", "Input",
  FontFamily->"Source Code Pro"],
 " (a Rule like ",
 StyleBox["\"Eigenvalues\" -> v", "Input",
  FontFamily->"Source Code Pro"],
 "), or ",
 StyleBox["\"PatternMachinery\"", "Input",
  FontFamily->"Source Code Pro"],
 " (internal). ",
 "Tally the heads to see the dominant input forms:"
}], "Text",ExpressionUUID->"b91bd558-e94a-42a5-8c30-82cc36de8c50"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Tally", "[", 
  RowBox[{
   RowBox[{
    RowBox[{"#", "[", "\"\<Head\>\"", "]"}], " ", "&"}], " ", "/@", " ", 
   RowBox[{"entry", "[", "\"\<Accepts\>\"", "]"}]}], "]"}]], "Input",
 CellLabel->"In[11]:=",ExpressionUUID->"2edcb335-59a6-4ff4-bc67-29bc59c84b1d"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"String", ",", "2"}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{"Symbol", ",", "2"}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{"SuperDagger", ",", "1"}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{"Blank", ",", "1"}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{"Association", ",", "1"}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{"Rule", ",", "1"}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{"QuantumOperator", ",", "1"}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{"QuantumMeasurementOperator", ",", "1"}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{"QuantumMeasurement", ",", "1"}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{"QuantumChannel", ",", "1"}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{"QuantumCircuitOperator", ",", "1"}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{"QuditBasis", ",", "1"}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{"QuantumBasis", ",", "1"}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{"BlankNullSequence", ",", "2"}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{"Except", ",", "1"}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{"QuantumState", ",", "2"}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{"PatternTest", ",", "1"}], "}"}]}], "}"}]], "Output",
 CellChangeTimes->{3.9876184347713614`*^9, 3.9876184908853416`*^9},
 CellLabel->"Out[11]=",
 CellID->989476793,ExpressionUUID->"e14b3ba5-8c5d-487d-8f7e-b8462b432a74"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["\<\
Filter to just the entries whose Role is Primary or Conversion (the ones that \
produce graph edges):\
\>", "Text",ExpressionUUID->"25c7a4c9-f43c-4c83-a66a-3759acee09a3"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Select", "[", 
  RowBox[{
   RowBox[{"entry", "[", "\"\<Accepts\>\"", "]"}], ",", " ", 
   RowBox[{
    RowBox[{"MemberQ", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"\"\<Primary\>\"", ",", " ", "\"\<Mutation\>\"", ",", 
        " ", "\"\<Conversion\>\""}], "}"}], ",", " ", 
