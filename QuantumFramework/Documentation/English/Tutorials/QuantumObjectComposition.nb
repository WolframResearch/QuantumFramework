       ",", "\<\"QuantumChannel\"\>"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"\<\"QuantumMeasurement\"\>", ",", "\<\"QuantumChannel\"\>"}], 
      "}"}]}], "}"}]}], "}"}]], "Output",
 CellChangeTimes->{3.987618435277198*^9, 3.987618491428952*^9},
