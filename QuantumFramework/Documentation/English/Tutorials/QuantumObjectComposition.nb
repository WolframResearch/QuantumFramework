Cell["Type-preserving: operator application", "Subsection",
 CellID->210,ExpressionUUID->"6bb509da-845e-4228-aa3e-5c8c9b322b52"],

Cell[CellGroupData[{

Cell[TextData[{
 "An ",
 Cell[BoxData[
  FormBox["Operator", TraditionalForm]], "InlineFormula",ExpressionUUID->
  "e3b740d7-40fa-4de9-b405-96c02578a66b"],
 "-kind head applied to a target of type ",
 Cell[BoxData[
  FormBox["T", TraditionalForm]], "InlineFormula",ExpressionUUID->
  "5a22b977-29c2-4660-a070-4926943cb611"],
 " typically returns a result of the same type ",
 Cell[BoxData[
  FormBox["T", TraditionalForm]], "InlineFormula",ExpressionUUID->
  "6f56a38f-6578-442c-8991-e3b6e7383578"],
 ". In the flow graph this is a self-loop on ",
 Cell[BoxData[
  FormBox["T", TraditionalForm]], "InlineFormula",ExpressionUUID->
  "7afc71f0-0040-4ff7-9d16-617d27f41f3d"],
 ". Build a state, apply Pauli-X, and check the head:"
}], "Text",ExpressionUUID->"500b8b86-7390-46ef-b9e5-dbfdc2bbcf8a"],

