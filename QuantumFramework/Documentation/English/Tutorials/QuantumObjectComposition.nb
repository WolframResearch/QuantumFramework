Cell[CellGroupData[{

Cell["What consumes a QuantumState?", "Subsection",
 CellID->221,ExpressionUUID->"2fb720b2-3b84-4b14-b416-428631356835"],

Cell[CellGroupData[{

Cell["\<\
The mirror query: outgoing edges from QuantumState. Equivalent to (but easier \
to read than) the symmetric look-up in ConsumedBy:\
\>", "Text",ExpressionUUID->"9fd536f7-8304-43be-bb1b-424ebc02c7d7"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"consumers", " ", "=", " ", 
  RowBox[{"Cases", "[", 
   RowBox[{
    RowBox[{"PacletFlowEdges", "[", "graphData", "]"}], ",", " ", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"\"\<QuantumState\>\"", ",", " ", "t_"}], "}"}], " ", ":>", " ",
      "t"}]}], "]"}]}]], "Input",
 CellLabel->"In[30]:=",ExpressionUUID->"ba3b8b6d-6308-44c1-964b-a2c48d09885a"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"\<\"QuantumBasis\"\>", ",", "\<\"QuantumCircuitOperator\"\>", 
   ",", "\<\"QuantumDistance\"\>", ",", "\<\"QuantumEntangledQ\"\>", 
   ",", "\<\"QuantumEntanglementMonotone\"\>", 
   ",", "\<\"QuantumMeasurement\"\>", 
   ",", "\<\"QuantumMeasurementOperator\"\>", 
   ",", "\<\"QuantumMeasurementSimulation\"\>", 
   ",", "\<\"QuantumOperator\"\>", ",", "\<\"QuantumPartialTrace\"\>", 
   ",", "\<\"QuantumPhaseSpaceTransform\"\>", 
   ",", "\<\"QuantumSimilarity\"\>", ",", "\<\"QuantumState\"\>", 
   ",", "\<\"QuantumTensorProduct\"\>", 
   ",", "\<\"QuantumWignerTransform\"\>"}], "}"}]], "Output",
 CellChangeTimes->{3.987618435309325*^9, 3.987618491468294*^9},
 CellLabel->"Out[30]=",
 CellID->1754086542,ExpressionUUID->"32651dea-cc95-4ece-a377-c7da49837c84"]
}, Open  ]]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["Which heads are closed under their own action?", "Subsection",
 CellID->222,ExpressionUUID->"3adb7480-7026-4b50-b933-cfeb9f5edd1b"],

Cell[CellGroupData[{

Cell[TextData[{
 "An operator-like head is closed if its ",
 StyleBox["OperatesOn", "Input",
  FontFamily->"Source Code Pro"],
 " maps some paclet head ",
 Cell[BoxData[
  FormBox["K", TraditionalForm]], "InlineFormula",ExpressionUUID->
  "9b351efe-f7d2-48f8-8a9d-227ea711192a"],
 " back to itself \[LongDash] in the flow graph, a self-loop or a parallel \
pair ",
 Cell[BoxData[
  FormBox["K", TraditionalForm]], "InlineFormula",ExpressionUUID->
  "5f67c0bb-0896-4c55-ad69-1e4232cb55f1"],
 " \[Rule] ",
 Cell[BoxData[
  FormBox["F", TraditionalForm]], "InlineFormula",ExpressionUUID->
  "72ba763b-9c23-4a2f-8b8f-1e7739e08f54"],
 " \[Rule] ",
 Cell[BoxData[
  FormBox["K", TraditionalForm]], "InlineFormula",ExpressionUUID->
  "bb3b6afc-bc8d-4df7-8c6f-7d924586816e"],
 "."
}], "Text",ExpressionUUID->"03b158b8-6e0f-40ea-bb90-21d48f8160a4"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"selfLoops", "[", "g_", "]"}], " ", ":=", " ", 
   RowBox[{"Cases", "[", 
    RowBox[{
     RowBox[{"PacletFlowEdges", "[", "g", "]"}], ",", " ", 
     RowBox[{"{", 
      RowBox[{"x_", ",", " ", "x_"}], "}"}]}], "]"}]}], ";"}], "\n", 
 RowBox[{"selfLoops", "[", "graphData", "]"}]}], "Input",
 CellLabel->"In[31]:=",ExpressionUUID->"f2ac5c7b-c3ab-468b-b66d-72711e3f7d82"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"\<\"QuantumOperator\"\>", ",", "\<\"QuantumOperator\"\>"}], 
    "}"}], ",", 
   RowBox[{"{", 
    RowBox[{"\<\"QuantumState\"\>", ",", "\<\"QuantumState\"\>"}], "}"}]}], 
  "}"}]], "Output",
 CellChangeTimes->{3.987618435328465*^9, 3.987618491485486*^9},
 CellLabel->"Out[32]=",
 CellID->277005378,ExpressionUUID->"b982bb59-997b-4719-a35a-0ec874190aa7"]
}, Open  ]]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["Which heads are sinks?", "Subsection",
 CellID->223,ExpressionUUID->"d6d094ff-b5fb-48a5-9a26-f6a4f4c78b4b"],

Cell[CellGroupData[{

Cell[TextData[{
 "A sink has incoming edges but no outgoing ones \[LongDash] symbols whose \
output is a scalar (",
 Cell[BoxData[
  FormBox["Real", TraditionalForm]], "InlineFormula",ExpressionUUID->
  "cb12b8f7-0793-40c9-bba6-9093f1191afa"],
 ", ",
 Cell[BoxData[
  FormBox["Boolean", TraditionalForm]], "InlineFormula",ExpressionUUID->
  "36724dc8-4be4-4f15-bcb4-7bc8fe0e0695"],
 ", ",
 Cell[BoxData[
  FormBox["Association", TraditionalForm]], "InlineFormula",ExpressionUUID->
  "c0ba3d0b-0d2f-420a-8fbf-c09e0076ba3e"],
 ") rather than a paclet object. ",
 Cell[BoxData[
  FormBox["QuantumDistance", TraditionalForm]], "InlineFormula",
  ExpressionUUID->"fef62e5b-6144-4cc8-8b0d-57649d1b8191"],
 " and ",
 Cell[BoxData[
  FormBox["QuantumEntangledQ", TraditionalForm]], "InlineFormula",
  ExpressionUUID->"0da5b496-4851-4ac8-a897-1b56c3ed828c"],
 " are typical sinks:"
}], "Text",ExpressionUUID->"0a3268f1-ba93-4e2d-9aa2-c097db6f92c9"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"sinks", "[", "g_", "]"}], " ", ":=", " ", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"e", " ", "=", " ", 
       RowBox[{"PacletFlowEdges", "[", "g", "]"}]}], "}"}], ",", "\n", "  ", 
     RowBox[{
      RowBox[{"Complement", "[", 
       RowBox[{
        RowBox[{"e", "[", 
         RowBox[{"[", 
          RowBox[{"All", ",", " ", "2"}], "]"}], "]"}], ",", " ", 
        RowBox[{"e", "[", 
         RowBox[{"[", 
          RowBox[{"All", ",", " ", "1"}], "]"}], "]"}]}], "]"}], " ", "//", 
      " ", "Union"}]}], "\n", "]"}]}], ";"}], "\n", 
 RowBox[{"sinks", "[", "graphData", "]"}]}], "Input",
 CellLabel->"In[33]:=",ExpressionUUID->"1e26c91a-3faf-4c23-a690-84081e750e06"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"\<\"QuantumDistance\"\>", ",", "\<\"QuantumEntangledQ\"\>", 
   ",", "\<\"QuantumEntanglementMonotone\"\>", ",", "\<\"QuantumEvolve\"\>", 
   ",", "\<\"QuantumMeasurementSimulation\"\>", 
   ",", "\<\"QuantumPartialTrace\"\>", 
   ",", "\<\"QuantumPhaseSpaceTransform\"\>", 
   ",", "\<\"QuantumSimilarity\"\>", ",", "\<\"QuantumTensorProduct\"\>", 
   ",", "\<\"QuantumWignerTransform\"\>"}], "}"}]], "Output",
 CellChangeTimes->{3.987618435346258*^9, 3.987618491499424*^9},
 CellLabel->"Out[34]=",
 CellID->2032324997,ExpressionUUID->"bde28da0-55c6-4b5f-b00a-d30dfa9f522b"]
}, Open  ]]
}, Open  ]]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["Where this leaves us", "Section",
 CellID->206,ExpressionUUID->"65669bfa-1383-44ae-a32d-60630de8a079"],

Cell["Three takeaways:", "Text",ExpressionUUID->"c652c9f7-d2db-4dac-8987-75033eb3fe3f"],

Cell[TextData[{
 "\[Bullet] Every public QuantumFramework head has a typed signature recorded \
in the function-graph. The composition rules are not buried in kernel files \
\[LongDash] one call to ",
 StyleBox["BuildFunctionGraph", "Input",
  FontFamily->"Source Code Pro"],
 " produces a queryable Association."
}], "Item",ExpressionUUID->"44f3612b-4f87-4840-8d0c-bc982770731c"],

Cell[TextData[{
 "\[Bullet] Operator-like heads are characterized by self-loops in the flow \
graph (their ",
 StyleBox["OperatesOn", "Input",
  FontFamily->"Source Code Pro"],
 " maps their target type back to itself). ",
 Cell[BoxData[
  FormBox["QuantumOperator", TraditionalForm]], "InlineFormula",
  ExpressionUUID->"ad90d58f-4dbb-43e2-bf86-e51278511640"],
 ", ",
 Cell[BoxData[
  FormBox["QuantumChannel", TraditionalForm]], "InlineFormula",ExpressionUUID->
  "1f505770-edfa-42e1-98b2-88777778ee4d"],
 ", and ",
 Cell[BoxData[
  FormBox["QuantumCircuitOperator", TraditionalForm]], "InlineFormula",
  ExpressionUUID->"4146b622-079b-421f-bd0d-9eaee8f9e0c1"],
 " all preserve ",
 Cell[BoxData[
  FormBox["QuantumState", TraditionalForm]], "InlineFormula",ExpressionUUID->
  "fe9f98b9-63e4-4902-91c7-55592ceaaefd"],
 " under application."
}], "Item",ExpressionUUID->"d1118d06-ba36-42dd-a972-b7deb5429b84"],

Cell[TextData[{
 "\[Bullet] Type-changing heads (",
 Cell[BoxData[
  FormBox["QuantumDistance", TraditionalForm]], "InlineFormula",
  ExpressionUUID->"aafab592-7df5-4904-a969-f75ec84e9511"],
 ", ",
 Cell[BoxData[
  FormBox["QuantumEntangledQ", TraditionalForm]], "InlineFormula",
  ExpressionUUID->"3c3015da-e4f6-4931-a97c-d7f08133f4b4"],
 ") return scalars and therefore appear as sink vertices: incoming edges only."
}], "Item",ExpressionUUID->"860bdd9f-d59d-4b17-a541-44226864511f"],

Cell[TextData[{
 "The same workflow applies to any paclet: ",
 StyleBox["Needs[\"Wolfram`PacletFunctionGraph`\"]", "Input",
  FontFamily->"Source Code Pro"],
 ", ",
 StyleBox["BuildFunctionGraph[\"/path/to/SomePaclet\"]", "Input",
  FontFamily->"Source Code Pro"],
 ", then render or query."
}], "Text",ExpressionUUID->"597337fa-8b50-44ec-a269-f5e10e63890d"]
}, Open  ]],

