Cell[CellGroupData[{

Cell["Quantum Object Composition", "Title",
 CellID->300,ExpressionUUID->"d421a0c5-7370-46ea-b587-f19d8ddc57e4"],

Cell[TextData[{
 "The public objects of ",
 ButtonBox["QuantumFramework",
  BaseStyle->"Link",
  ButtonData->
   "paclet:Wolfram/QuantumFramework/guide/WolframQuantumComputationFramework"],
 " \[LongDash] states, operators, channels, circuits, measurements, \
transforms \[LongDash] ",
 "compose with one another via typed transformations: a ",
 Cell[BoxData[
  FormBox["QuantumOperator", TraditionalForm]], "InlineFormula",
  ExpressionUUID->"474232fd-187e-4f19-99ab-6f21fe310ed5"],
 " acting on a ",
 Cell[BoxData[
  FormBox["QuantumState", TraditionalForm]], "InlineFormula",ExpressionUUID->
  "6679f069-ad7f-419a-b95d-0da11511c949"],
 " returns a ",
 Cell[BoxData[
  FormBox["QuantumState", TraditionalForm]], "InlineFormula",ExpressionUUID->
  "8880f7aa-89af-4533-be18-6825836c72e5"],
 "; a ",
 Cell[BoxData[
  FormBox["QuantumDistance", TraditionalForm]], "InlineFormula",
  ExpressionUUID->"5b7758c4-6e66-4fbe-8afb-749df5cecc72"],
 " of two ",
 Cell[BoxData[
  FormBox["QuantumState", TraditionalForm]], "InlineFormula",ExpressionUUID->
  "b88e94c0-ecec-4c3c-b592-ab82edac9b09"],
 "s returns a real number. ",
 "This tech note introduces a paclet-agnostic tool, ",
 StyleBox["Wolfram/PacletFunctionGraph", "Input",
  FontFamily->"Source Code Pro"],
 ", that introspects any paclet and produces a directed function-relation \
graph capturing exactly these compositions. ",
 "After working through it, you will be able to read the type signature of \
every public symbol, distinguish type-preserving from type-changing \
morphisms, and render or query the composition graph for any neighborhood of \
interest."
}], "Text",ExpressionUUID->"878266bc-178b-45ef-9df3-107cb54100de"],

Cell[CellGroupData[{

Cell["Loading the framework and building the graph", "Section",
 CellID->200,ExpressionUUID->"a457f58e-92fe-4731-8acc-906962aa59d2"],

Cell[CellGroupData[{

Cell[TextData[{
 "Load ",
 ButtonBox["QuantumFramework",
  BaseStyle->"Link",
  ButtonData->
   "paclet:Wolfram/QuantumFramework/guide/WolframQuantumComputationFramework"],
 " and the ",
 StyleBox["Wolfram`PacletFunctionGraph`", "Input",
  FontFamily->"Source Code Pro"],
 " helper paclet. The latter is not yet published, so we point ",
 StyleBox["PacletDirectoryLoad", "Input",
  FontFamily->"Source Code Pro"],
 " at the dev copy in this repository. The ",
 StyleBox["Remove", "Input",
  FontFamily->"Source Code Pro"],
 " call clears any Global\\` stubs interned by the front-end before the \
paclet was loaded, which would otherwise shadow the package's exports:"
}], "Text",ExpressionUUID->"e74c409b-b06f-48ab-9664-c299aea0ef6f"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"Needs", "[", "\"\<Wolfram`QuantumFramework`\>\"", "]"}], ";"}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
  "PacletDirectoryLoad", 
   "[", "\"\<~/QuantumFramework/OngoingProjects/Improving doc \
pages/PacletFunctionGraph\>\"", "]"}], ";"}], "\n", 
 RowBox[{
  RowBox[{"Needs", "[", "\"\<Wolfram`PacletFunctionGraph`\>\"", "]"}], 
  ";"}]}], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.98761845288832*^9, 3.9876184709641*^9}, {
  3.987621268097803*^9, 3.9876212722911158`*^9}},
 CellLabel->"In[1]:=",ExpressionUUID->"08c260d9-8b8c-4168-95a6-2a1e749f678d"]
}, Open  ]],

Cell[CellGroupData[{

Cell[TextData[{
 "Build the graph for QuantumFramework. ",
 StyleBox["BuildFunctionGraph", "Input",
  FontFamily->"Source Code Pro"],
 " loads the target paclet, walks its ",
 StyleBox["DownValues", "Input",
  FontFamily->"Source Code Pro"],
 " and ",
 StyleBox["SubValues", "Input",
  FontFamily->"Source Code Pro"],
 " to classify how every public symbol is called, and returns an Association \
keyed by symbol name. Predicate guards like ",
 StyleBox["_?QuantumStateQ", "Input",
  FontFamily->"Source Code Pro"],
 " or ",
 StyleBox["_?propQ", "Input",
  FontFamily->"Source Code Pro"],
 " are resolved automatically by walking each predicate's own DownValues \
\[LongDash] no manual configuration needed for any paclet:"
}], "Text",ExpressionUUID->"fbef9d4c-7f9c-4ec2-9a82-13dc70e7b8f8"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"pacletRoot", " ", "=", " ", 
   RowBox[{"ParentDirectory", "[", 
    RowBox[{
     RowBox[{"NotebookDirectory", "[", "]"}], ",", " ", "3"}], "]"}]}], 
  ";"}], "\n", 
 RowBox[{
  RowBox[{"graphData", " ", "=", " ", 
   RowBox[{"BuildFunctionGraph", "[", 
    RowBox[{"pacletRoot", ",", " ", 
     RowBox[{"\"\<WriteFile\>\"", " ", "->", " ", "False"}]}], "]"}]}], 
  ";"}]}], "Input",
 InitializationCell->True,
 CellLabel->"In[4]:=",ExpressionUUID->"4298e27a-f851-45f0-b5cf-b7ab4673fbef"]
}, Open  ]],

Cell[CellGroupData[{

Cell["\<\
The result is an Association. A top-level $Meta entry records when it was \
generated, the paclet identity, and any issues from generation:\
\>", "Text",ExpressionUUID->"00dd3580-2d66-4c14-90dd-0e039612404d"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"graphData", "[", "\"\<$Meta\>\"", "]"}]], "Input",
 CellLabel->"In[6]:=",ExpressionUUID->"edc2a3bb-e0b7-4f5b-ac1e-fe4ba05135a0"],

Cell[BoxData[
 RowBox[{"\[LeftAssociation]", 
  RowBox[{
   RowBox[{"\<\"Paclet\"\>", "\[Rule]", "\<\"Wolfram/QuantumFramework\"\>"}], 
   ",", 
   RowBox[{"\<\"PacletVersion\"\>", "\[Rule]", "\<\"2.0.0\"\>"}], ",", 
   RowBox[{"\<\"PrimaryContext\"\>", 
    "\[Rule]", "\<\"Wolfram`QuantumFramework`\"\>"}], ",", 
   RowBox[{"\<\"GeneratedAt\"\>", "\[Rule]", 
    TemplateBox[{
      RowBox[{"\"Tue 12 May 2026 16:48:10\"", 
        StyleBox[
         RowBox[{"\"GMT\"", "\[InvisibleSpace]", 
           StyleBox[
            RowBox[{"-", "7"}], NumberMarks -> False, StripOnInput -> 
            False]}], "TimeZoneLabel"]}], 
      RowBox[{"DateObject", "[", 
        RowBox[{
          RowBox[{"{", 
            
            RowBox[{"2026", ",", "5", ",", "12", ",", "16", ",", "48", ",", 
              "10.790087`7.785599932826881"}], "}"}], ",", "\"Instant\"", ",",
           "\"Gregorian\"", ",", 
          RowBox[{"-", "7.`"}]}], "]"}]},
     "DateObject",
     Editable->False]}], ",", 
   RowBox[{"\<\"GenerationIssues\"\>", "\[Rule]", 
    RowBox[{"{", "}"}]}]}], "\[RightAssociation]"}]], "Output",
 CellChangeTimes->{3.987618434700119*^9, 3.987618490811708*^9},
 CellLabel->"Out[6]=",
 CellID->1566210200,ExpressionUUID->"a30fa7be-dd2e-4c2b-a6c9-6e9aadd84591"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["\<\
Symbol entries (one per public head) populate the rest of the Association:\
\>", "Text",ExpressionUUID->"f04095e6-4f8a-441c-9933-e1c689182c53"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Keys", "[", 
  RowBox[{"KeyDrop", "[", 
   RowBox[{"graphData", ",", " ", "\"\<$Meta\>\""}], "]"}], "]"}]], "Input",
 CellLabel->"In[7]:=",ExpressionUUID->"38d97f5d-ad03-4231-b3f9-3e8048e9a2f5"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"\<\"QuantumBasis\"\>", ",", "\<\"QuantumChannel\"\>", 
   ",", "\<\"QuantumCircuitOperator\"\>", ",", "\<\"QuantumDistance\"\>", 
   ",", "\<\"QuantumEntangledQ\"\>", 
   ",", "\<\"QuantumEntanglementMonotone\"\>", ",", "\<\"QuantumEvolve\"\>", 
   ",", "\<\"QuantumMeasurement\"\>", 
   ",", "\<\"QuantumMeasurementOperator\"\>", 
   ",", "\<\"QuantumMeasurementSimulation\"\>", 
   ",", "\<\"QuantumOperator\"\>", ",", "\<\"QuantumPartialTrace\"\>", 
   ",", "\<\"QuantumPhaseSpaceTransform\"\>", 
   ",", "\<\"QuantumSimilarity\"\>", ",", "\<\"QuantumState\"\>", 
   ",", "\<\"QuantumStateEstimate\"\>", ",", "\<\"QuantumTensorProduct\"\>", 
   ",", "\<\"QuantumWignerTransform\"\>", ",", "\<\"QuditBasis\"\>", 
   ",", "\<\"QuditName\"\>"}], "}"}]], "Output",
 CellChangeTimes->{3.987618434718544*^9, 3.987618490825378*^9},
 CellLabel->"Out[7]=",
 CellID->1587770121,ExpressionUUID->"0ee30758-aa8a-4fc8-bd94-38286d5b0377"]
}, Open  ]]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["The type taxonomy", "Section",
 CellID->201,ExpressionUUID->"becb79f8-a6ea-4da1-b938-0373af05a390"],

Cell["\<\
Every public head is classified into one of five Kinds. The Kind controls how \
the head fits into the composition picture:\
\>", "Text",ExpressionUUID->"eed916f7-0428-47be-beaf-67bd3ecf2dad"],

Cell[BoxData[GridBox[{
   {
    StyleBox["Kind",
     FontWeight->"Bold"], 
    StyleBox["Meaning",
     FontWeight->"Bold"], 
    StyleBox["Examples",
     FontWeight->"Bold"]},
   {"Constructor", 
    RowBox[{
    "Builds", " ", "an", " ", "object", " ", "of", " ", "its", " ", "own", " ",
      "type", " ", "from", " ", "raw", " ", 
     RowBox[{"data", "."}]}], 
    RowBox[{
    "QuantumState", ",", " ", "QuantumBasis", ",", " ", 
     "QuantumMeasurement"}]},
   {"Operator", 
    RowBox[{
     RowBox[{
     "Object", " ", "that", " ", "also", " ", "acts", " ", "as", " ", "a", " ",
       "function", " ", "on", " ", "a", " ", "target", " ", "object"}], ",", 
     " ", 
     RowBox[{"typically", " ", "returning", " ", "the", " ", "same", " ", 
      RowBox[{"type", "."}]}]}], 
    RowBox[{
    "QuantumOperator", ",", " ", "QuantumChannel", ",", " ", 
     "QuantumCircuitOperator"}]},
   {"Transform", 
    RowBox[{
    "Function", " ", "that", " ", "takes", " ", "one", " ", "object", " ", 
     "and", " ", "returns", " ", "the", " ", "same", " ", "or", " ", "a", " ",
      "related", " ", 
     RowBox[{"type", "."}]}], 
    RowBox[{
    "QuantumPartialTrace", ",", " ", "QuantumTensorProduct", ",", " ", 
     "QuantumWignerTransform"}]},
   {"Predicate", 
    RowBox[{"Function", " ", "returning", " ", "a", " ", "Boolean", " ", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{
        RowBox[{"Symbol", " ", "True"}], " ", "|", " ", "False"}], ")"}], 
      "."}]}], "QuantumEntangledQ"},
   {"Distance", 
    RowBox[{"Function", " ", "returning", " ", "a", " ", "scalar", " ", 
     RowBox[{"(", "Real", ")"}], " ", "from", " ", "two", " ", 
     RowBox[{"states", "."}]}], 
    RowBox[{"QuantumDistance", ",", " ", "QuantumSimilarity"}]}
  },
  BaseStyle->{FontFamily -> "Source Sans Pro"},
  GridBoxDividers->{
   "Columns" -> {True, {False}, True}, "Rows" -> {True, {False}, True}},
  GridBoxSpacings->{"Columns" -> {
      Offset[4.199999999999999], {
       Offset[0.5599999999999999]}, 
      Offset[4.199999999999999]}, "Rows" -> {
      Offset[2.4], {
       Offset[0.4]}, 
      Offset[2.4]}}]], "Text",ExpressionUUID->"4d90a045-9f03-4344-8d46-\
2d5fb9e9232c"],

Cell[CellGroupData[{

Cell["Inspect the Kind distribution across the paclet:", "Text",ExpressionUUID->"73cfdc04-1201-4b2a-91ed-3d39ba2c22af"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"KeyValueMap", "[", 
   RowBox[{
    RowBox[{
     RowBox[{"{", 
      RowBox[{"#1", ",", " ", 
       RowBox[{"#2", "[", "\"\<Kind\>\"", "]"}]}], "}"}], " ", "&"}], ",", 
    " ", 
    RowBox[{"KeyDrop", "[", 
     RowBox[{"graphData", ",", " ", "\"\<$Meta\>\""}], "]"}]}], "]"}], " ", "//",
   " ", "TableForm"}]], "Input",
 CellLabel->"In[8]:=",ExpressionUUID->"f375979f-ae0b-41f0-b936-1d849beecec7"],

Cell[BoxData[
 TagBox[GridBox[{
    {"\<\"QuantumBasis\"\>", "\<\"Constructor\"\>"},
    {"\<\"QuantumChannel\"\>", "\<\"Operator\"\>"},
    {"\<\"QuantumCircuitOperator\"\>", "\<\"Operator\"\>"},
    {"\<\"QuantumDistance\"\>", "\<\"Distance\"\>"},
    {"\<\"QuantumEntangledQ\"\>", "\<\"Predicate\"\>"},
    {"\<\"QuantumEntanglementMonotone\"\>", "\<\"Constructor\"\>"},
    {"\<\"QuantumEvolve\"\>", "\<\"Constructor\"\>"},
    {"\<\"QuantumMeasurement\"\>", "\<\"Constructor\"\>"},
    {"\<\"QuantumMeasurementOperator\"\>", "\<\"Operator\"\>"},
    {"\<\"QuantumMeasurementSimulation\"\>", "\<\"Constructor\"\>"},
    {"\<\"QuantumOperator\"\>", "\<\"Operator\"\>"},
    {"\<\"QuantumPartialTrace\"\>", "\<\"Transform\"\>"},
    {"\<\"QuantumPhaseSpaceTransform\"\>", "\<\"Transform\"\>"},
    {"\<\"QuantumSimilarity\"\>", "\<\"Distance\"\>"},
    {"\<\"QuantumState\"\>", "\<\"Constructor\"\>"},
    {"\<\"QuantumStateEstimate\"\>", "\<\"Constructor\"\>"},
    {"\<\"QuantumTensorProduct\"\>", "\<\"Transform\"\>"},
    {"\<\"QuantumWignerTransform\"\>", "\<\"Transform\"\>"},
