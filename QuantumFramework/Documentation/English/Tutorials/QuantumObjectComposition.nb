Cell[CellGroupData[{

Cell["Rendering the graph", "Section",
 CellID->204,ExpressionUUID->"c81dd8ae-33e2-4b3f-a9b3-5ff79ca5184b"],

Cell[TextData[{
 "Three rendering helpers ship with ",
 StyleBox["Wolfram`PacletFunctionGraph`", "Input",
  FontFamily->"Source Code Pro"],
 ": ",
 StyleBox["PacletFlowEdges", "Input",
  FontFamily->"Source Code Pro"],
 " (the edge primitive), ",
 StyleBox["SymbolNeighborhoodGraph", "Input",
  FontFamily->"Source Code Pro"],
 " (one symbol's flow neighborhood), and ",
 StyleBox["PacletOverviewGraph", "Input",
  FontFamily->"Source Code Pro"],
 " (the whole paclet). All three accept the graph Association and return \
either an edge list or a ",
 Cell[BoxData[
  FormBox["Graph", TraditionalForm]], "InlineFormula",ExpressionUUID->
  "dcd1e9b8-26fe-49d8-8b76-9c259f4b7c5d"],
 "."
}], "Text",ExpressionUUID->"666d144b-eca0-49b4-acae-9953f6850a76"],

Cell[CellGroupData[{

Cell[TextData[{
 "The flow neighborhood of QuantumState: every incoming arrow is a head that \
flows into QuantumState (as constructor input or as the output of an operator \
that produces a state), and every outgoing arrow is a head that consumes a \
QuantumState. The bold black border marks the focal vertex; node color \
encodes ",
 StyleBox["Kind", "Input",
  FontFamily->"Source Code Pro"],
 "."
}], "Text",ExpressionUUID->"e4a1fa58-e618-4ccc-8137-a3a6932f64e6"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"SymbolNeighborhoodGraph", "[", 
  RowBox[{"graphData", ",", " ", "\"\<QuantumState\>\""}], "]"}]], "Input",
 CellLabel->"In[25]:=",ExpressionUUID->"2c704a54-dfd0-4769-8f15-127f3308d8d6"],

