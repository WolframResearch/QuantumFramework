  Function[BoxForm`e$, 
   TableForm[BoxForm`e$]]]], "Output",
 CellChangeTimes->{3.987618434738832*^9, 3.9876184908434057`*^9},
 CellLabel->"Out[8]//TableForm=",
 CellID->1020626025,ExpressionUUID->"e6dfd540-6e0d-4ba6-b1f3-f18b462b3086"]
