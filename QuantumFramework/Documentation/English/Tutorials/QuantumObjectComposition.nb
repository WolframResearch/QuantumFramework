Cell[BoxData[
 RowBox[{"PacletOverviewGraph", "[", "graphData", "]"}]], "Input",
 CellLabel->"In[26]:=",ExpressionUUID->"7659d917-972f-45f9-b06a-8ed7b00f616b"],

Cell[BoxData[
 GraphicsBox[
  NamespaceBox["NetworkGraphics",
   DynamicModuleBox[{Typeset`graph = HoldComplete[
     Graph[{
