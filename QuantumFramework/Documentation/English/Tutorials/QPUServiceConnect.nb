Cell[CellGroupData[{

Cell["\<\
Select one on-demand simulator (Amazon's state-vector simulator SV1) and one \
QPU by their Amazon Resource Names (ARNs), decoding each device's \
capabilities from JSON:\
\>", "Text",ExpressionUUID->"9dc42c7f-d8e2-4a31-85a1-0a2192ce6a58"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"sim", " ", "=", " ", 
   RowBox[{"devices", "[", "\n", "    ", 
    RowBox[{
     RowBox[{"SelectFirst", "[", 
      RowBox[{
       RowBox[{
       "#DeviceArn", " ", "==", 
        " ", "\"\<arn:aws:braket:::device/quantum-simulator/amazon/sv1\>\""}],
        " ", "&"}], "]"}], ",", "\n", "    ", 
     RowBox[{"MapAt", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"ImportString", "[", 
         RowBox[{"#", ",", " ", "\"\<RawJSON\>\""}], "]"}], " ", "&"}], ",", 
       " ", "\"\<DeviceCapabilities\>\""}], "]"}]}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"qpu", " ", "=", " ", 
   RowBox[{"devices", "[", "\n", "    ", 
    RowBox[{
     RowBox[{"SelectFirst", "[", 
      RowBox[{
       RowBox[{"StringContainsQ", "[", 
        RowBox[{"#DeviceArn", ",", " ", "\"\<ionq\>\""}], "]"}], " ", "&"}], 
      "]"}], ",", "\n", "    ", 
     RowBox[{"MapAt", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"ImportString", "[", 
         RowBox[{"#", ",", " ", "\"\<RawJSON\>\""}], "]"}], " ", "&"}], ",", 
       " ", "\"\<DeviceCapabilities\>\""}], "]"}]}], "]"}]}], ";"}]}], "Input",\
ExpressionUUID->"fc06c718-3dd2-4d02-93cb-431ec894cc84"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["Preparing the circuit as OpenQASM", "Subsection",ExpressionUUID->"c5e59d3a-a29b-478c-be35-339a2be5f092"],

Cell[CellGroupData[{

Cell[TextData[{
 "Build the circuit, then express it as OpenQASM for submission. Braket \
accepts OpenQASM, so the native ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["QuantumQASM"]], 
    "paclet:Wolfram/QuantumFramework/ref/QuantumQASM", 
    "Wolfram/QuantumFramework Package Symbol"},
   "PackageLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",ExpressionUUID->
  "ef962fb5-9b0e-4b62-9565-ac57d3a04e3b"],
 " output is a good way to inspect exactly what will be sent:"
}], "Text",ExpressionUUID->"fb1e9245-9431-4edb-a22a-fa1ebeae2f1c"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"qc", " ", "=", " ", 
   RowBox[{"QuantumCircuitOperator", "[", 
    RowBox[{"{", 
     RowBox[{"\"\<GHZ\>\"", ",", " ", 
      RowBox[{"\"\<Fourier\>\"", "[", "3", "]"}], ",", " ", 
      RowBox[{"{", 
       RowBox[{"1", ",", " ", "2", ",", " ", "3"}], "}"}]}], "}"}], "]"}]}], 
  ";"}], "\n", 
 RowBox[{"QuantumQASM", "[", "qc", "]"}]}], "Input",
 CellLabel->"In[7]:= ",ExpressionUUID->"61167494-a6b1-479a-80ca-d9926020358d"],

Cell[BoxData["\<\"OPENQASM 3.0;\\nqubit[3] q;\\nbit[3] \
c;\\nU(1.5707963267948966, 0., 3.141592653589793) q[0];\\nctrl(1) @ \
negctrl(0) @ U(3.141592653589793, 0., 3.141592653589793) q[0] q[1];\\nctrl(1) \
@ negctrl(0) @ U(3.141592653589793, 0., 3.141592653589793) q[1] \
q[2];\\nU(1.5707963267948966, 0., 3.141592653589793) q[0];\\nctrl(1) @ \
negctrl(0) @ U(0., 0., 1.5707963267948966) q[1] q[0];\\nctrl(1) @ negctrl(0) \
@ U(0., 0., 0.7853981633974483) q[2] q[0];\\nU(1.5707963267948966, 0., \
3.141592653589793) q[1];\\nctrl(1) @ negctrl(0) @ U(0., 0., \
1.5707963267948966) q[2] q[1];\\nU(1.5707963267948966, 0., 3.141592653589793) \
q[2];\\nswap q[0] q[2];\\nc[0] = measure q[0];\\nc[1] = measure q[1];\\nc[2] \
= measure q[2];\"\>"], "Output",
 CellLabel->"Out[7]= ",ExpressionUUID->"df7215cc-bd7c-43b2-875a-56d28cd27e3f"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell[TextData[{
 "For submission to a specific Braket backend it is safest to render the \
device dialect of OpenQASM, which maps the circuit onto that vendor's \
supported gate set. Passing ",
 Cell[BoxData[
  RowBox[{"\"\<Provider\>\"", " ", "->", " ", "\"\<AWSBraket\>\""}]], 
  "InlineFormula",ExpressionUUID->"e4ff330c-ee2d-47a9-b6fb-e1842e9dcd63"],
 " to the Qiskit interface does this conversion (it needs the Python Qiskit \
and Braket providers configured):"
}], "Text",ExpressionUUID->"3df631c9-4912-4b28-91c1-79f4f419ab34"],

Cell[BoxData[
 RowBox[{
  RowBox[{"qasm", " ", "=", " ", 
   RowBox[{
    RowBox[{"qc", "[", "\"\<Qiskit\>\"", "]"}], "[", 
    RowBox[{"\"\<QASM\>\"", ",", " ", 
     RowBox[{"\"\<Provider\>\"", " ", "->", " ", "\"\<AWSBraket\>\""}]}], 
    "]"}]}], ";"}]], "Input",ExpressionUUID->"0089a8dd-a452-4a73-8eff-\
a0c0e4ee02f0"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["Submitting a quantum task", "Subsection",ExpressionUUID->"c27c29cd-2d41-418a-a68e-fbe57d2a06ea"],

Cell[CellGroupData[{

Cell["\<\
A Braket job is a \"quantum task\". Submit the OpenQASM as the task action, \
naming the device ARN, the destination S3 bucket and the number of shots. Run \
it once on the simulator:\
\>", "Text",ExpressionUUID->"3f298ced-10bb-48ae-b986-abd70265110d"],

Cell[BoxData[
 RowBox[{"taskSV1", " ", "=", " ", 
  RowBox[{"braket", "[", 
   RowBox[{"\"\<CreateQuantumTask\>\"", ",", "\n", "    ", 
    RowBox[{"\"\<DeviceArn\>\"", " ", "->", " ", 
     RowBox[{"sim", "[", "\"\<DeviceArn\>\"", "]"}]}], ",", "\n", "    ", 
    RowBox[{"\"\<Shots\>\"", " ", "->", " ", "100"}], ",", "\n", "    ", 
    RowBox[{"\"\<Action\>\"", " ", "->", " ", 
     RowBox[{"<|", 
      RowBox[{
       RowBox[{"braketSchemaHeader", " ", "->", " ", 
        RowBox[{"<|", 
         RowBox[{
          RowBox[{
          "name", " ", "->", " ", "\"\<braket.ir.openqasm.program\>\""}], ",",
           " ", 
          RowBox[{"version", " ", "->", " ", "\"\<1\>\""}]}], "|>"}]}], ",", 
       " ", 
       RowBox[{"source", " ", "->", " ", "qasm"}]}], "|>"}]}], ",", "\n", 
    "    ", 
    RowBox[{"\"\<OutputS3Bucket\>\"", " ", "->", 
     " ", "\"\<amazon-braket-my-bucket\>\""}], ",", " ", 
    RowBox[{"\"\<OutputS3KeyPrefix\>\"", " ", "->", " ", "\"\<tasks\>\""}], ",",
     "\n", "    ", 
    RowBox[{"\"\<RequestRegion\>\"", " ", "->", " ", "\"\<us-east-1\>\""}]}], 
   "]"}]}]], "Input",ExpressionUUID->"263eeb19-d47f-49b2-a36b-94ff91c15988"]
}, Open  ]],

Cell[CellGroupData[{

Cell["The same call against the QPU ARN queues a hardware run:", "Text",ExpressionUUID->"ef4f6200-5e31-4333-a766-12922a208acf"],

Cell[BoxData[
 RowBox[{"taskIonQ", " ", "=", " ", 
  RowBox[{"braket", "[", 
   RowBox[{"\"\<CreateQuantumTask\>\"", ",", "\n", "    ", 
    RowBox[{"\"\<DeviceArn\>\"", " ", "->", " ", 
     RowBox[{"qpu", "[", "\"\<DeviceArn\>\"", "]"}]}], ",", "\n", "    ", 
    RowBox[{"\"\<Shots\>\"", " ", "->", " ", "100"}], ",", "\n", "    ", 
    RowBox[{"\"\<Action\>\"", " ", "->", " ", 
     RowBox[{"<|", 
      RowBox[{
       RowBox[{"braketSchemaHeader", " ", "->", " ", 
        RowBox[{"<|", 
         RowBox[{
          RowBox[{
          "name", " ", "->", " ", "\"\<braket.ir.openqasm.program\>\""}], ",",
           " ", 
          RowBox[{"version", " ", "->", " ", "\"\<1\>\""}]}], "|>"}]}], ",", 
       " ", 
       RowBox[{"source", " ", "->", " ", "qasm"}]}], "|>"}]}], ",", "\n", 
    "    ", 
    RowBox[{"\"\<OutputS3Bucket\>\"", " ", "->", 
     " ", "\"\<amazon-braket-my-bucket\>\""}], ",", " ", 
    RowBox[{"\"\<OutputS3KeyPrefix\>\"", " ", "->", " ", "\"\<tasks\>\""}], ",",
     "\n", "    ", 
    RowBox[{"\"\<RequestRegion\>\"", " ", "->", " ", "\"\<us-east-1\>\""}]}], 
   "]"}]}]], "Input",ExpressionUUID->"24e92df3-5e90-4340-a5b7-b9b19e29870f"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["Checking status and fetching results", "Subsection",ExpressionUUID->"c3bb2cb5-a053-44e9-9668-6c3322ee9c6e"],

Cell[CellGroupData[{

Cell[TextData[{
 "Query a task by its ARN. The simulator usually completes in seconds; a QPU \
task may sit ",
 Cell[BoxData[
 "QUEUED"], "InlineFormula",ExpressionUUID->
  "deb162d0-95f3-4b29-b369-a7441c87a7cd"],
 " until the device is available:"
}], "Text",ExpressionUUID->"1599ebdd-0d4f-46cc-9378-a67c4e301d77"],

Cell[BoxData[
 RowBox[{
  RowBox[{"braket", "[", 
   RowBox[{"\"\<GetQuantumTask\>\"", ",", " ", 
    RowBox[{"\"\<QuantumTaskArn\>\"", " ", "->", " ", 
     RowBox[{"taskSV1", "[", "\"\<quantumTaskArn\>\"", "]"}]}], ",", " ", 
    RowBox[{"\"\<RequestRegion\>\"", " ", "->", " ", "\"\<us-east-1\>\""}]}], 
   "]"}], "[", "\"\<status\>\"", "]"}]], "Input",ExpressionUUID->"739f5fd6-\
eb0f-4c56-8a87-316d492bb4df"]
}, Open  ]],

Cell[CellGroupData[{

Cell[TextData[{
 "The result is written to S3. Locate its directory, then read ",
 Cell["results.json", "InlineCode",ExpressionUUID->
  "ae0bdfdc-50f8-4431-be63-13b200c3e95a"],
 " from the bucket:"
}], "Text",ExpressionUUID->"d0474201-c58e-4ec7-9a94-614768fc8682"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"outputPath", " ", "=", " ", 
   RowBox[{
    RowBox[{"braket", "[", 
     RowBox[{"\"\<GetQuantumTask\>\"", ",", "\n", "    ", 
      RowBox[{"\"\<QuantumTaskArn\>\"", " ", "->", " ", 
       RowBox[{"taskSV1", "[", "\"\<quantumTaskArn\>\"", "]"}]}], ",", " ", 
      RowBox[{"\"\<RequestRegion\>\"", " ", "->", 
       " ", "\"\<us-east-1\>\""}]}], "]"}], "[", "\"\<outputS3Directory\>\"", 
    "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"results", " ", "=", " ", 
   RowBox[{"ImportByteArray", "[", "\n", "    ", 
    RowBox[{
     RowBox[{
      RowBox[{"s3", "[", 
       RowBox[{"\"\<GetObject\>\"", ",", " ", 
        RowBox[{"\"\<Bucket\>\"", " ", "->", 
         " ", "\"\<amazon-braket-my-bucket\>\""}], ",", "\n", "        ", 
        RowBox[{"\"\<Key\>\"", " ", "->", " ", 
         RowBox[{"FileNameJoin", "[", 
          RowBox[{"{", 
           RowBox[{"outputPath", ",", " ", "\"\<results.json\>\""}], "}"}], 
          "]"}]}], ",", " ", 
        RowBox[{"\"\<RequestRegion\>\"", " ", "->", 
         " ", "\"\<us-east-1\>\""}]}], "]"}], "[", "\"\<Body\>\"", "]"}], ",",
      "\n", "    ", "\"\<RawJSON\>\""}], "]"}]}], ";"}]}], "Input",ExpressionU\
UID->"2e70adcd-eb52-4807-a3dc-cc9dfa91dbe5"]
}, Open  ]],

Cell[TextData[{
 "The exact shape depends on the device: SV1 returns per-shot readouts under ",
 Cell[BoxData["\"\<measurements\>\""], "InlineFormula",ExpressionUUID->
  "f9108b3a-b856-4ae3-a0da-348a88b9d499"],
 ", while IonQ returns aggregated ",
 Cell[BoxData["\"\<measurementProbabilities\>\""], "InlineFormula",
  ExpressionUUID->"adde98c3-cc7b-4ed9-8f6d-fa96442536b7"],
 ". Either way you reduce to a probability over the eight basis states."
}], "Text",ExpressionUUID->"3ad70fd9-c470-4e32-9601-d6ccde05d604"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Comparing exact and simulator results", "Subsection",ExpressionUUID->"7b8e6b57-e94d-48cc-88b3-0df87f778eeb"],

Cell[CellGroupData[{

Cell[TextData[{
 "SV1 is a noiseless state-vector simulator, so its finite-shot output is a \
sample from the exact distribution, exactly what ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["QuantumMeasurement"]], 
    "paclet:Wolfram/QuantumFramework/ref/QuantumMeasurement", 
    "Wolfram/QuantumFramework Package Symbol"},
   "PackageLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",ExpressionUUID->
  "81edbcc1-9d32-4e62-a90b-8554f061f62e"],
 "'s own sampler produces. Comparing the exact probabilities with a 100-shot \
sample shows the sampling spread you should expect before any device noise \
enters:"
}], "Text",ExpressionUUID->"a6112183-d5e3-4c42-a2fd-9f993c502ac1"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"qc", " ", "=", " ", 
   RowBox[{"QuantumCircuitOperator", "[", 
    RowBox[{"{", 
     RowBox[{"\"\<GHZ\>\"", ",", " ", 
      RowBox[{"\"\<Fourier\>\"", "[", "3", "]"}], ",", " ", 
      RowBox[{"{", 
       RowBox[{"1", ",", " ", "2", ",", " ", "3"}], "}"}]}], "}"}], "]"}]}], 
  ";"}], "\n", 
 RowBox[{
  RowBox[{"exact", " ", "=", " ", 
   RowBox[{"N", "[", 
    RowBox[{
     RowBox[{"qc", "[", "]"}], "[", "\"\<ProbabilitiesList\>\"", "]"}], 
    "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"ordered", " ", "=", " ", 
   RowBox[{"Keys", "[", 
    RowBox[{"KeySort", "[", 
     RowBox[{
      RowBox[{"qc", "[", "]"}], "[", "\"\<Probabilities\>\"", "]"}], "]"}], 
    "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"SeedRandom", "[", "42", "]"}], ";"}], "\n", 
 RowBox[{
  RowBox[{"counts", " ", "=", " ", 
   RowBox[{"Counts", "[", 
    RowBox[{
     RowBox[{"qc", "[", "]"}], "[", 
     RowBox[{"\"\<SimulatedMeasurement\>\"", ",", " ", "100"}], "]"}], 
    "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"sv1", " ", "=", " ", 
   RowBox[{
    RowBox[{"N", "[", 
     RowBox[{"Lookup", "[", 
      RowBox[{"counts", ",", " ", "ordered", ",", " ", "0"}], "]"}], "]"}], "/",
     "100"}]}], ";"}], "\n", 
 RowBox[{"BarChart", "[", 
  RowBox[{
   RowBox[{"Transpose", "[", 
    RowBox[{"{", 
     RowBox[{"exact", ",", " ", "sv1"}], "}"}], "]"}], ",", "\n", "    ", 
   RowBox[{"ChartLegends", " ", "->", " ", 
    RowBox[{"{", 
     RowBox[{"\"\<Exact WL\>\"", ",", " ", "\"\<SV1 (100 shots)\>\""}], 
     "}"}]}], ",", "\n", "    ", 
   RowBox[{"ChartLabels", " ", "->", " ", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"Tuples", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"0", ",", " ", "1"}], "}"}], ",", " ", "3"}], "]"}], ",", 
      " ", "None"}], "}"}]}], ",", "\n", "    ", 
   RowBox[{"Frame", " ", "->", " ", "True"}], ",", " ", 
   RowBox[{"AspectRatio", " ", "->", " ", 
    RowBox[{"1", "/", "2"}]}]}], "]"}]}], "Input",
 CellLabel->"In[8]:= ",ExpressionUUID->"2ba60b0e-ef43-495d-bf4d-d7dcd7546b6b"],

