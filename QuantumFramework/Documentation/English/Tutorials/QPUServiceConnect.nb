      " ", "None"}], "}"}]}], ",", "\n", "    ", 
   RowBox[{"Frame", " ", "->", " ", "True"}], ",", " ", 
   RowBox[{"AspectRatio", " ", "->", " ", 
    RowBox[{"1", "/", "2"}]}]}], "]"}]}], "Input",
 CellLabel->"In[6]:= ",ExpressionUUID->"8462e8a9-80bb-49c9-93a8-c05cf9f0e89a"],

