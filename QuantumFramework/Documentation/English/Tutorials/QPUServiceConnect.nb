Notebook[{

Cell[CellGroupData[{
Cell["Connecting to QPU Services", "Title",
 CellID->509267359,ExpressionUUID->"4ddb5767-1f00-4973-a411-49eacd07850d"],

Cell[TextData[{
 "The ",
 ButtonBox["Wolfram Quantum Framework",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://www.wolfram.com/quantum-computation-framework/"], None}],
 " lets you build, simulate and analyze quantum circuits symbolically and \
numerically. The same circuit object can also be sent to real quantum \
processing units (QPUs) hosted in the cloud. This tutorial covers the three \
pieces you need for that: ",
 ButtonBox["OpenQASM",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://openqasm.com/"], None}],
 ", the portable text format that QPUs speak; the ",
 ButtonBox["IBM Quantum",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://www.ibm.com/quantum"], None}],
 " platform; and ",
 ButtonBox["Amazon Braket",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://aws.amazon.com/braket/"], None}],
 ", which exposes several hardware vendors through a single service."
}], "Text",ExpressionUUID->"7aa0c9ef-f91d-4abe-a800-373fecda29df"],

Cell[CellGroupData[{

Cell["\<\
Everything in the OpenQASM section runs locally with no account. The hardware \
sections need credentials with the respective provider, and those cells are \
marked so you can read the tutorial without running them. For help, write to \
quantum@wolfram.com.\
\>", "Text",ExpressionUUID->"1bf33cb7-ce58-4615-8e6b-bc3b090f316b"],

Cell[BoxData[
 RowBox[{"<<", " ", "Wolfram`QuantumFramework`"}]], "Input",
 CellLabel->"In[1]:= ",ExpressionUUID->"0d60a419-f640-4542-8e00-f9f17c8b0c58"]
}, Open  ]],

Cell[CellGroupData[{

Cell["OpenQASM: the common language of QPUs", "Section",ExpressionUUID->"d1b7ebd6-4131-4f69-97a9-ea6c114dfb41"],

Cell[TextData[{
 "A quantum circuit built in the Wolfram Language is a symbolic object. To \
run it on hardware it has to be expressed in a format the device understands, \
and the de facto standard is OpenQASM. Both IBM and Amazon Braket accept \
OpenQASM, so it is the bridge between a ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["QuantumCircuitOperator"]], 
    "paclet:Wolfram/QuantumFramework/ref/QuantumCircuitOperator", 
    "Wolfram/QuantumFramework Package Symbol"},
   "PackageLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",ExpressionUUID->
  "c28ac16c-fe02-4e77-9a0c-a4a437f8f5f5"],
 " and the cloud."
}], "Text",ExpressionUUID->"c97d8eb4-402e-4060-93c5-68eb88b44039"],

Cell[CellGroupData[{

Cell[TextData[{
 "Build a small reference circuit that we reuse throughout: a three-qubit GHZ \
state ",
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     StyleBox["GHZ", FontSlant -> "Plain"]},
    "Ket"], "=", 
   RowBox[{
    FractionBox["1", 
     SqrtBox["2"]], 
    RowBox[{"(", 
     RowBox[{
      TemplateBox[{"000"},
       "Ket"], "+", 
      TemplateBox[{"111"},
       "Ket"]}], ")"}]}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "4543c815-89f4-4d1d-a751-7e0ce86aab67"],
 ", followed by a quantum Fourier transform and a measurement of all three \
qubits."
}], "Text",ExpressionUUID->"d328f496-412c-439c-b8be-d379a07fa170"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"qc", " ", "=", " ", 
   RowBox[{"QuantumCircuitOperator", "[", 
    RowBox[{"{", 
     RowBox[{"\"\<GHZ\>\"", ",", " ", 
      RowBox[{"\"\<Fourier\>\"", "[", "3", "]"}], ",", " ", 
      RowBox[{"{", 
       RowBox[{"1", ",", " ", "2", ",", " ", "3"}], "}"}]}], "}"}], "]"}]}], 
  ";"}], "\n", 
 RowBox[{"qc", "[", "\"\<Diagram\>\"", "]"}]}], "Input",
 CellLabel->"In[2]:= ",ExpressionUUID->"1a849a27-b959-4261-9069-cec2963f56cb"],

