Cell[CellGroupData[{

Cell[TextData[{
 "Before spending QPU time, you can sample the circuit on a local noiseless \
simulator. ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["QuantumCircuitOperator"]], 
    "paclet:Wolfram/QuantumFramework/ref/QuantumCircuitOperator", 
    "Wolfram/QuantumFramework Package Symbol"},
   "PackageLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",ExpressionUUID->
  "f29784d0-1c7b-4dc4-990c-f3d08c9b7f07"],
 "'s ",
 Cell[BoxData["\"\<Qiskit\>\""], "InlineFormula",ExpressionUUID->
  "5acfb7ab-b446-48b5-8526-d559c0dd97f6"],
 " interface runs through a local Qiskit Aer simulator when no provider is \
given, returning a ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["QuantumMeasurement"]], 
    "paclet:Wolfram/QuantumFramework/ref/QuantumMeasurement", 
    "Wolfram/QuantumFramework Package Symbol"},
   "PackageLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",ExpressionUUID->
  "4f0d3c2d-310e-438c-a4a8-800a7b6c9891"],
 " whose statistics converge to the exact distribution as the shot count \
grows (this needs the Python Qiskit stack):"
}], "Text",ExpressionUUID->"a3341619-aa4d-4a46-a1ff-eadab360d289"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"qc", "[", "\"\<Qiskit\>\"", "]"}], "[", 
   RowBox[{"\"\<Shots\>\"", " ", "->", " ", "4096"}], "]"}], 
  "[", "\"\<ProbabilityPlot\>\"", "]"}]], "Input",ExpressionUUID->"a8f80077-\
cc71-47d9-982f-3b3d7dedb716"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["Running on hardware", "Subsection",ExpressionUUID->"7fdece1f-5dad-4ae9-85b1-57e99865d621"],

Cell[CellGroupData[{

Cell[TextData[{
 "With an active connection, ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["IBMJobSubmit"]], 
    "paclet:Wolfram/QuantumFramework/ref/IBMJobSubmit", 
    "Wolfram/QuantumFramework Package Symbol"},
   "PackageLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",ExpressionUUID->
  "d1bee210-fd00-4c7f-8bc6-c299e5c4245d"],
 " is the one call that runs a circuit on a QPU. It transpiles the circuit \
against the backend's own error-aware ",
 Cell[BoxData[
 "Target"], "InlineFormula",ExpressionUUID->
  "c5e3f2b8-952c-4f32-8cce-082643edc810"],
 " (per-instruction error and duration), submits it through the ",
 Cell[BoxData[
 "SamplerV2"], "InlineFormula",ExpressionUUID->
  "39139b70-e9e2-40e7-b8f4-645869a46653"],
 " primitive, and returns immediately with an asynchronous ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["IBMJob"]], "paclet:Wolfram/QuantumFramework/ref/IBMJob", 
    "Wolfram/QuantumFramework Package Symbol"},
   "PackageLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",ExpressionUUID->
  "52862c36-b703-494d-b80e-70606312b808"],
 " handle while the job sits in the queue. There is no manual OpenQASM, no \
raw request and no hex decoding of the classical register: the handle carries \
the per-bit to qubit map captured at transpile time, so results come back \
already in the Wolfram Language qubit order."
}], "Text",ExpressionUUID->"1a54d318-9b4b-4c11-abf0-c9179d915a54"],

Cell[BoxData[
 RowBox[{"job", " ", "=", " ", 
  RowBox[{"IBMJobSubmit", "[", 
   RowBox[{"qc", ",", " ", "\"\<ibm_fez\>\""}], "]"}]}]], "Input",ExpressionUU\
ID->"2ac139e8-9752-46bf-b211-6d88acdc65bb"]
}, Open  ]],

Cell[CellGroupData[{

Cell[TextData[{
 "The handle reports the job's status. Poll it while the job is queued, or \
pass ",
 Cell[BoxData[
  RowBox[{"\"\<Wait\>\"", " ", "->", " ", "True"}]], "InlineFormula",
  ExpressionUUID->"9dcdda40-f499-48ec-a92a-c61fe364447e"],
 " to ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["IBMJobSubmit"]], 
    "paclet:Wolfram/QuantumFramework/ref/IBMJobSubmit", 
    "Wolfram/QuantumFramework Package Symbol"},
   "PackageLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",ExpressionUUID->
  "5d8ba89d-0de2-4116-bd76-1d0e3cd7c5d7"],
 " to block until the job reaches a terminal status:"
}], "Text",ExpressionUUID->"ad832343-47a2-4f1e-a13e-d1071b7fa970"],

Cell[BoxData[
 RowBox[{"job", "[", "\"\<Status\>\"", "]"}]], "Input",ExpressionUUID->"b618bc21-ee87-4003-9b47-63c7e7730f69"]
}, Open  ]],

Cell[CellGroupData[{

Cell[TextData[{
 "Refresh the handle to pull a fresh snapshot from the service. Once the \
status is ",
 Cell[BoxData["\"\<Completed\>\""], "InlineFormula",ExpressionUUID->
  "a38096af-78c4-4766-99a2-d967c1ab8ced"],
 ", applying the handle returns the measurement reconstructed from the \
hardware counts, in the Wolfram Language qubit order:"
}], "Text",ExpressionUUID->"e7222b0f-34d8-4812-a288-27cfd3611876"],

Cell[BoxData[
 RowBox[{"qpu", " ", "=", " ", 
  RowBox[{
   RowBox[{"job", "[", "\"\<Refresh\>\"", "]"}], "[", "]"}]}]], "Input",Expres\
sionUUID->"2ebec00b-feda-4a9a-aac8-3f3f99aaedf0"]
}, Open  ]],

Cell[CellGroupData[{

Cell[TextData[{
 "The same handle keeps every response IBM returns under ",
 Cell[BoxData["\"\<Raw\>\""], "InlineFormula",ExpressionUUID->
  "99f4cd33-1829-4bd2-b8c0-fc452e929a0a"],
 " and exposes curated accessors on top, so the run's metadata is one query \
away. For example, the billed quantum runtime:"
}], "Text",ExpressionUUID->"138e023c-5001-41bc-8709-67d5c1ac9137"],

Cell[BoxData[
 RowBox[{"job", "[", "\"\<QuantumSeconds\>\"", "]"}]], "Input",ExpressionUUID->"51bb8aac-bdb6-41f3-99da-13e1c02d6908"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["Comparing exact and hardware results", "Subsection",ExpressionUUID->"31aeb50d-f951-4259-b496-d6a776a368b7"],

Cell[CellGroupData[{

Cell[TextData[{
 "Putting the exact distribution next to the hardware run shows the structure \
surviving the device noise: the dominant ",
 Cell[BoxData[
 "000"], "InlineFormula",ExpressionUUID->
  "1a8efcf7-bf22-48b3-8a17-64c1d1891e6b"],
 ", ",
 Cell[BoxData[
 "001"], "InlineFormula",ExpressionUUID->
  "e46deae3-8c4f-458b-a619-460565885a4f"],
 " and ",
 Cell[BoxData[
 "111"], "InlineFormula",ExpressionUUID->
  "d0799abe-7a02-4536-a42f-90363848e4d3"],
 " outcomes and the near-zero ",
 Cell[BoxData[
 "100"], "InlineFormula",ExpressionUUID->
  "5be672fc-94c0-4fee-ab7a-d328752c05f7"],
 " all come through, with the noise flattening the distribution. The hardware \
values below are ",
 Cell[BoxData[
  RowBox[{"qpu", "[", "\"\<Probabilities\>\"", "]"}]], "InlineFormula",
  ExpressionUUID->"8e0a2550-b3f9-4e6b-aaf3-c0e7f3048b43"],
 " from a recorded ",
 Cell[BoxData[
 "ibm_fez"], "InlineFormula",ExpressionUUID->
  "9beb719f-5792-4337-a451-230b99269c71"],
 " run:"
}], "Text",ExpressionUUID->"9221dcc2-56d6-4aca-9630-bdb66edccd43"],

Cell[CellGroupData[{

