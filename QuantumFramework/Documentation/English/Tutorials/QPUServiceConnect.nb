Cell[CellGroupData[{

Cell[TextData[{
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["QuantumQASM"]], 
    "paclet:Wolfram/QuantumFramework/ref/QuantumQASM", 
    "Wolfram/QuantumFramework Package Symbol"},
   "PackageLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",ExpressionUUID->
  "bad0161a-0bf1-45e2-ae04-b124d37995ac"],
 " is the single hub for OpenQASM. Called on a circuit with no extra \
arguments it emits OpenQASM ",
 StyleBox["3.0",
  FontWeight->"Bold"],
 " natively, in pure Wolfram Language with no external dependency, \
serializing the circuit exactly as built. Measurements become classical-bit \
assignments:"
}], "Text",ExpressionUUID->"0efbb84c-074f-4dff-b2b5-dc568a79daf4"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"QuantumQASM", "[", "qc", "]"}]], "Input",
 CellLabel->"In[3]:= ",ExpressionUUID->"63cf4f76-6caf-47ee-af6a-563bd1148465"],

Cell[BoxData["\<\"OPENQASM 3.0;\\nqubit[3] q;\\nbit[3] \
c;\\nU(1.5707963267948966, 0., 3.141592653589793) q[0];\\nctrl(1) @ \
negctrl(0) @ U(3.141592653589793, 0., 3.141592653589793) q[0] q[1];\\nctrl(1) \
@ negctrl(0) @ U(3.141592653589793, 0., 3.141592653589793) q[1] \
q[2];\\nU(1.5707963267948966, 0., 3.141592653589793) q[0];\\nctrl(1) @ \
negctrl(0) @ U(0., 0., 1.5707963267948966) q[1] q[0];\\nctrl(1) @ negctrl(0) \
@ U(0., 0., 0.7853981633974483) q[2] q[0];\\nU(1.5707963267948966, 0., \
3.141592653589793) q[1];\\nctrl(1) @ negctrl(0) @ U(0., 0., \
1.5707963267948966) q[2] q[1];\\nU(1.5707963267948966, 0., 3.141592653589793) \
q[2];\\nswap q[0] q[2];\\nc[0] = measure q[0];\\nc[1] = measure q[1];\\nc[2] \
= measure q[2];\"\>"], "Output",
 CellLabel->"Out[3]= ",ExpressionUUID->"545cdfc2-8935-4a7a-b6af-a11f91ea439d"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell[TextData[{
 "The hub is also an importer: handing OpenQASM source (or a ",
 Cell[".qasm", "InlineCode",ExpressionUUID->
  "b416579e-1233-4cb0-a7fa-679510f85326"],
 " file) back to ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["QuantumCircuitOperator"]], 
    "paclet:Wolfram/QuantumFramework/ref/QuantumCircuitOperator", 
    "Wolfram/QuantumFramework Package Symbol"},
   "PackageLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",ExpressionUUID->
  "47411d3a-6551-4e56-a524-8f11223a6854"],
 " reconstructs the circuit, again with no external dependency. The round \
trip recovers a circuit equal to the original:"
}], "Text",ExpressionUUID->"bb71df91-be39-4a61-8ccc-9d6c5714d03d"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"QuantumCircuitOperator", "[", 
   RowBox[{"QuantumQASM", "[", "qc", "]"}], "]"}], " ", "==", " ", 
  "qc"}]], "Input",
 CellLabel->"In[4]:= ",ExpressionUUID->"170b7c41-6473-4911-a841-8f1a24a1f9d5"],

Cell[BoxData["True"], "Output",
 CellLabel->"Out[4]= ",ExpressionUUID->"bfa70768-2bed-4de6-b0d2-35e5696a4723"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell[TextData[{
 "OpenQASM 3.0 is the native and recommended target. For older toolchains \
that still require the legacy ",
 Cell["qelib1.inc", "InlineCode",ExpressionUUID->
  "1b3cc548-2dc6-455b-addf-d9a0ee2ff445"],
 " gate set, pass ",
 Cell[BoxData[
  RowBox[{"\"\<Version\>\"", " ", "->", " ", "2"}]], "InlineFormula",
  ExpressionUUID->"01c61fb1-f786-4757-b26c-8bec83b81166"],
 " to emit OpenQASM 2.0. This path renders through Qiskit, so it needs the \
Python Qiskit stack configured:"
}], "Text",ExpressionUUID->"c7916e70-de85-46bb-9524-b625df9af4d3"],

Cell[BoxData[
 RowBox[{"QuantumQASM", "[", 
  RowBox[{"qc", ",", " ", 
   RowBox[{"\"\<Version\>\"", " ", "->", " ", "2"}]}], "]"}]], "Input",Express\
ionUUID->"418ff37c-c917-4714-9662-3f3a09415119"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["IBM Quantum", "Section",ExpressionUUID->"59cda1be-eeaa-4252-8343-6d68ad318236"],

Cell[CellGroupData[{

Cell["Connecting to the IBM Quantum Platform", "Subsection",ExpressionUUID->"ba396e3f-9dea-4677-bfd6-1df1ddf63f83"],

Cell[TextData[{
 "Create an account at ",
 ButtonBox["quantum.cloud.ibm.com",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://quantum.cloud.ibm.com/"], None}],
 ". From the dashboard you need two things: an ",
 StyleBox["IAM API key",
  FontWeight->"Bold"],
 " (the long secret string shown once when you create the key, not the key's \
display name) and the ",
 StyleBox["instance CRN",
  FontWeight->"Bold"],
 " (a ",
 Cell[BoxData[
  RowBox[{"crn", ":", "v1", ":", "\[Ellipsis]"}]], "InlineFormula",
  ExpressionUUID->"f95032b1-d4b0-4876-ad3c-250fbe6e6294"],
 " string identifying your instance)."
}], "Text",ExpressionUUID->"e5e944f3-7968-4b82-8d55-f5e230a88a2e"],

Cell[CellGroupData[{

Cell["\<\
The API key is a secret and is stored in your encrypted system credential \
store. The CRN is read from a local symbol that the connection consults when \
it builds the request headers, so set both before connecting:\
\>", "Text",ExpressionUUID->"6b9ee3e8-b39b-4758-b05c-0eba2904cf41"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"api", " ", "=", " ", "\"\<XXX\>\""}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"LocalSymbol", "[", "\"\<ibm_crn\>\"", "]"}], " ", "=", 
   " ", "\"\<XXX\>\""}], ";"}]}], "Input",ExpressionUUID->"3cf33881-4b72-4d9f-\
9663-9c2a6d253384"]
}, Open  ]],

Cell[CellGroupData[{

Cell[TextData[{
 "Loading the Wolfram Quantum Framework registers the IBM Quantum Platform \
service automatically, so ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["ServiceConnect"]], "paclet:ref/ServiceConnect"},
   "RefLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",ExpressionUUID->
  "179d101a-362c-4c66-9c76-b46b6a9d1355"],
 " recognizes the ",
 Cell[BoxData["\"\<IBMQuantumPlatform\>\""], "InlineFormula",ExpressionUUID->
  "eea3eac3-824e-4959-bec5-6c9f83be38d2"],
 " name directly:"
}], "Text",ExpressionUUID->"ad170ce2-6db0-467c-900c-877b57cbab8a"],

Cell[BoxData[
 RowBox[{"ibm", " ", "=", " ", 
  RowBox[{"ServiceConnect", "[", 
   RowBox[{"\"\<IBMQuantumPlatform\>\"", ",", " ", "\"\<New\>\"", ",", " ", 
    RowBox[{"Authentication", " ", "->", " ", 
     RowBox[{"{", 
      RowBox[{"\"\<apikey\>\"", " ", "->", " ", "api"}], "}"}]}]}], 
   "]"}]}]], "Input",ExpressionUUID->"b4997c54-9d5d-4e95-b821-f4295a6b0d3b"]
}, Open  ]],

Cell[CellGroupData[{

Cell[TextData[{
 "A connected service object lists the QPUs your account can reach through ",
 Cell[BoxData["\"\<Backends\>\""], "InlineFormula",ExpressionUUID->
  "2ac39d0f-ec00-4e45-b8d2-e8b5fe0f991c"],
 ". Submitting and retrieving jobs is handled for you by ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["IBMJobSubmit"]], 
    "paclet:Wolfram/QuantumFramework/ref/IBMJobSubmit", 
    "Wolfram/QuantumFramework Package Symbol"},
   "PackageLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",ExpressionUUID->
  "1c4e9e0d-bfae-4514-9db4-54ef52b3cc79"],
 " and the ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["IBMJob"]], "paclet:Wolfram/QuantumFramework/ref/IBMJob", 
    "Wolfram/QuantumFramework Package Symbol"},
   "PackageLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",ExpressionUUID->
  "c291032c-92f6-45fc-a91e-e50a53a0196d"],
 " handle, shown below. List the available backends:"
}], "Text",ExpressionUUID->"de62943a-2c1e-4d59-b424-2f3f29ebf7f6"],

Cell[BoxData[
 RowBox[{"ibm", "[", "\"\<Backends\>\"", "]"}]], "Input",ExpressionUUID->"4b1977fd-29d9-4f36-88a2-f841293deeac"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["Building and checking a circuit", "Subsection",ExpressionUUID->"a89330f2-1467-4e8c-b604-4744d54508f0"],

Cell[CellGroupData[{

Cell[TextData[{
 "Using the circuit ",
 Cell[BoxData[
 "qc"], "InlineFormula",ExpressionUUID->
  "26a24a0c-dcb4-4e87-8318-2ecdf6513bb2"],
 " from the previous section, plot its exact output distribution: the \
noiseless ground truth a QPU run approximates, and the reference we overlay \
with the hardware counts:"
}], "Text",ExpressionUUID->"8a77f2bd-2c2b-4e01-8988-18d2c9d775fd"],

Cell[CellGroupData[{

