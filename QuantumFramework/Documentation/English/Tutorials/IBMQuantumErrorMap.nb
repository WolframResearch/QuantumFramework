      "6c6cdbd2-caa7-49ec-95b0-5ce9973186b2"],
     " vertex color"
    }], "TableText",ExpressionUUID->"f0530438-5da4-4b74-90ca-837b6122c142"]},
   {Cell["      ", "ModInfo",ExpressionUUID->
     "b0614225-d603-4ce3-a384-8f77cc5a2b87"], Cell[TextData[Cell[
    BoxData["\"\<VertexColorReversed\>\""], "InlineFormula",ExpressionUUID->
     "a8818679-34ec-40fd-9634-09b8346cd629"]], "TableText",ExpressionUUID->
