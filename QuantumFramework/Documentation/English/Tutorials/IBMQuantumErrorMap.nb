Cell["What IBM actually exposes", "Section",ExpressionUUID->"750c4d5d-c74c-413e-bbc1-710d054340e6"],

Cell[TextData[{
 "Two read-only endpoints carry everything the map needs. The device's ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["ServiceConnect"]], "paclet:ref/ServiceConnect"},
   "RefLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",ExpressionUUID->
  "521300b0-d44c-49d2-a918-1169f1d09065"],
 " connection to ",
 Cell[BoxData["\"\<IBMQuantumPlatform\>\""], "InlineFormula",ExpressionUUID->
  "32ba5abd-79fd-4021-9232-cfd5b6c318a3"],
 " already defines both as raw requests."
}], "Text",ExpressionUUID->"352d5583-e69f-4f0e-b568-673ef56c080a"],

Cell[TextData[{
 Cell[BoxData["configuration"], "InlineFormula",
  FontWeight->"Bold",ExpressionUUID->"d048b6e3-082f-4db8-b530-508eb9db7ef4"],
 " gives the static layout: the coupling map (the list of physically \
connected qubit pairs), a per-qubit grid coordinate, and the native gate set \
(",
 Cell[BoxData[
  RowBox[{
   RowBox[{"{", 
    StyleBox["c", "TI"], 
    StyleBox["z", "TI"]}], 
   RowBox[{",", "\[ThinSpace]"}], 
   StyleBox[
    RowBox[{"i", "d"}], "TI"], 
   RowBox[{",", "\[ThinSpace]"}], 
   StyleBox[
    RowBox[{"r", "x"}], "TI"], 
   RowBox[{",", "\[ThinSpace]"}], 
   StyleBox[
    RowBox[{"r", "z"}], "TI"], 
   RowBox[{",", "\[ThinSpace]"}], 
   StyleBox[
    RowBox[{"r", "z", "z"}], "TI"], 
   RowBox[{",", "\[ThinSpace]"}], 
   StyleBox[
    RowBox[{"s", "x"}], "TI"], 
   RowBox[{",", "\[ThinSpace]"}], 
   RowBox[{
    StyleBox["x", "TI"], "}"}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "3de6040e-8671-49be-b0e9-93d253bf3e04"],
 " on Heron)."
}], "Item",ExpressionUUID->"60c67aac-a54e-4875-bd55-40aed12b5aaa"],

Cell[TextData[{
 Cell[BoxData["properties"], "InlineFormula",
  FontWeight->"Bold",ExpressionUUID->"4cc56f4b-11d0-4b92-bdd2-d569d16f72f7"],
 " gives the live calibration, each value time-stamped: per qubit the \
relaxation time ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["T", "TI"], "1"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "bfe9f5de-05a1-479a-b684-23dc5f1438b5"],
 ", the dephasing time ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["T", "TI"], "2"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "ef5106eb-13fd-4df2-83b0-a1a3ffc1315f"],
 ", the single-shot readout error, and the asymmetric \
state-preparation-and-measurement probabilities; per gate the error and \
duration; and, in a ",
 Cell[BoxData[
 "general"], "InlineFormula",ExpressionUUID->
  "58bca868-3721-4aee-b5af-15e7b1f7cec9"],
 " block, the static ",
 Cell[BoxData[
  StyleBox[
   RowBox[{"Z", "Z"}], "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "0a1fa0ce-34e5-4834-ac47-a02b1b2d6882"],
 " crosstalk for every coupled pair."
}], "Item",ExpressionUUID->"a56ef5a3-a011-43c0-84b7-7d3cf1542f5f"],

Cell[TextData[{
 "One thing is worth stating plainly, because it differs from QUALink: ",
 StyleBox["IBM publishes no Bell-state fidelity",
  FontWeight->"Bold"],
 ". There is no two-qubit fidelity number beyond the ",
 Cell[BoxData[
 "cz"], "InlineFormula",ExpressionUUID->
  "0e3f27e6-1764-48cb-883a-4019b4c41a8d"],
 " gate error itself. So the ",
 Cell[BoxData[
 "cz"], "InlineFormula",ExpressionUUID->
  "ff53dfcc-0f18-4c09-8d47-0f31e50c1bda"],
 " error becomes the bond ",
 StyleBox["color", "TI"],
 ", and the natural second per-bond channel is the static ",
 Cell[BoxData[
  StyleBox[
   RowBox[{"Z", "Z"}], "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "9ddbb505-fa19-47b1-b620-202cf9756ad6"],
 " crosstalk: the always-on residual coupling a pair carries even while idle, \
an error source independent of the gate error."
}], "Text",ExpressionUUID->"a5f73c1a-0ca0-4bbe-844f-e8f05ada7879"],

Cell["Building the map", "Section",ExpressionUUID->"2fb9d7e9-1b5a-43ff-81bc-f2c37ea80ea5"],

Cell[TextData[{
 "The error map is a property of the ",
 Cell[BoxData["\"\<IBMQuantumPlatform\>\""], "InlineFormula",ExpressionUUID->
  "31e38cb3-5fc8-4dea-ab5c-9597a490aa46"],
 " ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["ServiceConnect"]], "paclet:ref/ServiceConnect"},
   "RefLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",ExpressionUUID->
  "e0699ff6-bb48-410d-8c11-30aeb7dc0007"],
 " connection. It needs IBM credentials for the read-only metadata fetch: an \
API key, and the IBM Cloud resource name stored as ",
 Cell[BoxData[
  RowBox[{"LocalSymbol", "[", "\"\<ibm_crn\>\"", "]"}]], "InlineFormula",
  ExpressionUUID->"6012ecf8-7aaf-481d-a852-54bf1a15850e"],
 "."
}], "Text",ExpressionUUID->"46b2d77e-61b5-4d5c-bd30-38d3663776f3"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"LocalSymbol", "[", "\"\<ibm_crn\>\"", "]"}], " ", "=", 
   " ", "\"\<crn:v1:bluemix:public:quantum-computing:us-east:...\>\""}], 
  ";"}], "\n", 
 RowBox[{"ibm", " ", "=", " ", 
  RowBox[{"ServiceConnect", "[", 
   RowBox[{"\"\<IBMQuantumPlatform\>\"", ",", " ", "\"\<New\>\"", ",", " ", 
    RowBox[{"Authentication", " ", "->", " ", 
     RowBox[{"{", 
      RowBox[{"\"\<apikey\>\"", " ", "->", " ", "api"}], "}"}]}]}], 
   "]"}]}]}], "Input",ExpressionUUID->"e6447d2e-4a55-4e05-9cab-a538356fb233"],

Cell["\<\
Draw the map. A bare call uses the curated default styling shown above and \
the first available device:\
\>", "Text",ExpressionUUID->"694ae73c-6a30-4dd8-bbfd-42da784cc7a8"],

Cell[BoxData[
 RowBox[{"ibm", "[", "\"\<ErrorMap\>\"", "]"}]], "Input",ExpressionUUID->"7909bc46-b20a-4238-a531-3242fcdb675c"],

Cell[TextData[{
 "Pick a device by name with the ",
 Cell[BoxData["\"\<Backend\>\""], "InlineFormula",ExpressionUUID->
  "1b088699-e19d-4f0a-bf71-2bab76e3814a"],
 " parameter:"
}], "Text",ExpressionUUID->"e4862044-ccbc-4a18-be18-be1f1c0f6b85"],

Cell[BoxData[
 RowBox[{"ibm", "[", 
  RowBox[{"\"\<ErrorMap\>\"", ",", " ", 
   RowBox[{"\"\<Backend\>\"", " ", "->", " ", "\"\<ibm_fez\>\""}]}], 
  "]"}]], "Input",ExpressionUUID->"3bb6c7fd-02a2-42ad-bafc-f575105d2834"],

Cell["\<\
The connection also exposes the underlying error model and its projections, \
each keyed by the sorted qubit pair, so the map's numbers are independently \
queryable (still no circuit, no quantum time):\
\>", "Text",ExpressionUUID->"62870fa3-d557-4c57-b816-76b7858bceb6"],

Cell[BoxData[
 RowBox[{"ibm", "[", 
  RowBox[{"\"\<DeviceModel\>\"", ",", " ", 
   RowBox[{"\"\<Backend\>\"", " ", "->", " ", "\"\<ibm_fez\>\""}]}], 
  "]"}]], "Input",ExpressionUUID->"56785fbd-60aa-44af-aa66-6f1ebdb4ecef"],

Cell[TextData[{
 "The accessor family is ",
 Cell[BoxData["\"\<DeviceModel\>\""], "InlineFormula",ExpressionUUID->
  "0a32ef10-e084-47b5-9873-50fa4b13a23e"],
 ", ",
 Cell[BoxData["\"\<CouplingMap\>\""], "InlineFormula",ExpressionUUID->
  "618bb348-0ce3-4155-b15a-0915f1fc1b60"],
 ", ",
 Cell[BoxData["\"\<CZErrors\>\""], "InlineFormula",ExpressionUUID->
  "0eb82a84-60b0-4247-8121-6cda80952a6e"],
 ", ",
 Cell[BoxData["\"\<ZZ\>\""], "InlineFormula",ExpressionUUID->
  "c8f2ce53-a781-4a8b-8d77-c18d558fe07b"],
 ", ",
 Cell[BoxData["\"\<GateErrors\>\""], "InlineFormula",ExpressionUUID->
  "0aa6b4cd-ea5e-4bbc-a0ed-4f3d3ec60dc6"],
 " (which takes a ",
 Cell[BoxData["\"\<GateName\>\""], "InlineFormula",ExpressionUUID->
  "9fecf304-bd77-4d86-a5f8-2ba28669fbef"],
 " parameter, default ",
 Cell[BoxData["\"\<cz\>\""], "InlineFormula",ExpressionUUID->
  "80da2d9e-a177-4682-849a-8191d3a852ae"],
 "), ",
 Cell[BoxData["\"\<ReadoutErrors\>\""], "InlineFormula",ExpressionUUID->
  "6d6c08bb-b0b3-4c20-bead-9809c14fe231"],
 ", ",
 Cell[BoxData["\"\<Coherence\>\""], "InlineFormula",ExpressionUUID->
  "5d0741dc-c415-4393-b314-d0f83df8dce0"],
 ", and ",
 Cell[BoxData["\"\<Qubits\>\""], "InlineFormula",ExpressionUUID->
  "088b2f6c-f4d5-4194-b933-964146dd929b"],
 ". ",
 Cell[BoxData["\"\<DeviceModel\>\""], "InlineFormula",ExpressionUUID->
  "c769e5be-a6db-4364-a97d-5be0ffb0b8d3"],
 " fetches once and carries every projection as a key, so it is the efficient \
path when you need several at once; nothing device-specific is hardcoded, so \
a metric the device adds later is ingested with no change."
}], "Text",ExpressionUUID->"4ded52d9-904c-41d1-bab8-cd82df715199"],

Cell["Reading the map", "Section",ExpressionUUID->"dbf27454-98dd-4f89-a853-9cbe8273808b"],

Cell["\<\
The drawing carries four calibration channels at once, plus the qubit labels \
and the defect markers.\
\>", "Text",ExpressionUUID->"bfa68778-d6f0-45d2-9f4d-2930b505810e"],

Cell[TextData[{
 StyleBox["Bond color",
  FontWeight->"Bold"],
 " is the ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["log",
    FontSlant->"Plain"], "10"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "b8ed7976-3a0c-4968-b947-381c8c551fa9"],
 " of the ",
 Cell[BoxData[
 "cz"], "InlineFormula",ExpressionUUID->
  "ca346adc-2c3e-43d6-87d8-2a540b6bc0d6"],
 " gate error, on a temperature scale: blue is a clean coupler, red a lossy \
one."
}], "Item",ExpressionUUID->"3d68ed62-b69d-4013-a466-be0f784ff434"],

Cell[TextData[{
 StyleBox["Bond thickness",
  FontWeight->"Bold"],
 " is the static ",
 Cell[BoxData[
  StyleBox[
   RowBox[{"Z", "Z"}], "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "382c340c-6e28-44bd-b450-0e79689a1c81"],
 " crosstalk (0 to about 26 kHz on ",
 Cell[BoxData[
 "ibm_fez"], "InlineFormula",ExpressionUUID->
  "509ea01b-6de2-45cf-8ffa-123b1284e347"],
 "): a thick bond leaks more always-on coupling."
}], "Item",ExpressionUUID->"1c0ab1f8-a2a2-4692-a00e-084b7e3a4fc7"],

Cell[TextData[{
 StyleBox["Vertex color",
  FontWeight->"Bold"],
 " is ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["T", "TI"], "1"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "4309d33f-7adf-4806-9f6b-f549c84acead"],
 " on an avocado scale. Larger ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["T", "TI"], "1"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "e12dca0b-50a1-47b8-9be5-315d2220d48a"],
 " is better, so a long-lived qubit is dark green and a short-lived one glows \
yellow."
}], "Item",ExpressionUUID->"c767c4d6-ea5b-4c69-9447-ad638d4781dc"],

Cell[TextData[{
 StyleBox["Vertex size",
  FontWeight->"Bold"],
 " is the readout error, but ",
 StyleBox["inverted", "TI"],
 " so that a big disk is a good (low-readout) qubit. The single worst qubit \
is therefore the smallest dot."
}], "Item",ExpressionUUID->"42a75f8d-3d46-4583-bbd1-76dd2cd626aa"],

Cell[TextData[{
 StyleBox["Vertex label",
  FontWeight->"Bold"],
 " is the physical qubit index, so a problem qubit can be named, not just \
pointed at."
}], "Item",ExpressionUUID->"57684274-648b-40fc-af63-68250435646a"],

Cell["\<\
A coupler IBM currently flags as uncalibrated (gate error reported as exactly \
1, the analogue of QUALink's 0 sentinel) is drawn as a dashed gray defect \
bond, and a qubit with no readout number as a dashed defect site, so the full \
physical lattice is always visible. The bonds carry double-headed arrows; the \
next section says why.\
\>", "Text",ExpressionUUID->"8d5196a6-5abe-49c7-a42b-4813d095e26c"],

Cell["Options", "Section",ExpressionUUID->"4c8be6b0-dfee-41ec-948b-9108ddd16d30"],

Cell[TextData[{
 "Every channel is a parameter of the ",
 Cell[BoxData["\"\<ErrorMap\>\""], "InlineFormula",ExpressionUUID->
  "b77df3d2-e7f8-43d3-ac56-2fcc17b8e830"],
 " request, so the look is fully steerable; the defaults are the curated dark \
look above. Pass one override directly after the request name, or several \
wrapped in a list (the standard ",
 Cell[BoxData[
 "ServiceConnect"], "InlineFormula",ExpressionUUID->
  "d1ccbbb8-ebc6-4e86-8eac-2b3274dc4236"],
 " parameter form)."
}], "Text",ExpressionUUID->"6414fd67-72d4-4826-90c8-e82f55eb5f9a"],

Cell[BoxData[GridBox[{
   {Cell["      ", "ModInfo",ExpressionUUID->
     "ca5c58e0-4fda-460e-9aa9-a20f1f119631"], Cell["Parameter", "TableText",
     FontWeight->Bold,ExpressionUUID->"b06ec49b-391e-49a8-aa65-c95c66ab143c"],
     Cell["Default", "TableText",
