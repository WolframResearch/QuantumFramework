Notebook[{

Cell[CellGroupData[{
Cell["An IBM Quantum Error Map", "Title",
 CellID->509267359,ExpressionUUID->"4ddb5767-1f00-4973-a411-49eacd07850d"],

Cell[TextData[{
 "A quantum processor is only as good as its current calibration, and that \
calibration drifts from hour to hour. This note draws a single picture of an \
IBM device's instantaneous health: the qubit connectivity graph with the live \
per-qubit and per-bond calibration painted onto it. It is the IBM analogue of \
QUALink's ",
 Cell[BoxData[
  RowBox[{
   RowBox[{"QUAConnect", "[", 
    StyleBox["backend", "TI"], "]"}], "[", "\"\<ErrorMap\>\"", "]"}]], 
  "InlineFormula",ExpressionUUID->"62550f8d-3ce7-48ce-9464-e27339b0628d"],
 ", and it reads only the free metadata endpoints, so it runs no circuit and \
spends no quantum time."
}], "Text",ExpressionUUID->"613b7e85-d297-4e87-b836-4834a6f05a2a"],

Cell[TextData[{
 "The example below is ",
 Cell[BoxData[
 "ibm_fez"], "InlineFormula",ExpressionUUID->
  "6a9ff146-f7ec-40e0-a521-223c9510e35e"],
 ", a 156-qubit Heron r2 device."
}], "Text",ExpressionUUID->"33741934-e412-4408-8456-e175a1b041d6"],

