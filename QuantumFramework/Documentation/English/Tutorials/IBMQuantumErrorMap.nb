    }], "TableText",ExpressionUUID->"f38540a4-d1f4-4e38-a9f6-69ab01f89cde"]},
   {Cell["      ", "ModInfo",ExpressionUUID->
     "92eb9144-f8b8-4fc8-a646-dcd300ccfae6"], Cell[TextData[Cell[
    BoxData["\"\<EdgeThicknessRange\>\""], "InlineFormula",ExpressionUUID->
     "d131b5c7-ffb3-4254-a326-71dc82751f6f"]], "TableText",ExpressionUUID->
     "3c30be0c-f0a6-4dab-bf7d-311794f88cd3"], Cell[TextData[Cell[BoxData[
     RowBox[{"{", 
      RowBox[{"4.", ",", " ", "12."}], "}"}]], "InlineFormula",ExpressionUUID->
     "6e1a0935-8990-452c-b49f-50144c519484"]], "TableText",ExpressionUUID->
     "b76aa508-bc9c-4845-a516-2f964d3c15c9"], Cell[
    "thinnest-to-thickest bond width in points", "TableText",ExpressionUUID->
     "2896e461-8109-4c6e-884f-b35617b5097e"]},
   {Cell["      ", "ModInfo",ExpressionUUID->
