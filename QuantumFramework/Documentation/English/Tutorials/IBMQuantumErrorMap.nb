     "676600f0-cc89-4e95-9167-d0cb274259be"], Cell[TextData[Cell[BoxData[
    "True"], "InlineFormula",ExpressionUUID->
     "f3e392cc-6cf7-4455-a078-7de3cd040369"]], "TableText",ExpressionUUID->
     "48212e6e-fad6-417f-a7df-4b22febd4d32"], Cell[TextData[{
     "big disk = low readout error (good); set ",
