     "False"], "InlineFormula",ExpressionUUID->
      "8bcb9939-9afe-4ad4-8130-2e7cfa12c4ad"],
     " for big = bad"
    }], "TableText",ExpressionUUID->"68714ad5-6da3-4a86-a7d1-620e6c687dc8"]},
   {Cell["      ", "ModInfo",ExpressionUUID->
     "f156ab1a-d074-4eeb-9f18-1980c0309c2b"], Cell[TextData[Cell[
    BoxData["\"\<EdgeThicknessMetric\>\""], "InlineFormula",ExpressionUUID->
     "14f03767-312d-4f7d-9e6d-01ef20c29592"]], "TableText",ExpressionUUID->
     "a9059dad-afc2-461a-a6b9-8e0868eb835c"], Cell[TextData[Cell[
    BoxData["\"\<ZZ\>\""], "InlineFormula",ExpressionUUID->
     "4da17362-4d09-4365-9046-59daabfa5b2d"]], "TableText",ExpressionUUID->
     "c356aa6d-be4b-44db-a0c0-11984666c602"], Cell[TextData[{
     "bond thickness source: ",
     Cell[
