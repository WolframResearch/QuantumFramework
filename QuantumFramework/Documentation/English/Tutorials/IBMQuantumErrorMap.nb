    "True"], "InlineFormula",ExpressionUUID->
     "ae87fb03-6b3f-40d4-ab4a-e6b94aa88157"]], "TableText",ExpressionUUID->
     "e8efe909-1510-4521-b72b-f4b0a5db819d"], Cell[TextData[{
     "map low ",
     Cell[BoxData[
      SubscriptBox[
       StyleBox["T", "TI"], "1"]], "InlineFormula",
      FontSize->0.9 Inherited,ExpressionUUID->
      "fea48092-097a-4e07-a807-f7fa7367bc28"],
     " to the gradient's bright end"
    }], "TableText",ExpressionUUID->"53ad1ad5-2e13-4f49-b806-f6c545b5ef92"]},
   {Cell["      ", "ModInfo",ExpressionUUID->
     "540ba7ba-f1f5-4a89-9a86-7822fac86c4b"], Cell[TextData[Cell[
