   RowBox[{"job", "[", "\"\<Samples\>\"", "]"}], ",", " ", "2"}], 
  "]"}]], "Input",ExpressionUUID->"27c8cc01-fbce-41de-b940-2566db02e962"],

Cell["Estimator results", "ExampleSubsection",ExpressionUUID->"6fa74c0a-9e9d-4131-a2a6-ed6881ca3a9e"],

Cell[TextData[{
 "For a job submitted with ",
 Cell[BoxData[
  RowBox[{"\"\<Primitive\>\"", " ", "->", " ", "\"\<estimator\>\""}]], 
  "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "2e056df8-441a-4336-a7e8-da21e8111583"],
 ", the result is the observable's expectation value and its standard error \
rather than a measurement; the sampler accessors report ",
 Cell[BoxData[
  RowBox[{"Missing", "[", 
   RowBox[{"\"\<NotApplicable\>\"", ",", " ", "\"\<estimator\>\""}], "]"}]], 
  "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "f8629ed3-965e-423f-8a40-b6caaed51acd"],
 ":"
}], "ExampleText",ExpressionUUID->"defd3904-9938-4c19-8c5f-d742351bd4ab"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"estJob", " ", "=", " ", 
   RowBox[{"IBMJobSubmit", "[", 
    RowBox[{
     RowBox[{"QuantumCircuitOperator", "[", 
      RowBox[{"{", 
       RowBox[{"\"\<GHZ\>\"", ",", " ", 
        RowBox[{"{", 
         RowBox[{"1", ",", " ", "2", ",", " ", "3"}], "}"}]}], "}"}], "]"}], ",",
      " ", "\"\<ibm_fez\>\"", ",", "\n", "  ", 
     RowBox[{"\"\<Primitive\>\"", " ", "->", " ", "\"\<estimator\>\""}], ",", 
     " ", 
     RowBox[{"\"\<Observable\>\"", " ", "->", " ", "\"\<ZZZ\>\""}], ",", " ", 
     
     RowBox[{"\"\<Wait\>\"", " ", "->", " ", "True"}]}], "]"}]}], ";"}], "\n", 
 RowBox[{"{", 
  RowBox[{
   RowBox[{"estJob", "[", "\"\<ExpectationValue\>\"", "]"}], ",", " ", 
   RowBox[{"estJob", "[", "\"\<StandardErrors\>\"", "]"}]}], "}"}]}], "Input",\
ExpressionUUID->"d44b7e71-b249-4afe-bfdd-a1fa8263e8fb"],

Cell["Job metadata", "ExampleSubsection",ExpressionUUID->"621d0f8a-c461-4b7d-91f9-7cf992b5dd16"],

