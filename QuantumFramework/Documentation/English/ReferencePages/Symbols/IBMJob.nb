UUID->"e2c50b67-b785-40e0-9a55-8addd036562f"],

Cell["\t", "ExampleDelimiter",ExpressionUUID->"2501a33c-a04d-4c93-b1d0-0256a1c6895c"],

Cell[TextData[{
 "The submitted circuit, as stored in the job's ",
 Cell[BoxData["params"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "d31e52f6-0f98-457f-833c-4f8194c00f50"],
 " (qiskit serializes it before submission, so it is not OpenQASM text):"
}], "ExampleText",ExpressionUUID->"aaabf69d-93e0-4a41-bd42-f10bab9cb68b"],

Cell[BoxData[
 RowBox[{"job", "[", "\"\<SubmittedCircuit\>\"", "]"}]], "Input",ExpressionUUID->"82b93f88-ab38-477a-8839-cf787dc40b55"],

Cell["Lifecycle", "ExampleSubsection",ExpressionUUID->"02eb35be-1448-4e2b-8ef0-cf3f4b72aef6"],

Cell[TextData[{
 Cell[BoxData["\"\<Refresh\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "6c1b8222-b64a-45f5-9248-20825357757d"],
 " re-queries the service and gives a new handle with an updated snapshot:"
