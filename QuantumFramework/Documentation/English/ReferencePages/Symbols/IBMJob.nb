Notebook[{

Cell[CellGroupData[{
Cell["IBMJob", "ObjectName",
 CellID->1224892054,ExpressionUUID->"8393d601-4014-44ba-afc9-60862df940ec"],

Cell[TextData[{
 Cell["   ", "ModInfo",ExpressionUUID->"2ed9131c-3a7a-4ab9-832c-3917f89463e3"],
 Cell[BoxData[
  RowBox[{"IBMJob", "[", 
   StyleBox["assoc", "TI"], "]"}]], "InlineFormula",ExpressionUUID->
  "bd32e98d-d31a-4da0-a81a-c20d004a1353"],
 " ",
 "represents a job submitted to an IBM Quantum processing unit, carrying its \
identifier, backend and the raw service responses, with curated accessors \
layered on top.",
 "\n",
 Cell["   ", "ModInfo",ExpressionUUID->"3d628010-a569-4304-a492-6a547916b04a"],
 Cell[BoxData[
  RowBox[{
   RowBox[{"IBMJob", "[", 
    StyleBox["assoc", "TI"], "]"}], 
   "[", "\"\<\!\(\*StyleBox[\"prop\", \"TI\"]\)\>\"", "]"}]], "InlineFormula",
  ExpressionUUID->"bc88d275-72eb-44fd-ac89-76bd35ae91a1"],
 " ",
 "gives the value of the property ",
 StyleBox["\"prop\"", "TI"],
 ", such as ",
 Cell[BoxData["\"\<Status\>\""], "InlineFormula",ExpressionUUID->
  "3b6d45cc-f76e-415f-8d52-d9c11a7a6731"],
 ", ",
 Cell[BoxData["\"\<Counts\>\""], "InlineFormula",ExpressionUUID->
  "689203fb-9ccd-4ba6-ae03-a13d10aa7298"],
 " or ",
 Cell[BoxData["\"\<QuantumSeconds\>\""], "InlineFormula",ExpressionUUID->
  "37bdd0ed-e7ab-4946-ac22-73c0570c6f9a"],
 ".",
 "\n",
 Cell["   ", "ModInfo",ExpressionUUID->"fa7150cd-a570-4f1c-a201-db224a856a4c"],
 Cell[BoxData[
  RowBox[{
   RowBox[{"IBMJob", "[", 
    StyleBox["assoc", "TI"], "]"}], "[", "]"}]], "InlineFormula",
  ExpressionUUID->"f7bef703-ab72-41eb-8522-b798ef25b8b6"],
 " ",
 "gives the primary result: the ",
 Cell[BoxData[
 "QuantumMeasurement"], "InlineFormula",ExpressionUUID->
  "c7df9722-fdcb-4272-8e66-d0346589b90a"],
 " reconstructed from the hardware counts for a sampler job, or the \
observable's expectation value for an estimator job."
}], "Usage",ExpressionUUID->"f02d0ffb-22a5-4254-839e-9afeaf7e9201"],

Cell[TextData[{
 "An ",
 Cell[BoxData[
 "IBMJob"], "InlineFormula",ExpressionUUID->
  "8afad03d-4e38-4b18-b87c-dcd24b3951b1"],
 " is normally produced by ",
 Cell[BoxData[
 "IBMJobSubmit"], "InlineFormula",ExpressionUUID->
  "a09629f0-b2b2-4b2c-976f-c65ea59f06bd"],
 " or by the ",
 Cell[BoxData[
  RowBox[{
   RowBox[{"QuantumCircuitOperator", "[", 
    StyleBox["circ", "TI"], "]"}], "[", 
   RowBox[{
    ButtonBox["Method",
     BaseStyle->"Link"], " ", "->", " ", 
    RowBox[{"{", 
     RowBox[{"\"\<Qiskit\>\"", ",", " ", 
      RowBox[{"\"\<Provider\>\"", " ", "->", " ", "\"\<IBMProvider\>\""}], ",",
       " ", "\[Ellipsis]"}], "}"}]}], "]"}]], "InlineFormula",ExpressionUUID->
  "47779ada-d410-46df-ada2-691f31016a0c"],
 " hardware path, not constructed by hand."
}], "Notes",ExpressionUUID->"c53a5000-fd98-446a-bb41-f71438884ded"],

Cell[TextData[{
 "The object is a ",
 StyleBox["lossless",
  FontWeight->"Bold"],
 " carrier: the raw service responses are kept verbatim under ",
 Cell[BoxData["\"\<Raw\>\""], "InlineFormula",ExpressionUUID->
  "d4d9f715-cf0d-4ca0-b75d-18cb7c1b0650"],
 ", and every accessor reads from there, so no field the service returns is \
discarded."
}], "Notes",ExpressionUUID->"3f02b0c1-d87f-411e-a865-9b05be3c75b6"],

Cell[TextData[{
 "Accessors ",
 StyleBox["fetch lazily",
  FontWeight->"Bold"],
 ": a property reads from the stored snapshot when present, otherwise queries \
the service object. With no reachable connection an accessor gives ",
 Cell[BoxData[
  RowBox[{"Missing", "[", "\"\<NoConnection\>\"", "]"}]], "InlineFormula",
  ExpressionUUID->"df08f460-635c-4f06-be33-2b4cf3cca4ce"],
 "; before the job is ",
 Cell[BoxData["\"\<Completed\>\""], "InlineFormula",ExpressionUUID->
  "9a9a0f02-b6e7-446c-8bc4-fcf33914d250"],
 " the result accessors give ",
 Cell[BoxData[
  RowBox[{"Missing", "[", 
   RowBox[{"\"\<JobNotComplete\>\"", ","}]}]], "InlineFormula",ExpressionUUID->
  "2b3ad93d-3cc6-41b4-932a-63680a52158f"],
 StyleBox["status", "TI"],
 Cell[BoxData["]"], "InlineFormula",ExpressionUUID->
  "d9374e08-8ad9-4c06-997b-fa59b2605c41"],
 "."
}], "Notes",ExpressionUUID->"25b45607-66c4-4de7-b594-3c492cb300dd"],

Cell[TextData[{
 Cell[BoxData["\"\<Status\>\""], "InlineFormula",ExpressionUUID->
  "e065deff-1fea-4208-9d3d-fc095499a36f"],
 " is one of ",
 Cell[BoxData["\"\<Queued\>\""], "InlineFormula",ExpressionUUID->
  "42c64cec-08f7-468e-a7c1-aae5cd92c15a"],
 ", ",
 Cell[BoxData["\"\<Validating\>\""], "InlineFormula",ExpressionUUID->
  "ed158c3b-3948-4d7f-9463-82a900c92037"],
 ", ",
 Cell[BoxData["\"\<Initializing\>\""], "InlineFormula",ExpressionUUID->
  "0984661c-f650-46b7-a0e0-c27a24da1675"],
 ", ",
 Cell[BoxData["\"\<Running\>\""], "InlineFormula",ExpressionUUID->
  "40b587fa-9f95-4b38-88ea-44931088cc4d"],
 ", ",
 Cell[BoxData["\"\<Completed\>\""], "InlineFormula",ExpressionUUID->
  "c3bc72e7-b414-4476-a00d-3f0e115c572b"],
 ", ",
 Cell[BoxData["\"\<Cancelled\>\""], "InlineFormula",ExpressionUUID->
  "4f4217ee-1893-471c-be3d-b1516ebfb77c"],
 " or ",
 Cell[BoxData["\"\<Failed\>\""], "InlineFormula",ExpressionUUID->
  "e0893f50-ff77-4033-b72c-34d66c05854c"],
 "; the terminal statuses are ",
 Cell[BoxData["\"\<Completed\>\""], "InlineFormula",ExpressionUUID->
  "f67137b4-5ca1-4551-82e1-010861e317ee"],
 ", ",
 Cell[BoxData["\"\<Cancelled\>\""], "InlineFormula",ExpressionUUID->
  "23ea9018-5554-4013-8481-5fcb54c5b2d1"],
 " and ",
 Cell[BoxData["\"\<Failed\>\""], "InlineFormula",ExpressionUUID->
  "a3af58c1-3fcf-44bf-a61a-d1b0231b46f0"],
 "."
}], "Notes",ExpressionUUID->"bafcbc35-cc21-43ca-bd77-f39ee76692f0"],

Cell[TextData[{
 "The hardware counts decode into the Wolfram Language qubit order (ascending \
qubit) using the ",
 Cell[BoxData["\"\<MeasuredQubits\>\""], "InlineFormula",ExpressionUUID->
  "f4ea8e9c-4f0e-495a-9c1d-97a988c7cb66"],
 " map (classical bit to original qubit) captured at submission time, so a \
permuted or partial measurement and any backend layout decode correctly."
}], "Notes",ExpressionUUID->"aee7d0c4-243b-4603-b301-a59e6cf2af1a"],

Cell[TextData[{
 Cell[BoxData[
  RowBox[{"IBMJob", "["}]], "InlineFormula",ExpressionUUID->
  "d210ce26-9049-46c2-b4ec-67473e60284c"],
 StyleBox["assoc", "TI"],
 Cell[BoxData[
  RowBox[{"]", 
   RowBox[{"[", "\"\<Refresh\>\"", "]"}]}]], "InlineFormula",ExpressionUUID->
  "26317fa7-9cbf-4d3a-82df-612575c41989"],
 " re-queries the service and gives a ",
 StyleBox["new",
  FontWeight->"Bold"],
 " ",
 Cell[BoxData[
 "IBMJob"], "InlineFormula",ExpressionUUID->
  "9a7b7228-45a5-4b77-867f-e402f6da25ef"],
 " with an updated ",
 Cell[BoxData["\"\<Raw\>\""], "InlineFormula",ExpressionUUID->
  "f8acce2a-78b1-4c64-a3c3-12fb8fd298e2"],
 " snapshot; once the job is ",
 Cell[BoxData["\"\<Completed\>\""], "InlineFormula",ExpressionUUID->
  "3f608c7a-6694-4f67-8c16-9b4907a36def"],
 " it also pulls the results and metrics, and for an estimator job caches the \
qiskit-decoded expectation values. ",
 Cell[BoxData[
  RowBox[{"IBMJob", "["}]], "InlineFormula",ExpressionUUID->
  "50d4f14d-b6e9-4cc8-adec-bb73048ce983"],
 StyleBox["assoc", "TI"],
 Cell[BoxData[
  RowBox[{"]", 
   RowBox[{"[", "\"\<Cancel\>\"", "]"}]}]], "InlineFormula",ExpressionUUID->
  "7cc75357-d5a5-414f-bf41-a1be34533275"],
 " requests cancellation."
}], "Notes",ExpressionUUID->"e991754b-84a8-44a8-8c38-f3eab03f6da2"],

Cell[TextData[{
 "The result accessors are primitive-specific. For a ",
 StyleBox["sampler",
  FontWeight->"Bold"],
 " job the live accessors are ",
 Cell[BoxData["\"\<Counts\>\""], "InlineFormula",ExpressionUUID->
  "3fd8b5ff-0d55-4e51-af79-f5de1c0fd240"],
 ", ",
 Cell[BoxData["\"\<Measurement\>\""], "InlineFormula",ExpressionUUID->
  "b0f5344e-5528-4f5b-8ff9-4dac4a955fcb"],
 ", ",
 Cell[BoxData["\"\<Probabilities\>\""], "InlineFormula",ExpressionUUID->
  "8759a6c3-f922-45d5-85d6-ba5af208ae34"],
 ", ",
 Cell[BoxData["\"\<Samples\>\""], "InlineFormula",ExpressionUUID->
  "a470931a-c6d6-427b-87bc-45ea4b3e6e9d"],
 ", ",
 Cell[BoxData["\"\<NumBits\>\""], "InlineFormula",ExpressionUUID->
  "d0e9aa8a-0250-48b3-8f99-438b2daa518c"],
 " and ",
 Cell[BoxData["\"\<Shots\>\""], "InlineFormula",ExpressionUUID->
  "0ad69cb2-ebea-4132-9235-bc36faf72e05"],
 "; for an ",
 StyleBox["estimator",
  FontWeight->"Bold"],
 " job they are ",
 Cell[BoxData["\"\<ExpectationValue\>\""], "InlineFormula",ExpressionUUID->
  "fa229705-4c25-4054-8e8a-52d681ffd69f"],
 ", ",
 Cell[BoxData["\"\<ExpectationValues\>\""], "InlineFormula",ExpressionUUID->
  "351216f5-f96e-485d-9cae-0f4ad02a259c"],
 " and ",
 Cell[BoxData["\"\<StandardErrors\>\""], "InlineFormula",ExpressionUUID->
  "80bfc8b7-073c-4f3b-bf8d-e8e104d0e4eb"],
 ". An accessor that does not apply to the job's primitive gives ",
 Cell[BoxData[
  RowBox[{"Missing", "[", 
   RowBox[{"\"\<NotApplicable\>\"", ","}]}]], "InlineFormula",ExpressionUUID->
  "40b965b8-fbc9-4af3-a526-a7267b8f6807"],
 StyleBox["primitive", "TI"],
 Cell[BoxData["]"], "InlineFormula",ExpressionUUID->
  "b129d34e-44c4-4033-bcbf-dfdc4398eafc"],
 "."
}], "Notes",ExpressionUUID->"b990f61c-cee2-4612-a09b-eb8685a49df1"],

Cell[TextData[{
 "An unknown property name gives a ",
 Cell[BoxData[
  ButtonBox["Failure",
   BaseStyle->"Link",
   ButtonData->"paclet:ref/Failure"]], "InlineFormula",ExpressionUUID->
  "af1623c2-6a33-4129-b2dd-0b90763b8be9"],
 " listing the valid properties (see Possible Issues)."
}], "Notes",ExpressionUUID->"3054fd9f-353f-4837-95f6-d37f2589674e"],

Cell[TextData[{
 "The summary box shows the status (with a colored indicator), the backend \
and the job id; once ",
 Cell[BoxData["\"\<Completed\>\""], "InlineFormula",ExpressionUUID->
  "59829c7b-9bca-4231-ae56-a213def969aa"],
 " a sampler job also shows the qubit count, shot count and \
quantum-processing time, and an estimator job shows the expectation value and \
quantum-processing time."
}], "Notes",ExpressionUUID->"ca08dff4-282c-47be-8adf-ad9173db58a9"],

Cell[TextData[{
 "The full property list (",
 Cell[BoxData[
  RowBox[{"IBMJob", "["}]], "InlineFormula",ExpressionUUID->
  "78f073cc-8134-42e4-a24e-7e3a7dc02aaa"],
 StyleBox["assoc", "TI"],
 Cell[BoxData[
  RowBox[{"]", 
   RowBox[{"[", "\"\<Properties\>\"", "]"}]}]], "InlineFormula",
  ExpressionUUID->"ff18a58b-2f8b-4f85-ae0c-0b1d4e3149f6"],
 "):"
}], "Notes",ExpressionUUID->"83b85108-f9b7-4cf7-b9aa-8201777d632c"],

