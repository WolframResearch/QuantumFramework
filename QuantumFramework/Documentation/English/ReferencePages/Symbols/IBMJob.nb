   RowBox[{"job", "[", "\"\<NumBits\>\"", "]"}], ",", " ", 
   RowBox[{"job", "[", "\"\<Shots\>\"", "]"}]}], "}"}]], "Input",ExpressionUUI\
D->"ac0600ba-8f32-4807-ad64-1602796ea9d5"],

Cell["\t", "ExampleDelimiter",ExpressionUUID->"b9115ba6-940a-4320-9133-284c8f27a510"],

Cell["\<\
The classical-bit to original-qubit map used to decode the samples into qubit \
order:\
\>", "ExampleText",ExpressionUUID->"09626ed0-0054-447b-be4d-d5b2abdd765a"],

Cell[BoxData[
 RowBox[{"job", "[", "\"\<MeasuredQubits\>\"", "]"}]], "Input",ExpressionUUID->"1b86a827-19ed-42a4-8733-c4c743434f1f"],

Cell["\t", "ExampleDelimiter",ExpressionUUID->"f5b878bf-e8a4-4ea3-80bc-38eb17382c27"],

Cell["\<\
The raw per-shot outcomes, each the integer value of the classical register \
for that shot:\
\>", "ExampleText",ExpressionUUID->"cc4ae2ba-6dc8-455a-8926-5679eee00e5c"],

Cell[BoxData[
 RowBox[{"Short", "[", 
  RowBox[{
   RowBox[{"job", "[", "\"\<Samples\>\"", "]"}], ",", " ", "2"}], 
  "]"}]], "Input",ExpressionUUID->"5f303373-e4c7-49f1-b5f7-fb11abcb7cb5"],

Cell["Estimator results", "ExampleSubsection",ExpressionUUID->"834fa20a-fa7b-4b9b-ad78-d68c7f67dc64"],

Cell[TextData[{
 "For a job submitted with ",
 Cell[BoxData[
  RowBox[{"\"\<Primitive\>\"", " ", "->", " ", "\"\<estimator\>\""}]], 
  "InlineFormula",ExpressionUUID->"4bcdd78a-1cab-400c-9060-420de4667230"],
 ", the result is the observable's expectation value and its standard error \
rather than a measurement; the sampler accessors report ",
 Cell[BoxData[
  RowBox[{"Missing", "[", 
   RowBox[{"\"\<NotApplicable\>\"", ",", " ", "\"\<estimator\>\""}], "]"}]], 
  "InlineFormula",ExpressionUUID->"c58fdab8-87ae-44ea-b987-5df9d13a7e59"],
 ":"
}], "ExampleText",ExpressionUUID->"fa5f22c0-e0fb-4977-bf96-ad882780518f"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"estJob", " ", "=", " ", 
   RowBox[{"IBMJobSubmit", "[", 
    RowBox[{
     RowBox[{"QuantumCircuitOperator", "[", 
      RowBox[{"{", 
       RowBox[{"\"\<GHZ\>\"", ",", " ", 
        RowBox[{"{", 
         RowBox[{"1", ",", " ", "2", ",", " ", "3"}], "}"}]}], "}"}], "]"}], ",",
      " ", "\"\<ibm_fez\>\"", ",", "\n", "  ", 
     RowBox[{"\"\<Primitive\>\"", " ", "->", " ", "\"\<estimator\>\""}], ",", 
     " ", 
     RowBox[{"\"\<Observable\>\"", " ", "->", " ", "\"\<ZZZ\>\""}], ",", " ", 
     
     RowBox[{"\"\<Wait\>\"", " ", "->", " ", "True"}]}], "]"}]}], ";"}], "\n", 
 RowBox[{"{", 
  RowBox[{
   RowBox[{"estJob", "[", "\"\<ExpectationValue\>\"", "]"}], ",", " ", 
   RowBox[{"estJob", "[", "\"\<StandardErrors\>\"", "]"}]}], "}"}]}], "Input",\
ExpressionUUID->"b6c9c3c5-5257-4663-85d1-f37dc780fa65"],

Cell["Job metadata", "ExampleSubsection",ExpressionUUID->"b8421cc9-4d70-45ff-9acc-2de1a5042bf4"],

Cell["The job identifier and backend:", "ExampleText",ExpressionUUID->"31b09e4f-e671-46f4-82a9-78c34ca4866f"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{"job", "[", "\"\<ID\>\"", "]"}], ",", " ", 
   RowBox[{"job", "[", "\"\<Backend\>\"", "]"}]}], "}"}]], "Input",ExpressionU\
UID->"7541d19f-2f49-4a7a-bc3a-c6ad85a2af02"],

Cell["\t", "ExampleDelimiter",ExpressionUUID->"9fa2fa94-c7b8-4d6b-a10d-530b7971c1f2"],

Cell[TextData[{
 "The quantum-processing time consumed, as a ",
 Cell[BoxData[
 "Quantity"], "InlineFormula",ExpressionUUID->
  "44b6f367-9601-4b7f-930a-4b00e4683e19"],
 " in seconds:"
}], "ExampleText",ExpressionUUID->"e8eb7881-808f-478b-9694-4edb3d366ce4"],

Cell[BoxData[
 RowBox[{"job", "[", "\"\<QuantumSeconds\>\"", "]"}]], "Input",ExpressionUUID->"dd8a0c90-e7c8-4d21-9fed-215dba3d2fe3"],

Cell["\t", "ExampleDelimiter",ExpressionUUID->"3fcff46d-d873-4a01-ab2f-f50d9f876d40"],

Cell["\<\
The lifecycle timestamps and the running-to-finished duration:\
\>", "ExampleText",ExpressionUUID->"92bc33c0-9fa9-411d-b2ce-b97308ae24bd"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{"job", "[", "\"\<Timestamps\>\"", "]"}], ",", " ", 
   RowBox[{"job", "[", "\"\<Duration\>\"", "]"}]}], "}"}]], "Input",Expression\
UUID->"77145c34-5805-4731-adf0-fc0ebd66c8c1"],

Cell["\t", "ExampleDelimiter",ExpressionUUID->"7b6341c6-bb9f-4b15-826b-0ab09b372e7a"],

Cell[TextData[{
 "The submitted circuit, as stored in the job's ",
 Cell[BoxData[
 "params"], "InlineFormula",ExpressionUUID->
  "8333d6c9-03a0-4899-8aee-e2e2f33a6f99"],
 " (qiskit serializes it before submission, so it is not OpenQASM text):"
}], "ExampleText",ExpressionUUID->"8417cc59-782c-46eb-9d54-339d8e674dcd"],

Cell[BoxData[
 RowBox[{"job", "[", "\"\<SubmittedCircuit\>\"", "]"}]], "Input",ExpressionUUID->"fc9a92c2-c85f-49fc-8ee6-d87948229c9d"],

Cell["Lifecycle", "ExampleSubsection",ExpressionUUID->"d60f5ea6-0e3d-4891-a5c5-41065c60b4e7"],

Cell[TextData[{
 Cell[BoxData["\"\<Refresh\>\""], "InlineFormula",ExpressionUUID->
  "df43ae90-b927-4458-a874-689f7bfca445"],
 " re-queries the service and gives a new handle with an updated snapshot:"
}], "ExampleText",ExpressionUUID->"397d4cdd-f8ee-4088-bc5b-0acb3b9d3c5b"],

Cell[BoxData[
 RowBox[{
  RowBox[{"job", "[", "\"\<Refresh\>\"", "]"}], "[", "\"\<Status\>\"", 
  "]"}]], "Input",ExpressionUUID->"82296f10-2ec8-41f1-8aa3-e807cd697748"],

Cell["\t", "ExampleDelimiter",ExpressionUUID->"2877dfcf-fa24-4ce5-a974-6c118b58b654"],

Cell[TextData[{
 Cell[BoxData["\"\<Cancel\>\""], "InlineFormula",ExpressionUUID->
  "a93456fe-4bc4-4739-b8c5-29565e15e868"],
 " requests cancellation of a queued or running job:"
}], "ExampleText",ExpressionUUID->"8c963825-a5a1-4dce-abd6-768efea2b95d"],

Cell[BoxData[
 RowBox[{"job", "[", "\"\<Cancel\>\"", "]"}]], "Input",ExpressionUUID->"6afcca4e-1a82-44f6-b2d1-88e7bce1eda2"],

Cell["Properties and actions", "ExampleSubsection",ExpressionUUID->"9bab9e6c-15a4-457f-bfbb-031113a08fa3"],

Cell[TextData[{
 Cell[BoxData["\"\<Properties\>\""], "InlineFormula",ExpressionUUID->
  "e9081a1a-4de4-4a8e-af55-7e7009526ddb"],
 " lists the local accessors; mapping over them reads only the cached \
snapshot, with no network access:"
}], "ExampleText",ExpressionUUID->"e4a56380-c17b-4172-a9b5-e8df9090fd86"],

Cell[BoxData[
 RowBox[{"AssociationMap", "[", 
  RowBox[{"job", ",", " ", 
   RowBox[{"job", "[", "\"\<Properties\>\"", "]"}]}], "]"}]], "Input",Expressi\
onUUID->"47b8606c-2473-4b04-99e7-4ca58d3841da"],

Cell["\t", "ExampleDelimiter",ExpressionUUID->"8ba3cb44-1569-4414-8698-80fa34856857"],

Cell[TextData[{
 Cell[BoxData["\"\<Actions\>\""], "InlineFormula",ExpressionUUID->
  "d1ef1a77-790b-4e5a-ba82-dfc1a3004304"],
 " lists the names that need a live connection, kept out of ",
 Cell[BoxData["\"\<Properties\>\""], "InlineFormula",ExpressionUUID->
  "69982834-b3f3-4405-b878-0bc6c74de0c7"],
 " so a bulk map never re-queries, cancels or blocks on a remote fetch:"
}], "ExampleText",ExpressionUUID->"ba3e4563-fbb4-4314-9979-77b548fe2ed9"],

Cell[BoxData[
 RowBox[{"job", "[", "\"\<Actions\>\"", "]"}]], "Input",ExpressionUUID->"72eec026-bfee-4c67-8ab3-7c637bd73ddd"],

