 "An unknown property gives a ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["Failure"]], "paclet:ref/Failure"},
   "RefLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",ExpressionUUID->
  "aa1b2300-7f3e-4ed3-9841-d2e0a7325230"],
 " listing the valid data properties and actions:"
}], "ExampleText",ExpressionUUID->"91fe0adb-d3c2-40c9-ad9e-6fed2f4180ef"],

Cell[BoxData[
 RowBox[{"job", "[", "\"\<Frobnicate\>\"", "]"}]], "Input",ExpressionUUID->"ee4428be-4b9f-41ae-84f4-d8705aaafdfd"],

Cell["\t", "ExampleDelimiter",ExpressionUUID->"b2d37202-c87f-40c3-940e-d55b00bc743d"],

Cell[TextData[{
 Cell[BoxData["\"\<ExecutedCircuit\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "502198d6-2631-4ff9-a40c-ea4d67d6a53b"],
 " downloads the server-side transpiled circuit, which IBM stores only when \
the Runtime transpiles server-side. A circuit submitted already in ISA form \
to the V2 primitives stores none, so the request gives a ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["Failure"]], "paclet:ref/Failure"},
   "RefLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",ExpressionUUID->
  "959e0b6f-7968-412f-9cd0-6d50426dd178"],
 " rather than a circuit:"
}], "ExampleText",ExpressionUUID->"3f5021f1-3245-4da1-a1ec-361151e5e7e6"],

Cell[BoxData[
 RowBox[{"job", "[", "\"\<ExecutedCircuit\>\"", "]"}]], "Input",ExpressionUUID->"79056890-7327-40b6-b415-9911a866f4e0"],

Cell["\t", "ExampleDelimiter",ExpressionUUID->"39a5e8d2-6ab0-4a0a-ab81-8574e3dc73c2"],

Cell[TextData[{
 "When the transpiled-circuit object does exist, IBM serves it from a Cloud \
Object Storage direct endpoint (host starting ",
 Cell["s3.direct", "InlineCode",ExpressionUUID->
  "ced2b729-b789-466e-87a8-ecdd64f7242c"],
 ") reachable only from inside IBM Cloud, so the download from elsewhere \
gives a ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["Failure"]], "paclet:ref/Failure"},
   "RefLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",ExpressionUUID->
  "54aac6d3-af59-494f-a1e1-162a39e85f34"],
 " instead of timing out silently:"
}], "ExampleText",ExpressionUUID->"1732a587-1872-43b1-a34d-a0428ea09b9b"],

Cell[BoxData[
 RowBox[{"job", "[", "\"\<ExecutedCircuit\>\"", "]"}]], "Input",ExpressionUUID->"b4132d1e-5615-4faf-bafd-6ab76c8240b1"]
}, Open  ]]
}, Open  ]],

