}], "ExampleText",ExpressionUUID->"c6a87694-0cb4-4771-ab36-11930edf1a3f"],

Cell["job[\"Cancel\"]", "Program",ExpressionUUID->"c5013d7a-5e6a-4de3-8d01-d959a46b6c6a"],

Cell["Raw responses", "ExampleSubsection",ExpressionUUID->"69fe9127-3aff-4502-a412-3789f71b287e"],

Cell["\<\
The complete raw service responses are kept verbatim; ask for a single \
section by name:\
\>", "ExampleText",ExpressionUUID->"427ee6a7-e25a-4c3c-848f-0aedea74cae6"],

Cell["Keys @ job[\"Raw\"]", "Program",ExpressionUUID->"b9553b48-a699-4f5e-bde8-bfeaef3206b9"],

Cell["job[\"Raw\", \"Metrics\"]", "Program",ExpressionUUID->"c36f7abe-ed2d-41d3-a9a4-982e716bbd3d"]
