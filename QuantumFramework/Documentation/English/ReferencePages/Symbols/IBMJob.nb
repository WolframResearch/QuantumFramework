Cell["\t", "ExampleDelimiter",ExpressionUUID->"8c8cccb3-07be-4512-8095-f08ca313c1a2"],

Cell[TextData[{
 "The quantum-processing time consumed, as a ",
 Cell[BoxData[
 "Quantity"], "InlineFormula",ExpressionUUID->
  "ba02ea01-bd37-433b-a6c8-83953f081924"],
 " in seconds:"
}], "ExampleText",ExpressionUUID->"180c6c1d-ad10-40d5-b8d3-58920090a537"],

Cell["job[\"QuantumSeconds\"]", "Program",ExpressionUUID->"765eb9c1-4631-4d62-8909-850eeef0a374"],

Cell["\t", "ExampleDelimiter",ExpressionUUID->"469b20bd-bde9-4bc5-ad86-94fd4fe4ca4d"],

Cell["\<\
The lifecycle timestamps and the running-to-finished duration:\
\>", "ExampleText",ExpressionUUID->"7e3907b6-8cb3-4b10-8fff-bedbf14501e5"],

Cell["{job[\"Timestamps\"], job[\"Duration\"]}", "Program",ExpressionUUID->"138302a0-c9cf-48a7-9d8f-0227618b4a0b"],

Cell["\t", "ExampleDelimiter",ExpressionUUID->"940b9fa1-d609-4595-bfbc-0eebbbb5ab81"],

