Cell[TextData[{
 Cell[BoxData["\"\<ExecutedCircuit\>\""], "InlineFormula",ExpressionUUID->
  "d4189099-d984-4531-9840-77809acee498"],
 " downloads the server-side transpiled circuit, which IBM stores only when \
the Runtime transpiles server-side. A circuit submitted already in ISA form \
to the V2 primitives stores none, so the request gives a ",
 Cell[BoxData[
  ButtonBox["Failure",
   BaseStyle->"Link",
   ButtonData->"paclet:ref/Failure"]], "InlineFormula",ExpressionUUID->
  "ce3c4ae7-cb9e-45ed-92ee-20910ff1b8fb"],
 " rather than a circuit:"
}], "ExampleText",ExpressionUUID->"ef11d37f-5cac-492e-a30e-2093f3c95869"],

Cell[BoxData[
 RowBox[{"job", "[", "\"\<ExecutedCircuit\>\"", "]"}]], "Input",ExpressionUUID->"6dc2c2a9-6c99-4b7f-b5f8-ffc08a98575f"],

Cell["\t", "ExampleDelimiter",ExpressionUUID->"06be3f1a-c93a-4608-a4fc-1639653d6359"],

Cell[TextData[{
 "When the transpiled-circuit object does exist, IBM serves it from a Cloud \
Object Storage direct endpoint (host starting ",
 Cell[BoxData[
  RowBox[{"s3", ".", "direct"}]], "InlineFormula",ExpressionUUID->
  "f2460e94-6968-4145-9ce4-b53d95295493"],
 ") reachable only from inside IBM Cloud, so the download from elsewhere \
gives a ",
 Cell[BoxData[
  ButtonBox["Failure",
   BaseStyle->"Link",
   ButtonData->"paclet:ref/Failure"]], "InlineFormula",ExpressionUUID->
  "86ab3257-480c-4b43-bfb7-404d08dd9097"],
 " instead of timing out silently:"
}], "ExampleText",ExpressionUUID->"6a285e6a-8d50-40c0-9814-baeacfb04076"],

Cell[BoxData[
 RowBox[{"job", "[", "\"\<ExecutedCircuit\>\"", "]"}]], "Input",ExpressionUUID->"31394c43-4d5e-47c4-81e2-5d6aac3115db"]
}, Open  ]]
}, Open  ]],

