  FontSize->0.9 Inherited,ExpressionUUID->
  "a32b1f45-0a3b-4d60-8a03-d3014bd1fdb1"],
 " requests cancellation of a queued or running job:"
}], "ExampleText",ExpressionUUID->"6c56693f-4295-495d-885f-547abca5efa6"],

Cell[BoxData[
 RowBox[{"job", "[", "\"\<Cancel\>\"", "]"}]], "Input",ExpressionUUID->"b87353f7-5522-4848-9295-7cf27ad631f1"],

Cell["Properties and actions", "ExampleSubsection",ExpressionUUID->"b05fa599-2ca1-4447-ae9f-3b8f6d4c1b13"],

Cell[TextData[{
 Cell[BoxData["\"\<Properties\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "e53a6cb2-f6fb-4c78-a908-cf94647bd41a"],
 " lists the local accessors; mapping over them reads only the cached \
snapshot, with no network access:"
}], "ExampleText",ExpressionUUID->"1e700b48-29df-42d7-bcd5-dd5df80396ac"],

Cell[BoxData[
 RowBox[{"AssociationMap", "[", 
  RowBox[{"job", ",", " ", 
   RowBox[{"job", "[", "\"\<Properties\>\"", "]"}]}], "]"}]], "Input",Expressi\
onUUID->"bf7bcb34-0ed1-41fb-9fbc-c9256a1f414c"],

Cell["\t", "ExampleDelimiter",ExpressionUUID->"851baaab-1c58-4fe4-adf3-e7578e1b1f37"],

Cell[TextData[{
 Cell[BoxData["\"\<Actions\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "86cf0ad0-4668-4825-87a2-5363b3dc247d"],
 " lists the names that need a live connection, kept out of ",
 Cell[BoxData["\"\<Properties\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "45cc2919-1a41-4652-b43a-7c0df3bb4049"],
 " so a bulk map never re-queries, cancels or blocks on a remote fetch:"
}], "ExampleText",ExpressionUUID->"75aa0783-d3b9-4409-aec3-b45d91d0a2e0"],

Cell[BoxData[
 RowBox[{"job", "[", "\"\<Actions\>\"", "]"}]], "Input",ExpressionUUID->"d83d517a-66b0-4781-8858-19d4073eb26a"],

