Cell["Results", "ExampleSubsection",ExpressionUUID->"c4702ca5-2338-4dc3-8506-722d16325cfc"],

Cell["\<\
The outcome probabilities, computed from the measured frequencies and aligned \
to the Wolfram Language qubit order:\
\>", "ExampleText",ExpressionUUID->"b8aadad1-89e3-41e8-9676-bfe36dcfbd07"],

Cell[BoxData[
 RowBox[{"job", "[", "\"\<Probabilities\>\"", "]"}]], "Input",ExpressionUUID->"e7d68294-c316-445f-925a-0c4531a355f4"],

Cell["\t", "ExampleDelimiter",ExpressionUUID->"1fa4a05f-0080-4302-b0bf-7f0bf1681f8c"],

