Cell["Results", "ExampleSubsection",ExpressionUUID->"c2e0b1a4-2ecd-48c8-b504-5ca2e35bfb85"],

Cell["\<\
The outcome probabilities, computed from the measured frequencies and aligned \
to the Wolfram Language qubit order:\
\>", "ExampleText",ExpressionUUID->"4d496363-020f-4281-bf2d-1dca2c30cf78"],

Cell["job[\"Probabilities\"]", "Program",ExpressionUUID->"011d5604-0ce1-4c6f-a053-6ddfea792f34"],

Cell["\t", "ExampleDelimiter",ExpressionUUID->"29ea98f7-5b9e-4723-a5ef-8a6f7ee7de78"],

Cell["Exact integer counts keyed by the bit-list outcome:", "ExampleText",ExpressionUUID->"ca4f00b0-fabd-4c4e-9018-27dc1d936fc1"],

Cell["job[\"Counts\"]", "Program",ExpressionUUID->"4dd9126d-74b6-4456-a224-beaead397584"],

Cell["\t", "ExampleDelimiter",ExpressionUUID->"62b38b82-abd7-4f8a-b574-b62865c4c6c4"],

Cell["The number of measured qubits and the total number of shots:", \
"ExampleText",ExpressionUUID->"fbd13579-af2a-480f-81c7-1f43b63de0eb"],

Cell["{job[\"NumBits\"], job[\"Shots\"]}", "Program",ExpressionUUID->"b2d16b66-dd49-49a8-8175-e56e8e255b3a"],

Cell["\t", "ExampleDelimiter",ExpressionUUID->"461ae328-7e94-4f8a-aab2-f408bc2361dc"],

Cell["\<\
The classical-bit to original-qubit map used to decode the samples into qubit \
order:\
\>", "ExampleText",ExpressionUUID->"c0c22ed9-39ba-4b2a-8869-d96ee6327d29"],

Cell["job[\"MeasuredQubits\"]", "Program",ExpressionUUID->"623fa9f5-a4cf-4ebb-bde4-22929bbb2e28"],

Cell["\t", "ExampleDelimiter",ExpressionUUID->"edf83804-c3fa-42a7-9928-3d5f49861a1d"],

Cell["The raw per-shot classical-register readouts:", "ExampleText",ExpressionUUID->"d57ac306-358d-42d8-886f-d0243cf8e399"],

Cell["Short[job[\"Samples\"], 2]", "Program",ExpressionUUID->"d06772f3-db6d-4d9c-9f16-89419ebab19f"],

Cell["Job metadata", "ExampleSubsection",ExpressionUUID->"6e2f2e93-771c-42eb-8352-a0d8af92747f"],

Cell["The job identifier and backend:", "ExampleText",ExpressionUUID->"591c83cb-5fb7-447c-8c23-5e09025a9639"],

