Cell["StringTake[job[\"SubmittedCircuit\"], 40]", "Program",ExpressionUUID->"40be854c-34d6-4fb3-b9e7-391eae89a227"],

Cell["Lifecycle", "ExampleSubsection",ExpressionUUID->"5d62ca16-05f8-4b0f-ad33-769c83b6ce69"],

Cell[TextData[{
 Cell[BoxData["\"\<Refresh\>\""], "InlineFormula",ExpressionUUID->
  "45ccfd34-9660-42d9-a24d-c12e6a2bfc69"],
 " re-queries the service and gives a new handle with an updated snapshot:"
}], "ExampleText",ExpressionUUID->"4440ceaa-3983-4bb8-af3f-b8db9a5334c8"],

Cell["job[\"Refresh\"][\"Status\"]", "Program",ExpressionUUID->"51533e9c-baa9-4845-ac6e-fb2d517af122"],

