     "2d8b90c4-4c9b-4d54-a582-9a91618144be"], Cell[TextData[Cell[
    BoxData["\"\<QuantumSeconds\>\""], "InlineFormula",ExpressionUUID->
     "ad339d51-6aef-4aab-9139-35b2755779ff"]], "TableText",ExpressionUUID->
     "2184d9fd-f2ea-4dae-863a-f9ddfac62c1d"], Cell[
    "the quantum-processing time used, in seconds", "TableText",
     ExpressionUUID->"6eccc9ea-4274-45f6-9825-ed1626a358ec"]},
   {Cell["      ", "ModInfo",ExpressionUUID->
     "5a550516-00c0-4938-a957-6f8dd8f4b557"], Cell[TextData[Cell[
    BoxData["\"\<SubmittedCircuit\>\""], "InlineFormula",ExpressionUUID->
     "e48e0a4a-b4f5-44ad-93a2-e9e029085014"]], "TableText",ExpressionUUID->
     "dc4476c9-9741-4cd6-9f5e-ff5b0badbed1"], Cell[TextData[{
     "the submitted circuit, as stored in the job's ",
     Cell[BoxData[
     "params"], "InlineFormula",ExpressionUUID->
      "923b756a-9a5b-4bc1-96a2-6e552f0936b1"]
    }], "TableText",ExpressionUUID->"c43be4a2-f73a-4570-ae68-97f762972db7"]},
   {Cell["      ", "ModInfo",ExpressionUUID->
