 " in seconds:"
}], "ExampleText",ExpressionUUID->"3f3cf133-4a32-4b51-95d4-320b03e0fcac"],

Cell[BoxData[
 RowBox[{"job", "[", "\"\<QuantumSeconds\>\"", "]"}]], "Input",ExpressionUUID->"8428d822-79dd-43d0-8ef1-0281594820cb"],

Cell["\t", "ExampleDelimiter",ExpressionUUID->"02bd85a1-306b-4ffc-9df7-a0769ee6adc9"],

Cell["\<\
The lifecycle timestamps and the running-to-finished duration:\
\>", "ExampleText",ExpressionUUID->"d0aa4203-5817-45b6-a446-e5bf78c64431"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{"job", "[", "\"\<Timestamps\>\"", "]"}], ",", " ", 
   RowBox[{"job", "[", "\"\<Duration\>\"", "]"}]}], "}"}]], "Input",Expression\
UUID->"236a5fd7-f268-4109-9c78-f1c5852c3e6a"],

Cell["\t", "ExampleDelimiter",ExpressionUUID->"f323a418-580d-4a81-aa03-a39671645715"],

Cell[TextData[{
 "The submitted circuit, as stored in the job's ",
 Cell[BoxData[
 "params"], "InlineFormula",ExpressionUUID->
  "32ae5e94-33f2-411a-ae7d-cc58309a00df"],
 " (qiskit serializes it before submission, so it is not OpenQASM text):"
}], "ExampleText",ExpressionUUID->"648e999f-cf90-4be1-a80d-7be5a2d81da3"],

Cell[BoxData[
 RowBox[{"job", "[", "\"\<SubmittedCircuit\>\"", "]"}]], "Input",ExpressionUUID->"f26a5963-c5a9-4ffa-877b-1c5825acefe6"],

Cell["Lifecycle", "ExampleSubsection",ExpressionUUID->"6e5dd454-5f8a-4559-b804-87d695ef31be"],

Cell[TextData[{
 Cell[BoxData["\"\<Refresh\>\""], "InlineFormula",ExpressionUUID->
  "925a8deb-f959-4f09-b194-733d3d9bb2f9"],
 " re-queries the service and gives a new handle with an updated snapshot:"
}], "ExampleText",ExpressionUUID->"48c95557-7584-4aad-9f7a-7e60d6ad8beb"],

Cell[BoxData[
 RowBox[{
  RowBox[{"job", "[", "\"\<Refresh\>\"", "]"}], "[", "\"\<Status\>\"", 
  "]"}]], "Input",ExpressionUUID->"b1134005-6192-4ef6-9a6e-7cff59ad075c"],

Cell["\t", "ExampleDelimiter",ExpressionUUID->"eddbc3b2-67f8-43ea-9438-c9f2966a8e17"],

Cell[TextData[{
 Cell[BoxData["\"\<Cancel\>\""], "InlineFormula",ExpressionUUID->
  "a57cc717-f411-4e9f-8b21-addb73c814e3"],
 " requests cancellation of a queued or running job:"
}], "ExampleText",ExpressionUUID->"1b9f7b0e-1a60-42ba-b201-64a0aab80ec3"],

Cell[BoxData[
 RowBox[{"job", "[", "\"\<Cancel\>\"", "]"}]], "Input",ExpressionUUID->"8efe9680-cfcb-42de-82c9-6ef7add4b55f"],

Cell["Raw responses", "ExampleSubsection",ExpressionUUID->"2a0a0570-a50e-4c5e-861a-cd5980e0e827"],

Cell["\<\
The complete raw service responses are kept verbatim; ask for a single \
section by name:\
\>", "ExampleText",ExpressionUUID->"020470e3-969f-47c9-9923-43261226fb6c"],

Cell[BoxData[
 RowBox[{"Keys", " ", "@", " ", 
  RowBox[{"job", "[", "\"\<Raw\>\"", "]"}]}]], "Input",ExpressionUUID->\
"ac802274-4bc6-4993-8446-f313ff3d546c"],

Cell[BoxData[
 RowBox[{"job", "[", 
  RowBox[{"\"\<Raw\>\"", ",", " ", "\"\<Metrics\>\""}], "]"}]], "Input",Expres\
sionUUID->"f4a6249c-a5e4-4346-8f16-6fde81a69c0c"]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[
 InterpretationBox[Cell[
  "Possible Issues", "ExampleSection",ExpressionUUID->
   "dda06a82-eb41-4b48-8510-6cb821647761"],
  $Line = 0; Null]], "ExampleSection",
 CellID->1305812373,ExpressionUUID->"9397dd0b-9de4-443a-9371-be2b75148f2f"],

Cell[TextData[{
 "An unknown property gives a ",
 Cell[BoxData[
  ButtonBox["Failure",
   BaseStyle->"Link",
   ButtonData->"paclet:ref/Failure"]], "InlineFormula",ExpressionUUID->
  "2028eea3-4ea3-4832-94b5-d9baae315cb8"],
 " listing the valid property names:"
}], "ExampleText",ExpressionUUID->"14e9bf69-e3b7-4c83-8093-75d4589a3d65"],

Cell[BoxData[
 RowBox[{"job", "[", "\"\<Frobnicate\>\"", "]"}]], "Input",ExpressionUUID->"4c1208c4-a028-4ba0-8735-d43479a95502"],

Cell["\t", "ExampleDelimiter",ExpressionUUID->"7bd4cf1a-da7c-4eaf-945a-306421fceaf1"],

Cell[TextData[{
 Cell[BoxData["\"\<ExecutedCircuit\>\""], "InlineFormula",ExpressionUUID->
  "42feedde-75c3-483c-bfc8-823bd1affbdd"],
 " downloads the server-side transpiled circuit, which IBM stores only when \
the Runtime transpiles server-side. A circuit submitted already in ISA form \
to the V2 primitives stores none, so the request gives a ",
 Cell[BoxData[
  ButtonBox["Failure",
   BaseStyle->"Link",
   ButtonData->"paclet:ref/Failure"]], "InlineFormula",ExpressionUUID->
  "ed475337-6724-4648-8de0-adac9319f2a3"],
 " rather than a circuit:"
}], "ExampleText",ExpressionUUID->"a29fdb4d-b9ff-4400-bec2-4e16d4fd1e04"],

Cell[BoxData[
 RowBox[{"job", "[", "\"\<ExecutedCircuit\>\"", "]"}]], "Input",ExpressionUUID->"e52d8870-af78-4fee-aec5-373579453192"],

Cell["\t", "ExampleDelimiter",ExpressionUUID->"e2b4ba25-a1f5-4ff4-a44b-21cff9daf036"],

Cell[TextData[{
 "When the transpiled-circuit object does exist, IBM serves it from a Cloud \
Object Storage direct endpoint (host starting ",
 Cell[BoxData[
  RowBox[{"s3", ".", "direct"}]], "InlineFormula",ExpressionUUID->
  "187a644a-292f-4001-82df-68b589ac9a9e"],
 ") reachable only from inside IBM Cloud, so the download from elsewhere \
gives a ",
 Cell[BoxData[
  ButtonBox["Failure",
   BaseStyle->"Link",
   ButtonData->"paclet:ref/Failure"]], "InlineFormula",ExpressionUUID->
  "3f9005c2-15d2-4a18-a63d-33da1ec1bfbe"],
 " instead of timing out silently:"
}], "ExampleText",ExpressionUUID->"fa99c26d-fe13-43b1-a5d6-65f051674866"],

Cell[BoxData[
 RowBox[{"job", "[", "\"\<ExecutedCircuit\>\"", "]"}]], "Input",ExpressionUUID->"3ea6d1b7-d10a-4a57-80b3-09d335a47ca6"]
}, Open  ]]
}, Open  ]],

