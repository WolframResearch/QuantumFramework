Notebook[{

Cell[CellGroupData[{
Cell["IBMJob", "ObjectName",
 CellID->1224892054,ExpressionUUID->"8393d601-4014-44ba-afc9-60862df940ec"],

Cell[TextData[{
 Cell["   ", "ModInfo",ExpressionUUID->"7bb0e3ba-bd45-4c6b-a385-a9ad923b7b77"],
 Cell[BoxData[
  RowBox[{
   ButtonBox["IBMJob",
    BaseStyle->"Link",
    ButtonData->"paclet:Wolfram/QuantumFramework/ref/IBMJob"], "[", 
   StyleBox["assoc", "TI"], "]"}]], "InlineFormula",ExpressionUUID->
  "f9f5edf2-1aeb-4b6f-b592-f4cc296c48f7"],
 " ",
 "represents a job submitted to an IBM Quantum processing unit, carrying its \
identifier, backend and the raw service responses, with curated accessors \
layered on top.",
 "\n",
 Cell["   ", "ModInfo",ExpressionUUID->"dd3d6353-b15f-425d-87a8-db26d60070a6"],
 Cell[BoxData[
  RowBox[{
   RowBox[{"IBMJob", "[", 
    StyleBox["assoc", "TI"], "]"}], 
   "[", "\"\<\!\(\*StyleBox[\"prop\", \"TI\"]\)\>\"", "]"}]], "InlineFormula",
  ExpressionUUID->"bf1ef00c-0cc7-469d-a9a9-e955fedaee2b"],
 " ",
 "gives the value of the property ",
 StyleBox["\"prop\"", "TI"],
 ", such as ",
 Cell[BoxData["\"\<Status\>\""], "InlineFormula",ExpressionUUID->
  "42dbc8c3-9e8e-4844-9e36-4857421dff0d"],
 ", ",
 Cell[BoxData["\"\<Counts\>\""], "InlineFormula",ExpressionUUID->
  "2e83d457-b3de-4101-87df-59934bd47b20"],
 " or ",
 Cell[BoxData["\"\<QuantumSeconds\>\""], "InlineFormula",ExpressionUUID->
  "945b7895-9642-46c4-9c86-5d4793de0953"],
 ".",
 "\n",
 Cell["   ", "ModInfo",ExpressionUUID->"7a55ae30-af69-402e-98fb-90e6e09e4626"],
 Cell[BoxData[
  RowBox[{
   RowBox[{"IBMJob", "[", 
    StyleBox["assoc", "TI"], "]"}], "[", "]"}]], "InlineFormula",
  ExpressionUUID->"0b304b71-3575-4b94-b998-b56fe80270b7"],
 " ",
 "gives the primary result, the ",
 Cell[BoxData[
  ButtonBox["QuantumMeasurement",
   BaseStyle->"Link",
   ButtonData->"paclet:Wolfram/QuantumFramework/ref/QuantumMeasurement"]], 
  "InlineFormula",ExpressionUUID->"9cb82985-667e-4873-aade-13cdb6180969"],
 " reconstructed from the hardware counts."
}], "Usage",ExpressionUUID->"810d3e8c-3492-4e38-a801-d311f7357f87"],

Cell[TextData[{
 "An ",
 Cell[BoxData[
 "IBMJob"], "InlineFormula",ExpressionUUID->
  "85c5eb81-68eb-41ed-80c1-efb1ba20079f"],
 " is normally produced by ",
 Cell[BoxData[
  ButtonBox["IBMJobSubmit",
   BaseStyle->"Link",
   ButtonData->"paclet:Wolfram/QuantumFramework/ref/IBMJobSubmit"]], 
  "InlineFormula",ExpressionUUID->"45fd1494-bc95-4c9d-92a5-17ad8b81ff47"],
 " or by the ",
 Cell[BoxData[
  RowBox[{
   RowBox[{"QuantumCircuitOperator", "[", 
    StyleBox["circ", "TI"], "]"}], "[", 
   RowBox[{
    ButtonBox["Method",
     BaseStyle->"Link"], " ", "->", " ", 
    RowBox[{"{", 
     RowBox[{"\"\<Qiskit\>\"", ",", " ", 
      RowBox[{"\"\<Provider\>\"", " ", "->", " ", "\"\<IBMProvider\>\""}], ",",
       " ", "\[Ellipsis]"}], "}"}]}], "]"}]], "InlineFormula",ExpressionUUID->
  "1c68b4fc-f598-4e10-8bce-aa85fcf5538f"],
 " hardware path, not constructed by hand."
}], "Notes",ExpressionUUID->"b6c81431-180d-406b-a812-8bdc7bbb8f37"],

Cell[TextData[{
 "The object is a ",
 StyleBox["lossless",
  FontWeight->"Bold"],
 " carrier: the raw service responses are kept verbatim under ",
 Cell[BoxData["\"\<Raw\>\""], "InlineFormula",ExpressionUUID->
  "b6d7282e-d925-4479-ae9a-bc38a2e6c2da"],
 ", and every accessor reads from there, so no field the service returns is \
discarded."
}], "Notes",ExpressionUUID->"8e483b7d-3032-4515-a234-1756cc7fafc3"],

Cell[TextData[{
 "Accessors ",
 StyleBox["fetch lazily",
  FontWeight->"Bold"],
 ": a property reads from the stored snapshot when present, otherwise queries \
the service object. With no reachable connection an accessor gives ",
 Cell[BoxData[
  RowBox[{"Missing", "[", "\"\<NoConnection\>\"", "]"}]], "InlineFormula",
  ExpressionUUID->"e00bad6f-307c-4c57-85d7-30591b69f439"],
 "; before the job is ",
 Cell[BoxData["\"\<Completed\>\""], "InlineFormula",ExpressionUUID->
  "3dcd33bb-2d82-4e07-9c96-f3c3fd115886"],
 " the result accessors give ",
 Cell[BoxData[
  RowBox[{"Missing", "[", 
   RowBox[{"\"\<JobNotComplete\>\"", ","}]}]], "InlineFormula",ExpressionUUID->
  "d3cb159e-e9c1-4ce9-8303-4e210d9ea810"],
 StyleBox["status", "TI"],
 Cell[BoxData["]"], "InlineFormula",ExpressionUUID->
  "5ddeec5a-fc66-4a34-9f90-58bb1dfc97ac"],
 "."
}], "Notes",ExpressionUUID->"04a3e8cd-4628-43bc-b091-8ae0c53565c4"],

Cell[TextData[{
 Cell[BoxData["\"\<Status\>\""], "InlineFormula",ExpressionUUID->
  "e1c52e03-4710-4931-af03-719aaa2b3b7a"],
 " is one of ",
 Cell[BoxData["\"\<Queued\>\""], "InlineFormula",ExpressionUUID->
  "2fc2256e-6c81-4ac1-a946-efe3015c1d13"],
 ", ",
 Cell[BoxData["\"\<Validating\>\""], "InlineFormula",ExpressionUUID->
  "99aa93e8-f06b-4757-8fc3-52bc195055bf"],
 ", ",
 Cell[BoxData["\"\<Initializing\>\""], "InlineFormula",ExpressionUUID->
  "8a11a4cb-3c9c-4f1d-b6d3-e25f4369ae83"],
 ", ",
 Cell[BoxData["\"\<Running\>\""], "InlineFormula",ExpressionUUID->
  "ceafd0cd-271a-48c4-b300-a89fe45de56e"],
 ", ",
 Cell[BoxData["\"\<Completed\>\""], "InlineFormula",ExpressionUUID->
  "f73882c1-21f2-4b36-af9a-b75a150273c9"],
 ", ",
 Cell[BoxData["\"\<Cancelled\>\""], "InlineFormula",ExpressionUUID->
  "b13720f1-3db8-4c96-9a9c-80798d5a9e58"],
 " or ",
 Cell[BoxData["\"\<Failed\>\""], "InlineFormula",ExpressionUUID->
  "3ce328d9-4399-4af3-9f12-227836d506d2"],
 "; the terminal statuses are ",
 Cell[BoxData["\"\<Completed\>\""], "InlineFormula",ExpressionUUID->
  "b8ad8bae-e7aa-4c06-9661-99439c8f86dd"],
 ", ",
 Cell[BoxData["\"\<Cancelled\>\""], "InlineFormula",ExpressionUUID->
  "d4bb5de9-3130-43ae-b9d8-4cf9b0ac82b4"],
 " and ",
 Cell[BoxData["\"\<Failed\>\""], "InlineFormula",ExpressionUUID->
  "40383fb4-7744-4121-a734-809ffd65533a"],
 "."
}], "Notes",ExpressionUUID->"91b5d661-e75a-4685-b409-aa52e6be0722"],

Cell[TextData[{
 "The hardware counts decode into the Wolfram Language qubit order (ascending \
qubit) using the ",
 Cell[BoxData["\"\<MeasuredQubits\>\""], "InlineFormula",ExpressionUUID->
  "26e3a3f2-26de-48b8-9488-b442110908de"],
 " map (classical bit to original qubit) captured at submission time, so a \
permuted or partial measurement and any backend layout decode correctly."
}], "Notes",ExpressionUUID->"88a0c044-ac84-4660-8540-918c2779935d"],

Cell[TextData[{
 Cell[BoxData[
  RowBox[{"IBMJob", "["}]], "InlineFormula",ExpressionUUID->
  "bd89935b-998e-4b0e-9dae-11b9b794f5d7"],
 StyleBox["assoc", "TI"],
 Cell[BoxData[
  RowBox[{"]", 
   RowBox[{"[", "\"\<Refresh\>\"", "]"}]}]], "InlineFormula",ExpressionUUID->
  "d79bdf8f-4c52-4442-944d-5d7b2f3c9467"],
 " re-queries the service and gives a ",
 StyleBox["new",
  FontWeight->"Bold"],
 " ",
 Cell[BoxData[
 "IBMJob"], "InlineFormula",ExpressionUUID->
  "61ba8fb0-f205-4058-9d81-941fc49085ed"],
 " with an updated ",
 Cell[BoxData["\"\<Raw\>\""], "InlineFormula",ExpressionUUID->
  "ebc247f7-79ce-4ae7-a755-e7158528ce20"],
 " snapshot; once the job is ",
 Cell[BoxData["\"\<Completed\>\""], "InlineFormula",ExpressionUUID->
  "c6bb678e-9c6d-4e82-ba8a-861fa0c65860"],
 " it also pulls the results and metrics. ",
 Cell[BoxData[
  RowBox[{"IBMJob", "["}]], "InlineFormula",ExpressionUUID->
  "1bad91c6-b4a4-4d19-a10b-03150a0c30fb"],
 StyleBox["assoc", "TI"],
 Cell[BoxData[
  RowBox[{"]", 
   RowBox[{"[", "\"\<Cancel\>\"", "]"}]}]], "InlineFormula",ExpressionUUID->
  "176fc94a-bcf7-445e-8a2a-b34804f9f0df"],
 " requests cancellation."
}], "Notes",ExpressionUUID->"60611615-d97e-4141-b190-1a13049357cd"],

Cell[TextData[{
 "An unknown property name gives a ",
 Cell[BoxData[
  ButtonBox["Failure",
   BaseStyle->"Link",
   ButtonData->"paclet:ref/Failure"]], "InlineFormula",ExpressionUUID->
  "5b723aeb-f290-4145-84c3-6c2fdc0a72b4"],
 " listing the valid properties (see Possible Issues)."
}], "Notes",ExpressionUUID->"22ee2508-aa60-46c6-813c-3d3ae440645c"],

Cell[TextData[{
 "The summary box shows the status (with a colored indicator), the backend \
and the job id; once ",
 Cell[BoxData["\"\<Completed\>\""], "InlineFormula",ExpressionUUID->
  "cd76875f-f3f1-4bb4-8ea3-ff701c00d4d1"],
 " it also shows the qubit count, shot count and quantum-processing time."
}], "Notes",ExpressionUUID->"52077027-27af-4c84-b674-b5e9747446da"],

Cell[TextData[{
 "The full property list (",
 Cell[BoxData[
  RowBox[{"IBMJob", "["}]], "InlineFormula",ExpressionUUID->
  "c51eae3c-a986-4bb8-873b-6cce1614ebfb"],
 StyleBox["assoc", "TI"],
 Cell[BoxData[
  RowBox[{"]", 
   RowBox[{"[", "\"\<Properties\>\"", "]"}]}]], "InlineFormula",
  ExpressionUUID->"5a0cfaab-5c7f-4b6d-b633-088c9ace7bf6"],
 "):"
}], "Notes",ExpressionUUID->"95bd6739-5e68-44cb-9156-e66db101590d"],

