Cell[TextData[{
 "An unknown property gives a ",
 Cell[BoxData[
  ButtonBox["Failure",
   BaseStyle->"Link",
   ButtonData->"paclet:ref/Failure"]], "InlineFormula",ExpressionUUID->
  "136f26cf-f807-4f9f-8249-4abf0288b49a"],
 " listing the valid property names:"
}], "ExampleText",ExpressionUUID->"a055344b-d356-4d26-83c6-82dc85bb0593"],

Cell["job[\"Frobnicate\"]", "Program",ExpressionUUID->"243b207d-08c8-4c1c-96b8-17562c4da744"],

Cell["\t", "ExampleDelimiter",ExpressionUUID->"5de804b2-621f-430d-a602-5cd6995040b6"],

Cell[TextData[{
 Cell[BoxData["\"\<ExecutedCircuit\>\""], "InlineFormula",ExpressionUUID->
  "d6c7f1eb-b566-4b46-9b7a-8493c69c67c8"],
 " downloads the server-side transpiled circuit, which IBM stores only when \
the Runtime transpiles server-side. A circuit submitted already in ISA form \
to the V2 primitives stores none, so the request gives a ",
 Cell[BoxData[
  ButtonBox["Failure",
   BaseStyle->"Link",
   ButtonData->"paclet:ref/Failure"]], "InlineFormula",ExpressionUUID->
  "6a924605-269c-4b18-8024-d8e03e43ced3"],
 " rather than a circuit:"
}], "ExampleText",ExpressionUUID->"a3c1b5c6-f7c9-43e3-9e70-7710cc29379a"],

Cell["job[\"ExecutedCircuit\"]", "Program",ExpressionUUID->"b9b8da36-a567-4441-b6fa-c4a18bd40d20"],

Cell["\t", "ExampleDelimiter",ExpressionUUID->"32f67693-17ce-4972-8407-73a469d2b051"],

Cell[TextData[{
 "When the transpiled-circuit object does exist, IBM serves it from a Cloud \
Object Storage direct endpoint (host starting ",
 Cell[BoxData[
  RowBox[{"s3", ".", "direct"}]], "InlineFormula",ExpressionUUID->
  "31f7a6c7-9c33-409f-b4e1-d1fca8dff9d9"],
 ") reachable only from inside IBM Cloud, so the download from elsewhere \
gives a ",
 Cell[BoxData[
  ButtonBox["Failure",
   BaseStyle->"Link",
   ButtonData->"paclet:ref/Failure"]], "InlineFormula",ExpressionUUID->
  "858a16c5-0fbe-4eb6-9347-13e725f9bdb3"],
 " instead of timing out silently:"
}], "ExampleText",ExpressionUUID->"2c3ecd17-8c1c-4d3f-ae35-a9312e48b482"],

Cell["job[\"ExecutedCircuit\"]", "Program",ExpressionUUID->"fa5be19f-62c7-4131-b35e-f4385d0e7def"]
}, Open  ]]
}, Open  ]],

