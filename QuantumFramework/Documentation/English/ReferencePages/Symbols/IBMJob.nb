Notebook[{

Cell[CellGroupData[{
Cell["IBMJob", "ObjectName",
 CellID->1224892054,ExpressionUUID->"8393d601-4014-44ba-afc9-60862df940ec"],

Cell[TextData[{
 Cell["   ", "ModInfo",ExpressionUUID->"78ccd421-025e-47f5-b3dc-e00a6e010e2e"],
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     Cell[
      TextData["IBMJob"]], "paclet:Wolfram/QuantumFramework/ref/IBMJob", 
     "Wolfram/QuantumFramework Package Symbol"},
    "PackageLink",
    BaseStyle->"InlineFormula"], "[", 
   StyleBox["assoc", "TI"], "]"}]], "InlineFormula",ExpressionUUID->
  "ea600e94-3406-4bea-b305-9c5fa7a5c6b6"],
 " ",
 "represents a job submitted to an IBM Quantum processing unit, carrying its \
identifier, backend and the raw service responses, with curated accessors \
layered on top.",
 "\n",
 Cell["   ", "ModInfo",ExpressionUUID->"8970f20c-1d3f-46aa-9b5d-d61dabc5360d"],
 Cell[BoxData[
  RowBox[{
   RowBox[{"IBMJob", "[", 
    StyleBox["assoc", "TI"], "]"}], "[", "]"}]], "InlineFormula",
  ExpressionUUID->"65319163-8ed8-4c19-b328-86d090ac0707"],
 " ",
 "gives the primary result: the ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["QuantumMeasurement"]], 
    "paclet:Wolfram/QuantumFramework/ref/QuantumMeasurement", 
    "Wolfram/QuantumFramework Package Symbol"},
   "PackageLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",ExpressionUUID->
  "2cd34e65-a5ec-4aaf-8f6b-0c25b204d113"],
 " reconstructed from the hardware counts for a sampler job, or the \
observable's expectation value for an estimator job."
}], "Usage",ExpressionUUID->"84df8c64-d760-45fd-bb3e-56de63ff7c8f"],

Cell[TextData[{
 "An ",
 Cell[BoxData["IBMJob"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "0d75299f-2637-42af-87e6-5f259c4bd921"],
 " is normally produced by ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["IBMJobSubmit"]], 
    "paclet:Wolfram/QuantumFramework/ref/IBMJobSubmit", 
    "Wolfram/QuantumFramework Package Symbol"},
   "PackageLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",ExpressionUUID->
  "57093ba9-3ca6-4cf9-bbf5-0d03991ca480"],
 " or by the ",
 Cell[BoxData[
  RowBox[{
   RowBox[{"QuantumCircuitOperator", "[", 
    StyleBox["circ", "TI"], "]"}], "[", 
   RowBox[{
    ButtonBox["Method",
     BaseStyle->"Link"], " ", "->", " ", 
    RowBox[{"{", 
     RowBox[{"\"\<Qiskit\>\"", ",", " ", 
      RowBox[{"\"\<Provider\>\"", " ", "->", " ", "\"\<IBMProvider\>\""}], ",",
       " ", "\[Ellipsis]"}], "}"}]}], "]"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "bea4b1ab-d308-4ecc-809a-ea3fc3286a18"],
 " hardware path, not constructed by hand."
}], "Notes",ExpressionUUID->"0f68db9c-5836-4d83-a84e-f94369437bfd"],

Cell[TextData[{
 "The object is a ",
 StyleBox["lossless",
  FontWeight->"Bold"],
 " carrier: the raw service responses are kept verbatim under ",
 Cell[BoxData["\"\<Raw\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "d9e755f1-c716-42af-a4b6-1a64d9e782f0"],
 ", and every accessor reads from there, so no field the service returns is \
discarded."
}], "Notes",ExpressionUUID->"7256eba8-2c03-46b1-9a08-1f7638ce0f76"],

Cell[TextData[{
 "Accessors ",
 StyleBox["fetch lazily",
  FontWeight->"Bold"],
 ": a property reads from the stored snapshot when present, otherwise queries \
the service object. With no reachable connection an accessor gives ",
 Cell[BoxData[
  RowBox[{"Missing", "[", "\"\<NoConnection\>\"", "]"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "eb9eee7a-dd27-4df8-8333-de868cbaad7f"],
 "; before the job is ",
 Cell[BoxData["\"\<Completed\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "73e6810d-aeea-4fb2-931e-3bb817e66d22"],
 " the result accessors give ",
 Cell[BoxData[
  RowBox[{"Missing", "[", 
   RowBox[{"\"\<JobNotComplete\>\"", ","}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "bbb19a17-767a-4e3f-be43-ce40111096ac"],
 StyleBox["status", "TI"],
 Cell[BoxData["]"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "7e5f0f91-1d59-432d-ab23-958526fbae80"],
 "."
}], "Notes",ExpressionUUID->"c73e10c4-1fe7-4677-824a-4b1ef846ab82"],

Cell[TextData[{
 Cell[BoxData["\"\<Status\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "9820a845-47bc-47b1-bcd2-87f31d04a998"],
 " is one of ",
 Cell[BoxData["\"\<Queued\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "df4131d5-a979-4dae-b0db-4fb17515d966"],
 ", ",
 Cell[BoxData["\"\<Validating\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "09d21602-a23e-41db-980b-e3d4665f6ea9"],
 ", ",
 Cell[BoxData["\"\<Initializing\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "8221a736-6a54-4f11-99a2-ee5e22421925"],
 ", ",
 Cell[BoxData["\"\<Running\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "912e1faf-b6de-4096-811b-0bff08544e46"],
 ", ",
 Cell[BoxData["\"\<Completed\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "9e9f1817-4637-462a-b484-3dc8ec54241f"],
 ", ",
 Cell[BoxData["\"\<Cancelled\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "e6972323-8142-4726-b9e1-de82d5e53503"],
 " or ",
 Cell[BoxData["\"\<Failed\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "1dcb2321-e578-46ad-82e6-860c4e8ee45d"],
 "; the terminal statuses are ",
 Cell[BoxData["\"\<Completed\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "ae9160b9-eb96-4ac1-b108-0d44a024c628"],
 ", ",
 Cell[BoxData["\"\<Cancelled\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "f9befa4b-a215-463a-9fad-fdb23b1b1224"],
 " and ",
 Cell[BoxData["\"\<Failed\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "6c27a7d7-c914-48e9-8559-3ca6a448f998"],
 "."
}], "Notes",ExpressionUUID->"dedc54f3-372e-4280-a444-dc55d9b45994"],

Cell[TextData[{
 "The hardware counts decode into the Wolfram Language qubit order (ascending \
qubit) using the ",
 Cell[BoxData["\"\<MeasuredQubits\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "c1e0b231-1b26-49fe-83e9-0d839c4526cb"],
 " map (classical bit to original qubit) captured at submission time, so a \
permuted or partial measurement and any backend layout decode correctly."
}], "Notes",ExpressionUUID->"0c45c236-c85d-4bb5-b740-26db95f920f4"],

Cell[TextData[{
 "The handle exposes two kinds of names. ",
 StyleBox["Properties",
  FontWeight->"Bold"],
 " (",
 Cell[BoxData[
  RowBox[{"IBMJob", "["}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "8cc74364-b627-4867-8b1d-f000e74b6620"],
 StyleBox["assoc", "TI"],
 Cell[BoxData[
  RowBox[{"]", 
   RowBox[{"[", "\"\<Properties\>\"", "]"}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "f577b32a-97f6-4242-8d5e-86e525f20b7c"],
 ") are local accessors that read the cached snapshot and never touch the \
network, so a bulk map over them is fast and has no side effects. ",
 StyleBox["Actions",
  FontWeight->"Bold"],
 " (",
 Cell[BoxData[
  RowBox[{"IBMJob", "["}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "34fb73f2-ae22-44fe-ab1e-ac255adea045"],
 StyleBox["assoc", "TI"],
 Cell[BoxData[
  RowBox[{"]", 
   RowBox[{"[", "\"\<Actions\>\"", "]"}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "4e2d047f-40d8-4525-931f-6fff5e234455"],
 ") each require a live connection and are kept out of the property list, so \
that map never re-queries, cancels or blocks on a remote fetch; each is still \
callable by name. ",
 Cell[BoxData[
  RowBox[{"IBMJob", "["}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "cbebe62f-1f66-4994-8142-3eaa7b08aa9f"],
 StyleBox["assoc", "TI"],
 Cell[BoxData[
  RowBox[{"]", 
   RowBox[{"[", "\"\<Refresh\>\"", "]"}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "8e8c5544-4a77-4d98-8e7f-4b24cbb4980b"],
 " re-queries the service and gives a ",
 StyleBox["new",
  FontWeight->"Bold"],
 " ",
 Cell[BoxData["IBMJob"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "5f7ffabb-f427-460b-8083-56f507682857"],
 " with an updated ",
 Cell[BoxData["\"\<Raw\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "ed6bd194-cc8c-4f87-bf8b-945ffb5b477e"],
 " snapshot (once ",
 Cell[BoxData["\"\<Completed\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "ec231d23-a184-4eb5-905b-036d0ad9a7f9"],
 " it also pulls the results and metrics, and for an estimator job caches the \
qiskit-decoded expectation values); ",
 Cell[BoxData[
  RowBox[{"IBMJob", "["}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "118e1b2e-43f5-4e9b-b98b-9a27caee5db6"],
 StyleBox["assoc", "TI"],
 Cell[BoxData[
  RowBox[{"]", 
   RowBox[{"[", "\"\<Cancel\>\"", "]"}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "5a312e40-dac8-48b4-b405-c90555730c44"],
 " requests cancellation; ",
 Cell[BoxData[
  RowBox[{"IBMJob", "["}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "7643b88c-e237-4057-960d-6b24019de8ff"],
 StyleBox["assoc", "TI"],
 Cell[BoxData[
  RowBox[{"]", 
   RowBox[{"[", "\"\<ExecutedCircuit\>\"", "]"}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "3055645d-4b3c-4e14-b01e-5d95fb204372"],
 " downloads the server-side transpiled circuit (see Possible Issues)."
}], "Notes",ExpressionUUID->"5d3cff0f-3eb6-4c98-9212-175f96328fed"],

Cell[TextData[{
 "The result accessors are primitive-specific. For a ",
 StyleBox["sampler",
  FontWeight->"Bold"],
 " job the live accessors are ",
 Cell[BoxData["\"\<Counts\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "7e82047a-17e5-4577-aa77-329d5d810d57"],
 ", ",
 Cell[BoxData["\"\<Measurement\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "7b916f31-c37b-46bf-9c39-3b2d9fc9fed6"],
 ", ",
 Cell[BoxData["\"\<Probabilities\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "7df80e2c-590a-4b57-af2a-470c513bd98b"],
 ", ",
 Cell[BoxData["\"\<Samples\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "8cc26b2b-22f4-4eab-9d70-6ebb87de4360"],
 ", ",
 Cell[BoxData["\"\<NumBits\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "c9ceaf45-59ab-4168-a640-48efc589f6a7"],
 " and ",
 Cell[BoxData["\"\<Shots\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "cc397396-24ad-4fee-9cbd-eb3f81819397"],
 "; for an ",
 StyleBox["estimator",
  FontWeight->"Bold"],
 " job they are ",
 Cell[BoxData["\"\<ExpectationValue\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "8e37e94f-237f-4be6-9cba-230574dd8259"],
 ", ",
 Cell[BoxData["\"\<ExpectationValues\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "9b6e18a1-1d53-41a1-bf1d-57a6ea794291"],
 " and ",
 Cell[BoxData["\"\<StandardErrors\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "78db5d28-848d-499f-a8e2-d1dbb284b161"],
 ". An accessor that does not apply to the job's primitive gives ",
 Cell[BoxData[
  RowBox[{"Missing", "[", 
   RowBox[{"\"\<NotApplicable\>\"", ","}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "618011b0-13af-4103-a393-d8af92e21af4"],
 StyleBox["primitive", "TI"],
 Cell[BoxData["]"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "86de9e9b-df81-4989-abc6-485059cce4d4"],
 "."
}], "Notes",ExpressionUUID->"be888f52-ea29-4e95-bdde-72b32358fdb5"],

Cell[TextData[{
 "An unknown property name gives a ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["Failure"]], "paclet:ref/Failure"},
   "RefLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",ExpressionUUID->
  "d0346c46-40c5-47d5-9b94-57c1ebe93d53"],
 " listing the valid properties (see Possible Issues)."
}], "Notes",ExpressionUUID->"d0b5472a-0fbf-461f-b31d-cb8486f892a7"],

Cell[TextData[{
 "The summary box shows the status (with a colored indicator), the backend \
and the job id; once ",
 Cell[BoxData["\"\<Completed\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "25f6b9e7-e6c2-4b65-ba2d-d6e949ed1e0b"],
 " a sampler job also shows the qubit count, shot count and \
quantum-processing time, and an estimator job shows the expectation value and \
quantum-processing time."
}], "Notes",ExpressionUUID->"d17de36a-d525-47c0-8615-5bdd563bde39"],

Cell[TextData[{
 "The data properties (",
 Cell[BoxData[
  RowBox[{"IBMJob", "["}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "5982c9a4-c247-4a0e-85b1-226eb58b753b"],
 StyleBox["assoc", "TI"],
 Cell[BoxData[
  RowBox[{"]", 
   RowBox[{"[", "\"\<Properties\>\"", "]"}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "97d238ce-a41c-434b-9599-909956a69c87"],
 "), each read from the cached snapshot with no network access:"
}], "Notes",ExpressionUUID->"40beae4f-ad30-4c3b-bfd3-248017c66dd1"],

