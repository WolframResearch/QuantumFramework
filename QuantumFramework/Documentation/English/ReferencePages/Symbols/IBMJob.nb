      "a4f5fd32-196b-4d27-b469-3b1ef5804a78"]
    }], "TableText",ExpressionUUID->"97d734c9-7021-429c-a408-80843a61a9ee"]},
   {Cell["      ", "ModInfo",ExpressionUUID->
     "b989324b-a9b0-4883-9d11-bc06385e0690"], Cell[TextData[Cell[
    BoxData["\"\<Cost\>\""], "InlineFormula",
     FontSize->0.9 Inherited,ExpressionUUID->
     "a77d8436-a8e9-4339-b254-3fa97f24c2be"]], "TableText",ExpressionUUID->
     "02c8194b-50ed-4e78-8d58-bce05e89c26a"], Cell[
    "the reserved cost, in seconds", "TableText",ExpressionUUID->
     "0702642d-e2b4-487b-a686-d34b24c21bce"]},
   {Cell["      ", "ModInfo",ExpressionUUID->
     "78963844-92f4-48ca-b529-2d66179e1a6f"], Cell[TextData[Cell[
    BoxData["\"\<EstimatedRunTime\>\""], "InlineFormula",
     FontSize->0.9 Inherited,ExpressionUUID->
     "00313152-2660-49d7-9930-11927b05a8e5"]], "TableText",ExpressionUUID->
     "1f150d7d-78dd-4967-b3b3-ea405f206020"], Cell[
    "the estimated running time, in seconds", "TableText",ExpressionUUID->
     "e8ce8246-b669-4e0f-84a2-2fc813c3fb90"]},
