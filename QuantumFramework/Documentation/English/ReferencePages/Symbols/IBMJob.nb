Cell["\<\
The complete raw service responses are kept verbatim; ask for a single \
section by name:\
\>", "ExampleText",ExpressionUUID->"fa2512cb-c082-47a7-a1a8-b6e68b94cc32"],

Cell[BoxData[
 RowBox[{"Keys", " ", "@", " ", 
  RowBox[{"job", "[", "\"\<Raw\>\"", "]"}]}]], "Input",ExpressionUUID->\
