 Cell[BoxData[
  ButtonBox["Failure",
   BaseStyle->"Link",
   ButtonData->"paclet:ref/Failure"]], "InlineFormula",ExpressionUUID->
  "3888411b-434e-4654-8482-4456c8aabfb9"],
 " listing the valid data properties and actions:"
}], "ExampleText",ExpressionUUID->"04330d56-cb01-4f19-ab7a-5d2171cc7fae"],

Cell[BoxData[
 RowBox[{"job", "[", "\"\<Frobnicate\>\"", "]"}]], "Input",ExpressionUUID->"61f3d740-949c-4f4b-bae6-9c5033613adc"],

Cell["\t", "ExampleDelimiter",ExpressionUUID->"f472ba71-9493-405d-be3d-30294bdf65a3"],

Cell[TextData[{
 Cell[BoxData["\"\<ExecutedCircuit\>\""], "InlineFormula",ExpressionUUID->
  "4a1e1b95-a261-4eb8-b666-f33f881ee35d"],
 " downloads the server-side transpiled circuit, which IBM stores only when \
the Runtime transpiles server-side. A circuit submitted already in ISA form \
to the V2 primitives stores none, so the request gives a ",
 Cell[BoxData[
  ButtonBox["Failure",
   BaseStyle->"Link",
   ButtonData->"paclet:ref/Failure"]], "InlineFormula",ExpressionUUID->
  "fc0e5673-cf49-4022-98b6-ffb899edf15b"],
 " rather than a circuit:"
}], "ExampleText",ExpressionUUID->"6d9fc826-2ed3-49a7-9e26-e88080b0e52a"],

Cell[BoxData[
 RowBox[{"job", "[", "\"\<ExecutedCircuit\>\"", "]"}]], "Input",ExpressionUUID->"dc3e663e-7202-4f95-aabe-21e4f4f8b1a3"],

Cell["\t", "ExampleDelimiter",ExpressionUUID->"5c3fbd56-e032-4055-b3cb-df78afdd68c4"],

Cell[TextData[{
 "When the transpiled-circuit object does exist, IBM serves it from a Cloud \
Object Storage direct endpoint (host starting ",
 Cell[BoxData[
  RowBox[{"s3", ".", "direct"}]], "InlineFormula",ExpressionUUID->
  "2ffd3b5e-8e9d-4362-902f-6df34ee583f5"],
 ") reachable only from inside IBM Cloud, so the download from elsewhere \
gives a ",
 Cell[BoxData[
  ButtonBox["Failure",
   BaseStyle->"Link",
   ButtonData->"paclet:ref/Failure"]], "InlineFormula",ExpressionUUID->
  "7e11ac4c-93e2-4ed9-82c4-87ff8275a6ba"],
 " instead of timing out silently:"
}], "ExampleText",ExpressionUUID->"35b13b1e-8537-4a6c-a267-d2c5baeb83ca"],

Cell[BoxData[
 RowBox[{"job", "[", "\"\<ExecutedCircuit\>\"", "]"}]], "Input",ExpressionUUID->"e4c3bfa0-dfe7-4147-a7b8-aedd06d64009"]
}, Open  ]]
}, Open  ]],

