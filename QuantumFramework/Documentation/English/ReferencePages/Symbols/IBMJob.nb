order:\
\>", "ExampleText",ExpressionUUID->"e586f985-3af4-4f0d-9bc9-3fa9cd2d136d"],

Cell[BoxData[
 RowBox[{"job", "[", "\"\<MeasuredQubits\>\"", "]"}]], "Input",ExpressionUUID->"c7279206-5404-460b-a78d-e8fe1c411877"],

Cell["\t", "ExampleDelimiter",ExpressionUUID->"fcd97449-0237-4f55-a72d-9795556a811d"],

Cell["\<\
