Notebook[{

Cell[CellGroupData[{
Cell["IBMJob", "ObjectName",
 CellID->1224892054,ExpressionUUID->"8393d601-4014-44ba-afc9-60862df940ec"],

Cell[TextData[{
 Cell["   ", "ModInfo",ExpressionUUID->"afc0abac-ffa3-4fc0-9552-1537f54ba191"],
 Cell[BoxData[
  RowBox[{
   ButtonBox["IBMJob",
    BaseStyle->"Link",
    ButtonData->"paclet:Wolfram/QuantumFramework/ref/IBMJob"], "[", 
   StyleBox["assoc", "TI"], "]"}]], "InlineFormula",ExpressionUUID->
  "98ba8c0a-8377-4657-936a-e6837eb2cc12"],
 " ",
 "represents a job submitted to an IBM Quantum processing unit, carrying its \
identifier, backend and the raw service responses, with curated accessors \
layered on top.",
 "\n",
 Cell["   ", "ModInfo",ExpressionUUID->"36d7b713-6e28-4799-8542-ad788b765ef5"],
 Cell[BoxData[
  RowBox[{
   RowBox[{"IBMJob", "[", 
    StyleBox["assoc", "TI"], "]"}], 
   "[", "\"\<\!\(\*StyleBox[\"prop\", \"TI\"]\)\>\"", "]"}]], "InlineFormula",
  ExpressionUUID->"351bd936-5da9-4c37-bb34-b8aabb5b349a"],
 " ",
 "gives the value of the property ",
 StyleBox["\"prop\"", "TI"],
 ", such as ",
 Cell[BoxData["\"\<Status\>\""], "InlineFormula",ExpressionUUID->
  "469591f2-3b2e-49b5-9ce8-08c1cc1471c0"],
 ", ",
 Cell[BoxData["\"\<Counts\>\""], "InlineFormula",ExpressionUUID->
  "70931fd5-3e3e-485b-a0a1-7e38ecd93506"],
 " or ",
 Cell[BoxData["\"\<QuantumSeconds\>\""], "InlineFormula",ExpressionUUID->
  "04e7fe00-4cf2-461c-9e11-bf8406f82c49"],
 ".",
 "\n",
 Cell["   ", "ModInfo",ExpressionUUID->"e10105c1-bd6f-4466-afe3-cd3438e204ba"],
 Cell[BoxData[
  RowBox[{
   RowBox[{"IBMJob", "[", 
    StyleBox["assoc", "TI"], "]"}], "[", "]"}]], "InlineFormula",
  ExpressionUUID->"44fe7c34-fdf0-4bd6-a0f7-650433cbfb06"],
 " ",
 "gives the primary result: the ",
 Cell[BoxData[
  ButtonBox["QuantumMeasurement",
   BaseStyle->"Link",
   ButtonData->"paclet:Wolfram/QuantumFramework/ref/QuantumMeasurement"]], 
  "InlineFormula",ExpressionUUID->"22af686c-e18c-4cc8-aa68-ab55b471944c"],
 " reconstructed from the hardware counts for a sampler job, or the \
observable's expectation value for an estimator job."
}], "Usage",ExpressionUUID->"aee0dc0a-5f57-4185-b6a9-7a0470a17440"],

Cell[TextData[{
 "An ",
 Cell[BoxData[
 "IBMJob"], "InlineFormula",ExpressionUUID->
  "6566d4ab-f958-4f60-9206-a503b9455b75"],
 " is normally produced by ",
 Cell[BoxData[
  ButtonBox["IBMJobSubmit",
   BaseStyle->"Link",
   ButtonData->"paclet:Wolfram/QuantumFramework/ref/IBMJobSubmit"]], 
  "InlineFormula",ExpressionUUID->"94b42d22-52e9-4dfc-8702-45ada244020f"],
 " or by the ",
 Cell[BoxData[
  RowBox[{
   RowBox[{"QuantumCircuitOperator", "[", 
    StyleBox["circ", "TI"], "]"}], "[", 
   RowBox[{
    ButtonBox["Method",
     BaseStyle->"Link"], " ", "->", " ", 
    RowBox[{"{", 
     RowBox[{"\"\<Qiskit\>\"", ",", " ", 
      RowBox[{"\"\<Provider\>\"", " ", "->", " ", "\"\<IBMProvider\>\""}], ",",
       " ", "\[Ellipsis]"}], "}"}]}], "]"}]], "InlineFormula",ExpressionUUID->
  "980ca824-5d53-4ede-aee1-55003a23af76"],
 " hardware path, not constructed by hand."
}], "Notes",ExpressionUUID->"a2b988c6-517f-4855-a505-d5dc8026a236"],

Cell[TextData[{
 "The object is a ",
 StyleBox["lossless",
  FontWeight->"Bold"],
 " carrier: the raw service responses are kept verbatim under ",
 Cell[BoxData["\"\<Raw\>\""], "InlineFormula",ExpressionUUID->
  "569e79c8-cb9a-4a10-89b1-2fa41c924992"],
 ", and every accessor reads from there, so no field the service returns is \
discarded."
}], "Notes",ExpressionUUID->"9a9e05d1-02b9-4627-a699-a294313c9f29"],

Cell[TextData[{
 "Accessors ",
 StyleBox["fetch lazily",
  FontWeight->"Bold"],
 ": a property reads from the stored snapshot when present, otherwise queries \
the service object. With no reachable connection an accessor gives ",
 Cell[BoxData[
  RowBox[{"Missing", "[", "\"\<NoConnection\>\"", "]"}]], "InlineFormula",
  ExpressionUUID->"bcb6c09a-667c-460c-9d1f-8b0fc3b6d268"],
 "; before the job is ",
 Cell[BoxData["\"\<Completed\>\""], "InlineFormula",ExpressionUUID->
  "1ba1a3fa-de71-41c9-8379-70fc0c4ad666"],
 " the result accessors give ",
 Cell[BoxData[
  RowBox[{"Missing", "[", 
   RowBox[{"\"\<JobNotComplete\>\"", ","}]}]], "InlineFormula",ExpressionUUID->
  "c8690381-9d21-4473-aca0-687b6756595c"],
 StyleBox["status", "TI"],
 Cell[BoxData["]"], "InlineFormula",ExpressionUUID->
  "65943adf-de28-4e6b-9390-21a0c1211c21"],
 "."
}], "Notes",ExpressionUUID->"6c74774e-c312-4d51-9c0c-23ffaa188ca5"],

Cell[TextData[{
 Cell[BoxData["\"\<Status\>\""], "InlineFormula",ExpressionUUID->
  "28ed76ab-72eb-4560-b249-5b60eab17172"],
 " is one of ",
 Cell[BoxData["\"\<Queued\>\""], "InlineFormula",ExpressionUUID->
  "436eee52-8f27-41e4-b8e6-556ef973268c"],
 ", ",
 Cell[BoxData["\"\<Validating\>\""], "InlineFormula",ExpressionUUID->
  "fd91c357-6014-486a-8759-2d37d1e8cbc6"],
 ", ",
 Cell[BoxData["\"\<Initializing\>\""], "InlineFormula",ExpressionUUID->
  "443719d0-1589-464c-9e95-d242584ae85c"],
 ", ",
 Cell[BoxData["\"\<Running\>\""], "InlineFormula",ExpressionUUID->
  "b4784e37-ef86-4095-9f57-fd46b40d196d"],
 ", ",
 Cell[BoxData["\"\<Completed\>\""], "InlineFormula",ExpressionUUID->
  "eb93199e-6b00-4458-91fb-f19f476f2c0d"],
 ", ",
 Cell[BoxData["\"\<Cancelled\>\""], "InlineFormula",ExpressionUUID->
  "df05a4a7-8d35-4a67-bd36-3796f2bd1935"],
 " or ",
 Cell[BoxData["\"\<Failed\>\""], "InlineFormula",ExpressionUUID->
  "f62b9c58-9774-4bcc-9cc9-36b45c4d3cc1"],
 "; the terminal statuses are ",
 Cell[BoxData["\"\<Completed\>\""], "InlineFormula",ExpressionUUID->
  "9863f909-a3d5-4686-a6cf-3296c7a98116"],
 ", ",
 Cell[BoxData["\"\<Cancelled\>\""], "InlineFormula",ExpressionUUID->
  "dfd68c2a-6ba9-4c5d-bca3-198ccb783851"],
 " and ",
 Cell[BoxData["\"\<Failed\>\""], "InlineFormula",ExpressionUUID->
  "a3866c77-cb53-45a3-8b23-562c16153504"],
 "."
}], "Notes",ExpressionUUID->"65a07c1f-9c64-49ca-86e6-98a6ff91abca"],

Cell[TextData[{
 "The hardware counts decode into the Wolfram Language qubit order (ascending \
qubit) using the ",
 Cell[BoxData["\"\<MeasuredQubits\>\""], "InlineFormula",ExpressionUUID->
  "7d5e1251-d585-4280-81d1-bc35fdc441a8"],
 " map (classical bit to original qubit) captured at submission time, so a \
permuted or partial measurement and any backend layout decode correctly."
}], "Notes",ExpressionUUID->"00d1e354-339a-48d6-8d8c-8175fe446b02"],

Cell[TextData[{
 "The handle exposes two kinds of names. ",
 StyleBox["Properties",
  FontWeight->"Bold"],
 " (",
 Cell[BoxData[
  RowBox[{"IBMJob", "["}]], "InlineFormula",ExpressionUUID->
  "b32db67e-55e6-467e-9cd6-1d054c2561c3"],
 StyleBox["assoc", "TI"],
 Cell[BoxData[
  RowBox[{"]", 
   RowBox[{"[", "\"\<Properties\>\"", "]"}]}]], "InlineFormula",
  ExpressionUUID->"02c3b05d-320d-4bde-8146-a91043b13452"],
 ") are local accessors that read the cached snapshot and never touch the \
network, so a bulk map over them is fast and has no side effects. ",
 StyleBox["Actions",
  FontWeight->"Bold"],
 " (",
 Cell[BoxData[
  RowBox[{"IBMJob", "["}]], "InlineFormula",ExpressionUUID->
  "226bb51f-ee4b-4d58-86b6-60413ce58512"],
 StyleBox["assoc", "TI"],
 Cell[BoxData[
  RowBox[{"]", 
   RowBox[{"[", "\"\<Actions\>\"", "]"}]}]], "InlineFormula",ExpressionUUID->
  "2f69b0cd-8ff4-4957-82ad-c959d32b7bac"],
 ") each require a live connection and are kept out of the property list, so \
that map never re-queries, cancels or blocks on a remote fetch; each is still \
callable by name. ",
 Cell[BoxData[
  RowBox[{"IBMJob", "["}]], "InlineFormula",ExpressionUUID->
  "800b8efb-1cfb-463e-88de-5e73a8236461"],
 StyleBox["assoc", "TI"],
 Cell[BoxData[
  RowBox[{"]", 
   RowBox[{"[", "\"\<Refresh\>\"", "]"}]}]], "InlineFormula",ExpressionUUID->
  "b5e2798a-d843-4690-9860-7603be3a3ea4"],
 " re-queries the service and gives a ",
 StyleBox["new",
  FontWeight->"Bold"],
 " ",
 Cell[BoxData[
 "IBMJob"], "InlineFormula",ExpressionUUID->
  "e049acb5-456e-434a-9b43-984b653a84e8"],
 " with an updated ",
 Cell[BoxData["\"\<Raw\>\""], "InlineFormula",ExpressionUUID->
  "574aced9-77ba-425d-b80b-5a6d1cbf849b"],
 " snapshot (once ",
 Cell[BoxData["\"\<Completed\>\""], "InlineFormula",ExpressionUUID->
  "cf73968d-1abe-4ca2-bd88-af44165340b5"],
 " it also pulls the results and metrics, and for an estimator job caches the \
qiskit-decoded expectation values); ",
 Cell[BoxData[
  RowBox[{"IBMJob", "["}]], "InlineFormula",ExpressionUUID->
  "4e7b14d9-ec1f-4dc2-88a5-e60d0d3af83d"],
 StyleBox["assoc", "TI"],
 Cell[BoxData[
  RowBox[{"]", 
   RowBox[{"[", "\"\<Cancel\>\"", "]"}]}]], "InlineFormula",ExpressionUUID->
  "a9430428-1a40-4531-9baf-0fd00e98821d"],
 " requests cancellation; ",
 Cell[BoxData[
  RowBox[{"IBMJob", "["}]], "InlineFormula",ExpressionUUID->
  "8a2d496f-8741-45e3-bc87-9275cacf64e0"],
 StyleBox["assoc", "TI"],
 Cell[BoxData[
  RowBox[{"]", 
   RowBox[{"[", "\"\<ExecutedCircuit\>\"", "]"}]}]], "InlineFormula",
  ExpressionUUID->"19deb692-49e5-45a4-92c1-f4a093a24449"],
 " downloads the server-side transpiled circuit (see Possible Issues)."
}], "Notes",ExpressionUUID->"a099d18c-b861-4e81-9587-c2ca0be4c8de"],

Cell[TextData[{
 "The result accessors are primitive-specific. For a ",
 StyleBox["sampler",
  FontWeight->"Bold"],
 " job the live accessors are ",
 Cell[BoxData["\"\<Counts\>\""], "InlineFormula",ExpressionUUID->
  "77ff5e97-e8b7-47ba-8073-4df035cf6ff8"],
 ", ",
 Cell[BoxData["\"\<Measurement\>\""], "InlineFormula",ExpressionUUID->
  "267a0f5a-d6bf-42a3-8c6c-5265da8bd243"],
 ", ",
 Cell[BoxData["\"\<Probabilities\>\""], "InlineFormula",ExpressionUUID->
  "a1e69259-742f-4609-b3bb-4d02983b1405"],
 ", ",
 Cell[BoxData["\"\<Samples\>\""], "InlineFormula",ExpressionUUID->
  "d47c0fac-1e0f-4c57-9b8a-38a88b67971b"],
 ", ",
 Cell[BoxData["\"\<NumBits\>\""], "InlineFormula",ExpressionUUID->
  "b591d539-119a-4ce2-8831-ae60efb6a6eb"],
 " and ",
 Cell[BoxData["\"\<Shots\>\""], "InlineFormula",ExpressionUUID->
  "c80c3ee2-85b8-4c16-bc73-0255d8e82236"],
 "; for an ",
 StyleBox["estimator",
  FontWeight->"Bold"],
 " job they are ",
 Cell[BoxData["\"\<ExpectationValue\>\""], "InlineFormula",ExpressionUUID->
  "8b2578a8-347d-4137-b0ee-57848a6ea078"],
 ", ",
 Cell[BoxData["\"\<ExpectationValues\>\""], "InlineFormula",ExpressionUUID->
  "a5598522-c4d4-45f7-82d4-2e4c4a022e40"],
 " and ",
 Cell[BoxData["\"\<StandardErrors\>\""], "InlineFormula",ExpressionUUID->
  "759071a8-11c3-47b4-9f71-63a522849740"],
 ". An accessor that does not apply to the job's primitive gives ",
 Cell[BoxData[
  RowBox[{"Missing", "[", 
   RowBox[{"\"\<NotApplicable\>\"", ","}]}]], "InlineFormula",ExpressionUUID->
  "e6abbfcc-6d97-4ed5-b96f-fccec2262a4e"],
 StyleBox["primitive", "TI"],
 Cell[BoxData["]"], "InlineFormula",ExpressionUUID->
  "ae142ca6-4f9a-4637-b006-d3589777599c"],
 "."
}], "Notes",ExpressionUUID->"95a043f0-d6f9-4873-a707-b08d5afcd517"],

Cell[TextData[{
 "An unknown property name gives a ",
 Cell[BoxData[
  ButtonBox["Failure",
   BaseStyle->"Link",
   ButtonData->"paclet:ref/Failure"]], "InlineFormula",ExpressionUUID->
  "e7ea7a8a-edca-4c9e-9718-ae50d231be8b"],
 " listing the valid properties (see Possible Issues)."
}], "Notes",ExpressionUUID->"89b6ef4c-8199-4f2d-9304-9853bc219421"],

Cell[TextData[{
 "The summary box shows the status (with a colored indicator), the backend \
and the job id; once ",
 Cell[BoxData["\"\<Completed\>\""], "InlineFormula",ExpressionUUID->
  "ad383744-81c5-4420-a1bf-1000a9f10a71"],
 " a sampler job also shows the qubit count, shot count and \
quantum-processing time, and an estimator job shows the expectation value and \
quantum-processing time."
}], "Notes",ExpressionUUID->"543cc6c8-fe1c-4ecd-b25f-732198fa237e"],

Cell[TextData[{
 "The data properties (",
 Cell[BoxData[
  RowBox[{"IBMJob", "["}]], "InlineFormula",ExpressionUUID->
  "207a19b9-91ec-44f6-812b-ee6420c26e69"],
 StyleBox["assoc", "TI"],
 Cell[BoxData[
  RowBox[{"]", 
   RowBox[{"[", "\"\<Properties\>\"", "]"}]}]], "InlineFormula",
  ExpressionUUID->"13592f66-f242-4f72-9056-a02b23c33d2c"],
 "), each read from the cached snapshot with no network access:"
}], "Notes",ExpressionUUID->"78569628-a6a1-4454-bcc5-899ae12cb03a"],

