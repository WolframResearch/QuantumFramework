     "b0cf3df4-0c56-41df-b29c-8fdd39dd56a3"], Cell[
    "the current job status", "TableText",ExpressionUUID->
     "0618dde5-0529-482f-a299-7e8549d9c7ab"]},
   {Cell["      ", "ModInfo",ExpressionUUID->
     "32c48344-a31b-477d-8845-78d2ddd6a980"], Cell[TextData[Cell[
