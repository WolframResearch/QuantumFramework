Notebook[{

Cell[CellGroupData[{
Cell["IBMJob", "ObjectName",
 CellID->1224892054,ExpressionUUID->"8393d601-4014-44ba-afc9-60862df940ec"],

Cell[TextData[{
 Cell["   ", "ModInfo",ExpressionUUID->"9b747130-84c2-40cf-9360-e07d69272b59"],
 Cell[BoxData[
  RowBox[{
   ButtonBox["IBMJob",
    BaseStyle->"Link",
    ButtonData->"paclet:Wolfram/QuantumFramework/ref/IBMJob"], "[", 
   StyleBox["assoc", "TI"], "]"}]], "InlineFormula",ExpressionUUID->
  "7d33dc10-4e5e-47b3-bf18-92c769ea7502"],
 " ",
 "represents a job submitted to an IBM Quantum processing unit, carrying its \
identifier, backend and the raw service responses, with curated accessors \
layered on top.",
 "\n",
 Cell["   ", "ModInfo",ExpressionUUID->"683ac406-4f98-4030-bd1d-c08511b5568e"],
 Cell[BoxData[
  RowBox[{
   RowBox[{"IBMJob", "[", 
    StyleBox["assoc", "TI"], "]"}], 
   "[", "\"\<\!\(\*StyleBox[\"prop\", \"TI\"]\)\>\"", "]"}]], "InlineFormula",
  ExpressionUUID->"1fe4e448-4c7f-49d0-88d1-208e22f98c8b"],
 " ",
 "gives the value of the property ",
 StyleBox["\"prop\"", "TI"],
 ", such as ",
 Cell[BoxData["\"\<Status\>\""], "InlineFormula",ExpressionUUID->
  "3b61aa1c-379d-461d-9e32-20572490a7b1"],
 ", ",
 Cell[BoxData["\"\<Counts\>\""], "InlineFormula",ExpressionUUID->
  "f77f30ea-3c13-411c-8bbc-70ab2a8ac35b"],
 " or ",
 Cell[BoxData["\"\<QuantumSeconds\>\""], "InlineFormula",ExpressionUUID->
  "ea6322da-cfa9-4d35-aecf-b5d7c83fadb3"],
 ".",
 "\n",
 Cell["   ", "ModInfo",ExpressionUUID->"cb4da512-1779-42b6-a140-ad3f1c67c44f"],
 Cell[BoxData[
  RowBox[{
   RowBox[{"IBMJob", "[", 
    StyleBox["assoc", "TI"], "]"}], "[", "]"}]], "InlineFormula",
  ExpressionUUID->"8ddd6c30-7caa-47f3-9c37-677b33fb7b78"],
 " ",
 "gives the primary result, the ",
 Cell[BoxData[
  ButtonBox["QuantumMeasurement",
   BaseStyle->"Link",
   ButtonData->"paclet:Wolfram/QuantumFramework/ref/QuantumMeasurement"]], 
  "InlineFormula",ExpressionUUID->"250af286-9da3-4f3a-a1e5-5bbda38aa425"],
 " reconstructed from the hardware counts."
}], "Usage",ExpressionUUID->"e7f490bf-a048-4b66-a968-a2069ab0f346"],

Cell[TextData[{
 "An ",
 Cell[BoxData[
 "IBMJob"], "InlineFormula",ExpressionUUID->
  "5b4b2d6d-dd95-4c4e-b2cf-0b38c1870624"],
 " is normally produced by ",
 Cell[BoxData[
  ButtonBox["IBMJobSubmit",
   BaseStyle->"Link",
   ButtonData->"paclet:Wolfram/QuantumFramework/ref/IBMJobSubmit"]], 
  "InlineFormula",ExpressionUUID->"1d7f35e8-5be5-4af6-b5e9-17ead4d11d5d"],
 " or by the ",
 Cell[BoxData[
  RowBox[{
   RowBox[{"QuantumCircuitOperator", "[", 
    StyleBox["circ", "TI"], "]"}], "[", 
   RowBox[{
    ButtonBox["Method",
     BaseStyle->"Link"], " ", "->", " ", 
    RowBox[{"{", 
     RowBox[{"\"\<Qiskit\>\"", ",", " ", 
      RowBox[{"\"\<Provider\>\"", " ", "->", " ", "\"\<IBMProvider\>\""}], ",",
       " ", "\[Ellipsis]"}], "}"}]}], "]"}]], "InlineFormula",ExpressionUUID->
  "1b5c660b-029a-4077-b997-eca0feda7e33"],
 " hardware path, not constructed by hand."
}], "Notes",ExpressionUUID->"89a8336f-d29f-44cf-80b2-fef0cd3b0a9e"],

Cell[TextData[{
 "The object is a ",
 StyleBox["lossless",
  FontWeight->"Bold"],
 " carrier: the raw service responses are kept verbatim under ",
 Cell[BoxData["\"\<Raw\>\""], "InlineFormula",ExpressionUUID->
  "30fca646-f238-4db0-b90d-c0fd28c64e17"],
 ", and every accessor reads from there, so no field the service returns is \
discarded."
}], "Notes",ExpressionUUID->"51e20b63-fe6c-44be-8702-4d060833fdfe"],

Cell[TextData[{
 "Accessors ",
 StyleBox["fetch lazily",
  FontWeight->"Bold"],
 ": a property reads from the stored snapshot when present, otherwise queries \
the service object. With no reachable connection an accessor gives ",
 Cell[BoxData[
  RowBox[{"Missing", "[", "\"\<NoConnection\>\"", "]"}]], "InlineFormula",
  ExpressionUUID->"fc1fd87c-ad01-4e0f-8797-41f4c45f40f0"],
 "; before the job is ",
 Cell[BoxData["\"\<Completed\>\""], "InlineFormula",ExpressionUUID->
  "27e7641a-62ca-4e11-8578-212a3f0560e0"],
 " the result accessors give ",
 Cell[BoxData[
  RowBox[{"Missing", "[", 
   RowBox[{"\"\<JobNotComplete\>\"", ","}]}]], "InlineFormula",ExpressionUUID->
  "db92abf9-2879-40d0-a4c9-1dec546c54a0"],
 StyleBox["status", "TI"],
 Cell[BoxData["]"], "InlineFormula",ExpressionUUID->
  "8e00c220-f3a9-4fc5-b64f-53e2e6d30213"],
 "."
}], "Notes",ExpressionUUID->"6c7eec36-c8fb-4233-a207-38f45bce5dcd"],

Cell[TextData[{
 Cell[BoxData["\"\<Status\>\""], "InlineFormula",ExpressionUUID->
  "c0649e23-8102-412c-af5e-77de3ec597d5"],
 " is one of ",
 Cell[BoxData["\"\<Queued\>\""], "InlineFormula",ExpressionUUID->
  "e94ea472-bbce-4da2-8849-98dd10101db6"],
 ", ",
 Cell[BoxData["\"\<Validating\>\""], "InlineFormula",ExpressionUUID->
  "9ca7e68f-8cd1-48f2-bd04-8f791905e6af"],
 ", ",
 Cell[BoxData["\"\<Initializing\>\""], "InlineFormula",ExpressionUUID->
  "0c4cff49-0aac-4ec6-a0b1-e6af309a9479"],
 ", ",
 Cell[BoxData["\"\<Running\>\""], "InlineFormula",ExpressionUUID->
  "660439eb-f288-4635-958b-12f121bdfbf7"],
 ", ",
 Cell[BoxData["\"\<Completed\>\""], "InlineFormula",ExpressionUUID->
  "bb6cf640-8b2a-444b-a405-23f2e7e91ef8"],
 ", ",
 Cell[BoxData["\"\<Cancelled\>\""], "InlineFormula",ExpressionUUID->
  "4f553063-4573-4aa9-9b93-a81386dc340b"],
 " or ",
 Cell[BoxData["\"\<Failed\>\""], "InlineFormula",ExpressionUUID->
  "1ee8bca3-a86b-49b1-aa75-030611020374"],
 "; the terminal statuses are ",
 Cell[BoxData["\"\<Completed\>\""], "InlineFormula",ExpressionUUID->
  "ce074dde-e621-4c15-a7c1-c982daa22704"],
 ", ",
 Cell[BoxData["\"\<Cancelled\>\""], "InlineFormula",ExpressionUUID->
  "5b7cfeb5-0453-4ce5-83d0-c72125b78ac0"],
 " and ",
 Cell[BoxData["\"\<Failed\>\""], "InlineFormula",ExpressionUUID->
  "9217fd20-75c3-428e-b675-e618f30b5eb2"],
 "."
}], "Notes",ExpressionUUID->"f6fe849e-b8df-47ff-a8ec-e2f64b7b35fc"],

Cell[TextData[{
 "The hardware counts decode into the Wolfram Language qubit order (ascending \
qubit) using the ",
 Cell[BoxData["\"\<MeasuredQubits\>\""], "InlineFormula",ExpressionUUID->
  "6977450a-67ea-4b55-abec-f6be4007c14f"],
 " map (classical bit to original qubit) captured at submission time, so a \
permuted or partial measurement and any backend layout decode correctly."
}], "Notes",ExpressionUUID->"8b7e0a92-5d47-42ab-9482-337d8bf99982"],

Cell[TextData[{
 Cell[BoxData[
  RowBox[{"IBMJob", "["}]], "InlineFormula",ExpressionUUID->
  "390ee7ea-2839-4f44-b7f8-8272f3a6fb76"],
 StyleBox["assoc", "TI"],
 Cell[BoxData[
  RowBox[{"]", 
   RowBox[{"[", "\"\<Refresh\>\"", "]"}]}]], "InlineFormula",ExpressionUUID->
  "8cc4ff0c-7f48-4a48-a45e-f34ca149c756"],
 " re-queries the service and gives a ",
 StyleBox["new",
  FontWeight->"Bold"],
 " ",
 Cell[BoxData[
 "IBMJob"], "InlineFormula",ExpressionUUID->
  "f751a46f-537f-4756-b400-75acc809b411"],
 " with an updated ",
 Cell[BoxData["\"\<Raw\>\""], "InlineFormula",ExpressionUUID->
  "9af815a9-69ac-4809-b629-a9373ab433dd"],
 " snapshot; once the job is ",
 Cell[BoxData["\"\<Completed\>\""], "InlineFormula",ExpressionUUID->
  "c9a194af-b8a3-4ee8-b633-e361e6242050"],
 " it also pulls the results and metrics. ",
 Cell[BoxData[
  RowBox[{"IBMJob", "["}]], "InlineFormula",ExpressionUUID->
  "89427e38-a417-4797-987a-04119384eac5"],
 StyleBox["assoc", "TI"],
 Cell[BoxData[
  RowBox[{"]", 
   RowBox[{"[", "\"\<Cancel\>\"", "]"}]}]], "InlineFormula",ExpressionUUID->
  "a901bd2c-432d-449b-86db-63edc6c3fa22"],
 " requests cancellation."
}], "Notes",ExpressionUUID->"aa9fd273-a788-4737-8abf-6f91e69c88e0"],

Cell[TextData[{
 "An unknown property name gives a ",
 Cell[BoxData[
  ButtonBox["Failure",
   BaseStyle->"Link",
   ButtonData->"paclet:ref/Failure"]], "InlineFormula",ExpressionUUID->
  "12fed8f4-d664-4be5-b981-781c3b833091"],
 " listing the valid properties (see Possible Issues)."
}], "Notes",ExpressionUUID->"c04e0587-6ba2-411b-9f91-a239db157457"],

Cell[TextData[{
 "The summary box shows the status (with a colored indicator), the backend \
and the job id; once ",
 Cell[BoxData["\"\<Completed\>\""], "InlineFormula",ExpressionUUID->
  "1e8b4b00-9ad0-470a-8030-6792164e841e"],
 " it also shows the qubit count, shot count and quantum-processing time."
}], "Notes",ExpressionUUID->"ca072f44-c6b9-4cc0-9ff5-6fb182d2888f"],

Cell[TextData[{
 "The full property list (",
 Cell[BoxData[
  RowBox[{"IBMJob", "["}]], "InlineFormula",ExpressionUUID->
  "9d645241-9aca-4b80-93d4-f739f9457378"],
 StyleBox["assoc", "TI"],
 Cell[BoxData[
  RowBox[{"]", 
   RowBox[{"[", "\"\<Properties\>\"", "]"}]}]], "InlineFormula",
  ExpressionUUID->"f2a3d60d-df73-4c0d-b3c6-112385bd3066"],
 "):"
}], "Notes",ExpressionUUID->"102980c7-5217-4e0d-85e2-961a1f1f110c"],

