Cell[CellGroupData[{

Cell["Quantum error correction with the 5-qubit code", "ExampleSubsection",ExpressionUUID->"bb0b13e0-04c5-40b9-994c-61fb4152334c"],

Cell["\<\
Encode |0_L\[RightAngleBracket] in the 5-qubit code, inject an X error on \
qubit 3, and observe a non-trivial syndrome:\
\>", "ExampleText",ExpressionUUID->"af5253a0-3ac3-45d8-8242-b4e50a703b51"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Module", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"ps0", ",", " ", "psErr", ",", " ", "syndrome"}], "}"}], ",", " ", 
   RowBox[{
    RowBox[{"ps0", " ", "=", " ", 
     RowBox[{"PauliStabilizer", "[", "\"\<5QubitCode\>\"", "]"}]}], ";", " ", 
    
    RowBox[{"psErr", " ", "=", " ", 
     RowBox[{"ps0", "[", 
      RowBox[{"\"\<X\>\"", ",", " ", "3"}], "]"}]}], ";", " ", 
    RowBox[{"syndrome", " ", "=", " ", 
     RowBox[{"Sign", " ", "/@", " ", 
      RowBox[{"Table", "[", 
       RowBox[{
        RowBox[{"psErr", "[", 
         RowBox[{"\"\<Expectation\>\"", ",", " ", "g"}], "]"}], ",", " ", 
        RowBox[{"{", 
         RowBox[{"g", ",", " ", 
