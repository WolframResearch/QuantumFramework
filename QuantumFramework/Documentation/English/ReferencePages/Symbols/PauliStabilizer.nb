"ExampleText",ExpressionUUID->"8ebef1f6-452d-46ab-928c-0fd36614a350"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Module", "[", 
  RowBox[{
   RowBox[{"{", "products", "}"}], ",", " ", 
   RowBox[{
    RowBox[{"SeedRandom", "[", "42", "]"}], ";", " ", 
    RowBox[{"products", " ", "=", " ", 
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"Abs", "[", 
         RowBox[{
          RowBox[{"PauliStabilizer", "[", 
           RowBox[{"\"\<Random\>\"", ",", " ", "3"}], "]"}], "[", 
          RowBox[{"\"\<InnerProduct\>\"", ",", " ", 
           RowBox[{"PauliStabilizer", "[", 
            RowBox[{"\"\<Random\>\"", ",", " ", "3"}], "]"}]}], "]"}], "]"}], 
        "^", "2"}], ",", " ", 
       RowBox[{"{", "200", "}"}]}], "]"}]}], ";", " ", 
    RowBox[{"Tally", "[", 
     RowBox[{"Round", "[", 
      RowBox[{"products", ",", " ", 
       RowBox[{"1", "/", "8"}]}], "]"}], "]"}]}]}], "]"}]], "Input",
 CellLabel->"In[1]:= ",ExpressionUUID->"8c5338f7-7161-44b8-9b8e-fd8577687dd4"],

