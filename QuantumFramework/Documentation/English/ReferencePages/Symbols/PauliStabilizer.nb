   RowBox[{"{", 
    RowBox[{"qs", ",", " ", "ps"}], "}"}], ",", " ", 
   RowBox[{
    RowBox[{"qs", " ", "=", " ", 
     RowBox[{"QuantumState", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"1", ",", " ", "0", ",", " ", "0", ",", " ", "1"}], "}"}], "/", 
       RowBox[{"Sqrt", "[", "2", "]"}]}], "]"}]}], ";", " ", 
    RowBox[{"ps", " ", "=", " ", 
     RowBox[{"PauliStabilizer", "[", "qs", "]"}]}], ";", " ", 
    RowBox[{"ps", "[", "\"\<Stabilizers\>\"", "]"}]}]}], "]"}]], "Input",
 CellLabel->"In[1]:= ",ExpressionUUID->"de6a257e-a0f6-4355-9a44-09423ad969c5"],

