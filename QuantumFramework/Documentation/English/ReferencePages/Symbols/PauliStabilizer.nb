                   TagBox["\"Message: \"", "SummaryItemAnnotation"], 
                   "\[InvisibleSpace]", 
                   TagBox[
                   "\"Assertion \\!\\(\\*TagBox[RowBox[{\\\"1\\\", \\\"\
\[LessEqual]\\\", \\\"5\\\", \\\"\[LessEqual]\\\", \
\\\"Wolfram`QuantumFramework`Measurement`PackagePrivate`n\\\"}], \
Function[Short[Slot[1], 3]]]\\) failed.\"", "SummaryItem"]}}, 
                 GridBoxItemSize -> {"Columns" -> {6.5, All, Automatic}}, 
