Cell["50-qubit random Clifford tableau as MatrixPlot", "ExampleSubsection",ExpressionUUID->"a6cb5cae-95d0-49fc-b60c-febc16605875"],

Cell["\<\
Visualize the symplectic structure of a large random Clifford:\
\>", "ExampleText",ExpressionUUID->"0022fc76-8b72-4e44-923b-c4da56eedad0"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Module", "[", 
  RowBox[{
   RowBox[{"{", "ps", "}"}], ",", " ", 
   RowBox[{
    RowBox[{"SeedRandom", "[", "1", "]"}], ";", " ", 
