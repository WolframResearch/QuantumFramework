   FractionBox["1", "4"], ",", 
   FractionBox["1", "2"]}], "}"}]], "Output",
 CellLabel->"Out[1]=",
 CellID->176972442,ExpressionUUID->"d132ef76-6362-4f74-bd2c-548a03c67a29"]
}, Open  ]]
