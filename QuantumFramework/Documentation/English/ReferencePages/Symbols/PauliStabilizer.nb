Cell["Compose two stabilizer states (apply second, then first):", \
"ExampleText",
 CellID->563799188,ExpressionUUID->"c1117be3-88c6-48bd-b855-e624af758a15"],

Cell[BoxData[
 RowBox[{"Module", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"ps1", ",", " ", "ps2"}], "}"}], ",", " ", 
   RowBox[{
    RowBox[{"ps1", " ", "=", " ", 
     RowBox[{"PauliStabilizer", "[", 
      RowBox[{"QuantumCircuitOperator", "[", 
       RowBox[{"{", 
        RowBox[{"\"\<H\>\"", " ", "->", " ", "1"}], "}"}], "]"}], "]"}]}], ";",
     " ", 
    RowBox[{"ps2", " ", "=", " ", 
     RowBox[{"PauliStabilizer", "[", 
      RowBox[{"QuantumCircuitOperator", "[", 
       RowBox[{"{", 
        RowBox[{"\"\<S\>\"", " ", "->", " ", "1"}], "}"}], "]"}], "]"}]}], ";",
     " ", 
    RowBox[{
     RowBox[{"ps1", "[", "ps2", "]"}], "[", "\"\<Stabilizers\>\"", "]"}]}]}], 
  "]"}]], "Input",
