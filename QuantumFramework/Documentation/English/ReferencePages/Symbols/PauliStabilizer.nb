   RowBox[{
    RowBox[{"\"\<RX\>\"", "[", 
     RowBox[{"Pi", "/", "3"}], "]"}], ",", " ", 
    RowBox[{"{", "1", "}"}]}], "]"}], "[", 
  RowBox[{"QuantumState", "[", "\"\<0\>\"", "]"}], "]"}]], "Input",
 CellLabel->"In[101]:=",
 CellID->990010002,ExpressionUUID->"a1b1c1d1-0002-0002-0002-000000000002"],

