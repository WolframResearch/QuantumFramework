Cell[CellGroupData[{

Cell["PauliStabilizer::singular", "ExampleSubsection",ExpressionUUID->"4db5db47-67e6-47df-9f73-98e14b46c784"],

Cell["\<\
PauliStabilizer[{p1, p2, \[Ellipsis]}] from stabilizer rows alone fills the \
destabilizer rows with a Reverse-padded default, which may yield a symplectic \
matrix that is singular mod 2. Dagger requires the full tableau to be \
invertible, so this case emits PauliStabilizer::singular and returns $Failed:\
\
\>", "ExampleText",ExpressionUUID->"d212ab37-f4f6-4520-aa80-6bc12dbd3263"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"PauliStabilizer", "[", 
   RowBox[{"{", 
    RowBox[{"\"\<XX\>\"", ",", " ", "\"\<ZZ\>\""}], "}"}], "]"}], 
  "[", "\"\<Dagger\>\"", "]"}]], "Input",
 CellLabel->"In[1]:= ",ExpressionUUID->"337b1ce7-e616-476c-8929-0f66c7fc66fc"],

Cell["\<\
PauliStabilizer::singular: 
   Cannot compute Dagger: symplectic matrix is singular mod 2 (this happens
    when the input PauliStabilizer was built from a stabilizer-only list \
whose
    Reverse-padded destabilizers coincide with the stabilizer rows). Use a
    circuit-built fixture or supply explicit destabilizers.\
\>", "Message", "MSG",ExpressionUUID->"2c533a4a-cb7d-4460-8484-2e146e02371e"],

Cell[BoxData["$Failed"], "Output",
 CellLabel->"Out[1]= ",ExpressionUUID->"cc28521b-1d98-48bc-b232-86e9a710e81b"]
}, Open  ]],

Cell["\<\
Resolution: build the stabilizer from a Clifford circuit. The constructor \
PauliStabilizer[qco] runs the circuit on the all-zero state and sets up \
consistent destabilizers, so Dagger is well-defined:\
\>", "ExampleText",ExpressionUUID->"3f57a2ce-b5a1-43d5-848a-fa398b51eee9"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"PauliStabilizer", "[", 
   RowBox[{"QuantumCircuitOperator", "[", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"\"\<H\>\"", " ", "->", " ", "1"}], ",", " ", 
      RowBox[{"\"\<CNOT\>\"", " ", "->", " ", 
       RowBox[{"{", 
        RowBox[{"1", ",", " ", "2"}], "}"}]}]}], "}"}], "]"}], "]"}], 
  "[", "\"\<Dagger\>\"", "]"}]], "Input",
 CellLabel->"In[2]:= ",ExpressionUUID->"c52f9efe-feed-412d-ad48-88c68444af9a"],

