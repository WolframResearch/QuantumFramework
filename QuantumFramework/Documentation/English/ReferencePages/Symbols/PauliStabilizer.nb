Cell[CellGroupData[{

Cell["PauliStabilizer::expectationdim", "ExampleSubsection",ExpressionUUID->"a09dbd9c-6dea-4c42-9d3b-d62a47ad034a"],

Cell["\<\
ps[\"Expectation\", P] requires the Pauli string P to have one letter per \
qubit. A length mismatch emits PauliStabilizer::expectationdim and returns \
$Failed:\
\>", "ExampleText",ExpressionUUID->"456e3405-e4f2-4844-b754-0755c5277cda"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"PauliStabilizer", "[", "2", "]"}], "[", 
  RowBox[{"\"\<Expectation\>\"", ",", " ", "\"\<X\>\""}], "]"}]], "Input",
 CellLabel->"In[1]:= ",ExpressionUUID->"f005aa9e-c5db-45a5-9a95-56c78a135484"],

Cell["\<\
PauliStabilizer::expectationdim: 
   Pauli string 1 qubits does not match PauliStabilizer 2 qubits.\
\>", "Message", "MSG",ExpressionUUID->"d158f2f9-3aab-43b5-8dc4-7459aef6d6e3"],

Cell[BoxData["$Failed"], "Output",
 CellLabel->"Out[1]= ",ExpressionUUID->"0ef5a1a7-5220-4210-8676-b27c7d6beb0c"]
}, Open  ]],

Cell["\<\
Resolution: pass a Pauli string of length n where n is the qubit count. For a \
2-qubit stabilizer, use a 2-letter string from the alphabet {I, X, Y, Z}:\
\>", "ExampleText",ExpressionUUID->"8a539a6a-0178-4748-a7f8-1bc700574195"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"PauliStabilizer", "[", "2", "]"}], "[", 
  RowBox[{"\"\<Expectation\>\"", ",", " ", "\"\<XX\>\""}], "]"}]], "Input",
 CellLabel->"In[2]:= ",ExpressionUUID->"8a826959-0022-4228-ac35-5196f2d42c33"],

Cell[BoxData["0"], "Output",
 CellLabel->"Out[2]= ",ExpressionUUID->"ee1561db-75d6-4fed-8971-14d108bee47a"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["PauliStabilizer::partition", "ExampleSubsection",ExpressionUUID->"03846f53-a762-46d4-9039-78a05d5c3668"],

Cell["\<\
Measurement and entropy queries require qubit indices in {1, \[Ellipsis], n}. \
Out-of-range indices emit PauliStabilizer::partition and return $Failed:\
\>", "ExampleText",ExpressionUUID->"eaf2b82a-3055-46f8-bad3-435fc6e63a6f"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"PauliStabilizer", "[", "2", "]"}], "[", 
  RowBox[{"\"\<M\>\"", ",", " ", 
   RowBox[{"{", 
    RowBox[{"1", ",", " ", "5"}], "}"}]}], "]"}]], "Input",
 CellLabel->"In[1]:= ",ExpressionUUID->"0e1a169c-f14b-4d15-a673-cd4617b13e02"],

Cell["\<\
PauliStabilizer::partition: Partition {1, 5} is not a subset of {1, ..., 2}.\
\>", "Message", "MSG",ExpressionUUID->"d8aee729-3f1f-49a9-8a4a-17502e7346f2"],

Cell[BoxData["$Failed"], "Output",
 CellLabel->"Out[1]= ",ExpressionUUID->"868eeda1-9093-4916-8a69-6a1ce3d8e1d4"]
}, Open  ]],

Cell["\<\
Resolution: use indices within {1, \[Ellipsis], n}. For a 2-qubit stabilizer, \
valid indices are 1 and 2:\
\>", "ExampleText",ExpressionUUID->"98ff60f8-de18-4e1b-b0a3-65c99df19f95"],

