Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Module", "[", 
  RowBox[{
   RowBox[{"{", "ps", "}"}], ",", " ", 
   RowBox[{
    RowBox[{"ps", " ", "=", " ", 
     RowBox[{"PauliStabilizer", "[", "2", "]"}]}], ";", " ", 
    RowBox[{"AssociationThread", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"\"\<S\>\"", ",", " ", "\"\<X\>\"", ",", " ", "\"\<Y\>\"", ",",
         " ", "\"\<Z\>\"", ",", " ", "\"\<V\>\""}], "}"}], " ", "->", " ", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{
         RowBox[{"ps", "[", 
          RowBox[{"\"\<S\>\"", ",", " ", "1"}], "]"}], 
         "[", "\"\<Stabilizers\>\"", "]"}], ",", " ", 
        RowBox[{
         RowBox[{"ps", "[", 
          RowBox[{"\"\<X\>\"", ",", " ", "1"}], "]"}], 
         "[", "\"\<Stabilizers\>\"", "]"}], ",", " ", 
        RowBox[{
         RowBox[{"ps", "[", 
          RowBox[{"\"\<Y\>\"", ",", " ", "1"}], "]"}], 
         "[", "\"\<Stabilizers\>\"", "]"}], ",", " ", 
        RowBox[{
         RowBox[{"ps", "[", 
          RowBox[{"\"\<Z\>\"", ",", " ", "1"}], "]"}], 
         "[", "\"\<Stabilizers\>\"", "]"}], ",", " ", 
        RowBox[{
         RowBox[{"ps", "[", 
          RowBox[{"\"\<V\>\"", ",", " ", "1"}], "]"}], 
         "[", "\"\<Stabilizers\>\"", "]"}]}], "}"}]}], "]"}]}]}], 
