Cell["\<\
Recover a stabilizer state from a dense state vector via 4^n tomography and \
round-trip back:\
\>", "ExampleText",ExpressionUUID->"4ea00da5-6b55-4bc5-bf71-615129f11d5d"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Module", "[", 
