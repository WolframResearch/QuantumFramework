Cell["For random pairs the squared overlap is in {0, 1/2^k}:", "ExampleText",
 CellID->129624617,ExpressionUUID->"6e4e33d8-b00a-42d6-a09a-fc4911431ea3"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Module", "[", 
  RowBox[{
   RowBox[{"{", "vals", "}"}], ",", " ", 
   RowBox[{
    RowBox[{"SeedRandom", "[", "1", "]"}], ";", " ", 
    RowBox[{"vals", " ", "=", " ", 
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"Abs", "[", 
         RowBox[{
          RowBox[{"PauliStabilizer", "[", 
           RowBox[{"\"\<Random\>\"", ",", " ", "3"}], "]"}], "[", 
          RowBox[{"\"\<InnerProduct\>\"", ",", " ", 
           RowBox[{"PauliStabilizer", "[", 
            RowBox[{"\"\<Random\>\"", ",", " ", "3"}], "]"}]}], "]"}], "]"}], 
        "^", "2"}], ",", " ", 
       RowBox[{"{", "50", "}"}]}], "]"}]}], ";", " ", 
    RowBox[{"Union", "[", 
     RowBox[{"Round", "[", 
      RowBox[{"vals", ",", " ", 
       RowBox[{"1", "/", "8"}]}], "]"}], "]"}]}]}], "]"}]], "Input",
 CellLabel->"In[1]:=",
 CellID->229866296,ExpressionUUID->"c394aab2-d319-4c45-a242-c2b03335645a"],

Cell[BoxData[
 RowBox[{"{", 
