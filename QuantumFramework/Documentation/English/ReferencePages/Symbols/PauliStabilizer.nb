Notebook[{

Cell[CellGroupData[{
Cell["PauliStabilizer", "ObjectName",
 CellID->1224892054,ExpressionUUID->"8393d601-4014-44ba-afc9-60862df940ec"],

Cell[TextData[{
 Cell["   ", "ModInfo",ExpressionUUID->"f5849922-4273-4e24-903c-6ccb45874619"],
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     Cell[
      TextData["PauliStabilizer"]], 
     "paclet:Wolfram/QuantumFramework/ref/PauliStabilizer", 
     "Wolfram/QuantumFramework Package Symbol"},
    "PackageLink",
    BaseStyle->"InlineFormula"], "[", "]"}]], "InlineFormula",ExpressionUUID->
  "02d7d9e9-2131-4b96-a24a-fa70faeb797a"],
 "\[LineSeparator]",
 "represents an empty stabilizer state, equivalent to the single-qubit \
register ",
 Cell[BoxData[
  TemplateBox[{"0"},
   "Ket"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "4d22ed9b-b1f2-4d3d-accf-40943835b2d2"],
 ".",
 "\n",
 Cell["   ", "ModInfo",ExpressionUUID->"6ce2bf85-2f04-45fe-919e-a491cb44642a"],
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     Cell[
      TextData["PauliStabilizer"]], 
     "paclet:Wolfram/QuantumFramework/ref/PauliStabilizer", 
     "Wolfram/QuantumFramework Package Symbol"},
    "PackageLink",
    BaseStyle->"InlineFormula"], "[", 
   StyleBox["n", "TI"], "]"}]], "InlineFormula",ExpressionUUID->
  "ef2c8524-c0a5-450a-8fc0-e1b40bb7b8fe"],
 "\[LineSeparator]",
 "represents the ",
 StyleBox["n", "TI"],
 "-qubit ",
 Cell[BoxData[
  TemplateBox[{
    RowBox[{"0", "\[CenterDot]", 
      StyleBox["s", "TI"], "0"}]},
   "Ket"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "74813c5d-6734-477a-9858-3f405017686e"],
 " register state, with stabilizers ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["Z", "TI"], 
   StyleBox["i", "TI"]]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "33b02d93-047a-465b-855c-c9b4fc94fe28"],
 ".",
 "\n",
 Cell["   ", "ModInfo",ExpressionUUID->"57981ebc-a174-48e7-abf4-63a096c11bea"],
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     Cell[
      TextData["PauliStabilizer"]], 
     "paclet:Wolfram/QuantumFramework/ref/PauliStabilizer", 
     "Wolfram/QuantumFramework Package Symbol"},
    "PackageLink",
    BaseStyle->"InlineFormula"], "[", 
   RowBox[{"{", 
    RowBox[{
     SubscriptBox[
      StyleBox["stab", "TI"], 
      StyleBox["1", "TR"]], ",", " ", 
     SubscriptBox[
      StyleBox["stab", "TI"], 
      StyleBox["2", "TR"]], ",", " ", "\[Ellipsis]"}], "}"}], "]"}]], 
  "InlineFormula",ExpressionUUID->"7a713945-4ed3-493a-819e-a8b3ad481679"],
 "\[LineSeparator]",
 "constructs a stabilizer state from a list of Pauli strings.",
 "\n",
 Cell["   ", "ModInfo",ExpressionUUID->"96246841-88f6-4bab-80f8-744606f7b591"],
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     Cell[
      TextData["PauliStabilizer"]], 
     "paclet:Wolfram/QuantumFramework/ref/PauliStabilizer", 
     "Wolfram/QuantumFramework Package Symbol"},
    "PackageLink",
    BaseStyle->"InlineFormula"], "[", 
   RowBox[{
    RowBox[{"{", 
     StyleBox["stabs", "TI"], "}"}], ",", " ", 
    RowBox[{"{", 
     StyleBox["destabs", "TI"], "}"}]}], "]"}]], "InlineFormula",
  ExpressionUUID->"8728cc3b-cf60-47e9-b862-d60e92b18b02"],
 "\[LineSeparator]",
 "constructs a stabilizer state with explicit stabilizers and \
destabilizers.",
 "\n",
 Cell["   ", "ModInfo",ExpressionUUID->"5cc2f97b-0451-4a40-9a19-57e9e32fc3a6"],
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     Cell[
      TextData["PauliStabilizer"]], 
     "paclet:Wolfram/QuantumFramework/ref/PauliStabilizer", 
     "Wolfram/QuantumFramework Package Symbol"},
    "PackageLink",
    BaseStyle->"InlineFormula"], "[", 
   StyleBox["name", "TI"], "]"}]], "InlineFormula",ExpressionUUID->
  "6e62b7c1-b15c-4a12-a5e0-5eccdd741bd2"],
 "\[LineSeparator]",
 "returns a named stabilizer state. Names: ",
 Cell[BoxData["\"\<5QubitCode\>\""], "InlineFormula",ExpressionUUID->
  "d63ecbdb-87b9-4324-bddc-bb013bd7479d"],
 ", ",
 Cell[BoxData["\"\<SteaneCode\>\""], "InlineFormula",ExpressionUUID->
  "d99b3a6d-9263-4791-9de3-8de3626c2db0"],
 ", ",
 Cell[BoxData["\"\<9QubitCode\>\""], "InlineFormula",ExpressionUUID->
  "e3e50b03-74d9-44bd-b243-c3b6793f53fc"],
 ", their ",
 Cell[BoxData["\"\<\[CenterDot]1\>\""], "InlineFormula",ExpressionUUID->
  "51adf7f7-f35f-428f-9a66-abaa9dd9d285"],
 " siblings, and ",
 Cell[BoxData["\"\<Random\>\""], "InlineFormula",ExpressionUUID->
  "9bfea619-e562-4ccf-a043-3be55668fcf4"],
 ".",
 "\n",
 Cell["   ", "ModInfo",ExpressionUUID->"5b15f9eb-749e-449f-a6ba-1114f350387f"],
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     Cell[
      TextData["PauliStabilizer"]], 
     "paclet:Wolfram/QuantumFramework/ref/PauliStabilizer", 
     "Wolfram/QuantumFramework Package Symbol"},
    "PackageLink",
    BaseStyle->"InlineFormula"], "[", 
   RowBox[{"\"\<Random\>\"", ",", " ", 
    StyleBox["n", "TI"]}], "]"}]], "InlineFormula",ExpressionUUID->
  "81fbdf65-8dab-432d-8cb3-e847c1c9c7f8"],
 "\[LineSeparator]",
 "returns a uniformly random ",
 StyleBox["n", "TI"],
 "-qubit Clifford state via the Mallows sampler.",
 "\n",
 Cell["   ", "ModInfo",ExpressionUUID->"e5385dcf-a1b3-4318-b470-1caaee182557"],
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     Cell[
      TextData["PauliStabilizer"]], 
     "paclet:Wolfram/QuantumFramework/ref/PauliStabilizer", 
     "Wolfram/QuantumFramework Package Symbol"},
    "PackageLink",
    BaseStyle->"InlineFormula"], "[", 
   StyleBox["qs", "TI"], "]"}]], "InlineFormula",ExpressionUUID->
  "7b053fe7-d56b-4486-a482-f6a37d8d3f49"],
 "\[LineSeparator]",
 "converts a ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["QuantumState"]], 
    "paclet:Wolfram/QuantumFramework/ref/QuantumState", 
    "Wolfram/QuantumFramework Package Symbol"},
   "PackageLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",ExpressionUUID->
  "8427ebad-bc6b-4529-b5a4-b23913724a09"],
 ", ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["QuantumOperator"]], 
    "paclet:Wolfram/QuantumFramework/ref/QuantumOperator", 
    "Wolfram/QuantumFramework Package Symbol"},
   "PackageLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",ExpressionUUID->
  "54c445c5-c0fc-4491-9c0b-310fa29e8d72"],
 ", or ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["QuantumCircuitOperator"]], 
    "paclet:Wolfram/QuantumFramework/ref/QuantumCircuitOperator", 
    "Wolfram/QuantumFramework Package Symbol"},
   "PackageLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",ExpressionUUID->
  "ffa0568c-27b0-464b-b00f-8c0f5114e344"],
 " to a stabilizer state (Clifford only)."
}], "Usage",ExpressionUUID->"bb4b8f43-908c-4eaf-a8ea-67867529585c"],

Cell[TextData[{
 "A ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["PauliStabilizer"]], 
    "paclet:Wolfram/QuantumFramework/ref/PauliStabilizer", 
    "Wolfram/QuantumFramework Package Symbol"},
   "PackageLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",ExpressionUUID->
  "0d86bbcf-d80e-49de-831a-867ab1e97194"],
 " encodes an ",
 StyleBox["n", "TI"],
 "-qubit pure stabilizer state by a tableau of Pauli generators plus signs, \
requiring ",
 Cell[BoxData[
  RowBox[{
   StyleBox["O", "TI"], 
   StyleBox["(",
    SpanMaxSize->1], 
   SuperscriptBox[
    StyleBox["n", "TI"], "2"], 
   StyleBox[")",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "8d9ecd4e-3991-4408-9360-7cc1caebc279"],
 " memory."
}], "Notes",ExpressionUUID->"ce0d754e-b7b0-4941-a902-37e04fc211fd"],

Cell[TextData[{
 "The internal representation is an Association ",
 Cell[BoxData[
  RowBox[{"<|", 
   RowBox[{
    RowBox[{"\"\<Tableau\>\"", "->", "t"}], ",", 
    RowBox[{"\"\<Signs\>\"", "->", "s"}]}], "|>"}]], "InlineFormula",
  ExpressionUUID->"8c399785-7d16-4217-83cb-aa613d769c37"],
 " where ",
 StyleBox["t", "TI"],
 " is a rank-3 binary array of shape ",
 Cell[BoxData[
  RowBox[{
   RowBox[{
    RowBox[{"{", "2"}], 
    RowBox[{",", "\[ThinSpace]"}], " ", 
    StyleBox["n", "TI"], 
    RowBox[{",", "\[ThinSpace]"}], " ", "2", 
    StyleBox["n", "TI"]}], "}"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "bdac06a4-e27f-4a2d-9e00-dc9727e48a47"],
 " (X-block, Z-block; ",
 StyleBox["n", "TI"],
 " qubits; ",
 Cell[BoxData[
  RowBox[{"2", 
   StyleBox["n", "TI"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "9c6d0740-a713-4dc1-9e07-82321253b7ef"],
 " rows: destabilizers then stabilizers) and ",
 StyleBox["s", "TI"],
 " is a length-",
 Cell[BoxData[
  RowBox[{"2", 
   StyleBox["n", "TI"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "f2815794-7b6e-4fb8-a6e0-7490298248a2"],
 " list of ",
 Cell[BoxData[
  RowBox[{"\[PlusMinus]", "1"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "f075f3e4-baa0-4817-85fe-17fb6c85543a"],
 " signs."
}], "Notes",ExpressionUUID->"e9f2dbbc-6836-4a39-85b5-2bc721e76f63"],

Cell[TextData[{
 "Equivalent serialization keys are also accepted: ",
 Cell[BoxData["\"\<Phase\>\""], "InlineFormula",ExpressionUUID->
  "e89e1cd4-c5da-4e6d-9f0d-b452f44fde6f"],
 " (= ",
 Cell[BoxData[
  RowBox[{"1", "-", 
   StyleBox["S", "TI"], 
   StyleBox["i", "TI"], 
   StyleBox["g", "TI"], 
   StyleBox["n", "TI"], 
   StyleBox["s", "TI"], "/", "2"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "a92c6925-2656-4624-9122-090db8617f13"],
 ") and ",
 Cell[BoxData["\"\<Matrix\>\""], "InlineFormula",ExpressionUUID->
  "6df0a25a-2fa2-4371-8ed4-d24535610c6f"],
 " (the flat ",
 Cell[BoxData[
  RowBox[{"2", 
   StyleBox["n", "TI"], "\[Times]", "2", 
   StyleBox["n", "TI"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "2139a7ab-1e1e-4e36-ad77-3a567de82a32"],
 " binary tableau)."
}], "Notes",ExpressionUUID->"5c21d899-4d3c-447d-ba37-840341dfa22a"],

Cell[TextData[{
 "Stabilizer rows are the ",
 StyleBox["n", "TI"],
 " parity-check generators of the codespace. Destabilizer rows complete the \
symplectic basis and are required for measurement and ",
 Cell[BoxData["\"\<Dagger\>\""], "InlineFormula",ExpressionUUID->
  "00b12bd7-cd15-4775-9e98-274b2e8ed114"],
 ". String-list constructors auto-generate destabilizers via ",
 Cell[BoxData[
 "Reverse"], "InlineFormula",ExpressionUUID->
  "8a2fd62e-760d-49b5-ab3f-97b0e9c33170"],
 "; supply them explicitly with the two-list form to avoid singular \
fixtures."
}], "Notes",ExpressionUUID->"44b212dd-3418-44a8-942f-f381bd608144"],

Cell[TextData[{
 "Named codes follow the convention that ",
 Cell[BoxData["\"\<5QubitCode\>\""], "InlineFormula",ExpressionUUID->
  "2d6532cd-4f6f-4b7a-83f8-ea8ca7c19cd8"],
 " encodes ",
 Cell[BoxData[
  TemplateBox[{
    SubscriptBox["0", 
     StyleBox["L", "TI"]]},
   "Ket"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "06d76480-5fcb-463e-8f00-4dc8cea66601"],
 " (the +1 eigenstate of logical ",
 Cell[BoxData[
  StyleBox["Z", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "eb4afd68-e889-455e-bd0f-8b0e9d7779bc"],
 "), and the ",
 Cell[BoxData["\"\<\[CenterDot]1\>\""], "InlineFormula",ExpressionUUID->
  "b5bd7829-55fb-4a07-a339-df916d49852c"],
 " sibling encodes ",
 Cell[BoxData[
  TemplateBox[{
    SubscriptBox["1", 
     StyleBox["L", "TI"]]},
   "Ket"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "a5246504-63b7-438f-9f91-a95321f8304c"],
 "."
}], "Notes",ExpressionUUID->"4407c59b-b7c2-43b7-9a4d-21a7edbfaf90"],

Cell[TextData[{
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     Cell[
      TextData["PauliStabilizer"]], 
     "paclet:Wolfram/QuantumFramework/ref/PauliStabilizer", 
     "Wolfram/QuantumFramework Package Symbol"},
    "PackageLink",
    BaseStyle->"InlineFormula"], "[", 
   RowBox[{"\"\<Random\>\"", ",", " ", 
    StyleBox["n", "TI"]}], "]"}]], "InlineFormula",ExpressionUUID->
  "d59c15f2-b2dc-48a4-8580-2b36a342b60f"],
 " uses the Bravyi-Maslov / Koenig-Smolin (arXiv:1406.2170) Mallows sampler \
for uniform sampling over the ",
 Cell[BoxData[
  StyleBox["n", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "c344b4a8-dce5-4958-b8fe-e2190eb61e03"],
 "-qubit Clifford group modulo Paulis."
}], "Notes",ExpressionUUID->"d65d6bd0-5186-49a6-b8d6-f1330ff4305c"],

Cell[TextData[{
 "A stabilizer state ",
 StyleBox["ps", "TI"],
 " supports two access patterns: properties via ",
 Cell[BoxData[
  RowBox[{
   StyleBox["ps", "TI"], "[", "\"\<Property\>\"", "]"}]], "InlineFormula",
  ExpressionUUID->"b7f753a1-014a-4f15-9ecc-76ef750db3ba"],
 " (e.g. ",
 Cell[BoxData["\"\<Stabilizers\>\""], "InlineFormula",ExpressionUUID->
  "bfe950be-f5dd-4543-9ecc-12e317fe945b"],
 ", ",
 Cell[BoxData["\"\<Tableau\>\""], "InlineFormula",ExpressionUUID->
  "e353e083-d06d-41c5-ae0c-5c9514fe9671"],
 ", ",
 Cell[BoxData["\"\<State\>\""], "InlineFormula",ExpressionUUID->
  "ea4e9a81-136e-4ca1-b885-26498391778b"],
 ") and methods via ",
 Cell[BoxData[
  RowBox[{
   StyleBox["ps", "TI"], "[", 
   RowBox[{"\"\<Method\>\"", ",", "\[Ellipsis]"}], "]"}]], "InlineFormula",
  ExpressionUUID->"4be160af-dbf7-4782-884c-530b409e18c8"],
 " (e.g. Clifford gates, measurement, ",
 Cell[BoxData["\"\<InnerProduct\>\""], "InlineFormula",ExpressionUUID->
  "e73b520f-e085-4de6-b421-ae95b5b712ce"],
 "). The full list of accepted strings is available via ",
 Cell[BoxData[
  RowBox[{
   StyleBox["ps", "TI"], "[", "\"\<Properties\>\"", "]"}]], "InlineFormula",
  ExpressionUUID->"f14be382-4834-4f0b-9da4-8ecdf6d48d36"],
 "."
}], "Notes",ExpressionUUID->"04d82f7e-e730-4d20-8dd3-f9f9c0e45ecf"],

Cell[TextData[{
 "As an operator, a constructed ",
 StyleBox["ps", "TI"],
 " is applied by string dispatch: ",
 Cell[BoxData[
  RowBox[{
   StyleBox["ps", "TI"], "[", 
   RowBox[{
    StyleBox["method", "TI"], ",", " ", "\[Ellipsis]"}], "]"}]], 
  "InlineFormula",ExpressionUUID->"0ff64353-d41a-4b20-8903-0ae523571f31"],
 " applies a Clifford gate, measurement, or property accessor, and ",
 Cell[BoxData[
  RowBox[{
   StyleBox["ps", "TI"], "[", 
   SubscriptBox[
    StyleBox["ps", "TI"], 
    StyleBox["2", "TR"]], "]"}]], "InlineFormula",ExpressionUUID->
  "54ced22b-5187-4a9b-b190-043f9f5adf44"],
 " composes two stabilizer states (apply ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox[
    StyleBox[
     RowBox[{"p", "s"}], "TI"],
    FontSlant->"Italic"], "2"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "8de25ce0-1222-4f9d-80b7-108ec8b9c244"],
 " first, then ",
 StyleBox["ps", "TI"],
 ")."
}], "Notes",ExpressionUUID->"b00e7800-025b-4ec5-9374-a119a193eb7c"],

Cell[TextData[{
 "Clifford gate updates run in ",
 Cell[BoxData[
  RowBox[{
   StyleBox["O", "TI"], 
   StyleBox["(",
    SpanMaxSize->1], 
   SuperscriptBox[
    StyleBox["n", "TI"], "2"], 
   StyleBox[")",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "ce84fd31-ab15-4210-85f5-f6a039b7a468"],
 " time using the Aaronson-Gottesman tableau (arXiv:quant-ph/0406196). \
Single-qubit gates: ",
 Cell[BoxData["\"\<H\>\""], "InlineFormula",ExpressionUUID->
  "e35fdb5a-c279-460e-8fdd-e3fecf9bfc36"],
 ", ",
 Cell[BoxData["\"\<S\>\""], "InlineFormula",ExpressionUUID->
  "a561fb0c-df40-4043-a0ad-258d5edfa6ff"],
 ", ",
 Cell[BoxData[
  RowBox[{"\"\<\>", 
   StyleBox["S", "TI"], 
   SuperscriptBox["\"\<\>", "\[Dagger]"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "e44e3230-57fc-4b84-b2e2-0f29d3756f4f"],
 ", ",
 Cell[BoxData["\"\<X\>\""], "InlineFormula",ExpressionUUID->
  "d2a8ac41-ba41-497e-80aa-66d4b476701e"],
 ", ",
 Cell[BoxData["\"\<Y\>\""], "InlineFormula",ExpressionUUID->
  "e045d2bb-2837-487f-af9f-a196c6f468fd"],
 ", ",
 Cell[BoxData["\"\<Z\>\""], "InlineFormula",ExpressionUUID->
  "4604b2b6-5976-4341-8de8-bb28dfe4a270"],
 ", ",
 Cell[BoxData["\"\<V\>\""], "InlineFormula",ExpressionUUID->
  "34bf7860-22e0-4ca3-b48b-98dcf043da9d"],
 ". Two-qubit gates: ",
 Cell[BoxData["\"\<CNOT\>\""], "InlineFormula",ExpressionUUID->
  "3df6a1b5-7965-43ce-bcd4-45d040648f42"],
 " (or ",
 Cell[BoxData["\"\<CX\>\""], "InlineFormula",ExpressionUUID->
  "71a1a7ba-9baa-4781-b4e2-36fd16274ce3"],
 "), ",
 Cell[BoxData["\"\<CZ\>\""], "InlineFormula",ExpressionUUID->
  "dab6e335-c137-4b19-ab67-a78a34d104e6"],
 ", ",
 Cell[BoxData["\"\<SWAP\>\""], "InlineFormula",ExpressionUUID->
  "637ff80d-2e17-479c-838f-4c7b34b1c238"],
 "."
}], "Notes",ExpressionUUID->"f604cb8e-4193-4436-b07e-1a3f4cc73a3b"],

Cell[TextData[{
 "Non-Clifford gates ",
 Cell[BoxData[
  RowBox[{"\"\<\>", 
   StyleBox["P", "TI"], "\"\<\>", 
   RowBox[{
    StyleBox["[",
     SpanMaxSize->1], 
    StyleBox["\[Theta]", "TI"], 
    StyleBox["]",
     SpanMaxSize->1]}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "20f972d3-c033-4e3b-833e-984c996b842f"],
 ", ",
 Cell[BoxData["\"\<T\>\""], "InlineFormula",ExpressionUUID->
  "6f098884-1bc5-4f5e-9266-eadecb51be17"],
 ", and ",
 Cell[BoxData[
  RowBox[{"\"\<\>", 
   StyleBox["T", "TI"], 
   SuperscriptBox["\"\<\>", "\[Dagger]"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "1ff508c3-f4c6-4ba3-87a4-7eba8f74897b"],
 " return a ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["StabilizerFrame"]], 
    "paclet:Wolfram/QuantumFramework/ref/StabilizerFrame", 
    "Wolfram/QuantumFramework Package Symbol"},
   "PackageLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",ExpressionUUID->
  "04ffdfec-cbb1-4c51-affc-d112c5ba3049"],
 " (a coherent superposition of stabilizer states) rather than a ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["PauliStabilizer"]], 
    "paclet:Wolfram/QuantumFramework/ref/PauliStabilizer", 
    "Wolfram/QuantumFramework Package Symbol"},
   "PackageLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",ExpressionUUID->
  "9603d80a-8b69-44f4-833c-85c7253294b1"],
 ". The frame closes under further Clifford gates."
}], "Notes",ExpressionUUID->"19048bb6-dd95-49e3-83a2-1f9baaf2ae1a"],

Cell[TextData[{
 "Symbolic measurement (Fang-Ying 2023, arXiv:2311.03906) via ",
 Cell[BoxData["\"\<SymbolicMeasure\>\""], "InlineFormula",ExpressionUUID->
  "1752c7f8-2c8b-432e-8260-756f629ded4c"],
 " allocates a fresh ",
 Cell[BoxData[
  RowBox[{
   StyleBox["s", "TI"], 
   StyleBox["[",
    SpanMaxSize->1], 
   StyleBox["k", "TI"], 
   StyleBox["]",
    SpanMaxSize->1]}]], "InlineFormula",
