Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Module", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"ps", ",", " ", "qs", ",", " ", "ps2"}], "}"}], ",", " ", 
   RowBox[{
    RowBox[{"ps", " ", "=", " ", 
     RowBox[{"PauliStabilizer", "[", 
      RowBox[{"QuantumCircuitOperator", "[", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"\"\<H\>\"", " ", "->", " ", "1"}], ",", " ", 
         RowBox[{"\"\<CNOT\>\"", " ", "->", " ", 
          RowBox[{"{", 
           RowBox[{"1", ",", " ", "2"}], "}"}]}]}], "}"}], "]"}], "]"}]}], ";",
     " ", 
    RowBox[{"qs", " ", "=", " ", 
     RowBox[{"ps", "[", "\"\<State\>\"", "]"}]}], ";", " ", 
    RowBox[{"ps2", " ", "=", " ", 
     RowBox[{"PauliStabilizer", "[", "qs", "]"}]}], ";", " ", 
    RowBox[{
     RowBox[{"ps", "[", "\"\<Stabilizers\>\"", "]"}], " ", "===", " ", 
     RowBox[{"ps2", "[", "\"\<Stabilizers\>\"", "]"}]}]}]}], "]"}]], "Input",
