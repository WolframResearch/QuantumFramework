Cell[CellGroupData[{

Cell["50-qubit random Clifford tableau as MatrixPlot", "ExampleSubsection",
 CellID->560690554,ExpressionUUID->"09eeaaaf-fb46-490d-b975-9483b1f1f633"],

Cell["\<\
Visualize the symplectic structure of a large random Clifford:\
\>", "ExampleText",
 CellID->104877550,ExpressionUUID->"85fb3fd7-e215-4d4a-992b-f34b1d7de53b"],

Cell[BoxData[
 RowBox[{"Module", "[", 
  RowBox[{
   RowBox[{"{", "ps", "}"}], ",", " ", 
   RowBox[{
    RowBox[{"SeedRandom", "[", "1", "]"}], ";", " ", 
    RowBox[{"ps", " ", "=", " ", 
     RowBox[{"PauliStabilizer", "[", 
      RowBox[{"\"\<Random\>\"", ",", " ", "50"}], "]"}]}], ";", " ", 
    RowBox[{"MatrixPlot", "[", 
     RowBox[{
      RowBox[{"ps", "[", "\"\<Matrix\>\"", "]"}], ",", " ", 
      RowBox[{"FrameTicks", " ", "->", " ", "None"}], ",", " ", 
      RowBox[{"ImageSize", " ", "->", " ", "250"}]}], "]"}]}]}], 
  "]"}]], "Input",
 CellLabel->"In[1]:=",
 CellID->300019485,ExpressionUUID->"a158eca5-0547-47cf-80f0-229b5dfc2a2a"],

