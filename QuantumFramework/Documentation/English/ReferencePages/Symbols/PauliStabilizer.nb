   RowBox[{
    RowBox[{"\"\<RX\>\"", "[", 
     RowBox[{"Pi", "/", "3"}], "]"}], ",", " ", 
    RowBox[{"{", "1", "}"}]}], "]"}], "[", 
  RowBox[{"QuantumState", "[", "\"\<0\>\"", "]"}], "]"}]], "Input",
 CellLabel->"In[2]:= ",ExpressionUUID->"b411929d-d97d-46d0-a35d-ba682877316e"],

