Cell[CellGroupData[{

Cell["PauliStabilizer::nonclifford", "ExampleSubsection",ExpressionUUID->"b0d331ad-b846-427d-b471-b109fcc5e05c"],

Cell[TextData[{
 "The PauliStabilizer tableau formalism tracks only Clifford gates. Applying \
a non-Clifford operator such as a continuous rotation \"RX\"[",
 Cell[BoxData[
  StyleBox["\[Theta]", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "de51c8bf-7b59-48d9-9203-b1fc620507ac"],
 "] (via the public QuantumOperator-on-PauliStabilizer dispatch) cannot be \
folded into the tableau, emits PauliStabilizer::nonclifford, and returns \
$Failed. The fold short-circuits, so the message fires only once even in a \
multi-gate circuit:"
}], "ExampleText",ExpressionUUID->"6b88a6d4-5f2b-4711-80de-0f9cbc817094"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"QuantumOperator", "[", 
   RowBox[{
    RowBox[{"\"\<RX\>\"", "[", 
     RowBox[{"Pi", "/", "3"}], "]"}], ",", " ", 
    RowBox[{"{", "1", "}"}]}], "]"}], "[", 
  RowBox[{"PauliStabilizer", "[", "1", "]"}], "]"}]], "Input",
 CellLabel->"In[1]:= ",ExpressionUUID->"0c8f8522-01ba-46bd-811c-0990c7e0544c"],

Cell["\<\
PauliStabilizer::nonclifford: 
          Pi
   Gate R[--, {X -> {1}}] is not a Clifford operation; PauliStabilizer cannot
          3
     update the tableau. Use Method -> \"TensorNetwork\" or \"Schrodinger\" for
     non-Clifford circuits.\
\>", "Message", "MSG",ExpressionUUID->"a9fb66e8-6fb6-47cc-8019-13a047f308f1"],

Cell[BoxData["$Failed"], "Output",
 CellLabel->"Out[1]= ",ExpressionUUID->"3c06b687-6dab-4df4-b280-c26d8232c4d6"]
}, Open  ]],

Cell["\<\
Resolution: evaluate non-Clifford operators via the dense state-vector path: \
apply the QuantumOperator to a QuantumState instead of a PauliStabilizer. \
This sidesteps the tableau and supports arbitrary unitaries:\
\>", "ExampleText",ExpressionUUID->"17d3da46-a2f4-44a5-ba74-92ef7cf8d85f"],

