Cell[CellGroupData[{

Cell["PauliStabilizer::nonpaulibasis", "ExampleSubsection",ExpressionUUID->"baaedc39-9b30-4788-bad6-7a22b7a3f359"],

Cell["\<\
The PauliStabilizer fast-path for QuantumMeasurementOperator and \
QuantumChannel requires a Pauli-basis label. A non-Pauli basis (here a \
diagonal operator with eigenvalues {1, 2}) emits \
PauliStabilizer::nonpaulibasis and falls back to dense state-vector \
evaluation: the head of the result becomes QuantumMeasurement:\
\>", "ExampleText",ExpressionUUID->"9ac9adac-b1aa-4bd4-a394-1597ceeee711"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"QuantumMeasurementOperator", "[", 
   RowBox[{
    RowBox[{"QuantumOperator", "[", 
     RowBox[{"DiagonalMatrix", "[", 
      RowBox[{"{", 
       RowBox[{"1", ",", " ", "2"}], "}"}], "]"}], "]"}], ",", " ", 
    RowBox[{"{", "1", "}"}]}], "]"}], "[", 
  RowBox[{"PauliStabilizer", "[", "1", "]"}], "]"}]], "Input",
 CellLabel->"In[1]:= ",ExpressionUUID->"1c913433-3627-4699-a576-d6bc4001078e"],

Cell["\<\
PauliStabilizer::nonpaulibasis: 
   Hybrid interop: the measurement/channel basis is non-Pauli; falling back \
to
    the generic circuit path.\
\>", "Message", "MSG",ExpressionUUID->"d2a80ca7-5e33-452f-a043-b2c315f0c2c5"],

