      RowBox[{"ps", "[", "\"\<Stabilizers\>\"", "]"}], ",", " ", 
      RowBox[{"ps", "[", "\"\<Destabilizers\>\"", "]"}], ",", " ", 
      RowBox[{"Dimensions", "[", 
       RowBox[{"ps", "[", "\"\<Tableau\>\"", "]"}], "]"}], ",", " ", 
      RowBox[{"Dimensions", "[", 
       RowBox[{"ps", "[", "\"\<Matrix\>\"", "]"}], "]"}], ",", " ", 
      RowBox[{"Head", "[", 
       RowBox[{"ps", "[", "\"\<State\>\"", "]"}], "]"}]}], "}"}]}]}], 
