   RowBox[{"{", 
    RowBox[{"cc1", ",", " ", "cc2"}], "}"}], ",", " ", 
   RowBox[{
    RowBox[{"cc1", " ", "=", " ", 
     RowBox[{"CliffordChannel", "[", 
      RowBox[{"\"\<Identity\>\"", ",", " ", "2"}], "]"}]}], ";", " ", 
    RowBox[{"cc2", " ", "=", " ", 
     RowBox[{"CliffordChannel", "[", 
      RowBox[{"\"\<Identity\>\"", ",", " ", "2"}], "]"}]}], ";", " ", 
