        RowBox[{"\"\<OutputQubits\>\"", " ", "->", " ", "1"}], ",", " ", 
        RowBox[{"\"\<Source\>\"", " ", "->", " ", "\"\<S\>\""}]}], "]"}], 
      "]"}]}], ";", " ", 
    RowBox[{"ccS2", " ", "=", " ", 
     RowBox[{"ccS", "[", "ccS", "]"}]}], ";", " ", 
    RowBox[{"ccS3", " ", "=", " ", 
     RowBox[{"ccS", "[", "ccS2", "]"}]}], ";", " ", 
    RowBox[{"{", 
