   RowBox[{"{", 
    RowBox[{"ps", ",", " ", "cc", ",", " ", "psRecovered"}], "}"}], ",", " ", 
   
   RowBox[{
    RowBox[{"ps", " ", "=", " ", 
     RowBox[{"PauliStabilizer", "[", 
      RowBox[{"{", 
       RowBox[{"\"\<XX\>\"", ",", " ", "\"\<ZZ\>\""}], "}"}], "]"}]}], ";", 
    " ", 
    RowBox[{"cc", " ", "=", " ", 
     RowBox[{"CliffordChannel", "[", "ps", "]"}]}], ";", " ", 
    RowBox[{"psRecovered", " ", "=", " ", 
     RowBox[{"cc", "[", 
      RowBox[{"PauliStabilizer", "[", "2", "]"}], "]"}]}], ";", " ", 
    RowBox[{
     RowBox[{"psRecovered", "[", "\"\<Stabilizers\>\"", "]"}], " ", "===", 
