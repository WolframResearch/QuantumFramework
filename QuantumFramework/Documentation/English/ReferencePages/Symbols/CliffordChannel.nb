    RowBox[{"ccS", " ", "=", " ", 
     RowBox[{"CliffordChannel", "[", 
      RowBox[{"Association", "[", 
       RowBox[{
        RowBox[{"\"\<UA\>\"", " ", "->", " ", 
         RowBox[{"{", 
