        RowBox[{"\"\<OutputQubits\>\"", " ", "->", " ", "1"}], ",", " ", 
        RowBox[{"\"\<Source\>\"", " ", "->", " ", "\"\<S\>\""}]}], "]"}], 
      "]"}]}], ";", " ", 
    RowBox[{"ccZ", " ", "=", " ", 
     RowBox[{"ccS", "[", "ccS", "]"}]}], ";", " ", 
    RowBox[{"ccZ", "[", "\"\<c\>\"", "]"}]}]}], "]"}]], "Input",
