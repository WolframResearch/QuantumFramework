Notebook[{

Cell[CellGroupData[{
Cell["QiskitTarget", "ObjectName",
 CellID->1224892054,ExpressionUUID->"8393d601-4014-44ba-afc9-60862df940ec"],

Cell[TextData[{
 Cell["   ", "ModInfo",ExpressionUUID->"9d04079f-4c8c-48ee-b203-75a8867554d6"],
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     Cell[
      TextData["QiskitTarget"]], 
     "paclet:Wolfram/QuantumFramework/ref/QiskitTarget", 
     "Wolfram/QuantumFramework Package Symbol"},
    "PackageLink",
    BaseStyle->"InlineFormula"], "[", 
   StyleBox["spec", "TI"], "]"}]], "InlineFormula",ExpressionUUID->
  "897d93e9-b8f6-4a69-a39d-12272c6b9691"],
 " ",
 "builds a qiskit transpiler target from the device specification ",
 StyleBox["spec", "TI"],
 ", an Association of qiskit ",
 Cell[BoxData[
  RowBox[{"Target", ".", "from_configuration"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "6280c5be-7590-4f9c-ac84-f915422f8ad7"],
 " parameters.",
 "\n",
 Cell["   ", "ModInfo",ExpressionUUID->"b5affe10-2e52-41eb-94b6-716ea733a1cb"],
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     Cell[
      TextData["QiskitTarget"]], 
     "paclet:Wolfram/QuantumFramework/ref/QiskitTarget", 
     "Wolfram/QuantumFramework Package Symbol"},
    "PackageLink",
    BaseStyle->"InlineFormula"], "[", 
   RowBox[{
    RowBox[{"\"\<FromBackend\>\"", " ", "->", " ", 
     StyleBox["name", "TI"]}], ",", " ", 
    RowBox[{"\"\<Provider\>\"", " ", "->", " ", 
     StyleBox["p", "TI"]}]}], "]"}]], "InlineFormula",ExpressionUUID->
  "c8015c2c-4d4a-47bf-a174-70faaf7f2d43"],
 " ",
 "builds an error-aware target by reading the live backend ",
 StyleBox["name", "TI"],
 "'s own qiskit ",
 Cell[BoxData["Target"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "9842c7aa-9871-4e34-a784-c8eed61c01e3"],
 ", including its per-instruction error and duration; ",
 StyleBox["p", "TI"],
 " selects the provider (",
 Cell[BoxData["\"\<IBMProvider\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "4b217a2d-5e8c-43af-9e22-10f359ab1780"],
 ", ",
 Cell[BoxData["\"\<AWSProvider\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "88d17b1a-b317-46b5-88fa-58108c0f599d"],
 ", or ",
 Cell[BoxData["\"\<GenericV2\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "fe4faadf-3471-42be-b2bf-8643a69f0f9f"],
 " for a local fake device)."
}], "Usage",ExpressionUUID->"03f6301e-70e3-44e6-87ec-0ade36614676"],

Cell[TextData[{
 "A ",
 Cell[BoxData["QiskitTarget"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "d14608e3-cd63-4ae8-9825-2107852b4cc8"],
 " describes a device for transpilation: its native gate set, qubit \
connectivity, and (optionally) per-instruction errors and durations. It is \
the device argument of ",
 Cell[BoxData["QuantumQASM"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "31da9584-0c23-4706-9828-fb31aca32633"],
 "'s ",
 Cell[BoxData["\"\<Target\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "782fab41-49ef-4254-a6b1-64bba1729b92"],
 " option."
}], "Notes",ExpressionUUID->"413b1f6e-08e1-4e3d-877e-1c569ff024dc"],

Cell[TextData[{
 StyleBox["spec", "TI"],
 " is an Association whose keys are qiskit ",
 Cell[BoxData[
  RowBox[{"Target", ".", "from_configuration"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "103c1d7e-43cf-4219-a296-b4d28f227a1b"],
 " parameters: ",
 Cell[BoxData["\"\<BasisGates\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "fde4bb41-ad00-4cbb-a23e-7aabf9f694ee"],
 ", ",
 Cell[BoxData["\"\<NumQubits\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "d5eee94a-f30f-46f3-b2cb-7a92e2526952"],
 ", ",
 Cell[BoxData["\"\<CouplingMap\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "f19eff0f-9598-44f0-af4e-0bec22ac832d"],
 ", ",
 Cell[BoxData["\"\<InstructionDurations\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "3b5096d4-9d8d-44db-8bdd-d3bac6c66108"],
 ", ",
 Cell[BoxData["\"\<ConcurrentMeasurements\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "6a5352bc-0a7e-4fb7-87be-433576089609"],
 ", ",
 Cell[BoxData["\"\<Dt\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "68e3d4b0-f448-4e2c-b36c-8aa7abbd448c"],
 ", ",
 Cell[BoxData["\"\<TimingConstraints\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "f0b62ac2-4cf0-4088-8adc-61fbeee78990"],
 ", ",
 Cell[BoxData["\"\<CustomNameMapping\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "9457f8ed-aa65-4087-abdd-044f013ebf83"],
 ". Keys are CamelCase and map to qiskit's snake_case names; the raw \
snake_case name is accepted too. The accepted key set is read from the \
installed qiskit, so it tracks the ",
 ButtonBox["qiskit Target.from_configuration documentation",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://docs.quantum.ibm.com/api/qiskit/qiskit.transpiler.Target#\
from_configuration"], None}],
 " of whichever version is installed."
}], "Notes",ExpressionUUID->"5c2e801d-2b66-4b3b-92e8-7af3df2c131e"],

Cell[TextData[{
 "Each value takes qiskit's own form: ",
 Cell[BoxData["\"\<NumQubits\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "ad43dccc-2b4f-461a-984b-c56bec98ea7f"],
 " an integer; ",
 Cell[BoxData["\"\<CouplingMap\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "618797cd-b76e-4789-995e-1f5b99c06755"],
 " a list of directed integer pairs ",
 Cell[BoxData[
  RowBox[{"{", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"c", ",", " ", "t"}], "}"}], ",", " ", "\[Ellipsis]"}], "}"}]], 
  "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "64b022ea-7ece-4a0e-8f4b-09ae330d42b0"],
 "; ",
 Cell[BoxData["\"\<Dt\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "f748a817-be96-4ace-8387-81252b2c5ae7"],
 " a number of seconds; ",
 Cell[BoxData["\"\<InstructionDurations\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "167d8eb1-3d0a-4856-8684-f6663d594476"],
 ", ",
 Cell[BoxData["\"\<ConcurrentMeasurements\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "4e2c49f2-51df-4c5f-8883-f3eb83379544"],
 ", ",
 Cell[BoxData["\"\<TimingConstraints\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "0940a1b4-d1f3-4909-bf6f-6c85395cbb12"],
 " and ",
 Cell[BoxData["\"\<CustomNameMapping\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "fa60895d-d1a8-40c8-9240-b803f8965cd8"],
 " the structures qiskit's ",
 Cell[BoxData[
  RowBox[{"Target", ".", "from_configuration"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "ae3ee258-9179-45e5-984f-4d8cf44e621f"],
 " expects."
}], "Notes",ExpressionUUID->"26d2b31c-578c-4fc9-8a5c-7b143e1741f7"],

Cell[TextData[{
 Cell[BoxData["\"\<BasisGates\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "ab9ced28-b491-4be7-88cd-edb3747de0cc"],
 " is a list of qiskit ",
 StyleBox["standard gate names", "TI"],
 " \[LongDash] the names are defined by the installed qiskit, not by ",
 Cell[BoxData["QiskitTarget"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "bae53f52-0817-4472-aa69-94499fe6657b"],
 ", and vary by version. In the bundled qiskit 2.4.1 there are 54, including \
the single-qubit ",
 Cell[BoxData["\"\<x\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "e09d9e3b-894b-4eaa-81d8-ebe6f6bd2f6c"],
 ", ",
 Cell[BoxData["\"\<y\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "e6dfedfc-4d8f-48fd-a8e4-4ad7d1824a14"],
 ", ",
 Cell[BoxData["\"\<z\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "ab7a2dd7-ab05-459f-ae10-083a54b09e1f"],
 ", ",
 Cell[BoxData["\"\<h\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "6c08aba0-be61-46ec-b411-979747afccbe"],
 ", ",
 Cell[BoxData["\"\<s\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "9850db07-03b5-49e8-9db7-9e138aad0f4c"],
 ", ",
 Cell[BoxData["\"\<sx\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "d65b17eb-cf25-43e5-9a50-fd04f6320771"],
 ", ",
 Cell[BoxData["\"\<t\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "a3df2faa-51f8-4651-850c-3442f56bd435"],
 ", ",
 Cell[BoxData["\"\<rx\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "448e3542-11d9-4e4b-a8b9-19a070f2db4a"],
 ", ",
 Cell[BoxData["\"\<ry\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "d7e350ed-a2fc-4ae8-8ad0-6d40444b4997"],
 ", ",
 Cell[BoxData["\"\<rz\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "790536a5-95f3-49de-a7f7-dcff6cfc7d17"],
 ", ",
 Cell[BoxData["\"\<p\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "2954a68b-ca1c-4402-b528-378d2d3ec856"],
 ", ",
 Cell[BoxData["\"\<u\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "2d99a086-28ec-4cf8-aaf3-611e138d9d95"],
 ", ",
 Cell[BoxData["\"\<u3\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "3c34bc3b-8c9f-4203-921b-75ee7ddef336"],
 ", the two-qubit ",
 Cell[BoxData["\"\<cx\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "226ae503-38bf-4c5e-8271-f8bc2628cce6"],
 ", ",
 Cell[BoxData["\"\<cz\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "1722c627-5ba3-4718-a408-20f645e5293e"],
 ", ",
 Cell[BoxData["\"\<cy\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "ceafb073-614a-4b48-b383-fb2f3687e121"],
 ", ",
 Cell[BoxData["\"\<ch\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "200514e4-cb51-413d-b914-9b478d8cecce"],
 ", ",
 Cell[BoxData["\"\<swap\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "05024dc2-4dc2-447e-872c-1647b552e9de"],
 ", ",
 Cell[BoxData["\"\<iswap\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "248652d5-809c-4e50-bc53-66e01f5f7123"],
 ", ",
 Cell[BoxData["\"\<ecr\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "f38b8541-df38-4fbe-a95c-32ed0f87938d"],
 ", ",
 Cell[BoxData["\"\<rzz\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "3a9fe316-598d-4883-af46-0e9c4c016a14"],
 ", ",
 Cell[BoxData["\"\<rxx\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "8738f95a-2f5c-4e5c-b9b4-696d43a06a28"],
 ", and the three-qubit ",
 Cell[BoxData["\"\<ccx\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "bbcfb23a-f819-4be0-a562-72496e05768d"],
 ", ",
 Cell[BoxData["\"\<ccz\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "6fdde907-5677-49e0-9e58-3e3552a484f3"],
 ", ",
 Cell[BoxData["\"\<cswap\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "99cba10a-08d1-4c94-8094-b5f8c60f126f"],
 ". The names listed here are those of qiskit 2.4.1; a different qiskit \
version may add, rename, or remove gate names, so the list could differ from \
what is shown. The complete, version-correct list is qiskit's standard \
gate-name mapping, obtainable with ",
 Cell[BoxData[
  RowBox[{
   RowBox[{"qiskit", ".", "circuit", ".", "library", ".", "get_standard"}], 
   "_gate", "_name", "_mapping"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "e17ba0c2-304c-4981-b854-38a283f7089c"],
 " or from qiskit's ",
 ButtonBox["circuit-library documentation",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://docs.quantum.ibm.com/api/qiskit/circuit_library"], None}],
 ". A name outside that set must be supplied through ",
 Cell[BoxData["\"\<CustomNameMapping\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "b931addf-1f09-42ba-92d4-97b2a4fef884"],
 "."
}], "Notes",ExpressionUUID->"12e7fb73-c633-4ff8-a911-5d90975acb13"],

Cell[TextData[{
 "The keys are validated against the installed qiskit at call time, so an \
unknown key gives a ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["Failure"]], "paclet:ref/Failure"},
   "RefLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",ExpressionUUID->
  "c797facc-3625-4d68-8f9f-9585f1397509"],
 " (see Possible Issues) and any current or future qiskit ",
 Cell[BoxData["Target"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "8b193c12-095a-4b67-8d3c-f454b76f8b44"],
 " parameter is accepted without a change to ",
 Cell[BoxData["QiskitTarget"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "7a443752-68cc-4ad9-a704-3c043fbbf5e6"],
 "."
}], "Notes",ExpressionUUID->"c4d39d0d-d7cc-4fbb-844d-687c2275b40b"],

Cell[TextData[{
 Cell[BoxData["QiskitTarget"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "b4020b86-ede0-47a8-97af-6ee53e4d0ee5"],
 " stores the validated specification rather than a serialized qiskit ",
 Cell[BoxData["Target"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "c9d31719-6c8f-42b8-9c0e-230db4010baf"],
 "; the live target is rebuilt from the spec when it is used (inside ",
 Cell[BoxData["QuantumQASM"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "8d3a4b3a-f07b-4430-a72a-945993899494"],
 "), so the same object works across qiskit sessions and versions."
}], "Notes",ExpressionUUID->"05f39ef7-b7bd-46f0-9047-dd55c7f57436"],

Cell[TextData[{
 Cell[BoxData["measure"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "79895802-58c3-41fe-872c-2ccf48e802ad"],
 " and ",
 Cell[BoxData["reset"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "c7d1d43e-d314-472a-9b65-9156f6d8264f"],
 " are added on every qubit automatically \[LongDash] they are universal but ",
 Cell[BoxData[
  RowBox[{"Target", ".", "from_configuration"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "cf4921cb-68d2-4f90-b2bf-a1f0b7965f24"],
 " omits them for a bare unitary basis \[LongDash] so a target built from ",
 Cell[BoxData[
  RowBox[{"{", 
   RowBox[{"\"\<x\>\"", ",", " ", "\"\<sx\>\"", ",", " ", "\"\<rz\>\"", ",", 
    " ", "\"\<cz\>\""}], "}"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "e47cc937-b462-4caf-b674-3336bc6165dd"],
 " still transpiles circuits that contain measurements."
}], "Notes",ExpressionUUID->"a54d0c93-0dff-4ac2-bc2d-17b7679b61ab"],

Cell[TextData[{
 Cell[BoxData["\"\<InstructionProperties\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "421a808b-f57f-449b-b5f3-9a1dbc42822d"],
 " is a reserved spec key that makes transpilation ",
 StyleBox["error-aware",
  FontWeight->"Bold"],
 ": a list of rows ",
 Cell[BoxData[
  RowBox[{"{", 
   RowBox[{
    RowBox[{"*", "gate", "*"}], ",", " ", 
    RowBox[{"{", 
     RowBox[{"*", "qubits", "*", "\[Ellipsis]"}], "}"}], ",", " ", 
    RowBox[{"<|", 
     RowBox[{
      RowBox[{"\"\<Error\>\"", " ", "->", " ", 
       RowBox[{"*", "e", "*"}]}], ",", " ", 
      RowBox[{"\"\<Duration\>\"", " ", "->", " ", 
       RowBox[{"*", "d", "*"}]}]}], "|>"}]}], "}"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "c45940c5-5227-4f4f-a5ee-38cdf7610f7b"],
 " (either field may be omitted). After the target is built, each row is \
applied with qiskit's ",
 Cell[BoxData[
  RowBox[{
   RowBox[{"Target", ".", "update_instruction"}], "_properties"}]], 
  "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "e96f35bb-cb48-4f00-811b-4b816a8db003"],
 ", so ",
 Cell[BoxData["optimization_level"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "a76bdb1a-7187-46ff-aec9-36cf908b5042"],
 " 1 and above bias layout and routing toward low-error qubits and pairs. A \
row whose gate or qubits are not in the target is skipped (recorded on the \
transpiled circuit's metadata, surfaced by ",
 Cell[BoxData[
  RowBox[{"QuantumQASM", "::", "skippedProps"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "31ac58fd-2645-4a58-9ab1-6accb8d009a5"],
 "), never applied blindly; an ",
 Cell[BoxData["error"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "90bfc1ca-478c-4c31-a83c-d0b6b8e87ffe"],
 " of ",
 Cell[BoxData["measure"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "7f39e84c-67d4-4e9d-96cc-175b05ac0594"],
 " rows also steers the layout away from high-readout-error qubits."
}], "Notes",ExpressionUUID->"3f5f2cb3-5ff6-4ed6-b6f0-76e891abe824"],

Cell[TextData[{
 Cell[BoxData[
  RowBox[{
   RowBox[{"[", "QiskitTarget", "]"}], 
   RowBox[{
    RowBox[{"(", ")"}], "[", 
    RowBox[{
     RowBox[{"\"\<FromBackend\>\"", " ", "->", " ", 
      RowBox[{"*", "name", "*"}]}], ",", " ", "\[Ellipsis]"}], "]"}]}]], 
  "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "91eba9b1-38e5-4868-b605-9056d4d75fa6"],
 " reads ",
 Cell[BoxData[
  RowBox[{"*", "name", "*"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "45817b2b-a2c0-486d-a4d0-7935f6f0e763"],
 "'s populated ",
 Cell[BoxData["Target"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "6fce67c6-b35a-45d6-9348-a8e9a5a1a216"],
 " and emits exactly this ",
 Cell[BoxData["\"\<InstructionProperties\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "258a3fc0-9407-4520-8705-3651e1dbbdc1"],
 " spec, so a circuit transpiled against the result lands on the device's \
lowest-error qubits. The same spec can be produced for non-qiskit devices \
(for example by ",
 Cell[BoxData["QUALink"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "1184da92-8526-48df-aa34-cf5c76e5f6d0"],
 "'s ",
 Cell[BoxData[
  RowBox[{
   RowBox[{"QUAConnect", "[", "\[Ellipsis]", "]"}], "[", "\"\<TargetSpec\>\"",
    "]"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "5fbdbdc6-baff-4672-b16a-7b53fa7542db"],
 " for the IQCC ",
 Cell[BoxData["arbel"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "3c0cf8ad-73f3-4dd1-9167-e96d89fb6b34"],
 " QPU), so one error-aware-target mechanism serves every backend."
}], "Notes",ExpressionUUID->"745b2313-f2bc-4ce7-b50f-450a569adc42"],

Cell[TextData[{
 "A ",
 Cell[BoxData["QiskitTarget"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "2d4c94f2-24e5-4b77-9860-303fcd1bbb48"],
 " displays as a summary panel showing its qubit count, native gate names, \
number of coupling edges, and whether it carries per-instruction error data."
}], "Notes",ExpressionUUID->"388ee84e-bd2a-469f-8ada-b76f0d097e9f"],

Cell[TextData[{
