Cell[TextData[{
 "At ",
 Cell[BoxData["optimization_level"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "4ada1984-f231-4963-bdad-cfd2858a3dfd"],
 " 3 the Bell's ",
 Cell[BoxData["cz"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "70402635-6665-4219-b2e2-a3b8f25e7fb6"],
 " is routed onto that low-error edge:"
}], "ExampleText",ExpressionUUID->"099a6734-5f01-4e6d-ad17-3f56ea6ffc61"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"qc", " ", "=", " ", 
   RowBox[{"QuantumCircuitOperator", "[", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"\"\<H\>\"", " ", "->", " ", "1"}], ",", " ", 
      RowBox[{"\"\<CNOT\>\"", " ", "->", " ", 
       RowBox[{"{", 
        RowBox[{"1", ",", " ", "2"}], "}"}]}], ",", " ", 
      RowBox[{"{", "1", "}"}], ",", " ", 
      RowBox[{"{", "2", "}"}]}], "}"}], "]"}]}], ";"}], "\n", 
 RowBox[{"First", " ", "@", " ", 
  RowBox[{"StringCases", "[", 
   RowBox[{
    RowBox[{"QuantumQASM", "[", 
     RowBox[{"qc", ",", " ", 
      RowBox[{"\"\<Target\>\"", " ", "->", " ", "tgt"}], ",", " ", 
      RowBox[{"\"\<OptimizationLevel\>\"", " ", "->", " ", "3"}], ",", " ", 
      RowBox[{"\"\<SeedTranspiler\>\"", " ", "->", " ", "0"}]}], "]"}], ",", 
    "\n", "   ", 
    RowBox[{
     RowBox[{"\"\<cz $\>\"", " ", "~~", " ", 
      RowBox[{"a", " ", ":", " ", 
       RowBox[{"DigitCharacter", " ", ".."}]}], " ", "~~", " ", "\"\<, $\>\"",
       " ", "~~", " ", 
      RowBox[{"b", " ", ":", " ", 
       RowBox[{"DigitCharacter", " ", ".."}]}]}], " ", ":>", " ", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"FromDigits", " ", "@", " ", "a"}], ",", " ", 
       RowBox[{"FromDigits", " ", "@", " ", "b"}]}], "}"}]}]}], 
   "]"}]}]}], "Input",
 CellChangeTimes->{{3.990549529644773*^9, 3.990549529998551*^9}},
 CellLabel->"In[9]:=",ExpressionUUID->"82d2fb48-d56e-4e8f-8d2a-a7bbadf499b5"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"1", ",", "2"}], "}"}]], "Output",
 CellChangeTimes->{3.990549532910956*^9},
 CellLabel->"Out[10]=",
 CellID->1234552843,ExpressionUUID->"66e1567b-31d3-49fc-8c2b-c7c5b0781466"]
}, Open  ]],

Cell["\<\
Drop the error rows and the same circuit no longer prefers that edge, it \
places by connectivity alone:\
\>", "ExampleText",ExpressionUUID->"471ea19b-e8c4-445f-94ba-76f62f07c8ad"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"First", " ", "@", " ", 
  RowBox[{"StringCases", "[", 
   RowBox[{
    RowBox[{"QuantumQASM", "[", 
     RowBox[{"qc", ",", " ", 
      RowBox[{"\"\<Target\>\"", " ", "->", " ", 
       RowBox[{"QiskitTarget", "[", 
        RowBox[{"KeyDrop", "[", 
         RowBox[{
          RowBox[{"tgt", "[", "\"\<Spec\>\"", "]"}], ",", 
          " ", "\"\<instruction_properties\>\""}], "]"}], "]"}]}], ",", " ", 
      RowBox[{"\"\<OptimizationLevel\>\"", " ", "->", " ", "3"}], ",", " ", 
      RowBox[{"\"\<SeedTranspiler\>\"", " ", "->", " ", "0"}]}], "]"}], ",", 
    "\n", "   ", 
    RowBox[{
     RowBox[{"\"\<cz $\>\"", " ", "~~", " ", 
      RowBox[{"a", " ", ":", " ", 
       RowBox[{"DigitCharacter", " ", ".."}]}], " ", "~~", " ", "\"\<, $\>\"",
       " ", "~~", " ", 
      RowBox[{"b", " ", ":", " ", 
       RowBox[{"DigitCharacter", " ", ".."}]}]}], " ", ":>", " ", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"FromDigits", " ", "@", " ", "a"}], ",", " ", 
       RowBox[{"FromDigits", " ", "@", " ", "b"}]}], "}"}]}]}], 
   "]"}]}]], "Input",
 CellChangeTimes->{{3.990549554159916*^9, 3.9905495543449173`*^9}},
 CellLabel->"In[11]:=",ExpressionUUID->"5740f667-058a-4dfa-b187-7b87414b7545"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"0", ",", "1"}], "}"}]], "Output",
 CellChangeTimes->{3.990549558978539*^9},
 CellLabel->"Out[11]=",
 CellID->1493441184,ExpressionUUID->"af7488db-ea92-4ce8-ae4c-a43fa2689b69"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["Reading a backend's error model", "ExampleSubsection",ExpressionUUID->"fa384309-9532-4718-acb2-2264a9c844b8"],

Cell[TextData[{
 Cell[BoxData[
  RowBox[{"[", 
   RowBox[{
    RowBox[{"\"\<FromBackend\>\"", " ", "->", " ", 
     RowBox[{"*", "name", "*"}]}], ",", " ", 
    RowBox[{"\"\<Provider\>\"", " ", "->", " ", 
     RowBox[{"*", "p", "*"}]}]}], "]"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "bd46ed70-01da-410f-b700-0035b0fd7f9c"],
 " reads a live backend's own populated ",
 Cell[BoxData["Target"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "00ec4fc7-d98e-4c26-9c7e-218cfbef04ac"],
 " instead of building one by hand. ",
 Cell[BoxData["\"\<GenericV2\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "8e4387ce-d4b2-41be-8b66-4ab46cefa80b"],
 " is a local fake device (no credentials, no network) useful for testing the \
path; ",
 Cell[BoxData["\"\<IBMProvider\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "69c25827-8d2e-4f6b-aa9e-13a10704f159"],
 " and ",
 Cell[BoxData["\"\<AWSProvider\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "3cc86bea-8a0d-486b-a4e3-2d74599af77e"],
 " reach real hardware (see Applications). Here the fake device's target \
arrives already error-populated:"
}], "ExampleText",ExpressionUUID->"0929d28d-c8f5-40ae-85c2-91d803b4358b"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"gen", " ", "=", " ", 
   RowBox[{"QiskitTarget", "[", 
    RowBox[{
     RowBox[{"\"\<FromBackend\>\"", " ", "->", " ", "5"}], ",", " ", 
     RowBox[{"\"\<Provider\>\"", " ", "->", " ", "\"\<GenericV2\>\""}]}], 
    "]"}]}], ";"}], "\n", 
 RowBox[{"{", 
  RowBox[{
   RowBox[{"gen", "[", "\"\<NumQubits\>\"", "]"}], ",", " ", 
   RowBox[{"Length", " ", "@", " ", 
    RowBox[{"gen", "[", "\"\<InstructionProperties\>\"", "]"}]}]}], 
  "}"}]}], "Input",
 CellLabel->"In[1]:= ",ExpressionUUID->"697810f2-a2d6-43d8-b760-2c5f8c241466"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{
    RowBox[{"QiskitTarget", "[", 
     RowBox[{
      RowBox[{"\<\"FromBackend\"\>", "\[Rule]", "5"}], ",", 
      RowBox[{"\<\"Provider\"\>", "\[Rule]", "\<\"GenericV2\"\>"}]}], "]"}], 
    "[", "\<\"NumQubits\"\>", "]"}], ",", "1"}], "}"}]], "Output",
 CellLabel->"Out[1]= ",ExpressionUUID->"28ce44dd-d7fa-45fd-a07d-8b47c9fe6e0a"]
}, Open  ]],

Cell["Each row carries the backend's measured error and duration:", \
"ExampleText",ExpressionUUID->"e76a1c10-5583-4b79-a3a5-8f4e6a4ac929"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"SelectFirst", "[", 
  RowBox[{
   RowBox[{"gen", "[", "\"\<InstructionProperties\>\"", "]"}], ",", " ", 
   RowBox[{
    RowBox[{"MatchQ", "[", 
     RowBox[{"#", ",", " ", 
      RowBox[{"{", 
       RowBox[{"\"\<cx\>\"", ",", " ", "_", ",", " ", "_"}], "}"}]}], "]"}], 
    " ", "&"}]}], "]"}]], "Input",
 CellLabel->"In[2]:= ",ExpressionUUID->"95f40fd3-ca37-4883-b923-05f938224588"],

Cell[BoxData[
 RowBox[{"Missing", "[", "\<\"NotFound\"\>", "]"}]], "Output",
 CellLabel->"Out[2]= ",ExpressionUUID->"fcf160ce-e35c-4aee-94c7-2a008fb9f0b5"]
}, Open  ]]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[
 InterpretationBox[Cell[
  "Applications", "ExampleSection",ExpressionUUID->
   "d5715ee2-1cae-4f33-89b2-0e99ea9caa6e"],
  $Line = 0; Null]], "ExampleSection",
 CellID->258228157,ExpressionUUID->"1cd6234d-1e3c-431d-9989-71f3025eee95"],

Cell["\<\
Build a device target once and reuse it to transpile several circuits to \
native OpenQASM:\
\>", "ExampleText",ExpressionUUID->"77cceaab-cf58-46bc-add5-7830694033ba"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"With", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"tgt", " ", "=", " ", 
     RowBox[{"QiskitTarget", "[", 
      RowBox[{"<|", 
       RowBox[{
        RowBox[{"\"\<BasisGates\>\"", " ", "->", " ", 
         RowBox[{"{", 
          
          RowBox[{"\"\<x\>\"", ",", " ", "\"\<sx\>\"", ",", " ", "\"\<rz\>\"",
            ",", " ", "\"\<cz\>\""}], "}"}]}], ",", " ", 
        RowBox[{"\"\<NumQubits\>\"", " ", "->", " ", "4"}], ",", " ", 
        RowBox[{"\"\<CouplingMap\>\"", " ", "->", " ", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{"1", ",", " ", "0"}], "}"}], ",", " ", 
           RowBox[{"{", 
            RowBox[{"1", ",", " ", "3"}], "}"}], ",", " ", 
           RowBox[{"{", 
            RowBox[{"2", ",", " ", "0"}], "}"}], ",", " ", 
           RowBox[{"{", 
            RowBox[{"2", ",", " ", "3"}], "}"}]}], "}"}]}]}], "|>"}], "]"}]}],
     "}"}], ",", "\n", "  ", 
   RowBox[{
    RowBox[{
     RowBox[{"StringStartsQ", "[", 
      RowBox[{
       RowBox[{"QuantumQASM", "[", 
        RowBox[{"#", ",", " ", 
         RowBox[{"\"\<Target\>\"", " ", "->", " ", "tgt"}]}], "]"}], ",", 
       " ", "\"\<OPENQASM 3.0\>\""}], "]"}], " ", "&"}], " ", "/@", " ", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"QuantumCircuitOperator", "[", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"\"\<H\>\"", " ", "->", " ", "1"}], ",", " ", 
         RowBox[{"\"\<CNOT\>\"", " ", "->", " ", 
          RowBox[{"{", 
           RowBox[{"1", ",", " ", "2"}], "}"}]}], ",", " ", 
         RowBox[{"{", "1", "}"}], ",", " ", 
         RowBox[{"{", "2", "}"}]}], "}"}], "]"}], ",", " ", 
      RowBox[{"QuantumCircuitOperator", "[", 
       RowBox[{"\"\<GHZ\>\"", "[", "2", "]"}], "]"}]}], "}"}]}]}], "\n", 
  "]"}]], "Input",
 CellLabel->"In[1]:=",ExpressionUUID->"8f97b05b-2b69-4028-8d68-7f13ef312226"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"True", ",", "True"}], "}"}]], "Output",
 CellChangeTimes->{3.9905496271559067`*^9},
 CellLabel->"Out[1]=",
 CellID->33612203,ExpressionUUID->"9ea3efa4-d1b5-4891-91af-387b456284a4"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Error-aware routing on a real IBM device", "ExampleSubsection",ExpressionUUID->"b8f93747-f6c5-407a-a10c-f01ded945995"],

Cell[TextData[{
 "On real hardware every qubit and every two-qubit pair has a different error \
rate, so ",
 StyleBox["where", "TI"],
 " a circuit is placed sets its fidelity. ",
 Cell[BoxData[
  RowBox[{"[", "\"\<FromBackend\>\"", "]"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "d4eae5f6-c247-4613-9f96-c7afb05b518a"],
 " reads the device's own calibrated error model and lets ",
 Cell[BoxData["QuantumQASM"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "00b5ef56-31f3-49bc-8071-a8802d6cde04"],
 " choose that placement automatically. (Outputs below are recorded from a \
live IBM backend; ",
 Cell[BoxData["\"\<FromBackend\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "5fd13d1f-2036-45a0-989d-527017f3d42c"],
 " authenticates through the same stored IBM credentials as ",
 Cell[BoxData["IBMJobSubmit"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "07a0c083-0bbc-4b79-b40a-b44e1e8241df"],
 ".)"
}], "ExampleText",ExpressionUUID->"aa08390b-143b-4948-9f50-e5f480a0747e"],

Cell["\<\
Read the live backend's target, already populated, no assembly needed:\
\>", "ExampleText",ExpressionUUID->"bc6e0942-0dc4-4ca5-aa4f-939c1dd22479"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"tgt", " ", "=", " ", 
  RowBox[{"QiskitTarget", "[", 
   RowBox[{
    RowBox[{"\"\<FromBackend\>\"", " ", "->", " ", "Automatic"}], ",", " ", 
    RowBox[{"\"\<Provider\>\"", " ", "->", " ", "\"\<IBMProvider\>\""}]}], 
   "]"}]}]], "Input",
 CellChangeTimes->{{3.990549647841566*^9, 3.9905496498548937`*^9}},
 CellLabel->"In[1]:=",ExpressionUUID->"8a2d936d-9372-43ef-a16f-78cba8429f98"],

