 "A ",
 Cell[BoxData[
 "QiskitTarget"], "InlineFormula",ExpressionUUID->
  "7fd54597-b409-4b6e-b467-e8dce0909b45"],
 " is the device argument of ",
 Cell[BoxData[
  ButtonBox["QuantumQASM",
   BaseStyle->"Link",
   ButtonData->"paclet:Wolfram/QuantumFramework/ref/QuantumQASM"]], 
  "InlineFormula",ExpressionUUID->"c63c07c3-2904-44f5-bcae-c99e382579c8"],
 "; the circuit is transpiled to the target's basis and connectivity:"
}], "ExampleText",ExpressionUUID->"1438481d-7573-472c-9dda-c28a0c968709"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"QuantumQASM", "[", 
  RowBox[{
   RowBox[{"QuantumCircuitOperator", "[", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"\"\<H\>\"", " ", "->", " ", "1"}], ",", " ", 
      RowBox[{"\"\<CNOT\>\"", " ", "->", " ", 
       RowBox[{"{", 
        RowBox[{"1", ",", " ", "2"}], "}"}]}], ",", " ", 
      RowBox[{"{", "1", "}"}], ",", " ", 
      RowBox[{"{", "2", "}"}]}], "}"}], "]"}], ",", " ", 
   RowBox[{"\"\<Target\>\"", " ", "->", " ", 
    RowBox[{"QiskitTarget", "[", 
     RowBox[{"<|", 
      RowBox[{
       RowBox[{"\"\<BasisGates\>\"", " ", "->", " ", 
        RowBox[{"{", 
         RowBox[{"\"\<x\>\"", ",", " ", "\"\<sx\>\"", ",", " ", "\"\<rz\>\"", 
          ",", " ", "\"\<cz\>\""}], "}"}]}], ",", " ", 
       RowBox[{"\"\<NumQubits\>\"", " ", "->", " ", "4"}], ",", " ", 
       RowBox[{"\"\<CouplingMap\>\"", " ", "->", " ", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{"1", ",", " ", "0"}], "}"}], ",", " ", 
          RowBox[{"{", 
           RowBox[{"1", ",", " ", "3"}], "}"}], ",", " ", 
          RowBox[{"{", 
           RowBox[{"2", ",", " ", "0"}], "}"}], ",", " ", 
          RowBox[{"{", 
           RowBox[{"2", ",", " ", "3"}], "}"}]}], "}"}]}]}], "|>"}], 
     "]"}]}]}], "]"}]], "Input",
 CellLabel->"In[1]:=",ExpressionUUID->"7a791bb5-bcbc-4b8e-b6f9-c761f16e3ff4"],

Cell[BoxData["\<\"OPENQASM 3.0;\\ninclude \\\"stdgates.inc\\\";\\nbit[2] \
c;\\nrz(pi/2) $0;\\nsx $0;\\nrz(pi/2) $0;\\nrz(pi/2) $1;\\nsx $1;\\nrz(pi) \
$1;\\ncz $1, $0;\\nsx $1;\\nrz(pi/2) $1;\\nc[0] = measure $0;\\nc[1] = \
measure $1;\\n\"\>"], "Output",
 CellChangeTimes->{3.989680846080463*^9},
 CellLabel->"Out[1]=",
 CellID->1336221057,ExpressionUUID->"566ad6c9-2fc8-46ed-b0ed-5601ef7815f9"]
