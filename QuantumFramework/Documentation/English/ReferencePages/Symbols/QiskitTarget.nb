 CellID->732139958,ExpressionUUID->"5c1db605-86ec-4fc8-9aae-62b3a064bd29"]
}, Open  ]],

Cell[TextData[{
 "Scoring each chosen pair by its total expected error, that is its ",
 Cell[BoxData["cz"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "2c98efea-ba33-48ad-bf47-aef9e8d907fc"],
 " error plus the two readout errors, the error-aware placement is about four \
times cleaner, ",
 StyleBox["1.11%",
  FontWeight->"Bold"],
 " versus ",
 StyleBox["4.88%",
  FontWeight->"Bold"],
 ", decided automatically from the device's own published numbers with no \
hand-screening of qubits:"
}], "ExampleText",ExpressionUUID->"c166d737-3c42-4396-8996-ffe3ff9f5e51"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"budget", "[", 
    RowBox[{"t_", ",", " ", 
     RowBox[{"{", 
      RowBox[{"a_", ",", " ", "b_"}], "}"}]}], "]"}], " ", ":=", " ", 
   RowBox[{"With", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"ip", " ", "=", " ", 
       RowBox[{"t", "[", "\"\<InstructionProperties\>\"", "]"}]}], "}"}], ",",
      "\n", "   ", 
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{"SelectFirst", "[", 
         RowBox[{"ip", ",", " ", 
          RowBox[{
           RowBox[{"MatchQ", "[", 
            RowBox[{"#", ",", " ", 
             RowBox[{"{", 
              RowBox[{"\"\<cz\>\"", ",", " ", 
               RowBox[{
                RowBox[{"{", 
                 RowBox[{"a", ",", " ", "b"}], "}"}], " ", "|", " ", 
                RowBox[{"{", 
                 RowBox[{"b", ",", " ", "a"}], "}"}]}], ",", " ", "_"}], 
              "}"}]}], "]"}], " ", "&"}]}], "]"}], "[", 
        RowBox[{"[", "3", "]"}], "]"}], "[", "\"\<Error\>\"", "]"}], " ", "+",
       "\n", "    ", 
      RowBox[{
       RowBox[{
        RowBox[{"SelectFirst", "[", 
         RowBox[{"ip", ",", " ", 
          RowBox[{
           RowBox[{"MatchQ", "[", 
            RowBox[{"#", ",", " ", 
             RowBox[{"{", 
              RowBox[{"\"\<measure\>\"", ",", " ", 
               RowBox[{"{", "a", "}"}], ",", " ", "_"}], "}"}]}], "]"}], " ", 
           "&"}]}], "]"}], "[", 
        RowBox[{"[", "3", "]"}], "]"}], "[", "\"\<Error\>\"", "]"}], " ", "+",
       "\n", "    ", 
      RowBox[{
       RowBox[{
        RowBox[{"SelectFirst", "[", 
         RowBox[{"ip", ",", " ", 
          RowBox[{
           RowBox[{"MatchQ", "[", 
            RowBox[{"#", ",", " ", 
             RowBox[{"{", 
              RowBox[{"\"\<measure\>\"", ",", " ", 
               RowBox[{"{", "b", "}"}], ",", " ", "_"}], "}"}]}], "]"}], " ", 
           "&"}]}], "]"}], "[", 
        RowBox[{"[", "3", "]"}], "]"}], "[", "\"\<Error\>\"", "]"}]}]}], 
    "]"}]}], ";"}], "\n", 
 RowBox[{"{", 
  RowBox[{
   RowBox[{"budget", "[", 
    RowBox[{"tgt", ",", " ", 
     RowBox[{"{", 
      RowBox[{"25", ",", " ", "37"}], "}"}]}], "]"}], ",", " ", 
   RowBox[{"budget", "[", 
    RowBox[{"tgt", ",", " ", 
     RowBox[{"{", 
      RowBox[{"0", ",", " ", "1"}], "}"}]}], "]"}]}], "}"}]}], "Input",
 CellLabel->"In[8]:=",ExpressionUUID->"0ddc20ec-1a65-4388-98d5-09339bfb6f10"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"0.045426807664831176`", ",", "0.03952843438324616`"}], 
  "}"}]], "Output",
 CellChangeTimes->{3.9905497015077143`*^9},
 CellLabel->"Out[9]=",
 CellID->1839208278,ExpressionUUID->"a3a33ceb-2cf9-4f3d-9013-b37ed2ab9ea9"]
}, Open  ]],

Cell[TextData[{
 "The emitted QASM is ordinary native, physical-qubit OpenQASM 3, so the rest \
of the workflow is unchanged: the same error-aware circuit can be submitted \
through ",
 Cell[BoxData["IBMJobSubmit"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "202837e7-445a-4d35-b3a2-7607b674d7d6"],
 " (or, for the IQCC ",
 Cell[BoxData["arbel"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "2ad92a0a-1f43-4310-bb27-4ba968a450a5"],
 " QPU, through QUALink's gate-level pipeline). The one-line change, ",
 Cell[BoxData["\"\<FromBackend\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "b8c1ba20-c6b5-4637-ae9d-efd20d8a3934"],
 " instead of a hand-built target, places the circuit on the device's best \
qubits for free."
}], "ExampleText",ExpressionUUID->"5e2740d1-6474-4644-bfb7-86021452e062"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[
 InterpretationBox[Cell[
  "Properties & Relations", "ExampleSection",ExpressionUUID->
   "d18b1e1f-4c4c-49a5-bb54-1e5e145ddf4e"],
  $Line = 0; Null]], "ExampleSection",
 CellID->2123667759,ExpressionUUID->"0e0d5f37-f3c9-4474-a22b-9f10dcc8b438"],

Cell[TextData[{
 "Passing a ",
 Cell[BoxData["QiskitTarget"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "e6204a88-c366-4bf8-a43d-03b566fc7a33"],
 " is equivalent to passing its specification Association inline to ",
 Cell[BoxData["QuantumQASM"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "50d5026d-1cd0-4a5d-893f-c97bd7d125a9"],
 "'s ",
 Cell[BoxData["\"\<Target\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "3f879ecc-12f8-4158-8a92-01f2514e6ce8"],
 " option \[LongDash] the object simply validates and carries the spec:"
}], "ExampleText",ExpressionUUID->"3de68bde-1ae2-4ea4-b199-0b6f9dba8fb6"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"With", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{"circ", " ", "=", " ", 
      RowBox[{"QuantumCircuitOperator", "[", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"\"\<H\>\"", " ", "->", " ", "1"}], ",", " ", 
         RowBox[{"\"\<CNOT\>\"", " ", "->", " ", 
          RowBox[{"{", 
           RowBox[{"1", ",", " ", "2"}], "}"}]}], ",", " ", 
         RowBox[{"{", "1", "}"}], ",", " ", 
         RowBox[{"{", "2", "}"}]}], "}"}], "]"}]}], ",", " ", 
     RowBox[{"spec", " ", "=", " ", 
      RowBox[{"<|", 
       RowBox[{
        RowBox[{"\"\<BasisGates\>\"", " ", "->", " ", 
         RowBox[{"{", 
          
          RowBox[{"\"\<x\>\"", ",", " ", "\"\<sx\>\"", ",", " ", "\"\<rz\>\"",
            ",", " ", "\"\<cz\>\""}], "}"}]}], ",", " ", 
        RowBox[{"\"\<NumQubits\>\"", " ", "->", " ", "4"}], ",", " ", 
        RowBox[{"\"\<CouplingMap\>\"", " ", "->", " ", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{"1", ",", " ", "0"}], "}"}], ",", " ", 
           RowBox[{"{", 
            RowBox[{"1", ",", " ", "3"}], "}"}], ",", " ", 
           RowBox[{"{", 
            RowBox[{"2", ",", " ", "0"}], "}"}], ",", " ", 
           RowBox[{"{", 
            RowBox[{"2", ",", " ", "3"}], "}"}]}], "}"}]}]}], "|>"}]}]}], 
    "}"}], ",", "\n", "  ", 
   RowBox[{
    RowBox[{"QuantumQASM", "[", 
     RowBox[{"circ", ",", " ", 
      RowBox[{"\"\<Target\>\"", " ", "->", " ", 
       RowBox[{"QiskitTarget", "[", "spec", "]"}]}]}], "]"}], " ", "===", " ", 
    RowBox[{"QuantumQASM", "[", 
     RowBox[{"circ", ",", " ", 
      RowBox[{"\"\<Target\>\"", " ", "->", " ", "spec"}]}], "]"}]}]}], "\n", 
  "]"}]], "Input",
 CellLabel->"In[1]:=",ExpressionUUID->"9feee9a1-a98e-4adf-bfb8-c615fd89ec56"],

Cell[BoxData["True"], "Output",
 CellChangeTimes->{3.990549706265176*^9},
 CellLabel->"Out[1]=",
 CellID->1035006033,ExpressionUUID->"e6bb3c08-10b7-4011-9b34-7e9497027694"]
}, Open  ]]
}, Open  ]],

