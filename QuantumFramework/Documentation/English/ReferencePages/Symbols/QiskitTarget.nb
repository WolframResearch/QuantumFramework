Cell[CellGroupData[{

Cell["\t", "ExampleDelimiter",ExpressionUUID->"a5493c7a-06e9-41a3-b3f6-307d925440d5"],

Cell["\<\
The normalized device specification, with keys in qiskit's snake_case form:\
\>", "ExampleText",ExpressionUUID->"a6fbdc7a-3b37-421d-9ef2-803a8d01c759"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"QiskitTarget", "[", 
   RowBox[{"<|", 
    RowBox[{
     RowBox[{"\"\<BasisGates\>\"", " ", "->", " ", 
      RowBox[{"{", 
       RowBox[{"\"\<x\>\"", ",", " ", "\"\<sx\>\"", ",", " ", "\"\<rz\>\"", ",",
         " ", "\"\<cz\>\""}], "}"}]}], ",", " ", 
     RowBox[{"\"\<NumQubits\>\"", " ", "->", " ", "4"}], ",", " ", 
     RowBox[{"\"\<CouplingMap\>\"", " ", "->", " ", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"1", ",", " ", "0"}], "}"}], ",", " ", 
        RowBox[{"{", 
         RowBox[{"1", ",", " ", "3"}], "}"}], ",", " ", 
        RowBox[{"{", 
         RowBox[{"2", ",", " ", "0"}], "}"}], ",", " ", 
        RowBox[{"{", 
         RowBox[{"2", ",", " ", "3"}], "}"}]}], "}"}]}]}], "|>"}], "]"}], 
  "[", "\"\<Spec\>\"", "]"}]], "Input",
 CellLabel->"In[1]:=",ExpressionUUID->"d5476b57-bba4-4270-90ec-e3b3459fb8ef"],

Cell[BoxData[
 RowBox[{"\[LeftAssociation]", 
  RowBox[{
   RowBox[{"\<\"basis_gates\"\>", "\[Rule]", 
    RowBox[{"{", 
     RowBox[{"\<\"x\"\>", ",", "\<\"sx\"\>", ",", "\<\"rz\"\>", 
      ",", "\<\"cz\"\>"}], "}"}]}], ",", 
   RowBox[{"\<\"num_qubits\"\>", "\[Rule]", "4"}], ",", 
