Cell[TextData[{
 "The errors span a wide range across the chip, so qubit choice matters: ",
 Cell[BoxData["cz"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "54c6a715-fe28-4f6e-9380-038444c3d7f4"],
 " error runs from 0.12% to a stuck 100%, and readout from 0.2% to 32%:"
}], "ExampleText",ExpressionUUID->"0642f0b6-51e2-43b5-952c-28783eab8f26"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{"MinMax", " ", "@", " ", 
    RowBox[{"Cases", "[", 
     RowBox[{
      RowBox[{"tgt", "[", "\"\<InstructionProperties\>\"", "]"}], ",", " ", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"\"\<cz\>\"", ",", " ", 
         RowBox[{"{", 
          RowBox[{"_", ",", " ", "_"}], "}"}], ",", " ", "p_"}], "}"}], " ", ":>",
        " ", 
       RowBox[{"p", "[", "\"\<Error\>\"", "]"}]}]}], "]"}]}], ",", "\n", " ", 
   
   RowBox[{"MinMax", " ", "@", " ", 
    RowBox[{"Cases", "[", 
     RowBox[{
      RowBox[{"tgt", "[", "\"\<InstructionProperties\>\"", "]"}], ",", " ", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"\"\<measure\>\"", ",", " ", 
         RowBox[{"{", "_", "}"}], ",", " ", "p_"}], "}"}], " ", ":>", " ", 
       RowBox[{"p", "[", "\"\<Error\>\"", "]"}]}]}], "]"}]}]}], 
  "}"}]], "Input",
 CellLabel->"In[3]:=",ExpressionUUID->"39c09d26-0f7f-49be-9307-d1905e396d7b"],

Cell[BoxData[
 RowBox[{"{", 
