Cell["\<\
A device target from a native gate set, a qubit count, and a coupling map:\
\>", "ExampleText",ExpressionUUID->"b12bd446-5efb-4f00-a27c-8a2948143e7e"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"QiskitTarget", "[", 
  RowBox[{"<|", 
   RowBox[{
    RowBox[{"\"\<BasisGates\>\"", " ", "->", " ", 
     RowBox[{"{", 
      RowBox[{"\"\<x\>\"", ",", " ", "\"\<sx\>\"", ",", " ", "\"\<rz\>\"", ",",
        " ", "\"\<cz\>\""}], "}"}]}], ",", " ", 
    RowBox[{"\"\<NumQubits\>\"", " ", "->", " ", "4"}], ",", " ", 
    RowBox[{"\"\<CouplingMap\>\"", " ", "->", " ", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"1", ",", " ", "0"}], "}"}], ",", " ", 
       RowBox[{"{", 
        RowBox[{"1", ",", " ", "3"}], "}"}], ",", " ", 
       RowBox[{"{", 
        RowBox[{"2", ",", " ", "0"}], "}"}], ",", " ", 
       RowBox[{"{", 
        RowBox[{"2", ",", " ", "3"}], "}"}]}], "}"}]}]}], "|>"}], 
  "]"}]], "Input",
 CellLabel->"In[1]:=",ExpressionUUID->"9a745503-024b-4491-a70d-b6ac03a15113"],

