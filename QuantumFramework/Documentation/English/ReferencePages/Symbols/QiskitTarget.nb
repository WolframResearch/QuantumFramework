Cell["\<\
Transpile a Bell against the error-aware target and against a \
connectivity-only one (the same coupling map with the error rows dropped), \
and read off the physical pair each chose:\
\>", "ExampleText",ExpressionUUID->"003e97d0-bbbe-4dca-b671-e5aa34ac2ece"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"qc", "      ", "=", " ", 
   RowBox[{"QuantumCircuitOperator", "[", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"\"\<H\>\"", " ", "->", " ", "1"}], ",", " ", 
      RowBox[{"\"\<CNOT\>\"", " ", "->", " ", 
       RowBox[{"{", 
        RowBox[{"1", ",", " ", "2"}], "}"}]}], ",", " ", 
      RowBox[{"{", "1", "}"}], ",", " ", 
      RowBox[{"{", "2", "}"}]}], "}"}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"naive", "   ", "=", " ", 
   RowBox[{"QiskitTarget", "[", 
    RowBox[{"KeyDrop", "[", 
     RowBox[{
      RowBox[{"tgt", "[", "\"\<Spec\>\"", "]"}], ",", 
      " ", "\"\<instruction_properties\>\""}], "]"}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"pairOf", "[", "t_", "]"}], " ", ":=", " ", 
   RowBox[{"First", " ", "@", " ", 
    RowBox[{"StringCases", "[", 
     RowBox[{
      RowBox[{"QuantumQASM", "[", 
       RowBox[{"qc", ",", " ", 
        RowBox[{"\"\<Target\>\"", " ", "->", " ", "t"}], ",", " ", 
        RowBox[{"\"\<OptimizationLevel\>\"", " ", "->", " ", "3"}]}], "]"}], ",",
       "\n", "   ", 
      RowBox[{
       RowBox[{"\"\<cz $\>\"", " ", "~~", " ", 
        RowBox[{"a", " ", ":", " ", 
         RowBox[{"DigitCharacter", " ", ".."}]}], " ", "~~", 
        " ", "\"\<, $\>\"", " ", "~~", " ", 
        RowBox[{"b", " ", ":", " ", 
         RowBox[{"DigitCharacter", " ", ".."}]}]}], " ", ":>", " ", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"FromDigits", " ", "@", " ", "a"}], ",", " ", 
         RowBox[{"FromDigits", " ", "@", " ", "b"}]}], "}"}]}]}], "]"}]}]}], 
  ";"}], "\n", 
 RowBox[{"{", 
  RowBox[{
   RowBox[{"pairOf", "[", "tgt", "]"}], ",", " ", 
   RowBox[{"pairOf", "[", "naive", "]"}]}], "}"}]}], "Input",
 CellLabel->"In[4]:=",ExpressionUUID->"5d658c89-d8e7-4b9d-8ff6-aae68371d693"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{"{", 
