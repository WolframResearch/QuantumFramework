    "the number of qubits", "TableText",ExpressionUUID->
     "0569fdf2-2a8f-4e1c-84fd-339d8fd39ebe"]},
   {Cell["      ", "ModInfo",ExpressionUUID->
     "8ef9e09e-a244-4824-b478-714507de97bc"], Cell[TextData[Cell[
    BoxData["\"\<OperationNames\>\""], "InlineFormula",ExpressionUUID->
     "7a917613-5671-4194-86ef-3fe4a54f8bea"]], "TableText",ExpressionUUID->
     "f8b61a40-9059-46f5-8664-b38b6c484b43"], Cell[TextData[{
     "the sorted native operation names, including ",
     Cell[BoxData[
     "measure"], "InlineFormula",ExpressionUUID->
      "e30dbfed-0bb7-4b9a-8fc7-3d04eccbfca1"],
     " and ",
     Cell[BoxData[
     "reset"], "InlineFormula",ExpressionUUID->
      "46465c41-b334-474b-a9cd-77fed2367980"]
    }], "TableText",ExpressionUUID->"31839c95-14b4-491e-8b83-96b6601d6977"]},
   {Cell["      ", "ModInfo",ExpressionUUID->
     "2e9f76d2-637f-4f0e-852e-9d4dde963475"], Cell[TextData[Cell[
    BoxData["\"\<CouplingMap\>\""], "InlineFormula",ExpressionUUID->
     "82f17426-838b-4419-ba8f-820d1c661391"]], "TableText",ExpressionUUID->
     "2d1eadc1-d47a-49a3-89df-cd9cfb7f6256"], Cell[
    "the directed coupling pairs", "TableText",ExpressionUUID->
     "3934c84d-4f43-46bd-8ab4-12196efdcac0"]},
   {Cell["      ", "ModInfo",ExpressionUUID->
     "78af8ff2-bbdb-4bc8-a4b6-a6a2f8fbc6d9"], Cell[TextData[Cell[
    BoxData["\"\<Spec\>\""], "InlineFormula",ExpressionUUID->
     "59ffe8a7-7629-45b7-bc0f-852c94b1788a"]], "TableText",ExpressionUUID->
     "e9e21393-b236-41e5-bc60-616c60c65b80"], Cell[
    "the normalized specification Association", "TableText",ExpressionUUID->
     "8951fe9f-99e8-4570-bc29-f7d3f6d5a66c"]}
  }]], "2ColumnTableMod",ExpressionUUID->"d2fa5bd5-f75a-4d76-aed0-\
2ae12fe0eefb"]
}, Open  ]],

