Notebook[{

Cell[CellGroupData[{
Cell["QiskitTarget", "ObjectName",
 CellID->1224892054,ExpressionUUID->"8393d601-4014-44ba-afc9-60862df940ec"],

Cell[TextData[{
 Cell["   ", "ModInfo",ExpressionUUID->"39eea1cb-9eee-4e3a-b3b3-531b46568249"],
 Cell[BoxData[
  RowBox[{
   ButtonBox["QiskitTarget",
    BaseStyle->"Link",
    ButtonData->"paclet:Wolfram/QuantumFramework/ref/QiskitTarget"], "[", 
   StyleBox["spec", "TI"], "]"}]], "InlineFormula",ExpressionUUID->
  "8cfe641b-955d-45a4-bbcf-5896614944c8"],
 " ",
 "builds a qiskit transpiler target from the device specification ",
 StyleBox["spec", "TI"],
 ", an Association of qiskit ",
 Cell[BoxData[
  RowBox[{"Target", ".", "from_configuration"}]], "InlineFormula",
  ExpressionUUID->"4db7cb9e-78d1-4881-96b0-1de101507fd4"],
 " parameters.",
 "\n",
 Cell["   ", "ModInfo",ExpressionUUID->"230a4bd4-9a1d-403b-8acd-cf8c3cfe41a8"],
 Cell[BoxData[
  RowBox[{
   StyleBox["tgt", "TI"], "[", "\"\<\!\(\*StyleBox[\"prop\", \"TI\"]\)\>\"", 
   "]"}]], "InlineFormula",ExpressionUUID->
  "10460d81-44ec-459e-aa05-1e530452f6a8"],
 " ",
 "gives the property ",
 StyleBox["prop", "TI"],
 " of a ",
 Cell[BoxData[
 "QiskitTarget"], "InlineFormula",ExpressionUUID->
  "6ba50dc0-a15b-4a41-9832-a8fde309c970"],
 " object ",
 StyleBox["tgt", "TI"],
 ", one of ",
 Cell[BoxData["\"\<NumQubits\>\""], "InlineFormula",ExpressionUUID->
  "17dd8846-7fad-4e6d-b98c-d4753e82fa88"],
 ", ",
 Cell[BoxData["\"\<OperationNames\>\""], "InlineFormula",ExpressionUUID->
  "2918ff9f-2c3b-46b3-affe-f587700dafbc"],
 ", ",
 Cell[BoxData["\"\<CouplingMap\>\""], "InlineFormula",ExpressionUUID->
  "32f5a8b3-79de-4215-b0f1-a0b479acfa6a"],
 " or ",
 Cell[BoxData["\"\<Spec\>\""], "InlineFormula",ExpressionUUID->
  "621dff75-7b92-4671-bf59-98f7ceb863b7"],
 "."
}], "Usage",ExpressionUUID->"dba66bc7-8a1d-4e89-a8d8-12095377ce6d"],

Cell[TextData[{
 "A ",
 Cell[BoxData[
 "QiskitTarget"], "InlineFormula",ExpressionUUID->
  "db7f818d-d110-4ddd-9f0e-2530c8f36772"],
 " describes a device for transpilation: its native gate set, qubit \
connectivity, and (optionally) per-instruction errors and durations. It is \
the device argument of ",
 Cell[BoxData[
  ButtonBox["QuantumQASM",
   BaseStyle->"Link",
   ButtonData->"paclet:Wolfram/QuantumFramework/ref/QuantumQASM"]], 
  "InlineFormula",ExpressionUUID->"55658f28-8857-454e-b95d-2d58b0d832e7"],
 "'s ",
 Cell[BoxData["\"\<Target\>\""], "InlineFormula",ExpressionUUID->
  "c4d9d433-5387-4c33-9fbb-fdedffa70cbc"],
 " option."
}], "Notes",ExpressionUUID->"a8d9c372-1b45-49cb-95c8-ff75d4d3cf88"],

Cell[TextData[{
 StyleBox["spec", "TI"],
 " is an Association whose keys are qiskit ",
 Cell[BoxData[
  RowBox[{"Target", ".", "from_configuration"}]], "InlineFormula",
  ExpressionUUID->"a7e8250b-41f8-4ac9-b31c-9842444c3d52"],
 " parameters: ",
 Cell[BoxData["\"\<BasisGates\>\""], "InlineFormula",ExpressionUUID->
  "265440c0-0eda-44c4-995e-cb9f74677c70"],
 ", ",
 Cell[BoxData["\"\<NumQubits\>\""], "InlineFormula",ExpressionUUID->
  "a8b59daf-6ac6-40f9-8881-109e0fc31255"],
 ", ",
 Cell[BoxData["\"\<CouplingMap\>\""], "InlineFormula",ExpressionUUID->
  "2f228da9-a4c2-41a2-a271-500288210501"],
 ", ",
 Cell[BoxData["\"\<InstructionDurations\>\""], "InlineFormula",ExpressionUUID->
  "35ae8375-0d3a-46e6-9bb4-31b93e33e628"],
 ", ",
 Cell[BoxData["\"\<ConcurrentMeasurements\>\""], "InlineFormula",
  ExpressionUUID->"0dfd0ab3-da66-4703-9ce7-9fb27bdbdc12"],
 ", ",
 Cell[BoxData["\"\<Dt\>\""], "InlineFormula",ExpressionUUID->
  "6079d86d-9075-4a42-9a2f-f18acf1ba742"],
 ", ",
 Cell[BoxData["\"\<TimingConstraints\>\""], "InlineFormula",ExpressionUUID->
  "e2bf73d8-dbe0-494e-87ce-eff6fd078393"],
 ", ",
 Cell[BoxData["\"\<CustomNameMapping\>\""], "InlineFormula",ExpressionUUID->
  "b1bcea0d-af97-4a56-a282-f9ad3070e645"],
 ". Keys are CamelCase and map to qiskit's snake_case names; the raw \
snake_case name is accepted too. The accepted key set is read from the \
installed qiskit, so it tracks the ",
 ButtonBox["qiskit Target.from_configuration documentation",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://docs.quantum.ibm.com/api/qiskit/qiskit.transpiler.Target#\
from_configuration"], None}],
 " of whichever version is installed."
}], "Notes",ExpressionUUID->"9cbe0d58-3075-4573-b68a-47b56157df01"],

Cell[TextData[{
 "Each value takes qiskit's own form: ",
 Cell[BoxData["\"\<NumQubits\>\""], "InlineFormula",ExpressionUUID->
  "d2f24a00-5eb3-417b-ae77-455723a7bd62"],
 " an integer; ",
 Cell[BoxData["\"\<CouplingMap\>\""], "InlineFormula",ExpressionUUID->
  "d7178d01-b51e-457b-a87f-7a79a68e88ed"],
 " a list of directed integer pairs ",
 Cell[BoxData[
  RowBox[{"{", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"c", ",", " ", "t"}], "}"}], ",", " ", "\[Ellipsis]"}], "}"}]], 
  "InlineFormula",ExpressionUUID->"f8fe4866-e23d-47ab-9415-b3540da5023e"],
 "; ",
 Cell[BoxData["\"\<Dt\>\""], "InlineFormula",ExpressionUUID->
  "7f44cce2-c9a8-4a2a-ae16-2db9cf96f215"],
 " a number of seconds; ",
 Cell[BoxData["\"\<InstructionDurations\>\""], "InlineFormula",ExpressionUUID->
  "d6963241-dc2e-43bb-b7a1-f9ca61b5104a"],
 ", ",
 Cell[BoxData["\"\<ConcurrentMeasurements\>\""], "InlineFormula",
  ExpressionUUID->"5e8ab157-8ce1-40a0-b6ff-fccad71cd27f"],
 ", ",
 Cell[BoxData["\"\<TimingConstraints\>\""], "InlineFormula",ExpressionUUID->
  "60503f5c-1697-4824-aa79-6bd23b3f3b2f"],
 " and ",
 Cell[BoxData["\"\<CustomNameMapping\>\""], "InlineFormula",ExpressionUUID->
  "73be44c9-e091-4a24-8907-2b6c1f667bab"],
 " the structures qiskit's ",
 Cell[BoxData[
  RowBox[{"Target", ".", "from_configuration"}]], "InlineFormula",
  ExpressionUUID->"71098fcf-8fa5-4e25-842b-bdbe86d05b05"],
 " expects."
}], "Notes",ExpressionUUID->"03e346fc-b345-4546-8f87-4ef1d7da162b"],

Cell[TextData[{
 Cell[BoxData["\"\<BasisGates\>\""], "InlineFormula",ExpressionUUID->
  "cea9f116-7652-4d75-a46d-aeb274519b77"],
 " is a list of qiskit ",
 StyleBox["standard gate names", "TI"],
 " \[LongDash] the names are defined by the installed qiskit, not by ",
 Cell[BoxData[
 "QiskitTarget"], "InlineFormula",ExpressionUUID->
  "0c47643c-7f21-4094-bd30-643d4f3cda16"],
 ", and vary by version. In the bundled qiskit 2.4.1 there are 54, including \
the single-qubit ",
 Cell[BoxData["\"\<x\>\""], "InlineFormula",ExpressionUUID->
  "822e159f-e942-4c3a-b327-bb7d5aa0f21e"],
 ", ",
 Cell[BoxData["\"\<y\>\""], "InlineFormula",ExpressionUUID->
  "0450a98e-7dec-4a8e-9059-2aac9715f9ad"],
 ", ",
 Cell[BoxData["\"\<z\>\""], "InlineFormula",ExpressionUUID->
  "2d468587-f389-4426-b7df-aa5ed21125f5"],
 ", ",
 Cell[BoxData["\"\<h\>\""], "InlineFormula",ExpressionUUID->
  "9ca95430-85c7-4a5f-9d19-587cec4856a8"],
 ", ",
 Cell[BoxData["\"\<s\>\""], "InlineFormula",ExpressionUUID->
  "62ae4d51-8804-48a5-8cd4-3d61d9f82ed8"],
 ", ",
 Cell[BoxData["\"\<sx\>\""], "InlineFormula",ExpressionUUID->
  "14ae9aab-8965-4f61-ab67-7e87ca71058b"],
 ", ",
 Cell[BoxData["\"\<t\>\""], "InlineFormula",ExpressionUUID->
  "d7143e60-0f99-4ac1-b506-d21effdbd27a"],
 ", ",
 Cell[BoxData["\"\<rx\>\""], "InlineFormula",ExpressionUUID->
  "a5a64d2f-283f-4ec7-a0f1-b25bfa8f33c8"],
 ", ",
 Cell[BoxData["\"\<ry\>\""], "InlineFormula",ExpressionUUID->
  "c4a5c46f-f14f-4cec-8f00-92fcce4f1390"],
 ", ",
 Cell[BoxData["\"\<rz\>\""], "InlineFormula",ExpressionUUID->
  "6be1ab63-137a-4cae-b4f5-a98ade642309"],
 ", ",
 Cell[BoxData["\"\<p\>\""], "InlineFormula",ExpressionUUID->
  "ef7dea4c-faff-460a-b32b-b32f99be3dad"],
 ", ",
 Cell[BoxData["\"\<u\>\""], "InlineFormula",ExpressionUUID->
  "e70a2f2b-c4d4-4700-bec8-5e73d331849b"],
 ", ",
 Cell[BoxData["\"\<u3\>\""], "InlineFormula",ExpressionUUID->
  "646db6ba-873a-4989-94b5-46615519f0d8"],
 ", the two-qubit ",
 Cell[BoxData["\"\<cx\>\""], "InlineFormula",ExpressionUUID->
  "f0f05f21-d174-4a19-827f-24c99d0b38cd"],
 ", ",
 Cell[BoxData["\"\<cz\>\""], "InlineFormula",ExpressionUUID->
  "cb461549-b380-4352-a873-02dda6ce5c49"],
 ", ",
 Cell[BoxData["\"\<cy\>\""], "InlineFormula",ExpressionUUID->
  "355c7ae6-3316-460f-ba47-b849f9512cee"],
 ", ",
 Cell[BoxData["\"\<ch\>\""], "InlineFormula",ExpressionUUID->
  "d66f17b4-b391-427d-8abe-f1087187271e"],
 ", ",
 Cell[BoxData["\"\<swap\>\""], "InlineFormula",ExpressionUUID->
  "8c5b6a26-29ef-4bef-9bff-1172e4aba642"],
 ", ",
 Cell[BoxData["\"\<iswap\>\""], "InlineFormula",ExpressionUUID->
  "ed8458bf-1795-4d58-ab3d-17d53caaab05"],
 ", ",
 Cell[BoxData["\"\<ecr\>\""], "InlineFormula",ExpressionUUID->
  "96d91042-1b28-41f0-bad0-28ef19ce7edc"],
 ", ",
 Cell[BoxData["\"\<rzz\>\""], "InlineFormula",ExpressionUUID->
  "651630a4-0098-41eb-a899-8b4d79336cf6"],
 ", ",
 Cell[BoxData["\"\<rxx\>\""], "InlineFormula",ExpressionUUID->
  "514e6df8-cbc1-49ae-8838-c5e83fcdb97c"],
 ", and the three-qubit ",
 Cell[BoxData["\"\<ccx\>\""], "InlineFormula",ExpressionUUID->
  "c43607f6-2a70-4793-bb84-4950bed1c8e9"],
 ", ",
 Cell[BoxData["\"\<ccz\>\""], "InlineFormula",ExpressionUUID->
  "02f96d88-c2df-4a18-aead-152186fdf1ed"],
 ", ",
 Cell[BoxData["\"\<cswap\>\""], "InlineFormula",ExpressionUUID->
  "75456080-e463-4d69-a86f-c3c4998ddbdc"],
 ". The names listed here are those of qiskit 2.4.1; a different qiskit \
version may add, rename, or remove gate names, so the list could differ from \
what is shown. The complete, version-correct list is qiskit's standard \
gate-name mapping, obtainable with ",
 Cell[BoxData[
  RowBox[{
   RowBox[{"qiskit", ".", "circuit", ".", "library", ".", "get_standard"}], 
   "_gate", "_name", "_mapping"}]], "InlineFormula",ExpressionUUID->
  "7b4fbdd0-204f-45f7-828e-e94017b0c67f"],
 " or from qiskit's ",
 ButtonBox["circuit-library documentation",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://docs.quantum.ibm.com/api/qiskit/circuit_library"], None}],
 ". A name outside that set must be supplied through ",
 Cell[BoxData["\"\<CustomNameMapping\>\""], "InlineFormula",ExpressionUUID->
  "0ebb2e2c-e75b-494d-99cd-ef61effe854a"],
 "."
}], "Notes",ExpressionUUID->"30b2d10d-7336-4a7c-bf5f-385119a0404d"],

Cell[TextData[{
 "The keys are validated against the installed qiskit at call time, so an \
unknown key gives a ",
 Cell[BoxData[
  ButtonBox["Failure",
   BaseStyle->"Link",
   ButtonData->"paclet:ref/Failure"]], "InlineFormula",ExpressionUUID->
  "f8ba268a-74f8-486d-8118-f94f7323fd76"],
 " (see Possible Issues) and any current or future qiskit ",
 Cell[BoxData[
 "Target"], "InlineFormula",ExpressionUUID->
  "c55032a5-0309-4898-99e1-261e18688283"],
 " parameter is accepted without a change to ",
 Cell[BoxData[
 "QiskitTarget"], "InlineFormula",ExpressionUUID->
  "1741b8b4-0130-46e3-abe0-81f1d680af02"],
 "."
}], "Notes",ExpressionUUID->"3abf451b-01d2-4eff-b594-b71a9cdb044d"],

Cell[TextData[{
 Cell[BoxData[
 "QiskitTarget"], "InlineFormula",ExpressionUUID->
  "ce77ee07-52e4-4a42-aee2-393f711a736a"],
 " stores the validated specification rather than a serialized qiskit ",
 Cell[BoxData[
 "Target"], "InlineFormula",ExpressionUUID->
  "fec286d1-dc74-4a8b-9bb9-4f0b5e807ee7"],
 "; the live target is rebuilt from the spec when it is used (inside ",
 Cell[BoxData[
  ButtonBox["QuantumQASM",
   BaseStyle->"Link",
   ButtonData->"paclet:Wolfram/QuantumFramework/ref/QuantumQASM"]], 
  "InlineFormula",ExpressionUUID->"0214f970-169d-4327-9e85-381a1e52acab"],
 "), so the same object works across qiskit sessions and versions."
}], "Notes",ExpressionUUID->"007b2904-8d2b-4684-a0a9-a35abb3f3178"],

Cell[TextData[{
 Cell[BoxData[
 "measure"], "InlineFormula",ExpressionUUID->
  "a82f8b8e-7996-463d-baa4-c49b6eaa004f"],
 " and ",
 Cell[BoxData[
 "reset"], "InlineFormula",ExpressionUUID->
  "64ad12a8-5b2d-42e9-a599-daa9e59ee167"],
 " are added on every qubit automatically \[LongDash] they are universal but ",
 Cell[BoxData[
  RowBox[{"Target", ".", "from_configuration"}]], "InlineFormula",
  ExpressionUUID->"899e9e86-b1d3-4751-9321-3dbcf65a3ec2"],
 " omits them for a bare unitary basis \[LongDash] so a target built from ",
 Cell[BoxData[
  RowBox[{"{", 
   RowBox[{"\"\<x\>\"", ",", " ", "\"\<sx\>\"", ",", " ", "\"\<rz\>\"", ",", 
    " ", "\"\<cz\>\""}], "}"}]], "InlineFormula",ExpressionUUID->
  "aa428ede-12ea-40c7-9da1-d1e9318fbf27"],
 " still transpiles circuits that contain measurements."
}], "Notes",ExpressionUUID->"b6c0968e-0dca-4e77-9055-08dd1ea86cbb"],

Cell[TextData[{
 "A ",
 Cell[BoxData[
 "QiskitTarget"], "InlineFormula",ExpressionUUID->
  "db240f74-647d-47c7-b6b3-20c5f522e7d4"],
 " displays as a summary panel showing its qubit count, native gate names, \
and number of coupling edges."
}], "Notes",ExpressionUUID->"402aae51-e146-4f5e-8175-5fd2f7c513a7"],

Cell[BoxData[GridBox[{
   {Cell["      ", "ModInfo",ExpressionUUID->
     "5c230643-87d0-428a-a1d8-d2ae91dbd5ae"], Cell["Property", "TableText",
