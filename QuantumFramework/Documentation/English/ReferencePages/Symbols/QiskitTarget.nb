Cell[CellGroupData[{

Cell["Case-insensitive specification keys", "ExampleSubsection",ExpressionUUID->"20f33184-818b-4763-9b7a-077c54cde682"],

Cell["\<\
CamelCase and qiskit's snake_case spellings of the spec keys are \
interchangeable:\
\>", "ExampleText",ExpressionUUID->"a328e740-1cc2-47b2-8ef2-4ffd30ba0b32"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"With", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{"cm", " ", "=", " ", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"1", ",", " ", "0"}], "}"}], ",", " ", 
        RowBox[{"{", 
         RowBox[{"1", ",", " ", "3"}], "}"}], ",", " ", 
        RowBox[{"{", 
         RowBox[{"2", ",", " ", "0"}], "}"}], ",", " ", 
        RowBox[{"{", 
         RowBox[{"2", ",", " ", "3"}], "}"}]}], "}"}]}], ",", " ", 
     RowBox[{"b", " ", "=", " ", 
      RowBox[{"{", 
       RowBox[{"\"\<x\>\"", ",", " ", "\"\<sx\>\"", ",", " ", "\"\<rz\>\"", ",",
         " ", "\"\<cz\>\""}], "}"}]}]}], "}"}], ",", "\n", "  ", 
   RowBox[{
    RowBox[{
     RowBox[{"QiskitTarget", "[", 
      RowBox[{"<|", 
       RowBox[{
        RowBox[{"\"\<BasisGates\>\"", " ", "->", " ", "b"}], ",", " ", 
        RowBox[{"\"\<NumQubits\>\"", " ", "->", " ", "4"}], ",", " ", 
        RowBox[{"\"\<CouplingMap\>\"", " ", "->", " ", "cm"}]}], "|>"}], 
      "]"}], "[", "\"\<Spec\>\"", "]"}], " ", "===", "\n", "    ", 
    RowBox[{
     RowBox[{"QiskitTarget", "[", 
      RowBox[{"<|", 
       RowBox[{
        RowBox[{"\"\<basis_gates\>\"", " ", "->", " ", "b"}], ",", " ", 
        RowBox[{"\"\<num_qubits\>\"", " ", "->", " ", "4"}], ",", " ", 
        RowBox[{"\"\<coupling_map\>\"", " ", "->", " ", "cm"}]}], "|>"}], 
      "]"}], "[", "\"\<Spec\>\"", "]"}]}]}], "\n", "]"}]], "Input",
 CellLabel->"In[1]:=",ExpressionUUID->"571a934e-97af-4c50-b00a-b7f2b88b12a0"],

Cell[BoxData["True"], "Output",
 CellChangeTimes->{3.990549301349566*^9},
 CellLabel->"Out[1]=",
 CellID->209009327,ExpressionUUID->"1715f49d-8c03-41c8-9f43-8d2f51f12379"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["Use with QuantumQASM", "ExampleSubsection",ExpressionUUID->"804a607e-cbca-4ada-8cad-357f6d37914a"],

Cell[TextData[{
 "A ",
 Cell[BoxData["QiskitTarget"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "be7a3cec-3ac9-48e5-9fcf-a40efaf6d3c5"],
 " is the device argument of ",
 Cell[BoxData["QuantumQASM"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "63979aa3-2b38-416e-9722-bc6a3fa4dd32"],
 "; the circuit is transpiled to the target's basis and connectivity:"
}], "ExampleText",ExpressionUUID->"c5566243-c0a4-4137-8cd7-b2c111ec695f"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"QuantumQASM", "[", 
  RowBox[{
   RowBox[{"QuantumCircuitOperator", "[", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"\"\<H\>\"", " ", "->", " ", "1"}], ",", " ", 
      RowBox[{"\"\<CNOT\>\"", " ", "->", " ", 
       RowBox[{"{", 
        RowBox[{"1", ",", " ", "2"}], "}"}]}], ",", " ", 
      RowBox[{"{", "1", "}"}], ",", " ", 
      RowBox[{"{", "2", "}"}]}], "}"}], "]"}], ",", " ", 
   RowBox[{"\"\<Target\>\"", " ", "->", " ", 
    RowBox[{"QiskitTarget", "[", 
     RowBox[{"<|", 
      RowBox[{
       RowBox[{"\"\<BasisGates\>\"", " ", "->", " ", 
        RowBox[{"{", 
         RowBox[{"\"\<x\>\"", ",", " ", "\"\<sx\>\"", ",", " ", "\"\<rz\>\"", 
          ",", " ", "\"\<cz\>\""}], "}"}]}], ",", " ", 
       RowBox[{"\"\<NumQubits\>\"", " ", "->", " ", "4"}], ",", " ", 
       RowBox[{"\"\<CouplingMap\>\"", " ", "->", " ", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{"1", ",", " ", "0"}], "}"}], ",", " ", 
          RowBox[{"{", 
           RowBox[{"1", ",", " ", "3"}], "}"}], ",", " ", 
          RowBox[{"{", 
           RowBox[{"2", ",", " ", "0"}], "}"}], ",", " ", 
          RowBox[{"{", 
           RowBox[{"2", ",", " ", "3"}], "}"}]}], "}"}]}]}], "|>"}], 
     "]"}]}]}], "]"}]], "Input",
 CellLabel->"In[1]:=",ExpressionUUID->"10a7edb2-c8c2-42b4-bcba-ded7cc816c23"],

Cell[BoxData["\<\"OPENQASM 3.0;\\ninclude \\\"stdgates.inc\\\";\\nbit[2] \
c;\\nrz(pi/2) $0;\\nsx $0;\\nrz(pi/2) $0;\\nrz(pi/2) $1;\\nsx $1;\\nrz(pi) \
$1;\\ncz $1, $0;\\nsx $1;\\nrz(pi/2) $1;\\nc[0] = measure $0;\\nc[1] = \
measure $1;\\n\"\>"], "Output",
 CellChangeTimes->{3.9905493072436647`*^9},
 CellLabel->"Out[1]=",
 CellID->862818881,ExpressionUUID->"59ed4c0b-e68c-4887-9a5d-dd11679ad968"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["Error-aware targets", "ExampleSubsection",ExpressionUUID->"6b62ca2a-f94b-4a97-a2bd-2a91e269c9bb"],

Cell[TextData[{
 "The reserved ",
 Cell[BoxData["\"\<InstructionProperties\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "60264366-5bfb-4b9e-8b44-f3198cab28d2"],
 " key attaches a per-instruction error to the target, which makes the layout \
and routing passes prefer low-error qubits and pairs. Build a 4-qubit ring in \
which one ",
 Cell[BoxData["cz"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "7c127600-7401-47c3-8f91-768609712e96"],
 " edge, ",
 Cell[BoxData[
  RowBox[{"{", 
   RowBox[{"1", ",", " ", "2"}], "}"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "95b3a900-548d-4b1b-85a8-0ca556b4e516"],
 ", is far cleaner than the rest:"
