Cell["\<\
Build a device target once and reuse it to transpile several circuits to \
native OpenQASM:\
\>", "ExampleText",ExpressionUUID->"df39bf95-e951-451d-9ed8-96e834dfc445"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"With", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"tgt", " ", "=", " ", 
     RowBox[{"QiskitTarget", "[", 
      RowBox[{"<|", 
       RowBox[{
        RowBox[{"\"\<BasisGates\>\"", " ", "->", " ", 
         RowBox[{"{", 
          
          RowBox[{"\"\<x\>\"", ",", " ", "\"\<sx\>\"", ",", " ", "\"\<rz\>\"",
            ",", " ", "\"\<cz\>\""}], "}"}]}], ",", " ", 
        RowBox[{"\"\<NumQubits\>\"", " ", "->", " ", "4"}], ",", " ", 
        RowBox[{"\"\<CouplingMap\>\"", " ", "->", " ", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{"1", ",", " ", "0"}], "}"}], ",", " ", 
           RowBox[{"{", 
            RowBox[{"1", ",", " ", "3"}], "}"}], ",", " ", 
           RowBox[{"{", 
            RowBox[{"2", ",", " ", "0"}], "}"}], ",", " ", 
           RowBox[{"{", 
            RowBox[{"2", ",", " ", "3"}], "}"}]}], "}"}]}]}], "|>"}], "]"}]}],
     "}"}], ",", "\n", "  ", 
   RowBox[{
    RowBox[{
     RowBox[{"StringStartsQ", "[", 
      RowBox[{
       RowBox[{"QuantumQASM", "[", 
        RowBox[{"#", ",", " ", 
         RowBox[{"\"\<Target\>\"", " ", "->", " ", "tgt"}]}], "]"}], ",", 
       " ", "\"\<OPENQASM 3.0\>\""}], "]"}], " ", "&"}], " ", "/@", " ", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"QuantumCircuitOperator", "[", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"\"\<H\>\"", " ", "->", " ", "1"}], ",", " ", 
         RowBox[{"\"\<CNOT\>\"", " ", "->", " ", 
          RowBox[{"{", 
           RowBox[{"1", ",", " ", "2"}], "}"}]}], ",", " ", 
         RowBox[{"{", "1", "}"}], ",", " ", 
         RowBox[{"{", "2", "}"}]}], "}"}], "]"}], ",", " ", 
      RowBox[{"QuantumCircuitOperator", "[", 
       RowBox[{"\"\<GHZ\>\"", "[", "2", "]"}], "]"}]}], "}"}]}]}], "\n", 
  "]"}]], "Input",
 CellLabel->"In[1]:=",ExpressionUUID->"7ef5697e-bc7c-42dd-beff-5fcdef3e7987"],

