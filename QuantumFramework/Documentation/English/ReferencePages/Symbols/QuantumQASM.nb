Cell[CellGroupData[{

Cell["\t", "ExampleDelimiter",ExpressionUUID->"bb24ca59-dae1-41b6-82ba-b66fa8ddb2c4"],

Cell["\<\
Option names are case-insensitive: CamelCase and qiskit's snake_case \
spellings are interchangeable:\
\>", "ExampleText",ExpressionUUID->"b887fd02-1fa6-4759-9d89-1518309766ed"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"With", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{"qc", " ", "=", " ", 
      RowBox[{"QuantumCircuitOperator", "[", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"\"\<H\>\"", " ", "->", " ", "1"}], ",", " ", 
         RowBox[{"\"\<CNOT\>\"", " ", "->", " ", 
          RowBox[{"{", 
           RowBox[{"1", ",", " ", "2"}], "}"}]}], ",", " ", 
         RowBox[{"{", "1", "}"}], ",", " ", 
         RowBox[{"{", "2", "}"}]}], "}"}], "]"}]}], ",", " ", 
     RowBox[{"cm", " ", "=", " ", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"1", ",", " ", "0"}], "}"}], ",", " ", 
        RowBox[{"{", 
         RowBox[{"1", ",", " ", "3"}], "}"}], ",", " ", 
        RowBox[{"{", 
         RowBox[{"2", ",", " ", "0"}], "}"}], ",", " ", 
        RowBox[{"{", 
         RowBox[{"2", ",", " ", "3"}], "}"}]}], "}"}]}], ",", " ", 
     RowBox[{"b", " ", "=", " ", 
      RowBox[{"{", 
       RowBox[{"\"\<x\>\"", ",", " ", "\"\<sx\>\"", ",", " ", "\"\<rz\>\"", ",",
         " ", "\"\<cz\>\""}], "}"}]}]}], "}"}], ",", "\n", "  ", 
   RowBox[{
    RowBox[{"QuantumQASM", "[", 
     RowBox[{"qc", ",", " ", "b", ",", " ", 
      RowBox[{"\"\<CouplingMap\>\"", " ", "->", " ", "cm"}], ",", " ", 
      RowBox[{"\"\<OptimizationLevel\>\"", " ", "->", " ", "1"}]}], "]"}], 
    " ", "===", " ", 
    RowBox[{"QuantumQASM", "[", 
     RowBox[{"qc", ",", " ", "b", ",", " ", 
      RowBox[{"\"\<couplingMap\>\"", " ", "->", " ", "cm"}], ",", " ", 
      RowBox[{"\"\<optimization_level\>\"", " ", "->", " ", "1"}]}], 
     "]"}]}]}], "\n", "]"}]], "Input",
 CellLabel->"In[2]:=",ExpressionUUID->"28958f4b-165b-423f-8a17-8e23c5bf630c"],

Cell[BoxData["True"], "Output",
 CellChangeTimes->{3.989680409351403*^9, 3.9896805617888737`*^9},
 CellLabel->"Out[2]=",
 CellID->1858887104,ExpressionUUID->"4f36ee8e-9ab6-4b08-87d8-e54d3dad0b37"]
}, Open  ]]
}, Open  ]],

