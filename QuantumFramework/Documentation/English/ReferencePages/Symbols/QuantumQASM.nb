Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"QuantumQASM", "[", 
  RowBox[{
   RowBox[{
    RowBox[{"QuantumCircuitOperator", "[", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"\"\<H\>\"", " ", "->", " ", "1"}], ",", " ", 
       RowBox[{"\"\<CNOT\>\"", " ", "->", " ", 
