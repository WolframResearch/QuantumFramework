$0;\\nsx $0;\\nrz(pi/2) $0;\\nrz(pi/2) $1;\\nsx $1;\\nrz(pi) $1;\\ncz $0, $1;\
\\nsx $1;\\nrz(pi/2) $1;\\nrz(pi/2) $2;\\nsx $2;\\nrz(pi) $2;\\ncz $1, \
$2;\\nsx $2;\\nrz(pi/2) $2;\\n\"\>"], "Output",
