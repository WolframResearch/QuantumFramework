Cell[TextData[{
 "The table above is a snapshot of qiskit 2.4.1. A different qiskit version \
may add, rename, or remove these plugin names, so the list could differ from \
what is shown here \[LongDash] the authoritative set is always whatever the \
installed qiskit reports (queryable through ",
 Cell[BoxData[
  RowBox[{"list_stage", "_plugins"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "9a1ae282-ec52-4507-aa7d-77c0a6818aba"],
 "), not this page. ",
 Cell[BoxData["QuantumQASM"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "e89c7735-f760-4d0c-b651-bbf862cf83a4"],
 " itself does not depend on the table: it forwards whatever value you give \
straight to qiskit, so a value the installed qiskit does not recognize comes \
back as a ",
 Cell[BoxData["Failure"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "b6346143-e128-4b5a-8500-51719aa770b1"],
 " carrying qiskit's own message."
}], "Notes",ExpressionUUID->"f416991a-c21a-46e5-9817-e4c3f4eb18b2"],

Cell[TextData[{
 Cell[BoxData["\"\<OptimizationLevel\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "90af36e8-a3f5-498c-a74e-f8ad011d23b4"],
 " takes an integer 0 through 3; ",
 Cell[BoxData["\"\<SeedTranspiler\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "12f6b3f8-e63a-4df9-9baa-828c014840cc"],
 " takes any integer."
}], "Notes",ExpressionUUID->"15b9a132-69a3-4b5b-8cbd-0e26a1c85c82"]
}, Open  ]],

