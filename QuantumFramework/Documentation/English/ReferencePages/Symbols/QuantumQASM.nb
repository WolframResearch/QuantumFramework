Cell["\<\
Option names are case-insensitive: CamelCase and qiskit's snake_case \
spellings are interchangeable:\
\>", "ExampleText",ExpressionUUID->"d4496140-cccd-4dae-8d4d-5b5b2c183472"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"With", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{"qc", " ", "=", " ", 
      RowBox[{"QuantumCircuitOperator", "[", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"\"\<H\>\"", " ", "->", " ", "1"}], ",", " ", 
         RowBox[{"\"\<CNOT\>\"", " ", "->", " ", 
          RowBox[{"{", 
           RowBox[{"1", ",", " ", "2"}], "}"}]}], ",", " ", 
         RowBox[{"{", "1", "}"}], ",", " ", 
         RowBox[{"{", "2", "}"}]}], "}"}], "]"}]}], ",", " ", 
     RowBox[{"cm", " ", "=", " ", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"1", ",", " ", "0"}], "}"}], ",", " ", 
        RowBox[{"{", 
         RowBox[{"1", ",", " ", "3"}], "}"}], ",", " ", 
        RowBox[{"{", 
         RowBox[{"2", ",", " ", "0"}], "}"}], ",", " ", 
        RowBox[{"{", 
         RowBox[{"2", ",", " ", "3"}], "}"}]}], "}"}]}], ",", " ", 
     RowBox[{"b", " ", "=", " ", 
      RowBox[{"{", 
       RowBox[{"\"\<x\>\"", ",", " ", "\"\<sx\>\"", ",", " ", "\"\<rz\>\"", ",",
         " ", "\"\<cz\>\""}], "}"}]}]}], "}"}], ",", "\n", "  ", 
   RowBox[{
    RowBox[{"QuantumQASM", "[", 
     RowBox[{"qc", ",", " ", "b", ",", " ", 
      RowBox[{"\"\<CouplingMap\>\"", " ", "->", " ", "cm"}], ",", " ", 
      RowBox[{"\"\<OptimizationLevel\>\"", " ", "->", " ", "1"}]}], "]"}], 
    " ", "===", " ", 
    RowBox[{"QuantumQASM", "[", 
     RowBox[{"qc", ",", " ", "b", ",", " ", 
      RowBox[{"\"\<couplingMap\>\"", " ", "->", " ", "cm"}], ",", " ", 
      RowBox[{"\"\<optimization_level\>\"", " ", "->", " ", "1"}]}], 
     "]"}]}]}], "\n", "]"}]], "Input",
