Cell[TextData[{
 "The table above is a snapshot of qiskit 2.4.1. A different qiskit version \
may add, rename, or remove these plugin names, so the list could differ from \
what is shown here \[LongDash] the authoritative set is always whatever the \
installed qiskit reports (queryable through ",
 Cell[BoxData[
  RowBox[{"list_stage", "_plugins"}]], "InlineFormula",ExpressionUUID->
  "24d99f6d-a6ad-46bf-bd0c-a1cbe4f6a9d5"],
 "), not this page. ",
 Cell[BoxData[
 "QuantumQASM"], "InlineFormula",ExpressionUUID->
  "c4daa787-02d2-446f-9ee4-dc20a415d25c"],
 " itself does not depend on the table: it forwards whatever value you give \
straight to qiskit, so a value the installed qiskit does not recognize comes \
back as a ",
 Cell[BoxData[
 "Failure"], "InlineFormula",ExpressionUUID->
  "4a4038c9-eb31-4903-b85d-e3284f0cf1d3"],
 " carrying qiskit's own message."
}], "Notes",ExpressionUUID->"e64b3a7a-093f-46f1-8281-51ce10609fd1"],

Cell[TextData[{
 Cell[BoxData["\"\<OptimizationLevel\>\""], "InlineFormula",ExpressionUUID->
  "89e96a79-3232-40bd-8a22-962fd129b5a3"],
 " takes an integer 0 through 3; ",
 Cell[BoxData["\"\<SeedTranspiler\>\""], "InlineFormula",ExpressionUUID->
  "b5dbc82e-ef9d-4391-a2ca-722a3535bb7f"],
 " takes any integer."
}], "Notes",ExpressionUUID->"781d9730-5b0c-44c0-99a4-ada6c20dc131"]
}, Open  ]],

