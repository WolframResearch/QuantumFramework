Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"QuantumQASM", "[", 
  RowBox[{"qc", ",", " ", 
   RowBox[{"{", 
    RowBox[{"\"\<x\>\"", ",", " ", "\"\<sx\>\"", ",", " ", "\"\<rz\>\"", ",", 
     " ", "\"\<cz\>\""}], "}"}]}], "]"}]], "Input",
 CellChangeTimes->{{3.989680389277157*^9, 3.989680392202091*^9}},
 CellLabel->"In[27]:=",ExpressionUUID->"351ce681-1c08-4bec-89cd-bdac9ad3ff71"],

Cell[BoxData["\<\"OPENQASM 3.0;\\ninclude \\\"stdgates.inc\\\";\\nqubit[3] q;\
\\nrz(pi/2) q[2];\\ncz q[1], q[2];\\nsx q[2];\\nrz(3*pi/4) q[2];\\nsx \
q[2];\\nrz(pi) q[2];\\ncz q[0], q[2];\\nsx q[2];\\nrz(5*pi/4) q[2];\\nsx \
q[2];\\nrz(pi) q[2];\\ncz q[1], q[2];\\nrz(3*pi/4) q[1];\\nsx q[1];\\nrz(pi) \
q[1];\\nsx q[2];\\nrz(3*pi/4) q[2];\\nsx q[2];\\nrz(pi) q[2];\\ncz q[0], \
q[2];\\ncz q[0], q[1];\\nrz(pi/4) q[0];\\nsx q[1];\\nrz(3*pi/4) q[1];\\nsx \
q[1];\\nrz(pi) q[1];\\ncz q[0], q[1];\\nsx q[1];\\nrz(pi/2) q[1];\\nsx \
q[2];\\nrz(5*pi/4) q[2];\\nsx q[2];\\nrz(pi/2) q[2];\\n\"\>"], "Output",
 CellChangeTimes->{
  3.989680236172353*^9, {3.989680390000182*^9, 3.989680392437627*^9}, 
   3.989680431408979*^9},
 CellLabel->"Out[27]=",
 CellID->134197708,ExpressionUUID->"cdc5f0bc-16fa-456a-ac1b-53f409e57417"]
}, Open  ]],

