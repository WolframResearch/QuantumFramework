Cell[TextData[{
 "The OpenQASM 3 of a circuit, serialized exactly as built by the native, \
dependency-free emitter (single-qubit gates as ",
 Cell[BoxData[
  RowBox[{"U", 
   RowBox[{"(", 
    RowBox[{"\[Theta]", ",", " ", "\[CurlyPhi]", ",", " ", "\[Lambda]"}], 
    ")"}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "5b0bc515-7ed1-491b-9aaa-7b1dadf04a7b"],
 ", controls as ",
 Cell[BoxData[
  RowBox[{
   RowBox[{"ctrl", " ", "@", " ", "\[Ellipsis]"}], " ", 
   RowBox[{"negctrl", " ", "@", " ", "\[Ellipsis]"}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "f68ff984-0617-420c-9e4a-ed6ac6a6fbc5"],
 "):"
}], "ExampleText",ExpressionUUID->"b80d36b0-cf28-497d-9780-b6999d811474"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"QuantumQASM", "[", 
  RowBox[{"QuantumCircuitOperator", "[", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"\"\<H\>\"", " ", "->", " ", "1"}], ",", " ", 
     RowBox[{"\"\<CNOT\>\"", " ", "->", " ", 
      RowBox[{"{", 
       RowBox[{"1", ",", " ", "2"}], "}"}]}], ",", " ", 
     RowBox[{"{", "1", "}"}], ",", " ", 
     RowBox[{"{", "2", "}"}]}], "}"}], "]"}], "]"}]], "Input",
 CellLabel->"In[1]:=",ExpressionUUID->"456d99f3-bfc3-4bb6-a45e-84fd9fb36fb8"],

Cell[BoxData["\<\"OPENQASM 3.0;\\nqubit[2] q;\\nbit[2] \
c;\\nU(1.5707963267948966, 0., 3.141592653589793) q[0];\\nctrl(1) @ \
negctrl(0) @ U(3.141592653589793, 0., 3.141592653589793) q[0] q[1];\\nc[0] = \
measure q[0];\\nc[1] = measure q[1];\"\>"], "Output",
 CellChangeTimes->{3.9905498932317142`*^9},
 CellLabel->"Out[1]=",
 CellID->19595648,ExpressionUUID->"1cbf8fa9-29d8-46a2-baa0-1acb83cc3b73"]
}, Open  ]],

Cell[CellGroupData[{

Cell["\t", "ExampleDelimiter",ExpressionUUID->"297e6435-4df3-4806-86dd-406476be85ae"],

Cell["\<\
Pass any argument to route through qiskit instead, which emits standard named \
gates \[LongDash] here the same circuit as a faithful qiskit OpenQASM 3 dump:\
\
\>", "ExampleText",ExpressionUUID->"874e265e-7101-40e1-b971-a0698849c650"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"QuantumQASM", "[", 
  RowBox[{
   RowBox[{"QuantumCircuitOperator", "[", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"\"\<H\>\"", " ", "->", " ", "1"}], ",", " ", 
      RowBox[{"\"\<CNOT\>\"", " ", "->", " ", 
       RowBox[{"{", 
        RowBox[{"1", ",", " ", "2"}], "}"}]}], ",", " ", 
      RowBox[{"{", "1", "}"}], ",", " ", 
      RowBox[{"{", "2", "}"}]}], "}"}], "]"}], ",", " ", 
   RowBox[{"\"\<Version\>\"", " ", "->", " ", "3"}]}], "]"}]], "Input",
 CellLabel->"In[1]:=",ExpressionUUID->"1769af11-a683-4a11-81cc-d24ce2a1b3d0"],

Cell[BoxData["\<\"OPENQASM 3.0;\\ninclude \\\"stdgates.inc\\\";\\nbit[2] \
c;\\nqubit[2] q;\\nh q[0];\\ncx q[0], q[1];\\nc[0] = measure q[0];\\nc[1] = \
measure q[1];\\n\"\>"], "Output",
 CellChangeTimes->{3.9905498975127983`*^9},
 CellLabel->"Out[1]=",
 CellID->1977103279,ExpressionUUID->"12822077-3b61-46bb-8d7e-2bb31923505c"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["\t", "ExampleDelimiter",ExpressionUUID->"685f6ebd-3e23-4ea6-8505-d9e77bce4478"],

Cell["Transpile the same circuit to a native gate set:", "ExampleText",ExpressionUUID->"7cd0112e-534b-4eda-aaad-e234f091ce95"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"QuantumQASM", "[", 
  RowBox[{
   RowBox[{"QuantumCircuitOperator", "[", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"\"\<H\>\"", " ", "->", " ", "1"}], ",", " ", 
      RowBox[{"\"\<CNOT\>\"", " ", "->", " ", 
       RowBox[{"{", 
        RowBox[{"1", ",", " ", "2"}], "}"}]}], ",", " ", 
      RowBox[{"{", "1", "}"}], ",", " ", 
      RowBox[{"{", "2", "}"}]}], "}"}], "]"}], ",", " ", 
   RowBox[{"{", 
    RowBox[{"\"\<x\>\"", ",", " ", "\"\<sx\>\"", ",", " ", "\"\<rz\>\"", ",", 
     " ", "\"\<cz\>\""}], "}"}]}], "]"}]], "Input",
 CellLabel->"In[1]:=",ExpressionUUID->"2ecf4445-f833-40e2-8d65-a523118964fc"],

Cell[BoxData["\<\"OPENQASM 3.0;\\ninclude \\\"stdgates.inc\\\";\\nbit[2] \
c;\\nqubit[2] q;\\nrz(pi/2) q[0];\\nsx q[0];\\nrz(pi/2) q[0];\\nrz(pi/2) \
q[1];\\nsx q[1];\\nrz(pi) q[1];\\ncz q[0], q[1];\\nsx q[1];\\nrz(pi/2) \
q[1];\\nc[0] = measure q[0];\\nc[1] = measure q[1];\\n\"\>"], "Output",
 CellChangeTimes->{3.990549899498539*^9},
 CellLabel->"Out[1]=",
 CellID->304194647,ExpressionUUID->"3b53efc9-e41b-4ee4-842e-11237b7c1629"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["\t", "ExampleDelimiter",ExpressionUUID->"45f0d66e-f1c3-4be0-9ee8-48d390533540"],

Cell["\<\
Route onto a device coupling map, emitting two-qubit gates in the calibrated \
direction:\
\>", "ExampleText",ExpressionUUID->"39a90544-fa8a-42d6-8d5a-35814321ce48"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"QuantumQASM", "[", 
  RowBox[{
   RowBox[{"QuantumCircuitOperator", "[", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"\"\<H\>\"", " ", "->", " ", "1"}], ",", " ", 
      RowBox[{"\"\<CNOT\>\"", " ", "->", " ", 
       RowBox[{"{", 
        RowBox[{"1", ",", " ", "2"}], "}"}]}], ",", " ", 
      RowBox[{"{", "1", "}"}], ",", " ", 
      RowBox[{"{", "2", "}"}]}], "}"}], "]"}], ",", " ", 
   RowBox[{"{", 
    RowBox[{"\"\<x\>\"", ",", " ", "\"\<sx\>\"", ",", " ", "\"\<rz\>\"", ",", 
     " ", "\"\<cz\>\""}], "}"}], ",", " ", 
   RowBox[{"\"\<CouplingMap\>\"", " ", "->", " ", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"1", ",", " ", "0"}], "}"}], ",", " ", 
      RowBox[{"{", 
       RowBox[{"1", ",", " ", "3"}], "}"}], ",", " ", 
      RowBox[{"{", 
       RowBox[{"2", ",", " ", "0"}], "}"}], ",", " ", 
      RowBox[{"{", 
       RowBox[{"2", ",", " ", "3"}], "}"}]}], "}"}]}], ",", " ", 
   RowBox[{"\"\<OptimizationLevel\>\"", " ", "->", " ", "3"}]}], 
  "]"}]], "Input",
 CellLabel->"In[1]:=",ExpressionUUID->"03f8826c-ec54-42e4-a575-bc00cf22efaf"],

Cell[BoxData["\<\"OPENQASM 3.0;\\ninclude \\\"stdgates.inc\\\";\\nbit[2] \
c;\\nrz(pi/2) $0;\\nsx $0;\\nrz(pi/2) $0;\\nrz(pi/2) $1;\\nsx $1;\\nrz(pi) \
$1;\\ncz $1, $0;\\nsx $1;\\nrz(pi/2) $1;\\nc[0] = measure $0;\\nc[1] = \
measure $1;\\n\"\>"], "Output",
 CellChangeTimes->{3.990549901752901*^9},
 CellLabel->"Out[1]=",
 CellID->550699413,ExpressionUUID->"70da6d22-d515-4f8b-a249-d2bc5da703ce"]
}, Open  ]]
}, Open  ]]
}, Open  ]],

