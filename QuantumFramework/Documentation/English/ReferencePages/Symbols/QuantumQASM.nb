Notebook[{

Cell[CellGroupData[{
Cell["QuantumQASM", "ObjectName",
 CellID->1224892054,ExpressionUUID->"8393d601-4014-44ba-afc9-60862df940ec"],

Cell[TextData[{
 Cell["   ", "ModInfo",ExpressionUUID->"1700ab8e-c195-456c-9940-e9d8e9a162f7"],
 Cell[BoxData[
  RowBox[{
   ButtonBox["QuantumQASM",
    BaseStyle->"Link",
    ButtonData->"paclet:Wolfram/QuantumFramework/ref/QuantumQASM"], "[", 
   StyleBox["circ", "TI"], "]"}]], "InlineFormula",ExpressionUUID->
  "9b92e7ee-26de-4628-b9d1-861c86aac6bd"],
 " ",
 "gives the OpenQASM 3 string for the quantum circuit ",
 StyleBox["circ", "TI"],
 ", serialized exactly as built.",
 "\n",
 Cell["   ", "ModInfo",ExpressionUUID->"d328814f-760e-4b0c-9016-4de111f2a31b"],
 Cell[BoxData[
  RowBox[{
   ButtonBox["QuantumQASM",
    BaseStyle->"Link",
    ButtonData->"paclet:Wolfram/QuantumFramework/ref/QuantumQASM"], "[", 
   RowBox[{
    StyleBox["circ", "TI"], ",", " ", 
    RowBox[{"{", 
     RowBox[{
      SubscriptBox[
       StyleBox["g", "TI"], 
       StyleBox["1", "TR"]], ",", " ", 
      SubscriptBox[
       StyleBox["g", "TI"], 
       StyleBox["2", "TR"]], ",", " ", "\[Ellipsis]"}], "}"}]}], "]"}]], 
  "InlineFormula",ExpressionUUID->"2ec46855-de1f-4009-b304-a62c3f28e00a"],
 " ",
 "transpiles ",
 StyleBox["circ", "TI"],
 " to the native gate set ",
 Cell[BoxData[
  RowBox[{
   RowBox[{"{", 
    SubscriptBox[
     StyleBox["g", "TI"], "1"]}], ",", "\[ThinSpace]", 
   SubscriptBox[
    StyleBox["g", "TI"], "2"], ",", "\[ThinSpace]", 
   RowBox[{"\[Ellipsis]", "}"}]}]], "InlineFormula",ExpressionUUID->
  "ec0797ad-f642-40c1-9629-60be2c982ed3"],
 " and gives the resulting native OpenQASM.",
 "\n",
 Cell["   ", "ModInfo",ExpressionUUID->"9ce48e1d-db01-41c2-b362-ac6a86445b6e"],
 Cell[BoxData[
  RowBox[{
   ButtonBox["QuantumQASM",
    BaseStyle->"Link",
    ButtonData->"paclet:Wolfram/QuantumFramework/ref/QuantumQASM"], "[", 
   RowBox[{
    StyleBox["circ", "TI"], ",", " ", 
    StyleBox["basis", "TI"], ",", " ", 
    StyleBox["opts", "TI"]}], "]"}]], "InlineFormula",ExpressionUUID->
  "ad24de6b-ad15-4d65-8e78-54df4e1cb8e3"],
 " ",
 "applies qiskit transpiler options ",
 StyleBox["opts", "TI"],
 " such as ",
 Cell[BoxData["\"\<CouplingMap\>\""], "InlineFormula",ExpressionUUID->
  "fa63b71a-254e-402e-b67a-86aee1e0e1cf"],
 ", ",
 Cell[BoxData["\"\<OptimizationLevel\>\""], "InlineFormula",ExpressionUUID->
  "da01b3a2-5cae-4a2b-9c03-8f8b38e2babc"],
 " and ",
 Cell[BoxData["\"\<Target\>\""], "InlineFormula",ExpressionUUID->
  "905414d5-e438-4502-a05f-526141c83dc0"],
 ".",
 "\n",
 Cell["   ", "ModInfo",ExpressionUUID->"8fc4e8cb-dcc9-43a2-ac90-c369f8de08e8"],
 Cell[BoxData[
  RowBox[{
   ButtonBox["QuantumQASM",
    BaseStyle->"Link",
    ButtonData->"paclet:Wolfram/QuantumFramework/ref/QuantumQASM"], "[", 
   RowBox[{
    StyleBox["circ", "TI"], ",", " ", 
    RowBox[{"\"\<Version\>\"", " ", "->", " ", "2"}]}], "]"}]], 
  "InlineFormula",ExpressionUUID->"a51a5529-e080-4308-9394-aa7c3b8e0794"],
 " ",
 "gives OpenQASM 2 instead of the default OpenQASM 3."
}], "Usage",ExpressionUUID->"f2b768c8-b2c3-42d6-b34b-d582dd5ee4c7"],

Cell[TextData[{
 StyleBox["circ", "TI"],
 " can be a ",
 Cell[BoxData[
  ButtonBox["QuantumCircuitOperator",
   BaseStyle->"Link",
   ButtonData->"paclet:Wolfram/QuantumFramework/ref/QuantumCircuitOperator"]],
   "InlineFormula",ExpressionUUID->"d9e09196-5aa9-4082-88a6-a001d505c96a"],
 " or a ",
 Cell[BoxData[
  ButtonBox["QiskitCircuit",
   BaseStyle->"Link",
   ButtonData->"paclet:Wolfram/QuantumFramework/ref/QiskitCircuit"]], 
  "InlineFormula",ExpressionUUID->"9ce0884e-1bfa-4408-ad36-a5a577e209ce"],
 " (the value of ",
 Cell[BoxData[
  RowBox[{"qco", "[", "\"\<Qiskit\>\"", "]"}]], "InlineFormula",
  ExpressionUUID->"6d41a45c-2899-4268-9b55-0e4bb3f67faa"],
 ")."
}], "Notes",ExpressionUUID->"60ba1b5a-a13f-4447-913f-c127b983a964"],

Cell[TextData[{
 Cell[BoxData[
 "QuantumQASM"], "InlineFormula",ExpressionUUID->
  "529b34fb-0ba4-4917-9198-7f41989ed92d"],
 " is ",
 StyleBox["faithful by default",
  FontWeight->"Bold"],
 ": with no native gate set and no ",
 Cell[BoxData["\"\<Target\>\""], "InlineFormula",ExpressionUUID->
  "2be26d79-68ae-4327-b8cf-235462e09a62"],
 ", ",
 Cell[BoxData["\"\<CouplingMap\>\""], "InlineFormula",ExpressionUUID->
  "0b2b5a72-f732-4e90-8408-1c2ec35e0d1e"],
 " or other transpiler option, ",
 StyleBox["circ", "TI"],
 " is serialized exactly as built, with no qubit routing or optimization. \
Supplying any native gate set, target, coupling map or transpiler option \
makes ",
 Cell[BoxData[
 "QuantumQASM"], "InlineFormula",ExpressionUUID->
  "ade1d605-2fa7-4ded-bb03-6ee4fe0a37b2"],
 " transpile ",
 StyleBox["circ", "TI"],
 " first, then serialize the result."
}], "Notes",ExpressionUUID->"5ce9030d-7aa3-4364-af44-167c3a6ff41a"],

Cell[TextData[{
 Cell[BoxData[
 "QuantumQASM"], "InlineFormula",ExpressionUUID->
  "640bad44-03c6-4c00-a44e-a0c83af52913"],
 " returns an OpenQASM ",
 Cell[BoxData[
 "String"], "InlineFormula",ExpressionUUID->
  "ba66dd76-53fe-4a7d-8d10-59aa2c07d52e"],
 ". On any error it returns a ",
 Cell[BoxData[
  ButtonBox["Failure",
   BaseStyle->"Link",
   ButtonData->"paclet:ref/Failure"]], "InlineFormula",ExpressionUUID->
  "15412509-b635-4d78-acaa-6f2299a65d6a"],
 " instead of a partial program (see Possible Issues). It has no further \
property or accessor calls; the device model it accepts through ",
 Cell[BoxData["\"\<Target\>\""], "InlineFormula",ExpressionUUID->
  "3df7f966-0ac8-4543-bc82-0634a421ec2a"],
 ", a ",
 Cell[BoxData[
  ButtonBox["QiskitTarget",
   BaseStyle->"Link",
   ButtonData->"paclet:Wolfram/QuantumFramework/ref/QiskitTarget"]], 
  "InlineFormula",ExpressionUUID->"86a886e2-9541-4087-a99d-98df48b9dfdf"],
 " object, is what carries accessors such as ",
 Cell[BoxData[
  RowBox[{"[", "\"\<NumQubits\>\"", "]"}]], "InlineFormula",ExpressionUUID->
  "8c4edbd2-5f8f-4c94-b0a1-7e7d8b7b0974"],
 " and ",
 Cell[BoxData[
  RowBox[{"[", "\"\<OperationNames\>\"", "]"}]], "InlineFormula",
  ExpressionUUID->"5ae5f7a8-3135-4dbd-9143-db8f0bea6a32"],
 " (shown under Options)."
}], "Notes",ExpressionUUID->"2e69fb33-044a-4e50-8ba8-0fd3a9583d40"],

Cell[TextData[{
 "The native gate set is a list of qiskit ",
 StyleBox["standard gate names", "TI"],
 " such as ",
 Cell[BoxData[
  RowBox[{"{", 
   RowBox[{"\"\<x\>\"", ",", " ", "\"\<sx\>\"", ",", " ", "\"\<rz\>\"", ",", 
    " ", "\"\<cz\>\""}], "}"}]], "InlineFormula",ExpressionUUID->
  "897bc4ca-49fb-42df-b478-cf9fc9005078"],
 "; it can equivalently be given through the ",
 Cell[BoxData["\"\<BasisGates\>\""], "InlineFormula",ExpressionUUID->
  "2f505da4-637d-454d-9a5a-f6d06d8b7e76"],
 " option. The names are defined by the installed qiskit (54 in qiskit 2.4.1, \
e.g. ",
 Cell[BoxData["\"\<x\>\""], "InlineFormula",ExpressionUUID->
  "87e8cae1-f18c-4d77-b902-d8e7f23e1c32"],
 ", ",
 Cell[BoxData["\"\<sx\>\""], "InlineFormula",ExpressionUUID->
  "d4dbe2a1-aa78-4f50-ad78-67c2995bda92"],
 ", ",
 Cell[BoxData["\"\<rz\>\""], "InlineFormula",ExpressionUUID->
  "43d9fcdb-ab99-4c02-9d99-9f11d26c8c25"],
 ", ",
 Cell[BoxData["\"\<cz\>\""], "InlineFormula",ExpressionUUID->
  "74569bbe-918b-4c1e-8ed1-b5dcda9dd008"],
 ", ",
 Cell[BoxData["\"\<h\>\""], "InlineFormula",ExpressionUUID->
  "6b2ac69b-ea92-4537-a007-990c74b7c920"],
 ", ",
 Cell[BoxData["\"\<cx\>\""], "InlineFormula",ExpressionUUID->
  "b304eb08-554d-4226-9729-2b57a4e3e05f"],
 ", ",
 Cell[BoxData["\"\<ecr\>\""], "InlineFormula",ExpressionUUID->
  "38c732ac-1824-49bd-be8d-51f7eaa8dfaf"],
 ", ",
 Cell[BoxData["\"\<swap\>\""], "InlineFormula",ExpressionUUID->
  "d3a3144f-b66e-4a3a-9551-61dc493bc63e"],
 ", ",
 Cell[BoxData["\"\<ccx\>\""], "InlineFormula",ExpressionUUID->
  "50d90de4-39a8-4ec9-80bb-8e25053400ad"],
 "); this set can differ between qiskit versions, so the complete, \
version-correct list is qiskit's standard gate-name mapping, obtainable with ",
 Cell[BoxData[
  RowBox[{
   RowBox[{"qiskit", ".", "circuit", ".", "library", ".", "get_standard"}], 
   "_gate", "_name", "_mapping"}]], "InlineFormula",ExpressionUUID->
  "7288b183-2031-49e3-903e-0e99c56b1392"],
 " or from qiskit's ",
 ButtonBox["circuit-library documentation",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://docs.quantum.ibm.com/api/qiskit/circuit_library"], None}],
 "."
}], "Notes",ExpressionUUID->"e3ee61b5-2e67-4dcd-b0e2-599436d9cf10"],

Cell[TextData[{
 "Every option other than ",
 Cell[BoxData["\"\<Version\>\""], "InlineFormula",ExpressionUUID->
  "2b49ea7f-d3e1-49cd-9dfc-60ee5138a756"],
 " is forwarded to qiskit's transpiler. Option names are CamelCase and map to \
qiskit's snake_case parameter names (",
 Cell[BoxData["\"\<CouplingMap\>\""], "InlineFormula",ExpressionUUID->
  "3f9c5d76-a11d-4805-a02a-ea146db17eb8"],
 " to ",
 Cell[BoxData[
 "coupling_map"], "InlineFormula",ExpressionUUID->
  "8aab4eaf-538c-4f58-a150-4d945188fecf"],
 "); the raw snake_case name is accepted too. Any current or future qiskit \
transpile parameter therefore works without a change to ",
 Cell[BoxData[
 "QuantumQASM"], "InlineFormula",ExpressionUUID->
  "693bf4c4-de87-484a-8256-eb00ef085cb4"],
 "."
}], "Notes",ExpressionUUID->"475dbab3-87de-479d-b064-e3ea9a88c9aa"],

Cell[TextData[{
 "A ",
 Cell[BoxData["\"\<CouplingMap\>\""], "InlineFormula",ExpressionUUID->
  "80218fe7-71a5-4dc7-8329-4b5d0129c86a"],
 " is a list of directed pairs ",
 Cell[BoxData[
  RowBox[{"{", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"c", ",", " ", "t"}], "}"}], ",", " ", "\[Ellipsis]"}], "}"}]], 
  "InlineFormula",ExpressionUUID->"0d8b0043-e889-4e7b-ab37-d768271c9a63"],
 " of physical qubit indices that may interact; two-qubit gates are emitted \
in that calibrated direction."
}], "Notes",ExpressionUUID->"465f2999-0656-43c4-84a2-a84535c2191e"],

Cell[TextData[{
 "A qiskit-free alternative is the pure-Wolfram emitter ",
 Cell[BoxData[
  ButtonBox["QuantumCircuitOperator",
   BaseStyle->"Link",
   ButtonData->"paclet:Wolfram/QuantumFramework/ref/QuantumCircuitOperator"]],
   "InlineFormula",ExpressionUUID->"a48637b4-3d19-4faf-9701-9f862e557087"],
 " property ",
 Cell[BoxData["\"\<QASM\>\""], "InlineFormula",ExpressionUUID->
  "ead2d26e-159b-407a-9394-6b3169f30e11"],
 ", which emits a generic gate set; ",
 Cell[BoxData[
 "QuantumQASM"], "InlineFormula",ExpressionUUID->
  "778fded1-751c-40b9-8667-651627e5d61c"],
 " instead routes through qiskit and can decompose to a hardware-native basis."
}], "Notes",ExpressionUUID->"aea60c19-2661-4d7f-aa74-f897a3012200"],

Cell[TextData[{
 Cell[BoxData[
 "QuantumQASM"], "InlineFormula",ExpressionUUID->
  "9ff35f5b-923e-4a0a-a606-15ba5dc8c91b"],
 " builds the qiskit circuit through ",
 Cell[BoxData[
  RowBox[{"qco", "[", "\"\<Qiskit\>\"", "]"}]], "InlineFormula",
  ExpressionUUID->"3fb98608-d02b-4619-a1f1-5443108cd33b"],
 " and runs the qiskit transpiler in the framework's Python session; the \
qiskit package is installed automatically on first use."
}], "Notes",ExpressionUUID->"91da51b8-8a77-4d33-a7ce-7fd0be9d7a82"],

Cell[BoxData[GridBox[{
   {Cell["      ", "ModInfo",ExpressionUUID->
     "a5a750fc-6b5e-4ceb-b127-a7c99f65c4fd"], Cell["Option", "TableText",
     FontWeight->Bold,ExpressionUUID->"193224f3-72cc-48ac-8a28-0d6ebf691f41"],
     Cell["Default value", "TableText",
     FontWeight->Bold,ExpressionUUID->"034242d8-1b4a-477f-8430-a2926c4b42e6"],
     Cell["Description", "TableText",
     FontWeight->Bold,ExpressionUUID->"bcf4dfa5-9af3-4729-a58a-745c665fc66e"]},
   {Cell["      ", "ModInfo",ExpressionUUID->
     "1f433a87-dec0-4540-a277-3282847e9369"], Cell[TextData[Cell[
    BoxData["\"\<Version\>\""], "InlineFormula",ExpressionUUID->
     "c1f73d11-785b-4133-aed7-78920a4414e0"]], "TableText",ExpressionUUID->
     "744e6f2d-7956-40bc-81b8-f9a97537c088"], Cell[
    "3", "TableText",ExpressionUUID->"e1347f4b-c7e0-4e8a-8b7a-a497da55d920"], 
    Cell["the OpenQASM version to emit, 2 or 3", "TableText",ExpressionUUID->
     "6ade047c-6dbd-4687-8948-df1361a0cb61"]},
   {Cell["      ", "ModInfo",ExpressionUUID->
     "86a2ae68-663b-45eb-95de-e6b130aa5d5e"], Cell[TextData[Cell[
    BoxData["\"\<BasisGates\>\""], "InlineFormula",ExpressionUUID->
     "6f7bfebc-26e4-42c7-8627-a8ccac5bf734"]], "TableText",ExpressionUUID->
     "508277dd-e737-4a06-aba3-b0c693005173"], Cell[
    "Automatic", "TableText",ExpressionUUID->
     "452552d9-b38f-4d47-a3d0-dd412202f61a"], Cell[
    "the native gate set (the same as the second argument)", "TableText",
     ExpressionUUID->"7ef7f644-3500-4dfc-a6b9-e9f143b533dd"]},
   {Cell["      ", "ModInfo",ExpressionUUID->
     "9e0b3ee1-8dcc-4df6-8182-acd0c99bb931"], Cell[TextData[Cell[
    BoxData["\"\<CouplingMap\>\""], "InlineFormula",ExpressionUUID->
     "1fd7fa98-3e05-483c-afbc-77bce2ec3784"]], "TableText",ExpressionUUID->
     "b7ed0581-b31c-410b-b1b6-03dd55732068"], Cell[
    "Automatic", "TableText",ExpressionUUID->
     "11887923-c080-4b59-b335-ecf7429d72aa"], Cell[
    "directed pairs of physical qubits that may interact", "TableText",
     ExpressionUUID->"a7ff21c9-70d2-42d3-bc32-50b6393c83f3"]},
   {Cell["      ", "ModInfo",ExpressionUUID->
     "8d0a8cf4-2644-4a7c-b9e8-8fe2dc6962da"], Cell[TextData[Cell[
    BoxData["\"\<OptimizationLevel\>\""], "InlineFormula",ExpressionUUID->
     "bf251c84-efcd-4dee-8a23-c84e75b2cf88"]], "TableText",ExpressionUUID->
     "eef0e561-c631-4895-853e-4ac8dcf8c26d"], Cell[
    "Automatic", "TableText",ExpressionUUID->
     "378b3ff6-42f8-4ee8-bbb3-64b708194963"], Cell[
    "the qiskit optimization level, 0 through 3", "TableText",ExpressionUUID->
     "00a218d1-64e8-40b6-8ef9-6ed0946f5299"]},
   {Cell["      ", "ModInfo",ExpressionUUID->
     "4c78ddfd-e07c-4a31-bceb-9c1771d50ccb"], Cell[TextData[Cell[
    BoxData["\"\<Target\>\""], "InlineFormula",ExpressionUUID->
     "574eea5d-e46b-44d8-bc1b-b9d6f61fb252"]], "TableText",ExpressionUUID->
     "073dc450-f3b1-4ef5-a523-0d5aee54d13e"], Cell[
    "None", "TableText",ExpressionUUID->
     "35f9f829-169b-4acb-aa95-dac41f1a912a"], Cell[TextData[{
     "a ",
     Cell[BoxData[
      ButtonBox["QiskitTarget",
       BaseStyle->"Link",
       ButtonData->"paclet:Wolfram/QuantumFramework/ref/QiskitTarget"]], 
      "InlineFormula",ExpressionUUID->"bae784a3-85ec-4902-96e8-d1e98a5be910"],
     
     " object or an Association device spec"
    }], "TableText",ExpressionUUID->"569d563f-1ffb-47cb-b8b1-f423cd6f6cfe"]}
  }]], "3ColumnTableMod",ExpressionUUID->"46328502-4751-4101-8c06-\
4c299cbc7d0e"],

Cell[TextData[{
 "Any other qiskit ",
 Cell[BoxData[
 "transpile"], "InlineFormula",ExpressionUUID->
  "c73decc4-9ed1-4ea5-891f-dd463607f2be"],
 " parameter (for example ",
 Cell[BoxData["\"\<InitialLayout\>\""], "InlineFormula",ExpressionUUID->
  "a818be64-a5e7-41de-b063-5f2b2dbfde18"],
 ", ",
 Cell[BoxData["\"\<RoutingMethod\>\""], "InlineFormula",ExpressionUUID->
  "02e8c125-35ea-4c79-9aaa-cb9d735635b5"],
 ", ",
 Cell[BoxData["\"\<SeedTranspiler\>\""], "InlineFormula",ExpressionUUID->
  "dbc8e0b4-1165-41b7-b062-1f18d31f7323"],
 ") is also accepted."
}], "Notes",ExpressionUUID->"28ee5133-ecfd-4809-beb4-bdbd89e1056e"],

Cell[TextData[{
 "The string value of a ",
 StyleBox["method", "TI"],
 " option \[LongDash] ",
 Cell[BoxData["\"\<LayoutMethod\>\""], "InlineFormula",ExpressionUUID->
  "b8a2f7a2-19ac-4a89-8564-ce0a6e5b3fd0"],
 ", ",
 Cell[BoxData["\"\<RoutingMethod\>\""], "InlineFormula",ExpressionUUID->
  "001ec675-3509-470f-a5d7-b1e7b0a85a8d"],
 ", ",
 Cell[BoxData["\"\<TranslationMethod\>\""], "InlineFormula",ExpressionUUID->
  "b4488019-7247-40ef-afb6-d1cb742f78d4"],
 ", ",
 Cell[BoxData["\"\<SchedulingMethod\>\""], "InlineFormula",ExpressionUUID->
  "32e830d7-a8e4-4d9a-8576-e89a5f830645"],
 ", ",
 Cell[BoxData["\"\<InitMethod\>\""], "InlineFormula",ExpressionUUID->
  "1db71e26-47d6-48dd-890e-1bdb493ba9d1"],
 ", ",
 Cell[BoxData["\"\<OptimizationMethod\>\""], "InlineFormula",ExpressionUUID->
  "0b92f555-e834-474d-a815-5e02d9a064f2"],
 ", ",
 Cell[BoxData["\"\<UnitarySynthesisMethod\>\""], "InlineFormula",
  ExpressionUUID->"c70ff4a6-9b66-4c7a-a8df-86e183e9736e"],
 " \[LongDash] is the name of a qiskit transpiler ",
 StyleBox["stage plugin", "TI"],
 ". These names are defined by the installed qiskit, not by ",
 Cell[BoxData[
 "QuantumQASM"], "InlineFormula",ExpressionUUID->
  "9b97b973-9b9b-45d0-93b2-5572a022d132"],
 ", and vary by version; the authoritative list is qiskit's ",
 ButtonBox["transpilation defaults and configuration options",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://quantum.cloud.ibm.com/docs/en/guides/defaults-and-\
configuration-options"], None}],
 " guide, and they can be enumerated from the installed qiskit through ",
 Cell[BoxData[
  RowBox[{
   RowBox[{
   "qiskit", ".", "transpiler", ".", "preset_passmanagers", ".", "plugin", ".",
     "list_stage"}], "_plugins"}]], "InlineFormula",ExpressionUUID->
  "c081e653-9050-44b1-8200-249faa3eaca0"],
 ". For the qiskit 2.4.1 bundled with the framework the values are:"
}], "Notes",ExpressionUUID->"9e3c2356-e342-4686-9282-d1ac94be793b"],

Cell[BoxData[GridBox[{
   {Cell["      ", "ModInfo",ExpressionUUID->
     "50af0fda-8dba-42d2-a79e-2807eecd5ea5"], Cell[
    "Method option", "TableText",
     FontWeight->Bold,ExpressionUUID->"1ed593ed-3eed-4654-983b-121b90e0eef6"],
     Cell["qiskit 2.4.1 plugin names", "TableText",
     FontWeight->Bold,ExpressionUUID->"61108350-76eb-47f2-a9ed-51f67b823fe9"]},
   {Cell["      ", "ModInfo",ExpressionUUID->
     "544059fb-47f0-4f83-9e93-521ddd5fff70"], Cell[TextData[Cell[
    BoxData["\"\<LayoutMethod\>\""], "InlineFormula",ExpressionUUID->
     "74964e99-ffe1-4d9d-bda8-9f5a72143d5f"]], "TableText",ExpressionUUID->
     "c55f0b2c-7f33-44c2-9932-44423664151d"], Cell[TextData[{
     Cell[
     BoxData["\"\<trivial\>\""], "InlineFormula",ExpressionUUID->
      "ccedad8c-0fd7-42a3-9f8f-06366557c0cd"],
     ", ",
     Cell[
     BoxData["\"\<dense\>\""], "InlineFormula",ExpressionUUID->
      "818ada87-2bf2-4bbf-b994-3ae00d04a13b"],
     ", ",
