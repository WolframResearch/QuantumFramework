Notebook[{

Cell[CellGroupData[{
Cell["QuantumQASM", "ObjectName",
 CellID->1224892054,ExpressionUUID->"8393d601-4014-44ba-afc9-60862df940ec"],

Cell[TextData[{
 Cell["   ", "ModInfo",ExpressionUUID->"d58a7e9d-5efd-4066-aa7f-7039dd59f998"],
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     Cell[
      TextData["QuantumQASM"]], 
     "paclet:Wolfram/QuantumFramework/ref/QuantumQASM", 
     "Wolfram/QuantumFramework Package Symbol"},
    "PackageLink",
    BaseStyle->"InlineFormula"], "[", 
   StyleBox["circ", "TI"], "]"}]], "InlineFormula",ExpressionUUID->
  "31b6cf6a-f484-4c31-b843-2e2fcc5ef81f"],
 " ",
 "gives the OpenQASM 3 string for the quantum circuit ",
 StyleBox["circ", "TI"],
 ", serialized exactly as built by the native Wolfram Language emitter (no \
qiskit dependency).",
 "\n",
 Cell["   ", "ModInfo",ExpressionUUID->"12fd52af-f97e-4b3b-890d-fd53c306b3c2"],
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     Cell[
      TextData["QuantumQASM"]], 
     "paclet:Wolfram/QuantumFramework/ref/QuantumQASM", 
     "Wolfram/QuantumFramework Package Symbol"},
    "PackageLink",
    BaseStyle->"InlineFormula"], "[", 
   RowBox[{
    StyleBox["circ", "TI"], ",", " ", 
    RowBox[{"{", 
     RowBox[{
      SubscriptBox[
       StyleBox["g", "TI"], 
       StyleBox["1", "TR"]], ",", " ", 
      SubscriptBox[
       StyleBox["g", "TI"], 
       StyleBox["2", "TR"]], ",", " ", "\[Ellipsis]"}], "}"}]}], "]"}]], 
  "InlineFormula",ExpressionUUID->"1526b601-4f35-4d30-ac2d-5aeea6ac536a"],
 " ",
 "transpiles ",
 StyleBox["circ", "TI"],
 " to the native gate set ",
 Cell[BoxData[
  RowBox[{
   RowBox[{"{", 
    SubscriptBox[
     StyleBox["g", "TI"], "1"]}], 
   RowBox[{",", "\[ThinSpace]"}], 
   SubscriptBox[
    StyleBox["g", "TI"], "2"], 
   RowBox[{",", "\[ThinSpace]"}], 
   RowBox[{"\[Ellipsis]", "}"}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "b06ed187-ef81-46d1-805c-10bf47435ad7"],
 " and gives the resulting native OpenQASM.",
 "\n",
 Cell["   ", "ModInfo",ExpressionUUID->"663d2b22-8b27-4a62-9728-90c5548dff84"],
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     Cell[
      TextData["QuantumQASM"]], 
     "paclet:Wolfram/QuantumFramework/ref/QuantumQASM", 
     "Wolfram/QuantumFramework Package Symbol"},
    "PackageLink",
    BaseStyle->"InlineFormula"], "[", 
   RowBox[{
    StyleBox["circ", "TI"], ",", " ", 
    StyleBox["basis", "TI"], ",", " ", 
    StyleBox["opts", "TI"]}], "]"}]], "InlineFormula",ExpressionUUID->
  "bdc41d24-98b3-4dd0-8074-9c0a8e800e34"],
 " ",
 "transpiles ",
 StyleBox["circ", "TI"],
 " to the native gate set ",
 StyleBox["basis", "TI"],
 ", applying the qiskit transpiler options ",
 StyleBox["opts", "TI"],
 ".",
 "\n",
 Cell["   ", "ModInfo",ExpressionUUID->"fa44b503-3844-4963-a620-d7063b9f56c1"],
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     Cell[
      TextData["QuantumQASM"]], 
     "paclet:Wolfram/QuantumFramework/ref/QuantumQASM", 
     "Wolfram/QuantumFramework Package Symbol"},
    "PackageLink",
    BaseStyle->"InlineFormula"], "[", 
   RowBox[{
    StyleBox["circ", "TI"], ",", " ", 
    RowBox[{"\"\<Version\>\"", " ", "->", " ", "2"}]}], "]"}]], 
  "InlineFormula",ExpressionUUID->"804a617f-7287-43c3-bc12-cd1029e29a1c"],
 " ",
 "gives OpenQASM 2 instead of the default OpenQASM 3.",
 "\n",
 Cell["   ", "ModInfo",ExpressionUUID->"86933b3a-5b31-4d0a-a11d-55516e3f8c6e"],
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     Cell[
      TextData["QuantumQASM"]], 
     "paclet:Wolfram/QuantumFramework/ref/QuantumQASM", 
     "Wolfram/QuantumFramework Package Symbol"},
    "PackageLink",
    BaseStyle->"InlineFormula"], "[", 
   StyleBox["op", "TI"], "]"}]], "InlineFormula",ExpressionUUID->
  "02e08b22-70a8-4d70-aedc-5987b4f967ed"],
 " ",
 "gives the OpenQASM line for a single ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["QuantumOperator"]], 
    "paclet:Wolfram/QuantumFramework/ref/QuantumOperator", 
    "Wolfram/QuantumFramework Package Symbol"},
   "PackageLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",ExpressionUUID->
  "7058a202-0b33-4dca-8a4d-f6d7a1cb68a0"],
 " ",
 StyleBox["op", "TI"],
 ".",
 "\n",
 Cell["   ", "ModInfo",ExpressionUUID->"306c50df-eea5-4091-b3db-e2dc7a95ce6b"],
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     Cell[
      TextData["QuantumQASM"]], 
     "paclet:Wolfram/QuantumFramework/ref/QuantumQASM", 
     "Wolfram/QuantumFramework Package Symbol"},
    "PackageLink",
    BaseStyle->"InlineFormula"], 
   "[", "\"\<\!\(\*StyleBox[\"qasm\", \"TI\"]\)\>\"", "]"}]], "InlineFormula",
  ExpressionUUID->"d04edc59-38db-4445-aef7-a473e5450edc"],
 " ",
 "imports an OpenQASM 2 or 3 source string and gives the corresponding ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["QuantumCircuitOperator"]], 
    "paclet:Wolfram/QuantumFramework/ref/QuantumCircuitOperator", 
    "Wolfram/QuantumFramework Package Symbol"},
   "PackageLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",ExpressionUUID->
  "a58cbf6a-a4ea-4c92-846d-9fa01454470c"],
 ".",
 "\n",
 Cell["   ", "ModInfo",ExpressionUUID->"920aa711-eddd-4498-812e-21e5f27d3113"],
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     Cell[
      TextData["QuantumQASM"]], 
     "paclet:Wolfram/QuantumFramework/ref/QuantumQASM", 
     "Wolfram/QuantumFramework Package Symbol"},
    "PackageLink",
    BaseStyle->"InlineFormula"], "[", 
   RowBox[{
    ButtonBox["File",
     BaseStyle->"Link"], 
    "[", "\"\<\!\(\*StyleBox[\"file\", \"TI\"]\).qasm\>\"", "]"}], "]"}]], 
  "InlineFormula",ExpressionUUID->"446d6d20-cdb1-429f-8b23-23208656b6b6"],
 " ",
 "(or a bare ",
 Cell[BoxData["\"\<.qasm\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "82234604-c1ec-4158-844b-4302b4eee6df"],
 " file path) imports OpenQASM from a file."
}], "Usage",ExpressionUUID->"dacd2830-379e-4395-b312-8f51867c5022"],

Cell[TextData[{
 StyleBox["circ", "TI"],
 " can be a ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["QuantumCircuitOperator"]], 
    "paclet:Wolfram/QuantumFramework/ref/QuantumCircuitOperator", 
    "Wolfram/QuantumFramework Package Symbol"},
   "PackageLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",ExpressionUUID->
  "f96db338-9c6d-45ab-85f4-5cfe136a353d"],
 " or a ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["QiskitCircuit"]], 
    "paclet:Wolfram/QuantumFramework/ref/QiskitCircuit", 
    "Wolfram/QuantumFramework Package Symbol"},
   "PackageLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",ExpressionUUID->
  "df9b7de3-6b32-411a-af46-7ad64574828c"],
 " (the value of ",
 Cell[BoxData[
  RowBox[{"qco", "[", "\"\<Qiskit\>\"", "]"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "cfb1be63-8f95-4c07-90f3-3f0fd60f1c1d"],
 "). A single ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["QuantumOperator"]], 
    "paclet:Wolfram/QuantumFramework/ref/QuantumOperator", 
    "Wolfram/QuantumFramework Package Symbol"},
   "PackageLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",ExpressionUUID->
  "66b7af50-7ced-43cd-b724-6e1bec9390fe"],
 " ",
 StyleBox["op", "TI"],
 " is also accepted and gives just that gate's OpenQASM line."
}], "Notes",ExpressionUUID->"b359ce24-4066-499a-9c64-3c0f03e062e9"],

Cell[TextData[{
 Cell[BoxData[
  RowBox[{"QuantumQASM", "["}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "bfcba102-04a3-415a-8dad-866b62fbec9a"],
 StyleBox["circ", "TI"],
 Cell[BoxData[
  RowBox[{
   RowBox[{",", " ", "\"\<WL\>\""}], "]"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "e43fa49e-678f-461c-85c9-13fcb58292b9"],
 " is an explicit synonym for the native bare-call emission, and ",
 Cell[BoxData[
  RowBox[{"QuantumQASM", "["}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "78b1265f-48fb-4fc5-aaaf-225b5ba1d37e"],
 StyleBox["op", "TI"],
 Cell[BoxData[
  RowBox[{
   RowBox[{",", " ", "\"\<Simple\>\""}], "]"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "08ed9fc4-b231-4f5a-a02e-abbe84df9f65"],
 " gives the bare gate fragment (no qubit operands). These two are the \
dependency-free emitters that back the ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["QuantumCircuitOperator"]], 
    "paclet:Wolfram/QuantumFramework/ref/QuantumCircuitOperator", 
    "Wolfram/QuantumFramework Package Symbol"},
   "PackageLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",ExpressionUUID->
  "2942ec8b-dce9-4f88-b017-4506d5240152"],
 " ",
 Cell[BoxData["\"\<QASM\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "73797954-fc06-4429-b944-27c590b710b3"],
 ", ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["QuantumOperator"]], 
    "paclet:Wolfram/QuantumFramework/ref/QuantumOperator", 
    "Wolfram/QuantumFramework Package Symbol"},
   "PackageLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",ExpressionUUID->
  "3eca391f-4d72-4b25-8eb6-96c82f9f3554"],
 " ",
 Cell[BoxData["\"\<QASM\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "fcd8c108-050d-4763-92e9-66d4a84486f8"],
 ", and ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["QuantumOperator"]], 
    "paclet:Wolfram/QuantumFramework/ref/QuantumOperator", 
    "Wolfram/QuantumFramework Package Symbol"},
   "PackageLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",ExpressionUUID->
  "1f64b22f-807e-4adf-bb65-8b8ebb160186"],
 " ",
 Cell[BoxData["\"\<SimpleQASM\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "41068d8f-f86d-43a3-937b-d63d9b6640de"],
 " properties \[LongDash] every QASM property routes through ",
 Cell[BoxData["QuantumQASM"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "45db3de1-ca04-457a-986e-9c91530634aa"],
 "."
}], "Notes",ExpressionUUID->"19f4d1af-b06d-4fcb-8f9f-4816f8cf9ec4"],

Cell[TextData[{
 "Supplying a ",
 Cell[BoxData["\"\<Provider\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "5f9a94c8-51b4-4626-bb74-1733d944889f"],
 " or ",
 Cell[BoxData["\"\<Backend\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "e143cc13-0c30-4ca3-8812-6f04b53881ee"],
 " option engages the hardware-provider export path: the circuit is \
transpiled against a real backend and serialized, including the AWS-Braket \
OpenQASM conversion when the provider is AWS Braket (",
 Cell[BoxData[
  RowBox[{"\"\<Provider\>\"", " ", "->", " ", "\"\<AWSBraket\>\""}]], 
  "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "23a0bb7c-78ec-4a30-8ce3-9f7a252192c7"],
 ")."
}], "Notes",ExpressionUUID->"15f10d31-3c86-40ce-8d68-3f2b85d31167"],

Cell[TextData[{
 Cell[BoxData["QuantumQASM"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "d2b62e03-17ba-44dd-9039-a02487c350d0"],
 " is ",
 StyleBox["faithful by default",
  FontWeight->"Bold"],
 ": with no native gate set and no ",
 Cell[BoxData["\"\<Target\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "d1b1782d-1ec9-4d29-a413-2b54f38822cf"],
 ", ",
 Cell[BoxData["\"\<CouplingMap\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "50050473-55e1-4a27-975d-0165f0856ea4"],
 " or other transpiler option, ",
 StyleBox["circ", "TI"],
 " is serialized exactly as built, with no qubit routing or optimization. \
Supplying any native gate set, target, coupling map or transpiler option \
makes ",
 Cell[BoxData["QuantumQASM"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "fa5e64a3-a2c2-47bb-a5e1-94ab7a6e4112"],
 " transpile ",
 StyleBox["circ", "TI"],
 " first, then serialize the result."
}], "Notes",ExpressionUUID->"7f218df8-8726-4ad6-96c9-5ed7c12f07bf"],

Cell[TextData[{
 "The bare call ",
 Cell[BoxData[
  RowBox[{"QuantumQASM", "["}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "eb53be5a-9ec8-4575-8077-cf6007ecc487"],
 StyleBox["circ", "TI"],
 Cell[BoxData["]"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "b7f1007f-57fd-4f5a-9175-b8d141947adb"],
 " (no arguments) uses the ",
 StyleBox["native Wolfram Language",
  FontWeight->"Bold"],
 " emitter: it needs no qiskit or Python, is unaffected by qiskit version \
changes, and emits a generic gate set (single-qubit gates as ",
 Cell[BoxData[
  RowBox[{"U", 
   RowBox[{"(", 
    RowBox[{"\[Theta]", ",", " ", "\[CurlyPhi]", ",", " ", "\[Lambda]"}], 
    ")"}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "7928749f-4eb0-44d0-aef9-d63997026230"],
 ", controls as ",
 Cell[BoxData[
  RowBox[{
   RowBox[{"ctrl", " ", "@", " ", "\[Ellipsis]"}], " ", 
   RowBox[{"negctrl", " ", "@", " ", "\[Ellipsis]"}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "17ea840b-6a07-4b01-b32c-e7096ee73ac4"],
 "). Supplying ",
 StyleBox["any", "TI"],
 " argument (a native gate set, a ",
 Cell[BoxData["\"\<Target\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "db465931-e6ae-4694-a774-2ab2306dc26b"],
 ", an OpenQASM ",
 Cell[BoxData["\"\<Version\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "40455b1d-4d02-4e39-9df7-1a79ebf812f7"],
 ", or any transpiler option) routes through qiskit instead, which emits \
standard named gates (",
 Cell[BoxData["h"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "23241c84-3391-4492-a536-7b86b4e94dfc"],
 ", ",
 Cell[BoxData["cx"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "eb4eea97-2d45-4650-9784-b5b32fb83c0b"],
 ", \[Ellipsis]) and can decompose to a hardware-native basis."
}], "Notes",ExpressionUUID->"e4f4a917-5dfc-4599-a237-82f83f92169a"],

Cell[TextData[{
 Cell[BoxData["QuantumQASM"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "7506c17e-a4c8-415a-8858-18d74118be23"],
 " returns an OpenQASM ",
 Cell[BoxData["String"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "917cff59-62d2-43a1-aa82-2ac4ed6e9a31"],
 ". On any error it returns a ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["Failure"]], "paclet:ref/Failure"},
   "RefLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",ExpressionUUID->
  "0ad7adfc-079f-4921-ba33-66b59f40f2d6"],
 " instead of a partial program (see Possible Issues). It has no further \
property or accessor calls; the device model it accepts through ",
 Cell[BoxData["\"\<Target\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "32f4e980-cae2-4df4-a380-5fee908dc5fa"],
 ", a ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["QiskitTarget"]], 
    "paclet:Wolfram/QuantumFramework/ref/QiskitTarget", 
    "Wolfram/QuantumFramework Package Symbol"},
   "PackageLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",ExpressionUUID->
  "865cdd24-876e-4a55-a02e-ad57fb8fa5cb"],
 " object, is what carries accessors such as ",
 Cell[BoxData[
  RowBox[{"[", "\"\<NumQubits\>\"", "]"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "c8ab84d8-bc95-4a12-bada-5a3d9b571a28"],
 " and ",
 Cell[BoxData[
  RowBox[{"[", "\"\<OperationNames\>\"", "]"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "8c9efd52-0b6c-4eee-9279-3fba2c8e1f83"],
 " (shown under Options)."
}], "Notes",ExpressionUUID->"2990a704-2118-49f7-a2f9-7cfbe496cc0d"],

Cell[TextData[{
 "The native gate set is a list of qiskit ",
 StyleBox["standard gate names", "TI"],
 " such as ",
 Cell[BoxData[
  RowBox[{"{", 
   RowBox[{"\"\<x\>\"", ",", " ", "\"\<sx\>\"", ",", " ", "\"\<rz\>\"", ",", 
    " ", "\"\<cz\>\""}], "}"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "540d0506-b2b5-43bd-b189-a20a6c0f55a6"],
 "; it can equivalently be given through the ",
 Cell[BoxData["\"\<BasisGates\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "8eca56a4-a980-4aea-b237-848769da5bb7"],
 " option. The names are defined by the installed qiskit (54 in qiskit 2.4.1, \
e.g. ",
 Cell[BoxData["\"\<x\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "d98ce30c-1d12-4cd6-b8fc-a968374da00a"],
 ", ",
 Cell[BoxData["\"\<sx\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "b4a6aacc-c2fc-4809-ae1e-52b6bd4715a1"],
 ", ",
 Cell[BoxData["\"\<rz\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "23fefb5a-9082-487f-9350-bcbb05d1a31d"],
 ", ",
 Cell[BoxData["\"\<cz\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "52801867-a42a-48f5-9fc5-1dc860e16ae6"],
 ", ",
 Cell[BoxData["\"\<h\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "3dc5c10a-08d0-48ff-b4ec-0ff352adb435"],
 ", ",
 Cell[BoxData["\"\<cx\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "ad8397a8-2578-440a-a7b6-38481361216e"],
 ", ",
 Cell[BoxData["\"\<ecr\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "0c9a2aa2-6bee-4fba-b008-0015a39a75fc"],
 ", ",
 Cell[BoxData["\"\<swap\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "12f4f626-0008-460a-8857-a2142d2a88a7"],
 ", ",
 Cell[BoxData["\"\<ccx\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "a0fb1f76-498a-4d1b-8ae2-4efeb8715a4b"],
 "); this set can differ between qiskit versions, so the complete, \
version-correct list is qiskit's standard gate-name mapping, obtainable with ",
 Cell[BoxData[
  RowBox[{
   RowBox[{"qiskit", ".", "circuit", ".", "library", ".", "get_standard"}], 
   "_gate", "_name", "_mapping"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "be8380e5-7a06-4980-b966-bda9bfe2990b"],
 " or from qiskit's ",
 ButtonBox["circuit-library documentation",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://docs.quantum.ibm.com/api/qiskit/circuit_library"], None}],
 "."
}], "Notes",ExpressionUUID->"ab1a80f4-b6ec-4588-8309-2b7c617efdc0"],

Cell[TextData[{
 "Every option other than ",
 Cell[BoxData["\"\<Version\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "9c54578e-a5be-4453-b5a9-e21e738d9550"],
 " is forwarded to qiskit's transpiler. Option names are CamelCase and map to \
qiskit's snake_case parameter names (",
 Cell[BoxData["\"\<CouplingMap\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "b9c6db90-077c-4db1-b7a9-46f4f893940f"],
 " to ",
 Cell[BoxData["coupling_map"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "5bcec54f-02ba-49ec-8c65-adad1561c12b"],
 "); the raw snake_case name is accepted too. Any current or future qiskit \
transpile parameter therefore works without a change to ",
 Cell[BoxData["QuantumQASM"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "107f8277-5148-450a-846b-2c2963632054"],
 "."
}], "Notes",ExpressionUUID->"602a02f0-1d37-4b55-af60-9c41db2191a3"],

Cell[TextData[{
 "A ",
 Cell[BoxData["\"\<CouplingMap\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "10cbb8f3-7ed3-4e25-bf61-4dc72e3192ad"],
 " is a list of directed pairs ",
 Cell[BoxData[
  RowBox[{"{", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"c", ",", " ", "t"}], "}"}], ",", " ", "\[Ellipsis]"}], "}"}]], 
  "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "0213213a-1465-422f-a850-c4cdc7b8a7eb"],
 " of physical qubit indices that may interact; two-qubit gates are emitted \
in that calibrated direction."
}], "Notes",ExpressionUUID->"7564a588-9ce2-4c5a-95b9-970e91fea77e"],

Cell[TextData[{
 "A qiskit-free alternative is the pure-Wolfram emitter ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["QuantumCircuitOperator"]], 
    "paclet:Wolfram/QuantumFramework/ref/QuantumCircuitOperator", 
    "Wolfram/QuantumFramework Package Symbol"},
   "PackageLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",ExpressionUUID->
  "10253809-c897-4284-b598-8382dcc00e25"],
 " property ",
 Cell[BoxData["\"\<QASM\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "e8a7f67d-0217-45c6-86fa-d6c9cc69f6f5"],
 ", which emits a generic gate set; ",
 Cell[BoxData["QuantumQASM"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "83d458db-1423-4fca-abcd-9ebaf2286ac7"],
 " instead routes through qiskit and can decompose to a hardware-native basis."
}], "Notes",ExpressionUUID->"57e7bc5e-e3fc-4f54-ba67-e7a887f0cf69"],

Cell[TextData[{
 Cell[BoxData["QuantumQASM"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "049027cf-c59a-4b83-996c-ea4ae7e74494"],
 " builds the qiskit circuit through ",
 Cell[BoxData[
  RowBox[{"qco", "[", "\"\<Qiskit\>\"", "]"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "884c806a-5d45-4bf6-9e46-20e19c29ff58"],
 " and runs the qiskit transpiler in the framework's Python session; the \
qiskit package is installed automatically on first use."
}], "Notes",ExpressionUUID->"589a7a68-6bff-451e-b377-c0aefb1d4f87"],

Cell[TextData[{
 "Given an OpenQASM ",
 StyleBox["source string",
  FontWeight->"Bold"],
 " (one carrying an ",
 Cell[BoxData["OPENQASM"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "b326ad33-08c7-40e6-aca6-3871820edeb2"],
 " header) or a ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["File"]], "paclet:ref/File"},
   "RefLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",ExpressionUUID->
  "31dfc8c3-9f9e-4ad8-a81f-6385ad9847a9"],
 ", ",
 Cell[BoxData["QuantumQASM"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "e111e940-fbc6-4539-8282-8a6607a9d678"],
 " runs in the reverse direction and ",
 StyleBox["imports", "TI"],
 " the program into a ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["QuantumCircuitOperator"]], 
    "paclet:Wolfram/QuantumFramework/ref/QuantumCircuitOperator", 
    "Wolfram/QuantumFramework Package Symbol"},
   "PackageLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",ExpressionUUID->
  "78e79a85-3a27-4988-a82b-d78bc23d99bf"],
 ". Import is a ",
 StyleBox["native Wolfram Language",
  FontWeight->"Bold"],
 " parser with no qiskit or Python dependency, so it works on any \
installation and is unaffected by qiskit version changes. The ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["QuantumCircuitOperator"]], 
    "paclet:Wolfram/QuantumFramework/ref/QuantumCircuitOperator", 
    "Wolfram/QuantumFramework Package Symbol"},
   "PackageLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",ExpressionUUID->
  "cd6862d1-1799-4123-a901-baaa1a1661ae"],
 " constructor accepts the same OpenQASM source or file directly (",
 Cell[BoxData[
  RowBox[{
  "QuantumCircuitOperator", "[", "\"\<OPENQASM 3.0; \[Ellipsis]\>\"", "]"}]], 
  "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "6f6d95e0-8080-46df-be3f-3ec1ac10d7e5"],
 ")."
}], "Notes",ExpressionUUID->"a4876bd5-b83b-41cf-bc8f-bd0a544f3fc8"],

Cell[TextData[{
 "Import covers the circuit-level subset of OpenQASM 2 and 3: the version \
header, ",
 Cell[BoxData["include"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "0a769086-f9b9-459e-b26c-c0f9b6820414"],
 ", ",
 Cell[BoxData["qreg"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "e4f6d407-83e0-415c-8bfc-4d331798aecc"],
 "/",
 Cell[BoxData["creg"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "f6f5d859-7431-44f8-a6cc-1df618c5a987"],
 " and ",
 Cell[BoxData["qubit"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "e0c2c57e-aaca-429f-9d2e-be8531fcaa3f"],
 "/",
 Cell[BoxData["bit"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "d05b7c0e-c3a6-4a52-8190-58270586ec0d"],
 " declarations, standard and parametrized gate calls, custom ",
 Cell[BoxData["gate"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "cf681787-2cfa-41fc-a51e-0e0b73fc4b8f"],
 " definitions (imported as named subcircuits), the ",
 Cell[BoxData["inv"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "f27c0a1d-b7e5-479a-bf5d-e289e4f33b0c"],
 "/",
 Cell[BoxData["pow"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "1c5e758b-4a17-4845-94cb-46a580ac2e13"],
 "/",
 Cell[BoxData["ctrl"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "85c56009-1b68-4f3e-a87a-00728bcd10b7"],
 "/",
 Cell[BoxData["negctrl"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "630367a5-6d2d-4a6c-97b4-771e1663e20b"],
 " gate modifiers, ",
 Cell[BoxData["measure"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "9486051a-905d-4e95-85ad-82b9c5d9b1e4"],
 " (both the v2 ",
 Cell[BoxData[
  RowBox[{
   RowBox[{"measure", " ", "q"}], " ", "->", " ", "c"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "ea3b852b-6b36-4328-8132-26b33938db69"],
 " and v3 ",
 Cell[BoxData[
  RowBox[{"c", " ", "=", " ", 
   RowBox[{"measure", " ", "q"}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "de47907a-2f23-4e71-8cb5-b4c2c27e22e3"],
 " forms), ",
 Cell[BoxData["reset"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "c0de5a3a-0f46-4204-bcc6-33cbe9b5e569"],
 ", ",
 Cell[BoxData["barrier"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "352a93d8-39e9-4f52-9870-c816f5ac0ff2"],
 ", and ",
 Cell[BoxData["gphase"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "71ce5224-a900-4727-9e6f-e75289facbf7"],
 ". A construct outside this subset (classical control flow, ",
 Cell[BoxData["def"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "c144feb2-f63d-4503-a41c-ed575002162d"],
 ", ",
 Cell[BoxData["defcal"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "e3073299-430e-4702-8c29-acbe8c94e386"],
 ", timing, \[Ellipsis]) returns a ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["Failure"]], "paclet:ref/Failure"},
   "RefLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",ExpressionUUID->
  "774964eb-f8eb-40ae-877e-1a86aad0036e"],
 " that names the offending statement, never a partial circuit."
}], "Notes",ExpressionUUID->"adaa0ba4-f3ed-4d87-ad90-bce433ac80df"],

Cell[TextData[{
 "Gate-argument expressions may use arithmetic with ",
 Cell[BoxData["pi"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "6e091a55-86da-4d0d-b352-6e1d6f0f24ba"],
 ", ",
 Cell[BoxData["tau"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "5efb7f55-0f27-40c1-a5b2-6fe503a76e2f"],
 " and ",
 Cell[BoxData["euler"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "f4dd3e3d-1b7c-40a5-b479-5bab4d8775ee"],
 "; any other identifier (including an attempt to smuggle in a Wolfram \
Language function) is refused as a ",
 Cell[BoxData["Failure"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "bdc08a1c-c0fb-4dcd-83c3-30cf33f5175b"],
 " rather than evaluated."
}], "Notes",ExpressionUUID->"a5292bc4-32bc-4e79-a7aa-2dfa3f540f2f"],

Cell[BoxData[GridBox[{
   {Cell["      ", "ModInfo",ExpressionUUID->
     "c0c4ed0a-1dc6-483f-95f3-0c086dcf6fa2"], Cell["Option", "TableText",
     FontWeight->Bold,ExpressionUUID->"48d196d7-d3f3-411f-8d3e-1e2a5c785633"],
     Cell["Default value", "TableText",
     FontWeight->Bold,ExpressionUUID->"6bf53c8f-da99-4a40-ac1b-6521e42a5bda"],
     Cell["Description", "TableText",
     FontWeight->Bold,ExpressionUUID->"2503f80c-5354-4980-8805-43780f74203c"]},
   {Cell["      ", "ModInfo",ExpressionUUID->
     "6bf7640f-1088-491e-834f-8bb94dbb6d89"], Cell[TextData[Cell[
    BoxData["\"\<Version\>\""], "InlineFormula",
     FontSize->0.9 Inherited,ExpressionUUID->
     "0c75201e-fe98-4bce-b7cc-c92596bace5c"]], "TableText",ExpressionUUID->
     "a73ebc60-e1bd-409b-bf39-b2aa1f28bf41"], Cell[
    "3", "TableText",ExpressionUUID->"8c706957-12e8-4ab9-8638-bec33eac3b65"], 
    Cell["the OpenQASM version to emit, 2 or 3", "TableText",ExpressionUUID->
     "a3664193-169c-4028-af39-5a46f6b85cc3"]},
   {Cell["      ", "ModInfo",ExpressionUUID->
     "d346807c-30f9-42d3-8551-fcd323964869"], Cell[TextData[Cell[
    BoxData["\"\<BasisGates\>\""], "InlineFormula",
     FontSize->0.9 Inherited,ExpressionUUID->
     "714d8bdd-ddc2-4953-8773-2814d32ab8a0"]], "TableText",ExpressionUUID->
     "3da78da0-66c3-4471-8b25-b007b1145e22"], Cell[
    "Automatic", "TableText",ExpressionUUID->
     "15f2d21d-85f7-43f4-8e20-a703c0e2f523"], Cell[
    "the native gate set (the same as the second argument)", "TableText",
     ExpressionUUID->"945b35af-7eca-4c58-8502-d35ee4593cc0"]},
   {Cell["      ", "ModInfo",ExpressionUUID->
     "0191134d-e7a0-48a4-b321-00ab85210c43"], Cell[TextData[Cell[
    BoxData["\"\<CouplingMap\>\""], "InlineFormula",
     FontSize->0.9 Inherited,ExpressionUUID->
     "23fe1dd4-f563-42e5-a58f-9f6b669bc247"]], "TableText",ExpressionUUID->
     "c0b00d39-33c2-40d5-aa22-bd2773ecc270"], Cell[
    "Automatic", "TableText",ExpressionUUID->
     "1325a374-fe03-4e16-8cc8-6bb137f61a6f"], Cell[
    "directed pairs of physical qubits that may interact", "TableText",
     ExpressionUUID->"ab5c1e0e-e362-41e0-baf5-8828a18cf0f2"]},
   {Cell["      ", "ModInfo",ExpressionUUID->
     "af64ab3b-4586-4c94-a4e3-65cc9a9d7dba"], Cell[TextData[Cell[
    BoxData["\"\<OptimizationLevel\>\""], "InlineFormula",
     FontSize->0.9 Inherited,ExpressionUUID->
     "713e61b9-a05e-42b1-8139-609a4f932d9d"]], "TableText",ExpressionUUID->
     "c64974da-eef2-4464-a6d7-3f8c4232b66a"], Cell[
    "Automatic", "TableText",ExpressionUUID->
     "19667abf-5c3e-4b94-ac18-fa6602a27011"], Cell[
    "the qiskit optimization level, 0 through 3", "TableText",ExpressionUUID->
     "3f288325-cd20-4c7c-aa78-491179be1668"]},
   {Cell["      ", "ModInfo",ExpressionUUID->
     "69617896-87d6-43a7-a395-6f0e99df238c"], Cell[TextData[Cell[
    BoxData["\"\<Target\>\""], "InlineFormula",
     FontSize->0.9 Inherited,ExpressionUUID->
     "18025384-2333-4c31-b65e-0b5f72f3078b"]], "TableText",ExpressionUUID->
     "4015e9a7-5921-4339-8d9d-40259aee3320"], Cell[
    "None", "TableText",ExpressionUUID->
     "0bb00fd2-aba9-4f1f-b1d6-cd9167b5b0d1"], Cell[TextData[{
     "a ",
     Cell[BoxData[
      TemplateBox[{
        Cell[
         TextData["QiskitTarget"]], 
        "paclet:Wolfram/QuantumFramework/ref/QiskitTarget", 
        "Wolfram/QuantumFramework Package Symbol"},
       "PackageLink",
       BaseStyle->"InlineFormula"]], "InlineFormula",ExpressionUUID->
      "1b55378f-1597-4af8-8c9a-0b6bf0f37f9f"],
     " object or an Association device spec"
    }], "TableText",ExpressionUUID->"0342fbd4-60a2-4114-b1e3-da1d6df98159"]},
   {Cell["      ", "ModInfo",ExpressionUUID->
     "e0be16d5-33fe-4069-85b4-563b05e1467e"], Cell[TextData[Cell[
    BoxData["\"\<Provider\>\""], "InlineFormula",
     FontSize->0.9 Inherited,ExpressionUUID->
     "f8604487-4efc-4539-b663-feec3482b157"]], "TableText",ExpressionUUID->
     "c668c3bc-e239-4e58-b8fc-a655b2864034"], Cell[
    "None", "TableText",ExpressionUUID->
     "f6cb0b3d-6e2f-45de-b050-b977cd64c0b4"], Cell[TextData[{
     "a hardware provider (e.g. ",
     Cell[BoxData["\"\<IBMQ\>\""], "InlineFormula",
      FontSize->0.9 Inherited,ExpressionUUID->
      "b562eecd-8298-4b6b-9165-5a0012a45dae"],
     ", ",
     Cell[BoxData["\"\<AWSBraket\>\""], "InlineFormula",
      FontSize->0.9 Inherited,ExpressionUUID->
      "a29dcff4-a3ae-48da-ae31-3b8c9bed40b5"],
     "); engages the provider export path"
    }], "TableText",ExpressionUUID->"e38beb14-af7e-4a18-88b0-d3509f3f032d"]},
   {Cell["      ", "ModInfo",ExpressionUUID->
     "62acaf23-df61-4fad-ba28-fb78fc6246e7"], Cell[TextData[Cell[
    BoxData["\"\<Backend\>\""], "InlineFormula",
     FontSize->0.9 Inherited,ExpressionUUID->
     "ab7f9d32-7c4f-46a9-957d-8b8d6632df09"]], "TableText",ExpressionUUID->
     "62ad0777-22d2-42c2-9327-bc62ce791cf2"], Cell[
    "Automatic", "TableText",ExpressionUUID->
     "480a1a46-4bb3-426b-b42d-0eceedd102a6"], Cell[TextData[{
     "a specific backend to transpile against (used with ",
     Cell[BoxData["\"\<Provider\>\""], "InlineFormula",
      FontSize->0.9 Inherited,ExpressionUUID->
      "27744cb3-627f-4518-ad8f-b7f84bc0b5ee"],
     ")"
    }], "TableText",ExpressionUUID->"7e50921c-e20c-4c0f-bdd1-bbe7c13ddc23"]}
  }]], "3ColumnTableMod",ExpressionUUID->"38e5d2cc-7a44-428c-a748-\
4a27d94d59e1"],

Cell[TextData[{
 "Any other qiskit ",
 Cell[BoxData["transpile"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "65ec952b-aa96-4ad0-8e4c-e20775b1dc1b"],
 " parameter (for example ",
 Cell[BoxData["\"\<InitialLayout\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "07de2f18-1461-4fb6-baa7-8ef792b5de15"],
 ", ",
 Cell[BoxData["\"\<RoutingMethod\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "2bf19d58-b4b1-413f-a79b-9afb011c9265"],
 ", ",
 Cell[BoxData["\"\<SeedTranspiler\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "640b2c14-8476-49f2-876d-5c6f90b14d45"],
 ") is also accepted."
}], "Notes",ExpressionUUID->"97e55d61-3a88-408a-b0bf-e529944da698"],

Cell[TextData[{
 "The string value of a ",
 StyleBox["method", "TI"],
 " option \[LongDash] ",
 Cell[BoxData["\"\<LayoutMethod\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "95c493b1-ecfc-4d8e-9956-93a9dbfae5fa"],
 ", ",
 Cell[BoxData["\"\<RoutingMethod\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "c41d92a0-2da9-4880-b1ae-f02a75feb8a2"],
 ", ",
 Cell[BoxData["\"\<TranslationMethod\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "982994c5-bd68-40e1-a061-5c0cf4c0fb56"],
 ", ",
 Cell[BoxData["\"\<SchedulingMethod\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "0408b977-f068-4429-aa41-af05097873e2"],
 ", ",
 Cell[BoxData["\"\<InitMethod\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "e6dd1a04-2f7d-4b1f-8ee3-587678763578"],
 ", ",
 Cell[BoxData["\"\<OptimizationMethod\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "1b8b4f36-2927-4142-b8e8-36997ae56a25"],
 ", ",
 Cell[BoxData["\"\<UnitarySynthesisMethod\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "aedd18b4-0bc2-403a-aa4a-90c1854e058c"],
 " \[LongDash] is the name of a qiskit transpiler ",
 StyleBox["stage plugin", "TI"],
 ". These names are defined by the installed qiskit, not by ",
 Cell[BoxData["QuantumQASM"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "777b15cf-0584-4b14-b699-fba571822f30"],
 ", and vary by version; the authoritative list is qiskit's ",
 ButtonBox["transpilation defaults and configuration options",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://quantum.cloud.ibm.com/docs/en/guides/defaults-and-\
configuration-options"], None}],
 " guide, and they can be enumerated from the installed qiskit through ",
 Cell[BoxData[
  RowBox[{
   RowBox[{
   "qiskit", ".", "transpiler", ".", "preset_passmanagers", ".", "plugin", ".",
     "list_stage"}], "_plugins"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "8a5ad571-74d1-483d-8e54-b442d2482492"],
 ". For the qiskit 2.4.1 bundled with the framework the values are:"
}], "Notes",ExpressionUUID->"a065bfe9-1b3e-48ef-9790-af413a767130"],

Cell[BoxData[GridBox[{
   {Cell["      ", "ModInfo",ExpressionUUID->
     "a18a95ec-8f23-4959-90f6-f8ad933aeb47"], Cell[
    "Method option", "TableText",
     FontWeight->Bold,ExpressionUUID->"1704500c-7db6-4e37-962b-8fea7274bcb2"],
     Cell["qiskit 2.4.1 plugin names", "TableText",
     FontWeight->Bold,ExpressionUUID->"8ce9a85c-9935-48f3-a72e-eda858e26e41"]},
   {Cell["      ", "ModInfo",ExpressionUUID->
     "d3307175-d208-412b-bc50-3d20f39a111e"], Cell[TextData[Cell[
    BoxData["\"\<LayoutMethod\>\""], "InlineFormula",
     FontSize->0.9 Inherited,ExpressionUUID->
     "8d057ec4-b5f4-4b37-a427-551150364cdb"]], "TableText",ExpressionUUID->
     "fa8b1c2f-dab5-4847-a573-6c983f6eec15"], Cell[TextData[{
     Cell[BoxData["\"\<trivial\>\""], "InlineFormula",
      FontSize->0.9 Inherited,ExpressionUUID->
      "6ee3589c-9479-4906-8319-45fa90a6b22d"],
     ", ",
     Cell[BoxData["\"\<dense\>\""], "InlineFormula",
      FontSize->0.9 Inherited,ExpressionUUID->
      "05e8bde6-c8d4-41ad-890f-b8b40d62155f"],
     ", ",
     Cell[BoxData["\"\<sabre\>\""], "InlineFormula",
      FontSize->0.9 Inherited,ExpressionUUID->
      "7fa555d1-edf6-47f5-914f-f1c31c7510ee"],
     ", ",
     Cell[BoxData["\"\<default\>\""], "InlineFormula",
      FontSize->0.9 Inherited,ExpressionUUID->
      "dcd3f310-800c-4c8b-a68f-6013732497fb"]
    }], "TableText",ExpressionUUID->"0766d664-d5ed-47a8-a3d1-9ec4132b0e1a"]},
   {Cell["      ", "ModInfo",ExpressionUUID->
     "3ca1212c-1535-4b8b-93b5-5daaf9a54b4b"], Cell[TextData[Cell[
    BoxData["\"\<RoutingMethod\>\""], "InlineFormula",
     FontSize->0.9 Inherited,ExpressionUUID->
     "be0e3a1b-d629-4154-b500-d58d9e1b0cbb"]], "TableText",ExpressionUUID->
     "7f272231-8e86-4030-93a6-70d8df38ce64"], Cell[TextData[{
     Cell[BoxData["\"\<basic\>\""], "InlineFormula",
      FontSize->0.9 Inherited,ExpressionUUID->
      "27501522-9e6d-4a9d-9497-af537fd668fb"],
     ", ",
     Cell[BoxData["\"\<lookahead\>\""], "InlineFormula",
      FontSize->0.9 Inherited,ExpressionUUID->
      "46cc5f7d-951b-4a23-a744-1039249f0687"],
     ", ",
