Cell["The target can also be given inline as an Association:", "ExampleText",ExpressionUUID->"f042e179-6caa-445c-b14b-f0cfac22e70f"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"QuantumQASM", "[", 
  RowBox[{
   RowBox[{"QuantumCircuitOperator", "[", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"\"\<H\>\"", " ", "->", " ", "1"}], ",", " ", 
      RowBox[{"\"\<CNOT\>\"", " ", "->", " ", 
       RowBox[{"{", 
        RowBox[{"1", ",", " ", "2"}], "}"}]}], ",", " ", 
      RowBox[{"{", "1", "}"}], ",", " ", 
      RowBox[{"{", "2", "}"}]}], "}"}], "]"}], ",", " ", 
   RowBox[{"\"\<Target\>\"", " ", "->", " ", 
    RowBox[{"<|", 
     RowBox[{
      RowBox[{"\"\<BasisGates\>\"", " ", "->", " ", 
       RowBox[{"{", 
        RowBox[{"\"\<x\>\"", ",", " ", "\"\<sx\>\"", ",", " ", "\"\<rz\>\"", ",",
          " ", "\"\<cz\>\""}], "}"}]}], ",", " ", 
      RowBox[{"\"\<NumQubits\>\"", " ", "->", " ", "4"}], ",", " ", 
      RowBox[{"\"\<CouplingMap\>\"", " ", "->", " ", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"1", ",", " ", "0"}], "}"}], ",", " ", 
         RowBox[{"{", 
          RowBox[{"1", ",", " ", "3"}], "}"}], ",", " ", 
         RowBox[{"{", 
          RowBox[{"2", ",", " ", "0"}], "}"}], ",", " ", 
         RowBox[{"{", 
          RowBox[{"2", ",", " ", "3"}], "}"}]}], "}"}]}]}], "|>"}]}]}], 
  "]"}]], "Input",
 CellLabel->"In[1]:=",ExpressionUUID->"e6bbd0db-3007-4a99-bdef-6e139195b521"],

Cell[BoxData["\<\"OPENQASM 3.0;\\ninclude \\\"stdgates.inc\\\";\\nbit[2] \
c;\\nrz(pi/2) $0;\\nsx $0;\\nrz(pi/2) $0;\\nrz(pi/2) $1;\\nsx $1;\\nrz(pi) \
$1;\\ncz $1, $0;\\nsx $1;\\nrz(pi/2) $1;\\nc[0] = measure $0;\\nc[1] = \
measure $1;\\n\"\>"], "Output",
 CellChangeTimes->{3.989680576255962*^9},
 CellLabel->"Out[1]=",
