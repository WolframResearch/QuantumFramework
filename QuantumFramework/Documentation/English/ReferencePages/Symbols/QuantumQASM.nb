Cell[BoxData[
 RowBox[{"QuantumQASM", "[", 
  RowBox[{
   RowBox[{"QuantumCircuitOperator", "[", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"\"\<H\>\"", " ", "->", " ", "1"}], ",", " ", 
      RowBox[{"\"\<CNOT\>\"", " ", "->", " ", 
       RowBox[{"{", 
        RowBox[{"1", ",", " ", "2"}], "}"}]}], ",", " ", 
      RowBox[{"{", "1", "}"}], ",", " ", 
      RowBox[{"{", "2", "}"}]}], "}"}], "]"}], ",", " ", 
   RowBox[{"{", 
    RowBox[{"\"\<x\>\"", ",", " ", "\"\<sx\>\"", ",", " ", "\"\<rz\>\"", ",", 
     " ", "\"\<cz\>\""}], "}"}], ",", " ", 
   RowBox[{"\"\<BasisGates\>\"", " ", "->", " ", 
    RowBox[{"{", "\"\<x\>\"", "}"}]}]}], "]"}]], "Input",
