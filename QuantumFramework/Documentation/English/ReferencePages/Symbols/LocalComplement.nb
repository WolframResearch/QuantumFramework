 CellID->661147381,ExpressionUUID->"300bb8bc-8c22-495c-a8ab-8c70a0178b24"],

Cell["\<\
At the middle of a path graph, local complementation closes the path's outer \
arms into a triangle:\
\>", "ExampleText",
 CellID->666944493,ExpressionUUID->"84f61730-3dd7-439a-b186-6e513ffd558d"],

Cell[BoxData[
 RowBox[{"Module", "[", 
  RowBox[{
   RowBox[{"{", "p3", "}"}], ",", " ", 
   RowBox[{
    RowBox[{"p3", " ", "=", " ", 
     RowBox[{"PathGraph", "[", 
      RowBox[{"{", 
       RowBox[{"1", ",", " ", "2", ",", " ", "3"}], "}"}], "]"}]}], ";", " ", 
    
    RowBox[{"LocalComplement", "[", 
     RowBox[{"p3", ",", " ", "2"}], "]"}]}]}], "]"}]], "Input",
 CellLabel->"In[3]:=",
 CellID->675360451,ExpressionUUID->"8be08b63-9a8e-4575-94dd-cd6a81c43f72"],

Cell[BoxData[
 GraphicsBox[
  NamespaceBox["NetworkGraphics",
   DynamicModuleBox[{Typeset`graph = HoldComplete[
     Graph[{1, 2, 3}, {Null, {{1, 2}, {2, 3}, {1, 3}}}]]}, 
    TagBox[
