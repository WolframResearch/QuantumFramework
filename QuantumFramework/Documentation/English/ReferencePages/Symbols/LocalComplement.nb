     RowBox[{"GraphState", "[", 
      RowBox[{"CycleGraph", "[", "4", "]"}], "]"}]}], ";", " ", 
    RowBox[{"lc", " ", "=", " ", 
     RowBox[{"LocalComplement", "[", 
      RowBox[{"gs", ",", " ", "1"}], "]"}]}], ";", " ", 
    RowBox[{"{", 
     RowBox[{
