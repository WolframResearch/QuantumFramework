 CellLabel->"Out[1]=",
 CellID->179738018,ExpressionUUID->"082db715-bba6-4f04-964e-8c3a7896d219"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Reducing a graph state to a canonical form", "ExampleSubsection",
 CellID->662884806,ExpressionUUID->"ce5a4d38-a062-409d-82b7-c5ec52000518"],

Cell["\<\
Iteratively local-complement at the vertex that decreases the edge count, \
terminating in a sparse representative:\
\>", "ExampleText",
 CellID->42508230,ExpressionUUID->"8d5a9544-3853-408c-9510-ffdaf1541d62"],

Cell[BoxData[
 RowBox[{"Module", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"g", ",", " ", "reduce", ",", " ", "history"}], "}"}], ",", " ", 
   RowBox[{
    RowBox[{"g", " ", "=", " ", 
     RowBox[{"CompleteGraph", "[", "4", "]"}]}], ";", " ", 
    RowBox[{
     RowBox[{"reduce", "[", "gr_", "]"}], " ", ":=", " ", 
     RowBox[{"Module", "[", 
      RowBox[{
       RowBox[{"{", "cands", "}"}], ",", " ", 
       RowBox[{
        RowBox[{"cands", " ", "=", " ", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{
            RowBox[{"LocalComplement", "[", 
             RowBox[{"gr", ",", " ", "#1"}], "]"}], " ", "&"}], " ", ")"}], 
          " ", "/@", " ", 
          RowBox[{"VertexList", "[", "gr", "]"}]}]}], ";", " ", 
        RowBox[{"First", "[", 
         RowBox[{"SortBy", "[", 
          RowBox[{
           RowBox[{"Append", "[", 
            RowBox[{"cands", ",", " ", "gr"}], "]"}], ",", " ", "EdgeCount"}],
           "]"}], "]"}]}]}], "]"}]}], ";", " ", 
    RowBox[{"history", " ", "=", " ", 
     RowBox[{"NestList", "[", 
      RowBox[{"reduce", ",", " ", "g", ",", " ", "4"}], "]"}]}], ";", " ", 
