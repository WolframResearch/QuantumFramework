 GraphicsBox[
  NamespaceBox["NetworkGraphics",
   DynamicModuleBox[{Typeset`graph = HoldComplete[
     Graph[{1, 2, 3}, {}]]}, 
    TagBox[
     GraphicsGroupBox[
      GraphicsComplexBox[{{0.00001, -0.00001}, {
       0.00001, -0.000030000000000000004`}, {
       0.000030000000000000004`, -0.00001}}, {{}, 
