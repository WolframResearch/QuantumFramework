Cell[CellGroupData[{

Cell["Round-trip Graph -> GraphState -> PauliStabilizer", "ExampleSubsection",
 CellID->871157962,ExpressionUUID->"fc6a899c-36ed-4fa7-8d40-4877395617bb"],

Cell["\<\
Building a GraphState then converting to PauliStabilizer recovers the \
canonical graph-form stabilizer rows:\
\>", "ExampleText",
 CellID->741747437,ExpressionUUID->"7b4cf006-f36d-4b94-9e47-fc44e12fc690"],

Cell[BoxData[
 RowBox[{"Module", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"gs", ",", " ", "ps"}], "}"}], ",", " ", 
   RowBox[{
    RowBox[{"gs", " ", "=", " ", 
     RowBox[{"GraphState", "[", 
      RowBox[{"CycleGraph", "[", "3", "]"}], "]"}]}], ";", " ", 
    RowBox[{"ps", " ", "=", " ", 
     RowBox[{"gs", "[", "\"\<PauliStabilizer\>\"", "]"}]}], ";", " ", 
    RowBox[{"ps", "[", "\"\<Stabilizers\>\"", "]"}]}]}], "]"}]], "Input",
 CellLabel->"In[1]:=",
 CellID->680589203,ExpressionUUID->"14f83f00-72cf-46f8-862a-55a5653e6d53"],

Cell[BoxData[
 RowBox[{"{", 
