Notebook[{Cell[CellGroupData[{Cell["QiskitCircuit", "ObjectName", 
      CellID -> 1224892054, ExpressionUUID -> 
       "8393d601-4014-44ba-afc9-60862df940ec"], 
     Cell[TextData[{Cell["   ", "ModInfo", ExpressionUUID -> 
          "b2ec60a3-97d4-4cc2-b6e1-85326aad798e"], 
        Cell[BoxData[RowBox[{ButtonBox["QiskitCircuit", BaseStyle -> "Link", 
             ButtonData -> 
              "paclet:Wolfram/QuantumFramework/ref/QiskitCircuit"], "[", 
            StyleBox["qco", "TI"], "]"}]], "InlineFormula", 
         ExpressionUUID -> "aa687bd0-1647-4f81-b6c0-684b9c9898ff"], " ", 
        "builds a qiskit circuit from the ", 
        Cell[BoxData[ButtonBox["QuantumCircuitOperator", BaseStyle -> "Link", 
           ButtonData -> 
            "paclet:Wolfram/QuantumFramework/ref/QuantumCircuitOperator"]], 
         "InlineFormula", ExpressionUUID -> 
          "eacb4287-3b24-422a-821d-1a279b7fa7eb"], " ", 
        StyleBox["qco", "TI"], ".", "\n", Cell["   ", "ModInfo", 
         ExpressionUUID -> "41365396-2739-47f2-ad7c-ccf54432037f"], 
        Cell[BoxData[RowBox[{ButtonBox["QiskitCircuit", BaseStyle -> "Link", 
             ButtonData -> 
              "paclet:Wolfram/QuantumFramework/ref/QiskitCircuit"], "[", 
            "\"\!\(\*StyleBox[\"qasm\", \"TI\"]\)\"", "]"}]], 
         "InlineFormula", ExpressionUUID -> 
          "ea050d50-ead9-49fa-963c-47724e29eee7"], " ", 
        "builds a qiskit circuit from OpenQASM source ", 
        StyleBox["qasm", "TI"], ".", "\n", Cell["   ", "ModInfo", 
         ExpressionUUID -> "76a3e4bb-50e8-4af9-a6a1-7a0cc57afbef"], 
        Cell[BoxData[RowBox[{StyleBox["qkc", "TI"], "[", 
            "\"\!\(\*StyleBox[\"prop\", \"TI\"]\)\"", "]"}]], 
         "InlineFormula", ExpressionUUID -> 
          "bb9d774e-4528-4e89-862f-9b845bef92f3"], " ", 
        "gives the property ", StyleBox["prop", "TI"], " of a ", 
        Cell[BoxData["QiskitCircuit"], "InlineFormula", 
         ExpressionUUID -> "69fab572-a68d-410b-a125-51ee116899bd"], 
        " object ", StyleBox["qkc", "TI"], ".", "\n", Cell["   ", "ModInfo", 
         ExpressionUUID -> "8810a5b0-4786-4256-9091-8596cd5a072c"], 
        Cell[BoxData[RowBox[{StyleBox["qkc", "TI"], "[", "]"}]], 
         "InlineFormula", ExpressionUUID -> 
          "22f9c283-ae5d-4546-8382-58a7569815ad"], " ", "runs ", 
        StyleBox["qkc", "TI"], " on a simulator or backend, and ", 
        Cell[BoxData[RowBox[{StyleBox["qkc", "TI"], "[", StyleBox["state", 
             "TI"], "]"}]], "InlineFormula", ExpressionUUID -> 
          "abc4e614-18bb-4a09-99be-9592844d7d86"], 
        " runs it on the initial ", Cell[BoxData[ButtonBox["QuantumState", 
           BaseStyle -> "Link", ButtonData -> 
            "paclet:Wolfram/QuantumFramework/ref/QuantumState"]], 
         "InlineFormula", ExpressionUUID -> 
          "0a69ca2b-51a7-401f-b556-4d4990b4dc07"], " ", 
        StyleBox["state", "TI"], "."}], "Usage", ExpressionUUID -> 
       "93c79552-2490-4811-a32f-0f14754aed50"], 
     Cell[TextData[{"A ", Cell[BoxData["QiskitCircuit"], "InlineFormula", 
         ExpressionUUID -> "d9f35603-7bc3-477c-ab5c-38d218abeb13"], 
        " is the bridge between ", Cell[BoxData["QuantumFramework"], 
         "InlineFormula", ExpressionUUID -> 
          "ae9d112a-0192-4fcc-9209-bab74bb02cbe"], 
        " and qiskit: it wraps a pickled qiskit ", 
        Cell[BoxData["QuantumCircuit"], "InlineFormula", 
         ExpressionUUID -> "019dc007-0ee6-433f-b34a-41ac2331ab04"], " as a ", 
        Cell[BoxData[ButtonBox["ByteArray", BaseStyle -> "Link", 
           ButtonData -> "paclet:ref/ByteArray"]], "InlineFormula", 
         ExpressionUUID -> "1d940d72-31e9-4322-97d2-5adab5c322b1"], 
        " and exposes it through a property interface."}], "Notes", 
      ExpressionUUID -> "7f85ce52-2d55-49bd-ac18-50b51da52a60"], 
     Cell[TextData[{"A ", Cell[BoxData["QiskitCircuit"], "InlineFormula", 
         ExpressionUUID -> "45b95f9b-f101-4d56-a932-3dedad91cbde"], 
        " is produced by ", Cell[BoxData[ButtonBox["QuantumCircuitOperator", 
           BaseStyle -> "Link", ButtonData -> 
            "paclet:Wolfram/QuantumFramework/ref/QuantumCircuitOperator"]], 
         "InlineFormula", ExpressionUUID -> 
          "c201fffc-fe0e-4397-9364-065441044fbc"], "'s ", 
        Cell[BoxData["\"Qiskit\""], "InlineFormula", ExpressionUUID -> 
          "28e49584-76c7-4d90-9470-a40747897c1d"], " property, by ", 
        Cell[BoxData[ButtonBox["QuantumQASM", BaseStyle -> "Link", 
           ButtonData -> "paclet:Wolfram/QuantumFramework/ref/QuantumQASM"]], 
         "InlineFormula", ExpressionUUID -> 
          "ad520883-a528-4b3e-badc-3d2dae396853"], 
        " import, and by the transform properties below; ", 
        Cell[BoxData[RowBox[{ButtonBox["QuantumCircuitOperator", 
             BaseStyle -> "Link", ButtonData -> 
              "paclet:Wolfram/QuantumFramework/ref/QuantumCircuitOperator"], 
            "[", StyleBox["qkc", "TI"], "]"}]], "InlineFormula", 
         ExpressionUUID -> "f2a01c44-3ab2-424b-9cea-bd6f7a60421d"], 
        " converts one back to a ", 
        Cell[BoxData[ButtonBox["QuantumCircuitOperator", BaseStyle -> "Link", 
           ButtonData -> 
            "paclet:Wolfram/QuantumFramework/ref/QuantumCircuitOperator"]], 
         "InlineFormula", ExpressionUUID -> 
          "1b6f7f30-4190-4f94-a453-5e9538bbbf4d"], "."}], "Notes", 
      ExpressionUUID -> "4a74137c-2344-4af9-b334-2b1050b57e8d"], 
     Cell[TextData[{Cell[BoxData[RowBox[{ButtonBox["QiskitCircuit", 
             BaseStyle -> "Link", ButtonData -> 
              "paclet:Wolfram/QuantumFramework/ref/QiskitCircuit"], "[", 
            "\"\!\(\*StyleBox[\"qasm\", \"TI\"]\)\"", "]"}]], 
         "InlineFormula", ExpressionUUID -> 
          "0dca006b-fb39-406e-ac41-18059c58ae28"], 
        " accepts OpenQASM 2.0 or 3.0 source: the source is read with ", 
        Cell[BoxData[ButtonBox["QuantumCircuitOperator", BaseStyle -> "Link", 
           ButtonData -> 
            "paclet:Wolfram/QuantumFramework/ref/QuantumCircuitOperator"]], 
         "InlineFormula", ExpressionUUID -> 
          "7024b54b-02c0-45a4-8bf6-73b92bbb1130"], 
        " and re-emitted to qiskit, so it is equivalent to ", 
        Cell[BoxData[RowBox[{RowBox[{"QuantumCircuitOperator", "[", 
              "\"\!\(\*StyleBox[\"qasm\", \"TI\"]\)\"", "]"}], "[", 
            "\"Qiskit\"", "]"}]], "InlineFormula", ExpressionUUID -> 
          "6b2a4a3c-a955-4529-a326-54e37631b6f7"], 
        ". A string that is not OpenQASM gives a ", 
        Cell[BoxData[ButtonBox["Failure", BaseStyle -> "Link", 
           ButtonData -> "paclet:ref/Failure"]], "InlineFormula", 
         ExpressionUUID -> "a88eb50c-cf24-4bc7-88e4-d15148b38ddc"], 
        " (see Possible Issues)."}], "Notes", ExpressionUUID -> 
       "df6fda9f-5e5a-42ab-b917-b2ea7abd3024"], 
     Cell[TextData[{"Property evaluation runs in the framework's qiskit \
Python session, which is set up automatically. The hardware-facing properties \
", Cell[BoxData["\"Transpile\""], "InlineFormula", ExpressionUUID -> 
          "051ebba5-aa55-4fdd-bf51-9f66ae9dfedd"], ", ", 
        Cell[BoxData["\"Layout\""], "InlineFormula", ExpressionUUID -> 
          "9bcef122-7e31-4ce6-ba42-942c461a6586"], ", ", 
        Cell[BoxData["\"Validate\""], "InlineFormula", ExpressionUUID -> 
          "726f9046-0ae2-42b1-abdf-337ccff2d726"], ", ", 
        Cell[BoxData["\"QPY\""], "InlineFormula", ExpressionUUID -> 
          "42c13dc9-a2fc-4024-97da-33923c4ed59b"], ", and running ", 
        StyleBox["qkc", "TI"], " on a provider additionally need that \
provider configured (an IBM or AWS account); the default for ", 
        Cell[BoxData[RowBox[{"qkc", "[", "]"}]], "InlineFormula", 
         ExpressionUUID -> "c0ee0880-da37-4127-9c4f-c789b6f10827"], 
        " is a local Aer simulator."}], "Notes", ExpressionUUID -> 
       "a9c3324f-4dff-4160-ad34-7f96f980eed0"], 
     Cell[TextData[{"A ", Cell[BoxData["QiskitCircuit"], "InlineFormula", 
         ExpressionUUID -> "169e4c60-c453-4a25-8256-486c0d60eeda"], " \
displays as a summary panel showing its qubit count, depth, and gate counts."}\
], "Notes", ExpressionUUID -> "9edf5794-b003-4d00-b4db-ec0a3a96791a"], 
