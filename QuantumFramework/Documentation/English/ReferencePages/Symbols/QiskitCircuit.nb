Cell[CellGroupData[{
Cell["QiskitCircuit", "ObjectName", 
      CellID -> 1224892054, ExpressionUUID -> 
       "8393d601-4014-44ba-afc9-60862df940ec"],

Cell[TextData[{Cell["   ", "ModInfo", ExpressionUUID -> 
          "884cc084-2566-4a21-9548-383f0bb7555d"], 
        Cell[BoxData[RowBox[{ButtonBox["QiskitCircuit", BaseStyle -> "Link", 
             ButtonData -> 
              "paclet:Wolfram/QuantumFramework/ref/QiskitCircuit"], "[", 
            StyleBox["qco", "TI"], "]"}]], "InlineFormula", 
         ExpressionUUID -> "c93b8240-6c1f-4f83-b68e-67a12c37a939"], " ", 
        "builds a qiskit circuit from the ", 
        Cell[BoxData[ButtonBox["QuantumCircuitOperator", BaseStyle -> "Link", 
           ButtonData -> 
            "paclet:Wolfram/QuantumFramework/ref/QuantumCircuitOperator"]], 
         "InlineFormula", ExpressionUUID -> 
          "86fb78dd-d8ce-412d-9b21-c79638c4373c"], " ", 
        StyleBox["qco", "TI"], ".", "\n", Cell["   ", "ModInfo", 
         ExpressionUUID -> "c2af5749-82ff-4373-ae55-f2e427361462"], 
        Cell[BoxData[RowBox[{ButtonBox["QiskitCircuit", BaseStyle -> "Link", 
             ButtonData -> 
              "paclet:Wolfram/QuantumFramework/ref/QiskitCircuit"], "[", 
            "\"\!\(\*StyleBox[\"qasm\", \"TI\"]\)\"", "]"}]], 
         "InlineFormula", ExpressionUUID -> 
          "02788fbf-575f-4746-9b5e-4367ef623ac8"], " ", 
        "builds a qiskit circuit from OpenQASM source ", 
        StyleBox["qasm", "TI"], "."}], "Usage", ExpressionUUID -> 
       "e1cf455a-dec4-4725-9806-b23d67677c05"],

Cell[TextData[{"A ", Cell[BoxData["QiskitCircuit"], "InlineFormula", 
         ExpressionUUID -> "c9295b69-a39b-4fe6-b9ae-03d35937550b"], 
        " is the bridge between ", Cell[BoxData["QuantumFramework"], 
         "InlineFormula", ExpressionUUID -> 
          "7039d4a1-a87a-43ac-874c-1147f3ace323"], 
        " and qiskit: it wraps a pickled qiskit ", 
        Cell[BoxData["QuantumCircuit"], "InlineFormula", 
         ExpressionUUID -> "1cf2a1cc-255a-4592-8ceb-572e18633c0b"], " as a ", 
        Cell[BoxData[ButtonBox["ByteArray", BaseStyle -> "Link", 
           ButtonData -> "paclet:ref/ByteArray"]], "InlineFormula", 
         ExpressionUUID -> "9df40af7-acd2-42fe-a938-032d0adf508d"], 
        " and exposes it through a property interface."}], "Notes", 
      ExpressionUUID -> "a5660f32-504c-470e-9452-35174c54725a"],

Cell[TextData[{"A ", Cell[BoxData["QiskitCircuit"], "InlineFormula", 
         ExpressionUUID -> "a575553b-3f48-47cc-bfc7-b74b253ead01"], 
        " is produced by ", Cell[BoxData[ButtonBox["QuantumCircuitOperator", 
           BaseStyle -> "Link", ButtonData -> 
            "paclet:Wolfram/QuantumFramework/ref/QuantumCircuitOperator"]], 
         "InlineFormula", ExpressionUUID -> 
          "f58f4419-854e-4755-9ce3-8c3ba730a3dc"], "'s ", 
        Cell[BoxData["\"Qiskit\""], "InlineFormula", ExpressionUUID -> 
          "84782c85-0a70-4bec-a98f-002187e71099"], " property, by ", 
        Cell[BoxData[ButtonBox["QuantumQASM", BaseStyle -> "Link", 
           ButtonData -> "paclet:Wolfram/QuantumFramework/ref/QuantumQASM"]], 
         "InlineFormula", ExpressionUUID -> 
          "90338dc8-bb03-4371-a9a5-9a2ac6e8b933"], 
        " import, and by the transform properties below; ", 
        Cell[BoxData[RowBox[{ButtonBox["QuantumCircuitOperator", 
             BaseStyle -> "Link", ButtonData -> 
              "paclet:Wolfram/QuantumFramework/ref/QuantumCircuitOperator"], 
            "[", StyleBox["qkc", "TI"], "]"}]], "InlineFormula", 
         ExpressionUUID -> "cbd3a396-70df-40f4-a96e-366cb4719283"], 
        " converts one back to a ", 
        Cell[BoxData[ButtonBox["QuantumCircuitOperator", BaseStyle -> "Link", 
           ButtonData -> 
            "paclet:Wolfram/QuantumFramework/ref/QuantumCircuitOperator"]], 
         "InlineFormula", ExpressionUUID -> 
          "e1e3b1f8-b076-49c3-b563-c83e8b9dc654"], "."}], "Notes", 
      ExpressionUUID -> "c6f024cd-6ef5-4952-901d-724d48ba4fc2"],

Cell[TextData[{Cell[BoxData[RowBox[{ButtonBox["QiskitCircuit", 
             BaseStyle -> "Link", ButtonData -> 
              "paclet:Wolfram/QuantumFramework/ref/QiskitCircuit"], "[", 
            "\"\!\(\*StyleBox[\"qasm\", \"TI\"]\)\"", "]"}]], 
         "InlineFormula", ExpressionUUID -> 
          "7794d1f9-9755-452e-b78f-b7b50f118afb"], 
        " accepts OpenQASM 2.0 or 3.0 source: the source is read with ", 
        Cell[BoxData[ButtonBox["QuantumCircuitOperator", BaseStyle -> "Link", 
           ButtonData -> 
            "paclet:Wolfram/QuantumFramework/ref/QuantumCircuitOperator"]], 
         "InlineFormula", ExpressionUUID -> 
          "ff5397ec-6336-411d-b1df-236da565538b"], 
        " and re-emitted to qiskit, so it is equivalent to ", 
        Cell[BoxData[RowBox[{RowBox[{"QuantumCircuitOperator", "[", 
              "\"\!\(\*StyleBox[\"qasm\", \"TI\"]\)\"", "]"}], "[", 
            "\"Qiskit\"", "]"}]], "InlineFormula", ExpressionUUID -> 
          "7089f3c8-0eeb-41c8-963d-9ec0534f50bb"], 
        ". A string that is not OpenQASM gives a ", 
        Cell[BoxData[ButtonBox["Failure", BaseStyle -> "Link", 
           ButtonData -> "paclet:ref/Failure"]], "InlineFormula", 
         ExpressionUUID -> "1739ab2d-6c1c-4466-9554-7cc708b3c34f"], 
        " (see Possible Issues)."}], "Notes", ExpressionUUID -> 
       "a853b5bf-3933-4e95-8bce-1ebb0f4337b7"],

Cell[TextData[{"Applying a ", Cell[BoxData["QiskitCircuit"], 
         "InlineFormula", ExpressionUUID -> 
          "bbb5dde9-a10a-4d4b-a654-1b284b08bc1e"], " ", 
        StyleBox["qkc", "TI"], " runs the circuit: ", 
        Cell[BoxData[RowBox[{StyleBox["qkc", "TI"], "[", "]"}]], 
         "InlineFormula", ExpressionUUID -> 
          "7e5c01a3-17b3-46e3-9381-b1904d0d0b25"], 
        " simulates it and gives a ", Cell[BoxData[ButtonBox["QuantumState", 
           BaseStyle -> "Link", ButtonData -> 
            "paclet:Wolfram/QuantumFramework/ref/QuantumState"]], 
         "InlineFormula", ExpressionUUID -> 
          "9ab0c388-254a-4fa8-a538-9fdf32c7660f"], ", and ", 
        Cell[BoxData[RowBox[{StyleBox["qkc", "TI"], "[", StyleBox["state", 
             "TI"], "]"}]], "InlineFormula", ExpressionUUID -> 
          "601d31bf-9676-4740-af9e-c165939e5915"], " runs it on an initial ", 
        Cell[BoxData[ButtonBox["QuantumState", BaseStyle -> "Link", 
           ButtonData -> 
            "paclet:Wolfram/QuantumFramework/ref/QuantumState"]], 
         "InlineFormula", ExpressionUUID -> 
          "ec795f83-8050-4368-b482-1b35594ef257"], " ", 
        StyleBox["state", "TI"], ". Options include ", 
        Cell[BoxData["\"Shots\""], "InlineFormula", ExpressionUUID -> 
          "e1d2f0d0-95c6-4543-9d69-92c0d89e2391"], ", ", 
        Cell[BoxData["\"Provider\""], "InlineFormula", ExpressionUUID -> 
          "7fc41a29-3981-4ae5-883a-80e2097c4a10"], " and ", 
        Cell[BoxData["\"Backend\""], "InlineFormula", ExpressionUUID -> 
          "3d999c9d-1ca3-4c66-92e9-9ce2b71ae767"], "."}], "Notes", 
      ExpressionUUID -> "03c946f6-4b6e-46b4-839d-3ea6e7e72264"],

Cell[TextData[{"A ", Cell[BoxData["QiskitCircuit"], "InlineFormula", 
         ExpressionUUID -> "3dfd0350-dc32-47d1-9b1b-1a1982cc7a1c"], " ", 
        StyleBox["qkc", "TI"], " gives a property with ", 
        Cell[BoxData[RowBox[{StyleBox["qkc", "TI"], "[", 
            "\"\!\(\*StyleBox[\"prop\", \"TI\"]\)\"", "]"}]], 
         "InlineFormula", ExpressionUUID -> 
          "8cbbc1ac-1a8f-47e9-afcd-3ebfe3a49bee"], 
        ", with the properties in the table below."}], "Notes", 
      ExpressionUUID -> "6da1c173-dd6a-4d3d-819e-2f4b47735fa6"],

Cell[TextData[{"Property evaluation runs in the framework's qiskit \
Python session, which is set up automatically. The hardware-facing properties \
", Cell[BoxData["\"Transpile\""], "InlineFormula", ExpressionUUID -> 
          "cff3f7a3-1459-4fa7-8731-601430e8f363"], ", ", 
        Cell[BoxData["\"Layout\""], "InlineFormula", ExpressionUUID -> 
          "7e05d7ad-c02d-4862-8f8e-9651ba49f00b"], ", ", 
        Cell[BoxData["\"Validate\""], "InlineFormula", ExpressionUUID -> 
          "cdd4f5fe-3e2e-4c89-9870-240f7c2437c5"], ", ", 
        Cell[BoxData["\"QPY\""], "InlineFormula", ExpressionUUID -> 
          "d3f4c536-4449-4a3c-9698-c93cc99b02d5"], ", and running ", 
        StyleBox["qkc", "TI"], " on a provider additionally need that \
provider configured (an IBM or AWS account); the default for ", 
        Cell[BoxData[RowBox[{"qkc", "[", "]"}]], "InlineFormula", 
         ExpressionUUID -> "b1b1d2cd-13ae-4028-8996-09ecdff70cec"], 
        " is a local Aer simulator."}], "Notes", ExpressionUUID -> 
       "0e5bab57-8364-4edc-9895-d61bcfc19d24"],

Cell[TextData[{"A ", Cell[BoxData["QiskitCircuit"], "InlineFormula", 
         ExpressionUUID -> "a9d1c61c-b9a4-40b5-87d4-04b03fca1d8e"], " \
displays as a summary panel showing its qubit count, depth, and gate counts."}\
], "Notes", ExpressionUUID -> "3b412fdf-b667-4ed9-ad00-4be52d595f4a"],

