   {Cell["      ", "ModInfo",ExpressionUUID->
     "cdc1a63a-a644-45c7-b9f5-66bdc6600bd5"], Cell[TextData[Cell[
    BoxData["\"\<TensorNetworkGraph\>\""], "InlineFormula",ExpressionUUID->
     "42d88a25-4ae9-4d5e-b18e-e745ba56ca92"]], "TableText",ExpressionUUID->
     "9ac0e9e2-5c35-4001-88fd-8fd5871ad171"], Cell[
    "the graph of the circuit's tensor network", "TableText",ExpressionUUID->
     "f3903e6e-5d42-4657-9bff-a1dc92f9e3ac"]},
   {Cell["      ", "ModInfo",ExpressionUUID->
     "c24899bb-0171-431c-ab41-7318a7af2ca7"], Cell[TextData[Cell[
