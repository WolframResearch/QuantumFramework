}, Open  ]],

Cell[TextData[{
 "Bob assigns the bit 0 whenever he gets ",
 Cell[BoxData[
  RowBox[{"|", 
   SubscriptBox[
    StyleBox["z", "TI"], "+"], "\[RightAngleBracket]"}]], "InlineFormula",
  ExpressionUUID->"392716da-1a88-4bae-be57-be3f05fcfea0"],
 " or ",
 Cell[BoxData[
  RowBox[{"|", 
   SubscriptBox[
    StyleBox["x", "TI"], "+"], "\[RightAngleBracket]"}]], "InlineFormula",
  ExpressionUUID->"ea4d287a-6cb3-4fea-aaaf-a1ca2a905cd4"],
 ", and the bit 1 for ",
 Cell[BoxData[
  RowBox[{"|", 
   SubscriptBox[
    StyleBox["z", "TI"], "-"], "\[RightAngleBracket]"}]], "InlineFormula",
  ExpressionUUID->"111297e7-2d27-43c5-a064-49ff67826377"],
 " or ",
 Cell[BoxData[
  RowBox[{"|", 
   SubscriptBox[
    StyleBox["x", "TI"], "-"], "\[RightAngleBracket]"}]], "InlineFormula",
  ExpressionUUID->"0150e250-5a95-4699-84fc-4105046c1fa8"],
 ":"
}], "ExampleText",ExpressionUUID->"fabe3efe-e660-41a7-92ac-49fcc7b5e213"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"bobBits", " ", "=", " ", "\n", " ", 
  RowBox[{"bobRealization", " ", "/.", " ", "\n", "  ", 
   RowBox[{"Flatten", "[", 
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{"Alternatives", " ", "@@", " ", 
        RowBox[{"#", "[", 
         RowBox[{"[", 
          RowBox[{";;", " ", "2"}], "]"}], "]"}]}], " ", "->", " ", 
       RowBox[{"#", "[", 
        RowBox[{"[", 
         RowBox[{"-", "1"}], "]"}], "]"}]}], " ", "&"}], " ", "/@", " ", "\n",
      "    ", 
     RowBox[{"Transpose", "[", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{
         RowBox[{"QuditBasis", "[", "\"\<Z\>\"", "]"}], "[", "\"\<Names\>\"", 
         "]"}], ",", " ", "\n", "      ", 
        RowBox[{
         RowBox[{"QuditBasis", "[", "\"\<X\>\"", "]"}], "[", "\"\<Names\>\"", 
         "]"}], ",", " ", 
        RowBox[{"{", 
         RowBox[{"0", ",", " ", "1"}], "}"}]}], "}"}], "]"}]}], 
    "]"}]}]}]], "Input",
 CellLabel->
  "In[11]:= ",ExpressionUUID->"c042aa12-eb70-4e07-92ff-795c5213c586"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
  "0", ",", "0", ",", "1", ",", "1", ",", "1", ",", "0", ",", "1", ",", "0", ",",
    "1"}], "}"}]], "Output",
 CellLabel->
  "Out[11]= ",ExpressionUUID->"9fd9ff8b-6160-4621-bb99-9cc831ed999f"]
}, Open  ]],

Cell["\<\
Finally, Alice and Bob publicly share with each other the measurement basis \
that they used (in other words, they conduct a classical communication). If \
the basis is same, they each keep the bit; if not, they each disregard the \
corresponding bit. (Note that each does so separately, and each one obtains a \
secret key, which will be the same as the other's):\
\>", "ExampleText",ExpressionUUID->"66c60289-ccac-4d2e-aa75-af962c77c310"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"aliceSecretKey", " ", "=", " ", "\n", " ", 
  RowBox[{
   RowBox[{"Select", "[", 
    RowBox[{
     RowBox[{"Transpose", "[", 
      RowBox[{"{", 
       RowBox[{
       "aliceBits", ",", " ", "aliceBases", ",", " ", "\n", "     ", 
        "bobBases"}], "}"}], "]"}], ",", " ", 
     RowBox[{
      RowBox[{
       RowBox[{"#", "[", 
        RowBox[{"[", "2", "]"}], "]"}], " ", "==", " ", 
       RowBox[{"#", "[", 
        RowBox[{"[", "3", "]"}], "]"}]}], " ", "&"}]}], "]"}], "[", 
   RowBox[{"[", 
    RowBox[{"All", ",", " ", "1"}], "]"}], "]"}]}]], "Input",
 CellLabel->
  "In[12]:= ",ExpressionUUID->"f91fe71c-b9d8-414b-a61c-2e427a8eb3fe"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"0", ",", "0", ",", "1"}], "}"}]], "Output",
 CellLabel->
  "Out[12]= ",ExpressionUUID->"a26f6f37-9619-4e93-877e-31729caa0b03"]
}, Open  ]],

Cell["Likewise, Bob keeps the bits where the bases agreed:", "ExampleText",ExpressionUUID->"b0995f5f-94f4-411f-ab6c-ecd4c0c81fb2"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"bobSecretKey", " ", "=", " ", "\n", " ", 
  RowBox[{
   RowBox[{"Select", "[", 
    RowBox[{
     RowBox[{"Transpose", "[", 
      RowBox[{"{", 
       RowBox[{
       "bobBits", ",", " ", "aliceBases", ",", " ", "\n", "     ", 
        "bobBases"}], "}"}], "]"}], ",", " ", 
     RowBox[{
      RowBox[{
       RowBox[{"#", "[", 
        RowBox[{"[", "2", "]"}], "]"}], " ", "==", " ", 
       RowBox[{"#", "[", 
        RowBox[{"[", "3", "]"}], "]"}]}], " ", "&"}]}], "]"}], "[", 
   RowBox[{"[", 
    RowBox[{"All", ",", " ", "1"}], "]"}], "]"}]}]], "Input",
 CellLabel->
  "In[13]:= ",ExpressionUUID->"fd8c731a-5383-469c-89bd-a4e4a53fb644"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"0", ",", "0", ",", "1"}], "}"}]], "Output",
 CellLabel->
  "Out[13]= ",ExpressionUUID->"3c56f4b6-7186-45ae-858d-2f532752b5e7"]
}, Open  ]],

Cell["The two secret keys coincide:", "ExampleText",ExpressionUUID->"a156310d-bc1c-43eb-bdec-e19c087d6453"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"bobSecretKey", " ", "==", " ", "aliceSecretKey"}]], "Input",
 CellLabel->
  "In[14]:= ",ExpressionUUID->"e6c43dab-f09f-41bb-9906-b289b9d28885"],

Cell[BoxData["True"], "Output",
 CellLabel->
  "Out[14]= ",ExpressionUUID->"74bbbc29-62a1-4f4b-b2b1-6c2ae6fe2cc0"]
}, Open  ]],

Cell["\<\
Alice and Bob now share a secret key. Note that the key length is less than \
the number of qubits Alice sent to Bob (because Bob picks the measurement \
basis randomly, and he might not get the same outcome as Alice). Alice can \
keep sending Bob qubits until they reach a desired length. This can be \
implemented as follows:\
\>", "ExampleText",ExpressionUUID->"3061b6e5-ed9e-4016-be7e-544c7d42f3b0"],

Cell[BoxData[
 RowBox[{
  RowBox[{"add", "[", 
   RowBox[{"{", 
    RowBox[{"x_", ",", " ", "y_"}], "}"}], "]"}], " ", ":=", " ", "\n", " ", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
     "aliceBit", ",", " ", "aliceBase", ",", " ", "aliceQubit", ",", " ", 
      "bobBase", ",", " ", "bobBit"}], "}"}], ",", "\n", "  ", 
    RowBox[{
     RowBox[{"aliceBit", " ", "=", " ", 
      RowBox[{"RandomChoice", "[", 
       RowBox[{"{", 
        RowBox[{"0", ",", " ", "1"}], "}"}], "]"}]}], ";", "\n", "  ", 
     RowBox[{"aliceBase", " ", "=", " ", 
      RowBox[{"RandomChoice", "[", 
       RowBox[{"{", 
        RowBox[{"\"\<Z\>\"", ",", " ", "\"\<X\>\""}], "}"}], "]"}]}], ";", 
     "\n", "  ", 
     RowBox[{"aliceQubit", " ", "=", " ", 
      RowBox[{"aliceProtocol", "[", 
       RowBox[{"{", 
        RowBox[{"aliceBit", ",", " ", "aliceBase"}], "}"}], "]"}]}], ";", 
     "\n", "  ", 
     RowBox[{"bobBase", " ", "=", " ", 
      RowBox[{"RandomChoice", "[", 
       RowBox[{"{", 
        RowBox[{"\"\<Z\>\"", ",", " ", "\"\<X\>\""}], "}"}], "]"}]}], ";", 
     "\n", "  ", 
     RowBox[{"bobBit", " ", "=", " ", "\n", "   ", 
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{"QuantumMeasurementOperator", "[", "bobBase", "]"}], "[", 
         "aliceQubit", "]"}], "[", "\n", 
        "     ", "\"\<SimulatedMeasurement\>\"", "]"}], " ", "/.", " ", "\n", 
       "    ", 
       RowBox[{"Flatten", "[", 
        RowBox[{
         RowBox[{
          RowBox[{
           RowBox[{"Alternatives", " ", "@@", " ", 
            RowBox[{"#", "[", 
             RowBox[{"[", 
              RowBox[{";;", " ", "2"}], "]"}], "]"}]}], " ", "->", " ", 
           RowBox[{"#", "[", 
            RowBox[{"[", 
             RowBox[{"-", "1"}], "]"}], "]"}]}], " ", "&"}], " ", "/@", " ", 
         "\n", "      ", 
         RowBox[{"Transpose", "[", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{
             RowBox[{"QuditBasis", "[", "\"\<Z\>\"", "]"}], 
             "[", "\"\<Names\>\"", "]"}], ",", " ", "\n", "        ", 
            RowBox[{
             RowBox[{"QuditBasis", "[", "\"\<X\>\"", "]"}], 
             "[", "\"\<Names\>\"", "]"}], ",", " ", 
            RowBox[{"{", 
             RowBox[{"0", ",", " ", "1"}], "}"}]}], "}"}], "]"}]}], "]"}]}]}],
      ";", "\n", "  ", 
     RowBox[{"If", "[", 
      RowBox[{
       RowBox[{"aliceBase", " ", "==", " ", "bobBase"}], ",", " ", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"Append", "[", 
          RowBox[{"x", ",", " ", "aliceBit"}], "]"}], ",", " ", "\n", "    ", 
         
         RowBox[{"Append", "[", 
          RowBox[{"y", ",", " ", "bobBit"}], "]"}]}], "}"}], ",", " ", 
       RowBox[{"{", 
        RowBox[{"x", ",", " ", "y"}], "}"}]}], "]"}]}]}], "]"}]}]], "Input",
 CellLabel->
  "In[15]:= ",ExpressionUUID->"18f61bd4-3fad-48ba-bcb3-6398008f135f"],

Cell["For example, the key length is set to 5 bits below:", "ExampleText",ExpressionUUID->"4ade7c71-0c6f-4250-bd34-c1564df20da0"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"NestWhile", "[", 
  RowBox[{"add", ",", " ", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"{", "}"}], ",", " ", 
     RowBox[{"{", "}"}]}], "}"}], ",", " ", 
   RowBox[{
    RowBox[{
     RowBox[{"Length", "[", 
      RowBox[{"#", "[", 
       RowBox[{"[", "1", "]"}], "]"}], "]"}], " ", "<", " ", "5"}], " ", 
    "&"}]}], "]"}]], "Input",
 CellLabel->
  "In[16]:= ",ExpressionUUID->"b042248e-8109-45a0-ad3b-bd891fa34691"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"1", ",", "1", ",", "0", ",", "1", ",", "1"}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{"1", ",", "1", ",", "0", ",", "1", ",", "1"}], "}"}]}], 
  "}"}]], "Output",
 CellLabel->
  "Out[16]= ",ExpressionUUID->"86450280-39a0-4fb1-a21c-f18efdf09423"]
}, Open  ]],

Cell["Parity test", "ExampleSubsection",ExpressionUUID->"4cf6c5fe-a6b6-46f5-ac2c-29fbdd390edf"],

Cell["\<\
Quantum circuit for parity test. If the number of 1 in a bit string (e.g. \
0001101..) is even, the parity is assigned to 0 (even parity), if it is odd, \
the parity is assigned to 1 (odd parity). A quantum circuit to measure parity \
of an n-qubit state is given below:\
\>", "ExampleText",ExpressionUUID->"6eef2e49-a35e-4d68-ac39-1fc1c7f5eed7"],

Cell[BoxData[
 RowBox[{
  RowBox[{"parityMeasurementCircuit", "[", "n_", "]"}], " ", ":=", " ", "\n", 
  " ", 
  RowBox[{"QuantumCircuitOperator", "[", "\n", "  ", 
   RowBox[{"Append", "[", 
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{"\"\<CNOT\>\"", " ", "->", " ", 
        RowBox[{"{", 
         RowBox[{"#", ",", " ", 
          RowBox[{"n", " ", "+", " ", "1"}]}], "}"}]}], " ", "&"}], " ", "/@",
       " ", 
      RowBox[{"Range", "[", "n", "]"}]}], ",", " ", 
     RowBox[{"{", 
      RowBox[{"n", " ", "+", " ", "1"}], "}"}]}], "]"}], "]"}]}]], "Input",
 CellLabel->"In[1]:= ",ExpressionUUID->"b4aaf5c0-eb3d-48dc-9fe2-ee2eb400e937"],

Cell["Example of a parity measurement circuit for 3-qubit state:", \
"ExampleText",ExpressionUUID->"a1a0c2ff-d942-4845-9c49-2db7e87f547c"],

Cell[CellGroupData[{

Cell[BoxData[
