Cell["\<\
Check the multiplexer realizes the same unitary as the GrayOracle:\
\>", "ExampleText",ExpressionUUID->"aeff3d67-cfab-4596-ba05-d63a12a269a4"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"(", 
    RowBox[{
     RowBox[{"inv", "[", "\"\<Matrix\>\"", "]"}], " ", "-", " ", "\n", "    ", 
     RowBox[{
      RowBox[{"QuantumCircuitOperator", "[", "\n", "      ", 
       RowBox[{"\"\<GrayOracle\>\"", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"If", "[", 
           RowBox[{
            RowBox[{"#", " ", "==", " ", "0"}], ",", " ", "0", ",", " ", 
            RowBox[{"1.", "/", "#"}]}], "]"}], " ", "&"}], ",", " ", "prec", ",",
          " ", "1"}], "]"}], "]"}], "[", "\"\<Matrix\>\"", "]"}]}], ")"}], "[",
    "\n", "  ", "\"\<ExplicitValues\>\"", "]"}], " ", "//", " ", 
