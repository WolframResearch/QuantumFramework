Cell["\<\
Find the corresponding probabilities in the computational basis:\
\>", "ExampleText",ExpressionUUID->"1a6c1a30-19f9-4a2d-8ec8-fef66660822e"],

Cell[BoxData[
 RowBox[{
  RowBox[{"weight", " ", "=", " ", 
   RowBox[{
    RowBox[{"Abs", "[", 
     RowBox[{
      RowBox[{"qaoa", "[", 
       RowBox[{"q", ",", " ", "p"}], "]"}], "[", "\"\<Amplitudes\>\"", "]"}], 
     "]"}], "^", "2"}]}], ";"}]], "Input",
 CellLabel->
  "In[10]:= ",ExpressionUUID->"f1c579a4-5318-4a5c-b969-bc7ec7ff19c4"],

Cell[TextData[{
 "Find ",
 Cell[BoxData[
  RowBox[{
   AdjustmentBox["\[LeftAngleBracket]",
    BoxMargins->{{0, -0.2}, {0, 0}}], 
   RowBox[{
    StyleBox["\[Gamma]", "TI"], 
    RowBox[{",", "\[ThinSpace]"}], 
    RowBox[{
     StyleBox["\[Beta]", "TI"], 
     AdjustmentBox["|",
      BoxMargins->{{0, -0.2}, {0, 0}}], 
     StyleBox["H", "TI"], 
     AdjustmentBox["|",
      BoxMargins->{{-0.2, 0}, {0, 0}}], 
     StyleBox["\[Gamma]", "TI"]}], 
    RowBox[{",", "\[ThinSpace]"}], 
    StyleBox["\[Beta]", "TI"]}], 
   AdjustmentBox["\[RightAngleBracket]",
    BoxMargins->{{-0.2, 0}, {0, 0}}]}]], "InlineFormula",ExpressionUUID->
  "92eda422-36b8-41d2-975a-cbcc667d3e20"],
 " with ",
 Cell[BoxData[
  RowBox[{
   StyleBox["H", "TI"], "=", 
   UnderscriptBox["\[Sum]", 
    RowBox[{
     StyleBox["i", "TI"], ">", 
     StyleBox["j", "TI"]}]], 
   SubscriptBox[
    StyleBox["q", "TI"], 
    StyleBox["ij", "TI"]], 
   SubscriptBox[
    StyleBox["\[Sigma]", "TI"], 
    RowBox[{
     StyleBox["z", "TI"], ",", 
     StyleBox["i", "TI"]}]], 
   SubscriptBox[
    StyleBox["\[Sigma]", "TI"], 
    RowBox[{
     StyleBox["z", "TI"], ",", 
     StyleBox["j", "TI"]}]]}]], "InlineFormula",ExpressionUUID->
  "559c0b92-2636-44a7-8cb7-c3b40e340426"],
 " and ",
 Cell[BoxData[
  RowBox[{"|", 
   StyleBox["\[Gamma]", "TI"], 
   RowBox[{",", "\[ThinSpace]"}], 
   StyleBox["\[Beta]", "TI"], "\[RightAngleBracket]"}]], "InlineFormula",
  ExpressionUUID->"e850e0a3-39af-4ec1-9f28-56011b0f3324"],
 " the output of the above circuit:"
}], "ExampleText",ExpressionUUID->"3144d41b-ac28-4f6a-aefd-87844e512276"],

Cell[BoxData[
 RowBox[{
  RowBox[{"weightedEnergy", " ", "=", " ", "\n", "  ", 
   RowBox[{"Association", "@", "\n", "   ", 
    RowBox[{"KeyValueMap", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"#1", " ", "->", " ", 
        RowBox[{"#2", " ", 
         RowBox[{"Total", "[", "\n", "        ", 
          RowBox[{
           RowBox[{
            RowBox[{"UpperTriangularize", "[", 
             RowBox[{"q", ",", " ", "1"}], "]"}], " ", 
            RowBox[{"UpperTriangularize", "[", "\n", "          ", 
             RowBox[{
              RowBox[{"KroneckerProduct", "[", 
               RowBox[{
                RowBox[{
                 RowBox[{"(", 
                  RowBox[{"-", "1"}], ")"}], "^", 
                 RowBox[{"#1", "[", "\"\<Name\>\"", "]"}]}], ",", " ", 
                RowBox[{
                 RowBox[{"(", 
                  RowBox[{"-", "1"}], ")"}], "^", 
                 RowBox[{"#1", "[", "\"\<Name\>\"", "]"}]}]}], "]"}], ",", 
              " ", "1"}], "]"}]}], ",", " ", "2"}], "]"}]}]}], " ", "&"}], ",",
       "\n", "     ", "weight"}], "]"}]}]}], ";"}]], "Input",
 CellLabel->
  "In[11]:= ",ExpressionUUID->"931c3524-0119-4d04-b1de-3bb5674d9de1"],

Cell["Maximize the total weighted-mean value over the angles:", "ExampleText",ExpressionUUID->"6ce02880-30ff-4c81-abb3-0170e7dd95aa"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"optMax", " ", "=", " ", "\n", " ", 
  RowBox[{"Thread", "[", 
   RowBox[{"var", " ", "->", " ", "\n", "   ", 
    RowBox[{"NArgMax", "[", 
     RowBox[{
      RowBox[{"{", 
