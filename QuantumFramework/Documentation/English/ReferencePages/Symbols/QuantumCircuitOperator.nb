Cell["Calculate the probability of winning:", "ExampleText",ExpressionUUID->"2b6bf528-5af3-4111-8bce-bedb489c58c1"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"NProbability", "[", "\n", " ", 
  RowBox[{
   RowBox[{
    RowBox[{"BitAnd", "[", 
     RowBox[{"x", ",", " ", "y"}], "]"}], " ", "==", " ", 
    RowBox[{"BitXor", "[", 
     RowBox[{"a", ",", " ", "b"}], "]"}]}], ",", " ", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"a", ",", " ", "x", ",", " ", "y", ",", " ", "b"}], "}"}], " ", "\[Distributed]",
     " ", "\n", "  ", 
    RowBox[{
     RowBox[{
      RowBox[{"QuantumCircuitOperator", "[", "\"\<CHSH\>\"", "]"}], "[", 
      "]"}], "[", "\"\<MultivariateDistribution\>\"", "]"}]}]}], 
  "]"}]], "Input",
 CellLabel->"In[2]:= ",ExpressionUUID->"3001d01f-fb18-48f8-a6e8-1960822fb100"],

Cell[BoxData["0.853553390593274`"], "Output",
 CellLabel->"Out[2]= ",ExpressionUUID->"6658574d-5168-4621-8c35-62fece21df73"]
}, Open  ]]
}, Closed]],

