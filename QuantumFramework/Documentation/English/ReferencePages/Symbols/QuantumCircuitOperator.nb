 ")"
}], "ExampleText",ExpressionUUID->"8773207d-c6e7-4fa8-90c3-f9009d362980"],

Cell["Check the classical solution is the same as quantum one:", "ExampleText",ExpressionUUID->"d7c550ca-5c0a-40d9-a848-94ce477e2d5b"],

Cell[BoxData[
 RowBox[{"MemberQ", "[", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"#", "[", "\"\<Name\>\"", "]"}], " ", "&"}], " ", "/@", " ", 
    "\n", "  ", 
    RowBox[{"Keys", "[", 
     RowBox[{"TakeLargestBy", "[", 
      RowBox[{
       RowBox[{"Normal", "@", 
        RowBox[{"N", "[", 
         RowBox[{"weightedEnergy", " ", "/.", " ", "optMax"}], "]"}]}], ",", 
       " ", "Last", ",", " ", "2"}], "]"}], "]"}]}], ",", " ", "\n", " ", 
   RowBox[{"solMax", " ", "/.", " ", 
    RowBox[{
     RowBox[{"-", "1"}], " ", "->", " ", "0"}]}]}], "]"}]], "Input",
 CellLabel->
  "In[11]:= ",ExpressionUUID->"7d2c137d-4b20-45c0-bcc4-9a09926be55f"],

Cell[BoxData[
 RowBox[{"MemberQ", "[", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"#", "[", "\"\<Name\>\"", "]"}], " ", "&"}], " ", "/@", " ", 
    "\n", "  ", 
    RowBox[{"Keys", "[", 
     RowBox[{"TakeSmallestBy", "[", 
      RowBox[{
       RowBox[{"Normal", "@", 
        RowBox[{"N", "[", 
         RowBox[{"weightedEnergy", " ", "/.", " ", "optMin"}], "]"}]}], ",", 
       " ", "Last", ",", " ", "2"}], "]"}], "]"}]}], ",", " ", "\n", " ", 
