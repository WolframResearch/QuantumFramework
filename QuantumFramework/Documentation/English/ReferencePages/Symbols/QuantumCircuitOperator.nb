Cell["\<\
Trace out the 1st and 2nd qubits for each possible post-measurement state, \
and compare the reduced state of qubit 3:\
\>", "ExampleText",ExpressionUUID->"11fb4785-5a4d-4bc4-a93f-973d9c855427"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"Thread", "[", 
   RowBox[{
    RowBox[{"QuantumState", "[", 
     RowBox[{"{", 
      RowBox[{"\[Alpha]", ",", " ", "\[Beta]"}], "}"}], "]"}], " ", "==", " ",
     "\n", "   ", 
    RowBox[{
     RowBox[{"QuantumOperator", "[", 
      RowBox[{"\"\<Trace\>\"", " ", "->", " ", 
       RowBox[{"{", 
        RowBox[{"1", ",", " ", "2"}], "}"}]}], "]"}], " ", "/@", " ", "\n", 
     "    ", 
     RowBox[{
      RowBox[{"circuit", "[", "]"}], "[", "\"\<States\>\"", "]"}]}]}], "]"}], 
  " ", "//", " ", "FullSimplify"}]], "Input",
 CellLabel->"In[3]:= ",ExpressionUUID->"da505487-7a88-4387-8aad-bc0089e835e3"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"True", ",", "True", ",", "True", ",", "True"}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{"True", ",", "True", ",", "True", ",", "True"}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{"True", ",", "True", ",", "True", ",", "True"}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{"True", ",", "True", ",", "True", ",", "True"}], "}"}]}], 
  "}"}]], "Output",
 CellLabel->"Out[3]= ",ExpressionUUID->"5dddce51-945c-40c0-824b-6c18b08d411a"]
}, Open  ]],

Cell["Quantum key distribution as in BB84 protocol", "ExampleSubsection",ExpressionUUID->"7a63c4bb-2d9f-4c7b-b015-3f831e3857e8"],

Cell["\<\
As an example of a quantum key distribution (QKD), consider the BB84 \
protocol. Alice generates random bits and for each, randomly chooses either a \
Z-basis or X-basis of measurement. Consider a random sequence of 9 bits and \
corresponding basis:\
\>", "ExampleText",ExpressionUUID->"ced71392-7760-4621-a6ae-c6476bc4319f"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"aliceBits", " ", "=", " ", 
  RowBox[{"RandomChoice", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"0", ",", " ", "1"}], "}"}], ",", " ", "9"}], "]"}]}]], "Input",
 CellLabel->"In[1]:= ",ExpressionUUID->"43269dc6-6249-4f2a-9d0c-ca8ccd700635"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
  "0", ",", "0", ",", "0", ",", "1", ",", "1", ",", "1", ",", "0", ",", "0", ",",
    "0"}], "}"}]], "Output",
 CellLabel->"Out[1]= ",ExpressionUUID->"c991eda4-0064-4681-af10-48d099bd1a36"]
}, Open  ]],

Cell["Her randomly chosen measurement bases:", "ExampleText",ExpressionUUID->"b0475476-ad63-42a8-bf73-c650c4fc38d3"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"aliceBases", " ", "=", " ", 
  RowBox[{"RandomChoice", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"\"\<Z\>\"", ",", " ", "\"\<X\>\""}], "}"}], ",", " ", "9"}], 
   "]"}]}]], "Input",
 CellLabel->"In[2]:= ",ExpressionUUID->"50fba0cb-ff91-4435-991e-2970030901bc"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"\<\"Z\"\>", ",", "\<\"X\"\>", ",", "\<\"Z\"\>", ",", "\<\"Z\"\>", 
   ",", "\<\"Z\"\>", ",", "\<\"X\"\>", ",", "\<\"X\"\>", ",", "\<\"Z\"\>", 
   ",", "\<\"Z\"\>"}], "}"}]], "Output",
 CellLabel->"Out[2]= ",ExpressionUUID->"615fff6e-7c93-4343-8715-530e822fee81"]
}, Open  ]],

Cell["\<\
Depending on her choice of bit and basis, she follows this protocol for \
sending a qubit to Bob:\
\>", "ExampleText",ExpressionUUID->"fccd37d8-d261-4f24-84b7-af28335a6fde"],

Cell[BoxData[
 RowBox[{
  RowBox[{"aliceProtocol", " ", "=", " ", 
   RowBox[{"<|", 
    RowBox[{
     RowBox[{
      RowBox[{"{", 
       RowBox[{"0", ",", " ", "\"\<Z\>\""}], "}"}], " ", "->", " ", 
      RowBox[{"QuantumState", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"1", ",", " ", "0"}], "}"}], ",", " ", "\"\<Z\>\""}], 
       "]"}]}], ",", " ", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"0", ",", " ", "\"\<X\>\""}], "}"}], " ", "->", " ", "\n", 
      "    ", 
      RowBox[{"QuantumState", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"1", ",", " ", "0"}], "}"}], ",", " ", "\"\<X\>\""}], 
       "]"}]}], ",", " ", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"1", ",", " ", "\"\<Z\>\""}], "}"}], " ", "->", " ", "\n", 
      "    ", 
      RowBox[{"QuantumState", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"0", ",", " ", "1"}], "}"}], ",", " ", "\"\<Z\>\""}], 
       "]"}]}], ",", " ", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"1", ",", " ", "\"\<X\>\""}], "}"}], " ", "->", " ", 
      RowBox[{"QuantumState", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"0", ",", " ", "1"}], "}"}], ",", " ", "\"\<X\>\""}], 
       "]"}]}]}], "|>"}]}], ";"}]], "Input",
 CellLabel->"In[3]:= ",ExpressionUUID->"7993b341-124f-4db6-a0b6-70b6c8a05655"],

Cell["Show each protocol state as a formula:", "ExampleText",ExpressionUUID->"b3b88e30-89bc-43ba-9c1e-4a310764410f"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"#", "[", "\"\<Formula\>\"", "]"}], " ", "&"}], " ", "/@", " ", 
    "aliceProtocol"}], " ", "//", " ", "Normal"}], " ", "//", " ", 
  "Column"}]], "Input",
 CellLabel->"In[4]:= ",ExpressionUUID->"2b0e3341-4a7f-4def-96e7-1b65f0c69bed"],

Cell[BoxData[
 TagBox[GridBox[{
    {
     RowBox[{
      RowBox[{"{", 
       RowBox[{"0", ",", "\<\"Z\"\>"}], "}"}], "\[Rule]", 
      InterpretationBox[
       StyleBox[
        TemplateBox[{
          RowBox[{
            SubscriptBox["\"\[ScriptZ]\"", 
             InterpretationBox["\"+\"", 1]]}]},
         "Ket"],
        FontWeight->"Plain"],
       Wolfram`QuantumFramework`QuditName[
        Subscript["\[ScriptZ]", 
         Interpretation["+", 1]], "Dual" -> False]]}]},
    {
     RowBox[{
      RowBox[{"{", 
       RowBox[{"0", ",", "\<\"X\"\>"}], "}"}], "\[Rule]", 
      InterpretationBox[
       StyleBox[
        TemplateBox[{
          RowBox[{
            SubscriptBox["\"\[ScriptX]\"", 
             InterpretationBox["\"+\"", 1]]}]},
         "Ket"],
        FontWeight->"Plain"],
       Wolfram`QuantumFramework`QuditName[
        Subscript["\[ScriptX]", 
         Interpretation["+", 1]], "Dual" -> False]]}]},
    {
     RowBox[{
      RowBox[{"{", 
       RowBox[{"1", ",", "\<\"Z\"\>"}], "}"}], "\[Rule]", 
      InterpretationBox[
       StyleBox[
        TemplateBox[{
          RowBox[{
            SubscriptBox["\"\[ScriptZ]\"", 
             InterpretationBox["\"\[Minus]\"", -1]]}]},
         "Ket"],
        FontWeight->"Plain"],
       Wolfram`QuantumFramework`QuditName[
        Subscript["\[ScriptZ]", 
         Interpretation["\[Minus]", -1]], "Dual" -> False]]}]},
    {
     RowBox[{
      RowBox[{"{", 
       RowBox[{"1", ",", "\<\"X\"\>"}], "}"}], "\[Rule]", 
      InterpretationBox[
       StyleBox[
        TemplateBox[{
          RowBox[{
            SubscriptBox["\"\[ScriptX]\"", 
             InterpretationBox["\"\[Minus]\"", -1]]}]},
         "Ket"],
        FontWeight->"Plain"],
       Wolfram`QuantumFramework`QuditName[
        Subscript["\[ScriptX]", 
         Interpretation["\[Minus]", -1]], "Dual" -> False]]}]}
   },
   DefaultBaseStyle->"Column",
   GridBoxAlignment->{"Columns" -> {{Left}}},
   GridBoxItemSize->{"Columns" -> {{Automatic}}, "Rows" -> {{Automatic}}}],
  "Column"]], "Output",
 CellLabel->"Out[4]= ",ExpressionUUID->"e9978b2d-2eb5-4b88-9964-e6dbf2fa04b8"]
}, Open  ]],

Cell["\<\
With Alice's bits and bases generated randomly, she sends Bob the \
corresponding qubits:\
\>", "ExampleText",ExpressionUUID->"ae14d96f-aa0a-4933-a815-66dec306dc10"],

