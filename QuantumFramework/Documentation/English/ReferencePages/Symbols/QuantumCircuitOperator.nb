Cell["\<\
Define a function that returns the Boolean table of a Simon oracle:\
\>", "ExampleText",ExpressionUUID->"2873527d-9ee5-4a58-a748-b5bc92f2cf29"],

Cell[BoxData[
 RowBox[{
  RowBox[{"boolTable", "[", "oracle_", "]"}], " ", ":=", " ", "\n", " ", 
  RowBox[{"With", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"n", " ", "=", " ", 
      RowBox[{
       RowBox[{"oracle", "[", "\"\<Width\>\"", "]"}], "/", "2"}]}], "}"}], ",",
     " ", "\n", "  ", 
    RowBox[{
     RowBox[{"KeyValueMap", "[", 
      RowBox[{
       RowBox[{"TraditionalForm", " ", "/@", " ", 
        RowBox[{"{", 
         RowBox[{"#1", ",", " ", "#2"}], "}"}]}], " ", "&"}], "]"}], "@", 
     "\n", "   ", 
     RowBox[{"AssociationMap", "[", "\n", "    ", 
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{"QuantumOperator", "[", 
          RowBox[{
           RowBox[{"\"\<Discard\>\"", "[", "2", "]"}], " ", "->", " ", 
           RowBox[{"Range", "[", "n", "]"}]}], "]"}], "[", 
         RowBox[{"oracle", "[", "#", "]"}], "]"}], " ", "&"}], ",", " ", "\n",
        "    ", 
       RowBox[{
        RowBox[{"QuantumBasis", "[", 
         RowBox[{"2", ",", " ", "n"}], "]"}], "[", "\"\<BasisStates\>\"", 
        "]"}]}], "]"}]}]}], "]"}]}]], "Input",
 CellLabel->"In[3]:= ",ExpressionUUID->"a1382f5f-e8d7-4b72-98f2-8fa245a7da87"],

Cell["Return the Boolean table of the above Simon oracle:", "ExampleText",ExpressionUUID->"42c09ad8-aa22-429b-b356-dd946f544fcb"],

