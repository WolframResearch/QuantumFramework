Cell["Define a quantum circuit for any objective function:", "ExampleText",ExpressionUUID->"25559da9-6fec-4105-8cec-80069f0541c6"],

Cell[BoxData[{
 RowBox[{"ClearAll", "[", 
  RowBox[{"\[Gamma]", ",", " ", "\[Beta]", ",", " ", "qaoa"}], "]"}], "\n", 
 RowBox[{
  RowBox[{"qaoa", "[", 
   RowBox[{
    RowBox[{"obj_", "?", "SquareMatrixQ"}], ",", " ", 
    RowBox[{"p_", " ", ":", " ", "1"}]}], "]"}], " ", ":=", " ", 
  RowBox[{"With", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"l", " ", "=", " ", 
      RowBox[{"Length", "[", "obj", "]"}]}], "}"}], ",", "\n", "  ", 
    RowBox[{
     RowBox[{"QuantumCircuitOperator", "[", 
      RowBox[{"Join", "[", "\n", "     ", 
       RowBox[{
        RowBox[{"Table", "[", 
         RowBox[{
          RowBox[{"\"\<+\>\"", " ", "->", " ", "i"}], ",", " ", 
          RowBox[{"{", 
           RowBox[{"i", ",", " ", "l"}], "}"}]}], "]"}], ",", "\n", "     ", 
        RowBox[{"Catenate", "@", 
         RowBox[{"Table", "[", "\n", "       ", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{"\"\<Barrier\>\"", ",", "\n", "        ", 
             RowBox[{"Catenate", "@", 
              RowBox[{"Table", "[", "\n", "          ", "\n", "          ", 
               RowBox[{
                RowBox[{"If", "[", 
                 RowBox[{
                  RowBox[{
                   RowBox[{"obj", "[", 
                    RowBox[{"[", 
                    RowBox[{"i", ",", " ", "j"}], "]"}], "]"}], " ", "==", 
                   " ", "0"}], ",", " ", "Nothing", ",", " ", "\n", 
                  "           ", 
                  RowBox[{
                   RowBox[{"\"\<R\>\"", "[", 
                    RowBox[{
                    RowBox[{"2", " ", 
                    RowBox[{"\[Gamma]", "[", "m", "]"}], " ", 
                    RowBox[{"obj", "[", 
                    RowBox[{"[", 
                    RowBox[{"i", ",", " ", "j"}], "]"}], "]"}]}], ",", 
                    " ", "\"\<ZZ\>\""}], "]"}], " ", "->", " ", 
                   RowBox[{"{", 
                    RowBox[{"i", ",", " ", "j"}], "}"}]}]}], "]"}], ",", "\n",
                 "          ", 
                RowBox[{"{", 
                 RowBox[{"i", ",", " ", "l"}], "}"}], ",", " ", 
                RowBox[{"{", 
                 RowBox[{"j", ",", " ", 
                  RowBox[{"i", " ", "+", " ", "1"}], ",", " ", "l"}], "}"}]}],
                "\n", "          ", "]"}]}], ",", "\n", 
             "        ", "\"\<Barrier\>\"", ",", "\n", "        ", 
             RowBox[{"Table", "[", 
              RowBox[{
               RowBox[{
                RowBox[{"\"\<R\>\"", "[", " ", 
                 RowBox[{
                  RowBox[{"2", " ", 
                   RowBox[{"\[Beta]", "[", "m", "]"}]}], ",", 
                  " ", "\"\<X\>\""}], "]"}], " ", "->", " ", "i"}], ",", " ", 
               
               RowBox[{"{", 
                RowBox[{"i", ",", " ", "l"}], "}"}]}], "]"}]}], "}"}], "\n", 
           "       ", ",", " ", 
           RowBox[{"{", 
            RowBox[{"m", ",", " ", "p"}], "}"}]}], "]"}]}]}], "]"}], "\n", 
      "    ", "]"}], "[", "\"\<Flatten\>\"", "]"}]}], "]"}]}]}], "Input",
 CellLabel->"In[6]:= ",ExpressionUUID->"85c11b12-96a1-45a2-af86-1d38936ab14a"],

Cell["Set the number of QAOA layers:", "ExampleText",ExpressionUUID->"f72ba471-2187-43e7-8c85-d3ca22f41f51"],

Cell[BoxData[
 RowBox[{
  RowBox[{"p", " ", "=", " ", "2"}], ";"}]], "Input",
 CellLabel->"In[7]:= ",ExpressionUUID->"d7cab44a-eeaa-4974-8dc1-b7164693f473"],

