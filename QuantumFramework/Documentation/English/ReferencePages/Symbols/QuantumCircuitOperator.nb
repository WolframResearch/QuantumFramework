Cell["Some multi-qubit quantum gates:", "ExampleText",ExpressionUUID->"5cf8e8e0-8a60-41df-b127-ffe5cb307d3f"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"QuantumCircuitOperator", "[", 
   RowBox[{"{", 
    RowBox[{"\"\<CH\>\"", ",", " ", "\"\<CS\>\"", ",", " ", "\"\<CNOT\>\"", ",",
      " ", "\"\<CT\>\"", ",", " ", "\"\<CX\>\"", ",", " ", "\"\<CY\>\"", ",", 
     " ", "\"\<CZ\>\"", ",", " ", "\n", "   ", 
     RowBox[{"\"\<CP\>\"", "[", "\[Theta]", "]"}], ",", " ", 
     RowBox[{"{", 
      RowBox[{"\"\<C\>\"", ",", " ", 
       RowBox[{
        RowBox[{"\"\<RX\>\"", "[", 
         RowBox[{"Subscript", "[", 
          RowBox[{"\[Theta]", ",", " ", "x"}], "]"}], "]"}], " ", "->", " ", 
        "4"}], ",", " ", 
       RowBox[{"{", "3", "}"}]}], "}"}], ",", " ", 
     RowBox[{"{", 
      RowBox[{"\"\<C\>\"", ",", "\n", "     ", 
       RowBox[{
        RowBox[{"\"\<RY\>\"", "[", 
         RowBox[{"Subscript", "[", 
          RowBox[{"\[Theta]", ",", " ", "y"}], "]"}], "]"}], " ", "->", " ", 
        "4"}], ",", " ", 
       RowBox[{"{", "3", "}"}]}], "}"}], ",", " ", 
     RowBox[{"{", 
      RowBox[{"\"\<C\>\"", ",", " ", "\n", "    ", 
       RowBox[{
        RowBox[{"\"\<RZ\>\"", "[", 
         RowBox[{"Subscript", "[", 
          RowBox[{"\[Theta]", ",", " ", "z"}], "]"}], "]"}], " ", "->", " ", 
        "4"}], ",", " ", 
       RowBox[{"{", "3", "}"}]}], "}"}], ",", " ", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"\"\<R\>\"", ",", " ", 
        RowBox[{"Subscript", "[", 
         RowBox[{"\[Theta]", ",", "\n", "      ", "xx"}], "]"}], ",", 
        " ", "\"\<XX\>\""}], "}"}], " ", "->", " ", 
      RowBox[{"{", 
       RowBox[{"3", ",", " ", "4"}], "}"}]}], ",", " ", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"\"\<R\>\"", ",", " ", 
        RowBox[{"Subscript", "[", 
         RowBox[{"\[Theta]", ",", " ", "yy"}], "]"}], ",", " ", "\n", 
        "     ", "\"\<YY\>\""}], "}"}], " ", "->", " ", 
      RowBox[{"{", 
       RowBox[{"3", ",", " ", "4"}], "}"}]}], ",", " ", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"\"\<R\>\"", ",", " ", 
        RowBox[{"Subscript", "[", 
         RowBox[{"\[Theta]", ",", " ", "zz"}], "]"}], ",", 
        " ", "\"\<ZZ\>\""}], "}"}], " ", "->", " ", 
      RowBox[{"{", 
       RowBox[{"3", ",", " ", "4"}], "}"}]}], ",", " ", "\n", "   ", 
     RowBox[{"\"\<SWAP\>\"", " ", "->", " ", 
      RowBox[{"{", 
       RowBox[{"3", ",", " ", "4"}], "}"}]}], ",", " ", 
     RowBox[{"\"\<RootSWAP\>\"", " ", "->", " ", 
      RowBox[{"{", 
       RowBox[{"3", ",", " ", "4"}], "}"}]}], ",", " ", "\n", "   ", 
     RowBox[{"\"\<Permutation\>\"", " ", "->", " ", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"3", ",", " ", "4"}], "}"}], " ", "->", " ", 
       RowBox[{"{", 
        RowBox[{"4", ",", " ", "3"}], "}"}]}]}], ",", " ", "\n", 
