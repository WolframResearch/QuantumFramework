Cell["\t", "ExampleDelimiter",ExpressionUUID->"58357f2e-2e22-4e30-b2aa-6124dd1aa816"],

Cell["\<\
Create a quantum circuit composed of only single qubit gates:\
\>", "ExampleText",ExpressionUUID->"8b93320e-1fbd-4cd0-827b-66e5d7dfbee4"],

Cell[BoxData[
 RowBox[{
  RowBox[{"qc", " ", "=", " ", 
   RowBox[{"QuantumCircuitOperator", "[", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"QuantumOperator", "[", "\"\<X\>\"", "]"}], ",", " ", "\n", 
      "    ", 
      RowBox[{"QuantumOperator", "[", 
       RowBox[{"\"\<Y\>\"", ",", " ", 
        RowBox[{"{", "2", "}"}]}], "]"}]}], "}"}], "]"}]}], ";"}]], "Input",
 CellLabel->"In[1]:= ",ExpressionUUID->"b3a603b2-07f9-4cef-a83e-fed8fc4abe8c"],

Cell["Draw the associated circuit diagram:", "ExampleText",ExpressionUUID->"f7375fc3-4d75-46bd-9252-e1c388b194b7"],

Cell[BoxData[
 RowBox[{"qc", "[", "\"\<Diagram\>\"", "]"}]], "Input",
 CellLabel->"In[2]:= ",ExpressionUUID->"6a72cb4a-b70b-45c4-a804-5bde5d9a2619"],

Cell["Shorthand representation of the circuit:", "ExampleText",ExpressionUUID->"8bf9260e-fa07-4719-a6fa-21b5654a4a58"],

Cell[BoxData[
 RowBox[{
  RowBox[{"QuantumCircuitOperator", "[", "\"\<XY\>\"", "]"}], 
  "[", "\"\<Diagram\>\"", "]"}]], "Input",
 CellLabel->"In[3]:= ",ExpressionUUID->"b1430349-8b0e-42ca-b7df-0630f44f9a11"],

Cell["Another shorter version of input, to create above circuit:", \
"ExampleText",ExpressionUUID->"4acdbea9-d36f-4216-860d-e62425388797"],

Cell[BoxData[
 RowBox[{"QuantumShortcut", "@", "qc"}]], "Input",
 CellLabel->"In[4]:= ",ExpressionUUID->"485fffee-a586-488a-ba60-e0e7bc2ebecf"],

Cell[BoxData[
 RowBox[{
  RowBox[{"QuantumCircuitOperator", "[", "%", "]"}], "[", "\"\<Diagram\>\"", 
  "]"}]], "Input",
 CellLabel->"In[5]:= ",ExpressionUUID->"6aaae967-4f30-44cc-a300-f49844a987bc"],

Cell["\t", "ExampleDelimiter",ExpressionUUID->"dfff37ff-42b4-4ad4-b8ec-82b5d689470e"],

Cell["Create a circuit with multi-qubit gates:", "ExampleText",ExpressionUUID->"a2cc1178-67c0-457b-8c42-cf32f63d95c9"],

Cell[BoxData[
 RowBox[{
  RowBox[{"qc", " ", "=", " ", 
   RowBox[{"QuantumCircuitOperator", "[", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"QuantumOperator", "[", "\"\<CNOT\>\"", "]"}], ",", " ", "\n", 
      "    ", 
      RowBox[{"QuantumOperator", "[", 
       RowBox[{"\"\<H\>\"", " ", "->", " ", 
        RowBox[{"{", 
         RowBox[{"1", ",", " ", "2"}], "}"}]}], "]"}]}], "}"}], "]"}]}], 
  ";"}]], "Input",
 CellLabel->"In[1]:= ",ExpressionUUID->"da1c2424-58b2-4ccd-ade6-4edb71c5f51d"],

Cell["Associated circuit diagram:", "ExampleText",ExpressionUUID->"cf6ebd69-0828-42fb-b672-a835f055ddcf"],

Cell[BoxData[
 RowBox[{"qc", "[", "\"\<Diagram\>\"", "]"}]], "Input",
 CellLabel->"In[2]:= ",ExpressionUUID->"7debde45-4d1a-4307-96a9-2db322abaf47"],

Cell["The above circuit has a shorthand representation, too:", "ExampleText",ExpressionUUID->"d953e7ec-f6c8-47fd-944e-b204b7d95ab5"],

Cell[BoxData[
 RowBox[{
  RowBox[{"QuantumCircuitOperator", "[", 
   RowBox[{"{", 
    RowBox[{"\"\<CNOT\>\"", ",", " ", 
     RowBox[{"\"\<H\>\"", " ", "->", " ", 
      RowBox[{"{", 
       RowBox[{"1", ",", " ", "2"}], "}"}]}]}], "}"}], "]"}], " ", "==", " ", 
  "qc"}]], "Input",
 CellLabel->"In[3]:= ",ExpressionUUID->"de07798e-6e7a-48b2-b9cc-b4746672d32f"],

Cell["\<\
The dashed line between two Hadamards imply that they are defined as tensor \
product, although they are separable. Compared it with this case:\
\>", "ExampleText",ExpressionUUID->"94047f91-5b79-4779-8aed-5a8337d91b20"],

Cell[BoxData[
 RowBox[{
  RowBox[{"QuantumCircuitOperator", "[", 
   RowBox[{"{", 
    RowBox[{"\"\<CNOT\>\"", ",", " ", "\"\<H\>\"", ",", " ", 
     RowBox[{"\"\<H\>\"", " ", "->", " ", 
      RowBox[{"{", "2", "}"}]}]}], "}"}], "]"}], "[", "\"\<Diagram\>\"", 
  "]"}]], "Input",
 CellLabel->"In[4]:= ",ExpressionUUID->"cc7614b2-8a8b-4ea9-8456-d8b8fba4e1d9"],

Cell["\t", "ExampleDelimiter",ExpressionUUID->"d1bca06f-027f-4aee-aa27-6ed4493da2ba"],

Cell["A quantum state is transformed by a quantum circuit", "ExampleText",ExpressionUUID->"1b869938-1ab5-4d68-ba47-256b81cb1df8"],

Cell[BoxData[
 RowBox[{
  RowBox[{"QuantumCircuitOperator", "[", 
   RowBox[{"{", 
    RowBox[{"\"\<CNOT\>\"", ",", " ", "\"\<H\>\"", ",", " ", 
     RowBox[{"\"\<S\>\"", " ", "->", " ", 
      RowBox[{"{", "2", "}"}]}]}], "}"}], "]"}], "[", 
  RowBox[{"QuantumState", "[", "\"\<01\>\"", "]"}], "]"}]], "Input",
 CellLabel->"In[1]:= ",ExpressionUUID->"d0427d60-86d4-4747-a296-e8213197c694"],

Cell["\<\
If no input is given, the initial state is set as the corresponding register \
state\
\>", "ExampleText",ExpressionUUID->"7455cff0-1881-4c1b-ab12-2184957391a5"],

Cell[BoxData[
 RowBox[{
  RowBox[{"QuantumCircuitOperator", "[", 
   RowBox[{"{", 
    RowBox[{"\"\<CNOT\>\"", ",", " ", "\"\<H\>\"", ",", " ", 
     RowBox[{"\"\<S\>\"", " ", "->", " ", 
      RowBox[{"{", "2", "}"}]}]}], "}"}], "]"}], "[", "]"}]], "Input",
 CellLabel->"In[2]:= ",ExpressionUUID->"6ca343cd-d831-4f5f-bdba-cc28d5173233"],

Cell["\t", "ExampleDelimiter",ExpressionUUID->"94f17afd-b311-45a8-bc92-979f428c2ff9"],

Cell["Quantum circuit can include many quantum objects:", "ExampleText",ExpressionUUID->"10c4d667-62b4-490b-8fae-0422d22366dd"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"qc", " ", "=", " ", 
   RowBox[{"QuantumCircuitOperator", "[", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"QuantumState", "[", 
       RowBox[{"\"\<Bell\>\"", ",", " ", 
        RowBox[{"\"\<Label\>\"", " ", "->", " ", "\"\<Bell\>\""}]}], "]"}], ",",
       " ", "\n", "    ", "\"\<XY\>\"", ",", " ", 
      RowBox[{"{", 
       RowBox[{"\"\<C\>\"", ",", " ", 
        RowBox[{"\"\<RY\>\"", "[", 
         RowBox[{"\[Pi]", "/", "4"}], "]"}]}], "}"}], ",", " ", 
      RowBox[{"\"\<BitFlip\>\"", "[", ".3", "]"}], ",", " ", 
      RowBox[{"\"\<H\>\"", " ", "->", " ", "2"}], ",", " ", "\n", "    ", 
      RowBox[{
       RowBox[{"\"\<P\>\"", "[", 
        RowBox[{"\[Pi]", "/", "3"}], "]"}], " ", "->", " ", "2"}], ",", " ", 
      RowBox[{"{", "1", "}"}], ",", " ", 
      RowBox[{
       RowBox[{"\"\<M\>\"", "[", "\"\<X\>\"", "]"}], " ", "->", " ", "2"}]}], 
     "}"}], "]"}]}], ";"}], "\n", 
 RowBox[{"qc", "[", "\"\<Diagram\>\"", "]"}]}], "Input",
 CellLabel->"In[1]:= ",ExpressionUUID->"cde70cee-1d99-49bf-b0a6-8cca041e2313"],

Cell[BoxData[
 RowBox[{
  RowBox[{"qc", "[", "]"}], "[", "\"\<ProbabilityPlot\>\"", "]"}]], "Input",
 CellLabel->"In[2]:= ",ExpressionUUID->"5fa41466-18ed-4159-af03-e73893b45e0a"],

