Cell["\<\
Build a Simon circuit for a given hidden sequence (seeding the random oracle \
for reproducibility):\
\>", "ExampleText",ExpressionUUID->"cf095989-a492-44bf-871c-046bfc07edf5"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"SeedRandom", "[", "0", "]"}], ";"}], "\n", 
 RowBox[{
  RowBox[{"simon", " ", "=", " ", 
   RowBox[{"QuantumCircuitOperator", "[", 
    RowBox[{"\"\<Simon\>\"", "[", 
     RowBox[{"seq", " ", "=", " ", 
      RowBox[{"{", 
       RowBox[{"1", ",", " ", "0", ",", " ", "0", ",", " ", "1"}], "}"}]}], 
     "]"}], "]"}]}], ";"}]}], "Input",
 CellLabel->"In[5]:= ",ExpressionUUID->"5e36bca8-d8e1-4bb1-9801-87170dddefbb"],

