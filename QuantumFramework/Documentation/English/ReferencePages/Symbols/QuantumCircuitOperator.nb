Cell["Quantum circuit diagram", "ExampleSubsection",ExpressionUUID->"38677727-9fd1-4ffa-b6e3-75ab56d4a256"],

Cell["\<\
One can customize many features of a circuit diagram. See the Circuit Diagram \
documentation page for more details.\
\>", "ExampleText",ExpressionUUID->"8b640da1-a6f2-47ad-b044-ec54be941e06"],

Cell["Add custom wire labels and a measurement-wire label:", "ExampleText",ExpressionUUID->"b47aada4-51a4-4e8c-808b-f90bd0c6751e"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"QuantumCircuitOperator", "[", 
   RowBox[{"{", 
    RowBox[{"\"\<H\>\"", ",", " ", "\"\<CY\>\"", ",", " ", "\"\<H\>\"", ",", 
     " ", 
     RowBox[{"{", "1", "}"}]}], "}"}], "]"}], "[", 
  RowBox[{"\"\<Diagram\>\"", ",", " ", "\n", " ", 
   RowBox[{"\"\<WireLabels\>\"", " ", "->", " ", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{"Placed", "[", 
         RowBox[{"\"\<1st qubit\>\"", ",", " ", "Left"}], "]"}], ",", " ", 
        "\n", "    ", 
        RowBox[{"Placed", "[", 
         RowBox[{"\"\<Eigenvector of Y\>\"", ",", " ", "Right"}], "]"}]}], 
       "}"}], ",", " ", 
      RowBox[{"{", 
       RowBox[{"Placed", "[", 
        RowBox[{"\"\<2nd qubit\>\"", ",", " ", "Left"}], "]"}], "}"}]}], 
     "}"}]}], ",", " ", "\n", " ", 
   RowBox[{"\"\<MeasurementWireLabel\>\"", " ", "->", 
    " ", "\"\<Measurement Wire\>\""}]}], "]"}]], "Input",
 CellLabel->"In[1]:= ",ExpressionUUID->"6000940a-e41b-4dc5-8a58-2bd2ed861d48"],

