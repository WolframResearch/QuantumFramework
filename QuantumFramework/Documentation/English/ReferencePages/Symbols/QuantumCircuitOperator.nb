      RowBox[{"{", 
       RowBox[{"i", ",", " ", "p"}], "}"}]}], "]"}], ",", " ", 
    RowBox[{"Table", "[", 
     RowBox[{
      RowBox[{"\[Beta]", "[", "i", "]"}], ",", " ", 
