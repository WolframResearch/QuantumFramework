Cell[TextData[{
 "There are two solutions because the NOT of a solution is also a max/min (",
 Cell[BoxData[
  RowBox[{
   RowBox[{"(", 
    RowBox[{"-", 
     StyleBox["x", "TI"]}], ")"}], ".", 
   StyleBox["q", "TI"], ".", 
   RowBox[{"(", 
    RowBox[{"-", 
     StyleBox["x", "TI"]}], ")", "=", 
    StyleBox["x", "TI"]}], ".", 
   StyleBox["q", "TI"], ".", 
   StyleBox["x", "TI"]}]], "InlineFormula",ExpressionUUID->
  "2af03660-9e82-4dc4-9073-6dcc132becd2"],
 ")."
}], "ExampleText",ExpressionUUID->"6adb3504-b092-434b-a88c-891af21a6c78"],

Cell["\<\
Check that the classical maximizing solution matches the quantum one:\
\>", "ExampleText",ExpressionUUID->"98c5c00f-6697-40e0-b29d-148520fae12a"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"MemberQ", "[", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"#", "[", "\"\<Name\>\"", "]"}], " ", "&"}], " ", "/@", " ", 
    "\n", "  ", 
    RowBox[{"Keys", "[", 
     RowBox[{"TakeLargestBy", "[", 
      RowBox[{
       RowBox[{"Normal", "@", 
        RowBox[{"N", "[", 
         RowBox[{"weightedEnergy", " ", "/.", " ", "optMax"}], "]"}]}], ",", 
       " ", "Last", ",", " ", "2"}], "]"}], "]"}]}], ",", " ", "\n", " ", 
   RowBox[{"solMax", " ", "/.", " ", 
    RowBox[{
     RowBox[{"-", "1"}], " ", "->", " ", "0"}]}]}], "]"}]], "Input",
 CellLabel->
  "In[15]:= ",ExpressionUUID->"a70e90d1-bf81-4fef-b9bc-6e02f1d73883"],

Cell[BoxData["False"], "Output",
 CellLabel->
  "Out[15]= ",ExpressionUUID->"c4236fe0-8524-4b83-9bf2-8a5eeb3009de"]
}, Open  ]],

Cell["And likewise for the minimizing solution:", "ExampleText",ExpressionUUID->"052387d8-3234-462f-89f3-7d0b015447db"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"MemberQ", "[", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"#", "[", "\"\<Name\>\"", "]"}], " ", "&"}], " ", "/@", " ", 
    "\n", "  ", 
    RowBox[{"Keys", "[", 
     RowBox[{"TakeSmallestBy", "[", 
      RowBox[{
       RowBox[{"Normal", "@", 
        RowBox[{"N", "[", 
         RowBox[{"weightedEnergy", " ", "/.", " ", "optMin"}], "]"}]}], ",", 
       " ", "Last", ",", " ", "2"}], "]"}], "]"}]}], ",", " ", "\n", " ", 
   RowBox[{"solMin", " ", "/.", " ", 
    RowBox[{
     RowBox[{"-", "1"}], " ", "->", " ", "0"}]}]}], "]"}]], "Input",
 CellLabel->
  "In[16]:= ",ExpressionUUID->"6e88a8c3-6d30-4e57-89cd-5b378475e579"],

Cell[BoxData["True"], "Output",
 CellLabel->
  "Out[16]= ",ExpressionUUID->"4fb5c7b5-5593-4cf9-8d73-3cb8a9e3232d"]
}, Open  ]]
}, Closed]],

Cell[CellGroupData[{

Cell["Harrow-Hassidim-Lloyd (HHL) algorithm", "ExampleSubsection",ExpressionUUID->"d156de21-2108-4518-a5c8-0c531dd3c892"],

Cell[TextData[{
 "Given a matrix ",
 StyleBox["A", "TI"],
 " and a vector ",
 StyleBox["b", "TI"],
 ", we want to solve ",
 Cell[BoxData[
  RowBox[{
   StyleBox["A", "TI"], 
   StyleBox["\[CenterDot]", "TI"], 
   StyleBox["x", "TI"], "=", 
   StyleBox["b", "TI"]}]], "InlineFormula",ExpressionUUID->
  "0832235e-22bc-4d42-b8a2-760fd1bcc324"],
 "."
}], "ExampleText",ExpressionUUID->"0b7dc8e3-7a34-48cf-a79e-dfe49eecc8d6"],

Cell[TextData[{
 "Define a function that generates an HHL circuit from ",
 StyleBox["A", "TI"],
 ", ",
 StyleBox["b", "TI"],
 ", and a number of ancillary qubits:"
}], "ExampleText",ExpressionUUID->"886c7f41-45e2-4a3b-8b66-017a375ecf1f"],

Cell[BoxData[{
 RowBox[{"ClearAll", "[", "HHL", "]"}], "\n", 
 RowBox[{
  RowBox[{"HHL", "[", 
   RowBox[{
    RowBox[{"A_", "?", "SquareMatrixQ"}], ",", " ", 
    RowBox[{"b_", "?", "VectorQ"}], ",", " ", 
    RowBox[{"prec", " ", ":", " ", 
     RowBox[{"_Integer", "?", "Positive"}], " ", ":", " ", "4"}]}], "]"}], 
  " ", ":=", "\n", " ", 
  RowBox[{"Block", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
     "d", ",", " ", "qpe", ",", " ", "t0", ",", " ", "\n", "   ", "yTilde", ",",
       " ", "\[Lambda]Tilde", ",", " ", "\[Theta]\[Lambda]", ",", " ", 
      "\[Gamma]"}], "}"}], ",", "\n", "  ", 
    RowBox[{
     RowBox[{"d", " ", "=", " ", 
      RowBox[{"Log2", "@", 
       RowBox[{"Length", "[", "b", "]"}]}]}], ";", "\n", "  ", 
     RowBox[{"t0", " ", "=", " ", 
      RowBox[{
       RowBox[{"Floor", "@", "\[Pi]"}], "/", 
       RowBox[{"Norm", "[", "A", "]"}]}]}], ";", "\n", "  ", 
     RowBox[{"yTilde", " ", "=", " ", "\n", "   ", 
      RowBox[{
       RowBox[{
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{"0", " ", "<=", " ", "#", " ", "<=", " ", 
           RowBox[{"2", "^", 
            RowBox[{"(", 
             RowBox[{"prec", " ", "-", " ", "1"}], ")"}]}]}], ",", " ", "#", ",",
           " ", 
          RowBox[{"#", " ", "-", " ", 
           RowBox[{"2", "^", "prec"}]}]}], "]"}], " ", "&"}], " ", "/@", " ", 
       
       RowBox[{"Range", "[", 
        RowBox[{"0", ",", " ", 
         RowBox[{
          RowBox[{"2", "^", "prec"}], " ", "-", " ", "1"}]}], "]"}]}]}], ";", 
     "\n", "  ", 
     RowBox[{"\[Lambda]Tilde", " ", "=", " ", 
      RowBox[{
       RowBox[{
        RowBox[{"(", 
         RowBox[{"2", " ", "\[Pi]"}], ")"}], "/", "t0"}], " ", 
       RowBox[{"yTilde", "/", 
        RowBox[{"2", "^", "prec"}]}]}]}], ";", "\n", "  ", 
     RowBox[{"\[Gamma]", " ", "=", " ", 
      RowBox[{"Min", "[", 
       RowBox[{"DeleteCases", "[", 
        RowBox[{
         RowBox[{"Abs", "[", "\[Lambda]Tilde", "]"}], ",", " ", 
         RowBox[{"0.", " ", "|", " ", "0"}]}], "]"}], "]"}]}], ";", "\n", 
     "  ", 
     RowBox[{"\[Theta]\[Lambda]", " ", "=", " ", "\n", "   ", 
      RowBox[{
       RowBox[{
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"#", " ", "==", " ", "0"}], " ", "||", " ", 
           RowBox[{"#", " ", "==", " ", "0."}]}], ",", " ", "0.", ",", " ", 
          RowBox[{"2", " ", 
           RowBox[{"ArcSin", "[", 
            RowBox[{"\[Gamma]", "/", "#"}], "]"}]}]}], "]"}], " ", "&"}], " ",
        "/@", " ", "\[Lambda]Tilde"}]}], ";", "\n", "  ", 
     RowBox[{
      RowBox[{"QuantumCircuitOperator", "[", 
       RowBox[{"{", "\n", "     ", 
        RowBox[{
         RowBox[{
          RowBox[{"QuantumState", "[", 
           RowBox[{"Normalize", "[", "b", "]"}], "]"}], " ", "->", " ", 
          RowBox[{"1", " ", "+", " ", "prec", " ", "+", " ", 
           RowBox[{"Range", "[", "d", "]"}]}]}], ",", "\n", 
         "     ", "\"\<Barrier\>\"", ",", "\n", "     ", 
         RowBox[{"qpe", " ", "=", " ", "\n", "      ", 
          RowBox[{
           RowBox[{"QuantumCircuitOperator", "[", "\n", "        ", 
            RowBox[{
             RowBox[{"\"\<PhaseEstimation\>\"", "[", 
              RowBox[{
               RowBox[{"QuantumOperator", "[", 
                RowBox[{"MatrixExp", "[", 
                 RowBox[{"t0", " ", "I", " ", "A"}], "]"}], "]"}], ",", " ", 
               "prec"}], "]"}], ",", " ", "\n", "        ", 
             RowBox[{"1", " ", "+", " ", 
              RowBox[{"Range", "[", 
               RowBox[{"prec", " ", "+", " ", "d"}], "]"}]}]}], "]"}], "[", 
           RowBox[{"[", 
            RowBox[{
             RowBox[{"d", " ", "+", " ", "1"}], " ", ";;", " ", 
             RowBox[{
              RowBox[{"-", "prec"}], " ", "-", " ", "1"}]}], "]"}], "]"}]}], ",",
          "\n", "     ", "\"\<Barrier\>\"", ",", "\n", "     ", 
         RowBox[{"QuantumCircuitOperator", "[", 
          RowBox[{
           RowBox[{"\"\<GrayOracle\>\"", "[", 
            RowBox[{"\[Theta]\[Lambda]", ",", " ", "prec", ",", " ", "1"}], 
            "]"}], ",", " ", "\n", "      ", "\"\<Eigenvalue Inversion\>\""}],
           "]"}], ",", "\n", "     ", "\"\<Barrier\>\"", ",", "\n", "     ", 
         RowBox[{"qpe", "[", "\"\<Dagger\>\"", "]"}], ",", "\n", 
         "     ", "\"\<Barrier\>\"", ",", "\n", "     ", 
         RowBox[{"QuantumOperator", "[", "\n", "      ", 
          RowBox[{
           RowBox[{"QuantumState", "[", 
            RowBox[{"\"\<1\>\"", " ", "<>", " ", 
             RowBox[{"StringJoin", "[", 
              RowBox[{"ConstantArray", "[", 
               RowBox[{"\"\<0\>\"", ",", " ", "prec"}], "]"}], "]"}]}], "]"}],
            "[", "\n", "       ", "\"\<Dagger\>\"", "]"}], "]"}]}], "\n", 
        "     ", "}"}], "\n", "    ", "]"}], " ", "/;", " ", 
      RowBox[{"IntegerQ", "[", "d", "]"}]}]}]}], "\n", "  ", 
   "]"}]}]}], "Input",
 CellLabel->"In[1]:= ",ExpressionUUID->"70a1fe7a-0b79-458c-83d2-f0e02c52de72"],

Cell[TextData[{
 "Generate a complex-valued random Hermitian matrix on ",
 StyleBox["n", "TI"],
 " = 4 qubits (size ",
 Cell[BoxData[
  RowBox[{
   SuperscriptBox["2", 
    StyleBox["n", "TI"]], "\[Times]", 
   SuperscriptBox["2", 
    StyleBox["n", "TI"]]}]], "InlineFormula",ExpressionUUID->
  "4815f452-b4c3-4850-8b5c-cd638ba90872"],
 "):"
}], "ExampleText",ExpressionUUID->"63ccea26-f652-4edb-9013-2cd2bb0e9856"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"n", " ", "=", " ", "4"}], ";"}], "\n", 
 RowBox[{
  RowBox[{"a", " ", "=", " ", 
   RowBox[{
    RowBox[{"QuantumOperator", "[", 
     RowBox[{"\"\<RandomHermitian\>\"", ",", " ", "n"}], "]"}], 
    "[", "\"\<Matrix\>\"", "]"}]}], ";"}]}], "Input",
 CellLabel->"In[2]:= ",ExpressionUUID->"0079859f-fabd-4d5d-a188-60fd8620c3b1"],

Cell["Confirm it is Hermitian:", "ExampleText",ExpressionUUID->"66318301-7156-408d-8c99-c8bda5618469"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"HermitianMatrixQ", "[", "a", "]"}]], "Input",
 CellLabel->"In[3]:= ",ExpressionUUID->"9d58e8f5-2b18-4c23-bcb5-6c6e2856388a"],

Cell[BoxData["True"], "Output",
 CellLabel->"Out[3]= ",ExpressionUUID->"257e6003-9022-41f8-96fc-14a7ac06ab91"]
}, Open  ]],

Cell[TextData[{
 "Generate a complex-valued random vector ",
 StyleBox["b", "TI"],
 ":"
}], "ExampleText",ExpressionUUID->"124794fe-04da-41b1-a881-3f7703f2651f"],

Cell[BoxData[
 RowBox[{
  RowBox[{"b", " ", "=", " ", 
   RowBox[{
    RowBox[{
     RowBox[{"QuantumOperator", "[", 
      RowBox[{"\"\<RandomUnitary\>\"", ",", " ", "n"}], "]"}], 
     "[", "\"\<Matrix\>\"", "]"}], "[", 
    RowBox[{"[", 
     RowBox[{"All", ",", " ", "1"}], "]"}], "]"}]}], ";"}]], "Input",
 CellLabel->"In[4]:= ",ExpressionUUID->"b3128a1d-bfe7-4437-8323-2467336ae6fa"],

