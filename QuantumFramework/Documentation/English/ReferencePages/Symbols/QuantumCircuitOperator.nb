Cell["\<\
Given all Boolean functions with two variables, show number of True and False \
in their solutions, and also corresponding Deutsch-Jozsa probabilities:\
\>", "ExampleText",ExpressionUUID->"b3aa7186-db14-42c7-a61d-66ffa5175d51"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Grid", "[", 
  RowBox[{
   RowBox[{"Prepend", "[", "\n", "  ", 
    RowBox[{
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{"With", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"bf", " ", "=", " ", "\n", "      ", 
           RowBox[{"BooleanFunction", "[", 
            RowBox[{"f", ",", " ", "2"}], "]"}]}], "}"}], ",", " ", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{
            RowBox[{"BooleanConvert", "[", "\n", "       ", "bf", "]"}], "[", 
            
            RowBox[{"\[FormalX]", ",", " ", "\[FormalY]"}], "]"}], ",", " ", 
           RowBox[{
            RowBox[{"Count", "[", "True", "]"}], "[", 
            RowBox[{"BooleanTable", "[", "bf", "]"}], "]"}], ",", " ", "\n", 
           "     ", 
           RowBox[{
            RowBox[{"Count", "[", "False", "]"}], "[", 
            RowBox[{"BooleanTable", "[", "bf", "]"}], "]"}], ",", " ", "\n", 
           "     ", 
           RowBox[{"With", "[", 
            RowBox[{
             RowBox[{"{", 
              RowBox[{"rs", " ", "=", " ", "\n", "        ", 
               RowBox[{
                RowBox[{
                 RowBox[{"QuantumCircuitOperator", "[", 
                  RowBox[{"\"\<DeutschJozsa\>\"", "[", "bf", "]"}], "]"}], "[",
                  "]"}], "[", "\"\<Probabilities\>\"", "]"}]}], "}"}], ",", 
             "\n", "       ", 
             RowBox[{"BarChart", "[", 
              RowBox[{"rs", ",", " ", 
               RowBox[{"ChartLabels", " ", "->", " ", 
                RowBox[{"Keys", "[", "rs", "]"}]}], ",", " ", 
               RowBox[{"AspectRatio", " ", "->", " ", 
                RowBox[{"1", "/", "3"}]}], ",", " ", "\n", "       ", 
               RowBox[{"ImageSize", " ", "->", " ", "Small"}]}], "]"}]}], 
            "]"}]}], "}"}]}], "]"}], ",", " ", 
       RowBox[{"{", 
        RowBox[{"f", ",", " ", "0", ",", " ", "15"}], "}"}]}], "]"}], ",", 
     " ", "\n", "  ", 
     RowBox[{
      RowBox[{
       RowBox[{"Style", "[", 
        RowBox[{"#", ",", " ", "Bold"}], "]"}], " ", "&"}], " ", "/@", " ", 
      RowBox[{"{", 
       RowBox[{"\"\<Boolean function\>\"", ",", " ", "\"\<True\>\"", ",", 
        " ", "\"\<False\>\"", ",", " ", "\n", 
        "    ", "\"\<Deutsch-Jozsa probabilities\>\""}], "}"}]}]}], "]"}], ",",
    " ", 
   RowBox[{"Frame", " ", "->", " ", "All"}], ",", " ", "\n", " ", 
   RowBox[{"Alignment", " ", "->", " ", 
    RowBox[{"{", 
     RowBox[{"{", 
      RowBox[{
      "Left", ",", " ", "Center", ",", " ", "Center", ",", " ", "Center"}], 
      "}"}], "}"}]}]}], "]"}]], "Input",
 CellLabel->"In[7]:= ",ExpressionUUID->"f62c9807-aafd-4d4c-b193-f96299d6c147"],

