     " or ",
     Cell[BoxData[
      RowBox[{"\"\<C\>\"", "[", 
       RowBox[{"qc", ",", "c1", ",", "c0"}], "]"}]], "InlineFormula",
      ExpressionUUID->"17dfbf2d-9ae3-4c97-bd6f-24a066ed156c"]
    }], "TableText",ExpressionUUID->"c20fc63f-5281-4510-bd7f-9776cb867ca7"], 
    Cell["\<\
the controlled version of a circuit qc, controlled on the c1 qubits (value 1) \
and the c0 qubits (value 0)\
\>", "TableText",ExpressionUUID->"9d4a35ab-a0ec-4e11-ad1a-56d730f6c2fc"]},
   {Cell["      ", "ModInfo",ExpressionUUID->
     "26fc1dff-b6ff-4f63-a1c8-68c1b5cf2df9"], Cell[TextData[Cell[BoxData[
     RowBox[{"\"\<Multiplexer\>\"", "[", 
      RowBox[{"op1", ",", "op2", ",", "..."}], "]"}]], "InlineFormula",
     ExpressionUUID->"a62a6eef-e4ba-4935-8608-5218dd426734"]], "TableText",
     ExpressionUUID->"6c2cf02a-eaac-451c-a465-56cd7567e8f0"], Cell["\<\
a multiplexer (uniformly-controlled gate): applies the operator selected by \
the binary value of the control qubits\
\>", "TableText",ExpressionUUID->"411ce0eb-1584-432c-b365-ce9cdf5373f3"]},
   {Cell["      ", "ModInfo",ExpressionUUID->
     "fee3d882-a38a-4467-9f41-81074acf1498"], Cell[TextData[Cell[BoxData[
     RowBox[{"\"\<ControlledMultiplexer\>\"", "[", 
      RowBox[{"m", ",", "v"}], "]"}]], "InlineFormula",ExpressionUUID->
     "d372a605-3b5d-4041-ad61-4b6def9798b3"]], "TableText",ExpressionUUID->
     "2d9ca246-1ca5-474d-8c5d-a997bc576748"], Cell["\<\
the multiplexer-based linear-solver circuit produced by QuantumLinearSolve \
for a matrix m and vector v\
\>", "TableText",ExpressionUUID->"533bbdee-cf9f-4f83-93b4-dfb2cf355ac8"]},
   {Cell["      ", "ModInfo",ExpressionUUID->
     "f86dc852-088b-4b65-b8c3-ad864c4eadae"], Cell[TextData[Cell[BoxData[
     RowBox[{"\"\<Switch\>\"", "[", 
      RowBox[{"a", ",", "b"}], "]"}]], "InlineFormula",ExpressionUUID->
     "e02613c1-3b7b-4b02-adef-bc9d6782c5e1"]], "TableText",ExpressionUUID->
     "7df628fa-9330-4a23-abd2-18873f779c28"], Cell["\<\
quantum-switch circuit of two operators a and b (their order of application \
coherently controlled)\
\>", "TableText",ExpressionUUID->"8f61b644-6ee2-43d3-9500-c458c1839016"]},
   {Cell["      ", "ModInfo",ExpressionUUID->
     "9a286ebf-cd88-4818-926a-a91c912aa46b"], Cell[TextData[Cell[
    BoxData["\"\<CHSH\>\""], "InlineFormula",ExpressionUUID->
     "44d5e67c-76cd-49ed-8c7e-df5abe9e2938"]], "TableText",ExpressionUUID->
     "dd403dac-2446-430c-8b6d-4978b19df9a4"], Cell[TextData[{
     "CHSH Bell-test circuit with measurement angle ",
     Cell[BoxData[
     "\[Theta]"], "InlineFormula",ExpressionUUID->
      "3b928d8c-0611-484f-a419-d79a47c64ff1"],
     " (default ",
     Cell[BoxData[
      FractionBox["\[Pi]", "4"]], "InlineFormula",ExpressionUUID->
      "e587d1f7-d567-4708-b1d4-18e1b68db0cd"],
     ")"
    }], "TableText",ExpressionUUID->"338ef88a-8e64-4a90-9319-9b73ba4657ea"]},
   {Cell["      ", "ModInfo",ExpressionUUID->
     "c4ab908c-ef7a-44fc-901b-58facc370a31"], Cell[TextData[Cell[
    BoxData["\"\<LeggettGarg\>\""], "InlineFormula",ExpressionUUID->
     "2f2f2c4a-dac8-4b05-b6d8-c329424c13bd"]], "TableText",ExpressionUUID->
     "51835025-e771-4890-846a-6e3908597f16"], Cell[TextData[{
     "Leggett-Garg circuit for the Leggett-Garg inequality, with measurement \
angle ",
     Cell[BoxData[
     "\[Theta]"], "InlineFormula",ExpressionUUID->
      "0eb29d78-420e-4a52-9aaf-eae5306a8e68"],
     " (default ",
     Cell[BoxData[
      FractionBox["\[Pi]", "4"]], "InlineFormula",ExpressionUUID->
      "16b33e1a-0b59-48c8-9111-99286a08e5b6"],
     ")"
    }], "TableText",ExpressionUUID->"6e9aa51e-a18f-4462-b647-e89f2b95d493"]},
   {Cell["      ", "ModInfo",ExpressionUUID->
     "99b081af-1e68-4e76-824c-9c5d7817bc81"], Cell[TextData[Cell[
    BoxData["\"\<WignerCHSH\>\""], "InlineFormula",ExpressionUUID->
     "bc1f592e-5ac0-4673-b9ee-eae5abc5d60a"]], "TableText",ExpressionUUID->
     "38344f45-5c54-4788-bcec-ad34aa5aa655"], Cell[TextData[{
     "CHSH circuit in the Wigner (WignerMIC) basis, with measurement angle ",
     Cell[BoxData[
