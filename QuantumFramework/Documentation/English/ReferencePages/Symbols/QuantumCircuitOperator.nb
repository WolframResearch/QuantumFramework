Cell["\<\
Read off the most probable measurement outcome as a bit-string:\
\>", "ExampleText",ExpressionUUID->"0c89bef0-25c9-40a9-bc21-59018976d514"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"bits1", " ", "=", " ", 
  RowBox[{
   RowBox[{
    RowBox[{"Keys", "[", 
     RowBox[{"TakeLargest", "[", 
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{"N", "[", "qc", "]"}], "[", "]"}], 
        "[", "\"\<Probabilities\>\"", "]"}], ",", " ", "1"}], "]"}], "]"}], "[", 
    RowBox[{"[", "1", "]"}], "]"}], "[", "\"\<Name\>\"", "]"}]}]], "Input",
 CellLabel->"In[31]:=",ExpressionUUID->"e396f106-5ce4-49d9-bd3d-a0e2a278ea8a"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"0", ",", "1", ",", "0", ",", "0"}], "}"}]], "Output",
 CellChangeTimes->{3.990103243837554*^9, 3.990103524396937*^9, 
  3.990103667449194*^9},
 CellLabel->"Out[31]=",
 CellID->1968876202,ExpressionUUID->"cde563ae-e18e-4672-96b8-bd6126bc68d7"]
}, Open  ]],

Cell[TextData[{
 "Read its bitstring as the integer ",
 Cell[BoxData[
  FormBox["j", TraditionalForm]],ExpressionUUID->
  "1d92e7e3-d10b-45b7-9f81-6077cfd28304"],
 ", then estimate the eigenphase using ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SuperscriptBox["2", "n"], "\[Theta]"}], "\[TildeTilde]", "j"}], 
   TraditionalForm]],ExpressionUUID->"c2e04346-6157-4fea-8600-e95fedd8fc5f"],
 ":"
}], "ExampleText",
 CellChangeTimes->{{3.990103555557963*^9, 
  3.9901035704334507`*^9}},ExpressionUUID->"baabfd6c-dc92-4000-826a-\
1986ee9cd1cb"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"est1", " ", "=", " ", 
  RowBox[{
   RowBox[{
    RowBox[{"FromDigits", "[", 
     RowBox[{"bits1", ",", " ", "2"}], "]"}], "/", 
    RowBox[{"2", "^", "4"}]}], " ", "//", " ", "N"}]}]], "Input",
 CellLabel->"In[32]:=",ExpressionUUID->"1cd22aed-a955-4c00-a694-0b198451993a"],

Cell[BoxData["0.25`"], "Output",
 CellChangeTimes->{3.990103245801508*^9, 3.990103526062189*^9, 
  3.990103667492478*^9},
 CellLabel->"Out[32]=",
 CellID->326810391,ExpressionUUID->"7d24b1fa-8a86-48e7-b4fb-141c3b0e1a16"]
}, Open  ]],

