Cell[TextData[{
 "Fourier circuit transforms computational basis into momentum (Pauli-X) \
basis. Check ",
 Cell[BoxData[
  RowBox[{"|", "00", "\[RightAngleBracket]"}]], "InlineFormula",
  ExpressionUUID->"c4a93c82-ae27-4c84-a25e-a1f6b3adb99b"],
 " is transformed into ",
 Cell[BoxData[
  RowBox[{"|", 
   RowBox[{
    SubscriptBox[
     StyleBox["x", "TI"], "+"], 
    SubscriptBox[
     StyleBox["x", "TI"], "+"]}], "\[RightAngleBracket]"}]], "InlineFormula",
  ExpressionUUID->"42bd5215-32b8-4923-a036-051c31c14bd2"],
 ":"
}], "ExampleText",ExpressionUUID->"96df3345-9a2a-4bdc-8ba6-360405715d03"],

