Cell[TextData[{
 "InverseFourier circuit transforms from the momentum (Pauli-X) basis back \
into the computational basis. Check ",
 Cell[BoxData[
  RowBox[{"|", 
   RowBox[{
    SubscriptBox[
     StyleBox["x", "TI"], "+"], 
    SubscriptBox[
     StyleBox["x", "TI"], "+"]}], "\[RightAngleBracket]"}]], "InlineFormula",
  ExpressionUUID->"f1faacd7-8a99-4787-b3d3-096635612e04"],
 " is transformed into ",
 Cell[BoxData[
  RowBox[{"|", "00", "\[RightAngleBracket]"}]], "InlineFormula",
  ExpressionUUID->"28aa296e-f338-44a1-9485-cf41c47b305a"],
 ":"
}], "ExampleText",ExpressionUUID->"48388122-818c-4e8f-b637-e6dd3184d782"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"QuantumCircuitOperator", "[", "\"\<InverseFourier\>\"", "]"}], "[", 
   RowBox[{"QuantumState", "[", "\"\<++\>\"", "]"}], "]"}], "//", 
  "TraditionalForm"}]], "Input",
 CellChangeTimes->{{3.990103192981717*^9, 3.990103194152093*^9}},
 CellLabel->"In[2]:=",ExpressionUUID->"392f453b-fd42-4855-be74-399149d6635f"],

Cell[BoxData[
 FormBox[
  InterpretationBox[
   TooltipBox[
    StyleBox[
     FormBox[
      InterpretationBox[
       StyleBox[
        TemplateBox[{
          RowBox[{
            FormBox["0", TraditionalForm], "\[InvisibleSpace]", 
