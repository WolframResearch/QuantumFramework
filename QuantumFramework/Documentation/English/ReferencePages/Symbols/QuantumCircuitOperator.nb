     "fdafefdb-acca-4175-a472-9dc92074aa0e"]], "TableText",ExpressionUUID->
     "c60da17b-f77f-4018-ae8c-69d4b4a87dab"], Cell[
    "the circuit in OpenQASM 3.0", "TableText",ExpressionUUID->
     "6eb9041b-1e6d-47d2-8ee3-d2fc4fa4a73b"]},
   {Cell["      ", "ModInfo",ExpressionUUID->
     "3bbd7da2-295b-4914-bd84-288ad6172de5"], Cell[TextData[{
