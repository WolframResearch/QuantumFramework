 RowBox[{
  RowBox[{"aliceQubits", " ", "=", " ", 
   RowBox[{"aliceProtocol", " ", "/@", " ", 
    RowBox[{"Thread", "[", 
     RowBox[{"List", "[", 
      RowBox[{"aliceBits", ",", " ", "aliceBases"}], "]"}], "]"}]}]}], 
  ";"}]], "Input",
 CellLabel->"In[5]:= ",ExpressionUUID->"b681292e-9266-4c64-9e83-84a7ffb88059"],

