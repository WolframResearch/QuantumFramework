Cell[CellGroupData[{

Cell["\t", "ExampleDelimiter",ExpressionUUID->"bf670022-6339-4466-8af6-1c7f93369ae1"],

Cell["\<\
A quantum circuit can include many kinds of quantum objects: here a state, \
gates, a noise channel, a phase, and measurements:\
\>", "ExampleText",ExpressionUUID->"7a9f7ec8-3084-43a0-8cd3-903c38cb2bfe"],

Cell[BoxData[
 RowBox[{
  RowBox[{"qc", " ", "=", " ", 
   RowBox[{"QuantumCircuitOperator", "[", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"QuantumState", "[", 
       RowBox[{"\"\<Bell\>\"", ",", " ", 
        RowBox[{"\"\<Label\>\"", " ", "->", " ", "\"\<Bell\>\""}]}], "]"}], ",",
       " ", "\n", "    ", "\"\<XY\>\"", ",", " ", 
      RowBox[{"\"\<C\>\"", "[", 
       RowBox[{"\"\<RY\>\"", "[", 
        RowBox[{"\[Pi]", "/", "4"}], "]"}], "]"}], ",", " ", 
      RowBox[{"\"\<BitFlip\>\"", "[", ".3", "]"}], ",", " ", 
      RowBox[{"\"\<H\>\"", " ", "->", " ", "2"}], ",", " ", "\n", "    ", 
      RowBox[{
       RowBox[{"\"\<P\>\"", "[", 
        RowBox[{"\[Pi]", "/", "3"}], "]"}], " ", "->", " ", "2"}], ",", " ", 
      RowBox[{"{", "1", "}"}], ",", " ", 
      RowBox[{
       RowBox[{"\"\<M\>\"", "[", "\"\<X\>\"", "]"}], " ", "->", " ", "2"}]}], 
     "}"}], "]"}]}], ";"}]], "Input",
 CellChangeTimes->{{3.990102519214283*^9, 3.990102523226358*^9}},
 CellLabel->"In[1]:=",ExpressionUUID->"bbb1ff32-2026-43c1-9393-fdb9ff1b6b0c"],

