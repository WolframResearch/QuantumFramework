Cell["Quantum Approximate Optimization Algorithm  (QAOA)", "ExampleSubsection",ExpressionUUID->"3b6dbea8-9257-454f-90cf-9eec705e689b"],

Cell[TextData[{
 "One can find a binary vector ",
 Cell[BoxData[
  StyleBox["x", "TI"]], "InlineFormula",ExpressionUUID->
  "57aa3604-f78d-4bde-b067-faf2f1e8c155"],
 " that minimizes (or maximizes) the quadratic objective ",
 Cell[BoxData[
  RowBox[{
   StyleBox["x", "TI"], ".", 
   StyleBox["q", "TI"], ".", 
   RowBox[{
    StyleBox["x", "TI"], "+", 
    StyleBox["c", "TI"]}], ".", 
   StyleBox["x", "TI"]}]], "InlineFormula",ExpressionUUID->
  "441ffbfa-c493-4999-9763-6a38ecc5c497"],
 ", with no constraints. This is usually called Quadratic Unconstrained \
Binary Optimization (QUBO). The linear term ",
 Cell[BoxData[
  StyleBox["c", "TI"]], "InlineFormula",ExpressionUUID->
  "dcd0752c-6999-4271-a1d1-123f252c7068"],
 " can be dropped without losing generality."
}], "ExampleText",ExpressionUUID->"0675fba0-d90d-4ee3-89eb-890042f3a1f6"],

Cell[TextData[{
 "Define a ",
 Cell[BoxData[
  RowBox[{"4", "\[Times]", "4"}]], "InlineFormula",ExpressionUUID->
  "0dfca73d-f296-400a-9c6a-e8d6ca2b1978"],
 " real-valued upper-triangular objective matrix:"
}], "ExampleText",ExpressionUUID->"87e41e2b-2b8c-45d1-a8c2-6b0e9d0b5606"],

