Cell["\<\
Create a quantum circuit composed of only single qubit gates:\
\>", "ExampleText",ExpressionUUID->"cece0a85-adf9-4d18-858d-6f5238ccdbe5"],

Cell[BoxData[
 RowBox[{
  RowBox[{"qc", " ", "=", " ", 
   RowBox[{"QuantumCircuitOperator", "[", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"QuantumOperator", "[", "\"\<X\>\"", "]"}], ",", " ", "\n", 
      "    ", 
      RowBox[{"QuantumOperator", "[", 
       RowBox[{"\"\<Y\>\"", ",", " ", 
        RowBox[{"{", "2", "}"}]}], "]"}]}], "}"}], "]"}]}], ";"}]], "Input",
 CellLabel->"In[1]:= ",ExpressionUUID->"05e9d539-eebf-4417-908a-ca9f15c5abca"],

