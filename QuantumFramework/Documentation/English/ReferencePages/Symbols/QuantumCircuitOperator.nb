}, Open  ]],

Cell[TextData[{
 "Find corresponding eigenvalues (note they should be in the form ",
 Cell[BoxData[
  SuperscriptBox[
   StyleBox["e", "TI"], 
   RowBox[{
    StyleBox["i", "TI"], " ", "2", "\[Pi]", " ", 
    StyleBox["\[Lambda]", "TI"]}]]], "InlineFormula",ExpressionUUID->
  "76cf7ec3-0983-4318-914e-b980643e934f"],
 "):"
}], "ExampleText",ExpressionUUID->"a2db9541-b4fa-4f89-9d69-52261e3a019b"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"\[Lambda]", " ", "=", " ", 
  RowBox[{"Mod", "[", 
