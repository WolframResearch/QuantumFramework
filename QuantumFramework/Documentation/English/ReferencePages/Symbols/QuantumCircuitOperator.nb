      RowBox[{"\"\<QuantumState\>\"", "[", "qs", "]"}]], "InlineFormula",
      ExpressionUUID->"c3dd6767-cdd4-432b-ad75-e4e72715b194"],
     " or ",
     Cell[BoxData[
