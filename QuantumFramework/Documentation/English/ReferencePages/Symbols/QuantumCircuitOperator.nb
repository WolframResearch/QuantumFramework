Cell["Return the list of IBM-quantum backends and their queue:", "ExampleText",ExpressionUUID->"da58d00d-8a85-489b-971a-cbfb2a167a8c"],

Cell[BoxData[
 RowBox[{
  RowBox[{"ServiceConnect", "[", 
   RowBox[{"\"\<IBMQ\>\"", ",", " ", "\"\<New\>\""}], "]"}], 
  "[", "\"\<BackendQueue\>\"", "]"}]], "Input",ExpressionUUID->"4adebe43-89cb-\
45c7-a11f-453f8a70d65e"],

Cell["AWSBraket as Qiskit provider on a specific backend:", "ExampleText",ExpressionUUID->"6050678a-0a3b-43bb-b915-1c86d37db02f"],

Cell[BoxData[
 RowBox[{
  RowBox[{"QuantumCircuitOperator", "[", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"QuantumOperator", "[", 
      RowBox[{"\"\<RandomUnitary\>\"", ",", " ", 
       RowBox[{"Range", "[", "5", "]"}]}], "]"}], ",", " ", "\n", "   ", 
     RowBox[{"Range", "[", "5", "]"}]}], "}"}], "]"}], "[", 
  RowBox[{"Method", " ", "->", " ", 
   RowBox[{"{", 
    RowBox[{"\"\<Qiskit\>\"", ",", " ", 
     RowBox[{"\"\<Provider\>\"", " ", "->", " ", "\"\<AWSBraket\>\""}], ",", 
     " ", "\n", "   ", 
     RowBox[{"\"\<Backend\>\"", " ", "->", " ", "backend"}]}], "}"}]}], 
  "]"}]], "Input",ExpressionUUID->"6ef78033-793f-4aea-9208-a8b7dc581733"],

Cell["Connect to AWS:", "ExampleText",ExpressionUUID->"26ae6422-0f3f-4818-a4d1-6a14a0caf86b"],

Cell[BoxData[
 RowBox[{
  RowBox[{"aws", " ", "=", " ", 
   RowBox[{"ServiceConnect", "[", "\"\<AWS\>\"", "]"}]}], ";"}]], "Input",Expr\
essionUUID->"3490f403-a0e0-47d8-8f25-5326b46c39fe"],

Cell["Get the Braket service:", "ExampleText",ExpressionUUID->"e1817028-ea84-428f-8dcf-856a79457705"],

Cell[BoxData[
 RowBox[{
  RowBox[{"braket", " ", "=", " ", 
   RowBox[{"ServiceExecute", "[", 
    RowBox[{"aws", ",", " ", "\"\<GetService\>\"", ",", " ", 
     RowBox[{"{", 
      RowBox[{"\"\<Name\>\"", " ", "->", " ", "\"\<Braket\>\""}], "}"}]}], 
    "]"}]}], ";"}]], "Input",ExpressionUUID->"f419608f-c6eb-47da-be36-\
61043a4b12a9"],

Cell["List the available Braket devices:", "ExampleText",ExpressionUUID->"cccdd853-5ac0-4126-a2c9-b4824ef7d1b7"],

Cell[BoxData[
 RowBox[{"devices", " ", "=", " ", 
  RowBox[{
   RowBox[{"braket", "[", 
    RowBox[{"\"\<SearchDevices\>\"", ",", " ", 
     RowBox[{"\"\<Filters\>\"", " ", "->", " ", 
      RowBox[{"{", "}"}]}]}], "]"}], "[", 
   RowBox[{"\"\<Devices\>\"", ",", " ", "All"}], "]"}]}]], "Input",ExpressionU\
UID->"bbd7c70e-378f-4975-a0ee-4fa44326d6a8"],

Cell["\<\
For some circuit constructions, users can connect to Classiq:\
\>", "ExampleText",ExpressionUUID->"761cedd0-9ed9-4f81-86ac-ef3b70d4dd32"],

Cell[BoxData[
 RowBox[{
  RowBox[{"qc", " ", "=", " ", 
   RowBox[{"QuantumCircuitOperator", "[", "\n", "   ", 
    RowBox[{
     RowBox[{
      RowBox[{"QuantumState", "[", 
       RowBox[{"RandomReal", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"0", ",", " ", "1"}], "}"}], ",", " ", 
         RowBox[{"2", "^", "3"}]}], "]"}], "]"}], "[", "\"\<Normalized\>\"", 
      "]"}], ",", " ", "\n", "   ", 
     RowBox[{"Method", " ", "->", " ", "\"\<Classiq\>\""}]}], "]"}]}], 
  ";"}]], "Input",ExpressionUUID->"9854a644-47db-4c4b-ac81-e31f1e261a37"],

