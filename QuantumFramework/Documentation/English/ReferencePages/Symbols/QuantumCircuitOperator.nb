Cell["Their composition encodes 5 + 3 = 8:", "ExampleText",ExpressionUUID->"98cfdb58-5f91-42ab-9d48-fa76df61dc20"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(", 
   RowBox[{"qc1", "/*", "qc2"}], ")"}], " ", "==", " ", "\n", " ", 
  RowBox[{"QuantumCircuitOperator", "[", 
   RowBox[{"\"\<PhaseNumber\>\"", "[", " ", 
    RowBox[{
     RowBox[{"5", " ", "+", " ", "3"}], ",", " ", "6"}], "]"}], 
   "]"}]}]], "Input",
 CellChangeTimes->{{3.990104261562693*^9, 3.9901042783149853`*^9}},
 CellLabel->"In[6]:=",ExpressionUUID->"f1380ecf-bd99-4dc6-ab06-8d0ab1de9091"],

Cell[BoxData["True"], "Output",
 CellChangeTimes->{{3.990104265898014*^9, 3.9901042788216877`*^9}},
 CellLabel->"Out[6]=",
 CellID->466348640,ExpressionUUID->"299b5b1c-b9db-42c2-b15f-826ff0a51f95"]
}, Open  ]]
}, Closed]],

Cell[CellGroupData[{

Cell["Deutsch-Jozsa circuit", "ExampleSubsubsection",ExpressionUUID->"ed6012f3-3921-4ace-a90a-77267e99685a"],

Cell["\<\
For the Deutsch-Jozsa algorithm, the goal is to determine whether a Boolean \
function is constant (producing the same output regardless of the input, \
either 0 or 1) or balanced (yielding an equal number of 0s and 1s).\
\>", "ExampleText",ExpressionUUID->"194110b9-e19b-4005-920b-09f6180bf214"],

Cell["Define a balanced Boolean function:", "ExampleText",ExpressionUUID->"b1e182ed-ada8-489b-93c9-5f4c662507b4"],

Cell[BoxData[
 RowBox[{
  RowBox[{"bf", " ", "=", " ", 
   RowBox[{"BooleanFunction", "[", 
    RowBox[{"2", ",", " ", "2"}], "]"}]}], ";"}]], "Input",
 CellLabel->"In[1]:= ",ExpressionUUID->"bee901d4-7b92-4f2f-a3e9-c613bd4b0649"],

Cell["Show its disjunctive form:", "ExampleText",ExpressionUUID->"876e2a00-338f-47b6-812e-d72aef828a82"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"BooleanConvert", "[", "bf", "]"}], "[", 
  RowBox[{"\[FormalX]", ",", " ", "\[FormalY]"}], "]"}]], "Input",
 CellLabel->"In[2]:= ",ExpressionUUID->"c2fd8d06-cfa2-4463-a58d-32225c377e97"],

Cell[BoxData[
 RowBox[{
  RowBox[{"!", "\[FormalX]"}], "&&", "\[FormalY]"}]], "Output",
 CellLabel->"Out[2]= ",ExpressionUUID->"bda36385-00cf-4195-8594-fca3bd7a7eaa"]
}, Open  ]],

Cell["\<\
Show its Boolean table (note the equal number of True and False entries):\
\>", "ExampleText",ExpressionUUID->"99e512fe-6e29-4ea2-803d-f3b323023129"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"BooleanTable", "[", "bf", "]"}]], "Input",
 CellLabel->"In[3]:= ",ExpressionUUID->"a5b40ce2-fb3b-4a98-8bd8-cb05137ec970"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"False", ",", "False", ",", "True", ",", "False"}], "}"}]], "Output",\

 CellLabel->"Out[3]= ",ExpressionUUID->"0ac42c96-c4f4-49c3-8c87-b106a3959e00"]
}, Open  ]],

Cell["The Deutsch-Jozsa circuit for this function:", "ExampleText",ExpressionUUID->"95ddfda6-8050-4946-a674-527224f851d7"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"QuantumCircuitOperator", "[", 
   RowBox[{"\"\<DeutschJozsa\>\"", "[", "bf", "]"}], "]"}], 
  "[", "\"\<Diagram\>\"", "]"}]], "Input",
 CellLabel->"In[4]:= ",ExpressionUUID->"530b78fb-b1a7-4adc-a6a9-0f3c3462ad60"],

