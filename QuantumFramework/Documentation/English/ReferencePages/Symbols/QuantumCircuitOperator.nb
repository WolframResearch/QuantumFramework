     "e0372c63-1da6-435e-b5fd-14585b8dc079"]], "TableText",ExpressionUUID->
     "8ee6362c-c7da-4fb7-9b21-f9594d29fa5f"], Cell[
    "the number of parameters of the circuit", "TableText",ExpressionUUID->
     "5a4404a3-33ae-4f42-9753-8a58b8f14dac"]},
   {Cell["      ", "ModInfo",ExpressionUUID->
     "9fdf3d64-e94a-454d-a007-5aaadae62cc0"], Cell[TextData[Cell[
    BoxData["\"\<Properties\>\""], "InlineFormula",ExpressionUUID->
     "7bdd2894-b443-454d-bbcf-b6477aa4bd53"]], "TableText",ExpressionUUID->
     "396f833f-edb3-4e73-9e42-730e272dcf08"], Cell[
    "the list of supported properties", "TableText",ExpressionUUID->
     "6a9e4fdd-5e65-4747-9153-3c9cdca6c41d"]},
   {Cell["      ", "ModInfo",ExpressionUUID->
     "298c0e48-dc4d-4857-9637-0476c814cfc7"], Cell[TextData[Cell[
    BoxData["\"\<Diagram\>\""], "InlineFormula",ExpressionUUID->
     "b86271b3-8c7e-48cb-8463-4d9f56130cd6"]], "TableText",ExpressionUUID->
     "807d1114-e1f4-4a50-b7d0-78ce69a6cd7a"], Cell[
    "the diagram of the quantum circuit", "TableText",ExpressionUUID->
     "1e0c1191-e808-46e4-bdfe-a061a873dced"]},
   {Cell["      ", "ModInfo",ExpressionUUID->
     "d6fce260-17d1-46b9-9f0e-26ad82b9bca6"], Cell[TextData[Cell[
