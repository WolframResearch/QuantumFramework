}], "ExampleText",ExpressionUUID->"a9c9ffd7-5d79-4e2d-bd6e-3c65ceff2677"],

Cell["Some single-qubit quantum gates:", "ExampleText",ExpressionUUID->"c3a78203-0311-4370-9452-e442d4b7fe9a"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"QuantumCircuitOperator", "[", 
   RowBox[{"{", 
    RowBox[{"\"\<X\>\"", ",", " ", "\"\<Y\>\"", ",", " ", "\"\<Z\>\"", ",", 
     " ", 
     RowBox[{"\"\<P\>\"", "[", "\[Theta]", "]"}], ",", " ", "\n", "   ", 
     RowBox[{"\"\<RX\>\"", "[", 
      RowBox[{"Subscript", "[", 
       RowBox[{"\[Phi]", ",", " ", "x"}], "]"}], "]"}], ",", " ", 
     RowBox[{"\"\<RY\>\"", "[", 
      RowBox[{"Subscript", "[", 
       RowBox[{"\[Phi]", ",", " ", "y"}], "]"}], "]"}], ",", " ", "\n", "   ", 
     RowBox[{"\"\<RZ\>\"", "[", 
      RowBox[{"Subscript", "[", 
       RowBox[{"\[Phi]", ",", " ", "z"}], "]"}], "]"}], ",", " ", 
     RowBox[{"\"\<H\>\"", " ", "->", " ", "2"}], ",", " ", 
     RowBox[{"\"\<S\>\"", " ", "->", " ", "2"}], ",", " ", 
     RowBox[{"\"\<T\>\"", " ", "->", " ", "2"}], ",", " ", "\n", "   ", 
     RowBox[{"\"\<V\>\"", " ", "->", " ", "2"}], ",", " ", 
     RowBox[{"\"\<NOT\>\"", " ", "->", " ", "2"}], ",", " ", 
     RowBox[{"\"\<RootNOT\>\"", " ", "->", " ", "2"}], ",", " ", 
     RowBox[{"\"\<GlobalPhase\>\"", "[", "\[CapitalPhi]", "]"}], ",", "\n", 
     "    ", 
     RowBox[{
      RowBox[{"\"\<PhaseShift\>\"", "[", "2", "]"}], " ", "->", " ", "2"}]}], 
    "}"}], "]"}], "[", "\"\<Diagram\>\"", "]"}]], "Input",
 CellLabel->"In[1]:= ",ExpressionUUID->"b878b779-8b22-4454-ab58-a086afc6039d"],

