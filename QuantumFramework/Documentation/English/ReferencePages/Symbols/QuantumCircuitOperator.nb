Cell[TextData[{
 Cell[BoxData["\"\<DeutschJozsaPhase\>\""], "InlineFormula",ExpressionUUID->
  "4b1be6e4-5fc7-4cb4-8f49-89a254278440"],
 " can also take two integers: the first is ",
 Cell[BoxData[
  RowBox[{
   StyleBox["k", "TI"], "+", "1"}]], "InlineFormula",ExpressionUUID->
  "5f4160d9-53df-47f8-a835-3a0d11ac0bbe"],
 " and the second is ",
 Cell[BoxData[
  StyleBox["n", "TI"]], "InlineFormula",ExpressionUUID->
  "17a408fb-11c7-470c-82bb-fce950fcb55a"],
 ", selecting the Boolean function ",
 Cell[BoxData[
  RowBox[{"BooleanFunction", "[", 
   RowBox[{"k", ",", " ", "n"}], "]"}]], "InlineFormula",ExpressionUUID->
  "d14944a9-9572-477e-97d1-aa61a38d78d0"],
 ":"
}], "ExampleText",ExpressionUUID->"92f63b75-1efa-44ac-8adc-d132cb89ff92"],

Cell[CellGroupData[{

