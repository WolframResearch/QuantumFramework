Cell["\<\
InverseFourier is the same as conjugate transpose of Fourier:\
\>", "ExampleText",ExpressionUUID->"9a46be76-9362-4189-b8d6-12cf8e1e1a52"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"QuantumCircuitOperator", "[", "\"\<InverseFourier\>\"", "]"}], " ",
   "==", " ", "\n", " ", 
  RowBox[{
   RowBox[{"QuantumCircuitOperator", "[", "\"\<Fourier\>\"", "]"}], 
   "[", "\"\<Dagger\>\"", "]"}]}]], "Input",
 CellLabel->"In[6]:= ",ExpressionUUID->"37cd7563-f088-4e12-ac8c-036b33bfacf1"],

Cell[BoxData["True"], "Output",
 CellLabel->"Out[6]= ",ExpressionUUID->"e4f9acc5-20ba-41a6-8b7a-6665d9953010"]
}, Open  ]],

Cell["\<\
For 3 qubits, the QFT is the same as a basis transformation into the Fourier \
basis:\
\>", "ExampleText",ExpressionUUID->"abdd8c16-531f-49e0-8ec1-03038897b722"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"SparseArray", "[", "\n", "   ", 
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{"QuantumCircuitOperator", "[", 
        RowBox[{"\"\<Fourier\>\"", "[", "3", "]"}], "]"}], "[", "#", "]"}], 
      "[", "\"\<StateVector\>\"", "]"}], " ", "&"}], " ", "/@", " ", "\n", 
    "    ", 
    RowBox[{
     RowBox[{"QuantumBasis", "[", 
      RowBox[{"2", ",", " ", "3"}], "]"}], "[", "\"\<BasisStates\>\"", 
     "]"}]}], "]"}], " ", "==", " ", "\n", " ", 
  RowBox[{
   RowBox[{"QuantumBasis", "[", 
    RowBox[{"\"\<Fourier\>\"", "[", 
     RowBox[{"2", "^", "3"}], "]"}], "]"}], "[", "\"\<Elements\>\"", 
   "]"}]}]], "Input",
 CellLabel->"In[7]:= ",ExpressionUUID->"938b41a7-9e1f-4815-9a61-e548c96dccb5"],

Cell[BoxData["True"], "Output",
 CellLabel->"Out[7]= ",ExpressionUUID->"152fdbe5-c185-49f7-b821-b2c241ef15d2"]
}, Open  ]],

Cell["Phase estimation circuit", "ExampleSubsubsection",ExpressionUUID->"b32a5918-cebd-43f5-9691-d5e26dd92659"],

Cell[TextData[{
 "The quantum phase estimation ",
 Cell[BoxData[
  RowBox[{
   ButtonBox["QuantumCircuitOperator",
    BaseStyle->"Link",
    ButtonData->"paclet:Wolfram/QuantumFramework/ref/QuantumCircuitOperator"],
    "[", 
   RowBox[{"\"\<PhaseEstimation\>\"", "[", 
    RowBox[{
     StyleBox["u", "TI"], ",", 
     StyleBox["n", "TI"]}], "]"}], "]"}]], "InlineFormula",ExpressionUUID->
  "7e8c387c-6fc3-491c-b43a-a430588e17f7"],
 " takes two input arguments: a unitary operator u, and an integer n. The \
integer n specifies the number of qubits and ",
 Cell[BoxData[
  RowBox[{
   StyleBox["controlled", "TI"], "-", 
   SuperscriptBox[
    StyleBox["u", "TI"], 
    StyleBox["j", "TI"]]}]], "InlineFormula",ExpressionUUID->
  "c48fc4d5-295b-497d-a5ce-97efd70fe988"],
 " operators in the circuit, with ",
 Cell[BoxData[
  RowBox[{
   RowBox[{"j", "=", "0"}], ",", "1", ",", "\[Ellipsis]", ",", 
   RowBox[{"n", "-", "1"}]}]], "InlineFormula",ExpressionUUID->
  "2e00525a-9856-4a58-a5f0-68b7fc081dff"],
 ". The accuracy of phase estimation and the success probability depends on n."
}], "ExampleText",ExpressionUUID->"cc624543-27ac-4f9b-a3fa-80259289857b"],

Cell["Generate a random unitary operator:", "ExampleText",ExpressionUUID->"1991743c-cfe0-4b66-abc8-58a375f4c62f"],

Cell[BoxData[
 RowBox[{
  RowBox[{"u", " ", "=", " ", 
   RowBox[{"QuantumOperator", "[", "\"\<RandomUnitary\>\"", "]"}]}], 
  ";"}]], "Input",
 CellLabel->"In[1]:= ",ExpressionUUID->"89f0fac5-99e9-4f76-b6cd-1d89b8310952"],

Cell["\<\
Create the corresponding QPE circuit to find one of its eigenvalues:\
\>", "ExampleText",ExpressionUUID->"1ab910df-b379-4a3d-a24a-1d2fdfd86952"],

Cell[BoxData[
 RowBox[{
  RowBox[{"qc", " ", "=", " ", 
   RowBox[{"QuantumCircuitOperator", "[", 
    RowBox[{"\"\<PhaseEstimation\>\"", "[", "u", "]"}], "]"}]}], 
  ";"}]], "Input",
 CellLabel->"In[2]:= ",ExpressionUUID->"2194b8e6-c36e-4f16-be9c-ec0e7f755a4a"],

