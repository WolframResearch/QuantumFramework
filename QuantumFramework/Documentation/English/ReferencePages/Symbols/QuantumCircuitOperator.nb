Cell["\<\
List of all measured outcomes with nonzero probability (chopping the \
numerical noise from the floating-point measurement):\
\>", "ExampleText",ExpressionUUID->"eeca1f08-ebc2-4707-a503-22dbb661c1dd"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"m", " ", "=", " ", 
  RowBox[{"Normal", " ", "/@", " ", 
   RowBox[{"Keys", "@", 
    RowBox[{"Select", "[", 
     RowBox[{
      RowBox[{"simonMeas", "[", "\"\<Probabilities\>\"", "]"}], ",", " ", 
      RowBox[{
       RowBox[{
        RowBox[{"Chop", "[", "#", "]"}], " ", ">", " ", "0"}], " ", "&"}]}], 
     "]"}]}]}]}]], "Input",
 CellLabel->"In[9]:= ",ExpressionUUID->"08a3a264-ffe2-478d-b5fd-f092b01f4495"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"0", ",", "0", ",", "0", ",", "0"}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{"0", ",", "0", ",", "1", ",", "0"}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{"0", ",", "1", ",", "0", ",", "0"}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{"0", ",", "1", ",", "1", ",", "0"}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{"1", ",", "0", ",", "0", ",", "1"}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{"1", ",", "0", ",", "1", ",", "1"}], "}"}], ",", 
   RowBox[{"{", 
