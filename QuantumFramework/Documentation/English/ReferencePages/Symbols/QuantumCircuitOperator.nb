 CellLabel->"Out[6]= ",ExpressionUUID->"ea6efdb4-2c56-43fc-a3ae-bbabd2e75642"]
}, Open  ]],

Cell["\<\
Bob randomly generates a sequence of either Z-bases or X-bases of measurement:\
\>", "ExampleText",ExpressionUUID->"44b7a535-a384-4a0f-8828-5bebf8e0e35c"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"bobBases", " ", "=", " ", 
  RowBox[{"RandomChoice", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"\"\<Z\>\"", ",", " ", "\"\<X\>\""}], "}"}], ",", " ", "9"}], 
   "]"}]}]], "Input",
 CellLabel->"In[7]:= ",ExpressionUUID->"b99fc771-9da2-4aa1-b97d-184d9b54e426"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"\<\"Z\"\>", ",", "\<\"X\"\>", ",", "\<\"X\"\>", ",", "\<\"Z\"\>", 
   ",", "\<\"X\"\>", ",", "\<\"Z\"\>", ",", "\<\"Z\"\>", ",", "\<\"X\"\>", 
   ",", "\<\"X\"\>"}], "}"}]], "Output",
 CellLabel->"Out[7]= ",ExpressionUUID->"32af33b5-0c4a-4d28-acac-57ad8f923ab0"]
}, Open  ]],

Cell["\<\
Thus, Bob applies the following measurement operators on the qubits he got \
from Alice:\
\>", "ExampleText",ExpressionUUID->"6b7ca5b1-038f-4123-892c-8b214c354378"],

Cell[BoxData[
 RowBox[{
  RowBox[{"ops", " ", "=", " ", 
   RowBox[{"QuantumMeasurementOperator", " ", "/@", " ", "bobBases"}]}], 
  ";"}]], "Input",
 CellLabel->"In[8]:= ",ExpressionUUID->"9539c323-94f9-4bed-a1c4-2c56068a3b15"],

Cell["\<\
Post-measurement, it is the case that, whenever Bob's measurement basis is \
not the same as Alice's, he gets two random results:\
\>", "ExampleText",ExpressionUUID->"ab77bbca-b718-464b-97b3-d7ccdfc054b3"],

Cell[BoxData[
 RowBox[{
  RowBox[{"mea", " ", "=", " ", 
   RowBox[{"MapThread", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"#1", "[", "#2", "]"}], " ", "&"}], ",", " ", 
     RowBox[{"{", 
      RowBox[{"ops", ",", " ", "aliceQubits"}], "}"}]}], "]"}]}], 
  ";"}]], "Input",
 CellLabel->"In[9]:= ",ExpressionUUID->"ca820642-5ec1-4090-adad-8b19d2da9341"],

Cell["\<\
Return one possible realization of Bob's series of measurements (noting that \
some results will be consistent and others random, depending on Alice's qubit \
and Bob's measurement basis):\
\>", "ExampleText",ExpressionUUID->"48e3c7ab-d67b-438e-b281-ea7bd6a26c84"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"bobRealization", " ", "=", " ", 
  RowBox[{
   RowBox[{
    RowBox[{"#", "[", "\"\<SimulatedMeasurement\>\"", "]"}], " ", "&"}], " ", 
   "/@", " ", "mea"}]}]], "Input",
 CellLabel->
  "In[10]:= ",ExpressionUUID->"9e36d762-b407-45c5-95d7-cfbdbfed5abd"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   InterpretationBox[
    StyleBox[
     TemplateBox[{
       RowBox[{
         SubscriptBox["\"\[ScriptZ]\"", 
          InterpretationBox["\"+\"", 1]]}]},
      "Ket"],
     FontWeight->"Plain"],
    Wolfram`QuantumFramework`QuditName[
     Subscript["\[ScriptZ]", 
      Interpretation["+", 1]], "Dual" -> False]], ",", 
   InterpretationBox[
    StyleBox[
     TemplateBox[{
       RowBox[{
         SubscriptBox["\"\[ScriptX]\"", 
          InterpretationBox["\"+\"", 1]]}]},
      "Ket"],
     FontWeight->"Plain"],
    Wolfram`QuantumFramework`QuditName[
     Subscript["\[ScriptX]", 
      Interpretation["+", 1]], "Dual" -> False]], ",", 
   InterpretationBox[
    StyleBox[
     TemplateBox[{
       RowBox[{
         SubscriptBox["\"\[ScriptX]\"", 
          InterpretationBox["\"\[Minus]\"", -1]]}]},
      "Ket"],
     FontWeight->"Plain"],
    Wolfram`QuantumFramework`QuditName[
     Subscript["\[ScriptX]", 
      Interpretation["\[Minus]", -1]], "Dual" -> False]], ",", 
   InterpretationBox[
    StyleBox[
     TemplateBox[{
       RowBox[{
         SubscriptBox["\"\[ScriptZ]\"", 
          InterpretationBox["\"\[Minus]\"", -1]]}]},
      "Ket"],
     FontWeight->"Plain"],
    Wolfram`QuantumFramework`QuditName[
     Subscript["\[ScriptZ]", 
      Interpretation["\[Minus]", -1]], "Dual" -> False]], ",", 
   InterpretationBox[
    StyleBox[
     TemplateBox[{
       RowBox[{
         SubscriptBox["\"\[ScriptX]\"", 
          InterpretationBox["\"\[Minus]\"", -1]]}]},
      "Ket"],
     FontWeight->"Plain"],
    Wolfram`QuantumFramework`QuditName[
     Subscript["\[ScriptX]", 
      Interpretation["\[Minus]", -1]], "Dual" -> False]], ",", 
   InterpretationBox[
    StyleBox[
     TemplateBox[{
       RowBox[{
         SubscriptBox["\"\[ScriptZ]\"", 
          InterpretationBox["\"+\"", 1]]}]},
      "Ket"],
     FontWeight->"Plain"],
    Wolfram`QuantumFramework`QuditName[
     Subscript["\[ScriptZ]", 
      Interpretation["+", 1]], "Dual" -> False]], ",", 
   InterpretationBox[
    StyleBox[
     TemplateBox[{
       RowBox[{
         SubscriptBox["\"\[ScriptZ]\"", 
          InterpretationBox["\"\[Minus]\"", -1]]}]},
      "Ket"],
     FontWeight->"Plain"],
    Wolfram`QuantumFramework`QuditName[
     Subscript["\[ScriptZ]", 
      Interpretation["\[Minus]", -1]], "Dual" -> False]], ",", 
   InterpretationBox[
    StyleBox[
     TemplateBox[{
       RowBox[{
         SubscriptBox["\"\[ScriptX]\"", 
          InterpretationBox["\"+\"", 1]]}]},
      "Ket"],
     FontWeight->"Plain"],
    Wolfram`QuantumFramework`QuditName[
     Subscript["\[ScriptX]", 
      Interpretation["+", 1]], "Dual" -> False]], ",", 
   InterpretationBox[
    StyleBox[
     TemplateBox[{
       RowBox[{
         SubscriptBox["\"\[ScriptX]\"", 
          InterpretationBox["\"\[Minus]\"", -1]]}]},
      "Ket"],
     FontWeight->"Plain"],
    Wolfram`QuantumFramework`QuditName[
     Subscript["\[ScriptX]", 
      Interpretation["\[Minus]", -1]], "Dual" -> False]]}], "}"}]], "Output",
 CellLabel->
