Cell["Quantum error correction with the three-qubit code", "ExampleSubsection",ExpressionUUID->"e7c7ebbc-2d2c-42dd-a403-ff34ef610587"],

Cell[TextData[{
 "A logical qubit can be shielded from bit-flip noise by spreading it across \
three physical qubits. The encoder ",
 Cell[BoxData[
  RowBox[{"|", 
   StyleBox["\[Psi]", "TI"], "\[RightAngleBracket]", "|", "00", "\[RightAngleBracket]", 
   RowBox[{"\[Function]", 
    StyleBox["\[Alpha]", "TI"]}], "|", "000", "\[RightAngleBracket]", 
   RowBox[{"+", 
    StyleBox["\[Beta]", "TI"]}], "|", "111", "\[RightAngleBracket]"}]], 
  "InlineFormula",ExpressionUUID->"ec3c9012-cd07-437e-a303-5490d16643dc"],
 " copies the computational value with two CNOTs, and a later majority vote, \
implemented by a single Toffoli, restores the logical qubit as long as at \
most one of the three qubits flips."
}], "ExampleText",ExpressionUUID->"969c3911-48cb-4e69-9af8-d0f89c410626"],

Cell["\<\
We build the encoder and the decoder. The decoder undoes the two CNOTs and \
then applies a Toffoli whose controls are the two redundancy qubits, flipping \
the data qubit back exactly when the majority disagrees with it:\
\>", "ExampleText",ExpressionUUID->"53f838b5-b737-40b1-a624-ba79cc576378"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"encode", " ", "=", " ", 
   RowBox[{"QuantumCircuitOperator", "[", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"\"\<CNOT\>\"", " ", "->", " ", 
       RowBox[{"{", 
        RowBox[{"1", ",", " ", "2"}], "}"}]}], ",", " ", 
      RowBox[{"\"\<CNOT\>\"", " ", "->", " ", 
       RowBox[{"{", 
        RowBox[{"1", ",", " ", "3"}], "}"}]}]}], "}"}], "]"}]}], 
  ";"}], "\n", 
 RowBox[{
  RowBox[{"decode", " ", "=", " ", 
   RowBox[{"QuantumCircuitOperator", "[", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"\"\<CNOT\>\"", " ", "->", " ", 
       RowBox[{"{", 
        RowBox[{"1", ",", " ", "2"}], "}"}]}], ",", " ", 
      RowBox[{"\"\<CNOT\>\"", " ", "->", " ", 
       RowBox[{"{", 
        RowBox[{"1", ",", " ", "3"}], "}"}]}], ",", " ", "\n", "    ", 
      RowBox[{"\"\<Toffoli\>\"", " ", "->", " ", 
       RowBox[{"{", 
        RowBox[{"2", ",", " ", "3", ",", " ", "1"}], "}"}]}]}], "}"}], 
    "]"}]}], ";"}]}], "Input",
 CellLabel->"In[1]:= ",ExpressionUUID->"bf5623b9-e003-4a1b-a873-9079f584b572"],

Cell[TextData[{
 "Noise enters as a quantum channel. A bit-flip channel ",
 Cell[BoxData[
  RowBox[{"\"\<BitFlip\>\"", "[", "p", "]"}]], "InlineFormula",ExpressionUUID->
  "08412fe5-00b9-4de1-b23d-b77ef3360f24"],
 " applies an X with probability ",
 Cell[BoxData[
  StyleBox["p", "TI"]], "InlineFormula",ExpressionUUID->
  "eb077803-d248-4c8e-b395-882ba549ccd1"],
 "; dropped into a circuit as an ordinary element it turns the pure state \
into a mixed density matrix. We place an independent copy on every physical \
qubit:"
}], "ExampleText",ExpressionUUID->"998e4b79-b02b-4464-aaa0-f0f65c1449de"],

Cell[BoxData[
 RowBox[{
  RowBox[{"noise", "[", "p_", "]"}], " ", ":=", " ", "\n", " ", 
  RowBox[{"QuantumCircuitOperator", "[", 
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{"QuantumChannel", "[", 
       RowBox[{"\"\<BitFlip\>\"", "[", "p", "]"}], "]"}], " ", "->", " ", 
      "#"}], " ", "&"}], " ", "/@", " ", 
    RowBox[{"{", 
     RowBox[{"1", ",", " ", "2", ",", " ", "3"}], "}"}]}], "]"}]}]], "Input",
 CellLabel->"In[2]:= ",ExpressionUUID->"e1faa790-537b-4d0a-b6dc-ea9eebae4ba8"],

Cell["\<\
We assemble the full pipeline, encode then noise then decode, for an \
arbitrary input qubit, and trace out the two redundancy qubits to read off \
the recovered logical state:\
\>", "ExampleText",ExpressionUUID->"f1446c1c-a0c6-473f-bbd7-b431b718ed54"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"psi", " ", "=", " ", 
   RowBox[{"QuantumState", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"2", ",", " ", "1"}], "}"}], "/", 
     RowBox[{"Sqrt", "[", "5", "]"}]}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"protected", "[", "p_", "]"}], " ", ":=", " ", "\n", " ", 
  RowBox[{"QuantumPartialTrace", "[", "\n", "  ", 
   RowBox[{
    RowBox[{
     RowBox[{"QuantumCircuitOperator", "[", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"psi", " ", "->", " ", "1"}], ",", " ", "encode", ",", " ", 
        RowBox[{"noise", "[", "p", "]"}], ",", " ", "decode"}], "}"}], "]"}], 
     "[", "]"}], ",", " ", 
    RowBox[{"{", 
     RowBox[{"2", ",", " ", "3"}], "}"}]}], "]"}]}]}], "Input",
 CellLabel->"In[3]:= ",ExpressionUUID->"c2cc14a8-975e-4f21-9582-89a855388d1e"],

Cell["\<\
Compare the fidelity of the recovered logical qubit with that of the same \
qubit sent unprotected through one bit-flip channel:\
\>", "ExampleText",ExpressionUUID->"9351fa40-34ed-4272-867a-f8a27f628189"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{"QuantumSimilarity", "[", 
    RowBox[{"psi", ",", " ", 
     RowBox[{"protected", "[", "0.1", "]"}], ",", " ", "\"\<Fidelity\>\""}], 
    "]"}], ",", " ", "\n", " ", 
   RowBox[{"QuantumSimilarity", "[", 
    RowBox[{"psi", ",", " ", 
     RowBox[{
      RowBox[{"QuantumChannel", "[", 
       RowBox[{"\"\<BitFlip\>\"", "[", "0.1", "]"}], "]"}], "[", "psi", "]"}],
      ",", " ", "\"\<Fidelity\>\""}], "]"}]}], "}"}]], "Input",
 CellLabel->"In[4]:= ",ExpressionUUID->"37274faa-e99e-43c7-b6b9-16fbbdcb3776"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"0.9949472347818243`", ",", "0.981835016690686`"}], "}"}]], "Output",\

 CellLabel->"Out[4]= ",ExpressionUUID->"57956fca-8888-436a-b3b5-ab79337769ae"]
}, Open  ]],

Cell[TextData[{
 "The encoded qubit stays closer to the original. Because the code removes \
every single-qubit error, the logical infidelity grows as ",
 Cell[BoxData[
  SuperscriptBox[
   StyleBox["p", "TI"], "2"]], "InlineFormula",ExpressionUUID->
  "9afefb28-4cd0-4213-80b0-673d80584a16"],
 " rather than ",
 Cell[BoxData[
  StyleBox["p", "TI"]], "InlineFormula",ExpressionUUID->
  "02ef90c2-ea10-4048-8cba-9b8630df0b8b"],
 ", so encoding wins for every ",
 Cell[BoxData[
  RowBox[{
   StyleBox["p", "TI"], "<", "1", "/", "2"}]], "InlineFormula",ExpressionUUID->
  "57c79ead-9865-478d-a516-e0328c1b125b"],
 "."
}], "ExampleText",ExpressionUUID->"ea1a865f-6313-4bfd-9011-2b7a89011609"],

Cell["Tabulate both fidelities across the noise range:", "ExampleText",ExpressionUUID->"c19f6fc7-d9b6-468a-919a-fb01bcca6a5e"],

Cell[BoxData[
 RowBox[{
  RowBox[{"data", " ", "=", " ", 
   RowBox[{"Table", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"p", ",", " ", 
       RowBox[{"QuantumSimilarity", "[", 
        RowBox[{"psi", ",", " ", 
         RowBox[{"protected", "[", "p", "]"}], ",", " ", "\"\<Fidelity\>\""}],
         "]"}], ",", " ", "\n", "    ", 
       RowBox[{"QuantumSimilarity", "[", 
        RowBox[{"psi", ",", " ", 
         RowBox[{
          RowBox[{"QuantumChannel", "[", 
           RowBox[{"\"\<BitFlip\>\"", "[", "p", "]"}], "]"}], "[", "psi", 
          "]"}], ",", " ", "\n", "     ", "\"\<Fidelity\>\""}], "]"}]}], 
      "}"}], ",", " ", 
     RowBox[{"{", 
      RowBox[{"p", ",", " ", "0", ",", " ", "0.5", ",", " ", "0.05"}], 
      "}"}]}], "]"}]}], ";"}]], "Input",
 CellLabel->"In[5]:= ",ExpressionUUID->"88d15c2a-80be-445a-b597-30742c8dc2c2"],

Cell["Plot the encoded and unencoded fidelities together:", "ExampleText",ExpressionUUID->"84abaa97-257c-48d2-9e75-25798e14bb5e"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"ListLinePlot", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{"data", "[", 
      RowBox[{"[", 
       RowBox[{"All", ",", " ", 
        RowBox[{"{", 
         RowBox[{"1", ",", " ", "2"}], "}"}]}], "]"}], "]"}], ",", " ", 
     RowBox[{"data", "[", 
      RowBox[{"[", 
       RowBox[{"All", ",", " ", 
        RowBox[{"{", 
         RowBox[{"1", ",", " ", "3"}], "}"}]}], "]"}], "]"}]}], "}"}], ",", 
   " ", "\n", " ", 
   RowBox[{"PlotLegends", " ", "->", " ", 
    RowBox[{"{", 
     RowBox[{"\"\<encoded\>\"", ",", " ", "\"\<unencoded\>\""}], "}"}]}], ",",
    " ", "\n", " ", 
   RowBox[{"AxesLabel", " ", "->", " ", 
    RowBox[{"{", 
     RowBox[{"\"\<p\>\"", ",", " ", "\"\<fidelity\>\""}], "}"}]}], ",", " ", 
   RowBox[{"PlotMarkers", " ", "->", " ", "Automatic"}]}], "]"}]], "Input",
 CellLabel->"In[6]:= ",ExpressionUUID->"99490705-f2aa-46a5-9e2a-bf0a6d5b0792"],

Cell[BoxData[
 TemplateBox[{
   GraphicsBox[{{}, 
     InterpretationBox[{
       TagBox[{{{}, {}, 
          TagBox[{
            Hue[0.67, 0.6, 0.6], 
            Directive[
             PointSize[
              NCache[
               Rational[7, 360], 0.019444444444444445`]], 
             RGBColor[0.24, 0.6, 0.8], 
             AbsoluteThickness[2]], 
            
            LineBox[{{0., 0.9999999999999996}, {0.05, 0.9986941473744595}, {
             0.1, 0.9949472347818243}, {0.15000000000000002`, 
             0.989004550040089}, {0.2, 0.9811014218723764}, {0.25, 
             0.9714679613862717}, {0.30000000000000004`, 
