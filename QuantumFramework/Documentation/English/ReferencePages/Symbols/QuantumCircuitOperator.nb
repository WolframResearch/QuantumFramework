             RowBox[{
              RowBox[{"If", "[", 
               RowBox[{
                RowBox[{
                 RowBox[{"(", 
                  RowBox[{"solMin", " ", "/.", " ", 
                   RowBox[{
                    RowBox[{"-", "1"}], " ", "->", " ", "0"}]}], ")"}], " ", "==",
                  " ", 
                 RowBox[{"#", "[", "\"\<Name\>\"", "]"}]}], ",", " ", "\n", 
                "          ", 
                RowBox[{"Style", "[", 
                 RowBox[{
                  RowBox[{"#", "[", "\"\<Name\>\"", "]"}], ",", " ", "Red"}], 
                 "]"}], ",", " ", 
                RowBox[{"#", "[", "\"\<Name\>\"", "]"}]}], "]"}], ",", " ", 
              RowBox[{"Pi", "/", "2"}]}], "]"}], " ", "&"}], " ", "/@", " ", 
           RowBox[{"Keys", "[", "data", "]"}]}], ")"}]}], ",", " ", "\n", 
        "    ", 
        RowBox[{
        "PlotLabel", " ", "->", 
         " ", "\"\<Minimizing objective function\>\""}], ",", " ", 
        RowBox[{"ImageSize", " ", "->", " ", "200"}]}], "]"}]}], "]"}]}], 
   "}"}], "]"}]], "Input",
