Cell[CellGroupData[{

Cell["Parity test", "ExampleSubsection",ExpressionUUID->"4cf6c5fe-a6b6-46f5-ac2c-29fbdd390edf"],

Cell["\<\
Quantum circuit for parity test. If the number of 1 in a bit string (e.g. \
0001101..) is even, the parity is assigned to 0 (even parity), if it is odd, \
the parity is assigned to 1 (odd parity). A quantum circuit to measure parity \
of an n-qubit state is given below:\
\>", "ExampleText",ExpressionUUID->"6eef2e49-a35e-4d68-ac39-1fc1c7f5eed7"],

Cell[BoxData[
 RowBox[{
  RowBox[{"parityMeasurementCircuit", "[", "n_", "]"}], " ", ":=", " ", "\n", 
  " ", 
  RowBox[{"QuantumCircuitOperator", "[", "\n", "  ", 
   RowBox[{"Append", "[", 
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{"\"\<CNOT\>\"", " ", "->", " ", 
        RowBox[{"{", 
         RowBox[{"#", ",", " ", 
          RowBox[{"n", " ", "+", " ", "1"}]}], "}"}]}], " ", "&"}], " ", "/@",
       " ", 
      RowBox[{"Range", "[", "n", "]"}]}], ",", " ", 
     RowBox[{"{", 
      RowBox[{"n", " ", "+", " ", "1"}], "}"}]}], "]"}], "]"}]}]], "Input",
 CellLabel->"In[1]:= ",ExpressionUUID->"b4aaf5c0-eb3d-48dc-9fe2-ee2eb400e937"],

Cell["Example of a parity measurement circuit for 3-qubit state:", \
"ExampleText",ExpressionUUID->"a1a0c2ff-d942-4845-9c49-2db7e87f547c"],

