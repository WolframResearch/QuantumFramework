     "a1422caf-a2b2-4b08-b7a8-0af78aaeaf0a"]], "TableText",ExpressionUUID->
     "e0394925-8ec9-4181-8873-18d47fc3c37c"], Cell[
    "the list of parameters of a parametrized circuit", "TableText",
     ExpressionUUID->"ffa636fa-5dbf-45ae-b811-9e712fcda1a4"]},
   {Cell["      ", "ModInfo",ExpressionUUID->
     "9acb8edd-41ca-415f-b3a0-2e0a2853856a"], Cell[TextData[Cell[
