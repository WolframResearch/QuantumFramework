Cell["\<\
Given the most probable result, recover the integer from its bit-string:\
\>", "ExampleText",ExpressionUUID->"e48541cf-fb90-4db2-8899-6f95f8d12488"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"decoded", " ", "=", " ", 
  RowBox[{"FromDigits", "[", 
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{"Keys", "[", 
       RowBox[{"TakeLargest", "[", 
        RowBox[{
         RowBox[{"m", "[", "\"\<Probabilities\>\"", "]"}], ",", " ", "1"}], 
        "]"}], "]"}], "[", 
      RowBox[{"[", "1", "]"}], "]"}], "[", "\"\<Name\>\"", "]"}], ",", " ", 
    "2"}], "]"}]}]], "Input",
 CellLabel->"In[6]:= ",ExpressionUUID->"f3ad8472-b507-4d7c-b186-bd8513297fc1"],

Cell[BoxData["5"], "Output",
 CellLabel->"Out[6]= ",ExpressionUUID->"da9a64ad-f737-404b-8e80-019c59a5dd3f"]
}, Open  ]],

Cell["It matches the originally encoded number:", "ExampleText",ExpressionUUID->"e18b5670-8474-4603-95fd-03a9e7734381"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"decoded", " ", "==", " ", "5"}]], "Input",
 CellLabel->"In[7]:= ",ExpressionUUID->"542824c5-7e1c-493f-aa24-6466dc1e4818"],

Cell[BoxData["True"], "Output",
 CellLabel->"Out[7]= ",ExpressionUUID->"4c42691c-7b86-420c-9f68-6cb14c0e6737"]
}, Open  ]],

Cell["\<\
The PhaseNumber circuits follow the usual addition. Build a circuit encoding \
5 and another encoding 3:\
\>", "ExampleText",ExpressionUUID->"b7360c3d-1cda-4c90-835c-251206fe2eb4"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"qc1", " ", "=", " ", 
   RowBox[{"QuantumCircuitOperator", "[", 
    RowBox[{"{", 
     RowBox[{"\"\<PhaseNumber\>\"", ",", " ", "5", ",", " ", "6"}], "}"}], 
    "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"qc2", " ", "=", " ", 
   RowBox[{"QuantumCircuitOperator", "[", 
    RowBox[{"{", 
     RowBox[{"\"\<PhaseNumber\>\"", ",", " ", "3", ",", " ", "6", ",", " ", 
      "False"}], "}"}], "]"}]}], ";"}]}], "Input",
 CellLabel->"In[8]:= ",ExpressionUUID->"8e893523-c1b5-4c08-8f76-869769da0d42"],

Cell["Composing them gives the diagram:", "ExampleText",ExpressionUUID->"0fffb30f-2f5c-4de6-aed0-5e1270f44159"],

