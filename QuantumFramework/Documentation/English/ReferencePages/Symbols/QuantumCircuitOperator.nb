Cell["\<\
The BernsteinVaziraniOracle circuit accepts the secret as a binary vector or \
as a bit-string, equivalently:\
\>", "ExampleText",ExpressionUUID->"321a7415-dabd-4902-9328-4ee29d81968f"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"QuantumCircuitOperator", "[", 
   RowBox[{"\"\<BernsteinVaziraniOracle\>\"", "[", 
    RowBox[{"{", 
     RowBox[{"1", ",", " ", "0", ",", " ", "1"}], "}"}], "]"}], "]"}], " ", "==",
   " ", "\n", " ", 
  RowBox[{"QuantumCircuitOperator", "[", 
   RowBox[{"\"\<BernsteinVaziraniOracle\>\"", "[", "\"\<101\>\"", "]"}], 
   "]"}]}]], "Input",
 CellLabel->"In[4]:= ",ExpressionUUID->"1cb44c25-e29f-4fc4-a292-2cd1adf29a09"],

Cell[BoxData["True"], "Output",
 CellLabel->"Out[4]= ",ExpressionUUID->"41f4c6ba-9112-4f62-8749-734eb1f27391"]
}, Open  ]]
}, Closed]],

Cell[CellGroupData[{

Cell["Simon circuit", "ExampleSubsubsection",ExpressionUUID->"2ba4bfc5-fcdb-406a-8bb0-446d006e4b30"],

Cell["\<\
Simon\[CloseCurlyQuote]s algorithm is a quantum algorithm designed to solve \
the Simon\[CloseCurlyQuote]s problem efficiently. It aims to find a hidden \
bit-string by querying a black-box function.\
\>", "ExampleText",ExpressionUUID->"0ee888ab-a0c3-4795-ad15-7e820ede7e34"],

Cell["Create the corresponding Simon oracle:", "ExampleText",ExpressionUUID->"0015e171-eafa-4beb-a0b3-8f96032613b2"],

Cell[BoxData[
 RowBox[{
  RowBox[{"so", " ", "=", " ", 
   RowBox[{"QuantumCircuitOperator", "[", 
    RowBox[{"\"\<SimonOracle\>\"", "[", 
     RowBox[{"{", 
      RowBox[{"1", ",", " ", "0", ",", " ", "1", ",", " ", "1"}], "}"}], 
     "]"}], "]"}]}], ";"}]], "Input",
 CellLabel->"In[1]:= ",ExpressionUUID->"585029e6-6c1c-4180-94ee-0a07f9a82ac1"],

