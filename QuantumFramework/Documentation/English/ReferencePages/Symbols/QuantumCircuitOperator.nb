Cell["\<\
The same oracle can be built as a multiplexer over the same angles:\
\>", "ExampleText",ExpressionUUID->"8081c3b9-d13e-418d-b66a-7fccedef557a"],

Cell[BoxData[
 RowBox[{
  RowBox[{"inv", " ", "=", " ", 
   RowBox[{"QuantumCircuitOperator", "[", 
    RowBox[{
     RowBox[{"\"\<Multiplexer\>\"", " ", "@@", " ", 
      RowBox[{"\"\<RY\>\"", " ", "/@", " ", "angles"}]}], ",", " ", "\n", 
     "   ", 
     RowBox[{"RotateLeft", "[", 
      RowBox[{"Range", "[", 
       RowBox[{"prec", " ", "+", " ", "1"}], "]"}], "]"}]}], "]"}]}], 
  ";"}]], "Input",
 CellLabel->"In[4]:= ",ExpressionUUID->"a1e68fae-8568-4105-a271-2feedba2ab8b"],

Cell["Draw its circuit diagram:", "ExampleText",ExpressionUUID->"328e12e2-364e-446f-aae0-3e0e478b0625"],

