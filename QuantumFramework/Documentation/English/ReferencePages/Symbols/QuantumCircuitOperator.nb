Cell["Maximize the objective function classically:", "ExampleText",ExpressionUUID->"426af609-931e-4fa7-a0da-7a416961bb24"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"solMax", " ", "=", " ", "\n", " ", 
  RowBox[{"NArgMax", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{"x", " ", ".", " ", "q", " ", ".", " ", "x"}], ",", " ", 
      RowBox[{"0", " ", "\[VectorLess]", " ", 
       RowBox[{"x", "^", "2"}], " ", "\[VectorLessEqual]", " ", "1"}]}], 
     "}"}], ",", " ", "\n", "  ", 
    RowBox[{"x", " ", "\[Element]", " ", 
     RowBox[{"Vectors", "[", 
      RowBox[{
       RowBox[{"Length", "[", "q", "]"}], ",", " ", "Integers"}], "]"}]}]}], 
   "]"}]}]], "Input",
