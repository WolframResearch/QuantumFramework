Cell["Quantum teleportation", "ExampleSubsection",ExpressionUUID->"c444033f-6c65-4e31-b8ca-34719a97c99f"],

Cell[TextData[{
 "We shall implement a quantum circuit for teleporting a qubit. The 1st and \
2nd qubits represent Alice's system, while the last one is Bob's. The double \
lines carry classical bits. The state to be teleported is ",
 Cell[BoxData[
  RowBox[{"|", 
   SubscriptBox[
    StyleBox["\[Psi]", "TI"], "1"], "\[RightAngleBracket]", "=", 
   StyleBox["\[Alpha]", "TI"], "|", "0", "\[RightAngleBracket]", 
   RowBox[{"+", 
    StyleBox["\[Beta]", "TI"]}], "|", "1", "\[RightAngleBracket]"}]], 
  "InlineFormula",ExpressionUUID->"c5bfb523-01db-4b61-aa16-e9175ef041ad"],
 ", where ",
 Cell[BoxData[
  StyleBox["\[Alpha]", "TI"]], "InlineFormula",ExpressionUUID->
  "82fe7353-3af1-454d-88cf-da7ee96e9181"],
 " and ",
 Cell[BoxData[
  StyleBox["\[Beta]", "TI"]], "InlineFormula",ExpressionUUID->
  "7ecb3e69-e4a1-4d8f-9159-c2c8fc5714f6"],
 " are unknown amplitudes."
}], "ExampleText",ExpressionUUID->"df0a2e34-9d80-4f3a-a882-46212d31460f"],

Cell["Build the teleportation circuit:", "ExampleText",ExpressionUUID->"caddb393-ee2c-4c87-9bdc-8082be643b1a"],

Cell[BoxData[
 RowBox[{
  RowBox[{"circuit", " ", "=", " ", "\n", "  ", 
   RowBox[{"QuantumCircuitOperator", "[", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"QuantumCircuitOperator", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{
          RowBox[{"QuantumState", "[", 
           RowBox[{"\\\n", 
            RowBox[{"{", 
             RowBox[{"\[Alpha]", ",", " ", "\[Beta]"}], "}"}]}], "]"}], ",", 
          " ", 
          RowBox[{"\"\<Cup\>\"", " ", "->", " ", 
           RowBox[{"{", 
            RowBox[{"2", ",", " ", "3"}], "}"}]}]}], "}"}], ",", 
        " ", "\"\<State Prep.\>\""}], "]"}], ",", " ", "\"\<CX\>\"", ",", 
      " ", "\"\<H\>\"", ",", " ", "\n", "    ", 
      RowBox[{"\"\<CX\>\"", " ", "->", " ", 
       RowBox[{"{", 
        RowBox[{"2", ",", " ", "3"}], "}"}]}], ",", " ", 
      RowBox[{"\"\<CZ\>\"", " ", "->", " ", 
       RowBox[{"{", 
        RowBox[{"1", ",", " ", "3"}], "}"}]}], ",", " ", 
      RowBox[{"{", "1", "}"}], ",", " ", 
      RowBox[{"{", "2", "}"}]}], "}"}], "]"}]}], ";"}]], "Input",
 CellLabel->"In[1]:= ",ExpressionUUID->"c7b9bbc3-43d6-493e-abae-a711332cc0e7"],

Cell["Draw its circuit diagram:", "ExampleText",ExpressionUUID->"4036d149-320f-4a3c-b3e4-11fd3575af2e"],

