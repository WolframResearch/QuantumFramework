Cell["Plot the results given the optimal values:", "ExampleText",ExpressionUUID->"3598fbd9-a89d-477c-bb16-89c977793414"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Row", "[", 
  RowBox[{"{", 
   RowBox[{
    RowBox[{"With", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"data", " ", "=", " ", 
        RowBox[{"N", "[", 
         RowBox[{"weightedEnergy", " ", "/.", " ", "optMax"}], "]"}]}], "}"}],
       ",", " ", "\n", "   ", 
      RowBox[{"BarChart", "[", 
       RowBox[{"data", ",", " ", "\n", "    ", 
        RowBox[{"ChartLabels", " ", "->", " ", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{
            RowBox[{"Rotate", "[", "\n", "         ", 
             RowBox[{
              RowBox[{"If", "[", 
               RowBox[{
                RowBox[{
                 RowBox[{"(", 
                  RowBox[{"solMax", " ", "/.", " ", 
                   RowBox[{
                    RowBox[{"-", "1"}], " ", "->", " ", "0"}]}], ")"}], " ", "==",
                  " ", 
                 RowBox[{"#", "[", "\"\<Name\>\"", "]"}]}], ",", " ", "\n", 
                "          ", 
                RowBox[{"Style", "[", 
                 RowBox[{
                  RowBox[{"#", "[", "\"\<Name\>\"", "]"}], ",", " ", "Red"}], 
                 "]"}], ",", " ", 
                RowBox[{"#", "[", "\"\<Name\>\"", "]"}]}], "]"}], ",", " ", 
              RowBox[{"Pi", "/", "2"}]}], "]"}], " ", "&"}], " ", "/@", " ", 
           RowBox[{"Keys", "[", "data", "]"}]}], ")"}]}], ",", " ", "\n", 
        "    ", 
        RowBox[{
        "PlotLabel", " ", "->", 
         " ", "\"\<Maximizing objective function\>\""}], ",", " ", 
        RowBox[{"ImageSize", " ", "->", " ", "200"}]}], "]"}]}], "]"}], ",", 
    " ", "\n", "  ", 
    RowBox[{"With", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"data", " ", "=", " ", 
        RowBox[{"N", "[", 
         RowBox[{"weightedEnergy", " ", "/.", " ", "optMin"}], "]"}]}], "}"}],
