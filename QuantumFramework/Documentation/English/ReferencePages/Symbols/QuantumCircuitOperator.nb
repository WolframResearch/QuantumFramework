Cell["\<\
The PhaseNumber circuits follow the usual addition. Build a circuit encoding \
5 and another encoding 3:\
\>", "ExampleText",ExpressionUUID->"b7360c3d-1cda-4c90-835c-251206fe2eb4"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"qc1", " ", "=", " ", 
   RowBox[{"QuantumCircuitOperator", "[", 
    RowBox[{"\"\<PhaseNumber\>\"", "[", " ", 
     RowBox[{"5", ",", " ", "6"}], "]"}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"qc2", " ", "=", " ", 
   RowBox[{"QuantumCircuitOperator", "[", 
    RowBox[{"\"\<PhaseNumber\>\"", "[", " ", 
     RowBox[{"3", ",", " ", "6", ",", " ", "False"}], "]"}], "]"}]}], 
  ";"}]}], "Input",
 CellChangeTimes->{{3.990104237582425*^9, 3.9901042485284367`*^9}},
 CellLabel->"In[2]:=",ExpressionUUID->"8e893523-c1b5-4c08-8f76-869769da0d42"],

Cell["Composing them gives the diagram:", "ExampleText",ExpressionUUID->"0fffb30f-2f5c-4de6-aed0-5e1270f44159"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(", 
   RowBox[{"qc1", "/*", "qc2"}], ")"}], "[", "\"\<Diagram\>\"", 
  "]"}]], "Input",
 CellLabel->"In[4]:=",ExpressionUUID->"ffdb77a7-a942-4b50-ba8b-0daac8573bab"],

