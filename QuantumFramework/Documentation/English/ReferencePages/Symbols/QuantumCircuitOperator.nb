    RowBox[{
     RowBox[{"Arg", "[", 
      RowBox[{"u", "[", "\"\<Eigenvalues\>\"", "]"}], "]"}], "/", 
     RowBox[{"(", 
      RowBox[{"2", " ", "\[Pi]"}], ")"}]}], ",", " ", "1"}], "]"}]}]], "Input",\

