Cell[BoxData[
 RowBox[{"tn", " ", "=", " ", 
  RowBox[{
   RowBox[{"QuantumCircuitOperator", "[", 
    RowBox[{"\"\<Grover\>\"", "[", 
     RowBox[{
      RowBox[{"a", " ", "&&", " ", 
       RowBox[{"!", " ", "b"}]}], " ", "||", " ", "c"}], "]"}], "]"}], 
   "[", "\"\<TensorNetwork\>\"", "]"}]}]], "Input",
