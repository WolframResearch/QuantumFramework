Cell["Harrow-Hassidim-Lloyd (HHL) algorithm", "ExampleSubsection",ExpressionUUID->"9736e7e2-792a-48de-ac6a-8ea3cf0f64a4"],

Cell[TextData[{
 "Given a matrix A and a vector b, we want to solve ",
 Cell[BoxData[
  RowBox[{
   StyleBox["A", "TI"], 
   StyleBox["\[CenterDot]", "TI"], 
   StyleBox["x", "TI"], "=", 
   StyleBox["b", "TI"]}]], "InlineFormula",ExpressionUUID->
  "f36e1ed1-8bb0-4637-a46a-272211a0190b"]
}], "ExampleText",ExpressionUUID->"4771073b-215f-45e3-bdad-ec96aed4e7b4"],

Cell[TextData[{
 "Generate HHL circuit that takes ",
 StyleBox["A", "TI"],
 ", ",
 StyleBox["b", "TI"],
 ", and number of ancillary qubits:"
}], "ExampleText",ExpressionUUID->"3d37f456-62da-48f0-b99b-e57ee8db82ff"],

Cell[BoxData[{
 RowBox[{"ClearAll", "[", "HHL", "]"}], "\n", 
 RowBox[{
  RowBox[{"HHL", "[", 
   RowBox[{
    RowBox[{"A_", "?", "SquareMatrixQ"}], ",", " ", 
    RowBox[{"b_", "?", "VectorQ"}], ",", " ", 
    RowBox[{"prec", " ", ":", " ", 
     RowBox[{"_Integer", "?", "Positive"}], " ", ":", " ", "4"}]}], "]"}], 
  " ", ":=", "\n", " ", 
  RowBox[{"Block", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
     "d", ",", " ", "qpe", ",", " ", "t0", ",", " ", "\n", "   ", "yTilde", ",",
       " ", "\[Lambda]Tilde", ",", " ", "\[Theta]\[Lambda]", ",", " ", 
      "\[Gamma]"}], "}"}], ",", "\n", "  ", 
    RowBox[{
     RowBox[{"d", " ", "=", " ", 
      RowBox[{"Log2", "@", 
       RowBox[{"Length", "[", "b", "]"}]}]}], ";", "\n", "  ", 
     RowBox[{"t0", " ", "=", " ", 
      RowBox[{
       RowBox[{"Floor", "@", "\[Pi]"}], "/", 
       RowBox[{"Norm", "[", "A", "]"}]}]}], ";", "\n", "  ", 
     RowBox[{"yTilde", " ", "=", " ", "\n", "   ", 
      RowBox[{
       RowBox[{
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{"0", " ", "<=", " ", "#", " ", "<=", " ", 
           RowBox[{"2", "^", 
            RowBox[{"(", 
             RowBox[{"prec", " ", "-", " ", "1"}], ")"}]}]}], ",", " ", "#", ",",
           " ", 
          RowBox[{"#", " ", "-", " ", 
           RowBox[{"2", "^", "prec"}]}]}], "]"}], " ", "&"}], " ", "/@", " ", 
       
       RowBox[{"Range", "[", 
        RowBox[{"0", ",", " ", 
         RowBox[{
          RowBox[{"2", "^", "prec"}], " ", "-", " ", "1"}]}], "]"}]}]}], ";", 
     "\n", "  ", 
     RowBox[{"\[Lambda]Tilde", " ", "=", " ", 
      RowBox[{
       RowBox[{
        RowBox[{"(", 
         RowBox[{"2", " ", "\[Pi]"}], ")"}], "/", "t0"}], " ", 
       RowBox[{"yTilde", "/", 
        RowBox[{"2", "^", "prec"}]}]}]}], ";", "\n", "  ", 
     RowBox[{"\[Gamma]", " ", "=", " ", 
      RowBox[{"Min", "[", 
       RowBox[{"DeleteCases", "[", 
        RowBox[{
         RowBox[{"Abs", "[", "\[Lambda]Tilde", "]"}], ",", " ", 
         RowBox[{"0.", " ", "|", " ", "0"}]}], "]"}], "]"}]}], ";", "\n", 
     "  ", 
     RowBox[{"\[Theta]\[Lambda]", " ", "=", " ", "\n", "   ", 
      RowBox[{
       RowBox[{
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"#", " ", "==", " ", "0"}], " ", "||", " ", 
           RowBox[{"#", " ", "==", " ", "0."}]}], ",", " ", "0.", ",", " ", 
          RowBox[{"2", " ", 
           RowBox[{"ArcSin", "[", 
            RowBox[{"\[Gamma]", "/", "#"}], "]"}]}]}], "]"}], " ", "&"}], " ",
        "/@", " ", "\[Lambda]Tilde"}]}], ";", "\n", "  ", 
     RowBox[{
      RowBox[{"QuantumCircuitOperator", "[", 
       RowBox[{"{", "\n", "     ", 
        RowBox[{
         RowBox[{
          RowBox[{"QuantumState", "[", 
           RowBox[{"Normalize", "[", "b", "]"}], "]"}], " ", "->", " ", 
          RowBox[{"1", " ", "+", " ", "prec", " ", "+", " ", 
           RowBox[{"Range", "[", "d", "]"}]}]}], ",", "\n", 
         "     ", "\"\<Barrier\>\"", ",", "\n", "     ", 
         RowBox[{"qpe", " ", "=", " ", "\n", "      ", 
          RowBox[{
           RowBox[{"QuantumCircuitOperator", "[", "\n", "        ", 
            RowBox[{
             RowBox[{"\"\<PhaseEstimation\>\"", "[", 
              RowBox[{
               RowBox[{"QuantumOperator", "[", 
                RowBox[{"MatrixExp", "[", 
                 RowBox[{"t0", " ", "I", " ", "A"}], "]"}], "]"}], ",", " ", 
               "prec"}], "]"}], ",", " ", "\n", "        ", 
             RowBox[{"1", " ", "+", " ", 
              RowBox[{"Range", "[", 
               RowBox[{"prec", " ", "+", " ", "d"}], "]"}]}]}], "]"}], "[", 
           RowBox[{"[", 
            RowBox[{
             RowBox[{"d", " ", "+", " ", "1"}], " ", ";;", " ", 
             RowBox[{
              RowBox[{"-", "prec"}], " ", "-", " ", "1"}]}], "]"}], "]"}]}], ",",
          "\n", "     ", "\"\<Barrier\>\"", ",", "\n", "     ", 
         RowBox[{"QuantumCircuitOperator", "[", 
          RowBox[{
           RowBox[{"\"\<GrayOracle\>\"", "[", 
            RowBox[{"\[Theta]\[Lambda]", ",", " ", "prec", ",", " ", "1"}], 
            "]"}], ",", " ", "\n", "      ", "\"\<Eigenvalue Inversion\>\""}],
           "]"}], ",", "\n", "     ", "\"\<Barrier\>\"", ",", "\n", "     ", 
         RowBox[{"qpe", "[", "\"\<Dagger\>\"", "]"}], ",", "\n", 
         "     ", "\"\<Barrier\>\"", ",", "\n", "     ", 
         RowBox[{"QuantumOperator", "[", "\n", "      ", 
          RowBox[{
           RowBox[{"QuantumState", "[", 
            RowBox[{"\"\<1\>\"", " ", "<>", " ", 
             RowBox[{"StringJoin", "[", 
              RowBox[{"ConstantArray", "[", 
               RowBox[{"\"\<0\>\"", ",", " ", "prec"}], "]"}], "]"}]}], "]"}],
            "[", "\n", "       ", "\"\<Dagger\>\"", "]"}], "]"}]}], "\n", 
        "     ", "}"}], "\n", "    ", "]"}], " ", "/;", " ", 
      RowBox[{"IntegerQ", "[", "d", "]"}]}]}]}], "\n", "  ", 
   "]"}]}]}], "Input",
 CellLabel->"In[1]:= ",ExpressionUUID->"24536e89-677a-4a99-9be1-c1765274d137"],

Cell[TextData[{
 "Generate a complex-valued random Hermitian of ",
 StyleBox["n", "TI"],
 "-qubits (a matrix of ",
 StyleBox["n\[Times]n", "TI"],
 ")"
}], "ExampleText",ExpressionUUID->"e04119e9-28d5-46bf-a1db-53756c9410d5"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"n", " ", "=", " ", "4"}], ";"}], "\n", 
 RowBox[{
  RowBox[{"a", " ", "=", " ", 
   RowBox[{
    RowBox[{"QuantumOperator", "[", 
     RowBox[{"\"\<RandomHermitian\>\"", ",", " ", "n"}], "]"}], 
    "[", "\"\<Matrix\>\"", "]"}]}], ";"}], "\n", 
 RowBox[{"HermitianMatrixQ", "[", "a", "]"}]}], "Input",
 CellLabel->"In[2]:= ",ExpressionUUID->"913be96a-f96b-402a-8ac5-ef4551c5e535"],

Cell[TextData[{
 "Generate a complex-valued random vector ",
 StyleBox["b", "TI"],
 ":"
}], "ExampleText",ExpressionUUID->"067e7e26-06c7-4e83-993f-f8da4714456c"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"b", " ", "=", " ", 
   RowBox[{
    RowBox[{
     RowBox[{"QuantumOperator", "[", 
      RowBox[{"\"\<RandomUnitary\>\"", ",", " ", "n"}], "]"}], 
     "[", "\"\<Matrix\>\"", "]"}], "[", 
    RowBox[{"[", 
     RowBox[{"All", ",", " ", "1"}], "]"}], "]"}]}], ";"}], "\n", 
 RowBox[{"Norm", "[", "b", "]"}]}], "Input",
 CellLabel->"In[3]:= ",ExpressionUUID->"c6d34d5e-89c5-4a37-8d75-036ec7082bd2"],

Cell["Create HHL circuit:", "ExampleText",ExpressionUUID->"c9e6d411-cba7-4278-875f-798e7587829a"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"hhl", " ", "=", " ", 
   RowBox[{"N", "@", 
    RowBox[{"HHL", "[", 
     RowBox[{"a", ",", " ", "b", ",", " ", "6"}], "]"}]}]}], ";"}], "\n", 
 RowBox[{"hhl", "[", 
  RowBox[{"\"\<Diagram\>\"", ",", " ", 
   RowBox[{"\"\<ShowGateLabels\>\"", " ", "->", " ", "False"}]}], 
  "]"}]}], "Input",
 CellLabel->"In[4]:= ",ExpressionUUID->"3c9e824e-71dd-4f66-b4b0-19329ce53eb8"],

Cell["\<\
Given the result of above circuit, find corresponding amplitudes, and then \
normalize them to get solution of HHL solver:\
\>", "ExampleText",ExpressionUUID->"309c5cb5-54ce-4148-b17b-0fa1aee37323"],

Cell[BoxData[
 RowBox[{"xHHL", " ", "=", " ", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"hhl", "[", "]"}], "[", "\"\<Normalize\>\"", "]"}], 
    "[", "\"\<AmplitudesList\>\"", "]"}], " ", "//", " ", "Chop"}]}]], "Input",\

 CellLabel->"In[5]:= ",ExpressionUUID->"c9d38127-6199-459b-8507-d14c798cd120"],

Cell["Find the corresponding solution using classical approach:", \
"ExampleText",ExpressionUUID->"39712215-c7b6-4e59-963b-83e7be113a31"],

Cell[BoxData[
 RowBox[{"xClassical", " ", "=", " ", 
  RowBox[{"Normalize", "@", 
   RowBox[{"LinearSolve", "[", 
    RowBox[{"a", ",", " ", "b"}], "]"}]}]}]], "Input",
 CellLabel->"In[6]:= ",ExpressionUUID->"298a9b26-1f62-4bee-9e7c-a0fb6d6bebe2"],

Cell["\<\
Compare classical result with the quantum one (using the inner product as a \
measure; the closer to one the better)\"\
\>", "ExampleText",ExpressionUUID->"df602d5c-ae3e-4171-bfeb-c3994f6d1bca"],

Cell[BoxData[
 RowBox[{
  RowBox[{"Abs", "[", 
   RowBox[{
    RowBox[{"Conjugate", "[", "xClassical", "]"}], " ", ".", " ", "xHHL"}], 
   "]"}], "^", "2"}]], "Input",
 CellLabel->"In[7]:= ",ExpressionUUID->"f0be4757-d372-400f-8431-ecdeb82f54a1"],

Cell["\<\
As mentioned, the number of phase-estimation qubits (3rd argument) determines \
the precision of final outcome. Execute HHL with less phase-estimation \
qubits::\
\>", "ExampleText",ExpressionUUID->"d8ede08a-b417-4f81-ab24-701ed2699f13"],

Cell[BoxData[
 RowBox[{"xHHLLowPrecision", " ", "=", " ", "\n", " ", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{"N", "[", 
       RowBox[{"HHL", "[", 
        RowBox[{"a", ",", " ", "b", ",", " ", "3"}], "]"}], "]"}], "[", "]"}],
      "[", "\"\<Normalize\>\"", "]"}], "[", "\"\<AmplitudesList\>\"", "]"}], 
   " ", "//", " ", "Chop"}]}]], "Input",
 CellLabel->"In[8]:= ",ExpressionUUID->"ba0c7ebe-40b8-42d0-85e6-4cefa1d10320"],

Cell["\<\
Quantify the good ness of HHL result in compared with the classical result:\
\>", "ExampleText",ExpressionUUID->"19185d54-7682-44e7-9a7f-e0e48389eefe"],

Cell[BoxData[
 RowBox[{
  RowBox[{"Abs", "[", 
   RowBox[{
    RowBox[{"Conjugate", "[", "xClassical", "]"}], " ", ".", " ", 
    "xHHLLowPrecision"}], "]"}], "^", "2"}]], "Input",
 CellLabel->"In[9]:= ",ExpressionUUID->"1568468e-396f-4719-85e8-98aab7c931b1"],

Cell["Quantum error correction with the three-qubit code", "ExampleSubsection",ExpressionUUID->"1a30b7d5-c594-4e9d-9297-94b4c5a3208f"],

Cell[TextData[{
 "A logical qubit can be shielded from bit-flip noise by spreading it across \
three physical qubits. The encoder ",
 Cell[BoxData[
  RowBox[{"|", 
   RowBox[{"\[Psi]", "\[RightAngleBracket]"}], "|", "00", "\[RightAngleBracket]",
    "\[Function]", "\[Alpha]", "|", 
   RowBox[{"000", "\[RightAngleBracket]", "+", "\[Beta]"}], "|", "111", 
   "\[RightAngleBracket]"}]], "InlineFormula",ExpressionUUID->
  "b461ec6c-3980-46cc-9b30-96c85be3617e"],
 " copies the computational value with two CNOTs, and a later majority vote, \
implemented by a single Toffoli, restores the logical qubit as long as at \
most one of the three qubits flips."
}], "ExampleText",ExpressionUUID->"30dab68c-ab73-4b97-bd94-a96374d47fe4"],

Cell["\<\
We build the encoder and the decoder. The decoder undoes the two CNOTs and \
then applies a Toffoli whose controls are the two redundancy qubits, flipping \
the data qubit back exactly when the majority disagrees with it:\
\>", "ExampleText",ExpressionUUID->"0427a18f-c885-445b-8cc7-c291dee95b1b"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"encode", " ", "=", " ", 
   RowBox[{"QuantumCircuitOperator", "[", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"\"\<CNOT\>\"", " ", "->", " ", 
       RowBox[{"{", 
        RowBox[{"1", ",", " ", "2"}], "}"}]}], ",", " ", 
      RowBox[{"\"\<CNOT\>\"", " ", "->", " ", 
       RowBox[{"{", 
        RowBox[{"1", ",", " ", "3"}], "}"}]}]}], "}"}], "]"}]}], 
  ";"}], "\n", 
 RowBox[{
  RowBox[{"decode", " ", "=", " ", 
   RowBox[{"QuantumCircuitOperator", "[", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"\"\<CNOT\>\"", " ", "->", " ", 
       RowBox[{"{", 
        RowBox[{"1", ",", " ", "2"}], "}"}]}], ",", " ", 
      RowBox[{"\"\<CNOT\>\"", " ", "->", " ", 
       RowBox[{"{", 
        RowBox[{"1", ",", " ", "3"}], "}"}]}], ",", " ", "\n", "    ", 
      RowBox[{"\"\<Toffoli\>\"", " ", "->", " ", 
       RowBox[{"{", 
        RowBox[{"2", ",", " ", "3", ",", " ", "1"}], "}"}]}]}], "}"}], 
    "]"}]}], ";"}]}], "Input",
 CellLabel->"In[1]:= ",ExpressionUUID->"e9b4b7ad-c1a4-474a-a747-733514fdb323"],

Cell[TextData[{
 "Noise enters as a quantum channel. A bit-flip channel ",
 Cell[BoxData[
  RowBox[{"\"\<BitFlip\>\"", "[", "p", "]"}]], "InlineFormula",ExpressionUUID->
  "d727d6a1-8df0-4f7b-aeeb-ea9fae38e7c6"],
 " applies an X with probability ",
 Cell[BoxData[
  StyleBox["p", "TI"]], "InlineFormula",ExpressionUUID->
  "7a32ca6d-6eb8-465d-852b-ee3a114d6a7f"],
 "; dropped into a circuit as an ordinary element it turns the pure state \
into a mixed density matrix. We place an independent copy on every physical \
qubit:"
}], "ExampleText",ExpressionUUID->"afa3f3d3-3f74-4bce-9807-a82067463444"],

Cell[BoxData[
 RowBox[{
  RowBox[{"noise", "[", "p_", "]"}], " ", ":=", " ", "\n", " ", 
  RowBox[{"QuantumCircuitOperator", "[", 
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{"QuantumChannel", "[", 
       RowBox[{"\"\<BitFlip\>\"", "[", "p", "]"}], "]"}], " ", "->", " ", 
      "#"}], " ", "&"}], " ", "/@", " ", 
    RowBox[{"{", 
     RowBox[{"1", ",", " ", "2", ",", " ", "3"}], "}"}]}], "]"}]}]], "Input",
 CellLabel->"In[2]:= ",ExpressionUUID->"2bce4685-1f08-4e92-b96d-4b00b833e42d"],

Cell["\<\
We assemble the full pipeline, encode then noise then decode, for an \
arbitrary input qubit, and trace out the two redundancy qubits to read off \
the recovered logical state:\
\>", "ExampleText",ExpressionUUID->"0ceabbda-3cc2-474e-b2c9-b575dfb2968b"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"psi", " ", "=", " ", 
   RowBox[{"QuantumState", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"2", ",", " ", "1"}], "}"}], "/", 
     RowBox[{"Sqrt", "[", "5", "]"}]}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"protected", "[", "p_", "]"}], " ", ":=", " ", "\n", " ", 
  RowBox[{"QuantumPartialTrace", "[", "\n", "  ", 
   RowBox[{
    RowBox[{
     RowBox[{"QuantumCircuitOperator", "[", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"psi", " ", "->", " ", "1"}], ",", " ", "encode", ",", " ", 
        RowBox[{"noise", "[", "p", "]"}], ",", " ", "decode"}], "}"}], "]"}], 
     "[", "]"}], ",", " ", 
    RowBox[{"{", 
     RowBox[{"2", ",", " ", "3"}], "}"}]}], "]"}]}]}], "Input",
 CellLabel->"In[3]:= ",ExpressionUUID->"b94d7ccb-85c3-4fb1-b68f-e5a5a264512b"],

Cell["\<\
Compare the fidelity of the recovered logical qubit with that of the same \
qubit sent unprotected through one bit-flip channel:\
\>", "ExampleText",ExpressionUUID->"838be7fe-1759-4143-9c4f-5b2a519823f0"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{"QuantumSimilarity", "[", 
    RowBox[{"psi", ",", " ", 
     RowBox[{"protected", "[", "0.1", "]"}], ",", " ", "\"\<Fidelity\>\""}], 
    "]"}], ",", " ", "\n", " ", 
   RowBox[{"QuantumSimilarity", "[", 
    RowBox[{"psi", ",", " ", 
     RowBox[{
      RowBox[{"QuantumChannel", "[", 
       RowBox[{"\"\<BitFlip\>\"", "[", "0.1", "]"}], "]"}], "[", "psi", "]"}],
      ",", " ", "\"\<Fidelity\>\""}], "]"}]}], "}"}]], "Input",
 CellLabel->"In[4]:= ",ExpressionUUID->"21c1ad4f-aa4f-48b8-8f08-f65c2d2ff3ec"],

Cell[TextData[{
 "The encoded qubit stays closer to the original. Because the code removes \
every single-qubit error, the logical infidelity grows as ",
 Cell[BoxData[
  SuperscriptBox[
   StyleBox["p", "TI"], "2"]], "InlineFormula",ExpressionUUID->
  "926a5ebb-d851-41c6-88c1-9f067317abfc"],
 " rather than ",
 Cell[BoxData[
  StyleBox["p", "TI"]], "InlineFormula",ExpressionUUID->
  "05511014-1c3d-4bc4-a40c-9a41ab432e86"],
 ", so encoding wins for every ",
 Cell[BoxData[
  RowBox[{
   StyleBox["p", "TI"], "<", 
   FractionBox["1", "2"]}]], "InlineFormula",ExpressionUUID->
  "2cc6af4e-42cd-46b8-a741-04f669d4fdc7"],
 "."
}], "ExampleText",ExpressionUUID->"37cf7816-e59f-4fa7-b418-568a2ca86bd8"],

Cell["\<\
Tabulate both fidelities across the noise range and plot them:\
\>", "ExampleText",ExpressionUUID->"9c972611-27ee-46e2-99f0-005c9dbb8f08"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"data", " ", "=", " ", 
   RowBox[{"Table", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"p", ",", " ", 
       RowBox[{"QuantumSimilarity", "[", 
        RowBox[{"psi", ",", " ", 
         RowBox[{"protected", "[", "p", "]"}], ",", " ", "\"\<Fidelity\>\""}],
         "]"}], ",", " ", "\n", "    ", 
       RowBox[{"QuantumSimilarity", "[", 
        RowBox[{"psi", ",", " ", 
         RowBox[{
          RowBox[{"QuantumChannel", "[", 
           RowBox[{"\"\<BitFlip\>\"", "[", "p", "]"}], "]"}], "[", "psi", 
          "]"}], ",", " ", "\n", "     ", "\"\<Fidelity\>\""}], "]"}]}], 
      "}"}], ",", " ", 
     RowBox[{"{", 
      RowBox[{"p", ",", " ", "0", ",", " ", "0.5", ",", " ", "0.05"}], 
      "}"}]}], "]"}]}], ";"}], "\n", 
 RowBox[{"ListLinePlot", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{"data", "[", 
      RowBox[{"[", 
       RowBox[{"All", ",", " ", 
        RowBox[{"{", 
         RowBox[{"1", ",", " ", "2"}], "}"}]}], "]"}], "]"}], ",", " ", 
     RowBox[{"data", "[", 
      RowBox[{"[", 
       RowBox[{"All", ",", " ", 
        RowBox[{"{", 
         RowBox[{"1", ",", " ", "3"}], "}"}]}], "]"}], "]"}]}], "}"}], ",", 
   " ", "\n", " ", 
   RowBox[{"PlotLegends", " ", "->", " ", 
    RowBox[{"{", 
     RowBox[{"\"\<encoded\>\"", ",", " ", "\"\<unencoded\>\""}], "}"}]}], ",",
    " ", "\n", " ", 
   RowBox[{"AxesLabel", " ", "->", " ", 
    RowBox[{"{", 
     RowBox[{"\"\<p\>\"", ",", " ", "\"\<fidelity\>\""}], "}"}]}], ",", " ", 
   RowBox[{"PlotMarkers", " ", "->", " ", "Automatic"}]}], "]"}]}], "Input",
 CellLabel->"In[5]:= ",ExpressionUUID->"c1509996-4cf2-4e24-91fb-2dc23d2d906c"],

Cell["\<\
The encoded curve sits above the unencoded one throughout, the gap widening \
as the redundancy suppresses the leading-order error.\
\>", "ExampleText",ExpressionUUID->"073e6953-2b57-4544-9353-c83158e65487"],

Cell["Indefinite causal order: the quantum switch", "ExampleSubsection",ExpressionUUID->"b1c0d5cc-5f18-4085-8935-84cb5c187b94"],

Cell[TextData[{
 "Every circuit so far fixes the order in which its gates act. The quantum \
switch removes even that assumption: a control qubit coherently decides \
whether operation ",
 Cell[BoxData[
  StyleBox["A", "TI"]], "InlineFormula",ExpressionUUID->
  "556a5355-818c-4b6e-856d-7ec17e42ae20"],
 " precedes ",
 Cell[BoxData[
  StyleBox["B", "TI"]], "InlineFormula",ExpressionUUID->
  "79f72000-9b19-469e-813c-f8e704f37e9a"],
 " or the reverse, a resource with indefinite causal order that no fixed \
circuit can reproduce. ",
 Cell[BoxData[
 "QuantumCircuitOperator"], "InlineFormula",ExpressionUUID->
  "7f1a2a8a-6d93-4ac7-a6f4-5dad2cd2b5d7"],
 " provides it as the named circuit ",
 Cell[BoxData[
  RowBox[{"\"\<Switch\>\"", "[", 
   RowBox[{"A", ",", " ", "B"}], "]"}]], "InlineFormula",ExpressionUUID->
  "8c274206-5973-489a-90e2-1334f42eb56a"],
 "."
}], "ExampleText",ExpressionUUID->"859d8065-5654-4f53-abd9-64b6b09555c5"],

Cell["\<\
Build the switch of two single-qubit operations and inspect its structure:\
\>", "ExampleText",ExpressionUUID->"b936c76a-f9c7-491c-a030-541ecf46b889"],

Cell[BoxData[
 RowBox[{
  RowBox[{"QuantumCircuitOperator", "[", "\n", "  ", 
   RowBox[{"\"\<Switch\>\"", "[", 
    RowBox[{
     RowBox[{"QuantumOperator", "[", "\"\<X\>\"", "]"}], ",", " ", 
     RowBox[{"QuantumOperator", "[", "\"\<Z\>\"", "]"}]}], "]"}], "]"}], 
  "[", "\"\<Diagram\>\"", "]"}]], "Input",
 CellLabel->"In[1]:= ",ExpressionUUID->"ca1b522f-716a-4693-b36e-decf95324914"],

Cell[TextData[{
 "With the control prepared in ",
 Cell[BoxData[
  RowBox[{"|", 
   RowBox[{"+", "\[RightAngleBracket]"}]}]], "InlineFormula",ExpressionUUID->
  "b62224d4-5398-4ab4-93c3-a1ce5a751b30"],
 ", the switch outputs ",
 Cell[BoxData[
  RowBox[{
   RowBox[{
    FractionBox["1", 
     SqrtBox["2"]], "(", 
    RowBox[{"|", 
     RowBox[{"0", "\[RightAngleBracket]", 
      StyleBox["B", "TI"], 
      StyleBox["A", "TI"]}], "+", "|", 
     RowBox[{"1", "\[RightAngleBracket]", 
      StyleBox["A", "TI"], 
      StyleBox["B", "TI"]}]}], ")"}], "|", 
   RowBox[{"\[Psi]", "\[RightAngleBracket]"}]}]], "InlineFormula",
  ExpressionUUID->"67e0626e-36a8-4cea-b0df-c1a127b493ff"],
 ". Rotating the control back with a Hadamard and measuring it interferes the \
two orders: the control collapses to ",
 Cell[BoxData[
  RowBox[{"|", 
   RowBox[{"0", "\[RightAngleBracket]"}]}]], "InlineFormula",ExpressionUUID->
  "59b89e75-8bef-4149-a23b-318486f90bdb"],
 " when the operations commute (",
 Cell[BoxData[
  RowBox[{
   StyleBox["A", "TI"], 
   StyleBox["B", "TI"], "=", 
   StyleBox["B", "TI"], 
   StyleBox["A", "TI"]}]], "InlineFormula",ExpressionUUID->
  "72cc174d-4fb7-41e2-8047-0e0ad32a12fc"],
 ") and to ",
 Cell[BoxData[
  RowBox[{"|", 
   RowBox[{"1", "\[RightAngleBracket]"}]}]], "InlineFormula",ExpressionUUID->
  "88d03411-92e0-404f-93b0-20ce63e1531f"],
 " when they anticommute (",
 Cell[BoxData[
  RowBox[{
   StyleBox["A", "TI"], 
   StyleBox["B", "TI"], "=", "-", 
   StyleBox["B", "TI"], 
   StyleBox["A", "TI"]}]], "InlineFormula",ExpressionUUID->
  "d14113cb-605f-4922-9cd6-56b937f83775"],
 ")."
}], "ExampleText",ExpressionUUID->"81dc646b-18d2-4d07-941f-e83ae87e514c"],

Cell[TextData[{
 "We assemble the full single-query test, preparing the control in ",
 Cell[BoxData[
  RowBox[{"|", 
   RowBox[{"+", "\[RightAngleBracket]"}]}]], "InlineFormula",ExpressionUUID->
  "92230137-02a1-4c7d-802b-31d5be655365"],
 ", applying the switch, rotating back, and measuring the control:"
}], "ExampleText",ExpressionUUID->"fdbfcd6d-49e6-4c96-b9fd-102c804e854a"],

Cell[BoxData[
 RowBox[{
  RowBox[{"switchTest", "[", 
   RowBox[{"A_", ",", " ", "B_"}], "]"}], " ", ":=", " ", "\n", " ", 
  RowBox[{"QuantumCircuitOperator", "[", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"\"\<H\>\"", " ", "->", " ", "1"}], ",", " ", "\n", "   ", 
     RowBox[{"QuantumCircuitOperator", "[", 
      RowBox[{"\"\<Switch\>\"", "[", 
       RowBox[{"A", ",", " ", "B"}], "]"}], "]"}], ",", " ", 
     RowBox[{"\"\<H\>\"", " ", "->", " ", "1"}], ",", " ", 
     RowBox[{"{", "1", "}"}]}], "}"}], "]"}]}]], "Input",
 CellLabel->"In[2]:= ",ExpressionUUID->"e9310ba7-6546-4244-a3df-2924ba82b018"],

Cell["\<\
Two operators that commute (here X with itself) send the control to 0 with \
certainty:\
\>", "ExampleText",ExpressionUUID->"8aa96acc-8167-4ccc-8919-6253bce30a48"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"switchTest", "[", 
    RowBox[{
     RowBox[{"QuantumOperator", "[", "\"\<X\>\"", "]"}], ",", " ", 
     RowBox[{"QuantumOperator", "[", "\"\<X\>\"", "]"}]}], "]"}], "[", "]"}], 
  "[", "\"\<Probabilities\>\"", "]"}]], "Input",
 CellLabel->"In[3]:= ",ExpressionUUID->"fb656380-7abd-49e1-81c8-66e6c2212894"],

Cell["Two that anticommute (X and Z) send it to 1 with certainty:", \
"ExampleText",ExpressionUUID->"2b4e3fb4-57e5-42bf-b366-a713cc0206b3"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"switchTest", "[", 
    RowBox[{
     RowBox[{"QuantumOperator", "[", "\"\<X\>\"", "]"}], ",", " ", 
     RowBox[{"QuantumOperator", "[", "\"\<Z\>\"", "]"}]}], "]"}], "[", "]"}], 
  "[", "\"\<Probabilities\>\"", "]"}]], "Input",
 CellLabel->"In[4]:= ",ExpressionUUID->"0aa8d349-e03b-4929-b2d3-c4508629a000"],

Cell[TextData[{
 "Each run uses ",
 Cell[BoxData[
  StyleBox["A", "TI"]], "InlineFormula",ExpressionUUID->
  "ea1e320b-03f9-4dea-bb55-cf73b9c36488"],
 " and ",
 Cell[BoxData[
  StyleBox["B", "TI"]], "InlineFormula",ExpressionUUID->
  "0f116dfe-6452-47c5-a117-f992011d2867"],
 " exactly once, yet decides commutation versus anticommutation \
deterministically. No fixed-order circuit can do this with a single use of \
each operation: the single-query discrimination is a genuine signature of \
indefinite causal order."
}], "ExampleText",ExpressionUUID->"4b9850b1-349e-41c8-a1eb-b7c10290a370"],

Cell["\<\
When the operations neither commute nor anticommute (X and H), the control \
emerges maximally mixed, reflecting the intermediate algebra:\
\>", "ExampleText",ExpressionUUID->"65a3304f-ca88-46c2-9d31-a332ec54c1b5"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"switchTest", "[", 
    RowBox[{
     RowBox[{"QuantumOperator", "[", "\"\<X\>\"", "]"}], ",", " ", 
     RowBox[{"QuantumOperator", "[", "\"\<H\>\"", "]"}]}], "]"}], "[", "]"}], 
  "[", "\"\<Probabilities\>\"", "]"}]], "Input",
 CellLabel->"In[5]:= ",ExpressionUUID->"1014e134-3faa-411a-b183-5b4852886abc"]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[
 InterpretationBox[Cell[
  "Possible Issues", "ExampleSection",ExpressionUUID->
   "dda06a82-eb41-4b48-8510-6cb821647761"],
  $Line = 0; Null]], "ExampleSection",
 CellID->1305812373,ExpressionUUID->"9397dd0b-9de4-443a-9371-be2b75148f2f"],

Cell["\<\
Using Qiskit as Method, if too many qubits, the result will be an association \
and not a quantum measurement object:\
\>", "ExampleText",ExpressionUUID->"431ccb1f-7fda-439c-92bb-7ca0728f3262"],

Cell[BoxData[
 RowBox[{
  RowBox[{"QuantumCircuitOperator", "[", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"QuantumOperator", "[", 
