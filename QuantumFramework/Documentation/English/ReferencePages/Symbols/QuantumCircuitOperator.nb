Cell[CellGroupData[{

Cell[BoxData[
 InterpretationBox[Cell[
  "Scope", "ExampleSection",ExpressionUUID->
   "32e79d70-f7af-47ff-bb41-513374ef55db"],
  $Line = 0; Null]], "ExampleSection",
 CellID->1293636265,ExpressionUUID->"6d08f999-4c69-4709-9b28-82906be6ee75"],

Cell["Common quantum gates", "ExampleSubsection",ExpressionUUID->"4f86835c-6635-46ac-b3d8-39aad549053e"],

Cell[TextData[{
 Cell[BoxData[
 "QuantumCircuitOperator"], "InlineFormula",ExpressionUUID->
  "1aa18e5f-029a-44d2-a4c6-138e95ef0ff5"],
 " supports a large family of common quantum gates."
}], "ExampleText",ExpressionUUID->"de57ae06-c574-4842-b950-30d66ed908fd"],

Cell["Some single-qubit quantum gates:", "ExampleText",ExpressionUUID->"0984ab8c-7cdd-4570-a8ea-41d1850785d6"],

Cell[BoxData[
 RowBox[{
  RowBox[{"QuantumCircuitOperator", "[", 
   RowBox[{"{", 
    RowBox[{"\"\<X\>\"", ",", " ", "\"\<Y\>\"", ",", " ", "\"\<Z\>\"", ",", 
     " ", 
     RowBox[{"\"\<P\>\"", "[", "\[Theta]", "]"}], ",", " ", "\n", "   ", 
     RowBox[{"\"\<RX\>\"", "[", 
      RowBox[{"Subscript", "[", 
       RowBox[{"\[Phi]", ",", " ", "x"}], "]"}], "]"}], ",", " ", 
     RowBox[{"\"\<RY\>\"", "[", 
      RowBox[{"Subscript", "[", 
       RowBox[{"\[Phi]", ",", " ", "y"}], "]"}], "]"}], ",", " ", "\n", "   ", 
     RowBox[{"\"\<RZ\>\"", "[", 
      RowBox[{"Subscript", "[", 
       RowBox[{"\[Phi]", ",", " ", "z"}], "]"}], "]"}], ",", " ", 
     RowBox[{"\"\<H\>\"", " ", "->", " ", "2"}], ",", " ", 
     RowBox[{"\"\<S\>\"", " ", "->", " ", "2"}], ",", " ", 
     RowBox[{"\"\<T\>\"", " ", "->", " ", "2"}], ",", " ", "\n", "   ", 
     RowBox[{"\"\<V\>\"", " ", "->", " ", "2"}], ",", " ", 
     RowBox[{"\"\<NOT\>\"", " ", "->", " ", "2"}], ",", " ", 
     RowBox[{"\"\<RootNOT\>\"", " ", "->", " ", "2"}], ",", " ", 
     RowBox[{"\"\<GlobalPhase\>\"", "[", "\[CapitalPhi]", "]"}], ",", "\n", 
     "    ", 
     RowBox[{
      RowBox[{"\"\<PhaseShift\>\"", "[", "2", "]"}], " ", "->", " ", "2"}]}], 
    "}"}], "]"}], "[", "\"\<Diagram\>\"", "]"}]], "Input",
 CellLabel->"In[1]:= ",ExpressionUUID->"bf6b4414-95ad-4db3-8eec-edd0ff4723fb"],

Cell["Some multi-qubit quantum gates:", "ExampleText",ExpressionUUID->"24aa8a51-9d22-49d0-b3af-6b2b44c7754e"],

Cell[BoxData[
 RowBox[{
  RowBox[{"QuantumCircuitOperator", "[", 
   RowBox[{"{", 
    RowBox[{"\"\<CH\>\"", ",", " ", "\"\<CS\>\"", ",", " ", "\"\<CNOT\>\"", ",",
      " ", "\"\<CT\>\"", ",", " ", "\"\<CX\>\"", ",", " ", "\"\<CY\>\"", ",", 
     " ", "\"\<CZ\>\"", ",", " ", "\n", "   ", 
     RowBox[{"\"\<CP\>\"", "[", "\[Theta]", "]"}], ",", " ", 
     RowBox[{"{", 
      RowBox[{"\"\<C\>\"", ",", " ", 
       RowBox[{
        RowBox[{"\"\<RX\>\"", "[", 
         RowBox[{"Subscript", "[", 
          RowBox[{"\[Theta]", ",", " ", "x"}], "]"}], "]"}], " ", "->", " ", 
        "4"}], ",", " ", 
       RowBox[{"{", "3", "}"}]}], "}"}], ",", " ", 
     RowBox[{"{", 
      RowBox[{"\"\<C\>\"", ",", "\n", "     ", 
       RowBox[{
        RowBox[{"\"\<RY\>\"", "[", 
         RowBox[{"Subscript", "[", 
          RowBox[{"\[Theta]", ",", " ", "y"}], "]"}], "]"}], " ", "->", " ", 
        "4"}], ",", " ", 
       RowBox[{"{", "3", "}"}]}], "}"}], ",", " ", 
     RowBox[{"{", 
      RowBox[{"\"\<C\>\"", ",", " ", "\n", "    ", 
       RowBox[{
        RowBox[{"\"\<RZ\>\"", "[", 
         RowBox[{"Subscript", "[", 
          RowBox[{"\[Theta]", ",", " ", "z"}], "]"}], "]"}], " ", "->", " ", 
        "4"}], ",", " ", 
       RowBox[{"{", "3", "}"}]}], "}"}], ",", " ", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"\"\<R\>\"", ",", " ", 
        RowBox[{"Subscript", "[", 
         RowBox[{"\[Theta]", ",", "\n", "      ", "xx"}], "]"}], ",", 
        " ", "\"\<XX\>\""}], "}"}], " ", "->", " ", 
      RowBox[{"{", 
       RowBox[{"3", ",", " ", "4"}], "}"}]}], ",", " ", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"\"\<R\>\"", ",", " ", 
        RowBox[{"Subscript", "[", 
         RowBox[{"\[Theta]", ",", " ", "yy"}], "]"}], ",", " ", "\n", 
        "     ", "\"\<YY\>\""}], "}"}], " ", "->", " ", 
      RowBox[{"{", 
       RowBox[{"3", ",", " ", "4"}], "}"}]}], ",", " ", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"\"\<R\>\"", ",", " ", 
        RowBox[{"Subscript", "[", 
         RowBox[{"\[Theta]", ",", " ", "zz"}], "]"}], ",", 
        " ", "\"\<ZZ\>\""}], "}"}], " ", "->", " ", 
      RowBox[{"{", 
       RowBox[{"3", ",", " ", "4"}], "}"}]}], ",", " ", "\n", "   ", 
     RowBox[{"\"\<SWAP\>\"", " ", "->", " ", 
      RowBox[{"{", 
       RowBox[{"3", ",", " ", "4"}], "}"}]}], ",", " ", 
     RowBox[{"\"\<RootSWAP\>\"", " ", "->", " ", 
      RowBox[{"{", 
       RowBox[{"3", ",", " ", "4"}], "}"}]}], ",", " ", "\n", "   ", 
     RowBox[{"\"\<Permutation\>\"", " ", "->", " ", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"3", ",", " ", "4"}], "}"}], " ", "->", " ", 
       RowBox[{"{", 
        RowBox[{"4", ",", " ", "3"}], "}"}]}]}], ",", " ", "\n", 
     "   ", "\"\<CSWAP\>\"", ",", " ", 
     RowBox[{"{", 
      RowBox[{"\"\<C\>\"", ",", " ", "\"\<RandomUnitary\>\"", ",", " ", 
       RowBox[{"{", "3", "}"}], ",", " ", 
       RowBox[{"{", "4", "}"}]}], "}"}]}], "}"}], "]"}], 
  "[", "\"\<Diagram\>\"", "]"}]], "Input",
 CellLabel->"In[2]:= ",ExpressionUUID->"b1f3d1cd-d752-4cf8-8d91-dd5523c0a84e"],

Cell["Named built-in quantum circuits", "ExampleSubsection",ExpressionUUID->"534e82e4-8e2a-484d-af2c-7894bfea3181"],

Cell[TextData[{
 Cell[BoxData[
 "QuantumCircuitOperator"], "InlineFormula",ExpressionUUID->
  "aa139915-b1f8-4429-beeb-055f959ebdfd"],
 " supports a large family of common quantum circuit."
}], "ExampleText",ExpressionUUID->"73484ff6-9e8a-428d-99b0-75e2c6fb43e1"],

Cell["Bell, Cup and Cap circuits", "ExampleSubsubsection",ExpressionUUID->"529b7848-a0e2-4cb0-a1f7-0c044b385cb7"],

Cell["Bell circuit:", "ExampleText",ExpressionUUID->"40720b92-d659-4e47-8d90-857d4b41b7d6"],

Cell[BoxData[
 RowBox[{
  RowBox[{"QuantumCircuitOperator", "[", "\"\<Bell\>\"", "]"}], 
  "[", "\"\<Diagram\>\"", "]"}]], "Input",
 CellLabel->"In[1]:= ",ExpressionUUID->"02e60b8d-5d5f-42ad-ac7c-086a7912943a"],

Cell["\<\
The action of Bell circuit on the register state generates the Bell state:\
\>", "ExampleText",ExpressionUUID->"93ad3966-8f79-4a19-b9b2-13919514730d"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"QuantumCircuitOperator", "[", "\"\<Bell\>\"", "]"}], "[", "]"}], 
  " ", "==", " ", 
  RowBox[{"QuantumState", "[", "\"\<Bell\>\"", "]"}]}]], "Input",
 CellLabel->"In[2]:= ",ExpressionUUID->"985e9cb3-3c14-41ee-9fde-ee2442523c85"],

Cell[TextData[{
 "Bell circuit is similar to \"Cup\", with ",
 Cell[BoxData[
  SqrtBox["2"]], "InlineFormula",ExpressionUUID->
  "367ae24b-307c-458b-8130-9c094bf9e6be"],
 " factor"
}], "ExampleText",ExpressionUUID->"ec9e6658-2bc6-4eac-a241-2e159b9020d9"],

Cell[BoxData[
 RowBox[{
  RowBox[{"QuantumCircuitOperator", "[", 
   RowBox[{"{", "\"\<Cup\>\"", "}"}], "]"}], "[", "\"\<Diagram\>\"", 
  "]"}]], "Input",
 CellLabel->"In[3]:= ",ExpressionUUID->"72fd3091-8ad4-43e7-947f-9e2cffea7c78"],

Cell[TextData[{
 "With a ",
 Cell[BoxData[
  SqrtBox["2"]], "InlineFormula",ExpressionUUID->
  "ed64d5a0-b329-4e0e-b9c9-529c5a84ec15"],
 " factor difference, Cup generates a Bell state:"
}], "ExampleText",ExpressionUUID->"09041a14-f03f-4994-b29c-e360b855265a"],

Cell[BoxData[
 RowBox[{
  RowBox[{"QuantumCircuitOperator", "[", 
   RowBox[{"{", "\"\<Cup\>\"", "}"}], "]"}], "[", "]"}]], "Input",
 CellLabel->"In[4]:= ",ExpressionUUID->"47010915-dcc8-449c-8ca9-b7ace6571566"],

Cell["The cap circuit is the inverse of Cup:", "ExampleText",ExpressionUUID->"4e93667e-4dc6-4e87-a164-a853fede7719"],

Cell[BoxData[
 RowBox[{
  RowBox[{"QuantumCircuitOperator", "[", 
   RowBox[{"{", "\"\<Cap\>\"", "}"}], "]"}], "[", "\"\<Diagram\>\"", 
  "]"}]], "Input",
 CellLabel->"In[5]:= ",ExpressionUUID->"c035b31d-28fe-4823-a30a-f8bf7c158b3b"],

Cell["Toffoli circuit", "ExampleSubsubsection",ExpressionUUID->"077fafa8-2846-4713-b0d8-3f460d3630a2"],

Cell["\<\
The Toffoli circuit as a combination of one-qubit and two-qubit gates:\
\>", "ExampleText",ExpressionUUID->"92a06124-9f07-43a8-bb30-ca2815af6892"],

Cell[BoxData[
 RowBox[{
  RowBox[{"QuantumCircuitOperator", "[", "\"\<Toffoli\>\"", "]"}], 
  "[", "\"\<Diagram\>\"", "]"}]], "Input",
 CellLabel->"In[1]:= ",ExpressionUUID->"d3910ceb-5dde-4ffc-b851-10b456e08613"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"QuantumCircuitOperator", "[", "\"\<Toffoli\>\"", "]"}], 
   "[", "\"\<CircuitOperator\>\"", "]"}], " ", "==", " ", "\n", " ", 
  RowBox[{"QuantumOperator", "[", "\"\<Toffoli\>\"", "]"}]}]], "Input",
 CellLabel->"In[2]:= ",ExpressionUUID->"6b3e36d1-71c1-44ff-ae24-dbd103ac64e1"],

Cell["Fourier and InverseFourier circuit", "ExampleSubsubsection",ExpressionUUID->"437c6852-9a38-4351-909f-62907e067667"],

Cell[TextData[{
 "For the quantum Fourier circuit, we have ",
 Cell[BoxData[
  RowBox[{"QuantumCircuitOperator", "[", 
   RowBox[{"\"\<Fourier\>\"", "[", 
    StyleBox["n", "TI"], "]"}], "]"}]], "InlineFormula",ExpressionUUID->
  "8a40e1ba-391c-43e7-bcb1-d38e4c0ebef2"],
 " with ",
 StyleBox["n", "TI"],
 " the number of qubits. For example, the Fourier circuit of 2-qubits:"
}], "ExampleText",ExpressionUUID->"9a2372e1-b72c-4b71-b8d5-035eeaeeebdb"],

Cell[BoxData[
 RowBox[{
  RowBox[{"QuantumCircuitOperator", "[", "\"\<Fourier\>\"", "]"}], 
  "[", "\"\<Diagram\>\"", "]"}]], "Input",
 CellLabel->"In[1]:= ",ExpressionUUID->"eca4afe7-b463-49d2-b96b-fb22d47e5933"],

Cell[TextData[{
 "Fourier circuit transforms computational basis into momentum (Pauli-X) \
basis. Check ",
 Cell[BoxData[
  RowBox[{"|", 
   RowBox[{"00", "\[RightAngleBracket]"}]}]], "InlineFormula",ExpressionUUID->
  "a5477ea7-2ef6-4175-bfae-ad884717fbe5"],
 " is transformed into ",
 Cell[BoxData[
  RowBox[{"|", 
   RowBox[{
    SubscriptBox[
     StyleBox["x", "TI"], "+"], 
    SubscriptBox[
     StyleBox["x", "TI"], "+"], "\[RightAngleBracket]"}]}]], "InlineFormula",
  ExpressionUUID->"956686c1-c7d4-4285-8815-b641b595cea0"],
 ":"
}], "ExampleText",ExpressionUUID->"12b219bf-63e2-43fe-b886-db071eb601e9"],

Cell[BoxData[
 RowBox[{"QuantumState", "[", 
  RowBox[{
   RowBox[{
    RowBox[{"QuantumCircuitOperator", "[", "\"\<Fourier\>\"", "]"}], "[", 
    "]"}], ",", " ", "\"\<XX\>\""}], "]"}]], "Input",
 CellLabel->"In[2]:= ",ExpressionUUID->"8ba6d749-71ac-4f8e-83c2-9aa238e62496"],

Cell["Fourier circuit of 5-qubits:", "ExampleText",ExpressionUUID->"7f624367-81f9-461b-ad60-055d4960c811"],

Cell[BoxData[
 RowBox[{
  RowBox[{"QuantumCircuitOperator", "[", 
   RowBox[{"\"\<Fourier\>\"", "[", "5", "]"}], "]"}], "[", "\"\<Diagram\>\"", 
  "]"}]], "Input",
 CellLabel->"In[3]:= ",ExpressionUUID->"079e8c65-e670-4f54-84e3-c2a4b70b1110"],

Cell["InverseFourier circuit of 5-qubits:", "ExampleText",ExpressionUUID->"41f936c7-43fa-42b6-9e55-c7151672f370"],

Cell[BoxData[
 RowBox[{
  RowBox[{"QuantumCircuitOperator", "[", 
   RowBox[{"\"\<InverseFourier\>\"", "[", "5", "]"}], "]"}], 
  "[", "\"\<Diagram\>\"", "]"}]], "Input",
 CellLabel->"In[4]:= ",ExpressionUUID->"4526d87d-170c-4d70-ae31-6ddb67da5d98"],

Cell[TextData[{
 "InverseFourier circuit transforms from the momentum (Pauli-X) basis into \
the computational basis into . Check ",
 Cell[BoxData[
  RowBox[{"|", 
   RowBox[{
    SubscriptBox[
     StyleBox["x", "TI"], "+"], 
    SubscriptBox[
     StyleBox["x", "TI"], "+"], "\[RightAngleBracket]"}]}]], "InlineFormula",
  ExpressionUUID->"21579288-baa0-46a8-a268-674c9c995ebf"],
 " is transformed into ",
 Cell[BoxData[
  RowBox[{"|", 
   RowBox[{"00", "\[RightAngleBracket]"}]}]], "InlineFormula",ExpressionUUID->
  "c31ec6e6-bc36-4085-bec5-b39ec89773f3"],
 ":"
}], "ExampleText",ExpressionUUID->"4c5dc344-aa28-42dc-b968-f51b2bb72fa0"],

Cell[BoxData[
 RowBox[{
  RowBox[{"QuantumCircuitOperator", "[", "\"\<InverseFourier\>\"", "]"}], "[", 
  RowBox[{"QuantumState", "[", "\"\<++\>\"", "]"}], "]"}]], "Input",
 CellLabel->"In[5]:= ",ExpressionUUID->"0c0cdd94-c9ec-4d29-98f1-a89846441812"],

Cell["\<\
InverseFourier is the same as conjugate transpose of Fourier:\
\>", "ExampleText",ExpressionUUID->"436b8fc2-52a9-41f3-9ae1-2205fcb7f29a"],

Cell[BoxData[
 RowBox[{
  RowBox[{"QuantumCircuitOperator", "[", "\"\<InverseFourier\>\"", "]"}], " ",
   "==", " ", "\n", " ", 
  RowBox[{
   RowBox[{"QuantumCircuitOperator", "[", "\"\<Fourier\>\"", "]"}], 
   "[", "\"\<Dagger\>\"", "]"}]}]], "Input",
 CellLabel->"In[6]:= ",ExpressionUUID->"db28822c-afa9-46b0-baa3-cb5b4aa7c833"],

Cell["\<\
QFT is the same as basis transformation into the Fourier basis:\
\>", "ExampleText",ExpressionUUID->"192c3ecc-f45e-4619-981a-3ce35ab7fe9a"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"n", " ", "=", " ", "3"}], ";"}], "\n", 
 RowBox[{
  RowBox[{"SparseArray", "[", "\n", "  ", 
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{"QuantumCircuitOperator", "[", 
        RowBox[{"\"\<Fourier\>\"", "[", "n", "]"}], "]"}], "[", "#", "]"}], 
      "[", "\"\<StateVector\>\"", "]"}], " ", "&"}], " ", "/@", " ", "\n", 
    "   ", 
    RowBox[{
     RowBox[{"QuantumBasis", "[", 
      RowBox[{"2", ",", " ", "n"}], "]"}], "[", "\"\<BasisStates\>\"", 
     "]"}]}], "]"}], " ", "==", " ", "\n", " ", 
  RowBox[{
   RowBox[{"QuantumBasis", "[", 
    RowBox[{"\"\<Fourier\>\"", "[", 
     RowBox[{"2", "^", "n"}], "]"}], "]"}], "[", "\"\<Elements\>\"", 
   "]"}]}]}], "Input",
 CellLabel->"In[7]:= ",ExpressionUUID->"5823eb24-72c4-400b-bfb8-269ca762652d"],

Cell["Phase estimation circuit", "ExampleSubsubsection",ExpressionUUID->"2c26f1b4-9f58-4924-8a2f-ca24ebc1232b"],

Cell[TextData[{
 "The quantum phase estimation ",
 Cell[BoxData[
  RowBox[{"QuantumCircuitOperator", "[", 
   RowBox[{"\"\<PhaseEstimation\>\"", "[", 
    RowBox[{
     StyleBox["u", "TI"], ",", 
     StyleBox["n", "TI"]}], "]"}], "]"}]], "InlineFormula",ExpressionUUID->
  "96b1ce3a-94c6-4ad8-99c5-54deb838f25a"],
 " takes two input arguments: a unitary operator u, and an integer n. The \
integer n specifies the number of qubits and ",
 Cell[BoxData[
  RowBox[{
   StyleBox["controlled", "TI"], "-", 
   SuperscriptBox[
    StyleBox["u", "TI"], 
    StyleBox["j", "TI"]]}]], "InlineFormula",ExpressionUUID->
  "eb1d5ffe-c77a-417a-ad01-1f0f2891fb70"],
 " operators in the circuit, with ",
 Cell[BoxData[
  RowBox[{
   RowBox[{"j", "=", "0"}], ",", "1", ",", "\[Ellipsis]", ",", 
   RowBox[{"n", "-", "1"}]}]], "InlineFormula",ExpressionUUID->
  "af7c0d46-8cb7-4cdb-bc28-424c212a7650"],
 ". The accuracy of phase estimation and the success probability depends on n."
}], "ExampleText",ExpressionUUID->"301eb612-82a0-4533-a344-368801019c56"],

Cell["Generate a random unitary operator:", "ExampleText",ExpressionUUID->"10e6f23f-1a89-4737-b687-d2467a854b9c"],

Cell[BoxData[
 RowBox[{
  RowBox[{"u", " ", "=", " ", 
   RowBox[{"QuantumOperator", "[", "\"\<RandomUnitary\>\"", "]"}]}], 
  ";"}]], "Input",
 CellLabel->"In[1]:= ",ExpressionUUID->"b626d338-eab9-457a-a5d9-1fd04c5c1034"],

Cell["\<\
Create the corresponding QPE circuit to find one of its eigenvalues:\
\>", "ExampleText",ExpressionUUID->"a4392296-9890-4f37-a816-370021112e8d"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"qc", " ", "=", " ", 
   RowBox[{"QuantumCircuitOperator", "[", 
    RowBox[{"\"\<PhaseEstimation\>\"", "[", "u", "]"}], "]"}]}], 
  ";"}], "\n", 
 RowBox[{"qc", "[", "\"\<Diagram\>\"", "]"}]}], "Input",
 CellLabel->"In[2]:= ",ExpressionUUID->"e4809469-fafc-45ed-aa7c-780d21fce5a2"],

Cell["Calculate corresponding measurement probabilities:", "ExampleText",ExpressionUUID->"d8f65fa2-b4a3-4554-a3d8-49383c8a4ed8"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"N", "[", "qc", "]"}], "[", "]"}], "[", 
  RowBox[{"\"\<ProbabilityPlot\>\"", ",", " ", 
   RowBox[{"\"\<LabelsAngle\>\"", " ", "->", " ", 
    RowBox[{"\[Pi]", "/", "2"}]}], ",", " ", "\n", " ", 
   RowBox[{"AspectRatio", " ", "->", " ", 
    RowBox[{"1", "/", "4"}]}]}], "]"}]], "Input",
 CellLabel->"In[3]:= ",ExpressionUUID->"a8947f43-7926-438f-b81b-9ab16af1bea8"],

Cell["\<\
Given the result with max probability, estimate the eigenvalue:\
\>", "ExampleText",ExpressionUUID->"82842bcf-b226-40ba-8acd-758b4c61ba17"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"Keys", "[", 
    RowBox[{"TakeLargest", "[", 
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{"N", "[", "qc", "]"}], "[", "]"}], 
       "[", "\"\<Probabilities\>\"", "]"}], ",", " ", "1"}], "]"}], "]"}], "[", 
   RowBox[{"[", "1", "]"}], "]"}], "[", "\"\<Name\>\"", "]"}], "\n", 
 RowBox[{"est1", " ", "=", " ", 
  RowBox[{
   RowBox[{
    RowBox[{"FromDigits", "[", 
     RowBox[{"%", ",", " ", "2"}], "]"}], "/", 
    RowBox[{"2", "^", "4"}]}], " ", "//", " ", "N"}]}]}], "Input",
 CellLabel->"In[4]:= ",ExpressionUUID->"4cf92ee4-4221-414b-a433-8427dc5f32bc"],

Cell["\<\
Generate another QPE circuit, to obtain the other eigenvalue:\
\>", "ExampleText",ExpressionUUID->"ec6e72f2-40ea-4bc1-b424-c063433813ab"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"qc2", " ", "=", " ", 
   RowBox[{"qc", "[", 
    RowBox[{"[", 
     RowBox[{"2", " ", ";;"}], "]"}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"qc2", "[", "\"\<Flatten\>\"", "]"}], "[", "\"\<Diagram\>\"", 
  "]"}]}], "Input",
 CellLabel->"In[5]:= ",ExpressionUUID->"defe63c7-689b-4a6c-8053-1c1190e1ccda"],

Cell["Note the only difference is dropping the Pauli-X gate.", "ExampleText",ExpressionUUID->"56b0fc34-0a62-4607-b468-c626587a61a7"],

Cell["Calculate corresponding measurement probabilities:", "ExampleText",ExpressionUUID->"a80389d5-2571-442f-a678-f9d492e60b52"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"N", "[", "qc2", "]"}], "[", "]"}], "[", 
  RowBox[{"\"\<ProbabilityPlot\>\"", ",", " ", 
   RowBox[{"\"\<LabelsAngle\>\"", " ", "->", " ", 
    RowBox[{"\[Pi]", "/", "2"}]}], ",", " ", "\n", " ", 
   RowBox[{"AspectRatio", " ", "->", " ", 
    RowBox[{"1", "/", "4"}]}]}], "]"}]], "Input",
 CellLabel->"In[6]:= ",ExpressionUUID->"6655b400-794c-4fe5-91bf-3a25b2cd6c02"],

Cell["\<\
Given the result with max probability, estimate the eigenvalue:\
\>", "ExampleText",ExpressionUUID->"a6ea3baf-2e08-4f42-8e7d-32514151c61c"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"Keys", "[", 
    RowBox[{"TakeLargest", "[", 
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{"N", "[", "qc2", "]"}], "[", "]"}], 
       "[", "\"\<Probabilities\>\"", "]"}], ",", " ", "1"}], "]"}], "]"}], "[", 
   RowBox[{"[", "1", "]"}], "]"}], "[", "\"\<Name\>\"", "]"}], "\n", 
 RowBox[{"est2", " ", "=", " ", 
  RowBox[{
   RowBox[{
    RowBox[{"FromDigits", "[", 
     RowBox[{"%", ",", " ", "2"}], "]"}], "/", 
    RowBox[{"2", "^", "4"}]}], " ", "//", " ", "N"}]}]}], "Input",
 CellLabel->"In[7]:= ",ExpressionUUID->"f5d89570-cce0-44c3-840e-05e0664dc96a"],

Cell[TextData[{
 "Find corresponding eigenvalues (note they should be in the form ",
 Cell[BoxData[
  SuperscriptBox[
   StyleBox["e", "TI"], 
   RowBox[{
    StyleBox["i", "TI"], " ", "2", "\[Pi]", " ", "\[Lambda]"}]]], 
  "InlineFormula",ExpressionUUID->"fdd1071c-7fa8-4dcf-8d47-03018e571a26"],
 "):"
}], "ExampleText",ExpressionUUID->"d3c937e1-d70b-4847-b61b-ed46e06fed96"],

Cell[BoxData[
 RowBox[{"\[Lambda]", " ", "=", " ", 
  RowBox[{"Mod", "[", 
   RowBox[{
    RowBox[{
     RowBox[{"Arg", "[", 
      RowBox[{"u", "[", "\"\<Eigenvalues\>\"", "]"}], "]"}], "/", 
     RowBox[{"(", 
      RowBox[{"2", " ", "\[Pi]"}], ")"}]}], ",", " ", "1"}], "]"}]}]], "Input",\

 CellLabel->"In[8]:= ",ExpressionUUID->"ac2c7567-855f-4ed5-ad24-137a0db58c69"],

Cell["\<\
Calculate the estimated eigenvalues, compared to the expected ones and find \
the error%:\
\>", "ExampleText",ExpressionUUID->"685876c7-8b51-4845-a3a2-c652aa7650d4"],

Cell[BoxData[
 RowBox[{"100.", " ", 
  RowBox[{"(", 
   RowBox[{"1", " ", "-", " ", 
    RowBox[{
     RowBox[{"Sort", "[", 
      RowBox[{"{", 
       RowBox[{"est1", ",", " ", "est2"}], "}"}], "]"}], "/", 
     RowBox[{"Sort", "[", "\[Lambda]", "]"}]}]}], ")"}]}]], "Input",
 CellLabel->"In[9]:= ",ExpressionUUID->"64708e19-2be1-4eb8-9943-4191904b7c33"],

Cell["Graph circuit", "ExampleSubsubsection",ExpressionUUID->"ec525798-0db5-4d07-ba9d-86bd0bacb650"],

Cell["\<\
Given a graph, the corresponding circuit (which generates quantum \
graph/cluster states) is a series of controlled-Z operators on edges of graph:\
\>", "ExampleText",ExpressionUUID->"78fa9076-18e6-4603-ad8a-cfdfe0288fad"],

Cell[BoxData[
 RowBox[{"g", " ", "=", " ", 
  RowBox[{"Graph", "[", 
   RowBox[{
    RowBox[{"RandomGraph", "[", 
     RowBox[{"{", 
      RowBox[{"4", ",", " ", "5"}], "}"}], "]"}], ",", " ", 
    RowBox[{"VertexLabels", " ", "->", " ", "\"\<Name\>\""}]}], 
   "]"}]}]], "Input",
 CellLabel->"In[1]:= ",ExpressionUUID->"87c21cf8-a351-43bc-89b5-511570d17e3e"],

Cell[BoxData[
 RowBox[{
  RowBox[{"QuantumCircuitOperator", "[", 
   RowBox[{"\"\<Graph\>\"", "[", "g", "]"}], "]"}], "[", "\"\<Diagram\>\"", 
  "]"}]], "Input",
 CellLabel->"In[2]:= ",ExpressionUUID->"107130cc-8e49-4f31-b437-04cf2576c1f5"],

Cell["\<\
Graph circuit generates graph state (also called as cluster state):\
\>", "ExampleText",ExpressionUUID->"dc8b17cc-b208-4ee9-9261-d14ce48f9a90"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"QuantumCircuitOperator", "[", 
    RowBox[{"\"\<Graph\>\"", "[", "g", "]"}], "]"}], "[", "]"}], " ", "==", 
  " ", 
  RowBox[{"QuantumState", "[", 
   RowBox[{"\"\<Graph\>\"", "[", "g", "]"}], "]"}]}]], "Input",
 CellLabel->"In[3]:= ",ExpressionUUID->"a94cc41d-c6fd-4a4e-8f5a-42c2bf1c80fe"],

Cell["Check qubits on the same edge are entangled:", "ExampleText",ExpressionUUID->"a7b2d26d-9487-4fcf-b145-4b928624e7e1"],

Cell[BoxData[
 RowBox[{"With", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"st", " ", "=", " ", 
     RowBox[{"QuantumState", "[", 
      RowBox[{"\"\<Graph\>\"", "[", "g", "]"}], "]"}]}], "}"}], ",", " ", 
   "\n", " ", 
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{"QuantumEntangledQ", "[", 
       RowBox[{"st", ",", " ", "#"}], "]"}], " ", "&"}], "@*", "List"}], " ", 
    "@@@", " ", 
    RowBox[{"EdgeList", "[", "g", "]"}]}]}], "]"}]], "Input",
 CellLabel->"In[4]:= ",ExpressionUUID->"97ad9f7d-a102-4cd6-a3bc-086b9b4d029b"],

Cell["Bernstein-Vazirani circuit", "ExampleSubsubsection",ExpressionUUID->"edf9cc46-84ce-4a02-8133-63aaf3161c9d"],

Cell[TextData[{
 "For the Bernstein-Vazirani algorithm, one needs to specify a secret string \
bit st as st as follows: for the oracle we have ",
 Cell[BoxData[
  RowBox[{"QuantumCircuitOperator", "[", 
   RowBox[{"BernsteinVaziraniOracle", "[", 
    StyleBox["st", "TI"], "]"}], "]"}]], "InlineFormula",ExpressionUUID->
  "2c5e93f7-1c09-467a-8e88-67dfb9bfb54c"],
 ", and for the whole circuit e ",
 Cell[BoxData[
  RowBox[{"QuantumCircuitOperator", "[", 
   RowBox[{"BernsteinVazirani", "[", 
    StyleBox["st", "TI"], "]"}], "]"}]], "InlineFormula",ExpressionUUID->
  "88b7d591-b005-43fa-a265-63c8f33c96fb"],
 ". For example, the Bernstein-Vazirani oracle for the secret bit of 101:"
}], "ExampleText",ExpressionUUID->"0da76040-a9f8-469a-803d-2c695c79b201"],

Cell[BoxData[
 RowBox[{
  RowBox[{"QuantumCircuitOperator", "[", 
   RowBox[{"\"\<BernsteinVaziraniOracle\>\"", "[", "\"\<101\>\"", "]"}], 
   "]"}], "[", "\"\<Diagram\>\"", "]"}]], "Input",
 CellLabel->"In[1]:= ",ExpressionUUID->"41efd6ee-ec9c-4172-939e-0283b47a3418"],

Cell["The Bernstein-Vazirani circuit for the secret bit of 101:", \
"ExampleText",ExpressionUUID->"6008e0d4-612e-4612-b6fe-625f55125cc8"],

Cell[BoxData[
 RowBox[{
  RowBox[{"QuantumCircuitOperator", "[", 
   RowBox[{"\"\<BernsteinVazirani\>\"", "[", "\"\<101\>\"", "]"}], "]"}], 
  "[", "\"\<Diagram\>\"", "]"}]], "Input",
 CellLabel->"In[2]:= ",ExpressionUUID->"2b2a95e6-a217-43b7-9bec-ea6fe70604a1"],

Cell["\<\
Measurement results of the Bernstein-Vazirani circuit for the secret bit of \
101:\
\>", "ExampleText",ExpressionUUID->"3824a2e5-df93-4ad8-b340-83cb68767e48"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"QuantumCircuitOperator", "[", "\n", "   ", 
    RowBox[{"\"\<BernsteinVazirani\>\"", "[", "\"\<101\>\"", "]"}], "]"}], "[",
    "]"}], "[", "\"\<ProbabilitiesPlot\>\"", "]"}]], "Input",
 CellLabel->"In[3]:= ",ExpressionUUID->"09a5e4cc-a573-49c7-bdc0-77af9fcebf48"],

Cell["\<\
BernsteinVaziraniOracle circuit can take a binary vector, or bit-strings\
\>", "ExampleText",ExpressionUUID->"eecb5841-6a0d-4367-96b9-147f667e6fcc"],

Cell[BoxData[
 RowBox[{
  RowBox[{"QuantumCircuitOperator", "[", 
   RowBox[{"\"\<BernsteinVaziraniOracle\>\"", "[", 
    RowBox[{"{", 
     RowBox[{"1", ",", " ", "0", ",", " ", "1"}], "}"}], "]"}], "]"}], " ", "==",
   " ", "\n", " ", 
  RowBox[{"QuantumCircuitOperator", "[", 
   RowBox[{"\"\<BernsteinVaziraniOracle\>\"", "[", "\"\<101\>\"", "]"}], 
   "]"}]}]], "Input",
 CellLabel->"In[4]:= ",ExpressionUUID->"aec82fe2-db37-46af-b4f1-6285611b8ece"],

Cell["Simon circuit", "ExampleSubsubsection",ExpressionUUID->"6ef03ed3-62f8-4346-97b2-fd4a5288e0e0"],

Cell["\<\
Simon\[CloseCurlyQuote]s algorithm is a quantum algorithm designed to solve \
the Simon\[CloseCurlyQuote]s problem efficiently. It aims to find a hidden \
bit-string by querying a black-box function.\
\>", "ExampleText",ExpressionUUID->"06d81322-0933-4e93-b8f1-dc444c46919b"],

Cell["Create corresponding Simon oracle:", "ExampleText",ExpressionUUID->"8c868cc8-1629-4f81-a0c1-0ca654cddfba"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"so", " ", "=", " ", 
   RowBox[{"QuantumCircuitOperator", "[", 
    RowBox[{"\"\<SimonOracle\>\"", "[", 
     RowBox[{"{", 
      RowBox[{"1", ",", " ", "0", ",", " ", "1", ",", " ", "1"}], "}"}], 
     "]"}], "]"}]}], ";"}], "\n", 
 RowBox[{"so", "[", "\"\<Diagram\>\"", "]"}]}], "Input",
 CellLabel->"In[1]:= ",ExpressionUUID->"8be3a229-bd22-4f43-840e-9b4c6362eff9"],

Cell["A function that return the Boolean table of a Simon oracle:", \
"ExampleText",ExpressionUUID->"cf11d545-f123-4153-a205-c1607fa18f69"],

Cell[BoxData[
 RowBox[{
  RowBox[{"boolTable", "[", "oracle_", "]"}], " ", ":=", " ", "\n", " ", 
  RowBox[{"With", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"n", " ", "=", " ", 
      RowBox[{
       RowBox[{"oracle", "[", "\"\<Width\>\"", "]"}], "/", "2"}]}], "}"}], ",",
     " ", "\n", "  ", 
    RowBox[{
     RowBox[{"KeyValueMap", "[", 
      RowBox[{
       RowBox[{"TraditionalForm", " ", "/@", " ", 
        RowBox[{"{", 
         RowBox[{"#1", ",", " ", "#2"}], "}"}]}], " ", "&"}], "]"}], "@", 
     "\n", "   ", 
     RowBox[{"AssociationMap", "[", "\n", "    ", 
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{"QuantumOperator", "[", 
          RowBox[{
           RowBox[{"\"\<Discard\>\"", "[", "2", "]"}], " ", "->", " ", 
           RowBox[{"Range", "[", "n", "]"}]}], "]"}], "[", 
         RowBox[{"oracle", "[", "#", "]"}], "]"}], " ", "&"}], ",", " ", "\n",
        "    ", 
       RowBox[{
        RowBox[{"QuantumBasis", "[", 
         RowBox[{"2", ",", " ", "n"}], "]"}], "[", "\"\<BasisStates\>\"", 
        "]"}]}], "]"}]}]}], "]"}]}]], "Input",
 CellLabel->"In[2]:= ",ExpressionUUID->"4905885d-5043-405d-8c3d-ba0357456da1"],

Cell["Return Boolean table of above Simon oracle:", "ExampleText",ExpressionUUID->"78cd359e-c370-49eb-a13f-fc07799273dc"],

Cell[BoxData[
 RowBox[{"TableForm", "[", 
  RowBox[{
   RowBox[{"boolTable", "[", "so", "]"}], ",", " ", 
   RowBox[{"TableDepth", " ", "->", " ", "2"}], ",", " ", "\n", " ", 
   RowBox[{"TableHeadings", " ", "->", " ", 
    RowBox[{"{", 
     RowBox[{"None", ",", " ", 
      RowBox[{"{", 
       RowBox[{"\"\<bit\>\"", ",", " ", "\"\<oracle[bit]\>\""}], "}"}]}], 
     "}"}]}]}], "]"}]], "Input",
 CellLabel->"In[3]:= ",ExpressionUUID->"d6fb9651-725f-4fa9-ba03-1625ea4906e6"],

Cell["Simon circuit for a given hidden sequence:", "ExampleText",ExpressionUUID->"ebeb98ac-db23-4f34-877c-18b4bf76b6f5"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"SeedRandom", "[", "0", "]"}], ";"}], "\n", 
 RowBox[{
  RowBox[{"simon", " ", "=", " ", 
   RowBox[{"QuantumCircuitOperator", "[", 
    RowBox[{"\"\<Simon\>\"", "[", 
     RowBox[{"seq", " ", "=", " ", 
      RowBox[{"{", 
       RowBox[{"1", ",", " ", "0", ",", " ", "0", ",", " ", "1"}], "}"}]}], 
     "]"}], "]"}]}], ";"}], "\n", 
 RowBox[{"simon", "[", "\"\<Diagram\>\"", "]"}]}], "Input",
 CellLabel->"In[4]:= ",ExpressionUUID->"d656c398-afa5-4065-a4ae-01b040a6eb6a"],

Cell["\<\
The measurement probabilities given the Simon circuit for the binary string \
of 1001:\
\>", "ExampleText",ExpressionUUID->"4883aba6-375a-4193-b3ee-029a34df98d8"],

Cell[BoxData[
 RowBox[{"simonMeas", " ", "=", " ", 
  RowBox[{
   RowBox[{"N", "[", "simon", "]"}], "[", "]"}]}]], "Input",
 CellLabel->"In[5]:= ",ExpressionUUID->"537b104e-5b26-4e01-9a2e-42c936d2c07b"],

Cell["Plot probabilities:", "ExampleText",ExpressionUUID->"a2847c16-eb19-42c0-96e8-b0b57b4770e9"],

Cell[BoxData[
 RowBox[{"simonMeas", "[", 
  RowBox[{"\"\<ProbabilitiesPlot\>\"", ",", " ", 
   RowBox[{"AspectRatio", " ", "->", " ", 
    RowBox[{"1", "/", "4"}]}], ",", " ", "\n", " ", 
   RowBox[{"\"\<LabelsAngle\>\"", " ", "->", " ", 
    RowBox[{"\[Pi]", "/", "2"}]}]}], "]"}]], "Input",
 CellLabel->"In[6]:= ",ExpressionUUID->"907ba080-40d0-4ffc-b043-c26547e99d43"],

Cell["List of all potential results:", "ExampleText",ExpressionUUID->"68b71d5b-5b7b-4728-b986-e4f73637db6c"],

Cell[BoxData[
 RowBox[{"m", " ", "=", " ", 
  RowBox[{"Normal", " ", "/@", " ", 
   RowBox[{"Keys", "@", 
    RowBox[{"Select", "[", 
     RowBox[{
      RowBox[{"simonMeas", "[", "\"\<Probabilities\>\"", "]"}], ",", " ", 
      "Positive"}], "]"}]}]}]}]], "Input",
 CellLabel->"In[7]:= ",ExpressionUUID->"aae52386-d593-4264-a222-41340fd193ef"],

Cell[TextData[{
 "Find the null vector (",
 Cell[BoxData[
  RowBox[{
   RowBox[{"matrix", "\[CenterDot]", "m"}], "=", 
   RowBox[{"0", " ", "mod", " ", "2"}]}]], "InlineFormula",ExpressionUUID->
  "7d0e1bb5-912d-41f9-ae88-0f605dedac7b"],
 "):"
}], "ExampleText",ExpressionUUID->"13fca683-b9cb-4aac-ad8e-00503ee65566"],

Cell[BoxData[
 RowBox[{"NullSpace", "[", 
  RowBox[{"m", ",", " ", 
   RowBox[{"Modulus", " ", "->", " ", "2"}]}], "]"}]], "Input",
 CellLabel->"In[8]:= ",ExpressionUUID->"52a3c782-b3da-4e3f-a341-7833a8667f26"],

Cell["We found the secret bit:", "ExampleText",ExpressionUUID->"95b6d393-6c2e-4b4e-a02e-a5b9a7c21a11"],

Cell[BoxData[
 RowBox[{"seq", " ", "==", " ", 
  RowBox[{"%", "[", 
   RowBox[{"[", "1", "]"}], "]"}]}]], "Input",
 CellLabel->"In[9]:= ",ExpressionUUID->"7545e2a5-5a44-4425-b2f9-c4dc1067edb7"],

Cell["\<\
Note, the Simon circuit and its corresponding Boolean function is not \
uniquely determined. For each evaluation, one gets a different oracle that \
can solve the Simon problem:\
\>", "ExampleText",ExpressionUUID->"7b7cd639-6ed8-49c3-8225-0140cdd7e579"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"simon2", " ", "=", " ", 
   RowBox[{"QuantumCircuitOperator", "[", 
    RowBox[{"\"\<Simon\>\"", "[", "seq", "]"}], "]"}]}], ";"}], "\n", 
 RowBox[{"simon", " ", "==", " ", "simon2"}]}], "Input",
 CellLabel->
  "In[10]:= ",ExpressionUUID->"bb61991b-68f6-4706-af45-9adead90e23f"],

Cell["With the new circuit, one can find the hidden sequence:", "ExampleText",ExpressionUUID->"94999ea6-e0da-4c40-9a6f-c7ee3f2519bc"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"NullSpace", "[", 
    RowBox[{
     RowBox[{"Normal", " ", "/@", " ", 
      RowBox[{"Keys", "@", 
       RowBox[{"Select", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"simon2", "[", "]"}], "[", "\"\<Probabilities\>\"", "]"}], ",",
          " ", "Positive"}], "]"}]}]}], ",", " ", "\n", "   ", 
     RowBox[{"Modulus", " ", "->", " ", "2"}]}], "]"}], "[", 
   RowBox[{"[", "1", "]"}], "]"}], " ", "==", " ", "seq"}]], "Input",
 CellLabel->
  "In[11]:= ",ExpressionUUID->"1277cd09-1742-4d3b-b7cb-e9343f665cc0"],

Cell["GrayOracle", "ExampleSubsubsection",ExpressionUUID->"72841207-86de-465b-8e3e-ae78aa5d32ae"],

Cell[TextData[{
 "It takes a list of angles or a function, number of ancillary qubits and \
target qubit, to generate the corresponding oracle based on ",
 ButtonBox["Gray code",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://arxiv.org/pdf/quant-ph/0404089.pdf"], None}],
 "."
}], "ExampleText",ExpressionUUID->"93ac2de6-7fbf-465f-b740-35e909051f4c"],

Cell["\<\
Given 4-qubits as ancillary, generate angles for all possible bit-strings, \
and prepend zero angle, too:\
\>", "ExampleText",ExpressionUUID->"0a9350e6-6820-4d4c-806d-b6b8034afc4f"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"prec", " ", "=", " ", "4"}], ";"}], "\n", 
 RowBox[{
  RowBox[{"angles", " ", "=", " ", "\n", "  ", 
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{"1", "/", 
         RowBox[{"2", "^", "prec"}]}], " ", 
        RowBox[{"1", "/", 
         RowBox[{"FromDigits", "[", 
          RowBox[{"#", ",", " ", "2"}], "]"}]}]}], " ", "&"}], " ", "/@", " ", 
      RowBox[{"Rest", "@", 
       RowBox[{"Tuples", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"0", ",", " ", "1"}], "}"}], ",", " ", "prec"}], "]"}]}]}], 
     " ", "//", " ", "N"}], " ", "//", " ", "\n", "   ", 
    RowBox[{"Prepend", "[", "0", "]"}]}]}], ";"}]}], "Input",
 CellLabel->"In[1]:= ",ExpressionUUID->"fca356ec-3828-4b30-bf39-3a5cd8c6fecc"],

Cell["Generate the corresponding GrayOracle:", "ExampleText",ExpressionUUID->"061025b4-cab3-4b0b-8518-7601e8e93219"],

Cell[BoxData[
 RowBox[{
  RowBox[{"QuantumCircuitOperator", "[", 
   RowBox[{"\"\<GrayOracle\>\"", "[", 
    RowBox[{"angles", ",", " ", "prec", ",", " ", "1"}], "]"}], "]"}], "[", 
  RowBox[{"\"\<Diagram\>\"", ",", " ", "\n", " ", 
   RowBox[{"\"\<ShowGateLabels\>\"", " ", "->", " ", "False"}]}], 
  "]"}]], "Input",
 CellLabel->"In[2]:= ",ExpressionUUID->"efbd64ff-ac5f-4d0c-a003-0051baa171ab"],

Cell["\<\
It is the same as the following oracle, using a function as input:\
\>", "ExampleText",ExpressionUUID->"fc1f7912-04a4-43bb-9ea6-c776b907280f"],

Cell[BoxData[
 RowBox[{
  RowBox[{"QuantumCircuitOperator", "[", "\n", "  ", 
   RowBox[{"\"\<GrayOracle\>\"", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"If", "[", 
       RowBox[{
        RowBox[{"#", " ", "==", " ", "0"}], ",", " ", "0", ",", " ", 
        RowBox[{"1.", "/", "#"}]}], "]"}], " ", "&"}], ",", " ", "prec", ",", 
     " ", "1"}], "]"}], "]"}], "[", 
  RowBox[{"\"\<Diagram\>\"", ",", " ", "\n", " ", 
   RowBox[{"\"\<ShowGateLabels\>\"", " ", "->", " ", "False"}]}], 
  "]"}]], "Input",
 CellLabel->"In[3]:= ",ExpressionUUID->"d6669590-42ab-48d6-a30f-adc98092fcd9"],

Cell["GrayOracle is the same as Multiplexer with angles:", "ExampleText",ExpressionUUID->"d48e6d07-4121-4976-b2b1-0229da72f51b"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"inv", " ", "=", " ", 
   RowBox[{"QuantumCircuitOperator", "[", 
    RowBox[{
     RowBox[{"\"\<Multiplexer\>\"", " ", "@@", " ", 
      RowBox[{"\"\<RY\>\"", " ", "/@", " ", "angles"}]}], ",", " ", "\n", 
     "   ", 
     RowBox[{"RotateLeft", "[", 
      RowBox[{"Range", "[", 
       RowBox[{"prec", " ", "+", " ", "1"}], "]"}], "]"}]}], "]"}]}], ";"}], "\n", 
 RowBox[{"inv", "[", 
  RowBox[{"\"\<Diagram\>\"", ",", " ", 
   RowBox[{"\"\<ShowGateLabels\>\"", " ", "->", " ", "False"}]}], 
  "]"}]}], "Input",
 CellLabel->"In[4]:= ",ExpressionUUID->"02200870-dffd-4bac-9acd-a507431de69d"],

Cell["Check the Multiplexer is the same as GrayOracle:", "ExampleText",ExpressionUUID->"b0908a5c-038a-4414-af92-850c12be5971"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"(", 
    RowBox[{
     RowBox[{"inv", "[", "\"\<Matrix\>\"", "]"}], " ", "-", " ", "\n", "    ", 
     RowBox[{
      RowBox[{"QuantumCircuitOperator", "[", "\n", "      ", 
       RowBox[{"\"\<GrayOracle\>\"", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"If", "[", 
           RowBox[{
            RowBox[{"#", " ", "==", " ", "0"}], ",", " ", "0", ",", " ", 
            RowBox[{"1.", "/", "#"}]}], "]"}], " ", "&"}], ",", " ", "prec", ",",
          " ", "1"}], "]"}], "]"}], "[", "\"\<Matrix\>\"", "]"}]}], ")"}], "[",
    "\n", "  ", "\"\<ExplicitValues\>\"", "]"}], " ", "//", " ", 
  "Chop"}]], "Input",
 CellLabel->"In[5]:= ",ExpressionUUID->"c134f4bd-065e-4b84-ba55-b16d04cbe677"],

Cell["Grover circuit (and family of Boolean oracles)", "ExampleSubsubsection",ExpressionUUID->"49f7c118-78f1-47ff-bf5f-066cf8538b3f"],

Cell[TextData[{
 "There are a collection of named-circuits for the Grover search algorithm, \
and its oracles (e.g., Boolean, or Phase oracles) or amplification. The class \
of Grover-related named-circuits are ",
 Cell[BoxData[
  RowBox[{"QuantumCircuitOperator", "[", 
   RowBox[{
    StyleBox["name", "TI"], "[", 
    StyleBox["boo", "TI"], "]"}], "]"}]], "InlineFormula",ExpressionUUID->
  "8641e1ea-3547-4c71-8e03-6139be8ed877"],
 " with ",
 StyleBox["boo", "TI"],
 " a Boolean function."
}], "ExampleText",ExpressionUUID->"4e4b2720-5e11-4a23-a67d-daf9d2dcf6df"],

Cell["Boolean oracle for a given Boolean function:", "ExampleText",ExpressionUUID->"3961e720-0343-4242-8eae-bc72dc32716c"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"bo", " ", "=", " ", 
   RowBox[{"QuantumCircuitOperator", "[", 
    RowBox[{"\"\<BooleanOracle\>\"", "[", 
     RowBox[{"a", " ", "&&", " ", 
      RowBox[{"!", " ", "b"}]}], "]"}], "]"}]}], ";"}], "\n", 
 RowBox[{"bo", "[", "\"\<Diagram\>\"", "]"}]}], "Input",
 CellLabel->"In[1]:= ",ExpressionUUID->"2927c9c0-c6f9-4591-bcb5-0f2b17ad9d54"],

Cell[TextData[{
 "Boolean oracle will flip the ancillary qubit (in above example, 3rd qubit) \
only if the quantum state is a solution of the Boolean function. For example, \
",
 Cell[BoxData[
  RowBox[{"{", 
   RowBox[{"True", ",", "False"}], "}"}]], "InlineFormula",ExpressionUUID->
  "801bce5e-7b01-413f-9bcf-0ec3798b4604"],
 " (10) is a solution of ",
 Cell[BoxData[
  RowBox[{"a", "&&", 
   RowBox[{"!", "b"}]}]], "InlineFormula",ExpressionUUID->
  "f75b2a45-f8dd-4307-93ed-6b6b181447e6"],
 ", thus the ancillary qubit will be flipped:"
}], "ExampleText",ExpressionUUID->"cb60a534-ff20-49e8-a456-57a393064866"],

Cell[BoxData[
 RowBox[{
  RowBox[{"bo", "[", 
   RowBox[{"QuantumState", "[", "\"\<100\>\"", "]"}], "]"}], 
  "[", "\"\<Formula\>\"", "]"}]], "Input",
 CellLabel->"In[2]:= ",ExpressionUUID->"dfd6a718-424c-456f-a62b-c0515763cbd3"],

Cell["\<\
One can also get the decomposition of a Boolean oracle, in terms of CNOTs and \
Z-rotation:\
\>", "ExampleText",ExpressionUUID->"a333342c-b58e-4787-ad09-a582273b348e"],

Cell[BoxData[
 RowBox[{
  RowBox[{"QuantumCircuitOperator", "[", 
   RowBox[{"\"\<BooleanOracleR\>\"", "[", 
    RowBox[{"a", " ", "&&", " ", 
     RowBox[{"!", " ", "b"}]}], "]"}], "]"}], "[", "\"\<Diagram\>\"", 
  "]"}]], "Input",
 CellLabel->"In[3]:= ",ExpressionUUID->"091a260e-0b5a-43a1-8e7a-b45d18eeef79"],

Cell["\<\
For the diffusion part of the Grover circuit (also called, the amplification \
part), one only needs to specify the number of qubits:\
\>", "ExampleText",ExpressionUUID->"edad022e-bfdf-486e-b3ce-3ee541402ac0"],

Cell[BoxData[
 RowBox[{
  RowBox[{"QuantumCircuitOperator", "[", 
   RowBox[{"\"\<GroverDiffusion\>\"", "[", "3", "]"}], "]"}], 
  "[", "\"\<Diagram\>\"", "]"}]], "Input",
 CellLabel->"In[4]:= ",ExpressionUUID->"8177c201-a4a9-48ab-9468-a5a09a4b026d"],

Cell[BoxData[
 RowBox[{
  RowBox[{"QuantumCircuitOperator", "[", 
   RowBox[{"\"\<GroverDiffusion0\>\"", "[", "3", "]"}], "]"}], 
  "[", "\"\<Diagram\>\"", "]"}]], "Input",
 CellLabel->"In[5]:= ",ExpressionUUID->"b033f9c0-35e2-4d1c-9400-8877d3d07003"],

Cell["\<\
Another way of storing the solution of a Boolean function is to save it as a \
phase, rather than on an ancillary qubit. This can be archived by using a \
phase oracle, that add an overall phase of \[Pi] if the quantum state is a \
solution of the Boolean function.\
\>", "ExampleText",ExpressionUUID->"ceffe56a-a1d4-4f80-8f12-9cafb59cf637"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"po", " ", "=", " ", 
   RowBox[{"QuantumCircuitOperator", "[", 
    RowBox[{"\"\<PhaseOracle\>\"", "[", 
     RowBox[{"a", " ", "&&", " ", 
      RowBox[{"!", " ", "b"}]}], "]"}], "]"}]}], ";"}], "\n", 
 RowBox[{"po", "[", "\"\<Diagram\>\"", "]"}]}], "Input",
 CellLabel->"In[6]:= ",ExpressionUUID->"b8ddd1df-afb4-4002-9234-225d4b8ab1fd"],

Cell[BoxData[
 RowBox[{
  RowBox[{"po", "[", 
   RowBox[{"QuantumState", "[", "\"\<10\>\"", "]"}], "]"}], 
  "[", "\"\<Formula\>\"", "]"}]], "Input",
 CellLabel->"In[7]:= ",ExpressionUUID->"7ade624f-15f2-4b26-96b1-784ddacc2292"],

Cell["The corresponding diffusion part, given a phase oracle:", "ExampleText",ExpressionUUID->"017145f5-c13d-41c1-b232-c02bf84e54e0"],

Cell[BoxData[
 RowBox[{
  RowBox[{"QuantumCircuitOperator", "[", 
   RowBox[{"\"\<GroverPhaseDiffusion\>\"", "[", "2", "]"}], "]"}], 
  "[", "\"\<Diagram\>\"", "]"}]], "Input",
 CellLabel->"In[8]:= ",ExpressionUUID->"31c9585a-983f-4ac4-b640-685b0319580b"],

Cell["\<\
One can also create the overall Grover circuit, using controlled-1 gates and \
a Boolean oracle:\
\>", "ExampleText",ExpressionUUID->"042f83e6-8251-4728-8af1-571eac863602"],

Cell[BoxData[
 RowBox[{
  RowBox[{"QuantumCircuitOperator", "[", 
   RowBox[{"\"\<Grover\>\"", "[", 
    RowBox[{"a", " ", "&&", " ", 
     RowBox[{"!", " ", "b"}]}], "]"}], "]"}], "[", "\"\<Diagram\>\"", 
  "]"}]], "Input",
 CellLabel->"In[9]:= ",ExpressionUUID->"2935345e-ae5a-4b29-ad9e-614d5ab57def"],

Cell["\<\
One can also create the overall Grover circuit, using controlled-0 gates and \
a Boolean oracle:\
\>", "ExampleText",ExpressionUUID->"f4a4bcc6-fc58-47d6-a92f-8ee287da4bfc"],

Cell[BoxData[
 RowBox[{
  RowBox[{"QuantumCircuitOperator", "[", 
   RowBox[{"\"\<Grover0\>\"", "[", 
    RowBox[{"a", " ", "&&", " ", 
     RowBox[{"!", " ", "b"}]}], "]"}], "]"}], "[", "\"\<Diagram\>\"", 
  "]"}]], "Input",
 CellLabel->
  "In[10]:= ",ExpressionUUID->"cfd90f55-23ef-4d5f-93b1-1da28fc306f2"],

Cell["\<\
One can also create the overall Grover circuit, using controlled-1 gates and \
a phase oracle:\
\>", "ExampleText",ExpressionUUID->"a94b8b5f-5d66-4807-930b-8067f18865e7"],

Cell[BoxData[
 RowBox[{
  RowBox[{"QuantumCircuitOperator", "[", 
   RowBox[{"\"\<GroverPhase\>\"", "[", 
    RowBox[{"a", " ", "&&", " ", 
     RowBox[{"!", " ", "b"}]}], "]"}], "]"}], "[", "\"\<Diagram\>\"", 
  "]"}]], "Input",
 CellLabel->
  "In[11]:= ",ExpressionUUID->"9c9e8844-ddca-4f05-808c-374844770d49"],

Cell["\<\
One can also create the overall Grover circuit, using controlled-0 gates and \
a phase oracle:\
\>", "ExampleText",ExpressionUUID->"5547b163-aed5-4d6b-9ebf-31668483724a"],

Cell[BoxData[
 RowBox[{
  RowBox[{"QuantumCircuitOperator", "[", 
   RowBox[{"\"\<GroverPhase0\>\"", "[", 
    RowBox[{"a", " ", "&&", " ", 
     RowBox[{"!", " ", "b"}]}], "]"}], "]"}], "[", "\"\<Diagram\>\"", 
  "]"}]], "Input",
 CellLabel->
  "In[12]:= ",ExpressionUUID->"8b6f9553-4667-4c5a-bac5-897c5f87739b"],

Cell["CHSH circuit", "ExampleSubsubsection",ExpressionUUID->"aed0e9b4-0661-4160-ba2f-c7efd89c19f1"],

Cell["CHSH quantum circuit:", "ExampleText",ExpressionUUID->"6ca70fb3-8bec-4eb8-a6ad-d1aa5b61a2f0"],

Cell[BoxData[
 RowBox[{
  RowBox[{"QuantumCircuitOperator", "[", "\"\<CHSH\>\"", "]"}], "[", 
  RowBox[{"\"\<Diagram\>\"", ",", " ", 
   RowBox[{"Sequence", "[", "\n", " ", 
    RowBox[{
     RowBox[{"\"\<ShowMeasurementWire\>\"", " ", "->", " ", "False"}], ",", 
     " ", 
     RowBox[{"\"\<WireLabels\>\"", " ", "->", " ", 
      RowBox[{"{", "\n", 
       RowBox[{
        RowBox[{"Placed", "[", 
         RowBox[{"\"\<a\>\"", ",", " ", "Right"}], "]"}], ",", " ", "\n", 
        RowBox[{"Placed", "[", 
         RowBox[{"\"\<x\>\"", ",", " ", "Right"}], "]"}], ",", " ", "\n", 
        RowBox[{"Placed", "[", 
         RowBox[{"\"\<y\>\"", ",", " ", "Right"}], "]"}], ",", " ", "\n", 
        RowBox[{"Placed", "[", 
         RowBox[{"\"\<b\>\"", ",", " ", "Right"}], "]"}]}], "}"}]}], ",", " ", 
     RowBox[{"Epilog", " ", "->", " ", 
      RowBox[{"{", "\n", 
       RowBox[{
        RowBox[{"Opacity", "[", "0.3", "]"}], ",", " ", "\n", 
        RowBox[{"Text", "[", "\n", 
         RowBox[{
          RowBox[{"Style", "[", 
           
           RowBox[{"\"\<a\[Xor]b\\!\\(\\*OverscriptBox[\\(=\\), \\(?\\)]\\)x\
\[And]y\>\"", ",", " ", "Black", ",", " ", "\n", "      ", "20", ",", " ", 
            "Bold"}], "]"}], ",", " ", 
          RowBox[{"{", 
           RowBox[{"9.", ",", " ", 
            RowBox[{"-", "2.35"}]}], "}"}]}], "]"}]}], "}"}]}], ",", " ", 
     RowBox[{"PlotRange", " ", "->", " ", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"0", ",", " ", "10"}], "}"}], ",", " ", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"-", "5"}], ",", " ", "0"}], "}"}]}], "}"}]}], ",", " ", 
     "\n", "  ", 
     RowBox[{"ImageSize", " ", "->", " ", "Large"}]}], "]"}]}], 
  "]"}]], "Input",
 CellLabel->"In[1]:= ",ExpressionUUID->"3d63c5c0-0e61-4370-8128-9f1337928780"],

Cell["Calculate the probability of winning:", "ExampleText",ExpressionUUID->"928af881-1ef5-4f3b-b2e1-e9115eb516c2"],

Cell[BoxData[
 RowBox[{"NProbability", "[", "\n", " ", 
  RowBox[{
   RowBox[{
    RowBox[{"BitAnd", "[", 
     RowBox[{"x", ",", " ", "y"}], "]"}], " ", "==", " ", 
    RowBox[{"BitXor", "[", 
     RowBox[{"a", ",", " ", "b"}], "]"}]}], ",", " ", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"a", ",", " ", "x", ",", " ", "y", ",", " ", "b"}], "}"}], " ", "\[Distributed]",
     " ", "\n", "  ", 
    RowBox[{
     RowBox[{
      RowBox[{"QuantumCircuitOperator", "[", "\"\<CHSH\>\"", "]"}], "[", 
      "]"}], "[", "\"\<MultivariateDistribution\>\"", "]"}]}]}], 
  "]"}]], "Input",
 CellLabel->"In[2]:= ",ExpressionUUID->"3fa66275-d76d-4f05-9e2f-51ec774aaf90"],

Cell["Trotter-Suzuki", "ExampleSubsubsection",ExpressionUUID->"3c9125a4-b1f1-404f-b9cd-9bafe14553c4"],

Cell["\<\
One can find Trotter-Suzuki decomposition, to approximate a time evolution.\
\>", "ExampleText",ExpressionUUID->"6431a124-9ac9-49cc-99c8-e447cc570443"],

Cell["First order, only:", "ExampleText",ExpressionUUID->"b60e0772-4fb9-482d-9c4d-b65474b56ea0"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"qc", " ", "=", " ", 
   RowBox[{"QuantumCircuitOperator", "[", 
    RowBox[{"{", 
     RowBox[{"\"\<Trotterization\>\"", ",", " ", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"QuantumOperator", "[", "\n", "      ", 
         RowBox[{"\"\<X\>\"", ",", " ", 
          RowBox[{"{", 
           RowBox[{"1", ",", " ", "2"}], "}"}]}], "]"}], ",", " ", 
        RowBox[{"QuantumOperator", "[", 
         RowBox[{"\"\<X\>\"", ",", " ", 
          RowBox[{"{", 
           RowBox[{"2", ",", " ", "3"}], "}"}]}], "]"}]}], "}"}], ",", " ", 
      "1", ",", " ", "1", ",", " ", "1"}], "}"}], "]"}]}], ";"}], "\n", 
 RowBox[{"qc", "[", "\"\<Diagram\>\"", "]"}]}], "Input",
 CellLabel->"In[1]:= ",ExpressionUUID->"fbfeb180-a82d-4cf0-8696-746a2b219c01"],

Cell["2nd order:", "ExampleText",ExpressionUUID->"59153f9d-49a1-4286-823f-b54287c79c93"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"qc", " ", "=", " ", 
   RowBox[{"QuantumCircuitOperator", "[", 
    RowBox[{"{", 
     RowBox[{"\"\<Trotterization\>\"", ",", " ", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"QuantumOperator", "[", "\n", "      ", 
         RowBox[{"\"\<X\>\"", ",", " ", 
          RowBox[{"{", 
           RowBox[{"1", ",", " ", "2"}], "}"}]}], "]"}], ",", " ", 
        RowBox[{"QuantumOperator", "[", 
         RowBox[{"\"\<X\>\"", ",", " ", 
          RowBox[{"{", 
           RowBox[{"2", ",", " ", "3"}], "}"}]}], "]"}]}], "}"}], ",", " ", 
      "2", ",", " ", "1", ",", " ", "1"}], "}"}], "]"}]}], ";"}], "\n", 
 RowBox[{"qc", "[", "\"\<Diagram\>\"", "]"}]}], "Input",
 CellLabel->"In[2]:= ",ExpressionUUID->"d253e9db-516b-416f-a803-2980fd50ff79"],

Cell["2nd order, with 4 steps:", "ExampleText",ExpressionUUID->"fd7c4062-afde-4a33-ab4c-ab55d9eec2c1"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"qc", " ", "=", " ", 
   RowBox[{"QuantumCircuitOperator", "[", 
    RowBox[{"{", 
     RowBox[{"\"\<Trotterization\>\"", ",", " ", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"QuantumOperator", "[", "\n", "      ", 
         RowBox[{"\"\<X\>\"", ",", " ", 
          RowBox[{"{", 
           RowBox[{"1", ",", " ", "2"}], "}"}]}], "]"}], ",", " ", 
        RowBox[{"QuantumOperator", "[", 
         RowBox[{"\"\<X\>\"", ",", " ", 
          RowBox[{"{", 
           RowBox[{"2", ",", " ", "3"}], "}"}]}], "]"}]}], "}"}], ",", " ", 
      "2", ",", " ", "4", ",", " ", "1"}], "}"}], "]"}]}], ";"}], "\n", 
 RowBox[{"qc", "[", 
  RowBox[{"\"\<Diagram\>\"", ",", " ", 
   RowBox[{"FontSize", " ", "->", " ", "8"}]}], "]"}]}], "Input",
 CellLabel->"In[3]:= ",ExpressionUUID->"0b96de9f-0ae9-4f39-a032-9ea691546f50"],

Cell["4th order, only 1 step:", "ExampleText",ExpressionUUID->"12618967-8ea5-45a2-a4d6-1135f6edd5bd"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"qc", " ", "=", " ", 
   RowBox[{"QuantumCircuitOperator", "[", 
    RowBox[{"{", 
     RowBox[{"\"\<Trotterization\>\"", ",", " ", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"QuantumOperator", "[", "\n", "      ", 
         RowBox[{"\"\<X\>\"", ",", " ", 
          RowBox[{"{", 
           RowBox[{"1", ",", " ", "2"}], "}"}]}], "]"}], ",", " ", 
        RowBox[{"QuantumOperator", "[", 
         RowBox[{"\"\<X\>\"", ",", " ", 
          RowBox[{"{", 
           RowBox[{"2", ",", " ", "3"}], "}"}]}], "]"}]}], "}"}], ",", " ", 
      "4", ",", " ", "1", ",", " ", "1"}], "}"}], "]"}]}], ";"}], "\n", 
 RowBox[{"qc", "[", 
  RowBox[{"\"\<Diagram\>\"", ",", " ", 
   RowBox[{"\"\<ShowGateLabels\>\"", " ", "->", " ", "False"}]}], 
  "]"}]}], "Input",
 CellLabel->"In[4]:= ",ExpressionUUID->"3b92e9ff-a797-449c-ac8a-4d50e0c91293"],

Cell["PhaseNumber circuit", "ExampleSubsubsection",ExpressionUUID->"9628defd-eee7-46ce-8e0d-141dd2ccc902"],

Cell["PhaseNumber circuit encodes a number in n-qubit.", "ExampleText",ExpressionUUID->"75b747a8-492f-437e-88cd-e299a76f14ce"],

Cell["Encode 5 in 4-qubits:", "ExampleText",ExpressionUUID->"5ae79b57-2822-43de-926c-5bb839da9c24"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"num", " ", "=", " ", "5"}], ";"}], "\n", 
 RowBox[{
  RowBox[{"QuantumCircuitOperator", "[", 
   RowBox[{"\"\<PhaseNumber\>\"", "[", 
    RowBox[{"num", ",", " ", "4"}], "]"}], "]"}], "[", "\"\<Diagram\>\"", 
  "]"}]}], "Input",
 CellLabel->"In[1]:= ",ExpressionUUID->"123cd734-2509-4b8e-9c88-9bc1d42131cc"],

Cell["Remove Hadamards:", "ExampleText",ExpressionUUID->"69b6549c-8a2f-483a-8bf5-f61586cbf038"],

Cell[BoxData[
 RowBox[{
  RowBox[{"QuantumCircuitOperator", "[", 
   RowBox[{"\"\<PhaseNumber\>\"", "[", 
    RowBox[{"num", ",", " ", "4", ",", " ", "False"}], "]"}], "]"}], 
  "[", "\"\<Diagram\>\"", "]"}]], "Input",
 CellLabel->"In[2]:= ",ExpressionUUID->"71d0c3e2-750d-4d71-97ba-b3a5b6034e4e"],

Cell["\<\
PhaseNumber followed by InverseFourier generates a circuit that can be used \
to calculate the encoded number:\
\>", "ExampleText",ExpressionUUID->"cfa749e5-6ef0-4217-96cf-c6e375b64ab2"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"num", " ", "=", " ", "5"}], ";"}], "\n", 
 RowBox[{
  RowBox[{"qc", " ", "=", " ", 
   RowBox[{"QuantumCircuitOperator", "[", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"\"\<PhaseNumber\>\"", "[", 
       RowBox[{"num", ",", " ", "6"}], "]"}], ",", " ", "\n", "    ", 
      RowBox[{"\"\<InverseFourier\>\"", "[", "6", "]"}], ",", " ", 
      RowBox[{"Range", "[", "6", "]"}]}], "}"}], "]"}]}], ";"}], "\n", 
 RowBox[{"qc", "[", "\"\<Diagram\>\"", "]"}]}], "Input",
 CellLabel->"In[3]:= ",ExpressionUUID->"04dcb4f0-8a5a-46d2-a0d8-0ffc342d04e7"],

Cell["Corresponding measurement probabilities:", "ExampleText",ExpressionUUID->"0c085fd0-51fe-41f8-83e9-94ada9137da6"],

Cell[BoxData[
 RowBox[{"m", " ", "=", " ", 
  RowBox[{
   RowBox[{"N", "[", "qc", "]"}], "[", "]"}]}]], "Input",
 CellLabel->"In[4]:= ",ExpressionUUID->"22865f30-db11-4ed9-9a15-ec504df4ae1b"],

Cell["\<\
Given the result with max probability, find the corresponding integer from \
bit-string:\
\>", "ExampleText",ExpressionUUID->"4a0addf3-029d-45ad-82fb-d8df5cbf3125"],

Cell[BoxData[
 RowBox[{"FromDigits", "[", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"Keys", "[", 
      RowBox[{"TakeLargest", "[", 
       RowBox[{
        RowBox[{"m", "[", "\"\<Probabilities\>\"", "]"}], ",", " ", "1"}], 
       "]"}], "]"}], "[", 
     RowBox[{"[", "1", "]"}], "]"}], "[", "\"\<Name\>\"", "]"}], ",", " ", 
   "2"}], "]"}]], "Input",
 CellLabel->"In[5]:= ",ExpressionUUID->"44618d89-a616-450d-8216-55ff2468bad0"],

Cell["Check it is the same as initial encoded number:", "ExampleText",ExpressionUUID->"6ba6502c-12fa-4291-a912-101c55cbdaee"],

Cell[BoxData[
 RowBox[{"%", " ", "==", " ", "num"}]], "Input",
 CellLabel->"In[6]:= ",ExpressionUUID->"bbbcf04e-ccb6-481c-9e6c-6d8da5aac2d0"],

Cell["The PhaseNumber circuits follow the usual addition:", "ExampleText",ExpressionUUID->"32a95ef3-1b42-4e76-8ef5-17fccb0ece2d"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"qc1", " ", "=", " ", 
   RowBox[{"QuantumCircuitOperator", "[", 
    RowBox[{"{", 
     RowBox[{"\"\<PhaseNumber\>\"", ",", " ", "5", ",", " ", "6"}], "}"}], 
    "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"qc2", " ", "=", " ", 
   RowBox[{"QuantumCircuitOperator", "[", 
    RowBox[{"{", 
     RowBox[{"\"\<PhaseNumber\>\"", ",", " ", "3", ",", " ", "6", ",", " ", 
      "False"}], "}"}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"(", 
   RowBox[{"qc1", "/*", "qc2"}], ")"}], "[", "\"\<Diagram\>\"", 
  "]"}]}], "Input",
 CellLabel->"In[7]:= ",ExpressionUUID->"b9072c21-a143-48d0-88c5-b05afe4e1b0d"],

Cell["Test that 5+3=8, in terms of their circuits:", "ExampleText",ExpressionUUID->"0d2e6ef5-7c36-4e89-a1b5-25f85e940ca0"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"(", 
    RowBox[{"qc1", "/*", "qc2"}], ")"}], "[", "\"\<CircuitOperator\>\"", 
   "]"}], " ", "==", " ", "\n", " ", 
  RowBox[{
   RowBox[{"QuantumCircuitOperator", "[", 
    RowBox[{"{", 
     RowBox[{"\"\<PhaseNumber\>\"", ",", " ", 
      RowBox[{"5", " ", "+", " ", "3"}], ",", " ", "6"}], "}"}], "]"}], 
   "[", "\"\<CircuitOperator\>\"", "]"}]}]], "Input",
 CellLabel->"In[8]:= ",ExpressionUUID->"2f7a7f04-e630-4e76-8be9-3e7873411f64"],

Cell["Deutsch-Jozsa circuit", "ExampleSubsubsection",ExpressionUUID->"fdaa42bb-0163-4c3b-a3a8-98031a523e72"],

Cell["\<\
For the Deutsch-Jozsa algorithm, the goal is to determine whether a Boolean \
function is constant (producing the same output regardless of the input, \
either 0 or 1) or balanced (yielding an equal number of 0s and 1s).\
\>", "ExampleText",ExpressionUUID->"ac325f24-25a2-4dbd-8aa2-3349c1886287"],

Cell["Define a balanced Boolean function:", "ExampleText",ExpressionUUID->"40c4c001-0226-47c6-ab5c-e976cc1c0157"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"bf", " ", "=", " ", 
   RowBox[{"BooleanFunction", "[", 
    RowBox[{"2", ",", " ", "2"}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"BooleanConvert", "[", "bf", "]"}], "[", 
  RowBox[{"\[FormalX]", ",", " ", "\[FormalY]"}], "]"}]}], "Input",
 CellLabel->"In[1]:= ",ExpressionUUID->"f1eb427d-9cad-464e-b951-9a4c619bcaf5"],

Cell["Show its Boolean table (note same number of True and False)", \
"ExampleText",ExpressionUUID->"d43b3083-2fe7-47ea-9646-c3901db07dfc"],

Cell[BoxData[
 RowBox[{"BooleanTable", "[", "bf", "]"}]], "Input",
 CellLabel->"In[2]:= ",ExpressionUUID->"1c77f728-d392-47c4-a878-9718c51dd1d5"],

Cell[BoxData[
 RowBox[{
  RowBox[{"QuantumCircuitOperator", "[", 
   RowBox[{"\"\<DeutschJozsa\>\"", "[", "bf", "]"}], "]"}], 
  "[", "\"\<Diagram\>\"", "]"}]], "Input",
 CellLabel->"In[3]:= ",ExpressionUUID->"1f0c99f7-1c41-4499-8edf-48961aecb777"],

Cell["One can also get the Deutsch-Jozsa with a Phase oracle:", "ExampleText",ExpressionUUID->"0b69bba3-b14e-4dab-9a75-7b71688bcefc"],

Cell[BoxData[
 RowBox[{
  RowBox[{"QuantumCircuitOperator", "[", 
   RowBox[{"\"\<DeutschJozsaPhase\>\"", "[", "bf", "]"}], "]"}], 
  "[", "\"\<Diagram\>\"", "]"}]], "Input",
 CellLabel->"In[4]:= ",ExpressionUUID->"8caa48aa-1908-4d0a-aa3f-7cd3f46c8eda"],

Cell[TextData[{
 "Also, \[OpenCurlyDoubleQuote]DeutschJozsaPhase\[CloseCurlyDoubleQuote] can \
take two integers, with the first one ",
 Cell[BoxData[
  RowBox[{
   StyleBox["k", "TI"], "+", "1"}]], "InlineFormula",ExpressionUUID->
  "ee55c41a-8453-4e4f-bd68-96717bc8a774"],
 " and second one as ",
 Cell[BoxData[
  StyleBox["n", "TI"]], "InlineFormula",ExpressionUUID->
  "f728e728-089e-4e2d-83f8-9e71aabcb140"],
 ", where the Boolean function is defined as BooleanFunction[k,n]"
}], "ExampleText",ExpressionUUID->"08d18507-61a9-467d-bcaa-baa626ed18aa"],

Cell[BoxData[
 RowBox[{
  RowBox[{"QuantumCircuitOperator", "[", 
   RowBox[{"\"\<DeutschJozsaPhase\>\"", "[", 
    RowBox[{"3", ",", " ", "2"}], "]"}], "]"}], "[", "\"\<Diagram\>\"", 
  "]"}]], "Input",
 CellLabel->"In[5]:= ",ExpressionUUID->"d1e64859-3199-409e-9d27-b35355d7d3b1"],

Cell["\<\
Given all Boolean functions with two variables, show number of True and False \
in their solutions, and also corresponding Deutsch-Jozsa probabilities:\
\>", "ExampleText",ExpressionUUID->"c8fbe177-cca9-4839-9ad9-c8d32b1543ab"],

Cell[BoxData[
 RowBox[{"Grid", "[", 
  RowBox[{
   RowBox[{"Prepend", "[", "\n", "  ", 
    RowBox[{
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{"With", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"bf", " ", "=", " ", "\n", "      ", 
           RowBox[{"BooleanFunction", "[", 
            RowBox[{"f", ",", " ", "2"}], "]"}]}], "}"}], ",", " ", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{
            RowBox[{"BooleanConvert", "[", "\n", "       ", "bf", "]"}], "[", 
            
            RowBox[{"\[FormalX]", ",", " ", "\[FormalY]"}], "]"}], ",", " ", 
           RowBox[{
            RowBox[{"Count", "[", "True", "]"}], "[", 
            RowBox[{"BooleanTable", "[", "bf", "]"}], "]"}], ",", " ", "\n", 
           "     ", 
           RowBox[{
            RowBox[{"Count", "[", "False", "]"}], "[", 
            RowBox[{"BooleanTable", "[", "bf", "]"}], "]"}], ",", " ", "\n", 
           "     ", 
           RowBox[{"With", "[", 
            RowBox[{
             RowBox[{"{", 
              RowBox[{"rs", " ", "=", " ", "\n", "        ", 
               RowBox[{
                RowBox[{
                 RowBox[{"QuantumCircuitOperator", "[", 
                  RowBox[{"\"\<DeutschJozsa\>\"", "[", "bf", "]"}], "]"}], "[",
                  "]"}], "[", "\"\<Probabilities\>\"", "]"}]}], "}"}], ",", 
             "\n", "       ", 
             RowBox[{"BarChart", "[", 
              RowBox[{"rs", ",", " ", 
               RowBox[{"ChartLabels", " ", "->", " ", 
                RowBox[{"Keys", "[", "rs", "]"}]}], ",", " ", 
               RowBox[{"AspectRatio", " ", "->", " ", 
                RowBox[{"1", "/", "3"}]}], ",", " ", "\n", "       ", 
               RowBox[{"ImageSize", " ", "->", " ", "Small"}]}], "]"}]}], 
            "]"}]}], "}"}]}], "]"}], ",", " ", 
       RowBox[{"{", 
        RowBox[{"f", ",", " ", "0", ",", " ", "15"}], "}"}]}], "]"}], ",", 
     " ", "\n", "  ", 
     RowBox[{
      RowBox[{
       RowBox[{"Style", "[", 
        RowBox[{"#", ",", " ", "Bold"}], "]"}], " ", "&"}], " ", "/@", " ", 
      RowBox[{"{", 
       RowBox[{"\"\<Boolean function\>\"", ",", " ", "\"\<True\>\"", ",", 
        " ", "\"\<False\>\"", ",", " ", "\n", 
        "    ", "\"\<Deutsch-Jozsa probabilities\>\""}], "}"}]}]}], "]"}], ",",
    " ", 
   RowBox[{"Frame", " ", "->", " ", "All"}], ",", " ", "\n", " ", 
   RowBox[{"Alignment", " ", "->", " ", 
    RowBox[{"{", 
     RowBox[{"{", 
      RowBox[{
      "Left", ",", " ", "Center", ",", " ", "Center", ",", " ", "Center"}], 
      "}"}], "}"}]}]}], "]"}]], "Input",
 CellLabel->"In[6]:= ",ExpressionUUID->"ce5a9e0c-a3cb-4db9-bd5f-1323f66dd735"],

Cell["Leggett-Garg:", "ExampleSubsubsection",ExpressionUUID->"8f22823c-4758-4aa0-8231-8aaf2ddc36b1"],

Cell[BoxData[
 RowBox[{
  RowBox[{"QuantumCircuitOperator", "[", "\"\<LeggettGarg\>\"", "]"}], 
  "[", "\"\<Diagram\>\"", "]"}]], "Input",
 CellLabel->"In[1]:= ",ExpressionUUID->"657b91d0-3187-46be-943e-bc40d0594251"],

Cell["State-preparation", "ExampleSubsubsection",ExpressionUUID->"4483680b-f356-4625-9b25-91d714770dde"],

Cell["Generate a random pure state of 3-qubits:", "ExampleText",ExpressionUUID->"a2935bd9-5df7-42c1-8ea7-1c86c606add1"],

Cell[BoxData[
 RowBox[{"state", " ", "=", " ", 
  RowBox[{"QuantumState", "[", 
   RowBox[{"\"\<RandomPure\>\"", "[", "3", "]"}], "]"}]}]], "Input",
 CellLabel->"In[1]:= ",ExpressionUUID->"1256cff3-1ba5-4d2d-a055-45d8fd04dc91"],

Cell["Generate a circuit whose outcome is above state:", "ExampleText",ExpressionUUID->"227352e7-831a-40ee-bd2b-6ea928cbdb32"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"qc", " ", "=", " ", 
   RowBox[{"QuantumCircuitOperator", "[", 
    RowBox[{"\"\<QuantumState\>\"", "[", "state", "]"}], "]"}]}], ";"}], "\n", 
 RowBox[{"qc", "[", 
  RowBox[{"\"\<Diagram\>\"", ",", " ", 
   RowBox[{"\"\<ShowGateLabels\>\"", " ", "->", " ", "False"}]}], 
  "]"}]}], "Input",
 CellLabel->"In[2]:= ",ExpressionUUID->"433bf96a-2d29-4413-8e28-b101c029ddd2"],

Cell["Check the execution of the circuit gives the expected state:", \
"ExampleText",ExpressionUUID->"aa000b0f-a1be-465b-8ac3-2554c65ce98e"],

Cell[BoxData[
 RowBox[{
  RowBox[{"qc", "[", "]"}], " ", "==", " ", "state"}]], "Input",
 CellLabel->"In[3]:= ",ExpressionUUID->"e79f8872-3678-4141-a81d-f3e407f72a5e"],

Cell["One can also use \"StatePreparation\":", "ExampleText",ExpressionUUID->"d3ec9c44-1f08-45d6-ac1b-d6b06b09b919"],

Cell[BoxData[
 RowBox[{
  RowBox[{"QuantumCircuitOperator", "[", 
   RowBox[{"\"\<StatePreparation\>\"", "[", "state", "]"}], "]"}], "[", 
  RowBox[{"\"\<Diagram\>\"", ",", " ", "\n", " ", 
   RowBox[{"\"\<ShowGateLabels\>\"", " ", "->", " ", "False"}]}], 
  "]"}]], "Input",
 CellLabel->"In[4]:= ",ExpressionUUID->"12d193e2-c9b7-4ce3-822c-7718b9638655"],

Cell["Quantum circuit diagram", "ExampleSubsection",ExpressionUUID->"21a80d89-fbfe-4490-ab2d-a5dbc07ec593"],

Cell["\<\
One can customize many features of a circuit diagram. See Circuit Diagram \
documentation page, for more details.\
\>", "ExampleText",ExpressionUUID->"2760f788-16b8-4f97-8079-9aa8fb5e709f"],

Cell[BoxData[
 RowBox[{
  RowBox[{"QuantumCircuitOperator", "[", 
   RowBox[{"{", 
    RowBox[{"\"\<H\>\"", ",", " ", "\"\<CY\>\"", ",", " ", "\"\<H\>\"", ",", 
     " ", 
     RowBox[{"{", "1", "}"}]}], "}"}], "]"}], "[", 
  RowBox[{"\"\<Diagram\>\"", ",", " ", "\n", " ", 
   RowBox[{"\"\<WireLabels\>\"", " ", "->", " ", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{"Placed", "[", 
         RowBox[{"\"\<1st qubit\>\"", ",", " ", "Left"}], "]"}], ",", " ", 
        "\n", "    ", 
        RowBox[{"Placed", "[", 
         RowBox[{"\"\<Eigenvector of Y\>\"", ",", " ", "Right"}], "]"}]}], 
       "}"}], ",", " ", 
      RowBox[{"{", 
       RowBox[{"Placed", "[", 
        RowBox[{"\"\<2nd qubit\>\"", ",", " ", "Left"}], "]"}], "}"}]}], 
     "}"}]}], ",", " ", "\n", " ", 
   RowBox[{"\"\<MeasurementWireLabel\>\"", " ", "->", 
    " ", "\"\<Measurement Wire\>\""}]}], "]"}]], "Input",
 CellLabel->"In[1]:= ",ExpressionUUID->"dbe86eac-e77b-487e-b388-8ec6a81b27b6"],

Cell["Also, the overall size of the circuit can be adjusted:", "ExampleText",ExpressionUUID->"408eab1d-b816-4d52-9e73-6fd4ae49fd11"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"superdense", " ", "=", " ", "\n", "  ", 
   RowBox[{"QuantumCircuitOperator", "[", 
    RowBox[{"{", 
     RowBox[{"\"\<H\>\"", ",", " ", "\"\<CNOT\>\"", ",", " ", 
      RowBox[{"\"\<CX\>\"", " ", "->", " ", 
       RowBox[{"{", 
        RowBox[{"4", ",", " ", "1"}], "}"}]}], ",", " ", 
      RowBox[{"\"\<CZ\>\"", " ", "->", " ", 
       RowBox[{"{", 
        RowBox[{"3", ",", " ", "1"}], "}"}]}], ",", "\n", 
      "     ", "\"\<CNOT\>\"", ",", " ", "\"\<H\>\"", ",", " ", 
      RowBox[{"{", "1", "}"}], ",", " ", 
      RowBox[{"{", "2", "}"}]}], "}"}], "]"}]}], ";"}], "\n", 
 RowBox[{"superdense", "[", 
  RowBox[{"\"\<Diagram\>\"", ",", " ", 
   RowBox[{"\"\<Size\>\"", " ", "->", " ", ".5"}]}], "]"}]}], "Input",
 CellLabel->"In[2]:= ",ExpressionUUID->"9c96dae4-0f81-445e-8ba8-4ab489c0d155"],

Cell["\<\
Additionally, one can customize the horizontal and vertical gaps:\
\>", "ExampleText",ExpressionUUID->"72eec125-906e-41b1-aae9-34179de83564"],

Cell[BoxData[
 RowBox[{"superdense", "[", 
  RowBox[{"\"\<Diagram\>\"", ",", " ", 
   RowBox[{"\"\<HorizontalGapSize\>\"", " ", "->", " ", "3"}]}], 
  "]"}]], "Input",
 CellLabel->"In[3]:= ",ExpressionUUID->"2f1a4b8c-c292-4abb-93e6-12fe9d6ee338"],

Cell["Customize the vertical gap:", "ExampleText",ExpressionUUID->"f3374de2-60ef-4adf-ad29-2c2aae4a0e15"],

Cell[BoxData[
 RowBox[{"superdense", "[", 
  RowBox[{"\"\<Diagram\>\"", ",", " ", 
   RowBox[{"\"\<VerticalGapSize\>\"", " ", "->", " ", "2"}]}], "]"}]], "Input",\

 CellLabel->"In[4]:= ",ExpressionUUID->"874802fd-07bf-42e8-b535-89244e50b24a"],

Cell["\<\
Another interesting feature for the Diagram is showing the connectors as dot, \
specifying explicitly on what wires a gate acts:\
\>", "ExampleText",ExpressionUUID->"2b57eaa5-4782-4a7a-a72b-4c12c060b489"],

Cell[BoxData[
 RowBox[{
  RowBox[{"QuantumCircuitOperator", "[", 
   RowBox[{"{", 
    RowBox[{"QuantumOperator", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"\"\<R\>\"", ",", " ", "\[Theta]", ",", " ", "\"\<XX\>\""}], 
       "}"}], ",", " ", 
      RowBox[{"{", 
       RowBox[{"1", ",", " ", "\n", "     ", "3"}], "}"}]}], "]"}], "}"}], 
   "]"}], "[", 
  RowBox[{"\"\<Diagram\>\"", ",", " ", 
   RowBox[{"\"\<ShowConnectors\>\"", " ", "->", " ", "True"}]}], 
  "]"}]], "Input",
 CellLabel->"In[5]:= ",ExpressionUUID->"6e3be82d-277e-4d4d-b0fa-36e3f8d695d3"],

Cell["\<\
But a portion of a circuit in a gray box, to emphasizing one portion:\
\>", "ExampleText",ExpressionUUID->"2a4212e5-2fa6-4ed1-b0df-8507e657b9b7"],

Cell[BoxData[
 RowBox[{
  RowBox[{"QuantumCircuitOperator", "[", 
   RowBox[{"{", 
    RowBox[{"\"\<CNOT\>\"", ",", " ", "\n", "   ", 
     RowBox[{"QuantumCircuitOperator", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{"QuantumOperator", "[", 
          RowBox[{"\"\<SWAP\>\"", ",", " ", 
           RowBox[{"{", 
            RowBox[{"2", ",", " ", "4"}], "}"}]}], "]"}], ",", " ", "\n", 
         "     ", 
         RowBox[{"QuantumOperator", "[", 
          RowBox[{"{", 
           RowBox[{"\"\<Phase\>\"", ",", " ", "\[Gamma]"}], "}"}], "]"}]}], 
        "}"}], ",", " ", "\"\<MyCir\>\""}], "]"}]}], "}"}], "]"}], 
  "[", "\"\<Diagram\>\"", "]"}]], "Input",
 CellLabel->"In[6]:= ",ExpressionUUID->"063af23f-e67f-4b17-9547-3f172b533278"],

Cell["\<\
Drop the gate labels (if you hover you mouse over the diagram, the labels \
will be shown):\
\>", "ExampleText",ExpressionUUID->"8eed8c2e-12fb-4e7a-a64e-7a3c9afd07f3"],

Cell[BoxData[
 RowBox[{
  RowBox[{"QuantumCircuitOperator", "[", 
   RowBox[{"{", 
    RowBox[{"\"\<H\>\"", ",", " ", "\"\<CY\>\"", ",", " ", "\"\<H\>\"", ",", 
     " ", 
     RowBox[{"{", "1", "}"}]}], "}"}], "]"}], "[", 
  RowBox[{"\"\<Diagram\>\"", ",", " ", "\n", " ", 
   RowBox[{"\"\<ShowGateLabels\>\"", " ", "->", " ", "False"}]}], 
  "]"}]], "Input",
 CellLabel->"In[7]:= ",ExpressionUUID->"4be4d25d-8772-4f40-8305-adfa24881f35"],

Cell["Tensor network of a quantum circuit", "ExampleSubsection",ExpressionUUID->"cb1677ec-ac6c-470e-a505-79c5d5d7cf06"],

Cell["\<\
Corresponding tensor network of a quantum circuit can be generated as a \
property. See Tensor Network documentation page, for more details.\
\>", "ExampleText",ExpressionUUID->"41dec735-0af6-4915-8ca8-a990232167c3"],

Cell[BoxData[
 RowBox[{"tn", " ", "=", " ", 
  RowBox[{
   RowBox[{"QuantumCircuitOperator", "[", 
    RowBox[{"\"\<Grover\>\"", "[", 
     RowBox[{
      RowBox[{"a", " ", "&&", " ", 
       RowBox[{"!", " ", "b"}]}], " ", "||", " ", "c"}], "]"}], "]"}], 
   "[", "\"\<TensorNetwork\>\"", "]"}]}]], "Input",
 CellLabel->"In[1]:= ",ExpressionUUID->"e75a55ac-587d-4aef-a7a1-e4a3a7d10432"],

Cell["Corresponding index graph:", "ExampleText",ExpressionUUID->"9aa79ba2-b30c-43bf-a6f2-3783ac70c6fe"],

Cell[BoxData[
 RowBox[{"TensorNetworkIndexGraph", "[", 
  RowBox[{"tn", ",", " ", "\n", " ", 
   RowBox[{"GraphLayout", " ", "->", " ", 
    RowBox[{"{", 
     RowBox[{"\"\<LayeredDigraphEmbedding\>\"", ",", " ", 
      RowBox[{"\"\<Orientation\>\"", " ", "->", " ", "Left"}]}], "}"}]}]}], 
  "]"}]], "Input",
 CellLabel->"In[2]:= ",ExpressionUUID->"8b4807a0-69b2-484e-b563-bf0e07a7de8c"],

Cell["Parametrized quantum circuit", "ExampleSubsection",ExpressionUUID->"83b3b3a4-3ae8-434f-9d19-2c1aeca019cb"],

Cell["Define a parametrized quantum circuit, with two parameters:", \
"ExampleText",ExpressionUUID->"7e78545f-66fc-4d5b-ac9a-9ba9a18fdfbc"],

Cell[BoxData[
 RowBox[{"qc", " ", "=", " ", 
  RowBox[{"QuantumCircuitOperator", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{"\"\<RY\>\"", "[", "\[Theta]", "]"}], ",", " ", 
      RowBox[{"\"\<RZ\>\"", "[", "\[Phi]", "]"}]}], "}"}], ",", " ", "\n", 
    "  ", 
    RowBox[{"\"\<Parameters\>\"", " ", "->", " ", 
     RowBox[{"{", 
      RowBox[{"\[Theta]", ",", " ", "\[Phi]"}], "}"}]}]}], "]"}]}]], "Input",
 CellLabel->"In[1]:= ",ExpressionUUID->"913dd328-face-4006-b7b2-9d6006a00484"],

Cell["Assign numerical values to parameters:", "ExampleText",ExpressionUUID->"62ad2efc-f423-4dcb-9652-65462226356f"],

Cell[BoxData[
 RowBox[{
  RowBox[{"qc", "[", 
   RowBox[{"<|", 
    RowBox[{
     RowBox[{"\[Theta]", " ", "->", " ", 
      RowBox[{"\[Pi]", "/", "3"}]}], ",", " ", 
     RowBox[{"\[Phi]", " ", "->", " ", 
      RowBox[{"\[Pi]", "/", "4"}]}]}], "|>"}], "]"}], "[", "\"\<Diagram\>\"", 
  "]"}]], "Input",
 CellLabel->"In[2]:= ",ExpressionUUID->"4f02e04b-68d0-4661-9f7f-d3c65f00855e"],

Cell["Properties and downvalues", "ExampleSubsection",ExpressionUUID->"15b7dabb-670e-454f-a7ea-5471d7fdaf2e"],

Cell[TextData[{
 "A ",
 Cell[BoxData[
 "QuantumCircuitOperator"], "InlineFormula",ExpressionUUID->
  "476351db-526b-412a-a4f0-fe90605a8981"],
 " exposes a rich set of properties, accessed as ",
 Cell[BoxData[
  RowBox[{"qc", "[", "\"\<property\>\"", "]"}]], "InlineFormula",
  ExpressionUUID->"0eb3f7c5-ed33-4437-8421-adcca1f3116e"],
 " (its downvalues). Define a sample circuit:"
}], "ExampleText",ExpressionUUID->"8bfd83c2-30f3-4f9a-a7b4-be36e0fdd660"],

Cell[BoxData[
 RowBox[{"qc", " ", "=", " ", 
  RowBox[{"QuantumCircuitOperator", "[", 
   RowBox[{"{", 
    RowBox[{"\"\<H\>\"", ",", " ", "\"\<CNOT\>\"", ",", " ", 
     RowBox[{
      RowBox[{"\"\<RZ\>\"", "[", 
       RowBox[{"Pi", "/", "4"}], "]"}], " ", "->", " ", "2"}]}], "}"}], 
   "]"}]}]], "Input",
 CellLabel->"In[1]:= ",ExpressionUUID->"ada06662-bdd1-4e34-a0de-2a9c0b84d742"],

Cell[TextData[{
 "The full list of supported properties is returned by ",
 Cell[BoxData["\"\<Properties\>\""], "InlineFormula",ExpressionUUID->
  "4ee8f8b8-00d3-4e4d-9a0d-9375bece133a"],
 ":"
}], "ExampleText",ExpressionUUID->"f733e29c-1330-44fe-98b7-cec798aa702d"],

Cell[BoxData[
 RowBox[{"qc", "[", "\"\<Properties\>\"", "]"}]], "Input",
 CellLabel->"In[2]:= ",ExpressionUUID->"d7e06faa-d0ad-4864-875c-1e9df1e24987"],

Cell[TextData[{
 "Sizes and counts of the circuit (",
 Cell[BoxData["\"\<GateCount\>\""], "InlineFormula",ExpressionUUID->
  "9ba31d6a-387e-418e-a00d-29c1ad47ba00"],
 " is an alias of ",
 Cell[BoxData["\"\<OperatorCount\>\""], "InlineFormula",ExpressionUUID->
  "efe6c85a-6a55-48aa-896f-4a4e3e96620c"],
 "):"
}], "ExampleText",ExpressionUUID->"4fac0c3b-1f19-4a2c-ae03-89e504e32bd7"],

Cell[BoxData[
 RowBox[{"Dataset", " ", "@", " ", 
  RowBox[{"AssociationMap", "[", 
   RowBox[{"qc", ",", " ", 
    RowBox[{"{", 
     RowBox[{"\"\<Arity\>\"", ",", " ", "\"\<Width\>\"", ",", 
      " ", "\"\<Depth\>\"", ",", " ", "\"\<OperatorCount\>\"", ",", " ", "\n",
       "   ", "\"\<GateCount\>\""}], "}"}]}], "]"}]}]], "Input",
 CellLabel->"In[3]:= ",ExpressionUUID->"57dd4fe1-2be0-4528-947c-f40c37101b8a"],

Cell["The input and output qudit dimensions:", "ExampleText",ExpressionUUID->"0173e278-b216-4f72-ac55-27938e32cebc"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{"qc", "[", "\"\<InputDimensions\>\"", "]"}], ",", " ", 
   RowBox[{"qc", "[", "\"\<OutputDimensions\>\"", "]"}]}], "}"}]], "Input",
 CellLabel->"In[4]:= ",ExpressionUUID->"2fe6789b-6338-4a6a-98bf-4d0c26ad7e4b"],

Cell["The operators (gates) that make up the circuit:", "ExampleText",ExpressionUUID->"a1e87625-1bbf-4299-ae83-6a7f84f88cf5"],

Cell[BoxData[
 RowBox[{"qc", "[", "\"\<Operators\>\"", "]"}]], "Input",
 CellLabel->"In[5]:= ",ExpressionUUID->"e5029a1b-c29b-4bf5-9b8c-dff56104c7b4"],

Cell["The order (input and output qudits) of each operator:", "ExampleText",ExpressionUUID->"f0440a5c-7626-493c-9401-7c96c68312c3"],

Cell[BoxData[
 RowBox[{"qc", "[", "\"\<Orders\>\"", "]"}]], "Input",
 CellLabel->"In[6]:= ",ExpressionUUID->"880b6118-918e-4a9a-9361-1f800c590e33"],

Cell["The circuit label and its picture:", "ExampleText",ExpressionUUID->"49297f2d-5366-404b-b64c-9f303f54d870"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{"qc", "[", "\"\<Label\>\"", "]"}], ",", " ", 
   RowBox[{"qc", "[", "\"\<Picture\>\"", "]"}]}], "}"}]], "Input",
 CellLabel->"In[7]:= ",ExpressionUUID->"38cf00bc-25fd-4730-8b84-73f9a4f6acc1"],

Cell["The underlying data, as an association:", "ExampleText",ExpressionUUID->"be446e4e-dff1-444f-9fef-7f7733499966"],

Cell[BoxData[
 RowBox[{"qc", "[", "\"\<Association\>\"", "]"}]], "Input",
 CellLabel->"In[8]:= ",ExpressionUUID->"92ca228e-2fc0-4770-bc6a-7dee820381bc"],

Cell["The whole circuit collapsed into a single quantum operator:", \
"ExampleText",ExpressionUUID->"c74da157-55fc-4488-b3d4-e5a1b4af34f8"],

Cell[BoxData[
 RowBox[{"qc", "[", "\"\<CircuitOperator\>\"", "]"}]], "Input",
 CellLabel->"In[9]:= ",ExpressionUUID->"8a584ef5-8f7e-4d4a-a72d-d746db736c70"],

Cell["The circuit diagram:", "ExampleText",ExpressionUUID->"d88e3298-12a8-4a21-aed7-09d69b344e09"],

Cell[BoxData[
 RowBox[{"qc", "[", "\"\<Diagram\>\"", "]"}]], "Input",
 CellLabel->
  "In[10]:= ",ExpressionUUID->"2090865c-5418-493d-8dc2-5130930eba61"],

Cell["\<\
The circuit topology, with qudits/wires as vertices and gates as edges:\
\>", "ExampleText",ExpressionUUID->"d319068a-2b3c-4ab8-9e6c-fb9c7fc88e16"],

Cell[BoxData[
 RowBox[{"qc", "[", "\"\<Topology\>\"", "]"}]], "Input",
 CellLabel->
  "In[11]:= ",ExpressionUUID->"6b00513e-ef9a-46c8-8a5f-2ddaa29c0072"],

Cell["The tensor network representing the circuit:", "ExampleText",ExpressionUUID->"0afa6d71-3566-4927-a7db-6e8a3b214f85"],

Cell[BoxData[
 RowBox[{"qc", "[", "\"\<TensorNetwork\>\"", "]"}]], "Input",
 CellLabel->
  "In[12]:= ",ExpressionUUID->"9ad49ebd-9701-4a25-ad18-658732208734"],

Cell["The graph of that tensor network:", "ExampleText",ExpressionUUID->"a7c45866-2b94-4397-b8c0-c18fc3f89906"],

Cell[BoxData[
 RowBox[{"qc", "[", "\"\<TensorNetworkGraph\>\"", "]"}]], "Input",
 CellLabel->
  "In[13]:= ",ExpressionUUID->"a64bbdc1-29bf-4d25-a063-7910d8b3c287"],

Cell["Export the circuit to OpenQASM 3.0:", "ExampleText",ExpressionUUID->"41bcb791-1a16-4a66-b462-895e6595cbfa"],

Cell[BoxData[
 RowBox[{"qc", "[", "\"\<QASM\>\"", "]"}]], "Input",
 CellLabel->
  "In[14]:= ",ExpressionUUID->"1dc3efe8-1c4c-43af-a798-60c94d2749c5"],

Cell["\<\
The corresponding Qiskit circuit (requires Python as an external evaluator):\
\>", "ExampleText",ExpressionUUID->"e38a62db-6804-405d-89d3-a21dc81971cd"],

Cell[BoxData[
 RowBox[{"qc", "[", "\"\<QiskitCircuit\>\"", "]"}]], "Input",
 CellLabel->
  "In[15]:= ",ExpressionUUID->"9e12f85e-2726-484c-90bf-773a0415437f"],

Cell["\<\
Shift the qudits the circuit acts on by an offset (here, by 2):\
\>", "ExampleText",ExpressionUUID->"f6023221-6f0b-4c85-8e43-d35e6d7ef5e5"],

Cell[BoxData[
 RowBox[{
  RowBox[{"qc", "[", 
   RowBox[{"\"\<Shift\>\"", ",", " ", "2"}], "]"}], "[", "\"\<Orders\>\"", 
  "]"}]], "Input",
 CellLabel->
  "In[16]:= ",ExpressionUUID->"c7663366-c3d4-406d-8b6d-3cfeda167587"],

Cell[TextData[{
 "For a parametrized circuit, ",
 Cell[BoxData["\"\<Parameters\>\""], "InlineFormula",ExpressionUUID->
  "d2b37e72-6dd2-45c3-b6ef-5d9fc171d65e"],
 " lists the declared parameters and ",
 Cell[BoxData["\"\<ParameterArity\>\""], "InlineFormula",ExpressionUUID->
  "6c9cd3e2-b7e9-4760-81cd-84dc74dc2eec"],
 " counts them:"
}], "ExampleText",ExpressionUUID->"879130e9-8c97-454d-a54b-1849e581accd"],

Cell[BoxData[
 RowBox[{"pqc", " ", "=", " ", 
  RowBox[{"QuantumCircuitOperator", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{"\"\<RY\>\"", "[", "\[Theta]", "]"}], ",", " ", 
      RowBox[{
       RowBox[{"\"\<RZ\>\"", "[", "\[Phi]", "]"}], " ", "->", " ", "2"}]}], 
     "}"}], ",", " ", "\n", "   ", 
    RowBox[{"\"\<Parameters\>\"", " ", "->", " ", 
     RowBox[{"{", 
      RowBox[{"\[Theta]", ",", " ", "\[Phi]"}], "}"}]}]}], "]"}]}]], "Input",
 CellLabel->
  "In[17]:= ",ExpressionUUID->"a61a061c-b252-4a49-910d-66c43fe27784"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{"pqc", "[", "\"\<Parameters\>\"", "]"}], ",", " ", 
   RowBox[{"pqc", "[", "\"\<ParameterArity\>\"", "]"}]}], "}"}]], "Input",
 CellLabel->
  "In[18]:= ",ExpressionUUID->"edab62bf-f1a8-435d-b306-0bf6cdfa97ff"]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[
 InterpretationBox[Cell[
  "Generalizations & Extensions", "ExampleSection",ExpressionUUID->
   "a148ce84-caec-4483-aa99-5b7bd6d55bf1"],
  $Line = 0; Null]], "ExampleSection",
 CellID->1020263627,ExpressionUUID->"85bb6475-fccb-4f83-9c4c-95411a492aa7"],

Cell["\t", "ExampleDelimiter",ExpressionUUID->"111eaa42-9dbf-4bcb-8ad8-763dfc45469a"],

Cell[TextData[{
 Cell[BoxData[
 "QuantumCircuitOperator"], "InlineFormula",ExpressionUUID->
  "de3dd1f0-77eb-44f0-9a4a-6dc4eec13149"],
 " also supports controlled operators with more than one control or targets."
}], "ExampleText",ExpressionUUID->"c15cce4a-2cec-4b51-9861-d88b24253a3f"],

Cell[BoxData[
 RowBox[{
  RowBox[{"QuantumCircuitOperator", "[", "\n", "  ", 
   RowBox[{"QuantumOperator", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"\"\<C\>\"", ",", " ", "\"\<X\>\"", ",", " ", 
       RowBox[{"{", 
        RowBox[{"1", ",", " ", "4"}], "}"}], ",", " ", 
       RowBox[{"{", "2", "}"}]}], "}"}], ",", " ", 
     RowBox[{"{", "3", "}"}]}], "]"}], "]"}], "[", "\"\<Diagram\>\"", 
  "]"}]], "Input",
 CellLabel->"In[1]:= ",ExpressionUUID->"9dd0c6fa-9e7f-443d-acb4-1936ae5cac27"],

Cell["\t", "ExampleDelimiter",ExpressionUUID->"83559661-adb2-4a5b-80ed-5b365f3de3cd"],

Cell["Decompose Toffoli gate:", "ExampleText",ExpressionUUID->"2df95899-80a7-4fbb-bc1d-24468524da9d"],

Cell[BoxData[
 RowBox[{
  RowBox[{"v", " ", "=", " ", 
   RowBox[{"QuantumOperator", "[", 
    RowBox[{
     RowBox[{"MatrixPower", "[", 
      RowBox[{
       RowBox[{"PauliMatrix", "[", "1", "]"}], ",", " ", 
       RowBox[{"1", "/", "2"}]}], "]"}], ",", " ", 
     RowBox[{"\"\<Label\>\"", " ", "->", " ", "\"\<V\>\""}]}], "]"}]}], 
  ";"}]], "Input",
 CellLabel->"In[1]:= ",ExpressionUUID->"a09c0c87-9b06-42f1-b042-b64811292d6c"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"qc", " ", "=", " ", 
   RowBox[{"QuantumCircuitOperator", "[", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"QuantumOperator", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"\"\<Controlled\>\"", ",", " ", "v"}], "}"}], ",", " ", 
        RowBox[{"{", 
         RowBox[{"2", ",", " ", "3"}], "}"}]}], "]"}], ",", "\n", "     ", 
      RowBox[{"QuantumOperator", "[", "\"\<CX\>\"", "]"}], ",", " ", "\n", 
      "    ", 
      RowBox[{"QuantumOperator", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"\"\<Controlled\>\"", ",", " ", 
          RowBox[{"v", "[", "\"\<Dagger\>\"", "]"}]}], "}"}], ",", " ", 
        RowBox[{"{", 
         RowBox[{"2", ",", " ", "3"}], "}"}]}], "]"}], ",", " ", "\n", "    ", 
      RowBox[{"QuantumOperator", "[", "\"\<CX\>\"", "]"}], ",", " ", 
      RowBox[{"QuantumOperator", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"\"\<Controlled\>\"", ",", " ", "v"}], "}"}], ",", " ", 
        RowBox[{"{", 
         RowBox[{"1", ",", " ", "3"}], "}"}]}], "]"}]}], "}"}], "]"}]}], 
  ";"}], "\n", 
 RowBox[{"qc", "[", "\"\<Diagram\>\"", "]"}]}], "Input",
 CellLabel->"In[2]:= ",ExpressionUUID->"e6cf7dcf-5ab5-4b46-b1da-c122cb0f1d59"],

Cell["\<\
Show above implementation is the same as built-in Toffoli gate:\
\>", "ExampleText",ExpressionUUID->"0c33f7d4-8bd4-4110-9f52-4433573151b5"],

Cell[BoxData[
 RowBox[{
  RowBox[{"QuantumOperator", "[", "\"\<Toffoli\>\"", "]"}], " ", "==", " ", 
  RowBox[{"qc", "[", "\"\<CircuitOperator\>\"", "]"}]}]], "Input",
 CellLabel->"In[3]:= ",ExpressionUUID->"78d6be60-efa4-4263-bf2d-b92f73aa47d5"],

Cell["\t", "ExampleDelimiter",ExpressionUUID->"d9f5d0dd-d462-427b-a93d-40c337dc892c"],

Cell["\<\
Quantum circuits consisting of qudit gates are supported. Define a qudit gate \
of dimensionality 3:\
\>", "ExampleText",ExpressionUUID->"e4c8e0f2-98b8-4f11-b7bf-5bdb417092f5"],

Cell[BoxData[
 RowBox[{
  RowBox[{"QuantumCircuitOperator", "[", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"\"\<RandomUnitary\>\"", "[", "3", "]"}], ",", " ", "\n", "   ", 
     
     RowBox[{
      RowBox[{"\"\<Spider\>\"", "[", 
       RowBox[{"QuantumBasis", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"3", ",", " ", "2"}], "}"}], ",", " ", 
         RowBox[{"{", 
          RowBox[{"3", ",", " ", "2"}], "}"}]}], "]"}], "]"}], " ", "->", " ", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"1", ",", " ", "2"}], "}"}], " ", "->", " ", 
       RowBox[{"{", 
        RowBox[{"2", ",", " ", "\n", "      ", "1"}], "}"}]}]}]}], "}"}], 
   "]"}], "[", 
  RowBox[{"\"\<Diagram\>\"", ",", " ", 
   RowBox[{"\"\<ShowWireDimensions\>\"", " ", "->", " ", "True"}]}], 
  "]"}]], "Input",
 CellLabel->"In[1]:= ",ExpressionUUID->"b61a444b-6a6c-466c-b47d-f36a25e31d0d"],

Cell["\t", "ExampleDelimiter",ExpressionUUID->"3925528b-306c-466f-bb00-55c9a03330b9"],

Cell["\<\
One can shift a circuit, which means changing its overall order\
\>", "ExampleText",ExpressionUUID->"a1417150-af48-4938-ad66-272cbcee70ee"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"qc", " ", "=", " ", 
   RowBox[{"QuantumCircuitOperator", "[", 
    RowBox[{"{", 
     RowBox[{"\"\<Fourier\>\"", ",", " ", "3"}], "}"}], "]"}]}], 
  ";"}], "\n", 
 RowBox[{"qc", "[", "\"\<Diagram\>\"", "]"}]}], "Input",
 CellLabel->"In[1]:= ",ExpressionUUID->"87a56c7c-b94e-440a-8c1d-855c5d8d1418"],

Cell["Shift above circuit by 2 qudits:", "ExampleText",ExpressionUUID->"eac3a2fb-4e4b-4624-8bda-5b42ac8f3a88"],

Cell[BoxData[
 RowBox[{
  RowBox[{"qc", "[", 
   RowBox[{"\"\<Shift\>\"", ",", " ", "2"}], "]"}], "[", "\"\<Diagram\>\"", 
  "]"}]], "Input",
 CellLabel->"In[2]:= ",ExpressionUUID->"c7e63f11-0e99-47f5-a67a-41327ba4fbaa"]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[
 InterpretationBox[Cell[
  "Options", "ExampleSection",ExpressionUUID->
   "b26b6366-7922-4236-a426-38c0f5de13f0"],
  $Line = 0; Null]], "ExampleSection",
 CellID->2061341341,ExpressionUUID->"3276b1d7-cf51-4f3b-970a-56b0e7c469f0"],

Cell["Method", "ExampleSubsection",ExpressionUUID->"7b1f1801-13cf-45ed-8b77-8f34760b57c9"],

Cell["\<\
The default method creates the tensor network and then contracts it to get \
the results:\
\>", "ExampleText",ExpressionUUID->"0066b698-3fb8-4f14-b806-284d2d5543dd"],

Cell[BoxData[
 RowBox[{
  RowBox[{"QuantumCircuitOperator", "[", 
   RowBox[{"{", 
    RowBox[{"\"\<Bell\>\"", ",", " ", 
     RowBox[{"{", 
      RowBox[{"1", ",", " ", "2"}], "}"}]}], "}"}], "]"}], "[", 
  "]"}]], "Input",
 CellLabel->"In[1]:= ",ExpressionUUID->"0c1aabdf-0ef1-46eb-b5ce-9a5e181f029f"],

Cell[TextData[{
 "The tensor-network engine can also be requested explicitly with ",
 Cell[BoxData[
  RowBox[{"Method", " ", "->", " ", "\"\<TensorNetwork\>\""}]], 
  "InlineFormula",ExpressionUUID->"4ca0ae8c-dcfb-46ba-95da-2c0af9f14b57"],
 "; tensor-network options are passed as ",
 Cell[BoxData[
  RowBox[{"Method", " ", "->", " ", 
   RowBox[{"{", 
    RowBox[{"\"\<TensorNetwork\>\"", ",", " ", "opts"}], "}"}]}]], 
  "InlineFormula",ExpressionUUID->"e87a43af-e8eb-4785-aba0-4b4abfadd591"],
 ":"
}], "ExampleText",ExpressionUUID->"e02e0831-f71c-49db-a06b-f70708cd0a35"],

Cell[BoxData[
 RowBox[{
  RowBox[{"QuantumCircuitOperator", "[", 
   RowBox[{"{", 
    RowBox[{"\"\<H\>\"", ",", " ", "\"\<CNOT\>\""}], "}"}], "]"}], "[", 
  RowBox[{
   RowBox[{"QuantumState", "[", "\"\<00\>\"", "]"}], ",", " ", 
   RowBox[{"Method", " ", "->", " ", "\"\<TensorNetwork\>\""}]}], 
  "]"}]], "Input",
 CellLabel->"In[2]:= ",ExpressionUUID->"6ed70e4b-5179-4e26-947c-9a7ede0642fc"],

Cell[TextData[{
 "With ",
 Cell[BoxData[
  RowBox[{"Method", " ", "->", " ", "\"\<Schrodinger\>\""}]], "InlineFormula",
  ExpressionUUID->"b0d63a42-5caa-4f3a-8201-4b51498fef4e"],
 ", the circuit is applied gate by gate (a fold over the operators, \
simplifying after each step). It is slower than the tensor-network engine, \
but keeps the result in closed symbolic form, which is convenient for \
parametrized circuits:"
}], "ExampleText",ExpressionUUID->"1cac68da-3955-4456-95d1-17e10f5b44c7"],

Cell[BoxData[
 RowBox[{
  RowBox[{"QuantumCircuitOperator", "[", 
   RowBox[{"{", 
    RowBox[{"\"\<H\>\"", ",", " ", 
     RowBox[{
      RowBox[{"\"\<RX\>\"", "[", "\[Theta]", "]"}], " ", "->", " ", "2"}], ",",
      " ", "\"\<CNOT\>\""}], "}"}], "]"}], "[", "\n", "  ", 
  RowBox[{
   RowBox[{"QuantumState", "[", "\"\<00\>\"", "]"}], ",", " ", 
   RowBox[{"Method", " ", "->", " ", "\"\<Schrodinger\>\""}]}], 
  "]"}]], "Input",
 CellLabel->"In[3]:= ",ExpressionUUID->"5bc4edf7-aea8-45d8-91a8-d8ed2b38e4c4"],

Cell[TextData[{
 "For Clifford (stabilizer) circuits, ",
 Cell[BoxData[
  RowBox[{"Method", " ", "->", " ", "\"\<Stabilizer\>\""}]], "InlineFormula",
  ExpressionUUID->"28c95a6a-ce11-4d90-b6de-8ea73685f453"],
 " simulates the circuit in the stabilizer formalism and returns a \
PauliStabilizer, scaling polynomially in the number of qubits:"
}], "ExampleText",ExpressionUUID->"8c220364-7750-4425-b47d-5c8a150f23fb"],

Cell[BoxData[
 RowBox[{
  RowBox[{"QuantumCircuitOperator", "[", 
   RowBox[{"{", 
    RowBox[{"\"\<H\>\"", ",", " ", "\"\<CNOT\>\""}], "}"}], "]"}], "[", 
  RowBox[{"Method", " ", "->", " ", "\"\<Stabilizer\>\""}], "]"}]], "Input",
 CellLabel->"In[4]:= ",ExpressionUUID->"c9c55829-8245-437d-a612-9893d76956c4"],

Cell[TextData[{
 "With ",
 Cell[BoxData[
  RowBox[{"Method", " ", "->", " ", "\"\<QuEST\>\""}]], "InlineFormula",
  ExpressionUUID->"ae6542dc-abd3-4be4-93d2-d55bc50b89a1"],
 ", the circuit is simulated through the external QuEST high-performance \
simulator (qubit circuits only, requires the QuESTLink paclet):"
}], "ExampleText",ExpressionUUID->"d12ada7b-4a5c-4624-b558-63f309c30841"],

Cell[BoxData[
 RowBox[{
  RowBox[{"QuantumCircuitOperator", "[", 
   RowBox[{"{", 
    RowBox[{"\"\<H\>\"", ",", " ", "\"\<CNOT\>\""}], "}"}], "]"}], "[", 
  RowBox[{"Method", " ", "->", " ", "\"\<QuEST\>\""}], "]"}]], "Input",
 CellLabel->"In[5]:= ",ExpressionUUID->"e49106c6-cacb-4f91-b9c9-f394cb636fd7"],

Cell["\<\
Convert the circuit into Qiskit, and simulate it using the Qiskit default \
backend such as Aer (the results will be quantum objects in Wolfram quantum \
framework):\
\>", "ExampleText",ExpressionUUID->"2c53387e-1fb0-4c3c-a207-4795c46795c6"],

Cell[BoxData[
 RowBox[{
  RowBox[{"QuantumCircuitOperator", "[", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"QuantumOperator", "[", 
      RowBox[{"\"\<RandomUnitary\>\"", ",", " ", 
       RowBox[{"Range", "[", "5", "]"}]}], "]"}], ",", " ", "\n", "   ", 
     RowBox[{"Range", "[", "5", "]"}]}], "}"}], "]"}], "[", 
  RowBox[{"Method", " ", "->", " ", "\"\<Qiskit\>\""}], "]"}]], "Input",
 CellLabel->"In[6]:= ",ExpressionUUID->"9067aa22-21f5-4620-89a6-eb3763cd7615"],

Cell["IBMProvider as Qiskit provider:", "ExampleText",ExpressionUUID->"a027bddc-9979-43c4-a459-d171a694aad7"],

Cell[BoxData[
 RowBox[{
  RowBox[{"QuantumCircuitOperator", "[", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"QuantumOperator", "[", 
      RowBox[{"\"\<RandomUnitary\>\"", ",", " ", 
       RowBox[{"Range", "[", "5", "]"}]}], "]"}], ",", " ", "\n", "   ", 
     RowBox[{"Range", "[", "5", "]"}]}], "}"}], "]"}], "[", 
  RowBox[{"Method", " ", "->", " ", 
   RowBox[{"{", 
    RowBox[{"\"\<Qiskit\>\"", ",", " ", 
     RowBox[{"\"\<Provider\>\"", " ", "->", " ", "\"\<IBMProvider\>\""}]}], 
    "}"}]}], "]"}]], "Input",
 CellLabel->"In[7]:= ",ExpressionUUID->"31e8d3e8-7f91-41fb-9158-ee2455570147"],

Cell["IBMProvider as Qiskit provider on a specific backend:", "ExampleText",ExpressionUUID->"6aa4f45e-3f3b-4acb-a85c-5bca2825920a"],

Cell[BoxData[
 RowBox[{
  RowBox[{"QuantumCircuitOperator", "[", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"QuantumOperator", "[", 
      RowBox[{"\"\<RandomUnitary\>\"", ",", " ", 
       RowBox[{"Range", "[", "5", "]"}]}], "]"}], ",", " ", "\n", "   ", 
     RowBox[{"Range", "[", "5", "]"}]}], "}"}], "]"}], "[", 
  RowBox[{"Method", " ", "->", " ", 
   RowBox[{"{", 
    RowBox[{"\"\<Qiskit\>\"", ",", " ", 
     RowBox[{"\"\<Provider\>\"", " ", "->", " ", "\"\<IBMProvider\>\""}], ",",
      " ", "\n", "   ", 
     RowBox[{"\"\<Backend\>\"", " ", "->", " ", "backend"}]}], "}"}]}], 
  "]"}]], "Input",
 CellLabel->"In[8]:= ",ExpressionUUID->"d7a3e024-4203-4747-a3b1-35c6cee63dc8"],

Cell["A delay can be added into Qiskit circuit too:", "ExampleText",ExpressionUUID->"6568fcae-b4bc-44d4-aca0-b9c3f5d7ce35"],

Cell[BoxData[
 RowBox[{
  RowBox[{"QuantumCircuitOperator", "[", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"\"\<I\>\"", " ", "->", " ", 
      RowBox[{"\"\<Delay\>\"", "[", "2", "]"}]}], ",", " ", "\"\<M\>\""}], 
    "}"}], "]"}], "[", "\"\<Qiskit\>\"", "]"}]], "Input",
 CellLabel->"In[9]:= ",ExpressionUUID->"90ea4d59-0f62-4062-8351-cd1bf13c5705"],

Cell["Return the list of IBM-quantum backends and their queue:", "ExampleText",ExpressionUUID->"5dbc21a5-2b4d-4fc7-a2e5-db0e017f7088"],

Cell[BoxData[
 RowBox[{
  RowBox[{"ServiceConnect", "[", 
   RowBox[{"\"\<IBMQ\>\"", ",", " ", "\"\<New\>\""}], "]"}], 
  "[", "\"\<BackendQueue\>\"", "]"}]], "Input",
 CellLabel->
  "In[10]:= ",ExpressionUUID->"5e4858cb-391a-4ffe-b82c-db55d6ad859c"],

Cell["AWSBraket as Qiskit provider on a specific backend:", "ExampleText",ExpressionUUID->"7e5f6a2e-df1e-49e0-bdd9-249eb9dbb7aa"],

Cell[BoxData[
 RowBox[{
  RowBox[{"QuantumCircuitOperator", "[", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"QuantumOperator", "[", 
      RowBox[{"\"\<RandomUnitary\>\"", ",", " ", 
       RowBox[{"Range", "[", "5", "]"}]}], "]"}], ",", " ", "\n", "   ", 
     RowBox[{"Range", "[", "5", "]"}]}], "}"}], "]"}], "[", 
  RowBox[{"Method", " ", "->", " ", 
   RowBox[{"{", 
    RowBox[{"\"\<Qiskit\>\"", ",", " ", 
     RowBox[{"\"\<Provider\>\"", " ", "->", " ", "\"\<AWSBraket\>\""}], ",", 
     " ", "\n", "   ", 
     RowBox[{"\"\<Backend\>\"", " ", "->", " ", "backend"}]}], "}"}]}], 
  "]"}]], "Input",
 CellLabel->
  "In[11]:= ",ExpressionUUID->"196efe00-fd83-4b91-bdcf-ad0996065e6a"],

Cell["Return the list of AWSBraket backends:", "ExampleText",ExpressionUUID->"2de14e3e-8788-4606-ae8a-64d576c6ccf7"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"aws", " ", "=", " ", 
   RowBox[{"ServiceConnect", "[", "\"\<AWS\>\"", "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"braket", " ", "=", " ", 
   RowBox[{"ServiceExecute", "[", 
    RowBox[{"aws", ",", " ", "\"\<GetService\>\"", ",", " ", 
     RowBox[{"{", 
      RowBox[{"\"\<Name\>\"", " ", "->", " ", "\"\<Braket\>\""}], "}"}]}], 
    "]"}]}], ";"}], "\n", 
 RowBox[{"devices", " ", "=", " ", 
  RowBox[{
   RowBox[{"braket", "[", 
    RowBox[{"\"\<SearchDevices\>\"", ",", " ", 
     RowBox[{"\"\<Filters\>\"", " ", "->", " ", 
      RowBox[{"{", "}"}]}]}], "]"}], "[", 
   RowBox[{"\"\<Devices\>\"", ",", " ", "All"}], "]"}]}]}], "Input",
 CellLabel->
  "In[12]:= ",ExpressionUUID->"02a04c61-2ce8-4b89-a465-59bede212c0d"],

Cell["For some circuit creation, users can connect to Classiq:", "ExampleText",ExpressionUUID->"d3b711e4-7050-4c31-95cc-b370eb6dc1fd"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"qc", " ", "=", " ", 
   RowBox[{"QuantumCircuitOperator", "[", "\n", "   ", 
    RowBox[{
     RowBox[{
      RowBox[{"QuantumState", "[", 
       RowBox[{"RandomReal", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"0", ",", " ", "1"}], "}"}], ",", " ", 
         RowBox[{"2", "^", "3"}]}], "]"}], "]"}], "[", "\"\<Normalized\>\"", 
      "]"}], ",", " ", "\n", "   ", 
     RowBox[{"Method", " ", "->", " ", "\"\<Classiq\>\""}]}], "]"}]}], 
  ";"}], "\n", 
 RowBox[{"qc", "[", 
  RowBox[{"\"\<Diagram\>\"", ",", " ", 
   RowBox[{"\"\<ShowGateLabels\>\"", " ", "->", " ", "False"}]}], 
  "]"}]}], "Input",
 CellLabel->
  "In[13]:= ",ExpressionUUID->"4a990778-caba-4f74-8fad-a7157dbc7c01"]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[
 InterpretationBox[Cell[
  "Applications", "ExampleSection",ExpressionUUID->
   "d5715ee2-1cae-4f33-89b2-0e99ea9caa6e"],
  $Line = 0; Null]], "ExampleSection",
 CellID->258228157,ExpressionUUID->"1cd6234d-1e3c-431d-9989-71f3025eee95"],

Cell["POVM in a quantum circuit", "ExampleSubsection",ExpressionUUID->"e4d1e27d-6de1-4860-8121-418520c435ba"],

Cell["\<\
Collective measurement as well as POVM measurement are supported.\
\>", "ExampleText",ExpressionUUID->"da4d9d88-62eb-4f12-82af-5fae5691d976"],

Cell["\<\
Define a POVM measurement in a minimal information-ally complete basis:\
\>", "ExampleText",ExpressionUUID->"4fa74034-4443-4ed0-88ea-b3a2553fa568"],

Cell[BoxData[
 RowBox[{"povm", " ", "=", " ", 
  RowBox[{
  "QuantumMeasurementOperator", "[", "\"\<WignerMICPOVM\>\"", 
   "]"}]}]], "Input",
 CellLabel->"In[1]:= ",ExpressionUUID->"e2712f5a-c04b-490a-a5f4-7aabb5e087b3"],

Cell["Define a circuit consisting of the above measurements:", "ExampleText",ExpressionUUID->"a8d39f3b-cfc1-4280-bb25-6651e9bb5188"],

Cell[BoxData[
 RowBox[{
  RowBox[{"qc", " ", "=", " ", 
   RowBox[{"QuantumCircuitOperator", "[", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"QuantumState", "[", 
       RowBox[{"\"\<RandomPure\>\"", ",", " ", "\n", "    ", 
        RowBox[{"\"\<Label\>\"", " ", "->", " ", "\"\<RandomState\>\""}]}], 
       "]"}], ",", " ", "povm"}], "}"}], "]"}]}], ";", " ", 
  RowBox[{"qc", "[", "\"\<Diagram\>\"", "]"}]}]], "Input",
 CellLabel->"In[2]:= ",ExpressionUUID->"1d9cb8c9-a46f-4898-88cb-a1da61efa42f"],

Cell["Show", "ExampleText",ExpressionUUID->"d8a6b4c8-2121-48e1-8fdd-43603ed4d807"],

Cell[BoxData[
 RowBox[{
  RowBox[{"qc", "[", "]"}], "[", "\"\<Probabilities\>\"", "]"}]], "Input",
 CellLabel->"In[3]:= ",ExpressionUUID->"24a03616-40c0-4447-8e9d-fc54cd4a46b3"],

Cell["Quantum teleportation", "ExampleSubsection",ExpressionUUID->"f1e0d0e1-33de-43c4-a0e2-6f99d05b8574"],

Cell[TextData[{
 "We shall implement a quantum circuit for teleporting a qubit. The 1st and \
2nd qubits represent Alice\[CloseCurlyQuote]s system, while the last one is \
Bob\[CloseCurlyQuote]s. The double lines carry classical bits. The state to \
be teleported is ",
 Cell[BoxData[
  RowBox[{"|", 
   RowBox[{
    SubscriptBox["\[Psi]", "1"], "\[RightAngleBracket]", "=", "\[Alpha]", "|", 
    RowBox[{"0", "\[RightAngleBracket]", "+", "\[Beta]"}], "|", "1", 
    "\[RightAngleBracket]"}]}]], "InlineFormula",ExpressionUUID->
  "fe441d43-575f-4955-aefc-fe5aee497a19"],
 ", where \[Alpha] and \[Beta] are unknown amplitudes."
}], "ExampleText",ExpressionUUID->"11f10afb-54d6-474c-b9fc-5c1db10d8c43"],

Cell[BoxData[
 RowBox[{
  RowBox[{"circuit", " ", "=", " ", "\n", "  ", 
   RowBox[{"QuantumCircuitOperator", "[", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"QuantumCircuitOperator", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{
          RowBox[{"QuantumState", "[", 
           RowBox[{"\\\n", 
            RowBox[{"{", 
             RowBox[{"\[Alpha]", ",", " ", "\[Beta]"}], "}"}]}], "]"}], ",", 
          " ", 
          RowBox[{"\"\<Cup\>\"", " ", "->", " ", 
           RowBox[{"{", 
            RowBox[{"2", ",", " ", "3"}], "}"}]}]}], "}"}], ",", 
        " ", "\"\<State Prep.\>\""}], "]"}], ",", " ", "\"\<CX\>\"", ",", 
      " ", "\"\<H\>\"", ",", " ", "\n", "    ", 
      RowBox[{"\"\<CX\>\"", " ", "->", " ", 
       RowBox[{"{", 
        RowBox[{"2", ",", " ", "3"}], "}"}]}], ",", " ", 
      RowBox[{"\"\<CZ\>\"", " ", "->", " ", 
       RowBox[{"{", 
        RowBox[{"1", ",", " ", "3"}], "}"}]}], ",", " ", 
      RowBox[{"{", "1", "}"}], ",", " ", 
      RowBox[{"{", "2", "}"}]}], "}"}], "]"}]}], ";"}]], "Input",
 CellLabel->"In[1]:= ",ExpressionUUID->"eaaa5756-d1f6-41ad-aca1-3fbdb30d4701"],

Cell[BoxData[
 RowBox[{"circuit", "[", "\"\<Diagram\>\"", "]"}]], "Input",
 CellLabel->"In[2]:= ",ExpressionUUID->"d0925cd0-4aee-47fe-bad6-430d4da1abc5"],

Cell["\<\
Trace out 1st and 2nd qubit on possible post-measurement states, and compare \
the reduced state of only qubit 3:\
\>", "ExampleText",ExpressionUUID->"86126c27-7e07-423c-b5a9-7b798fe9ebb9"],

Cell[BoxData[
 RowBox[{
  RowBox[{"Thread", "[", 
   RowBox[{
    RowBox[{"QuantumState", "[", 
     RowBox[{"{", 
      RowBox[{"\[Alpha]", ",", " ", "\[Beta]"}], "}"}], "]"}], " ", "==", " ",
     "\n", "   ", 
    RowBox[{
     RowBox[{"QuantumOperator", "[", 
      RowBox[{"\"\<Trace\>\"", " ", "->", " ", 
       RowBox[{"{", 
        RowBox[{"1", ",", " ", "2"}], "}"}]}], "]"}], " ", "/@", " ", "\n", 
     "    ", 
     RowBox[{
      RowBox[{"circuit", "[", "]"}], "[", "\"\<States\>\"", "]"}]}]}], "]"}], 
  " ", "//", " ", "FullSimplify"}]], "Input",
 CellLabel->"In[3]:= ",ExpressionUUID->"6b83cc28-3b70-4e2a-b440-ef90aa1cf191"],

Cell["Quantum key distribution as in BB84 protocol", "ExampleSubsection",ExpressionUUID->"96ea037c-d8f8-4f66-ac83-b5d7cd319c99"],

Cell["\<\
As an example of a quantum key distribution (QKD), consider the BB84 \
protocol. Alice generates random bits and for each, randomly chooses either a \
Z-basis or X-basis of measurement. Consider a random sequence of 9 bits and \
corresponding basis:\
\>", "ExampleText",ExpressionUUID->"675ce4e7-65e0-4fb8-a6b7-4c205c45b282"],

Cell[BoxData[
 RowBox[{"aliceBits", " ", "=", " ", 
  RowBox[{"RandomChoice", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"0", ",", " ", "1"}], "}"}], ",", " ", "9"}], "]"}]}]], "Input",
 CellLabel->"In[1]:= ",ExpressionUUID->"c200e08f-e5cf-4bc4-aee2-e5003ddd5961"],

Cell[BoxData[
 RowBox[{"aliceBases", " ", "=", " ", 
  RowBox[{"RandomChoice", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"\"\<Z\>\"", ",", " ", "\"\<X\>\""}], "}"}], ",", " ", "9"}], 
   "]"}]}]], "Input",
 CellLabel->"In[2]:= ",ExpressionUUID->"a34e8c48-0360-4b64-9c47-f90f03ef970c"],

Cell["\<\
Depending on her choice of bit and base, she follows the following protocol \
for sending a qubit to Bob:\
\>", "ExampleText",ExpressionUUID->"e9672527-a1c1-46e2-bb16-e8599fe972e8"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"aliceProtocol", " ", "=", " ", 
   RowBox[{"<|", 
    RowBox[{
     RowBox[{
      RowBox[{"{", 
       RowBox[{"0", ",", " ", "\"\<Z\>\""}], "}"}], " ", "->", " ", 
      RowBox[{"QuantumState", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"1", ",", " ", "0"}], "}"}], ",", " ", "\"\<Z\>\""}], 
       "]"}]}], ",", " ", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"0", ",", " ", "\"\<X\>\""}], "}"}], " ", "->", " ", "\n", 
      "    ", 
      RowBox[{"QuantumState", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"1", ",", " ", "0"}], "}"}], ",", " ", "\"\<X\>\""}], 
       "]"}]}], ",", " ", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"1", ",", " ", "\"\<Z\>\""}], "}"}], " ", "->", " ", "\n", 
      "    ", 
      RowBox[{"QuantumState", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"0", ",", " ", "1"}], "}"}], ",", " ", "\"\<Z\>\""}], 
       "]"}]}], ",", " ", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"1", ",", " ", "\"\<X\>\""}], "}"}], " ", "->", " ", 
      RowBox[{"QuantumState", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"0", ",", " ", "1"}], "}"}], ",", " ", "\"\<X\>\""}], 
       "]"}]}]}], "|>"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"#", "[", "\"\<Formula\>\"", "]"}], " ", "&"}], " ", "/@", " ", 
    "aliceProtocol"}], " ", "//", " ", "Normal"}], " ", "//", " ", 
  "Column"}]}], "Input",
 CellLabel->"In[3]:= ",ExpressionUUID->"06420a4d-28fd-4a0b-9614-4ba45286f9bc"],

Cell["\<\
With Alice's bits and bases having been generated randomly, she will send Bob \
these qubits:\
\>", "ExampleText",ExpressionUUID->"173fdf52-d482-47e6-bedb-aacec307f8f2"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"aliceQubits", " ", "=", " ", 
   RowBox[{"aliceProtocol", " ", "/@", " ", 
    RowBox[{"Thread", "[", 
     RowBox[{"List", "[", 
      RowBox[{"aliceBits", ",", " ", "aliceBases"}], "]"}], "]"}]}]}], 
  ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"#", "[", "\"\<Formula\>\"", "]"}], " ", "&"}], " ", "/@", " ", 
  "aliceQubits"}]}], "Input",
 CellLabel->"In[4]:= ",ExpressionUUID->"b671e676-2985-426b-8746-2c986547a145"],

Cell["\<\
Bob randomly generates a sequence of either Z-bases or X-bases of measurement:\
\>", "ExampleText",ExpressionUUID->"b1bf9ea8-9fc9-41eb-8525-d0edcb9b2a7b"],

Cell[BoxData[
 RowBox[{"bobBases", " ", "=", " ", 
  RowBox[{"RandomChoice", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"\"\<Z\>\"", ",", " ", "\"\<X\>\""}], "}"}], ",", " ", "9"}], 
   "]"}]}]], "Input",
 CellLabel->"In[5]:= ",ExpressionUUID->"741c5874-0fab-44c0-8755-5870b986694a"],

Cell["\<\
Thus, Bob applies the following measurement operators on the qubits he got \
from Alice:\
\>", "ExampleText",ExpressionUUID->"a5edb8d5-7996-4fd7-bf22-c22519ab4f48"],

Cell[BoxData[
 RowBox[{
  RowBox[{"ops", " ", "=", " ", 
   RowBox[{"QuantumMeasurementOperator", " ", "/@", " ", "bobBases"}]}], 
  ";"}]], "Input",
 CellLabel->"In[6]:= ",ExpressionUUID->"2be13413-433a-472d-8cfa-c2f046e395e8"],

Cell["\<\
Post-measurement, it is the case that, whenever Bob's measurement basis is \
not the same as Alice's, he gets two random results:\
\>", "ExampleText",ExpressionUUID->"00c57806-a5c2-4e72-ae5c-0da3d873c981"],

Cell[BoxData[
 RowBox[{
  RowBox[{"mea", " ", "=", " ", 
   RowBox[{"MapThread", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"#1", "[", "#2", "]"}], " ", "&"}], ",", " ", 
     RowBox[{"{", 
      RowBox[{"ops", ",", " ", "aliceQubits"}], "}"}]}], "]"}]}], 
  ";"}]], "Input",
 CellLabel->"In[7]:= ",ExpressionUUID->"e4c88674-2a54-4a0b-87ef-2ec990723c06"],

Cell["\<\
Return one possible realization of Bob' s series of measurements (noting that \
some results will be consistent and other random, depending on Alice' s qubit \
and Bob's measurement):\
\>", "ExampleText",ExpressionUUID->"96796cc0-c7d6-41a9-8107-e5116d078a8f"],

Cell[BoxData[
 RowBox[{"bobRealization", " ", "=", " ", 
  RowBox[{
   RowBox[{
    RowBox[{"#", "[", "\"\<SimulatedMeasurement\>\"", "]"}], " ", "&"}], " ", 
   "/@", " ", "mea"}]}]], "Input",
 CellLabel->"In[8]:= ",ExpressionUUID->"412fc7c7-71b6-4bab-915c-43a5b813d599"],

Cell[TextData[{
 "Bob assigns the bit 0 whenever he gets ",
 Cell[BoxData[
  RowBox[{"|", 
   RowBox[{
    SubscriptBox[
     StyleBox["z", "TI"], "+"], "\[RightAngleBracket]"}]}]], "InlineFormula",
  ExpressionUUID->"e33a7b16-adc5-4c51-b2a4-b95d22db50be"],
 " or ",
 Cell[BoxData[
  RowBox[{"|", 
   RowBox[{
    SubscriptBox[
     StyleBox["x", "TI"], "+"], "\[RightAngleBracket]"}]}]], "InlineFormula",
  ExpressionUUID->"f0f9c9de-5e33-4b81-9574-5b233b5f2c4b"],
 ", and the bit 1 for ",
 Cell[BoxData[
  RowBox[{"|", 
   RowBox[{
    SubscriptBox[
     StyleBox["z", "TI"], "-"], "\[RightAngleBracket]"}]}]], "InlineFormula",
  ExpressionUUID->"c7a20ce4-8304-4c2c-a66f-31413e65b6be"],
 " or ",
 Cell[BoxData[
  RowBox[{"|", 
   RowBox[{
    SubscriptBox[
     StyleBox["x", "TI"], "-"], "\[RightAngleBracket]"}]}]], "InlineFormula",
  ExpressionUUID->"d1038210-f218-47f5-814d-6cc3b30802d7"],
 ":"
}], "ExampleText",ExpressionUUID->"07355d04-ddcc-4089-8bfc-9e1e108234e7"],

Cell[BoxData[
 RowBox[{"bobBits", " ", "=", " ", "\n", " ", 
  RowBox[{"bobRealization", " ", "/.", " ", "\n", "  ", 
   RowBox[{"Flatten", "[", 
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{"Alternatives", " ", "@@", " ", 
        RowBox[{"#", "[", 
         RowBox[{"[", 
          RowBox[{";;", " ", "2"}], "]"}], "]"}]}], " ", "->", " ", 
       RowBox[{"#", "[", 
        RowBox[{"[", 
         RowBox[{"-", "1"}], "]"}], "]"}]}], " ", "&"}], " ", "/@", " ", "\n",
      "    ", 
     RowBox[{"Transpose", "[", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{
         RowBox[{"QuditBasis", "[", "\"\<Z\>\"", "]"}], "[", "\"\<Names\>\"", 
         "]"}], ",", " ", "\n", "      ", 
        RowBox[{
         RowBox[{"QuditBasis", "[", "\"\<X\>\"", "]"}], "[", "\"\<Names\>\"", 
         "]"}], ",", " ", 
        RowBox[{"{", 
         RowBox[{"0", ",", " ", "1"}], "}"}]}], "}"}], "]"}]}], 
    "]"}]}]}]], "Input",
 CellLabel->"In[9]:= ",ExpressionUUID->"d2223cf1-5bde-4590-834a-0736cc088da0"],

Cell["\<\
Finally, Alice and Bob publicly share with each other the measurement basis \
that they used (in other words, they conduct a classical communication). If \
the basis is same, they each keep the bit; if not, they each disregard the \
corresponding bit. (Note that each does so separately, and each one obtains a \
secret key, which will be the same as the other's):\
\>", "ExampleText",ExpressionUUID->"55a6748e-6521-4e06-aa4f-2146e2bf2338"],

Cell[BoxData[
 RowBox[{"aliceSecretKey", " ", "=", " ", "\n", " ", 
  RowBox[{
   RowBox[{"Select", "[", 
    RowBox[{
     RowBox[{"Transpose", "[", 
      RowBox[{"{", 
       RowBox[{
       "aliceBits", ",", " ", "aliceBases", ",", " ", "\n", "     ", 
        "bobBases"}], "}"}], "]"}], ",", " ", 
     RowBox[{
      RowBox[{
       RowBox[{"#", "[", 
        RowBox[{"[", "2", "]"}], "]"}], " ", "==", " ", 
       RowBox[{"#", "[", 
        RowBox[{"[", "3", "]"}], "]"}]}], " ", "&"}]}], "]"}], "[", 
   RowBox[{"[", 
    RowBox[{"All", ",", " ", "1"}], "]"}], "]"}]}]], "Input",
 CellLabel->
  "In[10]:= ",ExpressionUUID->"38741f85-c63c-47df-b524-8817d0d95c9e"],

Cell[BoxData[
 RowBox[{"bobSecretKey", " ", "=", " ", "\n", " ", 
  RowBox[{
   RowBox[{"Select", "[", 
    RowBox[{
     RowBox[{"Transpose", "[", 
      RowBox[{"{", 
       RowBox[{
       "bobBits", ",", " ", "aliceBases", ",", " ", "\n", "     ", 
        "bobBases"}], "}"}], "]"}], ",", " ", 
     RowBox[{
      RowBox[{
       RowBox[{"#", "[", 
        RowBox[{"[", "2", "]"}], "]"}], " ", "==", " ", 
       RowBox[{"#", "[", 
        RowBox[{"[", "3", "]"}], "]"}]}], " ", "&"}]}], "]"}], "[", 
   RowBox[{"[", 
    RowBox[{"All", ",", " ", "1"}], "]"}], "]"}]}]], "Input",
 CellLabel->
  "In[11]:= ",ExpressionUUID->"a6f41c60-9eca-4446-8004-04fa98c36810"],

Cell[BoxData[
 RowBox[{"bobSecretKey", " ", "==", " ", "aliceSecretKey"}]], "Input",
 CellLabel->
  "In[12]:= ",ExpressionUUID->"920270b8-0a05-4290-bbba-f23e810e9aea"],

Cell["\<\
Alice and Bob now share a secret key. Note that the key length is less than \
the number of qubits Alice sent to Bob (because Bob picks the measurement \
basis randomly, and he might not get the same outcome as Alice). Alice can \
keep sending Bob qubits until they reach a desired length. This can be \
implemented as follows:\
\>", "ExampleText",ExpressionUUID->"d2be4247-c344-499d-89fb-ca7407064d4f"],

Cell[BoxData[
 RowBox[{
  RowBox[{"add", "[", 
   RowBox[{"{", 
    RowBox[{"x_", ",", " ", "y_"}], "}"}], "]"}], " ", ":=", " ", "\n", " ", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
     "aliceBit", ",", " ", "aliceBase", ",", " ", "aliceQubit", ",", " ", 
      "bobBase", ",", " ", "bobBit"}], "}"}], ",", "\n", "  ", 
    RowBox[{
     RowBox[{"aliceBit", " ", "=", " ", 
      RowBox[{"RandomChoice", "[", 
       RowBox[{"{", 
        RowBox[{"0", ",", " ", "1"}], "}"}], "]"}]}], ";", "\n", "  ", 
     RowBox[{"aliceBase", " ", "=", " ", 
      RowBox[{"RandomChoice", "[", 
       RowBox[{"{", 
        RowBox[{"\"\<Z\>\"", ",", " ", "\"\<X\>\""}], "}"}], "]"}]}], ";", 
     "\n", "  ", 
     RowBox[{"aliceQubit", " ", "=", " ", 
      RowBox[{"aliceProtocol", "[", 
       RowBox[{"{", 
        RowBox[{"aliceBit", ",", " ", "aliceBase"}], "}"}], "]"}]}], ";", 
     "\n", "  ", 
     RowBox[{"bobBase", " ", "=", " ", 
      RowBox[{"RandomChoice", "[", 
       RowBox[{"{", 
        RowBox[{"\"\<Z\>\"", ",", " ", "\"\<X\>\""}], "}"}], "]"}]}], ";", 
     "\n", "  ", 
     RowBox[{"bobBit", " ", "=", " ", "\n", "   ", 
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{"QuantumMeasurementOperator", "[", "bobBase", "]"}], "[", 
         "aliceQubit", "]"}], "[", "\n", 
        "     ", "\"\<SimulatedMeasurement\>\"", "]"}], " ", "/.", " ", "\n", 
       "    ", 
       RowBox[{"Flatten", "[", 
        RowBox[{
         RowBox[{
          RowBox[{
           RowBox[{"Alternatives", " ", "@@", " ", 
            RowBox[{"#", "[", 
             RowBox[{"[", 
              RowBox[{";;", " ", "2"}], "]"}], "]"}]}], " ", "->", " ", 
           RowBox[{"#", "[", 
            RowBox[{"[", 
             RowBox[{"-", "1"}], "]"}], "]"}]}], " ", "&"}], " ", "/@", " ", 
         "\n", "      ", 
         RowBox[{"Transpose", "[", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{
             RowBox[{"QuditBasis", "[", "\"\<Z\>\"", "]"}], 
             "[", "\"\<Names\>\"", "]"}], ",", " ", "\n", "        ", 
            RowBox[{
             RowBox[{"QuditBasis", "[", "\"\<X\>\"", "]"}], 
             "[", "\"\<Names\>\"", "]"}], ",", " ", 
            RowBox[{"{", 
             RowBox[{"0", ",", " ", "1"}], "}"}]}], "}"}], "]"}]}], "]"}]}]}],
      ";", "\n", "  ", 
     RowBox[{"If", "[", 
      RowBox[{
       RowBox[{"aliceBase", " ", "==", " ", "bobBase"}], ",", " ", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"Append", "[", 
          RowBox[{"x", ",", " ", "aliceBit"}], "]"}], ",", " ", "\n", "    ", 
         
         RowBox[{"Append", "[", 
          RowBox[{"y", ",", " ", "bobBit"}], "]"}]}], "}"}], ",", " ", 
       RowBox[{"{", 
        RowBox[{"x", ",", " ", "y"}], "}"}]}], "]"}]}]}], "]"}]}]], "Input",
 CellLabel->
  "In[13]:= ",ExpressionUUID->"6476220e-deea-4e80-b423-aea923ecebba"],

Cell["For example, the key length is set to 5 bits below:", "ExampleText",ExpressionUUID->"18309e03-d9af-4d17-beaf-ae7b273156a5"],

Cell[BoxData[
 RowBox[{"NestWhile", "[", 
  RowBox[{"add", ",", " ", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"{", "}"}], ",", " ", 
     RowBox[{"{", "}"}]}], "}"}], ",", " ", 
   RowBox[{
    RowBox[{
     RowBox[{"Length", "[", 
      RowBox[{"#", "[", 
       RowBox[{"[", "1", "]"}], "]"}], "]"}], " ", "<", " ", "5"}], " ", 
    "&"}]}], "]"}]], "Input",
 CellLabel->
  "In[14]:= ",ExpressionUUID->"67c730e4-0450-41a1-9e04-0f215270f4d8"],

Cell["Parity test", "ExampleSubsection",ExpressionUUID->"32c6a1fc-794e-49a1-8a1f-731f7297901f"],

Cell["\<\
Quantum circuit for parity test. If the number of 1 in a bit string (e.g. \
0001101..) is even, the parity is assigned to 0 (even parity), if it is odd, \
the parity is assigned to 1 (odd parity). A quantum circuit to measure parity \
of an n-qubit state is given below:\
\>", "ExampleText",ExpressionUUID->"102419d6-4d4c-495c-a3c9-c489a88d1937"],

Cell[BoxData[
 RowBox[{
  RowBox[{"parityMeasurementCircuit", "[", "n_", "]"}], " ", ":=", " ", "\n", 
  " ", 
  RowBox[{"QuantumCircuitOperator", "[", "\n", "  ", 
   RowBox[{"Append", "[", 
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{"\"\<CNOT\>\"", " ", "->", " ", 
        RowBox[{"{", 
         RowBox[{"#", ",", " ", 
          RowBox[{"n", " ", "+", " ", "1"}]}], "}"}]}], " ", "&"}], " ", "/@",
       " ", 
      RowBox[{"Range", "[", "n", "]"}]}], ",", " ", 
     RowBox[{"{", 
      RowBox[{"n", " ", "+", " ", "1"}], "}"}]}], "]"}], "]"}]}]], "Input",
 CellLabel->"In[1]:= ",ExpressionUUID->"ef704ce6-39ef-4e26-bdfd-1daed1d86ec4"],

Cell["Example of a parity measurement circuit for 3-qubit state:", \
"ExampleText",ExpressionUUID->"77731176-92e1-45b7-9b69-bea22a7d141d"],

Cell[BoxData[
 RowBox[{
  RowBox[{"parityMeasurementCircuit", "[", "3", "]"}], "[", "\"\<Diagram\>\"",
   "]"}]], "Input",
 CellLabel->"In[2]:= ",ExpressionUUID->"4692ee7f-40e6-47a6-b718-e5bc1299a7c1"],

Cell[TextData[{
 "Apply this circuit to ",
 Cell[BoxData[
  RowBox[{"|", 
   RowBox[{"000", "\[RightAngleBracket]", "\[CircleTimes]"}], "|", "0", 
   "\[RightAngleBracket]"}]], "InlineFormula",ExpressionUUID->
  "3491a4f5-ee18-4b67-ad94-7f85c177a19b"],
 " (even parity) and ",
 Cell[BoxData[
  RowBox[{"|", 
   RowBox[{"001", "\[RightAngleBracket]", "\[CircleTimes]"}], "|", "0", 
   "\[RightAngleBracket]"}]], "InlineFormula",ExpressionUUID->
  "edf8b077-0f07-46c5-979c-ccf110f076d8"],
 " (odd parity):"
}], "ExampleText",ExpressionUUID->"c73cded7-c500-4c8a-9cb3-e233d85711dc"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"parityMeasurementCircuit", "[", "3", "]"}], "[", 
     RowBox[{"QuantumState", "[", "\"\<0000\>\"", "]"}], "]"}], 
    "[", "\"\<ProbabilityPlot\>\"", "]"}], ",", "\n", "  ", 
   RowBox[{
    RowBox[{
     RowBox[{"parityMeasurementCircuit", "[", "3", "]"}], "[", 
     RowBox[{"QuantumState", "[", "\"\<0010\>\"", "]"}], "]"}], 
    "[", "\"\<ProbabilityPlot\>\"", "]"}]}], "}"}]], "Input",
 CellLabel->"In[3]:= ",ExpressionUUID->"b0171d7a-2167-4a61-af1a-ba0b3a3a739e"],

Cell["Quantum Approximate Optimization Algorithm  (QAOA)", "ExampleSubsection",ExpressionUUID->"eb833086-3972-4d54-b691-12d788bf509f"],

Cell[TextData[{
 "One can find a binary vector ",
 Cell[BoxData[
  StyleBox["x", "TI"]], "InlineFormula",ExpressionUUID->
  "5a980893-5c35-4240-9195-5b4ba9609f98"],
 " that minimizes (or maximizes) the quadratic objective ",
 Cell[BoxData[
  RowBox[{
   StyleBox["x", "TI"], ".", 
   StyleBox["q", "TI"], ".", 
   RowBox[{
    StyleBox["x", "TI"], "+", 
    StyleBox["c", "TI"]}], ".", 
   StyleBox["x", "TI"]}]], "InlineFormula",ExpressionUUID->
  "85e0b0f5-012e-4140-ad9f-6ab757bb774a"],
 ", with no constrains. This is usually called as Quadratic Unconstrained \
Binary Optimization (QUBO). The linear term ",
 Cell[BoxData[
  StyleBox["c", "TI"]], "InlineFormula",ExpressionUUID->
  "17ff33b6-4013-4e5a-bf4c-d2792b54d4eb"],
 " can be dropped, without losing generality."
}], "ExampleText",ExpressionUUID->"05a21324-f28a-4183-84d2-31823dae22d5"],

Cell[TextData[{
 "Define a ",
 Cell[BoxData[
  RowBox[{"4", "\[Times]", "4"}]], "InlineFormula",ExpressionUUID->
  "c1d99e5f-e902-4313-8418-3eeb23867499"],
 " real-valued upper triangular matrix, as the objective matrix:"
}], "ExampleText",ExpressionUUID->"dd9c43e0-fb54-444f-b4b3-8b6023b1eb52"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"q", " ", "=", " ", 
   RowBox[{"UpperTriangularize", "[", 
    RowBox[{"RandomReal", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{"-", "5"}], ",", " ", "5"}], "}"}], ",", " ", 
      RowBox[{"{", 
       RowBox[{"4", ",", " ", "4"}], "}"}]}], "]"}], "]"}]}], ";"}], "\n", 
 RowBox[{"q", " ", "//", " ", "MatrixForm"}]}], "Input",
 CellLabel->"In[1]:= ",ExpressionUUID->"b9ac6da4-640f-4f78-8d6b-4118f5b967de"],

Cell["Generate the corresponding objective function:", "ExampleText",ExpressionUUID->"6db622bd-bf0a-448e-8605-ab5de84ac35a"],

Cell[BoxData[
 RowBox[{"Expand", "@", 
  RowBox[{"Block", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"x", " ", "=", " ", 
      RowBox[{"Array", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"Indexed", "[", 
          RowBox[{"\[FormalX]", ",", " ", "#"}], "]"}], " ", "&"}], ",", " ", 
        
        RowBox[{"Length", "[", "q", "]"}]}], "]"}]}], "}"}], ",", " ", "\n", 
    "  ", 
    RowBox[{"x", " ", ".", " ", "q", " ", ".", " ", "x"}]}], "]"}]}]], "Input",\

 CellLabel->"In[2]:= ",ExpressionUUID->"59442437-3ce5-43fb-828c-eef20ec31195"],

Cell["\<\
Maximize and minimize the objective function (classical approach):\
\>", "ExampleText",ExpressionUUID->"7d69b749-5269-4a78-a2ad-66cce082f2d8"],

Cell[BoxData[{
 RowBox[{"solMax", " ", "=", " ", "\n", " ", 
  RowBox[{"NArgMax", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{"x", " ", ".", " ", "q", " ", ".", " ", "x"}], ",", " ", 
      RowBox[{"0", " ", "\[VectorLess]", " ", 
       RowBox[{"x", "^", "2"}], " ", "\[VectorLessEqual]", " ", "1"}]}], 
     "}"}], ",", " ", "\n", "  ", 
    RowBox[{"x", " ", "\[Element]", " ", 
     RowBox[{"Vectors", "[", 
      RowBox[{
       RowBox[{"Length", "[", "q", "]"}], ",", " ", "Integers"}], "]"}]}]}], 
   "]"}]}], "\n", 
 RowBox[{"solMin", " ", "=", " ", "\n", " ", 
  RowBox[{"NArgMin", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{"x", " ", ".", " ", "q", " ", ".", " ", "x"}], ",", " ", 
      RowBox[{"0", " ", "\[VectorLess]", " ", 
       RowBox[{"x", "^", "2"}], " ", "\[VectorLessEqual]", " ", "1"}]}], 
     "}"}], ",", " ", "\n", "  ", 
    RowBox[{"x", " ", "\[Element]", " ", 
     RowBox[{"Vectors", "[", 
      RowBox[{
       RowBox[{"Length", "[", "q", "]"}], ",", " ", "Integers"}], "]"}]}]}], 
   "]"}]}]}], "Input",
 CellLabel->"In[3]:= ",ExpressionUUID->"20d052ae-aa60-4292-9268-895a09d34972"],

Cell["Define a quantum circuit for any objective function:", "ExampleText",ExpressionUUID->"fb117aac-0ba4-4417-84be-97e02e0ff594"],

Cell[BoxData[{
 RowBox[{"ClearAll", "[", 
  RowBox[{"\[Gamma]", ",", " ", "\[Beta]", ",", " ", "qaoa"}], "]"}], "\n", 
 RowBox[{
  RowBox[{"qaoa", "[", 
   RowBox[{
    RowBox[{"obj_", "?", "SquareMatrixQ"}], ",", " ", 
    RowBox[{"p_", " ", ":", " ", "1"}]}], "]"}], " ", ":=", " ", 
  RowBox[{"With", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"l", " ", "=", " ", 
      RowBox[{"Length", "[", "obj", "]"}]}], "}"}], ",", "\n", "  ", 
    RowBox[{
     RowBox[{"QuantumCircuitOperator", "[", 
      RowBox[{"Join", "[", "\n", "     ", 
       RowBox[{
        RowBox[{"Table", "[", 
         RowBox[{
          RowBox[{"\"\<+\>\"", " ", "->", " ", "i"}], ",", " ", 
          RowBox[{"{", 
           RowBox[{"i", ",", " ", "l"}], "}"}]}], "]"}], ",", "\n", "     ", 
        RowBox[{"Catenate", "@", 
         RowBox[{"Table", "[", "\n", "       ", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{"\"\<Barrier\>\"", ",", "\n", "        ", 
             RowBox[{"Catenate", "@", 
              RowBox[{"Table", "[", "\n", "          ", "\n", "          ", 
               RowBox[{
                RowBox[{"If", "[", 
                 RowBox[{
                  RowBox[{
                   RowBox[{"obj", "[", 
                    RowBox[{"[", 
                    RowBox[{"i", ",", " ", "j"}], "]"}], "]"}], " ", "==", 
                   " ", "0"}], ",", " ", "Nothing", ",", " ", "\n", 
                  "           ", 
                  RowBox[{
                   RowBox[{"\"\<R\>\"", "[", 
                    RowBox[{
                    RowBox[{"2", " ", 
                    RowBox[{"\[Gamma]", "[", "m", "]"}], " ", 
                    RowBox[{"obj", "[", 
                    RowBox[{"[", 
                    RowBox[{"i", ",", " ", "j"}], "]"}], "]"}]}], ",", 
                    " ", "\"\<ZZ\>\""}], "]"}], " ", "->", " ", 
                   RowBox[{"{", 
                    RowBox[{"i", ",", " ", "j"}], "}"}]}]}], "]"}], ",", "\n",
                 "          ", 
                RowBox[{"{", 
                 RowBox[{"i", ",", " ", "l"}], "}"}], ",", " ", 
                RowBox[{"{", 
                 RowBox[{"j", ",", " ", 
                  RowBox[{"i", " ", "+", " ", "1"}], ",", " ", "l"}], "}"}]}],
                "\n", "          ", "]"}]}], ",", "\n", 
             "        ", "\"\<Barrier\>\"", ",", "\n", "        ", 
             RowBox[{"Table", "[", 
              RowBox[{
               RowBox[{
                RowBox[{"\"\<R\>\"", "[", " ", 
                 RowBox[{
                  RowBox[{"2", " ", 
                   RowBox[{"\[Beta]", "[", "m", "]"}]}], ",", 
                  " ", "\"\<X\>\""}], "]"}], " ", "->", " ", "i"}], ",", " ", 
               
               RowBox[{"{", 
                RowBox[{"i", ",", " ", "l"}], "}"}]}], "]"}]}], "}"}], "\n", 
           "       ", ",", " ", 
           RowBox[{"{", 
            RowBox[{"m", ",", " ", "p"}], "}"}]}], "]"}]}]}], "]"}], "\n", 
      "    ", "]"}], "[", "\"\<Flatten\>\"", "]"}]}], "]"}]}]}], "Input",
 CellLabel->"In[4]:= ",ExpressionUUID->"fe8558d0-75a1-460a-90c8-ddd3e13673aa"],

Cell["\<\
Generate the circuit for the objective matrix, with only two layers:\
\>", "ExampleText",ExpressionUUID->"40663a25-5bcd-497e-a61b-43432e74acc8"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"p", " ", "=", " ", "2"}], ";"}], "\n", 
 RowBox[{
  RowBox[{"qaoa", "[", 
   RowBox[{"q", ",", " ", "p"}], "]"}], "[", 
  RowBox[{"\"\<Diagram\>\"", ",", " ", 
   RowBox[{"FontSize", " ", "->", " ", "9"}], ",", " ", 
   RowBox[{"\"\<ShowGateLabels\>\"", " ", "->", " ", "False"}]}], 
  "]"}]}], "Input",
 CellLabel->"In[5]:= ",ExpressionUUID->"310de2a7-4952-4074-b4fb-324fb1fa70a2"],

Cell["Define variable (angles) that should be optimized", "ExampleText",ExpressionUUID->"5a218531-e637-4897-987a-7197f6973366"],

Cell[BoxData[
 RowBox[{"var", " ", "=", " ", 
  RowBox[{"Join", "[", 
   RowBox[{
    RowBox[{"Table", "[", 
     RowBox[{
      RowBox[{"\[Gamma]", "[", "i", "]"}], ",", " ", 
      RowBox[{"{", 
       RowBox[{"i", ",", " ", "p"}], "}"}]}], "]"}], ",", " ", 
    RowBox[{"Table", "[", 
     RowBox[{
      RowBox[{"\[Beta]", "[", "i", "]"}], ",", " ", 
      RowBox[{"{", 
       RowBox[{"i", ",", " ", "p"}], "}"}]}], "]"}]}], "]"}]}]], "Input",
 CellLabel->"In[6]:= ",ExpressionUUID->"70dcdd30-f57d-43c7-8cc8-efb4f513b4da"],

Cell["\<\
Find the corresponding probabilities in the computational basis:\
\>", "ExampleText",ExpressionUUID->"69e37964-f7c0-4a38-982c-cc7b8dfda349"],

Cell[BoxData[
 RowBox[{
  RowBox[{"weight", " ", "=", " ", 
   RowBox[{
    RowBox[{"Abs", "[", 
     RowBox[{
      RowBox[{"qaoa", "[", 
       RowBox[{"q", ",", " ", "p"}], "]"}], "[", "\"\<Amplitudes\>\"", "]"}], 
     "]"}], "^", "2"}]}], ";"}]], "Input",
 CellLabel->"In[7]:= ",ExpressionUUID->"64943048-e37a-4da2-b378-7e1c5d008143"],

Cell[TextData[{
 "Find ",
 Cell[BoxData[
  RowBox[{
   RowBox[{"\[LeftAngleBracket]", "\[Gamma]"}], 
   RowBox[{",", "\[ThinSpace]"}], 
   RowBox[{"\[Beta]", "|", 
    StyleBox["H", "TI"], "|", "\[Gamma]"}], 
   RowBox[{",", "\[ThinSpace]"}], 
   RowBox[{"\[Beta]", "\[RightAngleBracket]"}]}]], "InlineFormula",
  ExpressionUUID->"ebbf8fef-a822-4336-b8f6-8ecb58765b6e"],
 " with ",
 Cell[BoxData[
  RowBox[{
   StyleBox["H", "TI"], "=", 
   SubscriptBox["\[Sum]", 
    RowBox[{
     StyleBox["i", "TI"], ">", 
     StyleBox["j", "TI"]}]], 
   SubscriptBox[
    StyleBox["q", "TI"], 
    StyleBox["ij", "TI"]], 
   SubscriptBox["\[Sigma]", 
    RowBox[{
     StyleBox["z", "TI"], 
     RowBox[{",", "\[ThinSpace]"}], 
     StyleBox["i", "TI"]}]], 
   SubscriptBox["\[Sigma]", 
    RowBox[{
     StyleBox["z", "TI"], 
     RowBox[{",", "\[ThinSpace]"}], 
     StyleBox["j", "TI"]}]]}]], "InlineFormula",ExpressionUUID->
  "672084ad-6e73-40b1-9bd0-0073b52246c6"],
 " and ",
 Cell[BoxData[
  RowBox[{"|", "\[Gamma]", 
   RowBox[{",", "\[ThinSpace]"}], 
   RowBox[{"\[Beta]", "\[RightAngleBracket]"}]}]], "InlineFormula",
  ExpressionUUID->"3a4dec32-ede0-47b9-9572-d5545d83091c"],
 " the output of above circuit"
}], "ExampleText",ExpressionUUID->"44c60876-1fb1-4090-a3ef-f7f494713502"],

Cell[BoxData[
 RowBox[{
  RowBox[{"weightedEnergy", " ", "=", " ", "\n", "  ", 
   RowBox[{"Association", "@", "\n", "   ", 
    RowBox[{"KeyValueMap", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"#1", " ", "->", " ", 
        RowBox[{"#2", " ", 
         RowBox[{"Total", "[", "\n", "        ", 
          RowBox[{
           RowBox[{
            RowBox[{"UpperTriangularize", "[", 
             RowBox[{"q", ",", " ", "1"}], "]"}], " ", 
            RowBox[{"UpperTriangularize", "[", "\n", "          ", 
             RowBox[{
              RowBox[{"KroneckerProduct", "[", 
               RowBox[{
                RowBox[{
                 RowBox[{"(", 
                  RowBox[{"-", "1"}], ")"}], "^", 
                 RowBox[{"#1", "[", "\"\<Name\>\"", "]"}]}], ",", " ", 
                RowBox[{
                 RowBox[{"(", 
                  RowBox[{"-", "1"}], ")"}], "^", 
                 RowBox[{"#1", "[", "\"\<Name\>\"", "]"}]}]}], "]"}], ",", 
              " ", "1"}], "]"}]}], ",", " ", "2"}], "]"}]}]}], " ", "&"}], ",",
       "\n", "     ", "weight"}], "]"}]}]}], ";"}]], "Input",
 CellLabel->"In[8]:= ",ExpressionUUID->"29b5d2aa-e113-4876-8af9-f17a69dc699f"],

Cell["Maximize and minimize the total weighted-mean value", "ExampleText",ExpressionUUID->"b6fe1cfd-2469-4fe5-b04b-57b7f7b51a32"],

Cell[BoxData[{
 RowBox[{"optMax", " ", "=", " ", "\n", " ", 
  RowBox[{"Thread", "[", 
   RowBox[{"var", " ", "->", " ", "\n", "   ", 
    RowBox[{"NArgMax", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{"Total", "[", "weightedEnergy", "]"}], ",", " ", "\n", 
        "     ", 
        RowBox[{
        "0", " ", "\[VectorLessEqual]", " ", "var", " ", "\[VectorLessEqual]",
          " ", 
         RowBox[{"2", " ", "\[Pi]"}]}]}], "}"}], ",", " ", "var"}], "]"}]}], 
   "]"}]}], "\n", 
 RowBox[{"optMin", " ", "=", " ", "\n", " ", 
  RowBox[{"Thread", "[", 
   RowBox[{"var", " ", "->", " ", "\n", "   ", 
    RowBox[{"NArgMin", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{"Total", "[", "weightedEnergy", "]"}], ",", " ", "\n", 
        "     ", 
        RowBox[{
        "0", " ", "\[VectorLessEqual]", " ", "var", " ", "\[VectorLessEqual]",
          " ", 
         RowBox[{"2", " ", "\[Pi]"}]}]}], "}"}], ",", " ", "var"}], "]"}]}], 
   "]"}]}]}], "Input",
 CellLabel->"In[9]:= ",ExpressionUUID->"8ba39e49-cdf6-4f05-b2af-b52e496280e4"],

Cell["Plot the results given the optimal values:", "ExampleText",ExpressionUUID->"e716be6c-4bf6-43c2-8987-bf92fcc5eef1"],

Cell[BoxData[
 RowBox[{"Row", "[", 
  RowBox[{"{", 
   RowBox[{
    RowBox[{"With", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"data", " ", "=", " ", 
        RowBox[{"N", "[", 
         RowBox[{"weightedEnergy", " ", "/.", " ", "optMax"}], "]"}]}], "}"}],
       ",", " ", "\n", "   ", 
      RowBox[{"BarChart", "[", 
       RowBox[{"data", ",", " ", "\n", "    ", 
        RowBox[{"ChartLabels", " ", "->", " ", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{
            RowBox[{"Rotate", "[", "\n", "         ", 
             RowBox[{
              RowBox[{"If", "[", 
               RowBox[{
                RowBox[{
                 RowBox[{"(", 
                  RowBox[{"solMax", " ", "/.", " ", 
                   RowBox[{
                    RowBox[{"-", "1"}], " ", "->", " ", "0"}]}], ")"}], " ", "==",
                  " ", 
                 RowBox[{"#", "[", "\"\<Name\>\"", "]"}]}], ",", " ", "\n", 
                "          ", 
                RowBox[{"Style", "[", 
                 RowBox[{
                  RowBox[{"#", "[", "\"\<Name\>\"", "]"}], ",", " ", "Red"}], 
                 "]"}], ",", " ", 
                RowBox[{"#", "[", "\"\<Name\>\"", "]"}]}], "]"}], ",", " ", 
              RowBox[{"Pi", "/", "2"}]}], "]"}], " ", "&"}], " ", "/@", " ", 
           RowBox[{"Keys", "[", "data", "]"}]}], ")"}]}], ",", " ", "\n", 
        "    ", 
        RowBox[{
        "PlotLabel", " ", "->", 
         " ", "\"\<Maximizing objective function\>\""}], ",", " ", 
        RowBox[{"ImageSize", " ", "->", " ", "200"}]}], "]"}]}], "]"}], ",", 
    " ", "\n", "  ", 
    RowBox[{"With", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"data", " ", "=", " ", 
        RowBox[{"N", "[", 
         RowBox[{"weightedEnergy", " ", "/.", " ", "optMin"}], "]"}]}], "}"}],
       ",", " ", "\n", "   ", 
      RowBox[{"BarChart", "[", 
       RowBox[{"data", ",", " ", "\n", "    ", 
        RowBox[{"ChartLabels", " ", "->", " ", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{
            RowBox[{"Rotate", "[", "\n", "         ", 
             RowBox[{
              RowBox[{"If", "[", 
               RowBox[{
                RowBox[{
                 RowBox[{"(", 
                  RowBox[{"solMin", " ", "/.", " ", 
                   RowBox[{
                    RowBox[{"-", "1"}], " ", "->", " ", "0"}]}], ")"}], " ", "==",
                  " ", 
                 RowBox[{"#", "[", "\"\<Name\>\"", "]"}]}], ",", " ", "\n", 
                "          ", 
                RowBox[{"Style", "[", 
                 RowBox[{
                  RowBox[{"#", "[", "\"\<Name\>\"", "]"}], ",", " ", "Red"}], 
                 "]"}], ",", " ", 
                RowBox[{"#", "[", "\"\<Name\>\"", "]"}]}], "]"}], ",", " ", 
              RowBox[{"Pi", "/", "2"}]}], "]"}], " ", "&"}], " ", "/@", " ", 
           RowBox[{"Keys", "[", "data", "]"}]}], ")"}]}], ",", " ", "\n", 
        "    ", 
        RowBox[{
        "PlotLabel", " ", "->", 
         " ", "\"\<Minimizing objective function\>\""}], ",", " ", 
        RowBox[{"ImageSize", " ", "->", " ", "200"}]}], "]"}]}], "]"}]}], 
   "}"}], "]"}]], "Input",
 CellLabel->
  "In[10]:= ",ExpressionUUID->"811c2f50-2f04-46d9-ab6b-a69330324d4a"],

Cell[TextData[{
 "Two solutions is due to the fact that NOT of solution is also a max/min (",
 Cell[BoxData[
  RowBox[{
   RowBox[{"(", 
    RowBox[{"-", 
     StyleBox["x", "TI"]}], ")"}], ".", 
   StyleBox["q", "TI"], ".", 
   RowBox[{"(", 
    RowBox[{"-", 
     StyleBox["x", "TI"]}], ")", "=", 
