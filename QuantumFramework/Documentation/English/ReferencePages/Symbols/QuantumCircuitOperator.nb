Cell[TextData[{
 "The Boolean oracle flips the ancillary qubit (here the 3rd qubit) only when \
the input state is a solution of the Boolean function. For example, ",
 Cell[BoxData[
  RowBox[{"{", 
   RowBox[{"True", ",", " ", "False"}], "}"}]], "InlineFormula",
  ExpressionUUID->"3db62012-8e48-4c13-ba2b-ef63cbdeb841"],
 " (that is, 10) is a solution of ",
 Cell[BoxData[
  RowBox[{"a", " ", "&&", " ", 
   RowBox[{"!", "b"}]}]], "InlineFormula",ExpressionUUID->
  "86a2c683-d931-41a0-932e-e5ff4ccae6c2"],
 ", so the ancillary qubit is flipped:"
}], "ExampleText",ExpressionUUID->"d626df34-71d1-4c72-a94d-d5bd96a542f7"],

