Cell[TextData[{
 "InverseFourier circuit transforms from the momentum (Pauli-X) basis back \
into the computational basis. Check ",
 Cell[BoxData[
  RowBox[{"|", 
   RowBox[{
    SubscriptBox[
     StyleBox["x", "TI"], "+"], 
    SubscriptBox[
     StyleBox["x", "TI"], "+"]}], "\[RightAngleBracket]"}]], "InlineFormula",
  ExpressionUUID->"f1faacd7-8a99-4787-b3d3-096635612e04"],
 " is transformed into ",
 Cell[BoxData[
  RowBox[{"|", "00", "\[RightAngleBracket]"}]], "InlineFormula",
  ExpressionUUID->"28aa296e-f338-44a1-9485-cf41c47b305a"],
 ":"
}], "ExampleText",ExpressionUUID->"48388122-818c-4e8f-b637-e6dd3184d782"],

