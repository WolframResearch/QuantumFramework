Cell["\<\
The encoded curve sits above the unencoded one throughout, the gap widening \
as the redundancy suppresses the leading-order error.\
\>", "ExampleText",ExpressionUUID->"d9d920a6-92bb-4621-ace7-046bfe5a2229"],

Cell["Indefinite causal order: the quantum switch", "ExampleSubsection",ExpressionUUID->"03baa4a7-25e5-426f-ad25-821d59822772"],

Cell[TextData[{
 "Every circuit so far fixes the order in which its gates act. The quantum \
switch removes even that assumption: a control qubit coherently decides \
whether operation ",
 Cell[BoxData[
  StyleBox["A", "TI"]], "InlineFormula",ExpressionUUID->
  "972ebb24-33eb-4a94-9d42-a14541e41840"],
 " precedes ",
 Cell[BoxData[
  StyleBox["B", "TI"]], "InlineFormula",ExpressionUUID->
  "9ee06a36-68ee-4603-b176-7e4938e1af32"],
 " or the reverse, a resource with indefinite causal order that no fixed \
circuit can reproduce. ",
 Cell[BoxData[
 "QuantumCircuitOperator"], "InlineFormula",ExpressionUUID->
  "44b415a0-2ffe-4d3a-9c79-e3cc8b3029a8"],
 " provides it as the named circuit ",
 Cell[BoxData[
  RowBox[{"\"\<Switch\>\"", "[", 
   RowBox[{"A", ",", " ", "B"}], "]"}]], "InlineFormula",ExpressionUUID->
  "e75760c4-765a-4933-b86a-ae628aa4b7cb"],
 "."
}], "ExampleText",ExpressionUUID->"e4799730-db5c-4a16-8e5e-214a96661a60"],

Cell["\<\
Build the switch of two single-qubit operations and inspect its structure:\
\>", "ExampleText",ExpressionUUID->"acf7058d-2a35-4e6c-a150-bb57a5cf0b50"],

Cell[CellGroupData[{

