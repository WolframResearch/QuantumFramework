Cell["\<\
The same oracle can be built as a multiplexer over the same angles:\
\>", "ExampleText",ExpressionUUID->"8081c3b9-d13e-418d-b66a-7fccedef557a"],

Cell[BoxData[
 RowBox[{
  RowBox[{"inv", " ", "=", " ", 
   RowBox[{"QuantumCircuitOperator", "[", 
    RowBox[{
     RowBox[{"\"\<Multiplexer\>\"", " ", "@@", " ", 
      RowBox[{"\"\<RY\>\"", " ", "/@", " ", "angles"}]}], ",", " ", "\n", 
     "   ", 
     RowBox[{"RotateLeft", "[", 
      RowBox[{"Range", "[", 
       RowBox[{"prec", " ", "+", " ", "1"}], "]"}], "]"}]}], "]"}]}], 
