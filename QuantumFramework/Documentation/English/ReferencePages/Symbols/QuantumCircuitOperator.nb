Cell[TextData[{
 "The Boolean oracle flips the ancillary qubit (here the 3rd qubit) only when \
the input state is a solution of the Boolean function. For example, ",
 Cell[BoxData[
  RowBox[{"{", 
   RowBox[{"True", ",", " ", "False"}], "}"}]], "InlineFormula",
  ExpressionUUID->"3db62012-8e48-4c13-ba2b-ef63cbdeb841"],
 " (that is, 10) is a solution of ",
 Cell[BoxData[
  RowBox[{"a", " ", "&&", " ", 
   RowBox[{"!", "b"}]}]], "InlineFormula",ExpressionUUID->
  "86a2c683-d931-41a0-932e-e5ff4ccae6c2"],
 ", so the ancillary qubit is flipped:"
}], "ExampleText",ExpressionUUID->"d626df34-71d1-4c72-a94d-d5bd96a542f7"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"bo", "[", 
   RowBox[{"QuantumState", "[", "\"\<100\>\"", "]"}], "]"}], 
  "[", "\"\<Formula\>\"", "]"}]], "Input",
 CellLabel->"In[3]:= ",ExpressionUUID->"8b136fac-bcfd-40b2-9bee-ecf1b7c57af2"],

Cell[BoxData[
 InterpretationBox[
  StyleBox[
   TemplateBox[{
     RowBox[{"1", "\[InvisibleSpace]", "0", "\[InvisibleSpace]", "1"}]},
    "Ket"],
   FontWeight->"Plain"],
  Wolfram`QuantumFramework`QuditName[{1, 0, 1}, "Dual" -> False]]], "Output",
 CellLabel->"Out[3]= ",ExpressionUUID->"9762c520-3bb2-4f72-8051-0c23bdce060e"]
}, Open  ]],

Cell["\<\
One can also get the decomposition of a Boolean oracle, in terms of CNOTs and \
Z-rotation:\
\>", "ExampleText",ExpressionUUID->"ad4d80ed-1db4-4918-b037-70032771e5c2"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"QuantumCircuitOperator", "[", 
   RowBox[{"\"\<BooleanOracleR\>\"", "[", 
    RowBox[{"a", " ", "&&", " ", 
     RowBox[{"!", " ", "b"}]}], "]"}], "]"}], "[", "\"\<Diagram\>\"", 
  "]"}]], "Input",
 CellLabel->"In[4]:= ",ExpressionUUID->"5cdd067e-9f0e-4087-b68e-8631e91eb0b9"],

