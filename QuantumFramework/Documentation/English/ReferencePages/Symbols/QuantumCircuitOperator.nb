Cell["\<\
Read off the most probable measurement outcome as a bit-string:\
\>", "ExampleText",ExpressionUUID->"0c89bef0-25c9-40a9-bc21-59018976d514"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"bits1", " ", "=", " ", 
  RowBox[{
   RowBox[{
    RowBox[{"Keys", "[", 
     RowBox[{"TakeLargest", "[", 
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{"N", "[", "qc", "]"}], "[", "]"}], 
        "[", "\"\<Probabilities\>\"", "]"}], ",", " ", "1"}], "]"}], "]"}], "[", 
    RowBox[{"[", "1", "]"}], "]"}], "[", "\"\<Name\>\"", "]"}]}]], "Input",
 CellLabel->"In[5]:= ",ExpressionUUID->"e396f106-5ce4-49d9-bd3d-a0e2a278ea8a"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"1", ",", "1", ",", "0", ",", "1"}], "}"}]], "Output",
 CellLabel->"Out[5]= ",ExpressionUUID->"e375be36-6549-4eab-a00f-3bda948310aa"]
}, Open  ]],

Cell["Convert that bit-string into the estimated eigenvalue:", "ExampleText",ExpressionUUID->"baabfd6c-dc92-4000-826a-1986ee9cd1cb"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"est1", " ", "=", " ", 
  RowBox[{
   RowBox[{
    RowBox[{"FromDigits", "[", 
     RowBox[{"bits1", ",", " ", "2"}], "]"}], "/", 
    RowBox[{"2", "^", "4"}]}], " ", "//", " ", "N"}]}]], "Input",
 CellLabel->"In[6]:= ",ExpressionUUID->"1cd22aed-a955-4c00-a694-0b198451993a"],

Cell[BoxData["0.8125`"], "Output",
 CellLabel->"Out[6]= ",ExpressionUUID->"754b9f3a-5775-45c4-a2c6-f90eb2852c57"]
}, Open  ]],

Cell["\<\
Generate another QPE circuit (dropping the leading Pauli-X gate) to obtain \
the other eigenvalue:\
\>", "ExampleText",ExpressionUUID->"a0d90f69-4e34-4b62-81f3-a6642bd9722f"],

Cell[BoxData[
 RowBox[{
  RowBox[{"qc2", " ", "=", " ", 
   RowBox[{"qc", "[", 
    RowBox[{"[", 
     RowBox[{"2", " ", ";;"}], "]"}], "]"}]}], ";"}]], "Input",
 CellLabel->"In[7]:= ",ExpressionUUID->"8301e04f-deaf-4949-b71e-7c41d4e0d14a"],

Cell["Draw its flattened circuit diagram:", "ExampleText",ExpressionUUID->"07c0fc12-d3ec-4e9e-862d-30746a506b2f"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"qc2", "[", "\"\<Flatten\>\"", "]"}], "[", "\"\<Diagram\>\"", 
  "]"}]], "Input",
 CellLabel->"In[8]:= ",ExpressionUUID->"b105bde0-53fa-4361-ac74-46ab709d4b5e"],

