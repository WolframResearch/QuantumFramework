Cell[TextData[{
 "Decompose the Toffoli gate. First define the gate ",
 Cell[BoxData[
  RowBox[{
   StyleBox["V", "TI"], "=", 
   SqrtBox[
    StyleBox["X", "TI"]]}]], "InlineFormula",ExpressionUUID->
  "95706dc2-6062-47a4-acbf-506fff51e215"],
 ":"
}], "ExampleText",ExpressionUUID->"95a116dd-99a8-4e2d-b2f1-4c0f40bf4594"],

Cell[BoxData[
 RowBox[{
  RowBox[{"v", " ", "=", " ", 
   RowBox[{"QuantumOperator", "[", 
    RowBox[{
     RowBox[{"MatrixPower", "[", 
      RowBox[{
       RowBox[{"PauliMatrix", "[", "1", "]"}], ",", " ", 
       RowBox[{"1", "/", "2"}]}], "]"}], ",", " ", 
     RowBox[{"\"\<Label\>\"", " ", "->", " ", "\"\<V\>\""}]}], "]"}]}], 
  ";"}]], "Input",
 CellLabel->"In[1]:= ",ExpressionUUID->"4e1fe4d8-1f45-480c-8664-484b37f2ee10"],

Cell[TextData[{
 "Build the decomposition from controlled-",
 Cell[BoxData[
  StyleBox["V", "TI"]], "InlineFormula",ExpressionUUID->
  "4cf152c0-d751-493d-a09d-dc55c491251a"],
 " gates and CNOTs:"
}], "ExampleText",ExpressionUUID->"8f02fd8b-681a-411b-849f-30e7e154efa3"],

Cell[BoxData[
 RowBox[{
  RowBox[{"qc", " ", "=", " ", 
   RowBox[{"QuantumCircuitOperator", "[", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"QuantumOperator", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"\"\<Controlled\>\"", ",", " ", "v"}], "}"}], ",", " ", 
        RowBox[{"{", 
         RowBox[{"2", ",", " ", "3"}], "}"}]}], "]"}], ",", "\n", "     ", 
      RowBox[{"QuantumOperator", "[", "\"\<CX\>\"", "]"}], ",", " ", "\n", 
      "    ", 
      RowBox[{"QuantumOperator", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"\"\<Controlled\>\"", ",", " ", 
          RowBox[{"v", "[", "\"\<Dagger\>\"", "]"}]}], "}"}], ",", " ", 
        RowBox[{"{", 
         RowBox[{"2", ",", " ", "3"}], "}"}]}], "]"}], ",", " ", "\n", "    ", 
      RowBox[{"QuantumOperator", "[", "\"\<CX\>\"", "]"}], ",", " ", 
      RowBox[{"QuantumOperator", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"\"\<Controlled\>\"", ",", " ", "v"}], "}"}], ",", " ", 
        RowBox[{"{", 
         RowBox[{"1", ",", " ", "3"}], "}"}]}], "]"}]}], "}"}], "]"}]}], 
  ";"}]], "Input",
 CellLabel->"In[2]:= ",ExpressionUUID->"29f029fd-8b4c-42e1-9c35-03bf21427bb9"],

