Cell["Define a sample superdense-coding circuit:", "ExampleText",ExpressionUUID->"9da19260-b835-4f7d-acae-ea17222da548"],

Cell[BoxData[
 RowBox[{
  RowBox[{"superdense", " ", "=", " ", "\n", "  ", 
   RowBox[{"QuantumCircuitOperator", "[", 
    RowBox[{"{", 
     RowBox[{"\"\<H\>\"", ",", " ", "\"\<CNOT\>\"", ",", " ", 
      RowBox[{"\"\<CX\>\"", " ", "->", " ", 
       RowBox[{"{", 
        RowBox[{"4", ",", " ", "1"}], "}"}]}], ",", " ", 
      RowBox[{"\"\<CZ\>\"", " ", "->", " ", 
       RowBox[{"{", 
        RowBox[{"3", ",", " ", "1"}], "}"}]}], ",", "\n", 
      "     ", "\"\<CNOT\>\"", ",", " ", "\"\<H\>\"", ",", " ", 
      RowBox[{"{", "1", "}"}], ",", " ", 
      RowBox[{"{", "2", "}"}]}], "}"}], "]"}]}], ";"}]], "Input",
 CellLabel->"In[2]:= ",ExpressionUUID->"9687b02d-f956-4636-9a03-8ca05133a0b6"],

Cell["Adjust the overall size of the circuit:", "ExampleText",ExpressionUUID->"fb360e18-5c9b-4898-a0ea-9b7afa656670"],

