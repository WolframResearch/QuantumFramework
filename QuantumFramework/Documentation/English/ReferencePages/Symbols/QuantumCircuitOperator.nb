Cell[TextData[{
 "Another way to store the solution of a Boolean function is to record it as \
a phase rather than on an ancillary qubit. This is achieved with a phase \
oracle, which adds an overall phase of ",
 Cell[BoxData[
 "\[Pi]"], "InlineFormula",ExpressionUUID->
  "3c0f4d1f-1007-45b5-b3ff-7ebfcf444cb0"],
 " when the input state is a solution of the Boolean function:"
}], "ExampleText",ExpressionUUID->"f00b78da-74d1-4e04-9595-9dc0b235cbef"],

Cell[BoxData[
 RowBox[{
  RowBox[{"po", " ", "=", " ", 
   RowBox[{"QuantumCircuitOperator", "[", 
    RowBox[{"\"\<PhaseOracle\>\"", "[", 
     RowBox[{"a", " ", "&&", " ", 
      RowBox[{"!", " ", "b"}]}], "]"}], "]"}]}], ";"}]], "Input",
 CellLabel->"In[7]:= ",ExpressionUUID->"58a7481f-2231-4def-b57d-b39365c86864"],

