 RowBox[{
  RowBox[{"decode", " ", "=", " ", 
   RowBox[{"QuantumCircuitOperator", "[", 
    RowBox[{"{", 
     RowBox[{"\"\<CNOT\>\"", " ", ",", " ", 
      RowBox[{"\"\<CNOT\>\"", " ", "->", " ", 
       RowBox[{"{", 
        RowBox[{"1", ",", " ", "3"}], "}"}]}], ",", " ", "\n", "    ", 
      RowBox[{
       RowBox[{"QuantumOperator", "[", "\"\<Toffoli\>\"", " ", "]"}], "->", 
       " ", 
       RowBox[{"{", 
        RowBox[{"2", ",", " ", "3", ",", " ", "1"}], "}"}]}]}], "}"}], 
    "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"decode", "[", "\"\<Diagram\>\"", "]"}]}], "Input",
