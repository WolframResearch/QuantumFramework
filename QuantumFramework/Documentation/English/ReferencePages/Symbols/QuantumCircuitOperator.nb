Cell["\<\
Show the connectors as dots, making explicit which wires a gate acts on:\
\>", "ExampleText",ExpressionUUID->"2034cb23-0276-4565-960d-ab7293efe3ed"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"QuantumCircuitOperator", "[", 
   RowBox[{"{", 
    RowBox[{"QuantumOperator", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"\"\<R\>\"", ",", " ", "\[Theta]", ",", " ", "\"\<XX\>\""}], 
       "}"}], ",", " ", 
      RowBox[{"{", 
       RowBox[{"1", ",", " ", "\n", "     ", "3"}], "}"}]}], "]"}], "}"}], 
   "]"}], "[", 
