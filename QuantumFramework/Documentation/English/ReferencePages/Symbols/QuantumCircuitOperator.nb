Cell[TextData[{
 "With the control prepared in ",
 Cell[BoxData[
  RowBox[{"|", "+", "\[RightAngleBracket]"}]], "InlineFormula",ExpressionUUID->
  "29b536df-588a-461e-89d7-62840ac3c0d7"],
 ", the switch outputs ",
 Cell[BoxData[
  RowBox[{
   FractionBox["1", 
    SqrtBox["2"]], "(", "|", "0", "\[RightAngleBracket]", 
   StyleBox[
    RowBox[{"B", "A"}], "TI"], "+", "|", "1", "\[RightAngleBracket]", 
   StyleBox[
    RowBox[{"A", "B"}], "TI"], ")", "|", 
   StyleBox["\[Psi]", "TI"], "\[RightAngleBracket]"}]], "InlineFormula",
  ExpressionUUID->"52b03772-3999-4fe2-a2a7-bd751b34bcbf"],
 ". Rotating the control back with a Hadamard and measuring it interferes the \
two orders: the control collapses to ",
 Cell[BoxData[
  RowBox[{"|", "0", "\[RightAngleBracket]"}]], "InlineFormula",ExpressionUUID->
  "10c066e0-0098-423e-b114-6995771674a8"],
 " when the operations commute (",
 Cell[BoxData[
  RowBox[{
   StyleBox["A", "TI"], 
   StyleBox["B", "TI"], "=", 
   StyleBox["B", "TI"], 
   StyleBox["A", "TI"]}]], "InlineFormula",ExpressionUUID->
  "2bbf2203-ac0c-4516-ab63-1981fa934701"],
 ") and to ",
 Cell[BoxData[
  RowBox[{"|", "1", "\[RightAngleBracket]"}]], "InlineFormula",ExpressionUUID->
  "0058d574-4b17-4a03-b40a-28eda7d197a0"],
 " when they anticommute (",
 Cell[BoxData[
  RowBox[{
   StyleBox["A", "TI"], 
   StyleBox["B", "TI"], "=", "-", 
   StyleBox["B", "TI"], 
   StyleBox["A", "TI"]}]], "InlineFormula",ExpressionUUID->
  "28043a18-c5a0-4fb6-87c4-9b0645051c74"],
 ")."
}], "ExampleText",ExpressionUUID->"8ec17d6a-f154-401b-96c3-fdb8b93f0103"],

Cell[TextData[{
 "We assemble the full single-query test, preparing the control in ",
 Cell[BoxData[
  RowBox[{"|", "+", "\[RightAngleBracket]"}]], "InlineFormula",ExpressionUUID->
  "28d42b2c-71a0-4dcd-afda-ce6da022c5c1"],
 ", applying the switch, rotating back, and measuring the control:"
}], "ExampleText",ExpressionUUID->"43ebd2bb-1607-4922-b5a8-d41cb17f9396"],

Cell[BoxData[
 RowBox[{
  RowBox[{"switchTest", "[", 
   RowBox[{"A_", ",", " ", "B_"}], "]"}], " ", ":=", " ", "\n", " ", 
  RowBox[{"QuantumCircuitOperator", "[", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"\"\<H\>\"", " ", "->", " ", "1"}], ",", " ", "\n", "   ", 
     RowBox[{"QuantumCircuitOperator", "[", 
      RowBox[{"\"\<Switch\>\"", "[", 
       RowBox[{"A", ",", " ", "B"}], "]"}], "]"}], ",", " ", 
     RowBox[{"\"\<H\>\"", " ", "->", " ", "1"}], ",", " ", 
     RowBox[{"{", "1", "}"}]}], "}"}], "]"}]}]], "Input",
 CellLabel->"In[2]:= ",ExpressionUUID->"b37a990d-0a0c-4285-9a5d-0db34c92ef09"],

Cell["\<\
Two operators that commute (here X with itself) send the control to 0 with \
certainty:\
\>", "ExampleText",ExpressionUUID->"f41f942e-194a-41bf-a858-9031a194a184"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"switchTest", "[", 
    RowBox[{
     RowBox[{"QuantumOperator", "[", "\"\<X\>\"", "]"}], ",", " ", 
     RowBox[{"QuantumOperator", "[", "\"\<X\>\"", "]"}]}], "]"}], "[", "]"}], 
  "[", "\"\<Probabilities\>\"", "]"}]], "Input",
 CellLabel->"In[3]:= ",ExpressionUUID->"01bfe12d-8019-4bf7-a6e2-b0272c396987"],

Cell[BoxData[
 RowBox[{"\[LeftAssociation]", 
  RowBox[{
   RowBox[{
    InterpretationBox[
     StyleBox[
      TemplateBox[{
        RowBox[{"0"}]},
       "Ket"],
      FontWeight->"Plain"],
     Wolfram`QuantumFramework`QuditName[0, "Dual" -> False]], "\[Rule]", 
    "1"}], ",", 
   RowBox[{
    InterpretationBox[
     StyleBox[
      TemplateBox[{
        RowBox[{"1"}]},
       "Ket"],
      FontWeight->"Plain"],
     Wolfram`QuantumFramework`QuditName[1, "Dual" -> False]], "\[Rule]", 
    "0"}]}], "\[RightAssociation]"}]], "Output",
 CellLabel->"Out[3]= ",ExpressionUUID->"d6213248-848d-4feb-adde-c81afa3c1285"]
}, Open  ]],

Cell["Two that anticommute (X and Z) send it to 1 with certainty:", \
"ExampleText",ExpressionUUID->"93ced2f3-1599-4785-9e1f-32d4b976ccbe"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"switchTest", "[", 
    RowBox[{
     RowBox[{"QuantumOperator", "[", "\"\<X\>\"", "]"}], ",", " ", 
     RowBox[{"QuantumOperator", "[", "\"\<Z\>\"", "]"}]}], "]"}], "[", "]"}], 
  "[", "\"\<Probabilities\>\"", "]"}]], "Input",
 CellLabel->"In[4]:= ",ExpressionUUID->"8832c829-2afd-489c-a5ff-ce673ce4eb25"],

Cell[BoxData[
 RowBox[{"\[LeftAssociation]", 
  RowBox[{
   RowBox[{
    InterpretationBox[
     StyleBox[
      TemplateBox[{
        RowBox[{"0"}]},
       "Ket"],
      FontWeight->"Plain"],
     Wolfram`QuantumFramework`QuditName[0, "Dual" -> False]], "\[Rule]", 
    "0"}], ",", 
   RowBox[{
    InterpretationBox[
     StyleBox[
      TemplateBox[{
        RowBox[{"1"}]},
       "Ket"],
      FontWeight->"Plain"],
     Wolfram`QuantumFramework`QuditName[1, "Dual" -> False]], "\[Rule]", 
    "1"}]}], "\[RightAssociation]"}]], "Output",
 CellLabel->"Out[4]= ",ExpressionUUID->"f303ca0d-8c5b-4b70-b20f-04f69ded77c8"]
}, Open  ]],

Cell[TextData[{
 "Each run uses ",
 Cell[BoxData[
  StyleBox["A", "TI"]], "InlineFormula",ExpressionUUID->
  "a4933ff9-4559-4b8a-a939-f9ab9ee397da"],
 " and ",
 Cell[BoxData[
  StyleBox["B", "TI"]], "InlineFormula",ExpressionUUID->
  "cc021329-86e5-460b-af78-41e4d73932a7"],
 " exactly once, yet decides commutation versus anticommutation \
deterministically. No fixed-order circuit can do this with a single use of \
each operation: the single-query discrimination is a genuine signature of \
indefinite causal order."
}], "ExampleText",ExpressionUUID->"98ff42ef-8409-488a-858f-0d64a1700d41"],

Cell["\<\
When the operations neither commute nor anticommute (X and H), the control \
emerges maximally mixed, reflecting the intermediate algebra:\
\>", "ExampleText",ExpressionUUID->"87f76936-9448-4049-b280-a87277bf3d1f"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"switchTest", "[", 
    RowBox[{
     RowBox[{"QuantumOperator", "[", "\"\<X\>\"", "]"}], ",", " ", 
     RowBox[{"QuantumOperator", "[", "\"\<H\>\"", "]"}]}], "]"}], "[", "]"}], 
  "[", "\"\<Probabilities\>\"", "]"}]], "Input",
 CellLabel->"In[5]:= ",ExpressionUUID->"445cab1b-4c75-4e2f-b9d7-0bdacdb810a7"],

