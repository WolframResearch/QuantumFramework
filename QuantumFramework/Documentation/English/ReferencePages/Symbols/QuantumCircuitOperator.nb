Cell["Calculate the probability of winning:", "ExampleText",ExpressionUUID->"2b6bf528-5af3-4111-8bce-bedb489c58c1"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"NProbability", "[", "\n", " ", 
  RowBox[{
   RowBox[{
    RowBox[{"BitAnd", "[", 
     RowBox[{"x", ",", " ", "y"}], "]"}], " ", "==", " ", 
    RowBox[{"BitXor", "[", 
     RowBox[{"a", ",", " ", "b"}], "]"}]}], ",", " ", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"a", ",", " ", "x", ",", " ", "y", ",", " ", "b"}], "}"}], " ", "\[Distributed]",
     " ", "\n", "  ", 
    RowBox[{
     RowBox[{
      RowBox[{"QuantumCircuitOperator", "[", "\"\<CHSH\>\"", "]"}], "[", 
      "]"}], "[", "\"\<MultivariateDistribution\>\"", "]"}]}]}], 
  "]"}]], "Input",
 CellLabel->"In[2]:= ",ExpressionUUID->"3001d01f-fb18-48f8-a6e8-1960822fb100"],

Cell[BoxData["0.853553390593274`"], "Output",
 CellLabel->"Out[2]= ",ExpressionUUID->"6658574d-5168-4621-8c35-62fece21df73"]
}, Open  ]],

Cell["Trotter-Suzuki", "ExampleSubsubsection",ExpressionUUID->"d47e70b8-3aa7-4de1-8441-97c76634a23b"],

Cell["\<\
One can build a Trotter-Suzuki decomposition to approximate a time evolution.\
\
\>", "ExampleText",ExpressionUUID->"bcc6db66-0760-4304-89ea-9a22ca481548"],

Cell["First-order decomposition, one step:", "ExampleText",ExpressionUUID->"093dacc6-af7f-47eb-a2f2-804d3d7ac373"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"QuantumCircuitOperator", "[", 
   RowBox[{"{", 
    RowBox[{"\"\<Trotterization\>\"", ",", " ", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"QuantumOperator", "[", 
        RowBox[{"\"\<X\>\"", ",", " ", 
         RowBox[{"{", 
          RowBox[{"1", ",", " ", "2"}], "}"}]}], "]"}], ",", " ", "\n", 
       "    ", 
       RowBox[{"QuantumOperator", "[", 
        RowBox[{"\"\<X\>\"", ",", " ", 
         RowBox[{"{", 
          RowBox[{"2", ",", " ", "3"}], "}"}]}], "]"}]}], "}"}], ",", " ", 
     "1", ",", " ", "1", ",", " ", "1"}], "}"}], "]"}], "[", "\"\<Diagram\>\"",
   "]"}]], "Input",
 CellLabel->"In[1]:= ",ExpressionUUID->"78cea338-fc4a-4882-9789-6947a56bd5c4"],

