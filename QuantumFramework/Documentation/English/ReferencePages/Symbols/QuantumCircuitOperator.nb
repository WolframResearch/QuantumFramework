     ExpressionUUID->"9bac26f0-ef59-4574-8209-14c3e9ad3cff"]], "TableText",
     ExpressionUUID->"64bc43cf-3c6e-44e4-84db-ce5396667b60"], Cell["\<\
graph-state preparation circuit for a graph g (Hadamard on each vertex, then \
an entangling gate along each edge)\
\>", "TableText",ExpressionUUID->"2831a75c-b5fd-4b03-ba9b-c1d65e164a77"]},
   {Cell["      ", "ModInfo",ExpressionUUID->
     "2b2747a3-b553-4365-b8be-1cc5524be374"], Cell[TextData[{
