 CellLabel->"Out[9]= ",ExpressionUUID->"2a870afb-85bd-431f-9c52-bf3c5dca07fb"]
}, Open  ]],

Cell["Find the null space of that matrix modulo 2:", "ExampleText",ExpressionUUID->"459da510-9418-4840-afb4-ed8de3abada7"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"NullSpace", "[", 
  RowBox[{"m", ",", " ", 
   RowBox[{"Modulus", " ", "->", " ", "2"}]}], "]"}]], "Input",
 CellLabel->
  "In[10]:= ",ExpressionUUID->"737aa952-12c6-4265-8cf3-51ce7eadaa20"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"{", 
   RowBox[{"1", ",", "0", ",", "0", ",", "1"}], "}"}], "}"}]], "Output",
 CellLabel->
  "Out[10]= ",ExpressionUUID->"e1077063-808b-403b-9389-be5576c4c83f"]
}, Open  ]],

Cell["The recovered null vector matches the secret bit-string:", "ExampleText",ExpressionUUID->"6ff7e781-e561-4395-969b-cea185c1fe1b"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"seq", " ", "==", " ", 
  RowBox[{
   RowBox[{"NullSpace", "[", 
    RowBox[{"m", ",", " ", 
     RowBox[{"Modulus", " ", "->", " ", "2"}]}], "]"}], "[", 
   RowBox[{"[", "1", "]"}], "]"}]}]], "Input",
 CellLabel->
  "In[11]:= ",ExpressionUUID->"47bad044-f54a-4efc-b11d-0e64b441c6c2"],

Cell[BoxData["True"], "Output",
 CellLabel->
  "Out[11]= ",ExpressionUUID->"5d732ac8-8da3-4819-a521-2fdc0b7c09ab"]
}, Open  ]],

Cell["\<\
The Simon circuit and its Boolean function are not uniquely determined: each \
evaluation yields a different oracle that still solves the Simon problem. \
Build a second one for the same secret:\
\>", "ExampleText",ExpressionUUID->"af67c2e0-c7b1-46a6-ad5d-d66478087a9e"],

Cell[BoxData[
 RowBox[{
  RowBox[{"simon2", " ", "=", " ", 
   RowBox[{"QuantumCircuitOperator", "[", 
    RowBox[{"\"\<Simon\>\"", "[", "seq", "]"}], "]"}]}], ";"}]], "Input",
 CellLabel->
  "In[12]:= ",ExpressionUUID->"21ffa948-2c91-4ced-bd2f-49872458533d"],

Cell["It differs from the first circuit:", "ExampleText",ExpressionUUID->"8566d6e5-8d3a-4010-8f4b-261893c3de7f"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"simon", " ", "==", " ", "simon2"}]], "Input",
 CellLabel->
  "In[13]:= ",ExpressionUUID->"dc5df5bd-b74b-4f50-89e6-8fd31cdfe75c"],

Cell[BoxData["False"], "Output",
 CellLabel->
  "Out[13]= ",ExpressionUUID->"f5a44466-fe66-4dde-ad3c-ef103b4159bf"]
}, Open  ]],

Cell["\<\
With the new circuit, one can still recover the hidden sequence:\
\>", "ExampleText",ExpressionUUID->"64b2332c-2b0f-4678-8382-881c1cba4a4a"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"NullSpace", "[", 
    RowBox[{
     RowBox[{"Normal", " ", "/@", " ", 
      RowBox[{"Keys", "@", 
       RowBox[{"Select", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"simon2", "[", "]"}], "[", "\"\<Probabilities\>\"", "]"}], ",",
          " ", "Positive"}], "]"}]}]}], ",", " ", "\n", "   ", 
     RowBox[{"Modulus", " ", "->", " ", "2"}]}], "]"}], "[", 
   RowBox[{"[", "1", "]"}], "]"}], " ", "==", " ", "seq"}]], "Input",
 CellLabel->
  "In[14]:= ",ExpressionUUID->"5ba3293c-16ac-4629-adfa-7300f1065ac8"],

Cell[BoxData["True"], "Output",
 CellLabel->
  "Out[14]= ",ExpressionUUID->"a9b7a49b-8f6b-445b-adfb-cba01483366c"]
}, Open  ]],

Cell["GrayOracle", "ExampleSubsubsection",ExpressionUUID->"307f83d6-e6e2-4a76-b99a-b9d400e8c928"],

Cell[TextData[{
 "It takes a list of angles or a function, number of ancillary qubits and \
target qubit, to generate the corresponding oracle based on ",
 ButtonBox["Gray code",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://arxiv.org/pdf/quant-ph/0404089.pdf"], None}],
 "."
}], "ExampleText",ExpressionUUID->"f10e78fd-3fba-48f8-a79d-d354d36c709f"],

Cell["\<\
Given 4-qubits as ancillary, generate angles for all possible bit-strings, \
and prepend zero angle, too:\
\>", "ExampleText",ExpressionUUID->"cfa78591-90c4-49fd-9353-bd4ec6d84561"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"prec", " ", "=", " ", "4"}], ";"}], "\n", 
 RowBox[{
  RowBox[{"angles", " ", "=", " ", "\n", "  ", 
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{"1", "/", 
         RowBox[{"2", "^", "prec"}]}], " ", 
        RowBox[{"1", "/", 
         RowBox[{"FromDigits", "[", 
          RowBox[{"#", ",", " ", "2"}], "]"}]}]}], " ", "&"}], " ", "/@", " ", 
      RowBox[{"Rest", "@", 
       RowBox[{"Tuples", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"0", ",", " ", "1"}], "}"}], ",", " ", "prec"}], "]"}]}]}], 
     " ", "//", " ", "N"}], " ", "//", " ", "\n", "   ", 
    RowBox[{"Prepend", "[", "0", "]"}]}]}], ";"}]}], "Input",
 CellLabel->"In[1]:= ",ExpressionUUID->"cfeff74c-f910-4449-9ea9-5e40828aa307"],

Cell["Generate the corresponding GrayOracle:", "ExampleText",ExpressionUUID->"bac55426-4f0e-47a0-a7e6-4277aa8016cb"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"QuantumCircuitOperator", "[", 
   RowBox[{"\"\<GrayOracle\>\"", "[", 
    RowBox[{"angles", ",", " ", "prec", ",", " ", "1"}], "]"}], "]"}], "[", 
  RowBox[{"\"\<Diagram\>\"", ",", " ", "\n", " ", 
   RowBox[{"\"\<ShowGateLabels\>\"", " ", "->", " ", "False"}]}], 
  "]"}]], "Input",
 CellLabel->"In[2]:= ",ExpressionUUID->"dab851aa-d5cb-44e6-bd5b-cadff894ffbc"],

