     "793d8602-daf1-4134-8224-65e793d6e153"]], "TableText",ExpressionUUID->
     "82351664-0b75-483a-90b6-aba501e542c2"], Cell[
    "the list of parameters of a parametrized circuit", "TableText",
     ExpressionUUID->"a0267e9a-eb4c-4717-8a0f-968efbd6acc8"]},
   {Cell["      ", "ModInfo",ExpressionUUID->
     "fcd678be-7c3f-4d86-900c-8e1c43eafc78"], Cell[TextData[Cell[
    BoxData["\"\<ParameterArity\>\""], "InlineFormula",ExpressionUUID->
     "67e67a49-09c2-412f-a240-73b6512a029d"]], "TableText",ExpressionUUID->
     "34b47652-db12-4e25-88b2-4ab3aba43023"], Cell[
    "the number of parameters of the circuit", "TableText",ExpressionUUID->
     "82feb034-55b5-48d3-bb41-a33c31f6c737"]},
   {Cell["      ", "ModInfo",ExpressionUUID->
     "6f8e8637-d034-46a4-824c-8ec9fe61ff5b"], Cell[TextData[Cell[
    BoxData["\"\<Properties\>\""], "InlineFormula",ExpressionUUID->
     "812a130c-38d5-40f3-a592-4ef99df0c941"]], "TableText",ExpressionUUID->
     "af2b7d47-2e50-45cd-9e34-50ffc004db8f"], Cell[
    "the list of supported properties", "TableText",ExpressionUUID->
     "5de5565c-e34d-4efc-a102-ad85fe1957bc"]},
   {Cell["      ", "ModInfo",ExpressionUUID->
     "93504190-0b47-4307-b84c-00aecb886c0b"], Cell[TextData[Cell[
    BoxData["\"\<Diagram\>\""], "InlineFormula",ExpressionUUID->
     "ebbe67a2-4a4b-40b4-a75f-f2ce0e73d78d"]], "TableText",ExpressionUUID->
     "465339d6-590a-4e37-a472-ed15f810cfb3"], Cell[
    "the diagram of the quantum circuit", "TableText",ExpressionUUID->
     "f9aed8b6-6723-4bfe-9c42-fbacfa0c1e77"]},
   {Cell["      ", "ModInfo",ExpressionUUID->
     "85dcba56-562b-40d0-bf19-784dec9627e3"], Cell[TextData[Cell[
    BoxData["\"\<Topology\>\""], "InlineFormula",ExpressionUUID->
     "b31b2433-da07-438c-bf5c-010f08ac976b"]], "TableText",ExpressionUUID->
     "fc566d66-a4ad-4989-9247-f2d2d3545667"], Cell["\<\
the circuit topology graph, with qudits/wires as vertices and gates as edges\
\>", "TableText",ExpressionUUID->"292d839e-60ab-4365-bbdc-0c824bccf585"]},
   {Cell["      ", "ModInfo",ExpressionUUID->
     "678557ed-4e73-432b-a261-5e724d0dca88"], Cell[TextData[Cell[
    BoxData["\"\<TensorNetwork\>\""], "InlineFormula",ExpressionUUID->
     "85d29388-3775-47dc-8b6b-ac3df5fd990a"]], "TableText",ExpressionUUID->
     "01d3bbe4-bb0c-4f84-b60d-d12e0701a4b1"], Cell[
    "the corresponding tensor network representing the circuit", "TableText",
     ExpressionUUID->"7dba3cd5-9b50-4bad-9ce4-47a73965542b"]},
   {Cell["      ", "ModInfo",ExpressionUUID->
     "4748d4a9-6500-460f-a8cf-8dafcb7b1806"], Cell[TextData[Cell[
    BoxData["\"\<TensorNetworkGraph\>\""], "InlineFormula",ExpressionUUID->
     "8a850225-daf6-40ea-9488-7a3a23472aaf"]], "TableText",ExpressionUUID->
     "9cc475dd-c92a-491e-9c28-d87ea8ec1030"], Cell[
    "the graph of the circuit's tensor network", "TableText",ExpressionUUID->
     "50d54099-5ff6-416a-b607-7a665cf4bac8"]},
   {Cell["      ", "ModInfo",ExpressionUUID->
     "f94767ff-f17b-4384-9e22-43e6466145b9"], Cell[TextData[Cell[
    BoxData["\"\<QASM\>\""], "InlineFormula",ExpressionUUID->
     "0bea9bd3-3708-41b7-9ad3-fbc7c2540a09"]], "TableText",ExpressionUUID->
     "36ed46e5-ccb3-419f-a449-44fedd761118"], Cell[
    "the circuit in OpenQASM 3.0", "TableText",ExpressionUUID->
     "f6715392-53de-48d8-a1b9-e61ca14928a1"]},
   {Cell["      ", "ModInfo",ExpressionUUID->
     "40776321-3220-45c0-a25c-f2c54fe45502"], Cell[TextData[{
     Cell[
     BoxData["\"\<QiskitCircuit\>\""], "InlineFormula",ExpressionUUID->
      "069daf4d-2c49-42c8-95c8-4e4e3e06adb1"],
     " or ",
     Cell[
     BoxData["\"\<Qiskit\>\""], "InlineFormula",ExpressionUUID->
      "7c734b49-5243-429e-af95-bc2b1ee2ce53"]
    }], "TableText",ExpressionUUID->"d9c18eb1-81d1-436b-a4dc-66e4dc159c0d"], 
    Cell["\<\
the corresponding circuit in Qiskit (note you need Python as external \
evaluator for this property)\
\>", "TableText",ExpressionUUID->"e0f9aff3-70e6-4af0-8cde-6fe77eb9aba7"]},
   {Cell["      ", "ModInfo",ExpressionUUID->
     "c835bbb5-6e20-405b-9b95-683bf54e407c"], Cell[TextData[{
     Cell[
     BoxData["\"\<Shift\>\""], "InlineFormula",ExpressionUUID->
      "85794c51-a133-4bb2-9120-b7c620fae687"],
     ",",
     StyleBox["n", "TI"]
    }], "TableText",ExpressionUUID->"a95dae6f-fcb4-489f-b138-7e966c695030"], 
    Cell[TextData[{
     "shift the order of the circuit (the qudits it acts on) by ",
     StyleBox["n", "TI"]
    }], "TableText",ExpressionUUID->"33407b74-8264-4fbb-ac2e-f596fb624d4a"]}
  }]], "2ColumnTableMod",ExpressionUUID->"725508ea-3c32-4149-aa1e-\
2955b0141c99"],

Cell[TextData[{
 "There are many named-circuits, ",
 Cell[BoxData[
  RowBox[{"QuantumCircuitOperator", "[", 
   RowBox[{"{", 
    RowBox[{"\"\<\!\(\*StyleBox[\"circuitname\", \"TI\"]\)\>\"", ",", "..."}],
     "}"}], "]"}]], "InlineFormula",ExpressionUUID->
  "04133619-99f7-4edd-8123-e539fbcfa597"],
 ", for example, Bell, Toffoli, Grover (and its many oracles), quantum phase \
estimation, quantum fourier transform, Bernstein-Vazirani algorithm (and its \
many oracles), Graph and etc."
}], "Notes",ExpressionUUID->"be64f2ab-5315-495a-b0e4-f31d47dd5fec"],

Cell[BoxData[GridBox[{
   {Cell["      ", "ModInfo",ExpressionUUID->
     "3a4f10ce-e727-45b9-beaa-40bcffe29a6d"], Cell["", "TableText",
     FontWeight->Bold,ExpressionUUID->"3fc026de-d93a-4fa0-8de9-698cbe01a95a"],
     Cell["", "TableText",
     FontWeight->Bold,ExpressionUUID->"fa953c4b-e920-49c3-be26-3a3d4a0a02b9"]},
   {Cell["      ", "ModInfo",ExpressionUUID->
     "5d1c7e54-546d-4253-8721-9795f5ca980a"], Cell[TextData[Cell[
    BoxData["\"\<Bell\>\""], "InlineFormula",ExpressionUUID->
     "91723735-c449-4971-a91b-ca875155a733"]], "TableText",ExpressionUUID->
     "f626d3b0-b202-415c-b0a9-2f1fab2f3284"], Cell["\<\
Bell-state preparation circuit ({H, CNOT}); prepares a Bell pair from the \
all-zeros state\
\>", "TableText",ExpressionUUID->"cb9635f7-7229-466f-93d5-7651777dedf3"]},
   {Cell["      ", "ModInfo",ExpressionUUID->
     "523100f2-d488-4b01-8379-ff9bb52d2649"], Cell[TextData[Cell[BoxData[
     RowBox[{"\"\<GHZ\>\"", "[", "n", "]"}]], "InlineFormula",ExpressionUUID->
     "d24bf698-b890-4955-a708-12845edf1def"]], "TableText",ExpressionUUID->
     "aa962bab-9fd6-4bb7-9dce-0a4cbedab950"], Cell["\<\
preparation circuit for the n-qubit GHZ state (H, then a CNOT chain)\
\>", "TableText",ExpressionUUID->"b9293316-622c-4ef5-9851-66c9cace0455"]},
   {Cell["      ", "ModInfo",ExpressionUUID->
     "5269a539-4596-4f83-96c9-0d617335f618"], Cell[TextData[Cell[BoxData[
     RowBox[{"\"\<Graph\>\"", "[", "g", "]"}]], "InlineFormula",
     ExpressionUUID->"cbea4f16-5315-4b3e-8c3e-2b33f82d88b1"]], "TableText",
     ExpressionUUID->"a399c3f9-f076-4e6b-b871-6b6863c9c67b"], Cell["\<\
graph-state preparation circuit for a graph g (Hadamard on each vertex, then \
an entangling gate along each edge)\
\>", "TableText",ExpressionUUID->"71cc6116-faba-42d0-9ea8-91d59abfd2a4"]},
   {Cell["      ", "ModInfo",ExpressionUUID->
     "6de1dfe6-09a7-4131-8703-1ef37393cc4e"], Cell[TextData[{
     Cell[BoxData[
      RowBox[{"\"\<QuantumState\>\"", "[", "qs", "]"}]], "InlineFormula",
      ExpressionUUID->"144e837c-3c86-4db2-b404-5ec9672b72ca"],
     " or ",
     Cell[BoxData[
      RowBox[{"\"\<StatePreparation\>\"", "[", "qs", "]"}]], "InlineFormula",
