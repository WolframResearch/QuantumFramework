Cell["\<\
Quantum circuits consisting of qudit gates are supported. Define a qudit gate \
of dimensionality 3:\
\>", "ExampleText",ExpressionUUID->"78764b76-e3f3-4325-830f-940f4190fcd9"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"QuantumCircuitOperator", "[", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"\"\<RandomUnitary\>\"", "[", "3", "]"}], ",", " ", "\n", "   ", 
     
     RowBox[{
      RowBox[{"\"\<Spider\>\"", "[", 
       RowBox[{"QuantumBasis", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"3", ",", " ", "2"}], "}"}], ",", " ", 
         RowBox[{"{", 
          RowBox[{"3", ",", " ", "2"}], "}"}]}], "]"}], "]"}], " ", "->", " ", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"1", ",", " ", "2"}], "}"}], " ", "->", " ", 
       RowBox[{"{", 
        RowBox[{"2", ",", " ", "\n", "      ", "1"}], "}"}]}]}]}], "}"}], 
   "]"}], "[", 
  RowBox[{"\"\<Diagram\>\"", ",", " ", 
   RowBox[{"\"\<ShowWireDimensions\>\"", " ", "->", " ", "True"}]}], 
  "]"}]], "Input",
 CellLabel->"In[1]:= ",ExpressionUUID->"2008c877-ce89-4a60-be35-8a2bd356981a"],

