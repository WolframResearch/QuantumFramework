Cell["Maximize the objective function classically:", "ExampleText",ExpressionUUID->"426af609-931e-4fa7-a0da-7a416961bb24"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"solMax", " ", "=", " ", "\n", " ", 
  RowBox[{"NArgMax", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{"x", " ", ".", " ", "q", " ", ".", " ", "x"}], ",", " ", 
      RowBox[{"0", " ", "\[VectorLess]", " ", 
       RowBox[{"x", "^", "2"}], " ", "\[VectorLessEqual]", " ", "1"}]}], 
     "}"}], ",", " ", "\n", "  ", 
    RowBox[{"x", " ", "\[Element]", " ", 
     RowBox[{"Vectors", "[", 
      RowBox[{
       RowBox[{"Length", "[", "q", "]"}], ",", " ", "Integers"}], "]"}]}]}], 
   "]"}]}]], "Input",
 CellLabel->"In[4]:= ",ExpressionUUID->"a7bc1b23-8941-444f-aba9-9c39f9666488"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{"-", "1"}], ",", "1", ",", "1", ",", 
   RowBox[{"-", "1"}]}], "}"}]], "Output",
 CellLabel->"Out[4]= ",ExpressionUUID->"5707fa3c-a900-4374-a4c0-7ec657b57048"]
}, Open  ]],

