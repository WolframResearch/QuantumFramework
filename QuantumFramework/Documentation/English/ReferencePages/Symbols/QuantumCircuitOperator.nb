Cell["\<\
Compare the classical result with the quantum one (using the inner product as \
a measure; the closer to one, the better):\
\>", "ExampleText",ExpressionUUID->"df7cdaf1-1bdd-46ec-9ff5-249bd206e719"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"Abs", "[", 
   RowBox[{
    RowBox[{"Conjugate", "[", "xClassical", "]"}], " ", ".", " ", "xHHL"}], 
   "]"}], "^", "2"}]], "Input",
 CellLabel->
  "In[10]:= ",ExpressionUUID->"4a9bdec8-d18f-477d-bfc9-20da06d53b58"],

Cell[BoxData["0.99646972501801`"], "Output",
 CellLabel->
  "Out[10]= ",ExpressionUUID->"d868beb9-1b69-4e8b-923b-5686f3c1d66a"]
}, Open  ]],

Cell["\<\
The number of phase-estimation qubits (the 3rd argument) determines the \
precision of the final outcome. Execute HHL with fewer phase-estimation \
qubits:\
\>", "ExampleText",ExpressionUUID->"fd9a6466-7940-4cd0-b6e0-cfb3ae1e7777"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"xHHLLowPrecision", " ", "=", " ", "\n", " ", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{"N", "[", 
       RowBox[{"HHL", "[", 
        RowBox[{"a", ",", " ", "b", ",", " ", "3"}], "]"}], "]"}], "[", "]"}],
      "[", "\"\<Normalize\>\"", "]"}], "[", "\"\<AmplitudesList\>\"", "]"}], 
   " ", "//", " ", "Chop"}]}]], "Input",
 CellLabel->
  "In[11]:= ",ExpressionUUID->"8e8c9993-bd2d-417f-ba53-de64d0c3a115"],

