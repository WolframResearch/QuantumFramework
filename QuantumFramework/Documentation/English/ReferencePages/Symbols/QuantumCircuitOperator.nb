Cell["\<\
Read off the most probable measurement outcome as a bit-string:\
\>", "ExampleText",ExpressionUUID->"0d1e8b74-4b3b-4630-9a39-ca32b6b84090"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"bits2", " ", "=", " ", 
  RowBox[{
   RowBox[{
    RowBox[{"Keys", "[", 
     RowBox[{"TakeLargest", "[", 
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{"N", "[", "qc2", "]"}], "[", "]"}], 
        "[", "\"\<Probabilities\>\"", "]"}], ",", " ", "1"}], "]"}], "]"}], "[", 
    RowBox[{"[", "1", "]"}], "]"}], "[", "\"\<Name\>\"", "]"}]}]], "Input",
 CellLabel->
  "In[10]:= ",ExpressionUUID->"0cd88538-7d25-480e-b197-31c621b790a9"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"0", ",", "0", ",", "1", ",", "1"}], "}"}]], "Output",
 CellLabel->
  "Out[10]= ",ExpressionUUID->"59d6efd2-2442-427b-b324-3ed5890af45e"]
}, Open  ]],

Cell["Convert that bit-string into the estimated eigenvalue:", "ExampleText",ExpressionUUID->"77b3cfbc-ba8d-4d4d-b669-c91fbab17e20"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"est2", " ", "=", " ", 
  RowBox[{
   RowBox[{
    RowBox[{"FromDigits", "[", 
     RowBox[{"bits2", ",", " ", "2"}], "]"}], "/", 
    RowBox[{"2", "^", "4"}]}], " ", "//", " ", "N"}]}]], "Input",
 CellLabel->
