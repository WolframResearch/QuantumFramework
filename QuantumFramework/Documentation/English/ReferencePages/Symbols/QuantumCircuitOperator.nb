Notebook[{

Cell[CellGroupData[{
Cell["QuantumCircuitOperator", "ObjectName",
 CellID->1224892054,ExpressionUUID->"8393d601-4014-44ba-afc9-60862df940ec"],

Cell[TextData[{
 Cell["   ", "ModInfo",ExpressionUUID->"6b27ab53-38b0-4d0c-8668-94900d1ab7a5"],
 Cell[BoxData[
  RowBox[{"QuantumCircuitOperator", "[", 
   RowBox[{"{", 
    RowBox[{
     SubscriptBox[
      StyleBox["obj", "TI"], 
      StyleBox["1", "TR"]], ",", 
     SubscriptBox[
      StyleBox["obj", "TI"], 
      StyleBox["2", "TR"]], ",", 
     SubscriptBox[
      StyleBox["obj", "TI"], 
      StyleBox["3", "TR"]], ",", "..."}], "}"}], "]"}]], "InlineFormula",
  ExpressionUUID->"f73e81dd-46bc-4a70-8764-eac460360c05"],
 " ",
 "represents a quantum circuit with a list of quantum objects ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["obj", "TI"], 
   StyleBox["i", "TI"]]], "InlineFormula",ExpressionUUID->
  "11fca6d4-18f6-49a3-89a6-9d219091b37d"],
 ", e.g., quantum operator, quantum channel, quantum state or quantum \
measurement operators.",
 "\n",
 Cell["   ", "ModInfo",ExpressionUUID->"52296e44-0fbd-4a29-861c-66807898b181"],
 Cell[BoxData[
  RowBox[{"QuantumCircuitOperator", "[", 
   StyleBox["obj", "TI"], "]"}]], "InlineFormula",ExpressionUUID->
  "1d9f106a-cd9d-4459-b15e-01e5e3e65894"],
 " ",
 "wraps a single quantum object (operator, channel, state or measurement \
operator) as a one-element circuit.",
 "\n",
 Cell["   ", "ModInfo",ExpressionUUID->"417f9409-fb78-418f-a1c7-212cb40cb51e"],
 Cell[BoxData[
  RowBox[{"QuantumCircuitOperator", "[", 
   RowBox[{
    StyleBox["obj", "TI"], " ", "->", " ", 
    StyleBox["order", "TI"]}], "]"}]], "InlineFormula",ExpressionUUID->
  "08a66457-6617-4d74-9794-bba9db261f79"],
 " ",
 "places ",
 StyleBox["obj", "TI"],
 " on the qudit positions given by ",
 StyleBox["order", "TI"],
 ".",
 "\n",
 Cell["   ", "ModInfo",ExpressionUUID->"c67f9878-0c85-4558-a0d2-cca1886fb113"],
 Cell[BoxData[
  RowBox[{
  "QuantumCircuitOperator", "[", "\"\<\!\(\*StyleBox[\"name\", \"TI\"]\)\>\"",
    "]"}]], "InlineFormula",ExpressionUUID->
  "d2d9a062-7dd6-4ea4-a4f9-ca4f13a75e95"],
 " ",
 "or ",
 Cell[BoxData[
  RowBox[{"QuantumCircuitOperator", "[", 
   RowBox[{"\"\<\!\(\*StyleBox[\"name\", \"TI\"]\)\>\"", "[", 
    StyleBox["args", "TI"], "]"}], "]"}]], "InlineFormula",ExpressionUUID->
  "73d5238b-931f-4748-839a-2864aaa3f1c3"],
 " gives a named circuit, such as ",
 Cell[BoxData["\"\<Bell\>\""], "InlineFormula",ExpressionUUID->
  "bdf14661-dd44-472b-849a-11f84e7f2028"],
 ", ",
 Cell[BoxData["\"\<Toffoli\>\""], "InlineFormula",ExpressionUUID->
  "96b3f6d2-2198-41e2-839d-f22eaecdeee3"],
 " or ",
 Cell[BoxData[
  RowBox[{"\"\<Grover\>\"", "[", "f", "]"}]], "InlineFormula",ExpressionUUID->
  "7a8fd700-2b04-4fe6-87d6-d84a88a0f747"],
 ".",
 "\n",
 Cell["   ", "ModInfo",ExpressionUUID->"d00f0a37-dee0-4709-8d11-e1513e1bb480"],
 Cell[BoxData[
  RowBox[{"QuantumCircuitOperator", "[", 
   StyleBox["qs", "TI"], "]"}]], "InlineFormula",ExpressionUUID->
  "fe210cbd-b6f0-4897-97e9-bf0a1ff29856"],
 " ",
 "gives a circuit that prepares the quantum state ",
 StyleBox["qs", "TI"],
 ".",
 "\n",
 Cell["   ", "ModInfo",ExpressionUUID->"5bd048c8-d101-4dd0-aa75-634b150a44f1"],
 Cell[BoxData[
  RowBox[{
  "QuantumCircuitOperator", 
   "[", "\"\<\!\(\*StyleBox[\"string\", \"TI\"]\)\>\"", "]"}]], 
  "InlineFormula",ExpressionUUID->"703bcbab-02f7-47e8-a187-7acfcc706301"],
 " ",
 "gives a tensor-product gate from a string of single-qubit gate letters, \
such as ",
 Cell[BoxData["\"\<IXYZ\>\""], "InlineFormula",ExpressionUUID->
  "23622a83-52aa-42de-b52c-eca9c498feeb"],
 ".",
 "\n",
 Cell["   ", "ModInfo",ExpressionUUID->"2efa0bb9-db03-4966-a342-9ccf5d91e02f"],
 Cell[BoxData[
  RowBox[{"QuantumCircuitOperator", "[", 
   StyleBox["qasm", "TI"], "]"}]], "InlineFormula",ExpressionUUID->
  "7602e31b-35a6-4fa0-8621-3a7032efa07e"],
 " ",
 "imports a circuit from an OpenQASM string or file.",
 "\n",
 Cell["   ", "ModInfo",ExpressionUUID->"06e65ce6-467d-4182-a030-ab085af54d89"],
 Cell[BoxData[
  RowBox[{"QuantumCircuitOperator", "[", 
   RowBox[{
    StyleBox["qc", "TI"], ",", " ", 
    StyleBox["opts", "TI"]}], "]"}]], "InlineFormula",ExpressionUUID->
  "294f5994-2bf4-4a72-bd11-1bd564ca5221"],
 " ",
 "rebuilds an existing circuit ",
 StyleBox["qc", "TI"],
 " with new options."
}], "Usage",ExpressionUUID->"e600f355-e43a-4cd4-b513-3f87d3c39682"],

Cell[TextData[{
 "QuantumCircuitOperator[\[Ellipsis]][\"",
 StyleBox["prop", "TI"],
 "\"] will give the property ",
 StyleBox["prop", "TI"],
 " of the circuit."
}], "Notes",ExpressionUUID->"a6308ac7-d407-4850-b36c-cfc4343299aa"],

Cell[TextData[{
 "The following properties ",
 StyleBox["prop", "TI"],
 " are supported:"
}], "Notes",ExpressionUUID->"f9480877-1e68-41bd-9700-539f63569b41"],

Cell[BoxData[GridBox[{
   {Cell["      ", "ModInfo",ExpressionUUID->
     "213f165a-0038-46f9-97bb-0d805b41b34c"], Cell["", "TableText",
     FontWeight->Bold,ExpressionUUID->"a0eb7b1f-7988-468c-b27b-21f0444dc1ca"],
     Cell["", "TableText",
     FontWeight->Bold,ExpressionUUID->"d8b0f0aa-95b6-42e2-891a-ceb6873261b2"]},
   {Cell["      ", "ModInfo",ExpressionUUID->
