Cell["\<\
The graph circuit generates the graph state (also called a cluster state):\
\>", "ExampleText",ExpressionUUID->"72dca8fd-2e80-46e1-8856-d5f8cd1e08d2"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"QuantumCircuitOperator", "[", 
    RowBox[{"\"\<Graph\>\"", "[", "g", "]"}], "]"}], "[", "]"}], " ", "==", 
  " ", 
  RowBox[{"QuantumState", "[", 
   RowBox[{"\"\<Graph\>\"", "[", "g", "]"}], "]"}]}]], "Input",
 CellLabel->"In[3]:= ",ExpressionUUID->"5720f233-958c-411c-8069-aa11f410c43f"],

Cell[BoxData["True"], "Output",
 CellLabel->"Out[3]= ",ExpressionUUID->"b48b033d-3658-4ffa-bb32-4a234c74cb76"]
}, Open  ]],

Cell["Check qubits on the same edge are entangled:", "ExampleText",ExpressionUUID->"4720aced-e067-49d5-bd5c-ff88a13049e2"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"With", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"st", " ", "=", " ", 
     RowBox[{"QuantumState", "[", 
      RowBox[{"\"\<Graph\>\"", "[", "g", "]"}], "]"}]}], "}"}], ",", " ", 
   "\n", " ", 
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{"QuantumEntangledQ", "[", 
       RowBox[{"st", ",", " ", "#"}], "]"}], " ", "&"}], "@*", "List"}], " ", 
    "@@@", " ", 
    RowBox[{"EdgeList", "[", "g", "]"}]}]}], "]"}]], "Input",
 CellLabel->"In[4]:= ",ExpressionUUID->"e7b74e34-3bcd-47f9-b8d0-f16851db535d"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"True", ",", "True", ",", "True", ",", "True", ",", "True"}], 
  "}"}]], "Output",
 CellLabel->"Out[4]= ",ExpressionUUID->"9ed67892-bbc4-4ba7-accc-372351549bac"]
}, Open  ]],

Cell["Bernstein-Vazirani circuit", "ExampleSubsubsection",ExpressionUUID->"95b32ab3-79be-4153-8e1a-22d0db6b511f"],

Cell[TextData[{
 "For the Bernstein-Vazirani algorithm, one specifies a secret bit-string ",
 StyleBox["st", "TI"],
 ": the oracle is ",
 Cell[BoxData[
  RowBox[{
   ButtonBox["QuantumCircuitOperator",
    BaseStyle->"Link",
    ButtonData->"paclet:Wolfram/QuantumFramework/ref/QuantumCircuitOperator"],
    "[", 
   RowBox[{"BernsteinVaziraniOracle", "[", 
    StyleBox["st", "TI"], "]"}], "]"}]], "InlineFormula",ExpressionUUID->
  "d4a9624f-d7d8-4d85-8075-1d21f4d94e54"],
 ", and the whole circuit is ",
 Cell[BoxData[
  RowBox[{
   ButtonBox["QuantumCircuitOperator",
    BaseStyle->"Link",
    ButtonData->"paclet:Wolfram/QuantumFramework/ref/QuantumCircuitOperator"],
    "[", 
   RowBox[{"BernsteinVazirani", "[", 
    StyleBox["st", "TI"], "]"}], "]"}]], "InlineFormula",ExpressionUUID->
  "f6c3888f-55e6-48b7-88f1-e2aaea1e48cd"],
 ". For example, the Bernstein-Vazirani oracle for the secret bit-string \
101:"
}], "ExampleText",ExpressionUUID->"8ea8ccc4-5c73-4e4a-8df8-2120ef446ff1"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"QuantumCircuitOperator", "[", 
   RowBox[{"\"\<BernsteinVaziraniOracle\>\"", "[", "\"\<101\>\"", "]"}], 
   "]"}], "[", "\"\<Diagram\>\"", "]"}]], "Input",
 CellLabel->"In[1]:= ",ExpressionUUID->"bbaa3362-3adb-4e64-bdc7-342c47924cb2"],

