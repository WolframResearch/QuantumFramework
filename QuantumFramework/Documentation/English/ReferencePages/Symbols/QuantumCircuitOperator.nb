     "6dd66330-694c-43d8-8b3f-80b12b186968"]], "TableText",ExpressionUUID->
     "f75ec6b5-dfe0-4d7f-b1b8-2c060c510ae4"], Cell["\<\
the arity of the circuit: the number of input qudits it acts on\
\>", "TableText",ExpressionUUID->"6f400239-23c8-430f-8e44-c0b7c99e4cfd"]},
   {Cell["      ", "ModInfo",ExpressionUUID->
     "94eb3d3e-8350-4d6f-b31c-285ea24119a0"], Cell[TextData[Cell[
