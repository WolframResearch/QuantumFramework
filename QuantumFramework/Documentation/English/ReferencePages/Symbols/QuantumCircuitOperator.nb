     "14615bab-4818-4e4e-83e0-a04cc9cf117f"]], "TableText",ExpressionUUID->
     "5094dee6-b81a-40b0-b137-5e1ee4502c33"], Cell[
    "the underlying data of the circuit, as an Association", "TableText",
     ExpressionUUID->"9eecca0d-cf8c-4c52-b6e3-7eae2d093de4"]},
   {Cell["      ", "ModInfo",ExpressionUUID->
     "6f35c59b-24dc-4a3a-ac41-301490537391"], Cell[TextData[Cell[
