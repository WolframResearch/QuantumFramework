     "8246de39-40f4-4d2d-b66c-b3cfaf365fd2"], Cell[
    "the label of the circuit", "TableText",ExpressionUUID->
     "218210e3-efd3-450c-b788-03e36dcaf374"]},
   {Cell["      ", "ModInfo",ExpressionUUID->
     "37601546-d63e-4bd8-9c1c-f1612d387611"], Cell[TextData[Cell[
