     "e005b22f-3f90-45fd-aed4-cd1cbd19dc3d"]], "TableText",ExpressionUUID->
     "03e47dce-c218-4945-afca-b6549d065c93"], Cell["\<\
the circuit topology graph, with qudits/wires as vertices and gates as edges\
\>", "TableText",ExpressionUUID->"00ca9331-47e9-4a99-9407-76ad0bb8f58e"]},
   {Cell["      ", "ModInfo",ExpressionUUID->
     "03e054de-54d0-4267-b3ab-6c24dcdda275"], Cell[TextData[Cell[
    BoxData["\"\<TensorNetwork\>\""], "InlineFormula",ExpressionUUID->
     "15b58062-c416-4b41-9e0f-c074b7d28f1f"]], "TableText",ExpressionUUID->
     "04e69e22-d013-4954-b33d-61e878c27d5d"], Cell[
    "the corresponding tensor network representing the circuit", "TableText",
