     "3fc3a949-4dc5-4f84-87f7-beff377f69c1"], Cell[
    "the number of wires (qudits) the circuit spans", "TableText",
     ExpressionUUID->"d86e9aa1-f4d3-419d-8205-1f41c7d48581"]},
   {Cell["      ", "ModInfo",ExpressionUUID->
     "3a1604b3-d851-4b79-be64-60ae9079da68"], Cell[TextData[Cell[
