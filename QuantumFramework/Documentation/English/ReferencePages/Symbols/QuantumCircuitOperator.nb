Notebook[{

Cell[CellGroupData[{
Cell["QuantumCircuitOperator", "ObjectName",
 CellID->1224892054,ExpressionUUID->"8393d601-4014-44ba-afc9-60862df940ec"],

Cell[TextData[{
 Cell["   ", "ModInfo",ExpressionUUID->"2c886633-c3e4-4bfe-9758-af2fa3ee0a7b"],
 Cell[BoxData[
  RowBox[{
   ButtonBox["QuantumCircuitOperator",
    BaseStyle->"Link",
    ButtonData->"paclet:Wolfram/QuantumFramework/ref/QuantumCircuitOperator"],
    "[", 
   RowBox[{"{", 
    RowBox[{
     SubscriptBox[
      StyleBox["obj", "TI"], 
      StyleBox["1", "TR"]], ",", 
     SubscriptBox[
      StyleBox["obj", "TI"], 
      StyleBox["2", "TR"]], ",", 
     SubscriptBox[
      StyleBox["obj", "TI"], 
      StyleBox["3", "TR"]], ",", "..."}], "}"}], "]"}]], "InlineFormula",
  ExpressionUUID->"da08a3fe-e18b-4727-8292-c3d2e2ce1aa9"],
 " ",
 "represents a quantum circuit with a list of quantum objects ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["obj", "TI"], 
   StyleBox["i", "TI"]]], "InlineFormula",ExpressionUUID->
  "89382dde-be78-4760-8124-982f65458339"],
 ", e.g., quantum operator, quantum channel, quantum state or quantum \
measurement operators.",
 "\n",
 Cell["   ", "ModInfo",ExpressionUUID->"a467e44f-e710-4f46-862d-39cd4c2a7a39"],
 Cell[BoxData[
  RowBox[{
   ButtonBox["QuantumCircuitOperator",
    BaseStyle->"Link",
    ButtonData->"paclet:Wolfram/QuantumFramework/ref/QuantumCircuitOperator"],
    "[", 
   StyleBox["obj", "TI"], "]"}]], "InlineFormula",ExpressionUUID->
  "2151745f-6cd8-4ddf-b463-b2c6e5d526a1"],
 " ",
 "wraps a single quantum object (operator, channel, state or measurement \
operator) as a one-element circuit.",
 "\n",
 Cell["   ", "ModInfo",ExpressionUUID->"9221968a-7cfe-4e97-9104-df51fd6f2023"],
 Cell[BoxData[
  RowBox[{
   ButtonBox["QuantumCircuitOperator",
    BaseStyle->"Link",
    ButtonData->"paclet:Wolfram/QuantumFramework/ref/QuantumCircuitOperator"],
    "[", 
   RowBox[{
    StyleBox["obj", "TI"], " ", "->", " ", 
    StyleBox["order", "TI"]}], "]"}]], "InlineFormula",ExpressionUUID->
  "b8a1ce12-fa45-49a0-8eba-d68da255b47b"],
 " ",
 "places ",
 StyleBox["obj", "TI"],
 " on the qudit positions given by ",
 StyleBox["order", "TI"],
 ".",
 "\n",
 Cell["   ", "ModInfo",ExpressionUUID->"b0353e53-27bb-4b6a-b0a1-505c9015b58a"],
 Cell[BoxData[
  RowBox[{
   ButtonBox["QuantumCircuitOperator",
    BaseStyle->"Link",
    ButtonData->"paclet:Wolfram/QuantumFramework/ref/QuantumCircuitOperator"],
    "[", "\"\<\!\(\*StyleBox[\"name\", \"TI\"]\)\>\"", "]"}]], 
  "InlineFormula",ExpressionUUID->"cfe71e8f-1278-4cdb-a975-841c51ca3ff2"],
 " ",
 "or ",
 Cell[BoxData[
  RowBox[{
   ButtonBox["QuantumCircuitOperator",
    BaseStyle->"Link",
    ButtonData->"paclet:Wolfram/QuantumFramework/ref/QuantumCircuitOperator"],
    "[", 
   RowBox[{"\"\<\!\(\*StyleBox[\"name\", \"TI\"]\)\>\"", "[", 
    StyleBox["args", "TI"], "]"}], "]"}]], "InlineFormula",ExpressionUUID->
  "bb388925-4f52-4a98-afee-7278f569d14b"],
 " gives a named circuit, such as ",
 Cell[BoxData["\"\<Bell\>\""], "InlineFormula",ExpressionUUID->
  "3995a337-e4f6-4014-ae14-308160185bd9"],
 ", ",
 Cell[BoxData["\"\<Toffoli\>\""], "InlineFormula",ExpressionUUID->
  "94a2967e-eeb4-4495-9a6d-6f1ee0ad2c12"],
 " or ",
 Cell[BoxData[
  RowBox[{"\"\<Grover\>\"", "[", "f", "]"}]], "InlineFormula",ExpressionUUID->
  "4479a0d2-6d93-4291-9222-31ca15eef01d"],
 ".",
 "\n",
 Cell["   ", "ModInfo",ExpressionUUID->"5b331bc6-fe0c-4840-913e-40edaa009d28"],
 Cell[BoxData[
  RowBox[{
   ButtonBox["QuantumCircuitOperator",
    BaseStyle->"Link",
    ButtonData->"paclet:Wolfram/QuantumFramework/ref/QuantumCircuitOperator"],
    "[", 
   StyleBox["qs", "TI"], "]"}]], "InlineFormula",ExpressionUUID->
  "58fd04db-a455-4d37-9a43-6cdb13f07d94"],
 " ",
 "gives a circuit that prepares the quantum state ",
 StyleBox["qs", "TI"],
 ".",
 "\n",
 Cell["   ", "ModInfo",ExpressionUUID->"207a4443-bdb3-45ff-9a09-19449122ddc9"],
 Cell[BoxData[
  RowBox[{
   ButtonBox["QuantumCircuitOperator",
    BaseStyle->"Link",
    ButtonData->"paclet:Wolfram/QuantumFramework/ref/QuantumCircuitOperator"],
    "[", "\"\<\!\(\*StyleBox[\"string\", \"TI\"]\)\>\"", "]"}]], 
  "InlineFormula",ExpressionUUID->"fd187002-6a18-4031-92ef-7ed17caaef7c"],
 " ",
 "gives a tensor-product gate from a string of single-qubit gate letters, \
such as ",
 Cell[BoxData["\"\<IXYZ\>\""], "InlineFormula",ExpressionUUID->
  "452a86c1-0762-42f2-85fb-6e9b31d08275"],
 ".",
 "\n",
 Cell["   ", "ModInfo",ExpressionUUID->"d542dae3-4477-4a73-b930-daebbd64b09f"],
 Cell[BoxData[
  RowBox[{
   ButtonBox["QuantumCircuitOperator",
    BaseStyle->"Link",
    ButtonData->"paclet:Wolfram/QuantumFramework/ref/QuantumCircuitOperator"],
    "[", 
   StyleBox["qasm", "TI"], "]"}]], "InlineFormula",ExpressionUUID->
  "2c1e1a0e-db56-4228-b2a8-bdf191ce6163"],
 " ",
 "imports a circuit from an OpenQASM string or file.",
 "\n",
 Cell["   ", "ModInfo",ExpressionUUID->"17189f96-d790-407b-9e31-9cdf570dabd2"],
 Cell[BoxData[
  RowBox[{
   ButtonBox["QuantumCircuitOperator",
    BaseStyle->"Link",
    ButtonData->"paclet:Wolfram/QuantumFramework/ref/QuantumCircuitOperator"],
    "[", 
   RowBox[{
    StyleBox["qc", "TI"], ",", " ", 
    StyleBox["opts", "TI"]}], "]"}]], "InlineFormula",ExpressionUUID->
  "e093e4bc-2a9c-433f-8c91-1200c4aace43"],
 " ",
 "rebuilds an existing circuit ",
 StyleBox["qc", "TI"],
 " with new options."
}], "Usage",ExpressionUUID->"c0766b73-d3d0-4499-a0aa-06bff9dee23d"],

Cell[TextData[{
 "QuantumCircuitOperator[\[Ellipsis]][\"",
 StyleBox["prop", "TI"],
 "\"] will give the property ",
 StyleBox["prop", "TI"],
 " of the circuit."
}], "Notes",ExpressionUUID->"1adaadb2-ac1f-4c00-9ac0-8db3c2b9be3d"],

Cell[TextData[{
 "The following properties ",
 StyleBox["prop", "TI"],
 " are supported:"
}], "Notes",ExpressionUUID->"1afd311e-7e2b-431e-9dec-29b208259615"],

