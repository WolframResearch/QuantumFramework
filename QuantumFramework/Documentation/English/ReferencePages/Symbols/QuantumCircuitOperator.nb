Cell["\<\
Read off the most probable measurement outcome as a bit-string:\
\>", "ExampleText",ExpressionUUID->"0d1e8b74-4b3b-4630-9a39-ca32b6b84090"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"bits2", " ", "=", " ", 
  RowBox[{
   RowBox[{
    RowBox[{"Keys", "[", 
     RowBox[{"TakeLargest", "[", 
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{"N", "[", "qc2", "]"}], "[", "]"}], 
        "[", "\"\<Probabilities\>\"", "]"}], ",", " ", "1"}], "]"}], "]"}], "[", 
    RowBox[{"[", "1", "]"}], "]"}], "[", "\"\<Name\>\"", "]"}]}]], "Input",
 CellLabel->"In[36]:=",ExpressionUUID->"0cd88538-7d25-480e-b197-31c621b790a9"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"0", ",", "0", ",", "1", ",", "1"}], "}"}]], "Output",
 CellChangeTimes->{3.9901036149772*^9, 3.9901036684446077`*^9},
 CellLabel->"Out[36]=",
 CellID->1692732053,ExpressionUUID->"00d120d1-c1b6-4639-a5aa-735b150df471"]
}, Open  ]],

Cell["Convert that bit-string into the estimated eigenvalue:", "ExampleText",ExpressionUUID->"77b3cfbc-ba8d-4d4d-b669-c91fbab17e20"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"est2", " ", "=", " ", 
  RowBox[{
   RowBox[{
    RowBox[{"FromDigits", "[", 
     RowBox[{"bits2", ",", " ", "2"}], "]"}], "/", 
    RowBox[{"2", "^", "4"}]}], " ", "//", " ", "N"}]}]], "Input",
 CellLabel->"In[37]:=",ExpressionUUID->"481a9f8c-d4c5-41a0-9034-808f06e59be6"],

Cell[BoxData["0.1875`"], "Output",
 CellChangeTimes->{3.9901036190827837`*^9, 3.990103668475286*^9},
 CellLabel->"Out[37]=",
 CellID->2031742962,ExpressionUUID->"426034b4-cec7-4e02-9b75-ac3f73c15343"]
}, Open  ]],

Cell[TextData[{
 "Find corresponding eigenvalues (note they should be in the form ",
 Cell[BoxData[
  SuperscriptBox[
   StyleBox["e", "TI"], 
   RowBox[{
    StyleBox["i", "TI"], " ", "2", "\[Pi]", " ", 
    StyleBox["\[Lambda]", "TI"]}]]], "InlineFormula",ExpressionUUID->
  "76cf7ec3-0983-4318-914e-b980643e934f"],
 "):"
}], "ExampleText",ExpressionUUID->"a2db9541-b4fa-4f89-9d69-52261e3a019b"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"\[Lambda]", " ", "=", " ", 
  RowBox[{"Mod", "[", 
   RowBox[{
    RowBox[{
     RowBox[{"Arg", "[", 
      RowBox[{"u", "[", "\"\<Eigenvalues\>\"", "]"}], "]"}], "/", 
     RowBox[{"(", 
      RowBox[{"2", " ", "\[Pi]"}], ")"}]}], ",", " ", "1"}], "]"}]}]], "Input",\

 CellLabel->"In[38]:=",ExpressionUUID->"943740b1-d44c-45fe-b3f8-da29c0933080"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"0.23250000000000004`", ",", "0.17000000000000004`"}], 
  "}"}]], "Output",
 CellChangeTimes->{3.9901036253834248`*^9, 3.990103668517181*^9},
 CellLabel->"Out[38]=",
 CellID->366491387,ExpressionUUID->"e6772fcf-5455-4a22-b29e-e4989f3e65da"]
}, Open  ]],

Cell["\<\
Calculate the estimated eigenvalues, compared to the expected ones and find \
the error%:\
\>", "ExampleText",ExpressionUUID->"50ad15fd-20a0-42d1-bc15-3cdd823e8564"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"100.", " ", 
  RowBox[{"(", 
   RowBox[{"1", " ", "-", " ", 
    RowBox[{
     RowBox[{"Sort", "[", 
      RowBox[{"{", 
       RowBox[{"est1", ",", " ", "est2"}], "}"}], "]"}], "/", 
     RowBox[{"Sort", "[", "\[Lambda]", "]"}]}]}], ")"}]}]], "Input",
 CellLabel->"In[39]:=",ExpressionUUID->"b0adddf3-64bf-4048-bf1e-36181e3988df"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{"-", "10.294117647058787`"}], ",", 
   RowBox[{"-", "7.526881720430079`"}]}], "}"}]], "Output",
 CellChangeTimes->{3.9901036316488543`*^9, 3.9901036685449677`*^9},
 CellLabel->"Out[39]=",
 CellID->637641713,ExpressionUUID->"6c2c795f-d5e5-46f7-bc7c-1b9b88f4f7d7"]
}, Open  ]]
}, Closed]],

