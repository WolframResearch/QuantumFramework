Cell["\<\
PhaseNumber followed by InverseFourier gives a circuit that reads back the \
encoded number:\
\>", "ExampleText",ExpressionUUID->"c705396e-45c8-43e5-8238-442d740bcbfa"],

Cell[BoxData[
 RowBox[{
  RowBox[{"qc", " ", "=", " ", 
   RowBox[{"QuantumCircuitOperator", "[", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"\"\<PhaseNumber\>\"", "[", 
       RowBox[{"5", ",", " ", "6"}], "]"}], ",", " ", "\n", "    ", 
      RowBox[{"\"\<InverseFourier\>\"", "[", "6", "]"}], ",", " ", 
      RowBox[{"Range", "[", "6", "]"}]}], "}"}], "]"}]}], ";"}]], "Input",
 CellLabel->"In[3]:= ",ExpressionUUID->"9af02372-b1b5-4248-aab9-d6b8f66625b1"],

