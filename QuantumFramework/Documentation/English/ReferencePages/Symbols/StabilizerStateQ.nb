Cell[CellGroupData[{

Cell["QuantumState is never True without explicit conversion", \
"ExampleSubsection",
 CellID->132782778,ExpressionUUID->"14a78786-80dd-47b8-965d-fa876a68dbe3"],

Cell[TextData[{
 "Even known stabilizer states return ",
 Cell[BoxData[
 "False"], "InlineFormula",ExpressionUUID->
  "c20e33a5-d860-4e26-853b-8d5823e567b2"],
 " when wrapped ",
 "in a ",
 Cell[BoxData[
 "QuantumState"], "InlineFormula",ExpressionUUID->
  "08d088e0-f478-45d9-b401-5af2f492121a"],
 " (the predicate intentionally avoids ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["4", 
    StyleBox["n", "TI"]], TraditionalForm]], "InlineFormula",ExpressionUUID->
  "b11def54-c97d-46e6-b50a-45993aedbec6"],
 " tomography):"
}], "ExampleText",
 CellID->902057041,ExpressionUUID->"aa00d39c-6124-4c4c-86ac-bcfeb92f1ffa"],

Cell[BoxData[
 RowBox[{"StabilizerStateQ", " ", "/@", " ", 
  RowBox[{"{", 
   RowBox[{
    RowBox[{"QuantumState", "[", "\"\<Bell\>\"", "]"}], ",", " ", 
    RowBox[{"QuantumState", "[", "\"\<GHZ\>\"", "]"}], ",", " ", 
    RowBox[{"QuantumState", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"1", ",", " ", "0", ",", " ", "0", ",", " ", "0"}], "}"}], "/",
       "1"}], "]"}]}], "}"}]}]], "Input",
 CellLabel->"In[1]:=",
 CellID->903777866,ExpressionUUID->"084a22b3-0e76-4fe4-a8ec-c87afcb07524"],

Cell[BoxData[
 RowBox[{"{", 
