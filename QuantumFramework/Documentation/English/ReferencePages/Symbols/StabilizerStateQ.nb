Cell[CellGroupData[{

Cell["Verify a round-trip QuantumState -> PauliStabilizer", \
"ExampleSubsection",
 CellID->395042370,ExpressionUUID->"c3b67c58-cc6c-4c95-896a-defb1a2d1f17"],

Cell["\<\
Confirm that PauliStabilizer[qs] succeeds by checking the result:\
\>", "ExampleText",
 CellID->402038901,ExpressionUUID->"755bbd18-170f-4122-be28-e98ad712c83f"],

Cell[BoxData[
 RowBox[{"Module", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"qs", ",", " ", "ps"}], "}"}], ",", " ", 
   RowBox[{
    RowBox[{"qs", " ", "=", " ", 
     RowBox[{"QuantumState", "[", "\"\<Bell\>\"", "]"}]}], ";", " ", 
    RowBox[{"ps", " ", "=", " ", 
     RowBox[{"PauliStabilizer", "[", "qs", "]"}]}], ";", " ", 
    RowBox[{"StabilizerStateQ", "[", "ps", "]"}]}]}], "]"}]], "Input",
 CellLabel->"In[1]:=",
 CellID->49155168,ExpressionUUID->"30304e13-da18-4e6b-a3e3-321dc282316f"],

Cell[BoxData["True"], "Output",
 CellLabel->"Out[1]=",
 CellID->229501076,ExpressionUUID->"c126c7c0-756a-424e-baf7-bb2d7b65c7fc"]
}, Open  ]]
}, Open  ]],

