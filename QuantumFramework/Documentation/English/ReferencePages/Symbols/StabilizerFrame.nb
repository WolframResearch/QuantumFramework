       RowBox[{"-", "1"}], "+", 
       SuperscriptBox[
        RowBox[{"(", 
         RowBox[{"-", "1"}], ")"}], 
        RowBox[{"1", "/", "4"}]]}], ")"}], "2"]}]}], "}"}]], "Output",
 CellLabel->"Out[1]=",
