Cell[BoxData[
 RowBox[{"Module", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"f1", ",", " ", "f2"}], "}"}], ",", " ", 
   RowBox[{
    RowBox[{"f1", " ", "=", " ", 
     RowBox[{"StabilizerFrame", "[", 
      RowBox[{"PauliStabilizer", "[", 
       RowBox[{"{", "\"\<Z\>\"", "}"}], "]"}], "]"}]}], ";", " ", 
    RowBox[{"f2", " ", "=", " ", 
     RowBox[{
      RowBox[{"StabilizerFrame", "[", 
       RowBox[{"PauliStabilizer", "[", "1", "]"}], "]"}], "[", 
      RowBox[{"\"\<T\>\"", ",", " ", "1"}], "]"}]}], ";", " ", 
