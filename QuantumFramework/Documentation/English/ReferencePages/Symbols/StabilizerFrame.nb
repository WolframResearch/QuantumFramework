 CellID->198168807,ExpressionUUID->"fa8fca31-cc18-486f-a7c5-83c3ab8e46bd"],

Cell[TextData[{
 "Frame length doubles per ",
 Cell[BoxData["\"\<T\>\""], "InlineFormula",ExpressionUUID->
  "22b12599-4180-4eb3-bc92-63d2b2bf8122"],
 " gate applied to distinct components; Clifford gates leave the length \
unchanged:"
}], "ExampleText",
 CellID->748052787,ExpressionUUID->"35f43206-a493-4e38-9f22-5462745a27b9"],

Cell[BoxData[
 RowBox[{"Module", "[", 
