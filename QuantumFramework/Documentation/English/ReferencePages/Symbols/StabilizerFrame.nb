Cell["A StabilizerFrame built from a single PauliStabilizer:", "ExampleText",
 CellID->152841327,ExpressionUUID->"1ad570c1-a348-4abd-a6da-7f50ce69e22e"],

Cell[BoxData[
 RowBox[{"StabilizerFrame", "[", 
  RowBox[{"PauliStabilizer", "[", "2", "]"}], "]"}]], "Input",
 CellLabel->"In[1]:=",
 CellID->326136997,ExpressionUUID->"3d38e572-5cec-4a60-ad16-a2ce1ab3cc13"],

Cell[BoxData[
 InterpretationBox[
  RowBox[{
