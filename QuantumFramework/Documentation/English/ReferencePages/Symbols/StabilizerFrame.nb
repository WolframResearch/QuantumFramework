       SuperscriptBox[
        RowBox[{"(", 
         RowBox[{"-", "1"}], ")"}], 
        RowBox[{"1", "/", "4"}]]}], ")"}], "2"]}], ",", 
   RowBox[{
    FractionBox["1", "4"], "-", 
