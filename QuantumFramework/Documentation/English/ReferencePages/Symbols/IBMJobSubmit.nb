Cell[CellGroupData[{

Cell["\t", "ExampleDelimiter",ExpressionUUID->"bf6106c3-77f9-4eaa-9d90-de057218f5f9"],

Cell[TextData[{
 "Reach into the IBM Runtime options schema through ",
 Cell[BoxData["\"\<PrimitiveOptions\>\""], "InlineFormula",ExpressionUUID->
  "51de589c-280a-4011-9755-e076d6c839a3"],
 ", given in CamelCase and converted to the service's snake_case keys (here \
turning off dynamical decoupling and selecting a resilience level):"
}], "ExampleText",ExpressionUUID->"7772630c-9321-4627-af9a-151c0b1afd30"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"IBMJobSubmit", "[", 
  RowBox[{
   RowBox[{"QuantumCircuitOperator", "[", 
    RowBox[{"{", 
     RowBox[{"\"\<GHZ\>\"", ",", " ", 
      RowBox[{"{", 
       RowBox[{"1", ",", " ", "2", ",", " ", "3"}], "}"}]}], "}"}], "]"}], ",",
    " ", "\"\<ibm_fez\>\"", ",", "\n", "  ", 
   RowBox[{"\"\<PrimitiveOptions\>\"", " ", "->", " ", 
    RowBox[{"<|", 
     RowBox[{
      RowBox[{"\"\<DynamicalDecoupling\>\"", " ", "->", " ", 
       RowBox[{"<|", 
        RowBox[{"\"\<Enable\>\"", " ", "->", " ", "False"}], "|>"}]}], ",", 
      " ", 
      RowBox[{"\"\<ResilienceLevel\>\"", " ", "->", " ", "1"}]}], "|>"}]}]}], 
  "]"}]], "Input",
 CellLabel->"In[12]:=",ExpressionUUID->"51058a57-9208-428c-aa1a-672bf9fc1f70"],

