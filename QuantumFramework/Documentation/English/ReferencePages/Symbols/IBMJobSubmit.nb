Cell["\<\
Submit to the active connection's default backend by omitting the backend \
argument:\
\>", "ExampleText",ExpressionUUID->"66ff377b-5659-428c-9833-aadbf20d48da"],

Cell[BoxData[
 RowBox[{"IBMJobSubmit", "[", 
