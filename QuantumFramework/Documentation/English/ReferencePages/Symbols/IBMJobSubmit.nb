 CellID->1293636265,ExpressionUUID->"6d08f999-4c69-4709-9b28-82906be6ee75"],

Cell["\<\
Submit to the active connection's default backend by omitting the backend \
argument:\
\>", "ExampleText",ExpressionUUID->"6a0c2d9c-6261-4b65-a5ca-b0cbd46a0e8d"],

Cell["IBMJobSubmit[QuantumCircuitOperator[{\"GHZ\", {1, 2, 3}}]]", "Program",ExpressionUUID->"4c70a865-11a6-4f90-b4be-9d97730d1a4c"],

Cell["\t", "ExampleDelimiter",ExpressionUUID->"ba196312-ca86-4f9f-9420-039e11047257"],

Cell[TextData[{
 "Block until the job finishes with ",
 Cell[BoxData[
  RowBox[{"\"\<Wait\>\"", " ", "->", " ", "True"}]], "InlineFormula",
  ExpressionUUID->"41ec8820-caa7-4d0a-9d5a-962e8f085a9c"],
 "; the returned handle is already ",
 Cell[BoxData["\"\<Completed\>\""], "InlineFormula",ExpressionUUID->
  "f2faaabc-8c79-4220-b1fa-eef49a765f21"],
 ":"
}], "ExampleText",ExpressionUUID->"b6427399-b16f-4457-a243-9f6948afbfc3"],

Cell["\<\
IBMJobSubmit[QuantumCircuitOperator[{\"GHZ\", {1, 2, 3}}], \"ibm_fez\", \
\"Wait\" -> True][\"Status\"]\
\>", "Program",ExpressionUUID->"1946f374-b8e7-425a-988b-1a81647f9a5b"],

Cell["\t", "ExampleDelimiter",ExpressionUUID->"93d4fb04-6560-4637-9dea-567dcb20f890"],

Cell["Set the number of shots:", "ExampleText",ExpressionUUID->"04791b94-cd49-4695-92e5-96797bb110e5"],

Cell["\<\
IBMJobSubmit[QuantumCircuitOperator[{\"GHZ\", {1, 2, 3}}], \"ibm_fez\", \
\"Shots\" -> 1024]\
\>", "Program",ExpressionUUID->"dd6be245-c8d0-4869-9116-1bdf9a670c6a"],

Cell["\t", "ExampleDelimiter",ExpressionUUID->"8955f2c1-47ab-4fb4-84a8-3af42af2f4e4"],

Cell[TextData[{
 "Reach into the IBM Runtime options schema through ",
 Cell[BoxData["\"\<PrimitiveOptions\>\""], "InlineFormula",ExpressionUUID->
  "b7454adb-4d5e-4b7e-bab9-56498a4d57c7"],
 ", given in CamelCase and converted to the service's snake_case keys (here \
turning off dynamical decoupling and selecting a resilience level):"
}], "ExampleText",ExpressionUUID->"f831982b-54bf-47f4-8e3d-04df63675b9c"],

Cell["\<\
IBMJobSubmit[QuantumCircuitOperator[{\"GHZ\", {1, 2, 3}}], \"ibm_fez\",
  \"PrimitiveOptions\" -> <|\"DynamicalDecoupling\" -> <|\"Enable\" -> \
False|>, \"ResilienceLevel\" -> 1|>]\
\>", "Program",ExpressionUUID->"0da770b3-cb00-41a5-afe6-06790996668d"],

Cell["\t", "ExampleDelimiter",ExpressionUUID->"c738f626-462d-4028-901b-80cac42bd1a6"],

Cell[TextData[{
 "Submit an ",
 Cell[BoxData["\"\<estimator\>\""], "InlineFormula",ExpressionUUID->
  "e6b681c6-cdc1-48fd-97cf-786b2803bddc"],
 " job with an observable instead of a sampler job:"
}], "ExampleText",ExpressionUUID->"cef86d2e-8c7d-4075-9e2c-0fe37888ce2d"],

Cell["\<\
IBMJobSubmit[QuantumCircuitOperator[{\"GHZ\", {1, 2, 3}}], \"ibm_fez\", \
\"Primitive\" -> \"estimator\", \"Observable\" -> \"ZZZ\"]\
\>", "Program",ExpressionUUID->"2d6f0dba-0cd3-4ee4-8a90-242530271ad3"]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[
 InterpretationBox[Cell[
  "Options", "ExampleSection",ExpressionUUID->
   "b26b6366-7922-4236-a426-38c0f5de13f0"],
  $Line = 0; Null]], "ExampleSection",
 CellID->2061341341,ExpressionUUID->"3276b1d7-cf51-4f3b-970a-56b0e7c469f0"],

Cell["\"Shots\"", "ExampleSubsection",ExpressionUUID->"a4a91f9d-5bb6-4d76-8504-66c82125fd96"],

Cell[TextData[{
 "The number of shots is forwarded as the primitive's ",
 Cell[BoxData[
 "default_shots"], "InlineFormula",ExpressionUUID->
  "a8f1ecc3-01b2-4567-911a-f45df8fffe62"],
 ":"
}], "ExampleText",ExpressionUUID->"c5f4f8ef-adbc-4f72-991e-9daca0c3c9df"],

Cell["\<\
IBMJobSubmit[QuantumCircuitOperator[{\"GHZ\", {1, 2, 3}}], \"ibm_fez\", \
\"Shots\" -> 8192][\"Shots\"]\
\>", "Program",ExpressionUUID->"c1d1f085-ffcc-4772-9c4e-6f8fc53e6497"],

Cell["\"Version\"", "ExampleSubsection",ExpressionUUID->"fe80b208-8aa8-4c81-97d0-bf4e9e2f84c0"],

Cell["\<\
Emit the submitted ISA circuit as OpenQASM 3 instead of the default OpenQASM \
2:\
\>", "ExampleText",ExpressionUUID->"ec6d9c75-85dc-40bf-87a6-60c2fa62c096"],

Cell["\<\
StringStartsQ[IBMJobSubmit[QuantumCircuitOperator[{\"GHZ\", {1, 2, 3}}], \
\"ibm_fez\", \"Version\" -> 3][\"SubmittedCircuit\"], \"OPENQASM 3.0\"]\
\>", "Program",ExpressionUUID->"b303ca9a-884e-4bb5-a947-3453a99f2dcd"],

Cell["\"Wait\"", "ExampleSubsection",ExpressionUUID->"efd7f0c7-9c0f-4bec-b2c0-7a58217877ca"],

Cell[TextData[{
 Cell[BoxData[
  RowBox[{"\"\<Wait\>\"", " ", "->", " ", "True"}]], "InlineFormula",
  ExpressionUUID->"1b664111-b39d-460e-905c-609048faf373"],
 " polls the service until the job is terminal before returning the handle:"
}], "ExampleText",ExpressionUUID->"792baf48-8585-439c-b7bb-662a46bc13ff"],

Cell["\<\
IBMJobSubmit[QuantumCircuitOperator[{\"GHZ\", {1, 2, 3}}], \"ibm_fez\", \
\"Wait\" -> True][\"QuantumSeconds\"]\
\>", "Program",ExpressionUUID->"22ad9bc2-84c1-4786-b482-af36c2614845"],

Cell["\"Primitive\"", "ExampleSubsection",ExpressionUUID->"d9c7c022-1d2e-421e-b6eb-72ea2104ee37"],

Cell[TextData[{
 "Choose between the ",
 Cell[BoxData["\"\<sampler\>\""], "InlineFormula",ExpressionUUID->
  "5f153157-e259-4566-880e-feb75c8a8708"],
 " and ",
 Cell[BoxData["\"\<estimator\>\""], "InlineFormula",ExpressionUUID->
  "6b41c991-b6b1-45a4-8e7b-80dec8da1100"],
 " primitives; ",
 Cell[BoxData["\"\<Observable\>\""], "InlineFormula",ExpressionUUID->
  "e62fc82f-d5e0-4626-bd26-b2bdab6160c1"],
 " applies to the estimator:"
}], "ExampleText",ExpressionUUID->"f6b99b60-9970-4db0-a27e-20bba7eac361"],

Cell["\<\
IBMJobSubmit[QuantumCircuitOperator[{\"GHZ\", {1, 2, 3}}], \"ibm_fez\", \
\"Primitive\" -> \"estimator\", \"Observable\" -> \"ZZZ\"][\"ProgramID\"]\
\>", "Program",ExpressionUUID->"0294dcac-19d9-4685-b682-028759af4e09"]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[
 InterpretationBox[Cell[
  "Possible Issues", "ExampleSection",ExpressionUUID->
   "dda06a82-eb41-4b48-8510-6cb821647761"],
  $Line = 0; Null]], "ExampleSection",
 CellID->1305812373,ExpressionUUID->"9397dd0b-9de4-443a-9371-be2b75148f2f"],

Cell[TextData[{
 "With no active IBM Quantum Platform connection, ",
 Cell[BoxData[
 "IBMJobSubmit"], "InlineFormula",ExpressionUUID->
  "6467429f-ab2d-4b12-a5c8-dcfe937691d8"],
 " returns a ",
 Cell[BoxData[
  ButtonBox["Failure",
   BaseStyle->"Link",
   ButtonData->"paclet:ref/Failure"]], "InlineFormula",ExpressionUUID->
  "94bb4799-d2f0-4bb5-93f9-498fefa9c56e"],
 " and submits nothing:"
}], "ExampleText",ExpressionUUID->"e8ea068e-c71a-4de2-bf6f-c6c3b6b12e41"],

Cell["\<\
IBMJobSubmit[QuantumCircuitOperator[{\"GHZ\", {1, 2, 3}}], \"ibm_fez\"]\
\>", "Program",ExpressionUUID->"c7d1da9f-b7c8-4abd-8632-3466dd3ccbd9"],

Cell["\t", "ExampleDelimiter",ExpressionUUID->"3c66d3b9-f5e5-4b3c-a19d-b1272a000619"],

Cell[TextData[{
 "When the backend is ",
 Cell[BoxData[
 "Automatic"], "InlineFormula",ExpressionUUID->
  "c901c69f-df91-429a-8e1b-ac5d0d784905"],
 " and the active connection exposes no backends, the default backend cannot \
be determined:"
}], "ExampleText",ExpressionUUID->"8b5a609f-033e-4247-9e0c-b2cdfc54eca5"],

Cell["IBMJobSubmit[QuantumCircuitOperator[{\"GHZ\", {1, 2, 3}}]]", "Program",ExpressionUUID->"51ec747c-526b-40d0-aa03-b082bbf2f4ad"],

Cell["\t", "ExampleDelimiter",ExpressionUUID->"bf3f51ef-2549-4669-b2d9-319aed174a1b"],

Cell[TextData[{
 "A circuit carrying any non-qubit (higher-dimensional) system has no \
OpenQASM representation, so it is rejected before submission with the same ",
 Cell[BoxData[
  ButtonBox["Failure",
   BaseStyle->"Link",
   ButtonData->"paclet:ref/Failure"]], "InlineFormula",ExpressionUUID->
  "34de4ce5-905c-4a7d-9cb3-74baa9f00f7a"],
 " ",
 Cell[BoxData[
  ButtonBox["QuantumQASM",
   BaseStyle->"Link",
   ButtonData->"paclet:Wolfram/QuantumFramework/ref/QuantumQASM"]], 
  "InlineFormula",ExpressionUUID->"92d2deb2-5e60-462c-ba79-35ebc1a368a8"],
 " gives:"
}], "ExampleText",ExpressionUUID->"7efdd636-e91e-4da9-bdd3-85f3b27e91c1"],

Cell["\<\
IBMJobSubmit[QuantumCircuitOperator[{\"H\"[3] -> 1, {1}}], \"ibm_fez\"]\
\>", "Program",ExpressionUUID->"dba042db-e8d1-4c89-bd9e-991df215a9c0"],

Cell["\t", "ExampleDelimiter",ExpressionUUID->"0602d541-e5fe-48c4-8e2e-4a12e3923b09"],

Cell[TextData[{
 "If the service accepts the request but returns no job id, the response is \
surfaced in the ",
 Cell[BoxData[
  ButtonBox["Failure",
   BaseStyle->"Link",
   ButtonData->"paclet:ref/Failure"]], "InlineFormula",ExpressionUUID->
  "f51f31a6-e03d-4217-88c9-0d19a59b9589"],
 ":"
}], "ExampleText",ExpressionUUID->"5d053999-4e6f-43a2-9d60-51276988416b"],

Cell["\<\
IBMJobSubmit[QuantumCircuitOperator[{\"GHZ\", {1, 2, 3}}], \"ibm_fez\"]\
\>", "Program",ExpressionUUID->"1a56e2a7-68b3-49e7-8ccf-354800c76291"]
}, Open  ]]
}, Open  ]],

