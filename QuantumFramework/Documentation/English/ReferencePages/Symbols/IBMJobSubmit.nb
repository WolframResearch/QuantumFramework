     ")"
    }], "TableText",ExpressionUUID->"388d3e52-a8a1-4d2b-a74f-fa568503b07d"]},
   {Cell["      ", "ModInfo",ExpressionUUID->
     "e54706b0-142f-4b4f-a795-739b299439c3"], Cell[TextData[Cell[
    BoxData["\"\<Observable\>\""], "InlineFormula",ExpressionUUID->
     "7e66ffdc-1a8c-465d-8c63-d89d360b7cab"]], "TableText",ExpressionUUID->
     "7ba5aead-8620-45a4-9cab-3a637b179914"], Cell[TextData[Cell[
    BoxData["\"\<Z\>\""], "InlineFormula",ExpressionUUID->
