Notebook[{

Cell[CellGroupData[{
Cell["IBMJobSubmit", "ObjectName",
 CellID->1224892054,ExpressionUUID->"8393d601-4014-44ba-afc9-60862df940ec"],

Cell[TextData[{
 Cell["   ", "ModInfo",ExpressionUUID->"193da1a2-2020-498f-83d2-0a1d5d9548e9"],
 Cell[BoxData[
  RowBox[{
   ButtonBox["IBMJobSubmit",
    BaseStyle->"Link",
    ButtonData->"paclet:Wolfram/QuantumFramework/ref/IBMJobSubmit"], "[", 
   StyleBox["circ", "TI"], "]"}]], "InlineFormula",ExpressionUUID->
  "a7fd34da-c2cd-4057-a679-e96a5db0d64f"],
 " ",
 "submits the quantum circuit ",
 StyleBox["circ", "TI"],
 " to the default backend of the active IBM Quantum Platform connection and \
gives an ",
 Cell[BoxData[
  ButtonBox["IBMJob",
   BaseStyle->"Link",
   ButtonData->"paclet:Wolfram/QuantumFramework/ref/IBMJob"]], 
  "InlineFormula",ExpressionUUID->"2b186749-6957-4d19-b28d-43eabcf501d5"],
 " handle.",
 "\n",
 Cell["   ", "ModInfo",ExpressionUUID->"7647d37b-de4f-4e1a-a757-c470317627a3"],
 Cell[BoxData[
  RowBox[{
   ButtonBox["IBMJobSubmit",
    BaseStyle->"Link",
    ButtonData->"paclet:Wolfram/QuantumFramework/ref/IBMJobSubmit"], "[", 
   RowBox[{
    StyleBox["circ", "TI"], ",", 
    " ", "\"\<\!\(\*StyleBox[\"backend\", \"TI\"]\)\>\""}], "]"}]], 
  "InlineFormula",ExpressionUUID->"6b00084f-bd57-42b1-8563-8003c9ee2031"],
 " ",
 "submits ",
 StyleBox["circ", "TI"],
 " to the named backend.",
 "\n",
 Cell["   ", "ModInfo",ExpressionUUID->"b72f4d83-d4da-4d4f-85f3-5ac4bc98813e"],
 Cell[BoxData[
  RowBox[{
   ButtonBox["IBMJobSubmit",
    BaseStyle->"Link",
    ButtonData->"paclet:Wolfram/QuantumFramework/ref/IBMJobSubmit"], "[", 
   RowBox[{
    StyleBox["circ", "TI"], ",", " ", 
    StyleBox["backend", "TI"], ",", " ", 
    StyleBox["opts", "TI"]}], "]"}]], "InlineFormula",ExpressionUUID->
  "7e298f69-ab74-4cb2-b83b-24da99c6ab2b"],
 " ",
 "submits with the options ",
 StyleBox["opts", "TI"],
 ", such as the primitive, the number of shots and the pass-through primitive \
option tree."
}], "Usage",ExpressionUUID->"e4e8e6a6-b699-449c-b705-105459904e23"],

Cell[TextData[{
 StyleBox["circ", "TI"],
 " is a ",
 Cell[BoxData[
  ButtonBox["QuantumCircuitOperator",
   BaseStyle->"Link",
   ButtonData->"paclet:Wolfram/QuantumFramework/ref/QuantumCircuitOperator"]],
   "InlineFormula",ExpressionUUID->"01e0482c-95e9-4120-84b5-e8d57a2f3aa9"],
 ". It is transpiled to an ISA OpenQASM program against the chosen backend \
through ",
 Cell[BoxData[
  ButtonBox["QuantumQASM",
   BaseStyle->"Link",
   ButtonData->"paclet:Wolfram/QuantumFramework/ref/QuantumQASM"]], 
  "InlineFormula",ExpressionUUID->"687db1df-0959-4008-bb46-444fe4a6ff27"],
 " (the ",
 Cell[BoxData[
  RowBox[{"\"\<Provider\>\"", " ", "->", " ", "\"\<IBMProvider\>\""}]], 
  "InlineFormula",ExpressionUUID->"ee40b2b8-439b-4557-9239-e6830df9ee13"],
 " path) before submission."
}], "Notes",ExpressionUUID->"f59e3e6b-c5bb-4271-822d-ceababfeb8f1"],

Cell[TextData[{
 Cell[BoxData[
 "IBMJobSubmit"], "InlineFormula",ExpressionUUID->
  "5c3edd75-dd6d-4392-a99b-0caa6080247a"],
 " requires an ",
 StyleBox["active",
  FontWeight->"Bold"],
 " service connection: it consults ",
 Cell[BoxData[
  RowBox[{
  "ServiceFramework`GetDefaultServiceObject", 
   "[", "\"\<IBMQuantumPlatform\>\"", "]"}]], "InlineFormula",ExpressionUUID->
  "6d08a5d5-1e7f-4146-aaaa-9f6428429b2b"],
 " and never creates a connection or prompts for credentials. Run ",
 Cell[BoxData[
  RowBox[{
   ButtonBox["ServiceConnect",
    BaseStyle->"Link"], "[", "\"\<IBMQuantumPlatform\>\"", "]"}]], 
  "InlineFormula",ExpressionUUID->"312701f6-1109-4481-a343-6203e74ff90c"],
 " first (see the ",
 "Sending Queries to IBM QPUs",
 " tech note). With no active connection it returns a ",
 Cell[BoxData[
  ButtonBox["Failure",
   BaseStyle->"Link",
   ButtonData->"paclet:ref/Failure"]], "InlineFormula",ExpressionUUID->
  "071e72d3-1e0c-494b-819c-45a75d81d76a"],
 " and never submits."
}], "Notes",ExpressionUUID->"4f3d0562-6cb9-4bf0-b3f0-f911d04159e7"],

Cell[TextData[{
 Cell[BoxData[
 "IBMJobSubmit"], "InlineFormula",ExpressionUUID->
  "b1878419-4330-4663-9709-c3a7409d0d67"],
 " returns immediately with an asynchronous ",
 Cell[BoxData[
  ButtonBox["IBMJob",
   BaseStyle->"Link",
   ButtonData->"paclet:Wolfram/QuantumFramework/ref/IBMJob"]], 
  "InlineFormula",ExpressionUUID->"c9a6424f-29f7-4bb8-b701-0eda0fd9c863"],
 " handle whose ",
 Cell[BoxData["\"\<Status\>\""], "InlineFormula",ExpressionUUID->
  "c96a871a-cab0-44a1-a783-bb4bf4e5d616"],
 " is whatever the service reports (typically ",
 Cell[BoxData["\"\<Queued\>\""], "InlineFormula",ExpressionUUID->
  "460a2aea-f945-4b74-95b3-faac87f73ee5"],
 "). Query the handle later, or pass ",
 Cell[BoxData[
  RowBox[{"\"\<Wait\>\"", " ", "->", " ", "True"}]], "InlineFormula",
  ExpressionUUID->"da12e219-40a4-4a57-b748-c8e777a06435"],
 " to block until the job reaches a terminal status (",
 Cell[BoxData["\"\<Completed\>\""], "InlineFormula",ExpressionUUID->
  "4ce7046f-6712-460e-b11f-fed3c3e0062e"],
 ", ",
 Cell[BoxData["\"\<Cancelled\>\""], "InlineFormula",ExpressionUUID->
  "329d1aae-c00f-4145-837b-6fcbf0ec2b09"],
 " or ",
 Cell[BoxData["\"\<Failed\>\""], "InlineFormula",ExpressionUUID->
  "9f74705a-14bb-4e7a-83fb-3918a556c044"],
 ")."
}], "Notes",ExpressionUUID->"7899e8cb-f11a-42bd-af3a-0d9337d4b6d6"],

Cell[TextData[{
 "The submission carries the per-classical-bit to original-qubit map captured \
at transpile time into the ",
 Cell[BoxData[
  ButtonBox["IBMJob",
   BaseStyle->"Link",
   ButtonData->"paclet:Wolfram/QuantumFramework/ref/IBMJob"]], 
  "InlineFormula",ExpressionUUID->"27660917-ef4f-4cbd-a2f3-820425fa0900"],
 " as ",
 Cell[BoxData["\"\<MeasuredQubits\>\""], "InlineFormula",ExpressionUUID->
  "ce595bb3-cf2a-4db6-b586-6e27ce42d90d"],
 ", so the returned samples decode into ascending-qubit order regardless of \
how the backend lays out and routes the circuit."
}], "Notes",ExpressionUUID->"48c98fee-a74a-4ffe-a23d-d42d3db05dab"],

Cell[TextData[{
 StyleBox["backend", "TI"],
 " defaults to ",
 Cell[BoxData[
 "Automatic"], "InlineFormula",ExpressionUUID->
  "429c8d2f-a53c-4e76-b2b8-60a0c58eba5b"],
 ", the first backend in ",
 Cell[BoxData[
  RowBox[{"so", "[", "\"\<Backends\>\"", "]"}]], "InlineFormula",
  ExpressionUUID->"71a6f78a-fde8-4b65-97cc-c5476d74792f"],
 " for the active connection ",
 StyleBox["so", "TI"],
 "; give a string such as ",
 Cell[BoxData["\"\<ibm_fez\>\""], "InlineFormula",ExpressionUUID->
  "e2de6e59-2888-4811-b040-ac73090d75ad"],
 " to target a specific QPU."
}], "Notes",ExpressionUUID->"e2a82c6c-bf17-4cb4-a211-a5b66ca4471a"],

Cell[TextData[{
 "The job is submitted through the connection's low-level ",
 Cell[BoxData["\"\<RawJobRun\>\""], "InlineFormula",ExpressionUUID->
  "91da1488-594d-4fd9-b993-2da19445288e"],
 " request, which gives full control over the ",
 Cell[BoxData[
  RowBox[{"params", ".", "options"}]], "InlineFormula",ExpressionUUID->
  "c63ff9c7-35f3-43d0-98b5-51152b406166"],
 " block; the user's ",
 Cell[BoxData["\"\<PrimitiveOptions\>\""], "InlineFormula",ExpressionUUID->
  "b37eefeb-aba9-430c-94aa-d4692a5301e5"],
 " tree is deep-merged over the defaults ",
 Cell[BoxData[
  RowBox[{"<|", 
   RowBox[{
    RowBox[{"\"\<default_shots\>\"", " ", "->", " ", "shots"}], ",", " ", 
    RowBox[{"\"\<dynamical_decoupling\>\"", " ", "->", " ", 
     RowBox[{"<|", 
      RowBox[{"\"\<enable\>\"", " ", "->", " ", "True"}], "|>"}]}]}], "|>"}]],
   "InlineFormula",ExpressionUUID->"f336afc8-fd36-471f-9d39-93c430797128"],
 "."
}], "Notes",ExpressionUUID->"c5ffe436-1cb4-4810-ab30-60ffe90f6f45"],

Cell[TextData[{
 "Option keys in ",
 Cell[BoxData["\"\<PrimitiveOptions\>\""], "InlineFormula",ExpressionUUID->
  "73ba8335-db37-46f5-a9c6-24fdd8ed1836"],
 " are written in CamelCase and converted to the service's snake_case keys \
recursively (",
 Cell[BoxData["\"\<DynamicalDecoupling\>\""], "InlineFormula",ExpressionUUID->
  "61aa63d0-1606-4f87-a52d-5e4caa51183a"],
 " to ",
 Cell[BoxData[
 "dynamical_decoupling"], "InlineFormula",ExpressionUUID->
  "06b89dda-472a-44e0-9660-148a6a74a306"],
 "), so the whole IBM Runtime options schema is reachable without a curated \
key list."
}], "Notes",ExpressionUUID->"49882b07-0748-4c42-a10d-79d7f19f6cae"],

