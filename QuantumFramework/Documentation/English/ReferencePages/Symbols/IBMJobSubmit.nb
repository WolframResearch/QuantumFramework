    "2", "TableText",ExpressionUUID->"a8779364-4fdb-464d-803b-fe55d8cbc8a2"], 
    Cell["the OpenQASM version of the submitted ISA circuit, 2 or 3", 
     "TableText",ExpressionUUID->"52dfb879-7303-475a-9d53-5c2061ba8982"]},
   {Cell["      ", "ModInfo",ExpressionUUID->
