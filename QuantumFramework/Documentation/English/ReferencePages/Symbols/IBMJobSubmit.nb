q[143];\nsx q[144];\ncz q[143],q[144];\nrz(7*pi/8) q[143];\ncz q[143],q[136];\
\nsx q[136];\nrz(-7*pi/8) q[136];\nsx q[136];\ncz q[143],q[136];\nsx q[136];\n\
rz(5*pi/8) q[136];\nrz(pi/2) q[144];\nsx q[144];\ncz q[143],q[144];\nsx \
q[144];\nrz(-3*pi/4) q[144];\nsx q[144];\ncz q[143],q[144];\nsx q[143];\n\
rz(pi/2) q[143];\nsx q[144];\nrz(3*pi/4) q[144];\nmeasure q[143] -> c[0];\n\
measure q[144] -> c[1];\nmeasure q[136] -> c[2];"}}, "version" -> 2|>, 
