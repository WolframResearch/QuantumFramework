     " ", "\"\<ibm_fez\>\"", ",", " ", 
    RowBox[{"\"\<Primitive\>\"", " ", "->", " ", "\"\<estimator\>\""}], ",", 
    " ", 
    RowBox[{"\"\<Observable\>\"", " ", "->", " ", "\"\<ZZZ\>\""}], ",", " ", 
    RowBox[{"\"\<Wait\>\"", " ", "->", " ", "True"}]}], "]"}], 
  "[", "\"\<ExpectationValue\>\"", "]"}]], "Input",ExpressionUUID->"b4ecd243-\
d9f5-4154-8d39-73edf64101bb"]
}, Open  ]]
