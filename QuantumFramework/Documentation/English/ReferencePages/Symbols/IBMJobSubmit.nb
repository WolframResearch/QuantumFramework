   RowBox[{"\"\<PrimitiveOptions\>\"", " ", "->", " ", 
    RowBox[{"<|", 
     RowBox[{
      RowBox[{"\"\<DynamicalDecoupling\>\"", " ", "->", " ", 
       RowBox[{"<|", 
        RowBox[{"\"\<Enable\>\"", " ", "->", " ", "False"}], "|>"}]}], ",", 
      " ", 
      RowBox[{"\"\<ResilienceLevel\>\"", " ", "->", " ", "1"}]}], "|>"}]}]}], 
