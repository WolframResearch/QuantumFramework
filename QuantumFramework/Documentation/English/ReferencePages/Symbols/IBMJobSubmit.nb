Cell["\<\
With an active IBM Quantum Platform connection, submit a circuit and get back \
a job handle (the call returns immediately, while the job sits in the queue):\
\
\>", "ExampleText",ExpressionUUID->"d0578df0-8e09-47c9-9e25-27d3fe28adb2"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"job", " ", "=", " ", 
  RowBox[{"IBMJobSubmit", "[", 
   RowBox[{
    RowBox[{"QuantumCircuitOperator", "[", 
     RowBox[{"{", 
      RowBox[{"\"\<GHZ\>\"", ",", " ", 
       RowBox[{"\"\<Fourier\>\"", "[", "3", "]"}], ",", " ", 
       RowBox[{"{", 
        RowBox[{"1", ",", " ", "2", ",", " ", "3"}], "}"}]}], "}"}], "]"}], ",",
     " ", "\"\<ibm_fez\>\""}], "]"}]}]], "Input",
 CellLabel->"In[6]:=",ExpressionUUID->"c68fafb2-b39a-461d-a95c-aadbc8bd95d1"],

