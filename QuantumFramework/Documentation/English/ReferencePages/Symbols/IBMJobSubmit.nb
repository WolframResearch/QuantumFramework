 Cell[BoxData["\"\<PrimitiveOptions\>\""], "InlineFormula",ExpressionUUID->
  "0bc50c25-2362-4c11-8247-379e53905b54"],
 ", given in CamelCase and converted to the service's snake_case keys (here \
turning off dynamical decoupling and selecting a resilience level):"
}], "ExampleText",ExpressionUUID->"39728edc-90e5-4684-b2ff-c685ffcd8e8b"],

Cell[BoxData[
 RowBox[{"IBMJobSubmit", "[", 
  RowBox[{
