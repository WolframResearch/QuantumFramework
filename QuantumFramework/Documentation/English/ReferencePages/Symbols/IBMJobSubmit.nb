Notebook[{

Cell[CellGroupData[{
Cell["IBMJobSubmit", "ObjectName",
 CellID->1224892054,ExpressionUUID->"8393d601-4014-44ba-afc9-60862df940ec"],

Cell[TextData[{
 Cell["   ", "ModInfo",ExpressionUUID->"15e09b03-f3f6-41cb-8040-f426e36869e7"],
 Cell[BoxData[
  RowBox[{
   ButtonBox["IBMJobSubmit",
    BaseStyle->"Link",
    ButtonData->"paclet:Wolfram/QuantumFramework/ref/IBMJobSubmit"], "[", 
   StyleBox["circ", "TI"], "]"}]], "InlineFormula",ExpressionUUID->
  "ac040eb1-e37b-41fe-abb8-f5e3ef0d5429"],
 " ",
 "submits the quantum circuit ",
 StyleBox["circ", "TI"],
 " to the default backend of the active IBM Quantum Platform connection and \
gives an ",
 Cell[BoxData[
  ButtonBox["IBMJob",
   BaseStyle->"Link",
   ButtonData->"paclet:Wolfram/QuantumFramework/ref/IBMJob"]], 
  "InlineFormula",ExpressionUUID->"edc9107a-0dd8-4eb8-8635-e0cdcb43de4a"],
 " handle.",
 "\n",
 Cell["   ", "ModInfo",ExpressionUUID->"c941df0a-0d6f-447c-9c0d-35e99cab1fb1"],
 Cell[BoxData[
  RowBox[{
   ButtonBox["IBMJobSubmit",
    BaseStyle->"Link",
    ButtonData->"paclet:Wolfram/QuantumFramework/ref/IBMJobSubmit"], "[", 
   RowBox[{
    StyleBox["circ", "TI"], ",", 
    " ", "\"\<\!\(\*StyleBox[\"backend\", \"TI\"]\)\>\""}], "]"}]], 
  "InlineFormula",ExpressionUUID->"9f8e8cc2-dfbe-44e1-a412-4980c9fa4ec8"],
 " ",
 "submits ",
 StyleBox["circ", "TI"],
 " to the named backend.",
 "\n",
 Cell["   ", "ModInfo",ExpressionUUID->"3b04c2aa-d9e9-4d46-bd9d-80f9ae8d4b60"],
 Cell[BoxData[
  RowBox[{
   ButtonBox["IBMJobSubmit",
    BaseStyle->"Link",
    ButtonData->"paclet:Wolfram/QuantumFramework/ref/IBMJobSubmit"], "[", 
   RowBox[{
    StyleBox["circ", "TI"], ",", " ", 
    StyleBox["backend", "TI"], ",", " ", 
    StyleBox["opts", "TI"]}], "]"}]], "InlineFormula",ExpressionUUID->
  "4f706996-a81f-4429-952f-a86ac405ffc4"],
 " ",
 "submits with the options ",
 StyleBox["opts", "TI"],
 ", such as the primitive, the number of shots and the pass-through primitive \
option tree."
}], "Usage",ExpressionUUID->"546c24c4-8e67-480c-8fce-4d2a700785f3"],

Cell[TextData[{
 StyleBox["circ", "TI"],
 " is a ",
 Cell[BoxData[
  ButtonBox["QuantumCircuitOperator",
   BaseStyle->"Link",
   ButtonData->"paclet:Wolfram/QuantumFramework/ref/QuantumCircuitOperator"]],
   "InlineFormula",ExpressionUUID->"c2fdd872-fdf2-4b7d-bb92-f8747a12f2e9"],
 ". It is transpiled to an ISA OpenQASM program against the chosen backend \
through ",
 Cell[BoxData[
  ButtonBox["QuantumQASM",
   BaseStyle->"Link",
   ButtonData->"paclet:Wolfram/QuantumFramework/ref/QuantumQASM"]], 
  "InlineFormula",ExpressionUUID->"7b3facc0-d891-4b72-af9d-885c809f86a1"],
 " (the ",
 Cell[BoxData[
  RowBox[{"\"\<Provider\>\"", " ", "->", " ", "\"\<IBMProvider\>\""}]], 
  "InlineFormula",ExpressionUUID->"d59dae46-d318-4efd-8150-291a4226659c"],
 " path) before submission."
}], "Notes",ExpressionUUID->"0beeeb8a-c88b-4a4e-b2de-59ab4aa2caea"],

Cell[TextData[{
 Cell[BoxData[
 "IBMJobSubmit"], "InlineFormula",ExpressionUUID->
  "7961e615-ae78-4e07-8b70-f095d642759c"],
 " requires an ",
 StyleBox["active",
  FontWeight->"Bold"],
 " service connection: it consults ",
 Cell[BoxData[
  RowBox[{
  "ServiceFramework`GetDefaultServiceObject", 
   "[", "\"\<IBMQuantumPlatform\>\"", "]"}]], "InlineFormula",ExpressionUUID->
  "e9f859bd-4543-4ae8-9103-689fb958291b"],
 " and never creates a connection or prompts for credentials. Run ",
 Cell[BoxData[
  RowBox[{
   ButtonBox["ServiceConnect",
    BaseStyle->"Link"], "[", "\"\<IBMQuantumPlatform\>\"", "]"}]], 
  "InlineFormula",ExpressionUUID->"0e7285a0-e2ff-4adf-aa44-015be1da5db4"],
 " first (see the ",
 "Sending Queries to IBM QPUs",
 " tech note). With no active connection it returns a ",
 Cell[BoxData[
  ButtonBox["Failure",
   BaseStyle->"Link",
   ButtonData->"paclet:ref/Failure"]], "InlineFormula",ExpressionUUID->
  "d093afe3-5f03-4d5f-bfc8-e0e9c342bc5a"],
 " and never submits."
}], "Notes",ExpressionUUID->"5a8af258-4805-4cb6-a971-7d4236e74806"],

Cell[TextData[{
 Cell[BoxData[
 "IBMJobSubmit"], "InlineFormula",ExpressionUUID->
  "8361c1d8-714f-4724-91b6-f2e417c7e05b"],
 " returns immediately with an asynchronous ",
 Cell[BoxData[
  ButtonBox["IBMJob",
   BaseStyle->"Link",
   ButtonData->"paclet:Wolfram/QuantumFramework/ref/IBMJob"]], 
  "InlineFormula",ExpressionUUID->"8ab05536-d2d6-4d53-9e55-93f86b698d96"],
 " handle whose ",
 Cell[BoxData["\"\<Status\>\""], "InlineFormula",ExpressionUUID->
  "56532614-2b40-488d-92e9-79164db65dc2"],
 " is whatever the service reports (typically ",
 Cell[BoxData["\"\<Queued\>\""], "InlineFormula",ExpressionUUID->
  "350bfc3a-cfc3-42ed-9e4f-eb88c10a300d"],
 "). Query the handle later, or pass ",
 Cell[BoxData[
  RowBox[{"\"\<Wait\>\"", " ", "->", " ", "True"}]], "InlineFormula",
  ExpressionUUID->"21ab7c3c-fbb6-4166-bf5d-97e5f1109927"],
 " to block until the job reaches a terminal status (",
 Cell[BoxData["\"\<Completed\>\""], "InlineFormula",ExpressionUUID->
  "9ac2cb4a-c8b8-4516-a4da-ad75c1bf4bd1"],
 ", ",
 Cell[BoxData["\"\<Cancelled\>\""], "InlineFormula",ExpressionUUID->
  "649ab6d8-143c-467f-b160-314b82c195cc"],
 " or ",
 Cell[BoxData["\"\<Failed\>\""], "InlineFormula",ExpressionUUID->
  "933dc387-5a3b-4c81-8de8-d5ec6e2bca3a"],
 ")."
}], "Notes",ExpressionUUID->"49b5d1a1-d2a2-428e-973a-d0d054c5fa30"],

Cell[TextData[{
 "The submission carries the per-classical-bit to original-qubit map captured \
at transpile time into the ",
 Cell[BoxData[
  ButtonBox["IBMJob",
   BaseStyle->"Link",
   ButtonData->"paclet:Wolfram/QuantumFramework/ref/IBMJob"]], 
  "InlineFormula",ExpressionUUID->"8288f861-cdaf-4b77-a9a8-27b56e2fbce7"],
 " as ",
 Cell[BoxData["\"\<MeasuredQubits\>\""], "InlineFormula",ExpressionUUID->
  "2251e21a-740b-4c8f-8914-f8f7fedbd52f"],
 ", so the returned samples decode into ascending-qubit order regardless of \
how the backend lays out and routes the circuit."
}], "Notes",ExpressionUUID->"4ee0743d-8de7-4a4b-804a-bab16811462b"],

Cell[TextData[{
 StyleBox["backend", "TI"],
 " defaults to ",
 Cell[BoxData[
 "Automatic"], "InlineFormula",ExpressionUUID->
  "6ce00ae4-49f0-49bf-a5df-a6073040101a"],
 ", the first backend in ",
 Cell[BoxData[
  RowBox[{"so", "[", "\"\<Backends\>\"", "]"}]], "InlineFormula",
  ExpressionUUID->"1e33058a-54e0-4eca-b83e-ef553511e4d9"],
 " for the active connection ",
 StyleBox["so", "TI"],
 "; give a string such as ",
 Cell[BoxData["\"\<ibm_fez\>\""], "InlineFormula",ExpressionUUID->
  "cab8b11d-d39c-4c0f-9ad5-951654791c23"],
 " to target a specific QPU."
}], "Notes",ExpressionUUID->"719de75c-a8d8-415b-8961-90fa5d03fa0a"],

Cell[TextData[{
 "The job is submitted through the connection's low-level ",
 Cell[BoxData["\"\<RawJobRun\>\""], "InlineFormula",ExpressionUUID->
  "eecaf3d3-477a-4c0b-ae22-ff34501fa4e9"],
 " request, which gives full control over the ",
 Cell[BoxData[
  RowBox[{"params", ".", "options"}]], "InlineFormula",ExpressionUUID->
  "78477435-c504-4568-89c7-5f83a0ed3cfd"],
 " block; the user's ",
 Cell[BoxData["\"\<PrimitiveOptions\>\""], "InlineFormula",ExpressionUUID->
  "4575d81e-2918-4508-adab-d06f536599fc"],
 " tree is deep-merged over the defaults ",
 Cell[BoxData[
  RowBox[{"<|", 
   RowBox[{
    RowBox[{"\"\<default_shots\>\"", " ", "->", " ", "shots"}], ",", " ", 
    RowBox[{"\"\<dynamical_decoupling\>\"", " ", "->", " ", 
     RowBox[{"<|", 
      RowBox[{"\"\<enable\>\"", " ", "->", " ", "True"}], "|>"}]}]}], "|>"}]],
   "InlineFormula",ExpressionUUID->"4ea3f1a8-564d-4287-b122-adf303e1cc18"],
 "."
}], "Notes",ExpressionUUID->"6e4c5c0a-165b-461e-8fd2-9498c75a5dc3"],

Cell[TextData[{
 "Option keys in ",
 Cell[BoxData["\"\<PrimitiveOptions\>\""], "InlineFormula",ExpressionUUID->
  "58a0f672-0c93-4a85-8c4e-3c6921fd44e8"],
 " are written in CamelCase and converted to the service's snake_case keys \
recursively (",
 Cell[BoxData["\"\<DynamicalDecoupling\>\""], "InlineFormula",ExpressionUUID->
  "08010cff-1855-4f34-9978-f703970ce217"],
 " to ",
 Cell[BoxData[
 "dynamical_decoupling"], "InlineFormula",ExpressionUUID->
  "c1ca42ba-8afb-4694-93a3-df9c2be32db6"],
 "), so the whole IBM Runtime options schema is reachable without a curated \
key list."
}], "Notes",ExpressionUUID->"d0731242-498c-4015-ad13-40251f5c79a9"],

Cell[BoxData[GridBox[{
   {Cell["      ", "ModInfo",ExpressionUUID->
     "474001bc-70dc-41b8-84ad-0ec61406c2a3"], Cell["Option", "TableText",
     FontWeight->Bold,ExpressionUUID->"88a2cc1c-47b8-4e6f-9c0d-496e2d32d3d5"],
