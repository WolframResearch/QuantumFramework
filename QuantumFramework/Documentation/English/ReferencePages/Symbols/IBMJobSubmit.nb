Cell[CellGroupData[{

Cell["\t", "ExampleDelimiter",ExpressionUUID->"3bec505a-410f-4cc4-99c3-141508078789"],

Cell[TextData[{
 "Reach into the IBM Runtime options schema through ",
 Cell[BoxData["\"\<PrimitiveOptions\>\""], "InlineFormula",ExpressionUUID->
  "0bc50c25-2362-4c11-8247-379e53905b54"],
 ", given in CamelCase and converted to the service's snake_case keys (here \
turning off dynamical decoupling and selecting a resilience level):"
}], "ExampleText",ExpressionUUID->"39728edc-90e5-4684-b2ff-c685ffcd8e8b"],

Cell[BoxData[
 RowBox[{"IBMJobSubmit", "[", 
  RowBox[{
   RowBox[{"QuantumCircuitOperator", "[", 
    RowBox[{"{", 
     RowBox[{"\"\<GHZ\>\"", ",", " ", 
      RowBox[{"{", 
       RowBox[{"1", ",", " ", "2", ",", " ", "3"}], "}"}]}], "}"}], "]"}], ",",
    " ", "\"\<ibm_fez\>\"", ",", "\n", "  ", 
   RowBox[{"\"\<PrimitiveOptions\>\"", " ", "->", " ", 
    RowBox[{"<|", 
     RowBox[{
      RowBox[{"\"\<DynamicalDecoupling\>\"", " ", "->", " ", 
       RowBox[{"<|", 
        RowBox[{"\"\<Enable\>\"", " ", "->", " ", "False"}], "|>"}]}], ",", 
      " ", 
      RowBox[{"\"\<ResilienceLevel\>\"", " ", "->", " ", "1"}]}], "|>"}]}]}], 
  "]"}]], "Input",ExpressionUUID->"3c1c74a8-cf4b-4e8b-8179-2de59bdf4f9b"]
}, Open  ]],

Cell[CellGroupData[{

Cell["\t", "ExampleDelimiter",ExpressionUUID->"0a841b5b-9938-48ee-ba91-c07bde9444c2"],

Cell[TextData[{
 "Submit an ",
 Cell[BoxData["\"\<estimator\>\""], "InlineFormula",ExpressionUUID->
  "60656f21-600c-4cf7-ad0d-8a057cb43f50"],
 " job with an observable instead of a sampler job. The observable is laid \
out onto the transpiled circuit, so a 3-qubit ",
 Cell[BoxData["\"\<ZZZ\>\""], "InlineFormula",ExpressionUUID->
  "5c607660-d6fe-4005-8582-67a35b7820c4"],
 " is accepted against a many-qubit backend:"
}], "ExampleText",ExpressionUUID->"f1d021f1-ed7c-49c8-81d2-68a2651a0cf3"],

Cell[BoxData[
 RowBox[{"IBMJobSubmit", "[", 
  RowBox[{
   RowBox[{"QuantumCircuitOperator", "[", 
    RowBox[{"{", 
     RowBox[{"\"\<GHZ\>\"", ",", " ", 
      RowBox[{"{", 
       RowBox[{"1", ",", " ", "2", ",", " ", "3"}], "}"}]}], "}"}], "]"}], ",",
    " ", "\"\<ibm_fez\>\"", ",", " ", 
   RowBox[{"\"\<Primitive\>\"", " ", "->", " ", "\"\<estimator\>\""}], ",", 
   " ", 
   RowBox[{"\"\<Observable\>\"", " ", "->", " ", "\"\<ZZZ\>\""}]}], 
  "]"}]], "Input",ExpressionUUID->"33f1ee34-3cae-4a3c-bf52-a5d0d6c1969d"]
}, Open  ]],

Cell[CellGroupData[{

Cell["\t", "ExampleDelimiter",ExpressionUUID->"deab9389-7c9f-447a-9a48-829f29f7dd15"],

Cell[TextData[{
 "Once an estimator job completes, its default output and ",
 Cell[BoxData["\"\<ExpectationValue\>\""], "InlineFormula",ExpressionUUID->
  "e9a79a2d-8edf-4667-be76-81e526394791"],
 " are the qiskit-decoded expectation value of the observable, with ",
 Cell[BoxData["\"\<StandardErrors\>\""], "InlineFormula",ExpressionUUID->
  "18768193-d62b-4861-be3b-2de89100eff9"],
 " giving the per-observable standard error:"
}], "ExampleText",ExpressionUUID->"0a555b0f-93ed-4aad-a1b4-1aaa107598a1"],

