Cell["\<\
With an active IBM Quantum Platform connection, submit a circuit and get back \
a job handle (the call returns immediately, while the job sits in the queue):\
\
\>", "ExampleText",ExpressionUUID->"d0578df0-8e09-47c9-9e25-27d3fe28adb2"],

Cell[BoxData[
 RowBox[{"job", " ", "=", " ", 
  RowBox[{"IBMJobSubmit", "[", 
   RowBox[{
    RowBox[{"QuantumCircuitOperator", "[", 
     RowBox[{"{", 
      RowBox[{"\"\<GHZ\>\"", ",", " ", 
       RowBox[{"\"\<Fourier\>\"", "[", "3", "]"}], ",", " ", 
       RowBox[{"{", 
        RowBox[{"1", ",", " ", "2", ",", " ", "3"}], "}"}]}], "}"}], "]"}], ",",
     " ", "\"\<ibm_fez\>\""}], "]"}]}]], "Input",ExpressionUUID->"c68fafb2-\
b39a-461d-a95c-aadbc8bd95d1"],

Cell["\t", "ExampleDelimiter",ExpressionUUID->"c16903ee-eeab-4688-8785-bd6346c17e4f"],

Cell["\<\
Once the job completes, the handle's default output is the measurement \
reconstructed from the hardware counts, in the Wolfram Language qubit order:\
\>", "ExampleText",ExpressionUUID->"74c3672a-eb65-4833-8d0d-63afce8776db"],

Cell[BoxData[
 RowBox[{
  RowBox[{"job", "[", "\"\<Refresh\>\"", "]"}], "[", "]"}]], "Input",Expressio\
nUUID->"f6252907-b6e6-4111-9a1e-d7faf8677a4a"],

