Notebook[{

Cell[CellGroupData[{
Cell["IBMJobSubmit", "ObjectName",
 CellID->1224892054,ExpressionUUID->"8393d601-4014-44ba-afc9-60862df940ec"],

Cell[TextData[{
 Cell["   ", "ModInfo",ExpressionUUID->"64adaaf2-bba1-40ae-a90a-6c39cd0729a4"],
 Cell[BoxData[
  RowBox[{"IBMJobSubmit", "[", 
   StyleBox["circ", "TI"], "]"}]], "InlineFormula",ExpressionUUID->
  "764c7473-b611-4c49-8fb1-95d52c538344"],
 " ",
 "submits the quantum circuit ",
 StyleBox["circ", "TI"],
 " to the default backend of the active IBM Quantum Platform connection and \
gives an ",
 Cell[BoxData[
 "IBMJob"], "InlineFormula",ExpressionUUID->
  "33e335ca-d12e-43e0-91b1-84f45a6b4b0c"],
 " handle.",
 "\n",
 Cell["   ", "ModInfo",ExpressionUUID->"d47db206-7b19-4ae0-a698-a73f10aeeda9"],
 Cell[BoxData[
  RowBox[{"IBMJobSubmit", "[", 
   RowBox[{
    StyleBox["circ", "TI"], ",", 
    " ", "\"\<\!\(\*StyleBox[\"backend\", \"TI\"]\)\>\""}], "]"}]], 
  "InlineFormula",ExpressionUUID->"80420efa-5473-43a1-af31-616ecfff9000"],
 " ",
 "submits ",
 StyleBox["circ", "TI"],
 " to the named backend.",
 "\n",
 Cell["   ", "ModInfo",ExpressionUUID->"08370e09-9801-4e58-92f1-0adb356e8471"],
 Cell[BoxData[
  RowBox[{"IBMJobSubmit", "[", 
   RowBox[{
    StyleBox["circ", "TI"], ",", " ", 
    StyleBox["backend", "TI"], ",", " ", 
    StyleBox["opts", "TI"]}], "]"}]], "InlineFormula",ExpressionUUID->
  "59fe42c8-b649-4cf6-a50e-b057cdfd1c4c"],
 " ",
 "submits with the options ",
 StyleBox["opts", "TI"],
 ", such as the primitive, the number of shots and the pass-through primitive \
option tree."
}], "Usage",ExpressionUUID->"ff25294a-b0d9-473c-9405-e449e7e8334b"],

Cell[TextData[{
 StyleBox["circ", "TI"],
 " is a ",
 Cell[BoxData[
 "QuantumCircuitOperator"], "InlineFormula",ExpressionUUID->
  "7330d490-fa7b-4d28-8054-aa09a5640eba"],
 ". It is transpiled against the chosen backend and submitted through \
qiskit's own ",
 Cell[BoxData[
 "SamplerV2"], "InlineFormula",ExpressionUUID->
  "eb5bd20d-7ea0-4b02-bc61-8729b47eefe3"],
 " / ",
 Cell[BoxData[
 "EstimatorV2"], "InlineFormula",ExpressionUUID->
  "43db8faa-a0a3-49f5-8b6f-df1ead74d945"],
 " primitive, so qiskit owns every wire format: the circuit serialization, \
the estimator observable's layout, and the primitive options schema. The job \
is launched without blocking on its result, so the handle returns while the \
job is still queued."
}], "Notes",ExpressionUUID->"a23c449f-6cd3-44bd-8a28-b8f5392d871d"],

Cell[TextData[{
 Cell[BoxData[
 "IBMJobSubmit"], "InlineFormula",ExpressionUUID->
  "b1a160cc-6836-44c7-be1a-4a316d909957"],
 " requires an ",
 StyleBox["active",
  FontWeight->"Bold"],
 " service connection: it consults ",
 Cell[BoxData[
  RowBox[{
  "ServiceFramework`GetDefaultServiceObject", 
   "[", "\"\<IBMQuantumPlatform\>\"", "]"}]], "InlineFormula",ExpressionUUID->
  "f25ef4dd-4243-44cd-80d5-59ce92aa4d02"],
 " and never creates a connection or prompts for credentials. Run ",
 Cell[BoxData[
  RowBox[{
   ButtonBox["ServiceConnect",
    BaseStyle->"Link"], "[", "\"\<IBMQuantumPlatform\>\"", "]"}]], 
  "InlineFormula",ExpressionUUID->"efa27b43-a0bd-48e6-b8c0-3d56ecb267b0"],
 " first (see the ",
 "Sending Queries to IBM QPUs",
 " tech note). With no active connection it returns a ",
 Cell[BoxData[
  ButtonBox["Failure",
   BaseStyle->"Link",
   ButtonData->"paclet:ref/Failure"]], "InlineFormula",ExpressionUUID->
  "ba544737-cf9d-4e39-8120-46a5cc524c08"],
 " and never submits."
}], "Notes",ExpressionUUID->"8ced873f-fe70-4b4b-8397-aecc34eec5ba"],

Cell[TextData[{
 Cell[BoxData[
 "IBMJobSubmit"], "InlineFormula",ExpressionUUID->
  "487e9d95-0865-45e7-8b86-fe4aeee2d68a"],
 " returns immediately with an asynchronous ",
 Cell[BoxData[
 "IBMJob"], "InlineFormula",ExpressionUUID->
  "fcc9b513-6076-48d1-becc-50f618ab0144"],
 " handle whose ",
 Cell[BoxData["\"\<Status\>\""], "InlineFormula",ExpressionUUID->
  "65ccc25c-bc18-46ed-a584-a5fc7ffae372"],
 " is whatever the service reports (typically ",
 Cell[BoxData["\"\<Queued\>\""], "InlineFormula",ExpressionUUID->
  "2faf60a5-a079-4c0f-bd86-b73adb0343c2"],
 "). Query the handle later, or pass ",
 Cell[BoxData[
  RowBox[{"\"\<Wait\>\"", " ", "->", " ", "True"}]], "InlineFormula",
  ExpressionUUID->"3d2d455c-3381-4cdf-b856-258f2ee0d5a8"],
 " to block until the job reaches a terminal status (",
 Cell[BoxData["\"\<Completed\>\""], "InlineFormula",ExpressionUUID->
  "683a885b-a862-4014-93a1-1929813523b7"],
 ", ",
 Cell[BoxData["\"\<Cancelled\>\""], "InlineFormula",ExpressionUUID->
  "70a96e62-b9c9-4623-b8b4-51b3f8e1b8b2"],
 " or ",
 Cell[BoxData["\"\<Failed\>\""], "InlineFormula",ExpressionUUID->
  "76e6586c-89a2-474f-9512-879ff09a6a30"],
 ")."
}], "Notes",ExpressionUUID->"7c6f2e3f-2f99-4bd1-bbe2-1ccb4a36ba7c"],

Cell[TextData[{
 "For a sampler job the submission carries the per-classical-bit to \
original-qubit map captured at transpile time into the ",
 Cell[BoxData[
 "IBMJob"], "InlineFormula",ExpressionUUID->
  "f0cfad00-0573-4f78-ba4d-fcfa8bc03302"],
 " as ",
 Cell[BoxData["\"\<MeasuredQubits\>\""], "InlineFormula",ExpressionUUID->
  "981c57c1-9e3e-4e50-8eba-3a0c22b2f2c0"],
 ", so the returned samples decode into ascending-qubit order regardless of \
how the backend lays out and routes the circuit."
}], "Notes",ExpressionUUID->"60d60d9c-c115-4700-8669-9125a7754aaa"],

Cell[TextData[{
 StyleBox["backend", "TI"],
 " defaults to ",
 Cell[BoxData[
 "Automatic"], "InlineFormula",ExpressionUUID->
  "24195708-cc8a-4f2b-9743-c2d9bd4ccc5f"],
 ", the first backend in ",
 Cell[BoxData[
  RowBox[{"so", "[", "\"\<Backends\>\"", "]"}]], "InlineFormula",
  ExpressionUUID->"fb8bce4d-1526-4857-9a1b-c819f4e8398d"],
 " for the active connection ",
 StyleBox["so", "TI"],
 "; give a string such as ",
 Cell[BoxData["\"\<ibm_fez\>\""], "InlineFormula",ExpressionUUID->
  "17580cfc-6d40-46f4-814f-4f164d9a03fa"],
 " to target a specific QPU."
}], "Notes",ExpressionUUID->"c2873169-0b13-4e51-bf5d-62548416397a"],

Cell[TextData[{
 "For the ",
 Cell[BoxData["\"\<estimator\>\""], "InlineFormula",ExpressionUUID->
  "42b2730e-30ae-457a-8ea4-cfde824732cc"],
 " primitive the ",
 Cell[BoxData["\"\<Observable\>\""], "InlineFormula",ExpressionUUID->
  "b57b2583-684d-43f8-8f8a-ce7232a568af"],
 " is built into a qiskit ",
 Cell[BoxData[
 "SparsePauliOp"], "InlineFormula",ExpressionUUID->
  "478931a7-df9f-4239-9311-9cb6dbf7ab5b"],
 " and mapped onto the transpiled circuit's layout, which both reorders and \
",
 StyleBox["widens",
  FontWeight->"Bold"],
 " it to the backend's physical register. Submitting the bare logical-width \
observable is what an IBM Runtime estimator rejects (error 1501, \"the number \
of qubits of the circuit does not match the number of qubits of the \
observable\")."
}], "Notes",ExpressionUUID->"692d634e-05d3-452a-a54f-fbf8f6b5dc16"],

Cell[TextData[{
 "The ",
 Cell[BoxData["\"\<PrimitiveOptions\>\""], "InlineFormula",ExpressionUUID->
  "811e305a-11be-4643-8796-7632952561f6"],
 " tree is applied onto the qiskit primitive's own options object over the \
defaults ",
 Cell[BoxData[
  RowBox[{"default_shots", " ", "->", " ", "shots"}]], "InlineFormula",
  ExpressionUUID->"84ed4897-6ca6-4575-8996-e109929f2b66"],
 " and ",
 Cell[BoxData[
  RowBox[{
   RowBox[{"dynamical_decoupling", ".", "enable"}], " ", "->", " ", "True"}]],
   "InlineFormula",ExpressionUUID->"685b34bf-483e-41aa-a2e9-4867c52e8290"],
 ", so qiskit validates the option schema. Keys are written in CamelCase and \
converted to qiskit's snake_case attributes recursively (",
 Cell[BoxData["\"\<DynamicalDecoupling\>\""], "InlineFormula",ExpressionUUID->
  "ce3a689d-8a7b-47e8-8b14-c731cf1a5616"],
 " to ",
 Cell[BoxData[
 "dynamical_decoupling"], "InlineFormula",ExpressionUUID->
  "5ea089bc-5e01-4582-967c-36f58a53906a"],
 "), so the whole options schema is reachable without a curated key list."
}], "Notes",ExpressionUUID->"10b094f2-1fcd-4e79-a432-e811b96be20b"],

Cell[BoxData[GridBox[{
   {Cell["      ", "ModInfo",ExpressionUUID->
     "35e5c495-c60e-46e2-9a2f-01b4fa658af9"], Cell["Option", "TableText",
     FontWeight->Bold,ExpressionUUID->"f6a546ac-a4df-4df3-80cb-1cf1fb42f638"],
     Cell["Default value", "TableText",
     FontWeight->Bold,ExpressionUUID->"35cfc2e6-5219-4fbd-b592-900c08dcd9b0"],
     Cell["Description", "TableText",
     FontWeight->Bold,ExpressionUUID->"93d11abc-9cfd-4a85-8f86-29ea3622fd11"]},
   {Cell["      ", "ModInfo",ExpressionUUID->
     "e78cb156-0115-41a3-9ad1-f52e7ef4819e"], Cell[TextData[Cell[
    BoxData["\"\<Primitive\>\""], "InlineFormula",ExpressionUUID->
     "f9189bd0-84f2-485b-bdc2-4ee75fc4205e"]], "TableText",ExpressionUUID->
     "c13177bc-5846-4693-ac85-91af64c6bb08"], Cell[TextData[Cell[
    BoxData["\"\<sampler\>\""], "InlineFormula",ExpressionUUID->
     "029d1ce1-09d3-4ea1-8f19-a80cba04b806"]], "TableText",ExpressionUUID->
     "f8c17958-455e-41b9-95c4-d91d5dfc40ed"], Cell[TextData[{
     "the IBM Runtime primitive, ",
     Cell[
     BoxData["\"\<sampler\>\""], "InlineFormula",ExpressionUUID->
      "bc0dfc95-0216-4807-891a-6d27ee208e9d"],
     " or ",
     Cell[
     BoxData["\"\<estimator\>\""], "InlineFormula",ExpressionUUID->
      "e9bfb0c5-168a-41fd-9c89-9e5f555c0a9a"]
    }], "TableText",ExpressionUUID->"38305d2a-9fbe-4737-82e9-19179ce63fe5"]},
   {Cell["      ", "ModInfo",ExpressionUUID->
     "2d4bdc2b-1e73-4568-8805-cf6b9ff394b2"], Cell[TextData[Cell[
    BoxData["\"\<Shots\>\""], "InlineFormula",ExpressionUUID->
     "6286ba39-94a9-42b0-a99f-b7aef6b5168d"]], "TableText",ExpressionUUID->
     "953d3734-a003-442c-811f-bdcef549640b"], Cell[
    "4096", "TableText",ExpressionUUID->
     "32156956-55a8-4d0a-835e-859fe68c4292"], Cell[TextData[{
     "the number of shots (",
     Cell[BoxData[
     "default_shots"], "InlineFormula",ExpressionUUID->
      "0344560b-c6d5-44d7-95da-9857743e83c5"],
     ")"
    }], "TableText",ExpressionUUID->"1f9d158b-7c1c-4fa9-8891-6c6a78b4833f"]},
   {Cell["      ", "ModInfo",ExpressionUUID->
     "239b3768-1dd7-4a47-be30-e0023e9c44ab"], Cell[TextData[Cell[
    BoxData["\"\<Observable\>\""], "InlineFormula",ExpressionUUID->
     "9fa6c007-0f0f-430f-bd46-df63e0b576d2"]], "TableText",ExpressionUUID->
     "7c15a82f-a057-4d58-bb6b-ea3b93c09623"], Cell[TextData[Cell[
    BoxData["\"\<Z\>\""], "InlineFormula",ExpressionUUID->
     "d9100ed2-982e-4890-9ca7-710a842beb57"]], "TableText",ExpressionUUID->
     "ac85e0ac-6224-409b-952c-9090149a5db7"], Cell[TextData[{
     "the estimator observable: a Pauli string (",
     Cell[
     BoxData["\"\<ZZZ\>\""], "InlineFormula",ExpressionUUID->
      "adfddd25-59f0-4046-bf09-2c03b2627eab"],
     "), a list of Pauli strings, or a list of ",
     Cell[BoxData[
      RowBox[{"{", 
       RowBox[{"pauliString", ",", " ", "coefficient"}], "}"}]], 
      "InlineFormula",ExpressionUUID->"0acb7623-6c59-443b-905c-9927ec05841b"],
     
     " pairs; used only when ",
     Cell[
     BoxData["\"\<Primitive\>\""], "InlineFormula",ExpressionUUID->
      "8d02c307-3ed4-4746-989e-421b60f4d357"],
     " is ",
     Cell[
     BoxData["\"\<estimator\>\""], "InlineFormula",ExpressionUUID->
      "11fd692f-07e9-4ddd-8fa6-f7d853dc2bb7"]
    }], "TableText",ExpressionUUID->"442c52ec-fc87-446d-bbe8-7fc318d07520"]},
   {Cell["      ", "ModInfo",ExpressionUUID->
     "6ff30833-36bb-4994-b069-bc6196fb8b7b"], Cell[TextData[Cell[
    BoxData["\"\<Wait\>\""], "InlineFormula",ExpressionUUID->
     "4a19599b-e382-4bc9-94de-129c2608541d"]], "TableText",ExpressionUUID->
     "e7bec3ac-fa13-4e11-b04c-7aba3153f5bd"], Cell[
    "False", "TableText",ExpressionUUID->
     "4d13b564-616c-43d2-829b-aee4d085e3f1"], Cell[
    "whether to block until the job reaches a terminal status", "TableText",
     ExpressionUUID->"25ee7b20-b82d-47c9-829d-b41f33d722cd"]},
   {Cell["      ", "ModInfo",ExpressionUUID->
     "ac1275d7-c817-40f6-856d-df35dcee91de"], Cell[TextData[Cell[
    BoxData["\"\<PrimitiveOptions\>\""], "InlineFormula",ExpressionUUID->
     "cd123b4f-2216-437d-82f7-010e07796123"]], "TableText",ExpressionUUID->
     "bdf411f8-7ae9-416a-993b-ce7b5b012d68"], Cell[TextData[Cell[BoxData[
     RowBox[{"<|", "|>"}]], "InlineFormula",ExpressionUUID->
     "2e368957-0f81-40e3-a076-13561564359b"]], "TableText",ExpressionUUID->
     "ed38eaf7-6cbf-44f8-b5e5-4e88cda8f8eb"], Cell["\<\
an Association of IBM Runtime primitive options, applied onto the qiskit \
primitive's options object over the defaults\
\>", "TableText",ExpressionUUID->"9050a8f8-dcc2-4670-a2ed-22c0abd0c3be"]}
  }]], "3ColumnTableMod",ExpressionUUID->"1b3dd492-c7b5-4f1a-990f-\
b82efa53ae3b"]
}, Open  ]],

