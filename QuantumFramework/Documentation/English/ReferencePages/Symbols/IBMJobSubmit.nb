Cell["\<\
With an active IBM Quantum Platform connection, submit a circuit and get back \
a job handle (the call returns immediately, while the job sits in the queue):\
\
\>", "ExampleText",ExpressionUUID->"eb808cfd-a094-4ac8-b6a2-691e133b6571"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"job", " ", "=", " ", 
  RowBox[{"IBMJobSubmit", "[", 
   RowBox[{
    RowBox[{"QuantumCircuitOperator", "[", 
     RowBox[{"{", 
      RowBox[{"\"\<GHZ\>\"", ",", " ", 
       RowBox[{"\"\<Fourier\>\"", "[", "3", "]"}], ",", " ", 
       RowBox[{"{", 
        RowBox[{"1", ",", " ", "2", ",", " ", "3"}], "}"}]}], "}"}], "]"}], ",",
     " ", "\"\<ibm_fez\>\""}], "]"}]}]], "Input",
 CellLabel->"In[7]:=",ExpressionUUID->"8bfdb86f-596f-468a-91a4-2b443e6f10a4"],

