    BoxData["\"\<Primitive\>\""], "InlineFormula",ExpressionUUID->
     "78c50c27-8f7e-4cc4-a3a9-0b4aa2b57ae3"]], "TableText",ExpressionUUID->
     "bdf903c9-4c3e-4522-8560-d683157c17e4"], Cell[TextData[Cell[
