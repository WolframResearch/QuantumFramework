     "3310505e-76a3-4f29-9410-63a59f36c5f3"]], "TableText",ExpressionUUID->
     "94c959fe-00fe-48f7-acdf-5688f92a8e70"], Cell[TextData[{
     "the IBM Runtime primitive, ",
     Cell[
     BoxData["\"\<sampler\>\""], "InlineFormula",ExpressionUUID->
