Cell[4685, 109, 128, 0, 70, "Output",ExpressionUUID->"964fa390-4c96-488c-99b7-94edd83e4ace"],
Cell[4816, 111, 125, 0, 70, "Text",ExpressionUUID->"b9e3c614-010d-4fb3-b7b1-340bda87d6cf"],
Cell[4944, 113, 509, 14, 70, "Input",ExpressionUUID->"6b7de78d-c129-43f6-a8d7-7fc57f0f738d"],
Cell[5456, 129, 128, 0, 70, "Output",ExpressionUUID->"33b270dc-83bc-4476-ad9b-9e8d78e57543"],
