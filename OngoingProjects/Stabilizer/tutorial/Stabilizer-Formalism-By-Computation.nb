Cell[TextData[{
 "Read off its preparation circuit with the ",
 Cell[BoxData["\"\<Circuit\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "fba5501c-99c1-4c26-bc6e-8a55f841aa0c"],
 " property (a hundred-plus-gate object, so we hold it in ",
 Cell[BoxData["prep"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "bf7b3261-fcea-4788-9ab7-ef469a6a964a"],
 " rather than print it):"
}], "Text",ExpressionUUID->"6bb8de81-643c-4d79-9405-c71fbe3d6351"],

Cell[BoxData[
 RowBox[{
  RowBox[{"prep", " ", "=", " ", 
   RowBox[{"ps10", "[", "\"\<Circuit\>\"", "]"}]}], ";"}]], "Input",
 CellLabel->
  "In[68]:= ",ExpressionUUID->"fa449f18-dea0-47f0-9072-d6a7cb2ebbb2"],

Cell["\<\
then count its gates, which stay polynomial in the number of qubits:\
\>", "Text",ExpressionUUID->"a40b4451-2cd9-4e05-b6cd-c1d2c7e243f8"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Length", " ", "@", " ", 
  RowBox[{"QuantumShortcut", "[", "prep", "]"}]}]], "Input",
 CellLabel->
  "In[69]:= ",ExpressionUUID->"17340d20-a0d3-4a51-87a9-e3d9efdb6c4f"],

Cell[BoxData["136"], "Output",
 CellLabel->
  "Out[69]= ",ExpressionUUID->"dc83b96d-d481-4db2-8b1d-478e23ca1c97"]
}, Open  ]],

Cell[TextData[{
 "The result is an ordinary ",
 Cell[BoxData["QuantumCircuitOperator"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "5b1701ab-e2aa-4752-a332-da5e3785afdd"],
 ". It genuinely builds the state: applied to the all-zeros register it \
reproduces ",
 Cell[BoxData[
  TemplateBox[{
    StyleBox["\[Psi]", "TI"]},
   "Ket"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "8fd4c8a5-2a2a-454c-8bc9-9be19cf4f068"],
 " exactly. At ten qubits a full ",
 Cell[BoxData["QuantumSimilarity"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "1067ac22-7420-4dd2-8778-f37ed938412b"],
 " would form a ",
 Cell[BoxData[
  RowBox[{
   SuperscriptBox["2", "10"], "\[Times]", 
   SuperscriptBox["2", "10"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "07c7c150-560c-401a-bdd1-b8fd4e2203c2"],
 " density matrix, so here we take the cheaper direct state-vector overlap, \
whose magnitude is one:"
}], "Text",ExpressionUUID->"eae94b25-94e3-4b48-8170-07427b1331a2"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Chop", "[", 
  RowBox[{
   RowBox[{"Abs", "[", 
    RowBox[{
     RowBox[{"Conjugate", "[", 
      RowBox[{"Normal", " ", "@", " ", 
       RowBox[{
        RowBox[{"prep", "[", "]"}], "[", "\"\<StateVector\>\"", "]"}]}], 
      "]"}], " ", ".", " ", 
     RowBox[{"Normal", " ", "@", " ", 
      RowBox[{
       RowBox[{"ps10", "[", "\"\<State\>\"", "]"}], "[", "\"\<StateVector\>\"",
        "]"}]}]}], "]"}], " ", "-", " ", "1"}], "]"}]], "Input",
 CellLabel->
  "In[70]:= ",ExpressionUUID->"86df5367-e3b4-482f-a6c5-7c00df907147"],

Cell[BoxData["0"], "Output",
 CellLabel->
  "Out[70]= ",ExpressionUUID->"ec3c9bf1-46ff-44a0-b4ba-0c31a7e4e1ae"]
}, Open  ]],

Cell["\<\
This inverts gate-folding, which goes from circuit to tableau, and it is the \
workhorse behind code encoders: a code state's preparation circuit is exactly \
its encoding circuit.\
\>", "Text",ExpressionUUID->"f55792f4-3c98-456b-834c-fa1922f2e5fe"],

Cell[TextData[{
 "For long Clifford circuits the framework folds the entire gate list through \
a single compiled (C) kernel that operates on a bit-packed, generator-major \
tableau, the same data layout the specialized simulators use. Handing the \
whole gate list to ",
 Cell[BoxData[
  RowBox[{"ps", "[", "gates", "]"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "321cc52b-1a4a-4091-94ae-1a2f130aeb55"],
 " folds it in one such pass. First build a four-thousand-gate random \
Clifford stream on two hundred qubits (kept suppressed, since it is four \
thousand gate specs):"
}], "Text",ExpressionUUID->"e4970ec0-7d43-463f-a2de-56931614239d"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"SeedRandom", "[", "1", "]"}], ";"}], "\n", 
 RowBox[{
  RowBox[{"specs", " ", "=", " ", 
   RowBox[{"Table", "[", "\n", "   ", 
    RowBox[{
     RowBox[{"RandomChoice", "[", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"\"\<H\>\"", " ", "->", " ", 
         RowBox[{"RandomInteger", "[", 
          RowBox[{"{", 
           RowBox[{"1", ",", " ", "200"}], "}"}], "]"}]}], ",", " ", 
        RowBox[{"\"\<S\>\"", " ", "->", " ", 
         RowBox[{"RandomInteger", "[", 
          RowBox[{"{", 
           RowBox[{"1", ",", " ", "200"}], "}"}], "]"}]}], ",", "\n", "     ", 
        RowBox[{"\"\<CNOT\>\"", " ", "->", " ", 
         RowBox[{"RandomSample", "[", 
          RowBox[{
           RowBox[{"Range", "[", "200", "]"}], ",", " ", "2"}], "]"}]}]}], 
       "}"}], "]"}], ",", "\n", "   ", 
     RowBox[{"{", "4000", "}"}]}], "]"}]}], ";"}]}], "Input",
 CellLabel->
  "In[71]:= ",ExpressionUUID->"24d00336-d1b8-4ad6-9d17-97557ff283bd"],

Cell["then fold it and watch the wall-clock:", "Text",ExpressionUUID->"0d645b14-b372-49dd-9676-a795a6cd20ee"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"AbsoluteTiming", "[", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"PauliStabilizer", "[", "200", "]"}], "[", "specs", "]"}], 
    "[", "\"\<Stabilizers\>\"", "]"}], "[", 
   RowBox[{"[", "1", "]"}], "]"}], "]"}]], "Input",
 CellLabel->
  "In[72]:= ",ExpressionUUID->"1dd346c5-c012-4949-9e0a-8bdb0b0b4e84"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
  "0.035933`", 
   ",", "\<\"-\
XYIYZIIZZIXIIZZIYZIZIXYXIXYIXYZZXYXXYIIZZXIXXYIZXYIZYIXIYZZYIIXXZIIXXZYYYZZIXY\
ZIYZIXIYYYYZIXXXYXZZXXXZIIXZIIIIZXYYYXXYXXYXIXXZIZYIXZZXYZZIYIXZXXXIIXZXIYZZYI\
XIXZXXIIZIYIYXIIXIYXYZYZYIXZYIIZXIYIIZIZXZIZ\"\>"}], "}"}]], "Output",
 CellLabel->
  "Out[72]= ",ExpressionUUID->"52d8671c-40ac-4bf1-a8d9-6d3b5731415c"]
}, Open  ]],

Cell[TextData[{
 "That is roughly a quarter of a microsecond per gate, flat in the number of \
qubits, because each gate touches only the machine words of its own column. \
The same engine backs the circuit object: a ",
 Cell[BoxData["QuantumCircuitOperator"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "3e76adef-4caa-4f41-8e41-9a0835ee34fd"],
 " applied with ",
 Cell[BoxData[
  RowBox[{"Method", " ", "->", " ", "\"\<Stabilizer\>\""}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "1bf476f8-e265-40cf-aba3-18d064857a24"],
 " evolves a stabilizer state directly. Build a Bell circuit:"
}], "Text",ExpressionUUID->"eb01b83a-0ee9-492b-8552-150b7861bd11"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"qc", " ", "=", " ", 
  RowBox[{"QuantumCircuitOperator", "[", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"\"\<H\>\"", " ", "->", " ", "1"}], ",", " ", 
     RowBox[{"\"\<CNOT\>\"", " ", "->", " ", 
      RowBox[{"{", 
       RowBox[{"1", ",", " ", "2"}], "}"}]}]}], "}"}], "]"}]}]], "Input",
 CellLabel->
  "In[73]:= ",ExpressionUUID->"5e332abf-91ef-4157-a4ca-eac4ba6f3918"],

