 Cell[BoxData[
  StyleBox["X", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "fe7862ae-d89c-4c5d-bc88-f30b221455f0"],
 " in place of ",
 Cell[BoxData[
  StyleBox["H", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "69c38814-db41-4cbc-ba8b-0e90cb262439"],
 " carries ",
