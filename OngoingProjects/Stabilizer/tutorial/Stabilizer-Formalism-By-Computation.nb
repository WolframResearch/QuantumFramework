Cell["\<\
Two signs now carry the free bits; the third generator is still the bare \
parity check. A small helper reads the bit-string a resolved sample collapses \
to, by locating its one nonzero amplitude:\
\>", "Text",ExpressionUUID->"2e5cca3e-6e5b-4090-aecb-39e9ae935d97"],

Cell[BoxData[
 RowBox[{
  RowBox[{"readBits", "[", "ps_", "]"}], " ", ":=", " ", 
  RowBox[{"First", " ", "@", " ", 
   RowBox[{"Keys", " ", "@", " ", 
    RowBox[{"Select", "[", 
     RowBox[{
      RowBox[{"AssociationThread", "[", 
       RowBox[{
        RowBox[{"Tuples", "[", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{"0", ",", " ", "1"}], "}"}], ",", " ", 
          RowBox[{"ps", "[", "\"\<Qubits\>\"", "]"}]}], "]"}], ",", " ", 
        RowBox[{"Normal", "[", 
         RowBox[{
          RowBox[{"ps", "[", "\"\<State\>\"", "]"}], 
          "[", "\"\<StateVector\>\"", "]"}], "]"}]}], "]"}], ",", " ", 
      RowBox[{
       RowBox[{"#", " ", "!=", " ", "0"}], " ", "&"}]}], "]"}]}]}]}]], "Input",\

 CellLabel->
  "In[63]:= ",ExpressionUUID->"80f97338-5009-45f9-887a-1bb2cdbd917b"],

Cell["\<\
Substituting the two free bits over all four assignments traces out the \
determined third outcome, which is in every case the XOR of the first two:\
\>", "Text",ExpressionUUID->"8ce76491-f383-4e11-b750-664f00fdef4c"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"free", " ", "=", " ", 
   RowBox[{"DeleteDuplicates", " ", "@", " ", 
    RowBox[{"Cases", "[", 
     RowBox[{
      RowBox[{"smPar", "[", "\"\<Phase\>\"", "]"}], ",", " ", 
      RowBox[{"\[FormalS]", "[", "_", "]"}], ",", " ", "Infinity"}], 
     "]"}]}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"readBits", "[", 
    RowBox[{"smPar", "[", 
     RowBox[{"\"\<SubstituteOutcomes\>\"", ",", " ", 
      RowBox[{"Thread", "[", 
       RowBox[{"free", " ", "->", " ", "#"}], "]"}]}], "]"}], "]"}], " ", 
   "&"}], " ", "/@", " ", 
  RowBox[{"Tuples", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"0", ",", " ", "1"}], "}"}], ",", " ", 
    RowBox[{"Length", "[", "free", "]"}]}], "]"}]}]}], "Input",
 CellLabel->
  "In[64]:= ",ExpressionUUID->"8a8c9eda-73a5-4086-bcac-0d32e70b7bc4"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"0", ",", "0", ",", "0"}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{"0", ",", "1", ",", "1"}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{"1", ",", "0", ",", "1"}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{"1", ",", "1", ",", "0"}], "}"}]}], "}"}]], "Output",
 CellLabel->
  "Out[64]= ",ExpressionUUID->"092434c4-6dcf-4c98-873a-e8a394975956"]
}, Open  ]],

Cell[TextData[{
 "The third column is ",
 Cell[BoxData[
  RowBox[{
   SubscriptBox[
    StyleBox["m", "TI"], "3"], "=", 
   SubscriptBox[
    StyleBox["m", "TI"], "1"], "\[CirclePlus]", 
   SubscriptBox[
    StyleBox["m", "TI"], "2"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "bf58e4a2-35ee-4534-b88e-16396f49f30d"],
 " throughout, equivalently ",
 Cell[BoxData[
  RowBox[{
   SubscriptBox[
    StyleBox["m", "TI"], "1"], "\[CirclePlus]", 
   SubscriptBox[
    StyleBox["m", "TI"], "2"], "\[CirclePlus]", 
   SubscriptBox[
    StyleBox["m", "TI"], "3"], "=", "0"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "1a534489-c853-42bd-8c3e-2b016a2f6ab0"],
 ": the conserved ",
 Cell[BoxData[
  StyleBox[
   RowBox[{"Z", "Z", "Z"}], "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "5d989bf4-90d7-4991-a136-a9dcd7c18fca"],
 " stabilizer, read back as an explicit linear relation between outcomes. \
Sampling then honors that relation for free, never leaving the even-parity \
sector:"
}], "Text",ExpressionUUID->"656200f6-5ad4-4691-8550-2dad0c280599"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"SeedRandom", "[", "7", "]"}], ";"}], "\n", 
 RowBox[{"Counts", "[", 
  RowBox[{"readBits", " ", "/@", " ", 
   RowBox[{"smPar", "[", 
    RowBox[{"\"\<SampleOutcomes\>\"", ",", " ", "1000"}], "]"}]}], 
  "]"}]}], "Input",
 CellLabel->
  "In[65]:= ",ExpressionUUID->"3a1c70ed-3661-4fc7-b408-01ff0ba08ee0"],

Cell[BoxData[
 RowBox[{"\[LeftAssociation]", 
  RowBox[{
   RowBox[{
    RowBox[{"{", 
     RowBox[{"1", ",", "1", ",", "0"}], "}"}], "\[Rule]", "262"}], ",", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"0", ",", "1", ",", "1"}], "}"}], "\[Rule]", "249"}], ",", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"0", ",", "0", ",", "0"}], "}"}], "\[Rule]", "263"}], ",", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"1", ",", "0", ",", "1"}], "}"}], "\[Rule]", "226"}]}], 
  "\[RightAssociation]"}]], "Output",
 CellLabel->
  "Out[65]= ",ExpressionUUID->"1288f6a1-558d-46e5-9c7f-e888e74428da"]
}, Open  ]],

Cell["\<\
Only the four even-parity strings appear, each about a quarter of the shots: \
the randomness is genuine, but the parity the circuit built is enforced on \
every sample, carried from the one traversal by substitution alone.\
\>", "Text",ExpressionUUID->"95ed92fa-d1ad-42f1-bee8-73cd37acace5"],

Cell[TextData[{
 "This is why the technique was invented. The conserved parity ",
 Cell[BoxData[
  RowBox[{
   SubscriptBox[
    StyleBox["m", "TI"], "1"], "\[CirclePlus]", 
   SubscriptBox[
    StyleBox["m", "TI"], "2"], "\[CirclePlus]", 
   SubscriptBox[
    StyleBox["m", "TI"], "3"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "d6bfd261-0929-475b-91d4-87de6b210da3"],
 " is the ",
 StyleBox["syndrome", "TI"],
 " of the simplest possible code, a single ",
 Cell[BoxData[
  StyleBox["Z", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "257317b5-0eb9-4f04-ab06-05c1bc9fa669"],
 "-check: it reads ",
 Cell[BoxData["0"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "3402e4f0-f9af-4c1c-aab3-4a60b54a7727"],
 " as long as nothing goes wrong, which is exactly why every sampled shot \
stayed in the even-parity sector, and a bit-flip on any of the three qubits \
flips it to ",
 Cell[BoxData["1"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "ea44a64a-3194-4f70-94bb-7fdb33052dbb"],
 ". That is the operational content of the method. A fault that may or may \
not strike is carried exactly like an unmade measurement, written ",
 Cell[BoxData[
  SuperscriptBox[
   StyleBox["X", "TI"], 
   StyleBox["s", "TI"]]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "83f49bec-7ad9-443a-aa0b-19db48d5445e"],
 " with ",
 Cell[BoxData[
  StyleBox["s", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "04fed0d5-b401-4d54-8e28-a3c85dbc6954"],
 " a fresh bit, so each syndrome comes out as an explicit polynomial in the \
fault bits: the propagation map from physical errors to detectors. Evaluating \
that map for the millions of fault samples needed to score a fault-tolerant \
gadget is the acknowledged bottleneck of stabilizer simulation, even for the \
state-of-the-art engines. Symbolizing the signs turns \"re-traverse the \
circuit per sample\" into \"traverse once, then substitute,\" collapsing an \
entire sample batch into a single matrix multiply. The framework's ",
 Cell[BoxData["\"\<SymbolicMeasure\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "670d0097-2186-4720-885a-f01a8871e0f2"],
 " carries the measurement randomness this way in exact arithmetic, the \
in-language cousin of the bulk Pauli-frame samplers the dedicated engines use \
for the fault case."
}], "Text",ExpressionUUID->"e5a76be1-f314-4e82-b996-10284d70f6af"],

Cell["Scaling up: random Cliffords and compiled circuits", "Section",ExpressionUUID->"ed1df7c9-5cd5-48fc-b659-d4c6fe157bf6"],

Cell[TextData[{
 "Sampling a Clifford operation uniformly at random is a basic primitive for \
randomized benchmarking and for probing the typical entanglement of \
stabilizer states. The framework implements the Bravyi-Maslov construction \
via the Koenig-Smolin Mallows-distribution sampler, exposed as ",
 Cell[BoxData[
  RowBox[{"PauliStabilizer", "[", 
   RowBox[{"\"\<Random\>\"", "[", "n", "]"}], "]"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "317db82a-f4a9-4b29-a221-0ae274574035"],
 ". Sampling a random 200-qubit Clifford state and confirming it is a genuine \
stabilizer state is immediate:"
}], "Text",ExpressionUUID->"542a1669-43de-42ac-a659-da5ab061924d"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"SeedRandom", "[", "42", "]"}], ";"}], "\n", 
 RowBox[{"AbsoluteTiming", "[", 
  RowBox[{"StabilizerStateQ", "[", 
   RowBox[{"PauliStabilizer", "[", 
    RowBox[{"\"\<Random\>\"", "[", "200", "]"}], "]"}], "]"}], 
  "]"}]}], "Input",
 CellLabel->
  "In[66]:= ",ExpressionUUID->"567bfe68-4115-4913-b3d2-659199cea8f2"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"0.072066`", ",", "True"}], "}"}]], "Output",
 CellLabel->
  "Out[66]= ",ExpressionUUID->"43448782-fab6-4961-ac7e-f0825263eb9f"]
}, Open  ]],

Cell[TextData[{
 "That random state arrives as a bare tableau, with no circuit attached. The ",
 Cell[BoxData["\"\<Circuit\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "abd833c1-0f6d-4938-95c9-61303695d508"],
 " property hands one back: an explicit Clifford circuit that prepares the \
state from ",
 Cell[BoxData[
  TemplateBox[{
    RowBox[{"0", "\[Ellipsis]", "0"}]},
   "Ket"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "5ff1e442-9cd0-4a4e-808e-49d9fd776450"],
 ", by the Aaronson-Gottesman canonical decomposition. Unlike the membership \
test, this direction has real cost: the synthesis is ",
 Cell[BoxData[
  RowBox[{
   StyleBox["O", "TI"], 
   StyleBox["(",
    SpanMaxSize->1], 
   SuperscriptBox[
    StyleBox["n", "TI"], "3"], 
   StyleBox[")",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "5d60b107-6e12-42cb-bc1b-301255eda29f"],
 " gates and is ",
 StyleBox["not", "TI"],
 " length-minimized, so it is a moderate-",
 Cell[BoxData[
  StyleBox["n", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "db726767-30b1-45b0-a3ea-c5cad0f85187"],
 " tool rather than a thousand-qubit one. On a ten-qubit random Clifford it \
is immediate. Sample one:"
}], "Text",ExpressionUUID->"65dd7db3-05cc-41f7-8282-445e1fdb6926"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"SeedRandom", "[", "11", "]"}], ";"}], "\n", 
 RowBox[{"ps10", " ", "=", " ", 
  RowBox[{"PauliStabilizer", "[", 
   RowBox[{"\"\<Random\>\"", "[", "10", "]"}], "]"}]}]}], "Input",
 CellLabel->
  "In[67]:= ",ExpressionUUID->"fcf3508c-317b-47e9-9eef-ca7cffb8805e"],

Cell[BoxData[
 InterpretationBox[
  RowBox[{
   TagBox["PauliStabilizer",
    "SummaryHead"], "[", 
   DynamicModuleBox[{Typeset`open$$ = False, Typeset`embedState$$ = "Ready"}, 
    
    TemplateBox[{
      PaneSelectorBox[{False -> GridBox[{{
            PaneBox[
             ButtonBox[
              DynamicBox[
               FEPrivate`FrontEndResource["FEBitmaps", "SummaryBoxOpener"]], 
