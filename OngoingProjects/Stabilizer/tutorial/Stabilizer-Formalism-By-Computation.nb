Cell[TextData[{
 "The parities ",
 Cell[BoxData[
  StyleBox[
   RowBox[{"Z", "Z"}], "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "77b9da7c-e790-43cb-8c7a-c70b11f0c184"],
 " and ",
 Cell[BoxData[
  StyleBox[
   RowBox[{"X", "X"}], "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "d924c403-3a29-45be-be57-12fdeb35fa57"],
 " are certain (",
 Cell[BoxData[
  RowBox[{"+", "1"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "ef134b01-26a3-420d-94ef-db208b4eae59"],
 "), while a single-qubit ",
 Cell[BoxData[
  StyleBox["Z", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "d476b46b-152e-4061-b7b9-23bf6a479df1"],
 " is maximally uncertain (",
 Cell[BoxData["0"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "6e31cde9-2518-443e-b24a-e1cbc1cd1a8c"],
 "), the hallmark of an entangled state whose marginals are maximally mixed."
}], "Text",ExpressionUUID->"47324a06-20c7-4a9f-97d1-531ad4c57973"],

Cell[TextData[{
 "Before making this efficient, look closely at what ",
 Cell[BoxData[
  RowBox[{"ps", "[", 
   RowBox[{"\"\<M\>\"", ",", " ", "q"}], "]"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "9a2e48fc-6714-469e-b4b7-24be0496fc12"],
 " actually builds when measurements pile up, because that structure is what \
the next idea improves on. Each measurement does one of two things. If the \
observable is already certain, the outcome is forced and the state is \
unchanged; if it is undetermined, the outcome is a fair coin and the state \
collapses one of two ways. Measuring the qubits in turn therefore grows a ",
 StyleBox["tree of histories", "TI"],
 " that forks at every undetermined measurement, and the Association ",
 Cell[BoxData[
  RowBox[{"ps", "[", 
   RowBox[{"\"\<M\>\"", ",", " ", "q"}], "]"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "1b426117-0e55-4190-a39e-c52b137231a3"],
 " is exactly the set of branches at one node. WL grows the whole tree with \
",
 Cell[BoxData["NestTree"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "0c85d821-71f6-46c6-a389-b122fce37702"],
 ", which starts from a root and repeatedly applies a rule supplying each \
node's children; returning the branches as an Association keyed by the \
outcome puts each outcome on an edge:"
}], "Text",ExpressionUUID->"94ea9c82-29df-4099-876e-4472081b2dd6"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"step", "[", 
    RowBox[{"{", 
     RowBox[{"q_", ",", " ", "ps_"}], "}"}], "]"}], " ", ":=", " ", 
   RowBox[{"If", "[", 
    RowBox[{
     RowBox[{"q", " ", ">", " ", 
      RowBox[{"ps", "[", "\"\<Qubits\>\"", "]"}]}], ",", " ", 
     RowBox[{"<|", "|>"}], ",", " ", 
     RowBox[{"Map", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"{", 
         RowBox[{
          RowBox[{"q", " ", "+", " ", "1"}], ",", " ", "#"}], "}"}], " ", 
        "&"}], ",", " ", 
       RowBox[{"ps", "[", 
        RowBox[{"\"\<M\>\"", ",", " ", "q"}], "]"}]}], "]"}]}], "]"}]}], 
  ";"}], "\n", 
 RowBox[{
  RowBox[{"measurementTree", "[", "ps_", "]"}], " ", ":=", " ", 
  RowBox[{"TreeMap", "[", 
   RowBox[{
    RowBox[{"\"\<\>\"", " ", "&"}], ",", " ", 
    RowBox[{"NestTree", "[", 
     RowBox[{"step", ",", " ", 
      RowBox[{"{", 
       RowBox[{"1", ",", " ", "ps"}], "}"}], ",", " ", 
      RowBox[{"ps", "[", "\"\<Qubits\>\"", "]"}]}], "]"}]}], 
   "]"}]}]}], "Input",
 CellLabel->
  "In[52]:= ",ExpressionUUID->"7a853e6c-09a2-498c-834d-df67958355fb"],

Cell[TextData[{
 "Three independent ",
 Cell[BoxData[
  TemplateBox[{"+"},
   "Ket"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "100bbe09-a4ae-433d-9e82-0538cf9a7bbf"],
 " qubits are three independent fair coins, so the history forks at every \
step into all ",
 Cell[BoxData[
  RowBox[{
   SuperscriptBox["2", "3"], "=", "8"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "2ac5435a-6170-456f-9b65-66ae1bb03b69"],
 " leaves:"
}], "Text",ExpressionUUID->"eb8f4e12-4d2b-4e9e-a0ea-e337ae5258bf"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"measurementTree", "[", 
  RowBox[{
   RowBox[{"PauliStabilizer", "[", "3", "]"}], "[", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"\"\<H\>\"", " ", "->", " ", "1"}], ",", " ", 
     RowBox[{"\"\<H\>\"", " ", "->", " ", "2"}], ",", " ", 
     RowBox[{"\"\<H\>\"", " ", "->", " ", "3"}]}], "}"}], "]"}], 
  "]"}]], "Input",
 CellLabel->
  "In[53]:= ",ExpressionUUID->"8a123425-bb92-4693-acc8-b12eef422677"],

