Cell[TextData[{
 "The single key tells us the ",
 Cell[BoxData[
  StyleBox[
   RowBox[{"Z", "Z"}], "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "a6c3ca3d-d75c-4449-83d0-bf71e86e61d2"],
 " parity is certain. The same fact, as an expectation value, comes from ",
 Cell[BoxData["\"\<Expectation\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "ab7a2ef7-67a2-408c-aa76-ac7ce5fdc898"],
 ", which tracks the Aaronson-Gottesman ",
 Cell[BoxData[
  StyleBox["i", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "5ea0b31e-9bfa-4b48-a4e3-24cbb8252f9a"],
 "-powers in closed form and returns ",
 Cell[BoxData[
  RowBox[{"\[PlusMinus]", "1"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "2e57556d-db3a-40a6-aa46-229da86bf1ff"],
 " or ",
 Cell[BoxData["0"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "e279638c-49bd-491d-a0a7-af7cd070249a"],
 ":"
}], "Text",ExpressionUUID->"f6c9d01d-9b15-4e2a-8c25-e5227459e544"],

