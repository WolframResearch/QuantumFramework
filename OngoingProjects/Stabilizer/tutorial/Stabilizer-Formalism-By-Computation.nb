}, Open  ]],

Cell["and read its generators:", "Text",ExpressionUUID->"3f7302cf-f86f-4aa0-bf73-25d16635d26a"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"gs", "[", "\"\<Stabilizers\>\"", "]"}]], "Input",
 CellLabel->
  "In[89]:= ",ExpressionUUID->"232a8c71-a765-4ef5-b8be-e8d8ced24409"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"\<\"XZIZ\"\>", ",", "\<\"ZXZI\"\>", ",", "\<\"IZXZ\"\>", 
   ",", "\<\"ZIZX\"\>"}], "}"}]], "Output",
 CellLabel->
  "Out[89]= ",ExpressionUUID->"60fdd82c-91c6-4ca5-a3d8-18815f9dd4cd"]
}, Open  ]],

Cell[TextData[{
 "Each generator is an ",
 Cell[BoxData[
  StyleBox["X", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "03c7a13e-92be-4cfd-a3a5-ae7c9e398238"],
 " on one vertex dressed by ",
 Cell[BoxData[
  StyleBox["Z", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "2a3127cc-76bc-4f67-a849-c4c87f566ee6"],
 " on its neighbors, the cluster-state structure. A graph state is an \
ordinary stabilizer state, so it converts to a ",
 Cell[BoxData["PauliStabilizer"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "2408c6a5-be5c-4bfc-99e8-74bb5ffd0041"],
 " and answers the same questions. The 4-cycle cluster carries two bits of \
entanglement across the cut ",
 Cell[BoxData[
  RowBox[{
   RowBox[{"{", "1"}], ",", 
   RowBox[{"2", "}", "\[VerticalSeparator]", "{", "3"}], ",", 
   RowBox[{"4", "}"}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "a3d0600a-5764-4e7d-8163-8b8dac811f0b"],
 ", one per edge crossing it:"
}], "Text",ExpressionUUID->"6f76571d-64b9-4a95-9836-5aad72064add"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{"StabilizerStateQ", "[", 
    RowBox[{"gs", "[", "\"\<PauliStabilizer\>\"", "]"}], "]"}], ",", " ", 
   RowBox[{
    RowBox[{"gs", "[", "\"\<PauliStabilizer\>\"", "]"}], "[", 
    RowBox[{"\"\<Entropy\>\"", ",", " ", 
     RowBox[{"{", 
      RowBox[{"1", ",", " ", "2"}], "}"}]}], "]"}]}], "}"}]], "Input",
 CellLabel->
  "In[90]:= ",ExpressionUUID->"32268492-ba53-4977-89f3-aa27fd310132"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"True", ",", "2"}], "}"}]], "Output",
 CellLabel->
  "Out[90]= ",ExpressionUUID->"f7329db5-5fa3-43a8-a9f5-68b7a9d53336"]
}, Open  ]],

Cell[TextData[{
 "The graph is a far more compact record than the tableau when the state is \
sparse. A path graph gives the one-dimensional cluster state of \
measurement-based computation, each generator a local ",
 Cell[BoxData[
  StyleBox[
   RowBox[{"X", "Z"}], "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "3e512f5f-db79-4424-b351-18776fa362be"],
 " pattern:"
}], "Text",ExpressionUUID->"76ccaf49-7006-4ab6-af82-f5f7cd2bf9e0"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"GraphState", "[", 
   RowBox[{"PathGraph", "[", 
    RowBox[{"Range", "[", "3", "]"}], "]"}], "]"}], "[", "\"\<Stabilizers\>\"",
   "]"}]], "Input",
 CellLabel->
  "In[91]:= ",ExpressionUUID->"d5204d39-5f06-4f64-896b-03dd48ef1a99"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"\<\"XZI\"\>", ",", "\<\"ZXZ\"\>", ",", "\<\"IZX\"\>"}], 
  "}"}]], "Output",
 CellLabel->
  "Out[91]= ",ExpressionUUID->"9f04b5fa-b6ed-4baf-9c74-cb05fb0086ba"]
}, Open  ]],

Cell[TextData[{
 "The operation that moves through the local-Clifford equivalence class is ",
 StyleBox["local complementation", "TI"],
 ", which toggles the edges among the neighbors of a chosen vertex; here it \
is ",
 Cell[BoxData["LocalComplement"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "300bab0f-7471-4d5f-89ec-526db6e5e385"],
 ". Local-complementing the 4-cycle at vertex 1 adds the edge between its two \
neighbors:"
}], "Text",ExpressionUUID->"6e7b6b6d-f291-483a-9542-fec15408315d"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"EdgeList", "[", 
  RowBox[{"LocalComplement", "[", 
   RowBox[{
    RowBox[{"CycleGraph", "[", "4", "]"}], ",", " ", "1"}], "]"}], 
  "]"}]], "Input",
 CellLabel->
  "In[92]:= ",ExpressionUUID->"d9f51a26-d387-4de6-9c21-16a461b064c0"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{"1", "\[UndirectedEdge]", "2"}], ",", 
   RowBox[{"1", "\[UndirectedEdge]", "4"}], ",", 
   RowBox[{"2", "\[UndirectedEdge]", "3"}], ",", 
   RowBox[{"2", "\[UndirectedEdge]", "4"}], ",", 
   RowBox[{"3", "\[UndirectedEdge]", "4"}]}], "}"}]], "Output",
 CellLabel->
  "Out[92]= ",ExpressionUUID->"29fe5e4b-56cc-4604-811d-161e4375796a"]
}, Open  ]],

Cell["\<\
The graph is updated correctly, but the accompanying single-qubit Clifford \
corrections, the vertex operators that would make the equivalence exact at \
the state level, are not yet tracked. Use this for graph surgery rather than \
for exact state identity.\
\>", "Text",ExpressionUUID->"b79b058f-c722-4a7b-831e-c496184b87f1"],

Cell["Magic and stabilizer rank", "Subsection",ExpressionUUID->"84224c63-4d6b-4096-b78d-df471a7aed36"],

Cell[TextData[{
 "Clifford gates keep us inside the stabilizer world; a non-Clifford gate \
such as ",
 Cell[BoxData[
  StyleBox["T", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "01920511-8dd7-403f-b5cd-bdf079b06eee"],
 " does not. The framework represents a state that has left the stabilizer \
manifold as a ",
 Cell[BoxData["StabilizerFrame"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "6d1650a2-ca35-4d22-8d33-0f23afc66f79"],
 ", a superposition ",
 Cell[BoxData[
  RowBox[{
   UnderscriptBox["\[Sum]", 
    StyleBox["i", "TI"],
    LimitsPositioning->False], 
   RowBox[{
    SubscriptBox[
     StyleBox["c", "TI"], 
     StyleBox["i", "TI"]], 
    TemplateBox[{
      SubscriptBox[
       StyleBox["s", "TI"], 
       StyleBox["i", "TI"]]},
     "Ket"]}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "35722c19-0a8b-48d1-ae0d-af3be7bb93d7"],
 " of stabilizer states. Because ",
 Cell[BoxData[
  StyleBox["T", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "eb455f4e-3008-4223-97e8-b0401eb0a5ea"],
 " turns one Pauli into a sum of two, as in ",
 Cell[BoxData[
  RowBox[{
   StyleBox["T", "TI"], 
   StyleBox["X", "TI"], 
   SuperscriptBox[
    StyleBox["T", "TI"], "\[Dagger]"], "=", 
   StyleBox["(",
    SpanMaxSize->1], 
   RowBox[{
    StyleBox["X", "TI"], "+", 
    StyleBox["Y", "TI"]}], 
   StyleBox[")",
    SpanMaxSize->1], "/", 
   SqrtBox["2"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "b7207264-e16a-4ea4-8df6-fbe36da02fc7"],
 ", each ",
 Cell[BoxData[
  StyleBox["T", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "5ba5e4bc-8737-4f17-b7c4-72a385c55c95"],
 " gate at most ",
 StyleBox["doubles", "TI"],
 " the number of stabilizer terms. The term count is the ",
 StyleBox["stabilizer rank", "TI"],
 ", the quantity that controls the cost of classically simulating magic, in \
the sense of Bravyi and Gosset. Watch it double, gate by gate. A helper \
reports the term count, with a bare ",
 Cell[BoxData["PauliStabilizer"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "a834d084-505c-48bd-8bd4-b595691e89cd"],
 " counting as rank 1 and a frame as its component count:"
}], "Text",ExpressionUUID->"560d5dcf-e36e-4aa0-88a1-5932f6e72e4c"],

Cell[BoxData[
 RowBox[{
  RowBox[{"stabRank", "[", "x_", "]"}], " ", ":=", " ", 
  RowBox[{"If", "[", 
   RowBox[{
    RowBox[{"MatchQ", "[", 
     RowBox[{"x", ",", " ", "_StabilizerFrame"}], "]"}], ",", " ", 
    RowBox[{"x", "[", "\"\<Length\>\"", "]"}], ",", " ", "1"}], 
   "]"}]}]], "Input",
 CellLabel->
  "In[93]:= ",ExpressionUUID->"ce5ab2cf-5273-4dfe-bda1-f3bb3a4442aa"],

Cell[TextData[{
 "Apply ",
 Cell[BoxData[
  StyleBox["k", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "aa7771c6-0db5-4e24-9bb8-8ad6669af970"],
 " successive ",
 Cell[BoxData[
  StyleBox["T", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "b42a827e-07d3-4d7e-959a-04c774a331b4"],
 " gates to ",
 Cell[BoxData[
  TemplateBox[{"+"},
   "Ket"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "cacc6445-ac8a-4d36-8ba6-18c2f694ce84"],
 " and tabulate the rank:"
}], "Text",ExpressionUUID->"30cb7670-aa87-48f7-9223-b06dc9e21b93"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Table", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"k", ",", " ", 
     RowBox[{"stabRank", "[", 
      RowBox[{
       RowBox[{"PauliStabilizer", "[", "1", "]"}], "[", 
       RowBox[{"Join", "[", 
        RowBox[{
         RowBox[{"{", "\"\<H\>\"", "}"}], ",", " ", 
         RowBox[{"Table", "[", 
          RowBox[{"\"\<T\>\"", ",", " ", "k"}], "]"}]}], "]"}], "]"}], 
      "]"}]}], "}"}], ",", " ", 
   RowBox[{"{", 
    RowBox[{"k", ",", " ", "0", ",", " ", "5"}], "}"}]}], "]"}]], "Input",
 CellLabel->
  "In[94]:= ",ExpressionUUID->"fcd37e58-6b67-43bd-aeed-d779d0f5e821"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"0", ",", "1"}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{"1", ",", "2"}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{"2", ",", "4"}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{"3", ",", "8"}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{"4", ",", "16"}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{"5", ",", "32"}], "}"}]}], "}"}]], "Output",
 CellLabel->
  "Out[94]= ",ExpressionUUID->"7a678ebc-40ec-489b-bcb0-28dba2ddc1ae"]
}, Open  ]],

Cell[TextData[{
 "The rank goes ",
 Cell[BoxData[
  RowBox[{
   RowBox[{"1", ",", "2", ",", "4"}], ",", "\[Ellipsis]", ",", 
   SuperscriptBox["2", 
    StyleBox["k", "TI"]]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "f9fd2b9b-546a-40e4-ba89-5cc2cd012d7f"],
 ": the exponential cost of magic made concrete, and the reason a ",
 Cell[BoxData[
  StyleBox["T", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "a559e012-5b76-44a2-8bd3-6e6ec5d3d2d4"],
 "-rich circuit is hard where a Clifford circuit is easy. The rank tracks the \
amount of magic, not the size of the register. Three ",
 Cell[BoxData[
  StyleBox["T", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "4656fc2e-a91d-40f3-816c-92d5bd112074"],
 " gates on a Clifford backbone of growing width keep the component count \
pinned at ",
 Cell[BoxData[
  RowBox[{
   SuperscriptBox["2", "3"], "=", "8"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "f8ac85f2-4f06-4be1-aa7b-95d04fb19e09"],
 ", while the dense state vector it stands for grows as ",
 Cell[BoxData[
  SuperscriptBox["2", 
   StyleBox["n", "TI"]]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "43f8cac5-68c5-49c1-b10d-903fe46c45aa"],
 ". A helper builds that family, three ",
 Cell[BoxData[
  StyleBox["T", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "7e822d98-d65c-464c-875d-9e14d5d568c5"],
 " gates on top of an ",
 Cell[BoxData[
  StyleBox["n", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "9503f352-c6e4-48ca-93a4-4a58c8bb72c5"],
 "-qubit GHZ-like state:"
}], "Text",ExpressionUUID->"6162ed39-ffc1-4ade-b2f9-759be6de43c3"],

Cell[BoxData[
 RowBox[{
  RowBox[{"magicState", "[", "n_", "]"}], " ", ":=", " ", 
  RowBox[{
   RowBox[{"PauliStabilizer", "[", "n", "]"}], "[", 
   RowBox[{"Join", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"\"\<H\>\"", " ", "->", " ", "1"}], "}"}], ",", " ", 
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{"\"\<CNOT\>\"", " ", "->", " ", 
        RowBox[{"{", 
         RowBox[{"i", ",", " ", 
          RowBox[{"i", " ", "+", " ", "1"}]}], "}"}]}], ",", " ", 
       RowBox[{"{", 
        RowBox[{"i", ",", " ", "1", ",", " ", 
         RowBox[{"n", " ", "-", " ", "1"}]}], "}"}]}], "]"}], ",", " ", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"\"\<T\>\"", " ", "->", " ", "1"}], ",", " ", 
       RowBox[{"\"\<T\>\"", " ", "->", " ", "2"}], ",", " ", 
       RowBox[{"\"\<T\>\"", " ", "->", " ", "3"}]}], "}"}]}], "]"}], 
   "]"}]}]], "Input",
 CellLabel->
  "In[95]:= ",ExpressionUUID->"65c9429e-7c06-4268-9c59-3b30aa3bf059"],

