Cell[TextData[{
 "Its dimensions confirm the ",
 Cell[BoxData[
  RowBox[{
   RowBox[{"{", "2"}], ",", 
   StyleBox["n", "TI"], ",", 
   RowBox[{"2", 
    StyleBox["n", "TI"], "}", "=", "{", "2"}], ",", "2", ",", 
   RowBox[{"4", "}"}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "b4129021-7ad9-4644-8ea7-0bcd5933cb9a"],
 " layout directly:"
}], "Text",ExpressionUUID->"8f7d23bc-c2d4-4fb0-9431-41bca5bd5821"],

