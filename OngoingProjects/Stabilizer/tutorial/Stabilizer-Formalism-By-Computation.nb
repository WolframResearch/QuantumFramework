   RowBox[{"PauliMatrix", "[", "3", "]"}], " ", ".", " ", 
   RowBox[{"{", 
    RowBox[{"1", ",", " ", "0"}], "}"}]}], " ", "==", " ", 
  RowBox[{"{", 
