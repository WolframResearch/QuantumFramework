Cell[TextData[{
 "The single key tells us the ",
 Cell[BoxData[
  StyleBox[
   RowBox[{"Z", "Z"}], "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "0f019c97-0821-4151-ac74-273b1b8910e6"],
 " parity is certain. The same fact, as an expectation value, comes from ",
 Cell[BoxData["\"\<Expectation\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "6b63a802-7449-4a96-9eea-42143d8319e4"],
 ", which tracks the Aaronson-Gottesman ",
 Cell[BoxData[
  StyleBox["i", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "214b4821-602a-47d1-a4c3-01b94bc2962e"],
 "-powers in closed form and returns ",
 Cell[BoxData[
  RowBox[{"\[PlusMinus]", "1"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "6c2ff0c1-3531-4dc1-9dcb-9695cad1b643"],
 " or ",
 Cell[BoxData["0"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "8a5ce5f6-6564-480f-a150-eca9b35de6bb"],
 ":"
}], "Text",ExpressionUUID->"9000cf5f-1b26-4475-9853-d499e317736f"],

