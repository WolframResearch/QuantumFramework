}, Open  ]],

Cell["and read its generators:", "Text",ExpressionUUID->"702f78f8-af84-422e-abf2-ca5909f18ccb"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"gs", "[", "\"\<Stabilizers\>\"", "]"}]], "Input",
 CellLabel->
  "In[89]:= ",ExpressionUUID->"2151e56f-6ed8-4af7-99ff-cc5d353deda5"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"\<\"XZIZ\"\>", ",", "\<\"ZXZI\"\>", ",", "\<\"IZXZ\"\>", 
   ",", "\<\"ZIZX\"\>"}], "}"}]], "Output",
 CellLabel->
  "Out[89]= ",ExpressionUUID->"4f545421-c730-4195-a779-e3d7ca3ba212"]
}, Open  ]],

Cell[TextData[{
 "Each generator is an ",
 Cell[BoxData[
  StyleBox["X", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "de0f1968-31ac-429e-81dd-32ccbdd54d2e"],
 " on one vertex dressed by ",
 Cell[BoxData[
  StyleBox["Z", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "8374cb5a-fa26-417d-8be4-df3c8b6f3855"],
 " on its neighbors, the cluster-state structure. A graph state is an \
ordinary stabilizer state, so it converts to a ",
 Cell[BoxData["PauliStabilizer"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "6a5fe02c-96c5-48d5-8db7-7dec5092c2df"],
 " and answers the same questions. The 4-cycle cluster carries two bits of \
entanglement across the cut ",
 Cell[BoxData[
  RowBox[{
   RowBox[{"{", "1"}], ",", 
   RowBox[{"2", "}", "\[VerticalSeparator]", "{", "3"}], ",", 
   RowBox[{"4", "}"}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "2c1e68b4-674c-4865-8c40-f11fd75984fe"],
 ", one per edge crossing it:"
}], "Text",ExpressionUUID->"9e16a78d-2ab7-4001-becc-6cc64f465b7b"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{"StabilizerStateQ", "[", 
    RowBox[{"gs", "[", "\"\<PauliStabilizer\>\"", "]"}], "]"}], ",", " ", 
   RowBox[{
    RowBox[{"gs", "[", "\"\<PauliStabilizer\>\"", "]"}], "[", 
    RowBox[{"\"\<Entropy\>\"", ",", " ", 
     RowBox[{"{", 
      RowBox[{"1", ",", " ", "2"}], "}"}]}], "]"}]}], "}"}]], "Input",
 CellLabel->
  "In[90]:= ",ExpressionUUID->"04e4bbdb-0aa3-4124-b8aa-07cd5b18950c"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"True", ",", "2"}], "}"}]], "Output",
 CellLabel->
  "Out[90]= ",ExpressionUUID->"a073dcea-64fa-40c1-b58e-eced7f88ff88"]
}, Open  ]],

Cell[TextData[{
 "The graph is a far more compact record than the tableau when the state is \
sparse. A path graph gives the one-dimensional cluster state of \
measurement-based computation, each generator a local ",
 Cell[BoxData[
  StyleBox[
   RowBox[{"X", "Z"}], "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "5952ea14-e515-4e98-bb56-f1293ee671e5"],
 " pattern:"
}], "Text",ExpressionUUID->"8146ab02-8749-46fc-a99d-0392e3742ffc"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"GraphState", "[", 
   RowBox[{"PathGraph", "[", 
    RowBox[{"Range", "[", "3", "]"}], "]"}], "]"}], "[", "\"\<Stabilizers\>\"",
   "]"}]], "Input",
 CellLabel->
  "In[91]:= ",ExpressionUUID->"797b13ee-97d8-4c92-8880-49c4234e4d10"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"\<\"XZI\"\>", ",", "\<\"ZXZ\"\>", ",", "\<\"IZX\"\>"}], 
  "}"}]], "Output",
 CellLabel->
  "Out[91]= ",ExpressionUUID->"50e01766-cd28-40d5-946d-b03132b09404"]
}, Open  ]],

Cell[TextData[{
 "The operation that moves through the local-Clifford equivalence class is ",
 StyleBox["local complementation", "TI"],
 ", which toggles the edges among the neighbors of a chosen vertex; here it \
is ",
 Cell[BoxData["LocalComplement"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "8f49daca-e2ef-4fe5-882f-8feec392c9b7"],
 ". Local-complementing the 4-cycle at vertex 1 adds the edge between its two \
neighbors:"
}], "Text",ExpressionUUID->"9df04534-57af-4be0-999d-5cffe56877fe"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"EdgeList", "[", 
  RowBox[{"LocalComplement", "[", 
   RowBox[{
    RowBox[{"CycleGraph", "[", "4", "]"}], ",", " ", "1"}], "]"}], 
  "]"}]], "Input",
 CellLabel->
  "In[92]:= ",ExpressionUUID->"57d7eb0b-e70c-48b8-8428-71665bf6e63e"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{"1", "\[UndirectedEdge]", "2"}], ",", 
   RowBox[{"1", "\[UndirectedEdge]", "4"}], ",", 
   RowBox[{"2", "\[UndirectedEdge]", "3"}], ",", 
   RowBox[{"2", "\[UndirectedEdge]", "4"}], ",", 
   RowBox[{"3", "\[UndirectedEdge]", "4"}]}], "}"}]], "Output",
 CellLabel->
  "Out[92]= ",ExpressionUUID->"713d5047-fdeb-4357-9253-415ebecb74ac"]
}, Open  ]],

Cell["\<\
The graph is updated correctly, but the accompanying single-qubit Clifford \
corrections, the vertex operators that would make the equivalence exact at \
the state level, are not yet tracked. Use this for graph surgery rather than \
for exact state identity.\
\>", "Text",ExpressionUUID->"32ec06da-3434-4ac0-b09c-371ae4e731d8"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Magic and stabilizer rank", "Subsection",ExpressionUUID->"01dc2d45-aa31-49b2-9fba-ddf4970bf99d"],

Cell[TextData[{
 "Clifford gates keep us inside the stabilizer world; a non-Clifford gate \
such as ",
 Cell[BoxData[
  StyleBox["T", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "c42ec6b1-78a2-413b-aad0-11cfee8216fa"],
 " does not. The framework represents a state that has left the stabilizer \
manifold as a ",
 Cell[BoxData["StabilizerFrame"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "f38c8840-2dc4-4215-931f-c1aef743b629"],
 ", a superposition ",
 Cell[BoxData[
  RowBox[{
   UnderscriptBox["\[Sum]", 
    StyleBox["i", "TI"],
    LimitsPositioning->False], 
   RowBox[{
    SubscriptBox[
     StyleBox["c", "TI"], 
     StyleBox["i", "TI"]], 
    TemplateBox[{
      SubscriptBox[
       StyleBox["s", "TI"], 
       StyleBox["i", "TI"]]},
     "Ket"]}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "e8da6d51-5b0d-4526-8512-6ea8d96cfd73"],
 " of stabilizer states. Because ",
 Cell[BoxData[
  StyleBox["T", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "7281a87f-fd7f-4e10-a08e-d3e6e69f4c16"],
 " turns one Pauli into a sum of two, as in ",
 Cell[BoxData[
  RowBox[{
   StyleBox["T", "TI"], 
   StyleBox["X", "TI"], 
   SuperscriptBox[
    StyleBox["T", "TI"], "\[Dagger]"], "=", 
   StyleBox["(",
    SpanMaxSize->1], 
   RowBox[{
    StyleBox["X", "TI"], "+", 
    StyleBox["Y", "TI"]}], 
   StyleBox[")",
    SpanMaxSize->1], "/", 
   SqrtBox["2"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "aed6b87e-fc27-45b2-bd9a-9ec3f3324376"],
 ", each ",
 Cell[BoxData[
  StyleBox["T", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "83592135-a033-423c-8866-1703e458772c"],
 " gate at most ",
 StyleBox["doubles", "TI"],
 " the number of stabilizer terms. The term count is the ",
 StyleBox["stabilizer rank", "TI"],
 ", the quantity that controls the cost of classically simulating magic, in \
the sense of Bravyi and Gosset. Watch it double, gate by gate. A helper \
reports the term count, with a bare ",
 Cell[BoxData["PauliStabilizer"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "874754a0-c2b1-4ae9-bf44-6495b4feece6"],
 " counting as rank 1 and a frame as its component count:"
}], "Text",ExpressionUUID->"5acf1f81-3fc2-4eee-a441-8f9987d1f881"],

Cell[BoxData[
 RowBox[{
  RowBox[{"stabRank", "[", "x_", "]"}], " ", ":=", " ", 
  RowBox[{"If", "[", 
   RowBox[{
    RowBox[{"MatchQ", "[", 
     RowBox[{"x", ",", " ", "_StabilizerFrame"}], "]"}], ",", " ", 
    RowBox[{"x", "[", "\"\<Length\>\"", "]"}], ",", " ", "1"}], 
   "]"}]}]], "Input",
 CellLabel->
  "In[93]:= ",ExpressionUUID->"ea69412c-adfc-486d-9079-9128c51ad592"],

Cell[TextData[{
 "Apply ",
 Cell[BoxData[
  StyleBox["k", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "538c1dcb-8f5d-4b6b-8c1b-362b97395dc6"],
 " successive ",
 Cell[BoxData[
  StyleBox["T", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "fe5fd438-806c-414a-ab50-09c748333068"],
 " gates to ",
 Cell[BoxData[
  TemplateBox[{"+"},
   "Ket"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "3fa48db9-683d-41d6-be79-2b95580572f0"],
 " and tabulate the rank:"
}], "Text",ExpressionUUID->"1bf29edc-c268-419e-ae48-89bb3bca72e9"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Table", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"k", ",", " ", 
     RowBox[{"stabRank", "[", 
      RowBox[{
       RowBox[{"PauliStabilizer", "[", "1", "]"}], "[", 
       RowBox[{"Join", "[", 
        RowBox[{
         RowBox[{"{", "\"\<H\>\"", "}"}], ",", " ", 
         RowBox[{"Table", "[", 
          RowBox[{"\"\<T\>\"", ",", " ", "k"}], "]"}]}], "]"}], "]"}], 
      "]"}]}], "}"}], ",", " ", 
   RowBox[{"{", 
    RowBox[{"k", ",", " ", "0", ",", " ", "5"}], "}"}]}], "]"}]], "Input",
 CellLabel->
  "In[94]:= ",ExpressionUUID->"68b9051a-f1cc-449d-86a0-c3b042bef19f"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"0", ",", "1"}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{"1", ",", "2"}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{"2", ",", "4"}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{"3", ",", "8"}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{"4", ",", "16"}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{"5", ",", "32"}], "}"}]}], "}"}]], "Output",
 CellLabel->
  "Out[94]= ",ExpressionUUID->"58de7b41-0f27-4ec7-8aff-d97eac4fe8c3"]
}, Open  ]],

Cell[TextData[{
 "The rank goes ",
 Cell[BoxData[
  RowBox[{
   RowBox[{"1", ",", "2", ",", "4"}], ",", "\[Ellipsis]", ",", 
   SuperscriptBox["2", 
    StyleBox["k", "TI"]]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "281d8478-94d7-4bb4-a513-c4d31201e899"],
 ": the exponential cost of magic made concrete, and the reason a ",
 Cell[BoxData[
  StyleBox["T", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "44b13506-a0ef-4b5d-8768-b4300410e925"],
 "-rich circuit is hard where a Clifford circuit is easy. The rank tracks the \
amount of magic, not the size of the register. Three ",
 Cell[BoxData[
  StyleBox["T", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "dca3c1f8-7f30-4ec5-bbad-4dfe61ad4bbf"],
 " gates on a Clifford backbone of growing width keep the component count \
pinned at ",
 Cell[BoxData[
  RowBox[{
   SuperscriptBox["2", "3"], "=", "8"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "c92f5699-a104-4d62-b583-68d6574f706b"],
 ", while the dense state vector it stands for grows as ",
 Cell[BoxData[
  SuperscriptBox["2", 
   StyleBox["n", "TI"]]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "d1fa3a13-22ab-4403-a963-228d543d7e34"],
 ". A helper builds that family, three ",
 Cell[BoxData[
  StyleBox["T", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "64e5e75d-087e-4e5a-866b-bc1ad0c6cb56"],
 " gates on top of an ",
 Cell[BoxData[
  StyleBox["n", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "566ca069-0310-4896-bedd-5e90a2f71403"],
 "-qubit GHZ-like state:"
}], "Text",ExpressionUUID->"65a4d0c7-5f79-47f6-8900-4ef5dbe62a13"],

Cell[BoxData[
 RowBox[{
  RowBox[{"magicState", "[", "n_", "]"}], " ", ":=", " ", 
  RowBox[{
   RowBox[{"PauliStabilizer", "[", "n", "]"}], "[", 
   RowBox[{"Join", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"\"\<H\>\"", " ", "->", " ", "1"}], "}"}], ",", " ", 
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{"\"\<CNOT\>\"", " ", "->", " ", 
        RowBox[{"{", 
         RowBox[{"i", ",", " ", 
          RowBox[{"i", " ", "+", " ", "1"}]}], "}"}]}], ",", " ", 
       RowBox[{"{", 
        RowBox[{"i", ",", " ", "1", ",", " ", 
         RowBox[{"n", " ", "-", " ", "1"}]}], "}"}]}], "]"}], ",", " ", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"\"\<T\>\"", " ", "->", " ", "1"}], ",", " ", 
       RowBox[{"\"\<T\>\"", " ", "->", " ", "2"}], ",", " ", 
       RowBox[{"\"\<T\>\"", " ", "->", " ", "3"}]}], "}"}]}], "]"}], 
   "]"}]}]], "Input",
 CellLabel->
  "In[95]:= ",ExpressionUUID->"441d8c81-d8e7-49ce-9a50-3a7065e2605b"],

