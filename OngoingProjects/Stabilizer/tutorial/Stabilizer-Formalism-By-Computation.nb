Cell[TextData[{
 "The first three generators are pure ",
 Cell[BoxData[
  StyleBox["X", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "3c7a2194-8e16-4588-9d7e-0d081618b751"],
 " checks and the next three pure ",
 Cell[BoxData[
  StyleBox["Z", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "637a9536-f553-455f-b0f8-588f2c2bf568"],
 " checks, the defining CSS structure; the seventh is again the logical ",
 Cell[BoxData[
  OverscriptBox[
   StyleBox["Z", "TI"], "_"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "ee6431ca-1e82-4376-8135-6612b446c41c"],
 ". The ",
 Cell[BoxData[
  StyleBox["Z", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "e4bc04f1-f53f-4377-97d7-e69ea9eca487"],
 "-checks catch bit-flips and the ",
 Cell[BoxData[
  StyleBox["X", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "5e4398dd-3de5-4967-aedf-44770dc1f4f3"],
 "-checks catch phase-flips, the two error types handled by separate, \
commuting halves of one tableau."
}], "Text",ExpressionUUID->"3544df39-4313-4cac-940a-4cbef92e1f62"],

Cell["The frontier: graph states, magic, and channels", "Section",ExpressionUUID->"29765b56-c7bc-460b-8075-5f358957d691"],

Cell["\<\
Three directions take the formalism to the edge of current research, and the \
framework has a head for each. This section gives each one enough room to \
compute with, not just name.\
\>", "Text",ExpressionUUID->"dd67975a-5a30-4b4a-b544-d0547da3d15d"],

Cell["Graph states", "Subsection",ExpressionUUID->"a4e44583-1e9b-47b2-80f6-2ae3576b4a2c"],

Cell[TextData[{
 "A theorem of Van den Nest and others says every stabilizer state is \
local-Clifford-equivalent to a ",
 StyleBox["graph state", "TI"],
 ": place ",
 Cell[BoxData[
  TemplateBox[{"+"},
   "Ket"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "1bd1ffe4-3cf9-4855-99cf-bb79ace6ce7f"],
 " on each vertex of a graph and apply a controlled-",
 Cell[BoxData[
  StyleBox["Z", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "811f512a-3b6f-49e1-b1c1-edbe8cd6f5a1"],
 " along each edge. Its stabilizer at vertex ",
 Cell[BoxData[
  StyleBox["i", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "819f1318-b7af-48f8-a78d-3806509e0dc4"],
 " is ",
 Cell[BoxData[
  RowBox[{
   SubscriptBox[
    StyleBox["X", "TI"], 
    StyleBox["i", "TI"]], 
   UnderscriptBox["\[Product]", 
    RowBox[{
     StyleBox["j", "TI"], "\[Tilde]", 
     StyleBox["i", "TI"]}],
    LimitsPositioning->False], 
   SubscriptBox[
    StyleBox["Z", "TI"], 
    StyleBox["j", "TI"]]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "d48094a1-76ca-42b3-a900-7ade5be37ad6"],
 ". Build the graph state on a 4-cycle:"
}], "Text",ExpressionUUID->"6a23a456-c6e5-4080-b53c-caf9cf250034"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"gs", " ", "=", " ", 
  RowBox[{"GraphState", "[", 
   RowBox[{"CycleGraph", "[", "4", "]"}], "]"}]}]], "Input",
 CellLabel->
  "In[88]:= ",ExpressionUUID->"cc4780d4-563d-48ed-99d1-0c7de77d4612"],

Cell[BoxData[
 InterpretationBox[
  RowBox[{
   TagBox["GraphState",
    "SummaryHead"], "[", 
   DynamicModuleBox[{Typeset`open$$ = False, Typeset`embedState$$ = "Ready"}, 
    
    TemplateBox[{
      PaneSelectorBox[{False -> GridBox[{{
            PaneBox[
             ButtonBox[
              DynamicBox[
               FEPrivate`FrontEndResource["FEBitmaps", "SummaryBoxOpener"]], 
              ButtonFunction :> (Typeset`open$$ = True), Appearance -> None, 
              BaseStyle -> {}, Evaluator -> Automatic, Method -> 
              "Preemptive"], Alignment -> {Center, Center}, ImageSize -> 
             Dynamic[{
               Automatic, 
                3.5 (CurrentValue["FontCapHeight"]/AbsoluteCurrentValue[
                 Magnification])}]], 
            FrameBox["\"\[ScriptCapitalG]\"", StripOnInput -> False], 
            GridBox[{{
               RowBox[{
                 TagBox["\"Vertices: \"", "SummaryItemAnnotation"], 
                 "\[InvisibleSpace]", 
                 TagBox["4", "SummaryItem"]}]}, {
               RowBox[{
                 TagBox["\"Edges: \"", "SummaryItemAnnotation"], 
                 "\[InvisibleSpace]", 
                 TagBox["4", "SummaryItem"]}]}}, 
             GridBoxAlignment -> {
              "Columns" -> {{Left}}, "Rows" -> {{Automatic}}}, AutoDelete -> 
             False, GridBoxItemSize -> {
              "Columns" -> {{Automatic}}, "Rows" -> {{Automatic}}}, 
             GridBoxSpacings -> {"Columns" -> {{2}}, "Rows" -> {{Automatic}}},
              BaseStyle -> {
              ShowStringCharacters -> False, NumberMarks -> False, 
               PrintPrecision -> 3, ShowSyntaxStyles -> False}]}}, 
