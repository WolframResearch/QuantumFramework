Cell[TextData[{
 "The result is a ",
 Cell[BoxData["PauliStabilizer"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "b1196599-9681-4e79-a25c-21541400287a"],
 ", not a dense state. The stabilizer and Schr\[ODoubleDot]dinger \
constructions land on the same state, as they did on the GHZ circuit; here is \
that check at random, on a 30-gate Clifford circuit. First build the stream \
(suppressed, 30 gate specs):"
}], "Text",ExpressionUUID->"9cad7c19-e883-4be3-bb20-7fe20eeb1c60"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"SeedRandom", "[", "7", "]"}], ";"}], "\n", 
 RowBox[{
  RowBox[{"specs2", " ", "=", " ", 
   RowBox[{"Table", "[", "\n", "   ", 
    RowBox[{
     RowBox[{"RandomChoice", "[", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"\"\<H\>\"", " ", "->", " ", 
         RowBox[{"RandomInteger", "[", 
          RowBox[{"{", 
           RowBox[{"1", ",", " ", "4"}], "}"}], "]"}]}], ",", " ", 
        RowBox[{"\"\<S\>\"", " ", "->", " ", 
         RowBox[{"RandomInteger", "[", 
          RowBox[{"{", 
           RowBox[{"1", ",", " ", "4"}], "}"}], "]"}]}], ",", "\n", "     ", 
        RowBox[{"\"\<CNOT\>\"", " ", "->", " ", 
         RowBox[{"RandomSample", "[", 
          RowBox[{
           RowBox[{"Range", "[", "4", "]"}], ",", " ", "2"}], "]"}]}]}], 
       "}"}], "]"}], ",", "\n", "   ", 
     RowBox[{"{", "30", "}"}]}], "]"}]}], ";"}]}], "Input",
 CellLabel->
  "In[76]:= ",ExpressionUUID->"efb019ac-097e-476f-bc8d-28c1943e0925"],

Cell["Run it densely:", "Text",ExpressionUUID->"c552566a-d3f1-4297-806c-91d82599cb13"],

