Cell[TextData[{
 "The first reason to care is that the single symbolic traversal then serves \
arbitrarily many shots. The ",
 Cell[BoxData["\"\<SampleOutcomes\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "c814c537-5d5c-469b-87b5-3bcbc3e75988"],
 " property draws samples by substituting random bits for the formal ones, \
never re-running the ",
 Cell[BoxData["H"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "96bda93f-e404-4cfb-b753-b4a7b2d0b22b"],
 "-",
 Cell[BoxData["CNOT"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "a41a9f58-2d47-4678-a618-fcbe38e4e41a"],
 " circuit; a thousand shots of the qubit-1 outcome come out a fair coin:"
}], "Text",ExpressionUUID->"9f375710-ac12-4c98-a17e-6fb9b5974dfb"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"SeedRandom", "[", "7", "]"}], ";"}], "\n", 
 RowBox[{"Counts", "[", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"(", 
      RowBox[{"1", " ", "-", " ", 
       RowBox[{
        RowBox[{"#", "[", "\"\<StabilizerSigns\>\"", "]"}], "[", 
        RowBox[{"[", "1", "]"}], "]"}]}], ")"}], " ", "/", " ", "2"}], " ", 
    "&"}], " ", "/@", " ", 
   RowBox[{"sm", "[", 
    RowBox[{"\"\<SampleOutcomes\>\"", ",", " ", "1000"}], "]"}]}], 
  "]"}]}], "Input",
 CellLabel->
  "In[58]:= ",ExpressionUUID->"e7d1a181-104c-4b18-9f90-a909bd597580"],

Cell[BoxData[
 RowBox[{"\[LeftAssociation]", 
  RowBox[{
   RowBox[{"1", "\[Rule]", "492"}], ",", 
   RowBox[{"0", "\[Rule]", "508"}]}], "\[RightAssociation]"}]], "Output",
 CellLabel->
  "Out[58]= ",ExpressionUUID->"34071ab3-bf46-494d-b307-87b377d2a1b3"]
}, Open  ]],

Cell[TextData[{
 "The second reason is deeper: the formal bits ",
 StyleBox["compose", "TI"],
 ". When a later measurement is forced by the outcomes already taken, its \
result is not a fresh coin but an explicit Boolean function of the earlier \
bits, and the engine records that function instead of discarding it. A parity \
check makes this concrete. Prepare two qubits in ",
 Cell[BoxData[
  TemplateBox[{"+"},
   "Ket"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "67c3b926-25e1-4961-b6a4-1866117948d7"],
 ", so each carries a fair-coin ",
 Cell[BoxData[
  StyleBox["Z", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "84346f15-868d-435c-abf2-71912638f7a1"],
 "-outcome, then copy their parity onto a third qubit with two ",
 Cell[BoxData["CNOT"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "a0a02d49-2cb8-40b4-be08-c5b430280f79"],
 "s:"
}], "Text",ExpressionUUID->"3a9a0ade-586f-451d-b690-e9d0ed89527c"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"parityCheck", " ", "=", " ", 
  RowBox[{
   RowBox[{"PauliStabilizer", "[", "3", "]"}], "[", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"\"\<H\>\"", " ", "->", " ", "1"}], ",", " ", 
     RowBox[{"\"\<H\>\"", " ", "->", " ", "2"}], ",", " ", 
     RowBox[{"\"\<CNOT\>\"", " ", "->", " ", 
      RowBox[{"{", 
       RowBox[{"1", ",", " ", "3"}], "}"}]}], ",", " ", 
     RowBox[{"\"\<CNOT\>\"", " ", "->", " ", 
      RowBox[{"{", 
       RowBox[{"2", ",", " ", "3"}], "}"}]}]}], "}"}], "]"}]}]], "Input",
 CellLabel->
  "In[59]:= ",ExpressionUUID->"d9262d4c-42a4-4248-9e58-332b890e42a7"],

