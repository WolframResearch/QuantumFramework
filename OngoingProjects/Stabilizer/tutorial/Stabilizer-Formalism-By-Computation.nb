Cell[TextData[{
 "The outcomes are exactly ",
 Cell[BoxData[
  RowBox[{
   RowBox[{"{", "0"}], ",", "0", ",", 
   RowBox[{"0", "}"}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "252ccbc0-549e-448c-8287-2facfe34d35a"],
 " and ",
 Cell[BoxData[
  RowBox[{
   RowBox[{"{", "1"}], ",", "1", ",", 
   RowBox[{"1", "}"}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "da8d9e11-4bce-4112-ad8e-ef3941d9d9fa"],
 ": the GHZ state never returns a split string with some 0s and some 1s, \
which is the perfect three-body correlation. We can also measure a joint \
Pauli observable directly, for instance the parity ",
 Cell[BoxData[
  StyleBox[
   RowBox[{"Z", "Z"}], "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "ca6c0aa3-c7f2-4b24-b8eb-061ca5b93c72"],
 " on the Bell state, which is deterministic and equal to ",
 Cell[BoxData[
  RowBox[{"+", "1"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "b7e540da-f0a7-44d5-b39b-4351b3fcd0dc"],
 ":"
}], "Text",ExpressionUUID->"55c8515f-a8de-4505-b50b-05bb90eac0ef"],

