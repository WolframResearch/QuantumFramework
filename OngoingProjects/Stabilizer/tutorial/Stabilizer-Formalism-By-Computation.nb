 CellLabel->
  "In[102]:= ",ExpressionUUID->"84da0de4-bfe6-49f1-967e-b08b15a152a2"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     FractionBox["9", "10"], ",", 
     RowBox[{"{", "\<\"Z\"\>", "}"}]}], "}"}], ",", 
