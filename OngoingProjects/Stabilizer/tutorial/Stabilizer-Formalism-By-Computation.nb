Cell[TextData[{
 "The raw symplectic data is ",
 Cell[BoxData["\"\<Tableau\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "cb77c335-1974-4c1e-baf9-17f5859bdc43"],
 ", a rank-3 array stacking the ",
 Cell[BoxData[
  StyleBox["X", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "96b0fbb7-15d7-4ff3-8323-4611d7fcdbda"],
 " block above the ",
 Cell[BoxData[
  StyleBox["Z", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "98f35a02-780a-4888-94f6-9dade092e73d"],
 " block (shape ",
 Cell[BoxData[
  RowBox[{"2", "\[Times]", 
   StyleBox["n", "TI"], "\[Times]", "2", 
   StyleBox["n", "TI"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "103b2d68-34f7-4727-b6da-67d76e3c01f0"],
 ", here ",
 Cell[BoxData[
  RowBox[{"2", "\[Times]", "2", "\[Times]", "4"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "1473571c-41c0-4b18-b3cd-f680ac52c3af"],
 ": two blocks, ",
 Cell[BoxData[
  RowBox[{
   StyleBox["n", "TI"], "=", "2"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "61f85b5d-e630-4161-873b-2a986c10c889"],
 " qubits, ",
 Cell[BoxData[
  RowBox[{"2", 
   StyleBox["n", "TI"], "=", "4"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "99f91f27-71fd-436b-9926-b15031ddb3d7"],
 " rows):"
}], "Text",ExpressionUUID->"d7523227-f9af-496f-b488-bcfacf078a72"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"PauliStabilizer", "[", "2", "]"}], "[", "\"\<Tableau\>\"", 
  "]"}]], "Input",
 CellLabel->
  "In[16]:= ",ExpressionUUID->"de439568-53b7-479b-a280-1e75434c9f00"],

