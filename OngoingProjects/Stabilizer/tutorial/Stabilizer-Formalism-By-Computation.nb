 "Its five generators are four weight-four checks plus the logical ",
 Cell[BoxData[
  OverscriptBox[
   StyleBox["Z", "TI"], "_"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "b31c872e-a860-4342-8504-ab0e31bedfc8"],
 ":"
}], "Text",ExpressionUUID->"31898767-1cd2-42fc-b53a-cc42b2323710"],

