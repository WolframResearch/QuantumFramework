Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{"-", 
    FractionBox["1", 
     SqrtBox["2"]]}], ",", 
   FractionBox["1", 
    SqrtBox["2"]]}], "}"}]], "Output",
 CellLabel->
  "Out[14]= ",ExpressionUUID->"47ddb8a2-a69e-4fe8-aa4c-c7cfa5e5a262"]
}, Open  ]],

Cell["\<\
For everything observable, probabilities, expectation values, entanglement, \
the global phase is irrelevant, so this costs us nothing in practice. We flag \
it now because it is the one place where the cheap representation is \
genuinely less informative than the dense one.\
\>", "Text",ExpressionUUID->"a1696159-0f2b-41d4-987a-b3c94a79fa9d"],

Cell["The essentials of the one-qubit picture:", "Text",ExpressionUUID->"6a555218-fccb-442a-b38b-1c3330d6fc8e"],

Cell[TextData[{
 "A one-qubit stabilizer state is named by the single Pauli operator that \
fixes it: ",
 Cell[BoxData[
  StyleBox["Z", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "d00d12f2-ab30-4836-932c-058133f2ee55"],
 " for ",
 Cell[BoxData[
  TemplateBox[{"0"},
   "Ket"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "db79321d-34ea-428f-9766-b60276010997"],
 ", ",
 Cell[BoxData[
  StyleBox["X", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "c0992cdf-39f3-4232-ad86-cde2c3ed5b56"],
 " for ",
 Cell[BoxData[
  TemplateBox[{"+"},
   "Ket"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "651fa342-5dfe-4bcc-9f06-2597137e05bb"],
 ", ",
 Cell[BoxData[
  RowBox[{"-", 
   StyleBox["Z", "TI"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "bc1ddeee-d160-48d1-a4cc-32f423b79dc2"],
 " for ",
 Cell[BoxData[
  TemplateBox[{"1"},
   "Ket"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "56af30d6-2cff-4e9c-9d42-da58c3731581"],
 "."
}], "Item",ExpressionUUID->"ae3c22c9-4260-4a32-a7df-7fbbca378f53"],

Cell[TextData[{
 Cell[BoxData["PauliStabilizer"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "a1e3c1c4-4505-46bd-aa32-ad3645f98a34"],
 " carries that operator, not the amplitudes; the ",
 Cell[BoxData["\"\<State\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "5c6d265a-5c46-49b4-85ee-882906f64c3a"],
 " property hands back a full ",
 Cell[BoxData["QuantumState"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "92f2de22-a4c2-418e-9578-2dc0db8b0ddc"],
 " on demand, and ",
 Cell[BoxData["\"\<StateVector\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "5235e489-d4d0-44cd-9f6f-a86961307e0f"],
 " on that object gives the raw ",
 Cell[BoxData[
  SuperscriptBox["2", 
   StyleBox["n", "TI"]]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "5555a9ed-cf1c-4428-8901-8d09f5de41a4"],
 " amplitudes."
}], "Item",ExpressionUUID->"4d83c658-cf51-400c-a409-e17cf82850af"],

Cell["\<\
The reconstructed vector is exact up to a global phase, which never affects \
an observable.\
\>", "Item",ExpressionUUID->"715a9ed0-c15f-4b09-aeca-e86cee0cd2d4"]
}, Open  ]],

Cell[CellGroupData[{

Cell[TextData[{
 "The tableau: ",
 Cell[BoxData[
  StyleBox["n", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "56e20696-94ef-4eab-8586-356a2eaa6d10"],
 " generators instead of ",
 Cell[BoxData[
  SuperscriptBox["2", 
   StyleBox["n", "TI"]]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "5de99a5f-ca5d-4d8f-af37-53e3bc0e6aa8"],
 " amplitudes"
}], "Section",ExpressionUUID->"1997a91e-b674-45dc-aa7b-9d8257955613"],

Cell[TextData[{
 "For ",
 Cell[BoxData[
  StyleBox["n", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "4316a019-203d-427d-bd9e-d38c4cf17ecd"],
 " qubits the idea scales because the stabilizer group is generated by just \
",
 Cell[BoxData[
  StyleBox["n", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "da9d9221-e563-4b7a-ac31-10f92fa962ea"],
 " commuting, independent Pauli strings, and each Pauli string of length ",
 Cell[BoxData[
  StyleBox["n", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "ae0d240d-0c6a-44d3-b2fb-27f982984429"],
 " is two bits per qubit: an ",
 Cell[BoxData[
  StyleBox["X", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "938a5918-eb76-4806-8aa1-a3644e5e2113"],
 "-exponent and a ",
 Cell[BoxData[
  StyleBox["Z", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "d7db6b9a-626c-4eb4-9802-bf85ac501f5c"],
 "-exponent, since ",
 Cell[BoxData[
  RowBox[{
   StyleBox["Y", "TI"], "=", 
   StyleBox["i", "TI"], 
   StyleBox["X", "TI"], 
   StyleBox["Z", "TI"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "fb56e58a-63ac-4500-8d8c-473b0b6e2395"],
 ". So a stabilizer state is a binary matrix of shape ",
 Cell[BoxData[
  RowBox[{
   StyleBox["n", "TI"], "\[Times]", "2", 
   StyleBox["n", "TI"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "fa9ce690-2763-4de4-93c7-6405f45549a9"],
 " together with ",
 Cell[BoxData[
  StyleBox["n", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "4c18b280-0b90-4e3f-99db-b8601b312570"],
 " signs, which is ",
 Cell[BoxData[
  RowBox[{
   StyleBox["O", "TI"], 
   StyleBox["(",
    SpanMaxSize->1], 
   SuperscriptBox[
    StyleBox["n", "TI"], "2"], 
   StyleBox[")",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "6c6ed5d2-3847-4fa6-b70b-b30af391b3ae"],
 " bits in place of ",
 Cell[BoxData[
  SuperscriptBox["2", 
   StyleBox["n", "TI"]]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "22f0caf9-bd67-4957-854a-bdd477f2476c"],
 " amplitudes. This binary ",
 Cell[BoxData[
  RowBox[{
   StyleBox["(",
    SpanMaxSize->1], 
   RowBox[{
    StyleBox["X", "TI"], "\[VerticalSeparator]", 
    StyleBox["Z", "TI"]}], 
   StyleBox[")",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "ee5fb314-366a-4f16-a5b6-eaa3e6b2dfe6"],
 " encoding is the ",
 StyleBox["symplectic representation", "TI"],
 " of the Pauli group."
}], "Text",ExpressionUUID->"64e53b5b-916f-4558-9524-b424e0691177"],

Cell[TextData[{
 "Look at the two-qubit register ",
 Cell[BoxData[
  TemplateBox[{"00"},
   "Ket"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "6d53b6d4-b95d-4bf2-833c-802d78718393"],
 ". The object itself previews the generators and a tableau grid:"
}], "Text",ExpressionUUID->"264d9d80-ba3f-4b35-b24e-0440938892a3"],

