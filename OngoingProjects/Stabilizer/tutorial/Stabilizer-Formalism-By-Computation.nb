Cell["\<\
Its amplitudes are the answer the formalism has to reproduce:\
\>", "Text",ExpressionUUID->"1a55ce02-f32e-4d94-99c2-5141dd5b5d14"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"psiSchrodinger", "[", "\"\<StateVector\>\"", "]"}], " ", "//", " ",
   "Normal"}]], "Input",
 CellLabel->
  "In[33]:= ",ExpressionUUID->"4e0a69d5-273d-4b25-b694-235d8a382490"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   FractionBox["1", 
    SqrtBox["2"]], ",", "0", ",", "0", ",", "0", ",", "0", ",", "0", ",", "0",
    ",", 
   FractionBox["\[ImaginaryI]", 
    SqrtBox["2"]]}], "}"}]], "Output",
 CellLabel->
  "Out[33]= ",ExpressionUUID->"027eb238-f4eb-4769-a657-48f98d01925b"]
}, Open  ]],

Cell[TextData[{
 "The state is ",
 Cell[BoxData[
  RowBox[{
   RowBox[{"(", 
    RowBox[{
     TemplateBox[{"000"},
      "Ket"], "+", 
     RowBox[{
      StyleBox["i", "TI"], 
      TemplateBox[{"111"},
       "Ket"]}]}], ")"}], "/", 
   SqrtBox["2"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "47317adf-d4b1-4315-a5aa-1bee5ee446ad"],
 ", a GHZ-type state carrying the relative phase the ",
 Cell[BoxData[
  StyleBox["S", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "5e135788-b6b5-4ad3-9bbc-f34808003fcd"],
 " gate inserted."
}], "Text",ExpressionUUID->"351b9c3e-4fc7-4245-81c9-a491ac837363"],

Cell[TextData[{
 "Now the Heisenberg picture. Instead of asking where the state goes, ask \
what fixes it. If ",
 Cell[BoxData[
  StyleBox["g", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "c95bd620-01d5-488d-bbc2-588f65e49827"],
 " stabilizes ",
 Cell[BoxData[
  TemplateBox[{
    StyleBox["\[Psi]", "TI"]},
   "Ket"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "57d84975-3ca7-4435-8363-ef004898355d"],
 ", then after a gate ",
 Cell[BoxData[
  StyleBox["U", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "7f751c69-47b1-4ee1-88e1-c2dda9ea123b"],
 " the conjugated operator ",
 Cell[BoxData[
  RowBox[{
   StyleBox["U", "TI"], 
   StyleBox["g", "TI"], 
   SuperscriptBox[
    StyleBox["U", "TI"], "\[Dagger]"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "1aee1929-6112-4b40-98cc-b19337514ec0"],
 " stabilizes ",
 Cell[BoxData[
  RowBox[{
   StyleBox["U", "TI"], 
   TemplateBox[{
     StyleBox["\[Psi]", "TI"]},
    "Ket"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "ecf54eb5-ed18-4e46-b2cf-85398da83fa3"],
 ", because ",
 Cell[BoxData[
  RowBox[{
   RowBox[{
    StyleBox["g", "TI"], 
    TemplateBox[{
      StyleBox["\[Psi]", "TI"]},
     "Ket"]}], "=", 
   TemplateBox[{
     StyleBox["\[Psi]", "TI"]},
    "Ket"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "6946404f-635b-42d8-a9cf-ad4721bde843"],
 " gives ",
 Cell[BoxData[
  RowBox[{
   RowBox[{
    RowBox[{
     StyleBox["(",
      SpanMaxSize->1], 
     RowBox[{
      StyleBox["U", "TI"], 
      StyleBox["g", "TI"], 
      SuperscriptBox[
       StyleBox["U", "TI"], "\[Dagger]"]}], 
     StyleBox[")",
      SpanMaxSize->1]}], 
    StyleBox["U", "TI"], 
    TemplateBox[{
      StyleBox["\[Psi]", "TI"]},
     "Ket"]}], "=", 
   RowBox[{
    RowBox[{
     StyleBox["U", "TI"], 
     StyleBox["g", "TI"], 
     TemplateBox[{
       StyleBox["\[Psi]", "TI"]},
      "Ket"]}], "=", 
    RowBox[{
     StyleBox["U", "TI"], 
     TemplateBox[{
       StyleBox["\[Psi]", "TI"]},
      "Ket"]}]}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "3bf23128-0c5d-442a-a195-cebb1f44dc85"],
 ". The whole evolution of the state is therefore carried by the conjugation ",
 Cell[BoxData[
  RowBox[{
   StyleBox["g", "TI"], "\[Function]", 
   StyleBox["U", "TI"], 
   StyleBox["g", "TI"], 
   SuperscriptBox[
    StyleBox["U", "TI"], "\[Dagger]"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "98fe66dd-d84a-413e-86de-d73186431c1f"],
 " of its generators, and the one fact that makes this cheap is that a \
Clifford sends a Pauli to a Pauli. Take the input generator ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["Z", "TI"], "1"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "5383be27-b247-4565-b3bb-9dd1c9814967"],
 " and conjugate it by the circuit, ",
 Cell[BoxData[
  RowBox[{
   StyleBox["U", "TI"], " ", 
   SubscriptBox[
    StyleBox["Z", "TI"], "1"], " ", 
   SuperscriptBox[
    StyleBox["U", "TI"], "\[Dagger]"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "feb7c4a2-4700-4e6c-9f82-a99ecc235f15"],
 ". Writing that conjugation as a circuit that applies ",
 Cell[BoxData[
  SuperscriptBox[
   StyleBox["U", "TI"], "\[Dagger]"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "c7c1f2a7-edce-4950-9a3a-6ff871bb870d"],
 ", then ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["Z", "TI"], "1"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "38d54952-c5c7-4ce9-a3b5-1897beba8a52"],
 ", then ",
 Cell[BoxData[
  StyleBox["U", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "51e8cd26-b14b-41f6-a9b0-623af3c236bc"],
 ", ",
 Cell[BoxData["\"\<PauliDecompose\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "50bea117-be6a-4df7-8f7c-63b8cbff5ba1"],
 " reads off the result:"
}], "Text",ExpressionUUID->"fc3e9cb0-a21b-48bf-80b4-ebed97e51903"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"QuantumCircuitOperator", "[", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"cliffordCircuit", "[", "\"\<Dagger\>\"", "]"}], ",", " ", 
     RowBox[{"\"\<Z\>\"", " ", "->", " ", "1"}], ",", " ", 
     "cliffordCircuit"}], "}"}], "]"}], "[", "\"\<PauliDecompose\>\"", 
  "]"}]], "Input",
 CellLabel->
  "In[34]:= ",ExpressionUUID->"f118538f-e72e-4cba-b6d5-8ddc184f195c"],

Cell[BoxData[
 RowBox[{"\[LeftAssociation]", 
  RowBox[{"\<\"XYX\"\>", "\[Rule]", "1"}], "\[RightAssociation]"}]], "Output",\

 CellLabel->
  "Out[34]= ",ExpressionUUID->"8c94c7fd-bd95-428e-9938-ec67cc914624"]
}, Open  ]],

Cell[TextData[{
 "The decomposition has a single term, ",
 Cell[BoxData[
  RowBox[{
   SubscriptBox[
    StyleBox["X", "TI"], "1"], 
   SubscriptBox[
    StyleBox["Y", "TI"], "2"], 
   SubscriptBox[
    StyleBox["X", "TI"], "3"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "94aa926a-3183-4665-afc3-9ad2bce792f2"],
 ": the operator never left the Pauli group. One generator went in, one came \
out. That closure is why each tableau update is a fixed local rewrite of a \
few bits rather than a dense matrix multiply."
}], "Text",ExpressionUUID->"f82530c1-6443-4b63-bd62-6d4b318c87c3"],

Cell[TextData[{
 "Propagating all three input generators ",
 Cell[BoxData[
  RowBox[{
   SubscriptBox[
    StyleBox["Z", "TI"], "1"], ",", 
   SubscriptBox[
    StyleBox["Z", "TI"], "2"], ",", 
   SubscriptBox[
    StyleBox["Z", "TI"], "3"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "7e860cd3-4f41-42a3-b881-3405e66d270e"],
 " this way is exactly what the stabilizer backend does. Running the ",
 StyleBox["same circuit object", "TI"],
 " with ",
 Cell[BoxData[
  RowBox[{"Method", " ", "->", " ", "\"\<Stabilizer\>\""}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "34e56860-335f-4bac-9449-f0494060a979"],
 " in place of ",
 Cell[BoxData["\"\<Schrodinger\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "d92e6def-e3c3-4a4d-af74-9bb8d0fae89d"],
 " returns the stabilizer group of the final state, whose first generator is \
the ",
 Cell[BoxData[
  RowBox[{
   SubscriptBox[
    StyleBox["X", "TI"], "1"], 
   SubscriptBox[
    StyleBox["Y", "TI"], "2"], 
   SubscriptBox[
    StyleBox["X", "TI"], "3"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "52cc9633-7b79-403e-8254-12746caf1fae"],
 " we just conjugated by hand:"
}], "Text",ExpressionUUID->"643cd7af-a9a7-41a9-a0ac-52ec2d4d15d8"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"cliffordCircuit", "[", 
   RowBox[{
    RowBox[{"QuantumState", "[", "\"\<000\>\"", "]"}], ",", " ", 
    RowBox[{"Method", " ", "->", " ", "\"\<Stabilizer\>\""}]}], "]"}], 
  "[", "\"\<Stabilizers\>\"", "]"}]], "Input",
 CellLabel->
  "In[35]:= ",ExpressionUUID->"9cf92baa-3208-4aa9-af37-879c7c892ff5"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"\<\"XYX\"\>", ",", "\<\"ZZI\"\>", ",", "\<\"IZZ\"\>"}], 
  "}"}]], "Output",
 CellLabel->
  "Out[35]= ",ExpressionUUID->"18951d1a-661a-4bb4-9acf-19caf54c6248"]
}, Open  ]],

Cell[TextData[{
 "The two pictures must describe the same physics, and they do. Materialize \
the state from the final generators (the formalism's ",
 Cell[BoxData["\"\<State\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "85dde6b7-76d5-4f45-a14b-b11828db8075"],
 "):"
}], "Text",ExpressionUUID->"85c6d2d6-cea7-48b2-b848-a060832a27ac"],

