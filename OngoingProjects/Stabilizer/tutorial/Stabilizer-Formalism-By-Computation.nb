Cell[TextData[{
 "The outcomes are exactly ",
 Cell[BoxData[
  RowBox[{
   RowBox[{"{", "0"}], ",", "0", ",", 
   RowBox[{"0", "}"}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "7157e2e7-f80d-4269-aad7-99ba12600a74"],
 " and ",
 Cell[BoxData[
  RowBox[{
   RowBox[{"{", "1"}], ",", "1", ",", 
   RowBox[{"1", "}"}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "b384c4dd-3154-4d67-8bde-4ee133378101"],
 ": the GHZ state never returns a split string with some 0s and some 1s, \
which is the perfect three-body correlation. We can also measure a joint \
Pauli observable directly, for instance the parity ",
 Cell[BoxData[
  StyleBox[
   RowBox[{"Z", "Z"}], "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "963ec943-2482-4985-994e-ada916ea7452"],
 " on the Bell state, which is deterministic and equal to ",
 Cell[BoxData[
  RowBox[{"+", "1"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "6522244b-0ace-417a-80d1-0316718c4843"],
 ":"
}], "Text",ExpressionUUID->"71b21fd5-b687-4e19-b4c5-0b853e951607"],

