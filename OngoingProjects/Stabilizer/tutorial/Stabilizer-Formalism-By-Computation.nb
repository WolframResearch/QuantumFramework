Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"psAffineDemo", "[", "\"\<State\>\"", "]"}], 
   "[", "\"\<StateVector\>\"", "]"}], " ", "//", " ", "Normal"}]], "Input",
 CellLabel->
