 RowBox[{"parityCheck", " ", "=", " ", 
  RowBox[{
   RowBox[{"PauliStabilizer", "[", "3", "]"}], "[", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"\"\<H\>\"", " ", "->", " ", "1"}], ",", " ", 
     RowBox[{"\"\<H\>\"", " ", "->", " ", "2"}], ",", " ", 
     RowBox[{"\"\<CNOT\>\"", " ", "->", " ", 
      RowBox[{"{", 
       RowBox[{"1", ",", " ", "3"}], "}"}]}], ",", " ", 
     RowBox[{"\"\<CNOT\>\"", " ", "->", " ", 
      RowBox[{"{", 
       RowBox[{"2", ",", " ", "3"}], "}"}]}]}], "}"}], "]"}]}]], "Input",
 CellLabel->
  "In[59]:= ",ExpressionUUID->"950c5b8b-7fd6-45bc-84c7-02810960dffd"],

