}, Open  ]],

Cell[TextData[{
 "The parities ",
 Cell[BoxData[
  StyleBox[
   RowBox[{"Z", "Z"}], "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "8763066f-ada3-4a77-972e-da52a7f04d1c"],
 " and ",
 Cell[BoxData[
  StyleBox[
   RowBox[{"X", "X"}], "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "7998b12a-0053-41d5-9ad4-6cdb283fa99e"],
 " are certain (",
 Cell[BoxData[
  RowBox[{"+", "1"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "b4b6a781-c62e-4c7e-a58a-4ee89c3623fb"],
 "), while a single-qubit ",
 Cell[BoxData[
  StyleBox["Z", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "0a1f1d1b-cf13-4314-bb53-22991c458b2d"],
 " is maximally uncertain (",
 Cell[BoxData["0"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "be142796-574a-4812-afba-e88e87c46a49"],
 "), the hallmark of an entangled state whose marginals are maximally mixed."
}], "Text",ExpressionUUID->"4f11daae-47ed-4985-be6d-79d713334df2"],

Cell[TextData[{
 "Before making this efficient, look closely at what ",
 Cell[BoxData[
  RowBox[{"ps", "[", 
   RowBox[{"\"\<M\>\"", ",", " ", "q"}], "]"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "4de88b64-acc3-47b0-85b0-816633d40226"],
 " actually builds when measurements pile up, because that structure is what \
the next idea improves on. Each measurement does one of two things. If the \
observable is already certain, the outcome is forced and the state is \
unchanged; if it is undetermined, the outcome is a fair coin and the state \
collapses one of two ways. Measuring the qubits in turn therefore grows a ",
 StyleBox["tree of histories", "TI"],
 " that forks at every undetermined measurement, and the Association ",
 Cell[BoxData[
  RowBox[{"ps", "[", 
   RowBox[{"\"\<M\>\"", ",", " ", "q"}], "]"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "70336f65-b9c7-4672-8305-5ca23983aa66"],
 " is exactly the set of branches at one node. WL grows the whole tree with \
",
 Cell[BoxData["NestTree"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "2d5620d3-6244-415e-ad03-96f3b676f038"],
 ", which starts from a root and repeatedly applies a rule supplying each \
node's children; returning the branches as an Association keyed by the \
outcome puts each outcome on an edge:"
}], "Text",ExpressionUUID->"512517ac-c0e6-4dac-9760-2dc323b32c2e"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"step", "[", 
    RowBox[{"{", 
     RowBox[{"q_", ",", " ", "ps_"}], "}"}], "]"}], " ", ":=", " ", 
   RowBox[{"If", "[", 
    RowBox[{
     RowBox[{"q", " ", ">", " ", 
      RowBox[{"ps", "[", "\"\<Qubits\>\"", "]"}]}], ",", " ", 
     RowBox[{"<|", "|>"}], ",", " ", 
     RowBox[{"Map", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"{", 
         RowBox[{
          RowBox[{"q", " ", "+", " ", "1"}], ",", " ", "#"}], "}"}], " ", 
        "&"}], ",", " ", 
       RowBox[{"ps", "[", 
        RowBox[{"\"\<M\>\"", ",", " ", "q"}], "]"}]}], "]"}]}], "]"}]}], 
  ";"}], "\n", 
 RowBox[{
  RowBox[{"measurementTree", "[", "ps_", "]"}], " ", ":=", " ", 
  RowBox[{"TreeMap", "[", 
   RowBox[{
    RowBox[{"\"\<\>\"", " ", "&"}], ",", " ", 
    RowBox[{"NestTree", "[", 
     RowBox[{"step", ",", " ", 
      RowBox[{"{", 
       RowBox[{"1", ",", " ", "ps"}], "}"}], ",", " ", 
      RowBox[{"ps", "[", "\"\<Qubits\>\"", "]"}]}], "]"}]}], 
   "]"}]}]}], "Input",
 CellLabel->
  "In[52]:= ",ExpressionUUID->"88bbb68b-8e9c-409e-84e8-531c1b1bdb4a"],

Cell[TextData[{
 "Three independent ",
 Cell[BoxData[
  TemplateBox[{"+"},
   "Ket"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "2705faa7-0cf3-4f38-a398-df4b42cdef91"],
 " qubits are three independent fair coins, so the history forks at every \
step into all ",
 Cell[BoxData[
  RowBox[{
   SuperscriptBox["2", "3"], "=", "8"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "e4dc874f-083c-4401-aea7-d1eafad3bb35"],
 " leaves:"
}], "Text",ExpressionUUID->"44ddce8e-de78-42f6-af1d-7dcea99756e0"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"measurementTree", "[", 
  RowBox[{
   RowBox[{"PauliStabilizer", "[", "3", "]"}], "[", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"\"\<H\>\"", " ", "->", " ", "1"}], ",", " ", 
     RowBox[{"\"\<H\>\"", " ", "->", " ", "2"}], ",", " ", 
     RowBox[{"\"\<H\>\"", " ", "->", " ", "3"}]}], "}"}], "]"}], 
  "]"}]], "Input",
 CellLabel->
  "In[53]:= ",ExpressionUUID->"f13d86c5-8f65-4f7c-8eee-c684ebc84f28"],

