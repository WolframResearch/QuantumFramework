Cell["\<\
Every error produces a different, nonzero syndrome. In fact the fifteen \
errors realize exactly the fifteen nonzero four-bit strings, none missing and \
none repeated:\
\>", "Text",ExpressionUUID->"cbc3fbf4-d393-4c67-ae42-3e7293247a18"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"Sort", "[", 
   RowBox[{"syndrome", " ", "/@", " ", "errors"}], "]"}], " ", "===", " ", 
  RowBox[{"Sort", " ", "@", " ", 
   RowBox[{"DeleteCases", "[", 
    RowBox[{
     RowBox[{"Tuples", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"0", ",", " ", "1"}], "}"}], ",", " ", "4"}], "]"}], ",", " ", 
     RowBox[{"{", 
      RowBox[{"0", ",", " ", "0", ",", " ", "0", ",", " ", "0"}], "}"}]}], 
    "]"}]}]}]], "Input",
 CellLabel->
  "In[86]:= ",ExpressionUUID->"f6ee0c8a-91aa-4b97-98ca-04f7a7d5d360"],

Cell[BoxData["True"], "Output",
 CellLabel->
  "Out[86]= ",ExpressionUUID->"4accb498-51a9-455c-856b-313214a3881f"]
}, Open  ]],

Cell[TextData[{
 "That bijection is what \"perfect code\" means, and what \"distance three, \
corrects one\" buys: every single-qubit error carries its own fingerprint, so \
a decoder recovers the error by inverting the table, and reading the four \
checks never disturbs the logical qubit they protect. This is syndrome \
extraction, the conserved-parity check generalized from one ",
 Cell[BoxData[
  StyleBox[
   RowBox[{"Z", "Z", "Z"}], "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "78542cfd-4e73-4344-8ffa-f8a0ce1522f7"],
 " to a real code's full set of checks."
}], "Text",ExpressionUUID->"c570018b-26d9-48cd-9a6d-e38162ebd7b1"],

Cell[TextData[{
 "The Steane code, the CSS code built from the classical ",
 Cell[BoxData[
  RowBox[{
   StyleBox["[",
    SpanMaxSize->1], 
   RowBox[{"7", ",", "4"}], 
   StyleBox["]",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "52771a0c-c587-4d04-83c2-e3ce578b3e9c"],
 " Hamming code, sorts the same machinery into ",
 Cell[BoxData[
  StyleBox["X", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "2b383290-aaf3-4cf0-b10a-d3f16eb6ad37"],
 "-type and ",
 Cell[BoxData[
  StyleBox["Z", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "47f14afc-885b-4997-8787-df1387aa3798"],
 "-type checks:"
}], "Text",ExpressionUUID->"b2427b33-889f-485a-b9ca-650f5a52943f"],

