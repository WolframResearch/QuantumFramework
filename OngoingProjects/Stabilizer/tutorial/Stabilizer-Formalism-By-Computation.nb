  StyleBox["Z", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "7b528536-1df4-4029-b8f3-d27b2dca692f"],
 "-type generator ",
 Cell[BoxData[
  StyleBox[
   RowBox[{"Z", "Z", "Z"}], "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "a6307981-03fe-4c8d-a969-3e009f3ceea6"],
 ", the conserved parity that binds the three ",
 Cell[BoxData[
  StyleBox["Z", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "86ba32dc-a3c5-429b-a817-13138b72835c"],
 "-outcomes."
}], "Text",ExpressionUUID->"6e66b26c-efc3-4296-896b-8ca598d54d51"],

