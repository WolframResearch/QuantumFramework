}, Open  ]],

Cell[TextData[{
 "The parities ",
 Cell[BoxData[
  StyleBox[
   RowBox[{"Z", "Z"}], "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "9d89da02-8664-4fec-b9c3-ef5689657b90"],
 " and ",
 Cell[BoxData[
  StyleBox[
   RowBox[{"X", "X"}], "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "04ec407b-c8e6-4a6f-9fe6-55c4202960cd"],
 " are certain (",
 Cell[BoxData[
  RowBox[{"+", "1"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "7de8be89-ff1c-4b80-8748-cd43bb2d7b5c"],
 "), while a single-qubit ",
 Cell[BoxData[
  StyleBox["Z", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "e0a5a5d9-f26a-4d35-9cec-86248a05b3e4"],
 " is maximally uncertain (",
 Cell[BoxData["0"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "b1f62eca-908e-4441-908b-93f1bf438449"],
 "), the hallmark of an entangled state whose marginals are maximally mixed."
}], "Text",ExpressionUUID->"d793b600-e243-4c79-9a5e-08613024d71e"],

Cell[TextData[{
 "Before making this efficient, look closely at what ",
 Cell[BoxData[
  RowBox[{"ps", "[", 
   RowBox[{"\"\<M\>\"", ",", " ", "q"}], "]"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "ac5cc8c7-af31-47ea-9175-dc16c2b0f148"],
 " actually builds when measurements pile up, because that structure is what \
the next idea improves on. Each measurement does one of two things. If the \
observable is already certain, the outcome is forced and the state is \
unchanged; if it is undetermined, the outcome is a fair coin and the state \
collapses one of two ways. Measuring the qubits in turn therefore grows a ",
 StyleBox["tree of histories", "TI"],
 " that forks at every undetermined measurement, and the Association ",
 Cell[BoxData[
  RowBox[{"ps", "[", 
   RowBox[{"\"\<M\>\"", ",", " ", "q"}], "]"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "5abe09f0-6c2a-433a-a247-a949c097b814"],
 " is exactly the set of branches at one node. WL grows the whole tree with \
",
 Cell[BoxData["NestTree"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "b3b06f24-45b0-4dd6-9dfc-34680831d900"],
 ", which starts from a root and repeatedly applies a rule supplying each \
node's children; returning the branches as an Association keyed by the \
outcome puts each outcome on an edge:"
}], "Text",ExpressionUUID->"d4ff02cb-01b0-48cf-985a-97f29ab276ee"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"step", "[", 
    RowBox[{"{", 
     RowBox[{"q_", ",", " ", "ps_"}], "}"}], "]"}], " ", ":=", " ", 
   RowBox[{"If", "[", 
    RowBox[{
     RowBox[{"q", " ", ">", " ", 
      RowBox[{"ps", "[", "\"\<Qubits\>\"", "]"}]}], ",", " ", 
     RowBox[{"<|", "|>"}], ",", " ", 
     RowBox[{"Map", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"{", 
         RowBox[{
          RowBox[{"q", " ", "+", " ", "1"}], ",", " ", "#"}], "}"}], " ", 
        "&"}], ",", " ", 
       RowBox[{"ps", "[", 
        RowBox[{"\"\<M\>\"", ",", " ", "q"}], "]"}]}], "]"}]}], "]"}]}], 
  ";"}], "\n", 
 RowBox[{
  RowBox[{"measurementTree", "[", "ps_", "]"}], " ", ":=", " ", 
  RowBox[{"TreeMap", "[", 
   RowBox[{
    RowBox[{"\"\<\>\"", " ", "&"}], ",", " ", 
    RowBox[{"NestTree", "[", 
     RowBox[{"step", ",", " ", 
      RowBox[{"{", 
       RowBox[{"1", ",", " ", "ps"}], "}"}], ",", " ", 
      RowBox[{"ps", "[", "\"\<Qubits\>\"", "]"}]}], "]"}]}], 
   "]"}]}]}], "Input",
 CellLabel->
  "In[52]:= ",ExpressionUUID->"8a90ad66-6508-452f-a0db-26a65acbf7d9"],

Cell[TextData[{
 "Three independent ",
 Cell[BoxData[
  TemplateBox[{"+"},
   "Ket"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "f0d46855-5beb-494e-889e-701d4953d377"],
 " qubits are three independent fair coins, so the history forks at every \
step into all ",
 Cell[BoxData[
  RowBox[{
   SuperscriptBox["2", "3"], "=", "8"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "d2af2b1e-cbd4-4ab5-8af9-6c78a74e229f"],
 " leaves:"
}], "Text",ExpressionUUID->"70819279-53e5-4707-90b2-73b23bc1f42d"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"measurementTree", "[", 
  RowBox[{
   RowBox[{"PauliStabilizer", "[", "3", "]"}], "[", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"\"\<H\>\"", " ", "->", " ", "1"}], ",", " ", 
     RowBox[{"\"\<H\>\"", " ", "->", " ", "2"}], ",", " ", 
     RowBox[{"\"\<H\>\"", " ", "->", " ", "3"}]}], "}"}], "]"}], 
  "]"}]], "Input",
 CellLabel->
  "In[53]:= ",ExpressionUUID->"c460e207-e857-4bf5-b4c2-28b5e73bb9f4"],

