Cell[TextData[{
 "Rather than chase that phase by hand, compare the two states with the \
framework's ",
 Cell[BoxData["QuantumSimilarity"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "f15c0df9-e920-47f5-8eaa-ae41812a4fb5"],
 ", which is one exactly when they agree up to a global phase:"
}], "Text",ExpressionUUID->"a0719529-182e-4723-9016-a89316eb89d4"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"QuantumSimilarity", "[", 
  RowBox[{"psiSchrodinger", ",", " ", "psiStabilizer"}], "]"}]], "Input",
 CellLabel->
  "In[38]:= ",ExpressionUUID->"6c9ea2eb-b935-46c1-af17-5ea03cf5eefc"],

Cell[BoxData["1"], "Output",
 CellLabel->
  "Out[38]= ",ExpressionUUID->"00dc697e-e191-4cab-ad71-64f3daffedec"]
}, Open  ]],

Cell[TextData[{
 "This is the Gottesman-Knill theorem made concrete: a Clifford circuit on a \
stabilizer input is simulated by propagating ",
 Cell[BoxData[
  StyleBox["n", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "8faf09e2-7c68-4c5f-893d-8102e635ff00"],
 " generators at ",
 Cell[BoxData[
  RowBox[{
   StyleBox["O", "TI"], 
   StyleBox["(",
    SpanMaxSize->1], 
   StyleBox["n", "TI"], 
   StyleBox[")",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "d147d45b-cab7-4f94-a560-96b4277d62a9"],
 " work per gate, and the state it computes is exactly the one Schr\
\[ODoubleDot]dinger evolution would, with the ",
 Cell[BoxData[
  SuperscriptBox["2", 
   StyleBox["n", "TI"]]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "0122cbd4-93d7-4ccc-a7a9-34f98bd6c15d"],
 " vector never formed except, here, to check."
}], "Text",ExpressionUUID->"06c3cce9-861d-4ae0-9932-4a7442ba4db9"],

Cell[TextData[{
 "The construction rests entirely on Clifford conjugation keeping a Pauli a \
Pauli, so it is also clear where it must break. A non-Clifford gate does not \
respect the Pauli group. The ",
 Cell[BoxData[
  StyleBox["T", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "1bf6e5c4-1ef7-4e26-a90e-4ab58fa3cbf4"],
 " gate commutes with ",
 Cell[BoxData[
  StyleBox["Z", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "4d22b3a9-c7f8-4587-ba4d-3c1be95fb618"],
 ", but conjugating ",
 Cell[BoxData[
  StyleBox["X", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "6a587df0-eb7d-4acc-8eff-161e443a7470"],
 " by it gives a sum. The conjugation ",
 Cell[BoxData[
  RowBox[{
   StyleBox["T", "TI"], 
   StyleBox["X", "TI"], 
   SuperscriptBox[
    StyleBox["T", "TI"], "\[Dagger]"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "0ff37f99-e3a4-452b-bfd9-1d157dbd694d"],
 " is cleanest as the circuit ",
 Cell[BoxData[
  RowBox[{
   RowBox[{"{", 
    SuperscriptBox[
     StyleBox["T", "TI"], "\[Dagger]"]}], ",", 
   StyleBox["X", "TI"], ",", 
   RowBox[{
    StyleBox["T", "TI"], "}"}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "42541659-c097-4a5a-812e-cdb33e5bb12f"],
 " decomposed into Paulis:"
}], "Text",ExpressionUUID->"42c11ce3-8a42-4020-9363-797de15176ae"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"ExpToTrig", " ", "@", " ", 
  RowBox[{
   RowBox[{"QuantumCircuitOperator", "[", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"SuperDagger", "[", "\"\<T\>\"", "]"}], ",", " ", "\"\<X\>\"", ",",
       " ", "\"\<T\>\""}], "}"}], "]"}], "[", "\"\<PauliDecompose\>\"", 
   "]"}]}]], "Input",
 CellLabel->
  "In[39]:= ",ExpressionUUID->"b6a8738b-eeda-4748-aefd-c11b64a7a1db"],

Cell[BoxData[
 RowBox[{"\[LeftAssociation]", 
  RowBox[{
   RowBox[{"\<\"X\"\>", "\[Rule]", 
    FractionBox["1", 
     SqrtBox["2"]]}], ",", 
   RowBox[{"\<\"Y\"\>", "\[Rule]", 
    FractionBox["1", 
     SqrtBox["2"]]}]}], "\[RightAssociation]"}]], "Output",
 CellLabel->
  "Out[39]= ",ExpressionUUID->"78f8d936-03fb-4c32-9100-09aca32f0a7b"]
}, Open  ]],

Cell[TextData[{
 "Here ",
 Cell[BoxData[
  RowBox[{
   StyleBox["T", "TI"], 
   StyleBox["X", "TI"], 
   SuperscriptBox[
    StyleBox["T", "TI"], "\[Dagger]"], "=", 
   StyleBox["(",
    SpanMaxSize->1], 
   RowBox[{
    StyleBox["X", "TI"], "+", 
    StyleBox["Y", "TI"]}], 
   StyleBox[")",
    SpanMaxSize->1], "/", 
   SqrtBox["2"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "8cc46723-a48c-427c-87d5-5fb8c7898170"],
 " has two terms, not one. A single generator no longer maps to a single \
generator, the group stops being generated by ",
 Cell[BoxData[
  StyleBox["n", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "7b694ad1-073c-4f4d-aaeb-e0196605097c"],
 " Pauli strings, and the cheap representation fails. That failure is not an \
accident of implementation but the edge of the classically tractable world; \
stabilizer frames push a bounded distance past that edge, at a cost that \
grows with the number of non-Clifford gates."
}], "Text",ExpressionUUID->"fa116fd5-7b44-4422-b354-9a1920576f2f"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Entanglement for free: Bell and GHZ", "Section",ExpressionUUID->"2986b2a6-fee2-4fc6-8b99-d8f2674e56ad"],

Cell[TextData[{
 "Entangled states are not special in this language; they are simply \
stabilizer groups whose generators are not single-qubit operators. The Bell \
state ",
 Cell[BoxData[
  TemplateBox[{
    SuperscriptBox["\[CapitalPhi]", "+"]},
   "Ket"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "428f592a-6de5-4cf6-8aac-f4846057f24e"],
 " is prepared from ",
 Cell[BoxData[
  TemplateBox[{"00"},
   "Ket"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "81e3b27d-74c0-4e70-aded-95ebe7476d57"],
 " by a Hadamard and a CNOT, and its stabilizer group is generated by ",
 Cell[BoxData[
  StyleBox[
   RowBox[{"X", "X"}], "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "4fb9e8a5-9a75-426f-8ded-9910870a5a0b"],
 " and ",
 Cell[BoxData[
  StyleBox[
   RowBox[{"Z", "Z"}], "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "d63d97e6-1ed8-40e1-81c9-2157690d4199"],
 "."
}], "Text",ExpressionUUID->"a532898a-e53a-4270-b1a9-e92c8391d0d6"],

Cell["Build the Bell state:", "Text",ExpressionUUID->"3a30509c-84a6-409d-96c1-803739f77264"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"bell", " ", "=", " ", 
