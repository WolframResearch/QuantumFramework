 RowBox[{"{", 
  RowBox[{
   FractionBox["1", 
    SqrtBox["2"]], ",", "0", ",", "0", ",", 
   FractionBox["1", 
    SqrtBox["2"]]}], "}"}]], "Output",
 CellLabel->
  "Out[42]= ",ExpressionUUID->"e1d7ce0a-bd17-4dfb-9665-70d948150ee1"]
}, Open  ]],

Cell[TextData[{
 "Entanglement entropy, normally a Schmidt-decomposition computation that \
blows up with system size, has a closed form for stabilizer states. Fattal \
and collaborators showed that the entanglement entropy across a cut ",
 Cell[BoxData[
  StyleBox["A", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "a3fa05cb-8882-4432-808d-fc9be0c633a2"],
 " equals the ",
 Cell[BoxData[
  SubscriptBox["\|01d53d", "2"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "00004266-2131-420d-8315-c42356322d71"],
 "-rank of the generators restricted to ",
 Cell[BoxData[
  StyleBox["A", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "d2f8fa94-beb0-4ca1-a68a-70094cbbb7b1"],
 " (for each generator keep only the symplectic columns of the qubits in ",
 Cell[BoxData[
  StyleBox["A", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "293b455d-ac46-440c-aa6b-20c799dfdc9e"],
 "), minus ",
 Cell[BoxData[GridBox[{
    {
     StyleBox["A", "TI"]}
   },
   GridBoxDividers->{"Columns" -> {True, True}, "Rows" -> {}},
   GridBoxSpacings->{"Columns" -> {{0.15}}}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "abcb476e-cf80-4a5a-96ed-3f151d2447a2"],
 ". The framework computes this with ",
 Cell[BoxData["\"\<Entropy\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "c591d5b1-4304-475e-a057-ec0d4844922e"],
 ", in ",
 Cell[BoxData[
  RowBox[{
   StyleBox["O", "TI"], 
   StyleBox["(",
    SpanMaxSize->1], 
   SuperscriptBox[
    StyleBox["n", "TI"], "3"], 
   StyleBox[")",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "5bcdd70b-2894-47ed-b089-875bd8423b25"],
 " and with no dependence on ",
 Cell[BoxData[GridBox[{
    {
     StyleBox["A", "TI"]}
   },
   GridBoxDividers->{"Columns" -> {True, True}, "Rows" -> {}},
   GridBoxSpacings->{"Columns" -> {{0.15}}}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "e00ba725-90e9-4277-a4ae-968ad88315b2"],
 ". For the Bell state, tracing out one qubit gives one bit of entropy:"
}], "Text",ExpressionUUID->"e1f26980-6234-4846-a2b9-a1dc2ee7cc92"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"bell", "[", 
  RowBox[{"\"\<Entropy\>\"", ",", " ", 
   RowBox[{"{", "1", "}"}]}], "]"}]], "Input",
 CellLabel->
  "In[43]:= ",ExpressionUUID->"0ebe0ae1-7729-4cf8-be05-50053a9b2f9f"],

Cell[BoxData["1"], "Output",
 CellLabel->
  "Out[43]= ",ExpressionUUID->"7b4d5ff6-bdbb-43e7-9858-d9603527d902"]
}, Open  ]],

Cell[TextData[{
 "The payoff is scale. A GHZ state on a thousand qubits is built by one \
Hadamard and a ladder of CNOTs. Build it (the object prints as a compact \
summary, never forming a ",
 Cell[BoxData[
  SuperscriptBox["2", "1000"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "44be08fa-7f08-41bf-96b4-feafa9b9a16f"],
 " vector):"
}], "Text",ExpressionUUID->"9ddae386-5d36-4fcf-8694-b0a5a569a9cc"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"ghz", " ", "=", " ", 
  RowBox[{
   RowBox[{"PauliStabilizer", "[", "1000", "]"}], "[", 
   RowBox[{"Prepend", "[", 
    RowBox[{
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{"\"\<CNOT\>\"", " ", "->", " ", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"q", " ", "-", " ", "1"}], ",", " ", "q"}], "}"}]}], ",", 
       " ", 
       RowBox[{"{", 
        RowBox[{"q", ",", " ", "2", ",", " ", "1000"}], "}"}]}], "]"}], ",", 
     " ", "\"\<H\>\""}], "]"}], "]"}]}]], "Input",
 CellLabel->
  "In[44]:= ",ExpressionUUID->"9ef21c34-adc9-46c2-9c58-01423edbe7ed"],

