}, Open  ]],

Cell["\<\
For everything observable, probabilities, expectation values, entanglement, \
the global phase is irrelevant, so this costs us nothing in practice. We flag \
it now because it is the one place where the cheap representation is \
genuinely less informative than the dense one.\
\>", "Text",ExpressionUUID->"3ee5e69c-ae51-4687-87b3-1b83c1952fea"],

Cell["The essentials of the one-qubit picture:", "Text",ExpressionUUID->"4471f2ab-ec7b-4118-be34-ab2084caa248"],

Cell[TextData[{
 "A one-qubit stabilizer state is named by the single Pauli operator that \
fixes it: ",
 Cell[BoxData[
  StyleBox["Z", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "a27ec4c8-4468-43fb-9c63-cddb3a445994"],
 " for ",
 Cell[BoxData[
  TemplateBox[{"0"},
   "Ket"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "c1f308a9-ad14-48e1-b254-31129bdd6eec"],
 ", ",
 Cell[BoxData[
  StyleBox["X", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "fff9ab7b-3f57-474f-a402-53f72107149d"],
 " for ",
 Cell[BoxData[
  TemplateBox[{"+"},
   "Ket"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "02c1c12c-0eea-4969-a316-d089110af3ba"],
 ", ",
 Cell[BoxData[
  RowBox[{"-", 
   StyleBox["Z", "TI"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "7f885e87-b6cf-436a-813d-3427cb6c9d9c"],
 " for ",
 Cell[BoxData[
  TemplateBox[{"1"},
   "Ket"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "5766288c-a45d-4543-b73a-a5f90eaba667"],
 "."
}], "Item",ExpressionUUID->"67a29a93-1d50-42f5-b1fe-34be06236063"],

Cell[TextData[{
 Cell[BoxData["PauliStabilizer"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "e2a292a9-ded0-4eef-b879-f85777b76dee"],
 " carries that operator, not the amplitudes; the ",
 Cell[BoxData["\"\<State\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "c5f045f6-a34f-4a70-a1ba-f2524b943b15"],
 " property hands back a full ",
 Cell[BoxData["QuantumState"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "ae1487b7-6564-4e92-b405-c156132b0c43"],
 " on demand, and ",
 Cell[BoxData["\"\<StateVector\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "a59a40e0-e320-4636-a2ed-6af07557a387"],
 " on that object gives the raw ",
 Cell[BoxData[
  SuperscriptBox["2", 
   StyleBox["n", "TI"]]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "a939df6f-6c80-4c1b-beaa-5b14aa1f771e"],
 " amplitudes."
}], "Item",ExpressionUUID->"86790fbc-746a-4c7c-b4ca-7ac44effd6dc"],

Cell["\<\
The reconstructed vector is exact up to a global phase, which never affects \
an observable.\
\>", "Item",ExpressionUUID->"9eee6820-eae3-4544-87aa-f81dddf80a8c"],

Cell[TextData[{
 "The tableau: ",
 Cell[BoxData[
  StyleBox["n", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "aeb28d5e-75b6-483d-a31f-437305745cab"],
 " generators instead of ",
 Cell[BoxData[
  SuperscriptBox["2", 
   StyleBox["n", "TI"]]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "0f3d64a4-2f5c-4af5-80b6-1c2e6595d7d5"],
 " amplitudes"
}], "Section",ExpressionUUID->"2b6fbb77-e55f-4795-a161-4fe926162897"],

Cell[TextData[{
 "For ",
 Cell[BoxData[
  StyleBox["n", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "f2856181-2aca-4b86-95b3-ae73c6f2d782"],
 " qubits the idea scales because the stabilizer group is generated by just \
",
 Cell[BoxData[
  StyleBox["n", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "28ba71e3-b7dc-417c-b865-92776cf21ecc"],
 " commuting, independent Pauli strings, and each Pauli string of length ",
 Cell[BoxData[
  StyleBox["n", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "59084544-bd1c-48a4-993c-f5d745879c53"],
 " is two bits per qubit: an ",
 Cell[BoxData[
  StyleBox["X", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "905a6430-251c-48a2-a6aa-884f87f100e8"],
 "-exponent and a ",
 Cell[BoxData[
  StyleBox["Z", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "6c9e15bb-6890-4ea7-8210-ffc23bfffa70"],
 "-exponent, since ",
 Cell[BoxData[
  RowBox[{
   StyleBox["Y", "TI"], "=", 
   StyleBox["i", "TI"], 
   StyleBox["X", "TI"], 
   StyleBox["Z", "TI"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "6b214444-d39a-4627-97f2-3924510c35a2"],
 ". So a stabilizer state is a binary matrix of shape ",
 Cell[BoxData[
  RowBox[{
   StyleBox["n", "TI"], "\[Times]", "2", 
   StyleBox["n", "TI"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "ac02defd-f4e3-4348-9998-59720eecdf1e"],
 " together with ",
 Cell[BoxData[
  StyleBox["n", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "c4e7147c-816c-4131-899f-479a6121dd81"],
 " signs, which is ",
 Cell[BoxData[
  RowBox[{
   StyleBox["O", "TI"], 
   StyleBox["(",
    SpanMaxSize->1], 
   SuperscriptBox[
    StyleBox["n", "TI"], "2"], 
   StyleBox[")",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "182b3f38-d2b3-4795-9ccb-25f5cba16910"],
 " bits in place of ",
 Cell[BoxData[
  SuperscriptBox["2", 
   StyleBox["n", "TI"]]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "acb0f0ae-240c-40c8-8033-4578d28a970a"],
 " amplitudes. This binary ",
 Cell[BoxData[
  RowBox[{
   StyleBox["(",
    SpanMaxSize->1], 
   RowBox[{
    StyleBox["X", "TI"], "\[VerticalSeparator]", 
    StyleBox["Z", "TI"]}], 
   StyleBox[")",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "aedf7cb9-7fef-4e08-8c34-3fc17a87c29e"],
 " encoding is the ",
 StyleBox["symplectic representation", "TI"],
 " of the Pauli group."
}], "Text",ExpressionUUID->"32685769-f410-4a37-b641-d9e3e476f756"],

Cell[TextData[{
 "Look at the two-qubit register ",
 Cell[BoxData[
  TemplateBox[{"00"},
   "Ket"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "2f42b51d-cd2e-450d-bca4-2c3791e3f6a2"],
 ". The object itself previews the generators and a tableau grid:"
}], "Text",ExpressionUUID->"668a4b97-94a6-4c37-9afd-1e9329fe07d1"],

