   ",", "\<\"ZXIXZ\"\>", ",", "\<\"ZZZZZ\"\>"}], "}"}]], "Output",
 CellLabel->
  "Out[81]= ",ExpressionUUID->"0d0815d8-732a-43c5-bab1-c18ee549f5bb"]
}, Open  ]],

Cell[TextData[{
 "The four cyclic permutations ",
 Cell[BoxData[
  RowBox[{
   StyleBox[
    RowBox[{"X", "Z", "Z", "X", "I"}], "TI"], ",", 
   StyleBox[
    RowBox[{"I", "X", "Z", "Z", "X"}], "TI"], ",", 
   StyleBox[
    RowBox[{"X", "I", "X", "Z", "Z"}], "TI"], ",", 
   StyleBox[
    RowBox[{"Z", "X", "I", "X", "Z"}], "TI"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "9908bafe-a03d-4477-9ab8-5b2144033ddb"],
 " are the parity checks; the last generator ",
 Cell[BoxData[
  StyleBox[
   RowBox[{"Z", "Z", "Z", "Z", "Z"}], "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "71d5736f-410c-4fd5-9fcd-39bb08d5aa05"],
 " is the logical ",
 Cell[BoxData[
  OverscriptBox[
   StyleBox["Z", "TI"], "_"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "25914c86-da78-44c4-8312-71172969822e"],
 ", which fixes ",
 Cell[BoxData[
  TemplateBox[{
    SubscriptBox["0", 
     StyleBox["L", "TI"]]},
   "Ket"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "7ecbe833-b3fb-4e4d-901f-d0c9099a4047"],
 " inside the code space. Keep the checks alone:"
}], "Text",ExpressionUUID->"db544fdf-65b0-48c8-bf28-f9fc35bd8ca3"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"checks", " ", "=", " ", 
  RowBox[{"Most", "[", 
   RowBox[{"code", "[", "\"\<Stabilizers\>\"", "]"}], "]"}]}]], "Input",
 CellLabel->
  "In[82]:= ",ExpressionUUID->"1bfdfda0-c16b-4824-9a25-3427b347cdef"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"\<\"XZZXI\"\>", ",", "\<\"IXZZX\"\>", ",", "\<\"XIXZZ\"\>", 
   ",", "\<\"ZXIXZ\"\>"}], "}"}]], "Output",
 CellLabel->
  "Out[82]= ",ExpressionUUID->"9f1b9d21-de3a-4586-919d-d0397a574d93"]
}, Open  ]],

Cell[TextData[{
 "A list of four operators is worth only what it can diagnose, and this is \
where the formalism earns its keep. The clean codeword is a ",
 Cell[BoxData[
  RowBox[{"+", "1"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "1f355209-2c8a-4e69-98aa-ffd127e3b492"],
 " eigenstate of every check, so the four checks all read ",
 Cell[BoxData[
  RowBox[{"+", "1"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "a845a454-addb-41fa-adf2-c24ac94a36b3"],
 ". A single-qubit error ",
 Cell[BoxData[
  StyleBox["E", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "8110d6e8-b85d-4972-b36d-0c6e3f607295"],
 " commutes or anticommutes with each check, and wherever it anticommutes it \
flips that reading to ",
 Cell[BoxData[
  RowBox[{"-", "1"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "ab668b9d-9bd6-4307-8aa9-5f3f1cbcfb19"],
 ". The pattern of flips is the ",
 StyleBox["syndrome", "TI"],
 ": a four-bit string, ",
 Cell[BoxData["0"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "e622c73c-8a8f-43a5-a81b-27a9ae7b23c1"],
 " for an undisturbed check and ",
 Cell[BoxData["1"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "cd5c9574-df1e-4e29-b206-284d43aab8fe"],
 " for a flipped one."
}], "Text",ExpressionUUID->"07efce5b-e802-43e5-bc7a-4bf77e321dfb"],

Cell[BoxData[
 RowBox[{
  RowBox[{"syndrome", "[", "err_", "]"}], " ", ":=", " ", 
  RowBox[{
   RowBox[{"(", 
    RowBox[{"1", " ", "-", " ", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{"code", "[", "err", "]"}], "[", 
         RowBox[{"\"\<Expectation\>\"", ",", " ", "#"}], "]"}], " ", "&"}], 
       " ", "/@", " ", "checks"}], ")"}]}], ")"}], " ", "/", " ", 
   "2"}]}]], "Input",
 CellLabel->
  "In[83]:= ",ExpressionUUID->"6e9b2d53-db67-456d-88b6-6d7edff8f8d2"],

Cell["\<\
A bit-flip on qubit 2 anticommutes with the first check alone:\
\>", "Text",ExpressionUUID->"310af133-aa48-4425-ac4c-c33ffd0e5e64"],

