Cell[TextData[{
 "The answer is the single Pauli string ",
 Cell[BoxData["\"\<Z\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "a487488e-0842-4bf2-b99c-70599903f1b1"],
 ", exactly as the chalkboard argument predicted. The ",
 Cell[BoxData["\"\<State\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "a27771a0-bfe6-4066-9b03-de45c373b7d0"],
 " property is the bridge back to the rest of the framework: it materializes \
the stabilizer object into a full ",
 Cell[BoxData["QuantumState"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "3f62cc0b-60ff-49f0-b266-d8b2a0991190"],
 ", at the cost of the ",
 Cell[BoxData[
  SuperscriptBox["2", 
   StyleBox["n", "TI"]]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "0216445c-de2e-42f6-bbf3-79558ab8eeab"],
 " blow-up the formalism exists to avoid."
}], "Text",ExpressionUUID->"87b7e8d6-7e27-4052-9e7f-c7fb0b86b041"],

