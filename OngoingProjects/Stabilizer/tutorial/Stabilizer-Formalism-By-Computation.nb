 CellLabel->
  "In[46]:= ",ExpressionUUID->"b58bbfda-2771-4c79-a8f8-3d154160bfe9"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"0.48405`", ",", "1"}], "}"}]], "Output",
 CellLabel->
  "Out[46]= ",ExpressionUUID->"9263d9f6-d32f-4bc3-aa22-4a62f0719127"]
}, Open  ]],

Cell["What we have established:", "Text",ExpressionUUID->"b7e80f53-238e-4f05-b7c0-51acd2248d31"],

Cell[TextData[{
 "An entangled stabilizer state is one whose generators are multi-qubit Pauli \
strings; Bell is ",
 Cell[BoxData[
  RowBox[{
   StyleBox["\[LeftAngleBracket]",
    SpanMaxSize->1], 
   RowBox[{
    StyleBox[
     RowBox[{"X", "X"}], "TI"], ",", 
    StyleBox[
     RowBox[{"Z", "Z"}], "TI"]}], "\[VeryThinSpace]", 
   StyleBox["\[RightAngleBracket]",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "4765be08-b8b5-4a6d-bedd-cd2847d8982e"],
 "."
}], "Item",ExpressionUUID->"3e52b856-18c8-4b65-a749-64cb514c9ec7"],

Cell[TextData[{
 "Entanglement entropy is an ",
 Cell[BoxData[
  SubscriptBox["\|01d53d", "2"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "8fd2e594-b4c7-4b9d-a254-469dbc334965"],
 " rank, computable at ",
 Cell[BoxData[
  RowBox[{
   StyleBox["n", "TI"], "=", "1000"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "9705d7da-c7aa-406f-9bf8-83793907968c"],
 " in milliseconds."
}], "Item",ExpressionUUID->"d1f1bd69-d45a-490d-bd55-85bd14e1ed78"],

Cell[TextData[{
 "The cost of all this is ",
 Cell[BoxData[
  RowBox[{
   StyleBox["O", "TI"], 
   StyleBox["(",
    SpanMaxSize->1], 
   SuperscriptBox[
    StyleBox["n", "TI"], "2"], 
   StyleBox[")",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "8b33eeda-d736-4882-b708-529a2dabc74c"],
 " storage and ",
 Cell[BoxData[
  RowBox[{
   StyleBox["O", "TI"], 
   StyleBox["(",
    SpanMaxSize->1], 
   SuperscriptBox[
    StyleBox["n", "TI"], "3"], 
   StyleBox[")",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "729e9b79-0300-46c9-8e95-028ce3edb1b0"],
 " for the rank, never ",
 Cell[BoxData[
  RowBox[{
   StyleBox["O", "TI"], 
   StyleBox["(",
    SpanMaxSize->1], 
   SuperscriptBox["2", 
    StyleBox["n", "TI"]], 
   StyleBox[")",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "3d96a269-253c-4ab4-9501-540de4420f13"],
 "."
}], "Item",ExpressionUUID->"0a973c80-9f1d-47c8-b526-f735bd9c1901"],

Cell["Measurement: randomness, back-action, and correlation", "Section",ExpressionUUID->"e5185fd9-5425-43ba-9eee-58a31d35abea"],

Cell[TextData[{
 "Measurement is where the destabilizers earn their keep. Measuring ",
 Cell[BoxData[
  StyleBox["Z", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "31189635-1b38-411f-9b0a-a1f4b5bb8109"],
 " on qubit ",
 Cell[BoxData[
  StyleBox["a", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "0221505a-34aa-4bff-b830-24e4957cc8a1"],
 " splits into two cases. If ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["Z", "TI"], 
   StyleBox["a", "TI"]]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "691522bf-73ac-44aa-b464-112ecaca5c47"],
 " commutes with every stabilizer, then ",
 Cell[BoxData[
  RowBox[{"\[PlusMinus]", 
   SubscriptBox[
    StyleBox["Z", "TI"], 
    StyleBox["a", "TI"]]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "5f631a4a-a5ef-40ff-9dc9-2ce2282336ab"],
 " already lies in the stabilizer group: the outcome is ",
 StyleBox["deterministic", "TI"],
 ", the state is unchanged, and the bit is the sign of the generator product \
that equals ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["Z", "TI"], 
   StyleBox["a", "TI"]]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "09ee2d74-72b8-46d7-994e-87eba5b2f750"],
 ", which the destabilizers locate in ",
 Cell[BoxData[
  RowBox[{
   StyleBox["O", "TI"], 
   StyleBox["(",
    SpanMaxSize->1], 
   SuperscriptBox[
    StyleBox["n", "TI"], "2"], 
   StyleBox[")",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "98cbd24a-e339-40f6-be1a-033d5dcc9901"],
 ". If instead some stabilizer anticommutes with ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["Z", "TI"], 
   StyleBox["a", "TI"]]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "1eed4b0a-6def-41ad-98e6-8d13ecc19486"],
 ", the outcome is a fair coin, and the post-measurement state follows from a \
sequence of Aaronson-Gottesman row sums into one anticommuting generator, \
with a destabilizer as scratch. Either way the work is ",
 Cell[BoxData[
  RowBox[{
   StyleBox["O", "TI"], 
   StyleBox["(",
    SpanMaxSize->1], 
   SuperscriptBox[
    StyleBox["n", "TI"], "2"], 
   StyleBox[")",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "ecd1966e-818a-428c-8f91-e145a3294c10"],
 ", never ",
 Cell[BoxData[
  RowBox[{
   StyleBox["O", "TI"], 
   StyleBox["(",
    SpanMaxSize->1], 
   SuperscriptBox["2", 
    StyleBox["n", "TI"]], 
   StyleBox[")",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "65f991ff-e637-4c6b-a5d4-d47c7f4b7791"],
 "."
}], "Text",ExpressionUUID->"172dddc9-3b91-4dd2-bf5e-7ae278892477"],

Cell["\<\
A measurement on a stabilizer state returns an association from outcome to \
post-state. For the Bell state, measuring qubit 1 is random, so both branches \
appear:\
\>", "Text",ExpressionUUID->"ca7a160b-99ac-463a-a311-78a4a8ad0e97"],

