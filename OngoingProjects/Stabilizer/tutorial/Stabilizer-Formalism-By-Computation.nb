Cell[TextData[{
 "The sign of the first generator is now ",
 Cell[BoxData[
  RowBox[{"1", "-", "2", 
   SubscriptBox[
    StyleBox["s", "TI"], "1"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "36d0b1c7-ddf0-44e1-863d-c9eb9d36f048"],
 ", which is ",
 Cell[BoxData[
  RowBox[{"+", "1"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "78924995-1a91-4720-947a-422f44800269"],
 " at ",
 Cell[BoxData[
  RowBox[{
   SubscriptBox[
    StyleBox["s", "TI"], "1"], "=", "0"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "66a9683c-b5db-4c0f-9fd2-7a418ae77b7b"],
 " and ",
 Cell[BoxData[
  RowBox[{"-", "1"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "dbdb9d19-aae6-459a-aa87-b84d5c13e4e2"],
 " at ",
 Cell[BoxData[
  RowBox[{
   SubscriptBox[
    StyleBox["s", "TI"], "1"], "=", "1"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "50536d44-6f37-494a-9db5-88006adb9ae6"],
 ": the formal bit ",
 StyleBox["is", "TI"],
 " the unmade measurement. (The subscript on ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["s", "TI"], 
   StyleBox["k", "TI"]]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "902bc8a8-5960-458a-a3a2-57ae1ea89441"],
 " is a running session counter, so measuring again or re-running these cells \
allocates ",
 Cell[BoxData[
  RowBox[{
   SubscriptBox[
    StyleBox["s", "TI"], "2"], ",", 
   SubscriptBox[
    StyleBox["s", "TI"], "3"], ",", "\[Ellipsis]"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "4e513919-db6c-4820-8871-3875381d42de"],
 ".) Substituting a concrete value resolves it, and the two substitutions \
reproduce the two post-measurement branches exactly:"
}], "Text",ExpressionUUID->"5682b63a-5438-42d7-b154-9dde66fb3916"],

