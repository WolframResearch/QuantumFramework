Cell["\<\
Its amplitudes are the answer the formalism has to reproduce:\
\>", "Text",ExpressionUUID->"0a776536-4a33-45c5-967a-d6770ad9bbb1"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"psiSchrodinger", "[", "\"\<StateVector\>\"", "]"}], " ", "//", " ",
   "Normal"}]], "Input",
 CellLabel->
  "In[33]:= ",ExpressionUUID->"ace5284b-8da3-4a8d-9777-e918166a121c"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   FractionBox["1", 
    SqrtBox["2"]], ",", "0", ",", "0", ",", "0", ",", "0", ",", "0", ",", "0",
    ",", 
   FractionBox["\[ImaginaryI]", 
    SqrtBox["2"]]}], "}"}]], "Output",
 CellLabel->
  "Out[33]= ",ExpressionUUID->"e5e75c79-7906-41ad-9032-9f45372ebf36"]
}, Open  ]],

Cell[TextData[{
 "The state is ",
 Cell[BoxData[
  RowBox[{
   RowBox[{"(", 
    RowBox[{
     TemplateBox[{"000"},
      "Ket"], "+", 
     RowBox[{
      StyleBox["i", "TI"], 
      TemplateBox[{"111"},
       "Ket"]}]}], ")"}], "/", 
   SqrtBox["2"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "5d08f4fb-9274-43ef-8829-844b37d03abc"],
 ", a GHZ-type state carrying the relative phase the ",
 Cell[BoxData[
  StyleBox["S", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "b930c971-0097-49cc-ada4-b7a2f061548c"],
 " gate inserted."
}], "Text",ExpressionUUID->"14f5bf28-2884-44a9-b681-e39d7ed0e15d"],

Cell[TextData[{
 "Now the Heisenberg picture. Instead of asking where the state goes, ask \
what fixes it. If ",
 Cell[BoxData[
  StyleBox["g", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "f337ae8c-fbd1-4912-8717-b7625fe86a98"],
 " stabilizes ",
 Cell[BoxData[
  TemplateBox[{
    StyleBox["\[Psi]", "TI"]},
   "Ket"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "604dbf7c-b281-4215-9c38-9db7637f2e4c"],
 ", then after a gate ",
 Cell[BoxData[
  StyleBox["U", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "28abdda1-78d7-4f38-8c41-a39c3844d1a3"],
 " the conjugated operator ",
 Cell[BoxData[
  RowBox[{
   StyleBox["U", "TI"], 
   StyleBox["g", "TI"], 
   SuperscriptBox[
    StyleBox["U", "TI"], "\[Dagger]"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "da6c6611-e14f-414e-89e3-d6ce3f328436"],
 " stabilizes ",
 Cell[BoxData[
  RowBox[{
   StyleBox["U", "TI"], 
   TemplateBox[{
     StyleBox["\[Psi]", "TI"]},
    "Ket"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "e4a02444-c3a3-4e71-8d69-60e46e7e994f"],
 ", because ",
 Cell[BoxData[
  RowBox[{
   RowBox[{
    StyleBox["g", "TI"], 
    TemplateBox[{
      StyleBox["\[Psi]", "TI"]},
     "Ket"]}], "=", 
   TemplateBox[{
     StyleBox["\[Psi]", "TI"]},
    "Ket"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "ea25a41f-b857-4b45-a545-09432c0f9958"],
 " gives ",
 Cell[BoxData[
  RowBox[{
   RowBox[{
    RowBox[{
     StyleBox["(",
      SpanMaxSize->1], 
     RowBox[{
      StyleBox["U", "TI"], 
      StyleBox["g", "TI"], 
      SuperscriptBox[
       StyleBox["U", "TI"], "\[Dagger]"]}], 
     StyleBox[")",
      SpanMaxSize->1]}], 
    StyleBox["U", "TI"], 
    TemplateBox[{
      StyleBox["\[Psi]", "TI"]},
     "Ket"]}], "=", 
   RowBox[{
    RowBox[{
     StyleBox["U", "TI"], 
     StyleBox["g", "TI"], 
     TemplateBox[{
       StyleBox["\[Psi]", "TI"]},
      "Ket"]}], "=", 
    RowBox[{
     StyleBox["U", "TI"], 
     TemplateBox[{
       StyleBox["\[Psi]", "TI"]},
      "Ket"]}]}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "4e16dfc2-dcc5-41b4-90db-37f440ba60bf"],
 ". The whole evolution of the state is therefore carried by the conjugation ",
 Cell[BoxData[
  RowBox[{
   StyleBox["g", "TI"], "\[Function]", 
   StyleBox["U", "TI"], 
   StyleBox["g", "TI"], 
   SuperscriptBox[
    StyleBox["U", "TI"], "\[Dagger]"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "22934006-25a6-4251-a1bd-60531835be91"],
 " of its generators, and the one fact that makes this cheap is that a \
Clifford sends a Pauli to a Pauli. Take the input generator ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["Z", "TI"], "1"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "7b8d047c-4224-4e1a-862e-831bbcf55d75"],
 " and conjugate it by the circuit, ",
 Cell[BoxData[
  RowBox[{
   StyleBox["U", "TI"], " ", 
   SubscriptBox[
    StyleBox["Z", "TI"], "1"], " ", 
   SuperscriptBox[
    StyleBox["U", "TI"], "\[Dagger]"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "5263292a-c991-4493-83a9-f8a0c370d526"],
 ". Writing that conjugation as a circuit that applies ",
 Cell[BoxData[
  SuperscriptBox[
   StyleBox["U", "TI"], "\[Dagger]"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "08282da0-fb92-4e79-afc1-d9988ce82b66"],
 ", then ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["Z", "TI"], "1"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "4276b5f2-7285-406a-a967-83a818f54569"],
 ", then ",
 Cell[BoxData[
  StyleBox["U", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "3fbe61d0-3c7e-4c6f-ba9b-0dbb66cabaea"],
 ", ",
 Cell[BoxData["\"\<PauliDecompose\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "4c82283e-9d2f-420f-a2d8-6549d3d341cf"],
 " reads off the result:"
}], "Text",ExpressionUUID->"8bababb8-6e92-41a9-b6c2-c4b88f326550"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"QuantumCircuitOperator", "[", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"cliffordCircuit", "[", "\"\<Dagger\>\"", "]"}], ",", " ", 
     RowBox[{"\"\<Z\>\"", " ", "->", " ", "1"}], ",", " ", 
     "cliffordCircuit"}], "}"}], "]"}], "[", "\"\<PauliDecompose\>\"", 
  "]"}]], "Input",
 CellLabel->
  "In[34]:= ",ExpressionUUID->"7972d1f9-2c61-44f2-8768-6fe183627285"],

Cell[BoxData[
 RowBox[{"\[LeftAssociation]", 
  RowBox[{"\<\"XYX\"\>", "\[Rule]", "1"}], "\[RightAssociation]"}]], "Output",\

 CellLabel->
  "Out[34]= ",ExpressionUUID->"7d190647-8439-4e6a-a346-73ac292e1344"]
}, Open  ]],

Cell[TextData[{
 "The decomposition has a single term, ",
 Cell[BoxData[
  RowBox[{
   SubscriptBox[
    StyleBox["X", "TI"], "1"], 
   SubscriptBox[
    StyleBox["Y", "TI"], "2"], 
   SubscriptBox[
    StyleBox["X", "TI"], "3"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "5a30b281-f050-4a26-9205-563c119c377a"],
 ": the operator never left the Pauli group. One generator went in, one came \
out. That closure is why each tableau update is a fixed local rewrite of a \
few bits rather than a dense matrix multiply."
}], "Text",ExpressionUUID->"e13842ad-a3a7-43b9-ac22-dd8472505e11"],

Cell[TextData[{
 "Propagating all three input generators ",
 Cell[BoxData[
  RowBox[{
   SubscriptBox[
    StyleBox["Z", "TI"], "1"], ",", 
   SubscriptBox[
    StyleBox["Z", "TI"], "2"], ",", 
   SubscriptBox[
    StyleBox["Z", "TI"], "3"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "76479a70-6aaa-47ed-9f43-e74d783bd457"],
 " this way is exactly what the stabilizer backend does. Running the ",
 StyleBox["same circuit object", "TI"],
 " with ",
 Cell[BoxData[
  RowBox[{"Method", " ", "->", " ", "\"\<Stabilizer\>\""}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "3af68c88-b3ab-442b-a8b2-dc2041d7ee46"],
 " in place of ",
 Cell[BoxData["\"\<Schrodinger\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "74694baf-be3c-458d-9759-fb60eabe6862"],
 " returns the stabilizer group of the final state, whose first generator is \
the ",
 Cell[BoxData[
  RowBox[{
   SubscriptBox[
    StyleBox["X", "TI"], "1"], 
   SubscriptBox[
    StyleBox["Y", "TI"], "2"], 
   SubscriptBox[
    StyleBox["X", "TI"], "3"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "bb5dfc68-c83f-4317-bdf6-077e5cbfbd19"],
 " we just conjugated by hand:"
}], "Text",ExpressionUUID->"b4a50d93-5e7c-4ba3-bd6f-c5b67ddc070e"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"cliffordCircuit", "[", 
   RowBox[{
    RowBox[{"QuantumState", "[", "\"\<000\>\"", "]"}], ",", " ", 
    RowBox[{"Method", " ", "->", " ", "\"\<Stabilizer\>\""}]}], "]"}], 
  "[", "\"\<Stabilizers\>\"", "]"}]], "Input",
