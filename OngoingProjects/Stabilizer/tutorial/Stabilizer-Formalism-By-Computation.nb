Cell[TextData[{
 "Read off its preparation circuit with the ",
 Cell[BoxData["\"\<Circuit\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "8a100c70-582b-4b39-9269-ce608f5fbaf5"],
 " property (a hundred-plus-gate object, so we hold it in ",
 Cell[BoxData["prep"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "f04f8842-6ed5-439c-8acb-7ff68611b752"],
 " rather than print it):"
}], "Text",ExpressionUUID->"1b516204-fb27-407e-be59-aa166e7f8152"],

Cell[BoxData[
 RowBox[{
  RowBox[{"prep", " ", "=", " ", 
   RowBox[{"ps10", "[", "\"\<Circuit\>\"", "]"}]}], ";"}]], "Input",
 CellLabel->
  "In[68]:= ",ExpressionUUID->"3b9b27c6-8a31-4760-965b-38908a5fc0ab"],

Cell["\<\
then count its gates, which stay polynomial in the number of qubits:\
\>", "Text",ExpressionUUID->"ba236347-9b85-49a0-ad97-101d40cc2302"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Length", " ", "@", " ", 
  RowBox[{"QuantumShortcut", "[", "prep", "]"}]}]], "Input",
 CellLabel->
  "In[69]:= ",ExpressionUUID->"b8d81122-750e-486e-bd57-763fe2c45d60"],

Cell[BoxData["136"], "Output",
 CellLabel->
  "Out[69]= ",ExpressionUUID->"d533360d-e52f-4bc7-b406-82e7a57a6fae"]
}, Open  ]],

Cell[TextData[{
 "The result is an ordinary ",
 Cell[BoxData["QuantumCircuitOperator"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "27fe33d1-9b82-44d7-a1cf-b559e003e74b"],
 ". It genuinely builds the state: applied to the all-zeros register it \
reproduces ",
 Cell[BoxData[
  TemplateBox[{
    StyleBox["\[Psi]", "TI"]},
   "Ket"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "0ef73df7-315c-49ce-b296-22f62360f735"],
 " exactly. At ten qubits a full ",
 Cell[BoxData["QuantumSimilarity"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "c9ff140f-cbb0-4ed2-84d2-e38812bc8fc8"],
 " would form a ",
 Cell[BoxData[
  RowBox[{
   SuperscriptBox["2", "10"], "\[Times]", 
   SuperscriptBox["2", "10"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "ce166ec4-7f32-487c-9ef6-c25a6f462a7c"],
 " density matrix, so here we take the cheaper direct state-vector overlap, \
whose magnitude is one:"
}], "Text",ExpressionUUID->"6aca8611-319b-4716-a205-06192a7cd338"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Chop", "[", 
  RowBox[{
   RowBox[{"Abs", "[", 
    RowBox[{
     RowBox[{"Conjugate", "[", 
      RowBox[{"Normal", " ", "@", " ", 
       RowBox[{
        RowBox[{"prep", "[", "]"}], "[", "\"\<StateVector\>\"", "]"}]}], 
      "]"}], " ", ".", " ", 
     RowBox[{"Normal", " ", "@", " ", 
      RowBox[{
       RowBox[{"ps10", "[", "\"\<State\>\"", "]"}], "[", "\"\<StateVector\>\"",
        "]"}]}]}], "]"}], " ", "-", " ", "1"}], "]"}]], "Input",
 CellLabel->
  "In[70]:= ",ExpressionUUID->"d49aa38c-cd5e-4fb0-b10f-08c6b327de02"],

Cell[BoxData["0"], "Output",
 CellLabel->
  "Out[70]= ",ExpressionUUID->"a3809792-5ebe-44ca-ba5c-b3ec8a92e79d"]
}, Open  ]],

Cell["\<\
This inverts gate-folding, which goes from circuit to tableau, and it is the \
workhorse behind code encoders: a code state's preparation circuit is exactly \
its encoding circuit.\
\>", "Text",ExpressionUUID->"56e7c832-f2a2-4352-9474-1b3be1c05d9c"],

Cell[TextData[{
 "For long Clifford circuits the framework folds the entire gate list through \
a single compiled (C) kernel that operates on a bit-packed, generator-major \
tableau, the same data layout the specialized simulators use. Handing the \
whole gate list to ",
 Cell[BoxData[
  RowBox[{"ps", "[", "gates", "]"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "4a4ff9b2-2936-4e50-a51b-8de11fc35c0c"],
 " folds it in one such pass. First build a four-thousand-gate random \
Clifford stream on two hundred qubits (kept suppressed, since it is four \
thousand gate specs):"
}], "Text",ExpressionUUID->"be9812a6-7a44-4797-970e-ce3664976844"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"SeedRandom", "[", "1", "]"}], ";"}], "\n", 
 RowBox[{
  RowBox[{"specs", " ", "=", " ", 
   RowBox[{"Table", "[", "\n", "   ", 
    RowBox[{
     RowBox[{"RandomChoice", "[", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"\"\<H\>\"", " ", "->", " ", 
         RowBox[{"RandomInteger", "[", 
          RowBox[{"{", 
           RowBox[{"1", ",", " ", "200"}], "}"}], "]"}]}], ",", " ", 
        RowBox[{"\"\<S\>\"", " ", "->", " ", 
         RowBox[{"RandomInteger", "[", 
          RowBox[{"{", 
           RowBox[{"1", ",", " ", "200"}], "}"}], "]"}]}], ",", "\n", "     ", 
        RowBox[{"\"\<CNOT\>\"", " ", "->", " ", 
         RowBox[{"RandomSample", "[", 
          RowBox[{
           RowBox[{"Range", "[", "200", "]"}], ",", " ", "2"}], "]"}]}]}], 
       "}"}], "]"}], ",", "\n", "   ", 
     RowBox[{"{", "4000", "}"}]}], "]"}]}], ";"}]}], "Input",
 CellLabel->
  "In[71]:= ",ExpressionUUID->"a6aae06d-061a-4189-96f2-84c8f70ce8ff"],

Cell["then fold it and watch the wall-clock:", "Text",ExpressionUUID->"59efd3e5-8a7b-40ac-85be-9e6190935e81"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"AbsoluteTiming", "[", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"PauliStabilizer", "[", "200", "]"}], "[", "specs", "]"}], 
    "[", "\"\<Stabilizers\>\"", "]"}], "[", 
   RowBox[{"[", "1", "]"}], "]"}], "]"}]], "Input",
 CellLabel->
  "In[72]:= ",ExpressionUUID->"e265f5c3-23e0-4777-8c7c-0810f5c954bf"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
  "0.035128`", 
   ",", "\<\"-\
XYIYZIIZZIXIIZZIYZIZIXYXIXYIXYZZXYXXYIIZZXIXXYIZXYIZYIXIYZZYIIXXZIIXXZYYYZZIXY\
ZIYZIXIYYYYZIXXXYXZZXXXZIIXZIIIIZXYYYXXYXXYXIXXZIZYIXZZXYZZIYIXZXXXIIXZXIYZZYI\
XIXZXXIIZIYIYXIIXIYXYZYZYIXZYIIZXIYIIZIZXZIZ\"\>"}], "}"}]], "Output",
 CellLabel->
  "Out[72]= ",ExpressionUUID->"cad605b2-6af0-40f8-8dd4-6f2719932441"]
}, Open  ]],

Cell[TextData[{
 "That is roughly a quarter of a microsecond per gate, flat in the number of \
qubits, because each gate touches only the machine words of its own column. \
The same engine backs the circuit object: a ",
 Cell[BoxData["QuantumCircuitOperator"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "b6cc2b32-97b2-41f3-b52b-1cc3e7662856"],
 " applied with ",
 Cell[BoxData[
  RowBox[{"Method", " ", "->", " ", "\"\<Stabilizer\>\""}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "f0439f59-69c4-498f-9aec-7dff0f585ed7"],
 " evolves a stabilizer state directly. Build a Bell circuit:"
}], "Text",ExpressionUUID->"8542d643-fed4-4fb9-ab33-439802c12843"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"qc", " ", "=", " ", 
  RowBox[{"QuantumCircuitOperator", "[", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"\"\<H\>\"", " ", "->", " ", "1"}], ",", " ", 
     RowBox[{"\"\<CNOT\>\"", " ", "->", " ", 
      RowBox[{"{", 
       RowBox[{"1", ",", " ", "2"}], "}"}]}]}], "}"}], "]"}]}]], "Input",
 CellLabel->
  "In[73]:= ",ExpressionUUID->"db064d39-71ba-47b4-aef8-c4bbe4166965"],

