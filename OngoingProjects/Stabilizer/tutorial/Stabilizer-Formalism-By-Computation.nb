}, Open  ]],

Cell[TextData[{
 "Different states are fixed by different operators. The state ",
 Cell[BoxData[
  RowBox[{
   TemplateBox[{"+"},
    "Ket"], "=", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{
      TemplateBox[{"0"},
       "Ket"], "+", 
      TemplateBox[{"1"},
       "Ket"]}], ")"}], "/", 
    SqrtBox["2"]}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "7168f1b6-735f-4b99-9ba0-acacf8e9932c"],
 " is the ",
 Cell[BoxData[
  RowBox[{"+", "1"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "3cd5677a-7916-4f6f-9dc6-2952497ee292"],
 " eigenstate of ",
 Cell[BoxData[
  StyleBox["X", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "52da0045-6cbf-4927-b351-ee3029485e0f"],
 ", and a Hadamard turns one into the other. Apply ",
 Cell[BoxData[
  StyleBox["H", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "f7cc75bc-c861-4ecc-be0b-eba81ad14f3e"],
 " to ",
 Cell[BoxData[
  TemplateBox[{"0"},
   "Ket"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "128c1c89-78b6-40fd-b5fa-7340ceb31427"],
 " and read the new stabilizer:"
}], "Text",ExpressionUUID->"016b0a41-6276-47bd-951e-85c96a15d754"],

