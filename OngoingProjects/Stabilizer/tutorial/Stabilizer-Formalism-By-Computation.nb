  TemplateBox[{"+"},
   "Ket"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "75594294-fe11-4514-a34e-c2a2a61673aa"],
 ". The state vector confirms it:"
}], "Text",ExpressionUUID->"23d81e52-63f7-46c3-be5e-f078c5e5be43"],

