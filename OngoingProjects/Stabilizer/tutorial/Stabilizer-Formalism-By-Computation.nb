Cell[TextData[{
 "The raw symplectic data is ",
 Cell[BoxData["\"\<Tableau\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "30d1d36b-b53e-4f6b-b6e9-8ffbe7b4ea7a"],
 ", a rank-3 array stacking the ",
 Cell[BoxData[
  StyleBox["X", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "6d765f58-f721-4520-b1cb-e2d43f91e77c"],
 " block above the ",
 Cell[BoxData[
  StyleBox["Z", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "b6736913-7bbb-4bdd-aebf-51c5a38f4831"],
 " block (shape ",
 Cell[BoxData[
  RowBox[{"2", "\[Times]", 
   StyleBox["n", "TI"], "\[Times]", "2", 
   StyleBox["n", "TI"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "e6611fb6-f4b5-4201-ad95-42ccc1977da9"],
 ", here ",
 Cell[BoxData[
  RowBox[{"2", "\[Times]", "2", "\[Times]", "4"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "ac001508-6b34-4635-8431-be87a0542ab0"],
 ": two blocks, ",
 Cell[BoxData[
  RowBox[{
   StyleBox["n", "TI"], "=", "2"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "6e60a276-b91b-441b-bb0e-2eefce177a44"],
 " qubits, ",
 Cell[BoxData[
  RowBox[{"2", 
   StyleBox["n", "TI"], "=", "4"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "f4b365a2-3996-4f8c-9a4a-58404f1bbfbe"],
 " rows):"
}], "Text",ExpressionUUID->"da7e134c-26d8-415d-a724-d890e1965d6b"],

