}, Open  ]],

Cell[TextData[{
 "Four of the eight amplitudes are ",
 Cell[BoxData[
  RowBox[{"1", "/", "2"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "0a70324d-1654-4dbb-a82c-26747ff65a4a"],
 " and the rest vanish. Read the support directly off the state vector, the \
bit-strings whose amplitude is nonzero:"
}], "Text",ExpressionUUID->"fc0bb7dd-5f00-4924-9c3d-77382190f4ff"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"support", " ", "=", " ", 
  RowBox[{
   RowBox[{"Select", "[", 
    RowBox[{
     RowBox[{"AssociationThread", "[", 
      RowBox[{
       RowBox[{"Tuples", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"0", ",", " ", "1"}], "}"}], ",", " ", "3"}], "]"}], ",", 
       " ", 
       RowBox[{"Normal", "[", 
        RowBox[{
         RowBox[{"psAffineDemo", "[", "\"\<State\>\"", "]"}], 
         "[", "\"\<StateVector\>\"", "]"}], "]"}]}], "]"}], ",", " ", 
     RowBox[{
      RowBox[{"#", " ", "!=", " ", "0"}], " ", "&"}]}], "]"}], " ", "//", " ",
    "Keys"}]}]], "Input",
 CellLabel->
  "In[27]:= ",ExpressionUUID->"53dcdde7-eb60-4933-952b-37ac146b8dab"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"0", ",", "0", ",", "0"}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{"0", ",", "1", ",", "1"}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{"1", ",", "0", ",", "1"}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{"1", ",", "1", ",", "0"}], "}"}]}], "}"}]], "Output",
 CellLabel->
  "Out[27]= ",ExpressionUUID->"a762dfd5-3308-44c9-84a0-c96a0ea7b9cd"]
}, Open  ]],

Cell[TextData[{
 "These four strings are exactly the even-parity ones. Taking the parity ",
 Cell[BoxData[
  RowBox[{
   SubscriptBox[
    StyleBox["x", "TI"], "1"], "\[CirclePlus]", 
   SubscriptBox[
    StyleBox["x", "TI"], "2"], "\[CirclePlus]", 
   SubscriptBox[
    StyleBox["x", "TI"], "3"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "b33f8974-3237-4dae-8f93-13a11249905b"],
 " of each, as a sum mod 2, confirms it:"
}], "Text",ExpressionUUID->"ecbbd7d8-4213-4e62-9d34-ed582a6ee822"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"Mod", "[", 
    RowBox[{
     RowBox[{"Total", "[", "#", "]"}], ",", " ", "2"}], "]"}], " ", "&"}], 
  " ", "/@", " ", "support"}]], "Input",
 CellLabel->
  "In[28]:= ",ExpressionUUID->"3a71a442-633c-41e0-91f7-cb8a368ad7d4"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"0", ",", "0", ",", "0", ",", "0"}], "}"}]], "Output",
 CellLabel->
  "Out[28]= ",ExpressionUUID->"5f2b2db8-7834-466f-a518-942f28cd3bbd"]
}, Open  ]],

Cell[TextData[{
 "Every parity vanishes, so the support is the two-dimensional subspace of ",
 Cell[BoxData[
  SubsuperscriptBox["\|01d53d", "2", "3"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "b96b61b5-50a5-420c-92be-bc1a2500b99e"],
 " cut out by the generator ",
 Cell[BoxData[
  StyleBox[
   RowBox[{"Z", "Z", "Z"}], "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "f7e52588-cb74-4d08-9368-e93a96d50d17"],
 ". That ",
 Cell[BoxData[
  StyleBox[
   RowBox[{"Z", "Z", "Z"}], "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "364d1927-4530-451c-b2a9-b6e63d1c2af2"],
 " really sits in the stabilizer group shows up as a ",
 Cell[BoxData[
  RowBox[{"+", "1"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "e2084d5d-90ea-4317-a36a-af76eaa09bd2"],
 " expectation value:"
}], "Text",ExpressionUUID->"affa7afb-b8e0-4931-83f8-741d61e07cbb"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"psAffineDemo", "[", 
  RowBox[{"\"\<Expectation\>\"", ",", " ", "\"\<ZZZ\>\""}], "]"}]], "Input",
 CellLabel->
  "In[29]:= ",ExpressionUUID->"2e56d24b-ba22-493c-97d2-22b32bf10c76"],

Cell[BoxData["1"], "Output",
 CellLabel->
  "Out[29]= ",ExpressionUUID->"97970a83-37a5-456a-82ce-a9ee70461e1a"]
}, Open  ]],

Cell[TextData[{
 "That is the whole anatomy of a stabilizer state: a uniform superposition \
over a coset, with the relative signs fixed by the generator signs. The \
exponential compression is now intuitive: naming the subspace and the signs \
costs ",
 Cell[BoxData[
  RowBox[{
   StyleBox["O", "TI"], 
   StyleBox["(",
    SpanMaxSize->1], 
   SuperscriptBox[
    StyleBox["n", "TI"], "2"], 
   StyleBox[")",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "565d0a2b-ff56-4a7b-be80-f370af217c78"],
 " bits, while listing the amplitudes costs ",
 Cell[BoxData[
  SuperscriptBox["2", 
   StyleBox["n", "TI"]]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "b1c4039b-9cbd-40bd-a777-cd511663d016"],
 "."
}], "Text",ExpressionUUID->"2071e677-95e8-4cab-89e1-e799a4ca3543"],

Cell[TextData[{
 "Why is any of this fast? Because of what a ",
 StyleBox["Clifford", "TI"],
 " gate is: precisely a unitary that conjugates every Pauli to a Pauli, that \
is, an element of the normalizer of the Pauli group. The Hadamard, the phase \
gate ",
 Cell[BoxData[
  StyleBox["S", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "fca4683b-8518-4d1f-9c5f-d5f3c2c0b792"],
 ", and CNOT generate the whole Clifford group, and they are exactly the \
gates the tableau handles. Updating the state therefore means updating each \
generator, ",
 Cell[BoxData[
  RowBox[{
   StyleBox["g", "TI"], "\[Function]", 
   StyleBox["U", "TI"], 
   StyleBox["g", "TI"], 
   SuperscriptBox[
    StyleBox["U", "TI"], "\[Dagger]"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "68187e7e-58a1-4940-a4c0-d47ac375e479"],
 ", which is a fixed local rewrite of two bits and a sign per affected qubit. \
This is the content of the Gottesman-Knill theorem: a circuit of Clifford \
gates on a stabilizer input can be simulated in time polynomial in ",
 Cell[BoxData[
  StyleBox["n", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "fb701961-bab4-41b5-b92e-91022a03f07f"],
 ", with ",
 Cell[BoxData[
  RowBox[{
   StyleBox["O", "TI"], 
   StyleBox["(",
    SpanMaxSize->1], 
   StyleBox["n", "TI"], 
   StyleBox[")",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "1d0fd7c1-85eb-4dde-a8d3-53baa0adfeea"],
 " work per gate, rather than the ",
 Cell[BoxData[
  RowBox[{
   StyleBox["O", "TI"], 
   StyleBox["(",
    SpanMaxSize->1], 
   SuperscriptBox["2", 
    StyleBox["n", "TI"]], 
   StyleBox[")",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "cc151a6f-b2f3-4796-be68-a0c5e149cb6b"],
 " of dense state-vector evolution. The single-qubit gate methods (",
 Cell[BoxData["\"\<H\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "551eec18-b662-4e8a-96f5-73149e8e3c75"],
 ", ",
 Cell[BoxData["\"\<S\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "2650e72e-3538-4e21-9a88-d98b071b73e4"],
 ", ",
 Cell[BoxData["\"\<X\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "6b7d8676-1733-472e-a134-3bde16776b69"],
 ", ",
 Cell[BoxData["\"\<Y\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "c2f0bab2-75e3-4e99-83f1-d96604d76619"],
 ", ",
 Cell[BoxData["\"\<Z\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "167c4282-b86f-4f9a-a816-e1e85ca736f9"],
 ", ",
 Cell[BoxData["\"\<V\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "ee97b9d8-adfa-4608-8bdd-e767beb08941"],
 " for ",
 Cell[BoxData[
  SqrtBox[
   StyleBox["X", "TI"]]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "a2bcef26-3308-4499-b212-f0987bdcd99b"],
 ", and ",
 Cell[BoxData[
  RowBox[{"SuperDagger", "[", "\"\<S\>\"", "]"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "4e050875-08df-4a1d-afa7-d17784695501"],
 ") and the two-qubit ",
 Cell[BoxData["\"\<CNOT\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "9d8325ae-e5e6-48e5-9fa7-9c96b6d5a7db"],
 ", ",
 Cell[BoxData["\"\<CZ\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "1f4aad97-1d1f-4af5-8406-8f48bfbc59cb"],
 ", ",
 Cell[BoxData["\"\<SWAP\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "e07cb869-c10e-4267-8323-0f2521161f69"],
 " each perform exactly that rewrite."
}], "Text",ExpressionUUID->"45486c4c-ad7c-4f5c-8cf9-75a2c6c4deb6"],

Cell["Two pictures of one circuit: Schr\[ODoubleDot]dinger and Heisenberg", \
"Section",ExpressionUUID->"0edebd3c-c1ea-45e7-88e1-9a63c9b2d980"],

Cell[TextData[{
 "That rewrite is worth slowing down on, because it is the whole reason the \
formalism reproduces ordinary quantum mechanics on its domain. The standard \
task is concrete: given a circuit, produce the final state. There are two \
ways to do it. The ",
 StyleBox["Schr\[ODoubleDot]dinger", "TI"],
 " way carries the state vector forward, ",
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     StyleBox["\[Psi]", "TI"]},
    "Ket"], "\[Function]", 
   RowBox[{
    StyleBox["U", "TI"], 
    TemplateBox[{
      StyleBox["\[Psi]", "TI"]},
     "Ket"]}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "d1293fca-73ee-496b-96f8-1bdda563a8f9"],
 ", with ",
 Cell[BoxData[
  SuperscriptBox["2", 
   StyleBox["n", "TI"]]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "10d09b8d-ef1b-40ab-948a-334696952c0b"],
 " amplitudes evolving under ",
 Cell[BoxData[
  RowBox[{
   SuperscriptBox["2", 
    StyleBox["n", "TI"]], "\[Times]", 
   SuperscriptBox["2", 
    StyleBox["n", "TI"]]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "0fdf9edb-68ac-494f-a0cb-4ef4f43331ce"],
 " matrices. The ",
 StyleBox["Heisenberg", "TI"],
 " way carries the generators forward and never forms the state at all. They \
return the same state, and watching them meet is the clearest way to see what \
the tableau computes."
}], "Text",ExpressionUUID->"4571472e-6ec6-4756-a999-c3c11d15d18c"],

Cell[TextData[{
 "Fix a small Clifford circuit on three qubits, with an ",
 Cell[BoxData[
  StyleBox["S", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "c40f228a-622c-4796-a15f-a0e54dd4bfc9"],
 " gate to make the result nontrivial:"
}], "Text",ExpressionUUID->"b94f054e-9295-43bd-a804-3acc50967fd9"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"cliffordCircuit", " ", "=", " ", 
  RowBox[{"QuantumCircuitOperator", "[", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"\"\<H\>\"", " ", "->", " ", "1"}], ",", " ", 
     RowBox[{"\"\<CNOT\>\"", " ", "->", " ", 
      RowBox[{"{", 
       RowBox[{"1", ",", " ", "2"}], "}"}]}], ",", " ", 
     RowBox[{"\"\<S\>\"", " ", "->", " ", "2"}], ",", " ", 
     RowBox[{"\"\<CNOT\>\"", " ", "->", " ", 
      RowBox[{"{", 
       RowBox[{"2", ",", " ", "3"}], "}"}]}]}], "}"}], "]"}]}]], "Input",
 CellLabel->
  "In[30]:= ",ExpressionUUID->"d7d813d0-f8df-44dc-90e7-b3138382d0ec"],

