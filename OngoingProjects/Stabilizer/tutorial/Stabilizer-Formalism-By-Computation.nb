Cell[TextData[{
 "It is worth pausing on what these states look like in general, because the \
picture is simple. Every stabilizer state is a ",
 StyleBox["flat", "TI"],
 " superposition: its nonzero amplitudes all share a single magnitude, up to \
signs and factors of ",
 Cell[BoxData[
  StyleBox["i", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "e157d3d7-0b95-4416-b2f4-79560797f764"],
 ", and they sit on an affine subspace of ",
 Cell[BoxData[
  SubsuperscriptBox["\|01d53d", "2", 
   StyleBox["n", "TI"]]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "98e90c46-13db-48b3-b124-a69726a1fdb1"],
 ", the solution set of the ",
 Cell[BoxData[
  StyleBox["Z", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "ad0867cd-0462-4a4c-95e6-3cf14e32459f"],
 "-type parity checks in the stabilizer group. A three-qubit example shows \
the anatomy directly. Build it:"
}], "Text",ExpressionUUID->"d919720b-c717-4641-b50e-fd54c4fe32fc"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"psAffineDemo", " ", "=", " ", 
  RowBox[{
   RowBox[{"PauliStabilizer", "[", "3", "]"}], "[", 
   RowBox[{"{", 
    RowBox[{"\"\<H\>\"", ",", " ", 
     RowBox[{"\"\<H\>\"", " ", "->", " ", 
      RowBox[{"{", "2", "}"}]}], ",", " ", 
     RowBox[{"\"\<CNOT\>\"", " ", "->", " ", 
      RowBox[{"{", 
       RowBox[{"1", ",", " ", "3"}], "}"}]}], ",", " ", 
     RowBox[{"\"\<CNOT\>\"", " ", "->", " ", 
      RowBox[{"{", 
       RowBox[{"2", ",", " ", "3"}], "}"}]}]}], "}"}], "]"}]}]], "Input",
 CellLabel->
  "In[25]:= ",ExpressionUUID->"9a9aca61-a18d-43f9-8fcf-60d72128dc79"],

