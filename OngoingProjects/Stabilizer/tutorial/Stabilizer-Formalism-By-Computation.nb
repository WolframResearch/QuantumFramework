Cell[TextData[{
 "The sign of the first generator is now ",
 Cell[BoxData[
  RowBox[{"1", "-", "2", 
   SubscriptBox[
    StyleBox["s", "TI"], "1"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "fe2f54d3-6a78-4118-b3ac-9fc75154795b"],
 ", which is ",
 Cell[BoxData[
  RowBox[{"+", "1"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "d2702a30-634c-4ecd-90a7-32b57d260298"],
 " at ",
 Cell[BoxData[
  RowBox[{
   SubscriptBox[
    StyleBox["s", "TI"], "1"], "=", "0"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "2a2b00c9-1f7b-4a8e-bb90-c2081c2c0110"],
 " and ",
 Cell[BoxData[
  RowBox[{"-", "1"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "72a092af-fbcf-43aa-ae2e-6b0bc49b0d50"],
 " at ",
 Cell[BoxData[
  RowBox[{
   SubscriptBox[
    StyleBox["s", "TI"], "1"], "=", "1"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "0c178bc6-3b1f-4a74-a569-35fee5d4dbab"],
 ": the formal bit ",
 StyleBox["is", "TI"],
 " the unmade measurement. (The subscript on ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["s", "TI"], 
   StyleBox["k", "TI"]]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "c2e15ecb-1e50-4fb9-8ec8-0d1876f270ed"],
 " is a running session counter, so measuring again or re-running these cells \
allocates ",
 Cell[BoxData[
  RowBox[{
   SubscriptBox[
    StyleBox["s", "TI"], "2"], ",", 
   SubscriptBox[
    StyleBox["s", "TI"], "3"], ",", "\[Ellipsis]"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "b48714c7-44fd-4fff-a7f5-a82393b59be1"],
 ".) Substituting a concrete value resolves it, and the two substitutions \
reproduce the two post-measurement branches exactly:"
}], "Text",ExpressionUUID->"69df7ed5-f4af-4c9b-a982-63259f300479"],

