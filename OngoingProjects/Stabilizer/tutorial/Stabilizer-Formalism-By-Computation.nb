Cell[TextData[{
 "At twenty qubits the frame carries eight stabilizer terms where the \
amplitudes would need over a million: it is exponentially smaller than the \
state it represents, sized by the magic content alone. That compactness is \
the entire reason stabilizer-rank methods exist, and the relating Pauli on \
each component keeps the superposition phase-coherent, so the frame is also \
",
 StyleBox["exact", "TI"],
 "."
}], "Text",ExpressionUUID->"6291c610-468c-4e17-8800-b451b1f50f65"],

Cell[TextData[{
 "Being exact, it reaches physics the bare tableau cannot. A single ",
 Cell[BoxData[
  StyleBox["T", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "de3b4bbf-3408-437b-8ad8-031058aac8c8"],
 " on ",
 Cell[BoxData[
  TemplateBox[{"+"},
   "Ket"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "264f4f65-5b6f-4d47-8e96-8f2042668cb5"],
 " is the magic state ",
 Cell[BoxData[
  TemplateBox[{
    StyleBox["T", "TI"]},
   "Ket"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "72fb4047-4f92-403a-a01c-81360434335e"],
 ", a rank-two frame:"
}], "Text",ExpressionUUID->"8a2b6a5a-c7d7-48c0-a464-9e9f2368ddc6"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Tmagic", " ", "=", " ", 
  RowBox[{
   RowBox[{"PauliStabilizer", "[", "1", "]"}], "[", 
   RowBox[{"{", 
    RowBox[{"\"\<H\>\"", ",", " ", "\"\<T\>\""}], "}"}], "]"}]}]], "Input",
 CellLabel->
  "In[97]:= ",ExpressionUUID->"9f6ec33f-552f-4f5b-9c35-68b5c32397aa"],

Cell[BoxData[
 InterpretationBox[
  RowBox[{
   TagBox["StabilizerFrame",
    "SummaryHead"], "[", 
   DynamicModuleBox[{Typeset`open$$ = False, Typeset`embedState$$ = "Ready"}, 
    
    TemplateBox[{
      PaneSelectorBox[{False -> GridBox[{{
            PaneBox[
             ButtonBox[
              DynamicBox[
               FEPrivate`FrontEndResource["FEBitmaps", "SummaryBoxOpener"]], 
              ButtonFunction :> (Typeset`open$$ = True), Appearance -> None, 
              BaseStyle -> {}, Evaluator -> Automatic, Method -> 
              "Preemptive"], Alignment -> {Center, Center}, ImageSize -> 
             Dynamic[{
               Automatic, 
                3.5 (CurrentValue["FontCapHeight"]/AbsoluteCurrentValue[
                 Magnification])}]], 
            FrameBox["\"\[ScriptCapitalF]\"", StripOnInput -> False], 
            GridBox[{{
               RowBox[{
                 TagBox["\"Components: \"", "SummaryItemAnnotation"], 
                 "\[InvisibleSpace]", 
                 TagBox["2", "SummaryItem"]}]}, {
               RowBox[{
                 TagBox["\"Qubits: \"", "SummaryItemAnnotation"], 
                 "\[InvisibleSpace]", 
                 TagBox["1", "SummaryItem"]}]}}, 
             GridBoxAlignment -> {
              "Columns" -> {{Left}}, "Rows" -> {{Automatic}}}, AutoDelete -> 
             False, GridBoxItemSize -> {
              "Columns" -> {{Automatic}}, "Rows" -> {{Automatic}}}, 
             GridBoxSpacings -> {"Columns" -> {{2}}, "Rows" -> {{Automatic}}},
              BaseStyle -> {
              ShowStringCharacters -> False, NumberMarks -> False, 
               PrintPrecision -> 3, ShowSyntaxStyles -> False}]}}, 
          GridBoxAlignment -> {"Columns" -> {{Left}}, "Rows" -> {{Top}}}, 
          AutoDelete -> False, 
          GridBoxItemSize -> {
           "Columns" -> {{Automatic}}, "Rows" -> {{Automatic}}}, 
          BaselinePosition -> {1, 1}], True -> GridBox[{{
            PaneBox[
             ButtonBox[
              DynamicBox[
               FEPrivate`FrontEndResource["FEBitmaps", "SummaryBoxCloser"]], 
              ButtonFunction :> (Typeset`open$$ = False), Appearance -> None, 
              BaseStyle -> {}, Evaluator -> Automatic, Method -> 
              "Preemptive"], Alignment -> {Center, Center}, ImageSize -> 
             Dynamic[{
               Automatic, 
                3.5 (CurrentValue["FontCapHeight"]/AbsoluteCurrentValue[
                 Magnification])}]], 
            FrameBox["\"\[ScriptCapitalF]\"", StripOnInput -> False], 
            GridBox[{{
               RowBox[{
                 TagBox["\"Components: \"", "SummaryItemAnnotation"], 
                 "\[InvisibleSpace]", 
                 TagBox["2", "SummaryItem"]}]}, {
               RowBox[{
                 TagBox["\"Qubits: \"", "SummaryItemAnnotation"], 
                 "\[InvisibleSpace]", 
                 TagBox["1", "SummaryItem"]}]}, {
               RowBox[{
                 TagBox["\"First coefficient: \"", "SummaryItemAnnotation"], 
                 "\[InvisibleSpace]", 
                 TagBox[
                  RowBox[{
                    FractionBox["1", "2"], " ", 
                    RowBox[{"(", 
                    RowBox[{"1", "+", 
                    SuperscriptBox["\[ExponentialE]", 
                    FractionBox[
                    RowBox[{"\[ImaginaryI]", " ", "\[Pi]"}], "4"]]}], ")"}]}],
                   "SummaryItem"]}]}}, 
             GridBoxAlignment -> {
              "Columns" -> {{Left}}, "Rows" -> {{Automatic}}}, AutoDelete -> 
             False, GridBoxItemSize -> {
              "Columns" -> {{Automatic}}, "Rows" -> {{Automatic}}}, 
             GridBoxSpacings -> {"Columns" -> {{2}}, "Rows" -> {{Automatic}}},
              BaseStyle -> {
              ShowStringCharacters -> False, NumberMarks -> False, 
               PrintPrecision -> 3, ShowSyntaxStyles -> False}]}}, 
          GridBoxAlignment -> {"Columns" -> {{Left}}, "Rows" -> {{Top}}}, 
          AutoDelete -> False, 
          GridBoxItemSize -> {
           "Columns" -> {{Automatic}}, "Rows" -> {{Automatic}}}, 
          BaselinePosition -> {1, 1}]}, 
       Dynamic[Typeset`open$$], ImageSize -> Automatic]},
     "SummaryPanel"],
    DynamicModuleValues:>{}], "]"}],
  Wolfram`QuantumFramework`StabilizerFrame[<|
   "Components" -> {{(1 + E^((I/4) Pi))/2, 
       Wolfram`QuantumFramework`PauliStabilizer[<|
        "PackedX" -> {{0, 1}}, "PackedZ" -> {{1, 0}}, "Signs" -> {1, 1}, 
         "Qubits" -> 1|>]}, {(1 - E^((I/4) Pi))/2, 
       Wolfram`QuantumFramework`PauliStabilizer[<|
        "PackedX" -> {{0, 1}}, "PackedZ" -> {{1, 0}}, "Signs" -> {1, -1}, 
         "Qubits" -> 1|>]}}, "Paulis" -> {{{0}, {0}, 1}, {{0}, {1}, 1}}|>],
  Editable->False,
  SelectWithContents->True,
  Selectable->False]], "Output",
 CellLabel->
  "Out[97]= ",ExpressionUUID->"6105d14e-a558-4cbf-bcdc-ba4a7395789c"]
}, Open  ]],

Cell[TextData[{
 "Its two amplitudes have equal magnitude ",
 Cell[BoxData[
  RowBox[{"1", "/", 
   SqrtBox["2"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "4f088d53-73cb-4802-80dd-7d6ac8e61127"],
 ", but the second carries the phase ",
 Cell[BoxData[
  RowBox[{"\[Pi]", "/", "4"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "c368221b-f965-45a0-a6c8-58d444a6fb6c"],
 ", the eighth root of unity ",
 Cell[BoxData[
  SuperscriptBox[
   StyleBox["e", "TI"], 
   RowBox[{
    StyleBox["i", "TI"], "\[Pi]", "/", "4"}]]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "51281e7c-ba8c-4b96-ab56-2372fd9de307"],
 " that no stabilizer-state amplitude (those are only ",
 Cell[BoxData[
  RowBox[{"\[PlusMinus]", "1"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "8a412c67-433f-41d4-b80e-c85c3542eb8f"],
 " and ",
 Cell[BoxData[
  RowBox[{"\[PlusMinus]", 
   StyleBox["i", "TI"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "68a9bc74-51d3-41ad-9dec-8771646c1faa"],
 " times a fixed magnitude) ever has:"
}], "Text",ExpressionUUID->"4819d421-1011-436d-8f4d-60422c66bc54"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"Tmagic", "[", "\"\<StateVector\>\"", "]"}], " ", "//", " ", 
   "Normal"}], " ", "//", " ", "FullSimplify"}]], "Input",
 CellLabel->
  "In[98]:= ",ExpressionUUID->"69d89406-6604-4e36-b280-709bc762cefb"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   FractionBox["1", 
    SqrtBox["2"]], ",", 
   RowBox[{
    FractionBox["1", "2"], "+", 
    FractionBox["\[ImaginaryI]", "2"]}]}], "}"}]], "Output",
 CellLabel->
  "Out[98]= ",ExpressionUUID->"25fb1128-4d97-4283-8193-e53d93f6dd6a"]
}, Open  ]],

Cell[TextData[{
 "The entry ",
 Cell[BoxData[
  RowBox[{
   FractionBox["1", "2"], "+", 
   FractionBox[
    StyleBox["i", "TI"], "2"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "7c582a2b-6e8b-42cd-abf9-33d64b453474"],
 " is exactly ",
 Cell[BoxData[
  RowBox[{
   SuperscriptBox[
    StyleBox["e", "TI"], 
    RowBox[{
     StyleBox["i", "TI"], "\[Pi]", "/", "4"}]], "/", 
   SqrtBox["2"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "66e39c86-0da0-4072-bdc1-31cf751a13e6"],
 ". Measuring ",
 Cell[BoxData[
  TemplateBox[{
    StyleBox["T", "TI"]},
   "Ket"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "e1898798-03b2-4d9f-aff5-40db0a870fe9"],
 " in the ",
 Cell[BoxData[
  StyleBox["X", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "d2e99241-f623-4c25-9f4a-02cb9b0b2725"],
 " basis then gives a Born probability no stabilizer state can produce, since \
a Pauli measurement on a stabilizer state yields only ",
 Cell[BoxData["0"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "b6586894-bb0f-4005-b760-fba6367b2a06"],
 ", ",
 Cell[BoxData[
  FractionBox["1", "2"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "e6624c59-0ffc-44b0-a7b4-c9159a926584"],
 ", or ",
 Cell[BoxData["1"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "634b8756-5ebe-4963-be1c-bcc134918231"],
 ":"
}], "Text",ExpressionUUID->"ba5fba27-a29b-4ec0-ad58-734b111a4290"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"Abs", "[", 
    RowBox[{
     RowBox[{"Normalize", "[", 
      RowBox[{"{", 
       RowBox[{"1", ",", " ", "1"}], "}"}], "]"}], " ", ".", " ", 
     RowBox[{"Normal", "[", 
      RowBox[{"Tmagic", "[", "\"\<StateVector\>\"", "]"}], "]"}]}], "]"}], "^",
    "2"}], " ", "//", " ", "FullSimplify"}]], "Input",
 CellLabel->
  "In[99]:= ",ExpressionUUID->"c472e095-8916-4d2e-b6d9-dcff77fd6ab9"],

Cell[BoxData[
 RowBox[{
  FractionBox["1", "4"], " ", 
  RowBox[{"(", 
   RowBox[{"2", "+", 
    SqrtBox["2"]}], ")"}]}]], "Output",
 CellLabel->
  "Out[99]= ",ExpressionUUID->"2651e395-3bf6-4c3a-9f6a-a754ef60d84a"]
}, Open  ]],

Cell[TextData[{
 "The result is ",
 Cell[BoxData[
  RowBox[{
   StyleBox["(",
    SpanMaxSize->1], 
   RowBox[{"2", "+", 
    SqrtBox["2"]}], 
   StyleBox[")",
    SpanMaxSize->1], "/", "4", "\[TildeTilde]", "0.854"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "415e0ad1-ab4f-4c6f-b7c9-a7a37584e78a"],
 ", an irrational probability that is the fingerprint of genuine magic: the \
frame has carried the computation across the Clifford boundary that the \
tableau alone cannot cross."
}], "Text",ExpressionUUID->"24d9022a-df6f-4041-a1be-31bc9fc6b937"],

Cell[TextData[{
 "Two honest limitations remain, both under active work. First, the frame \
does not yet ",
 StyleBox["compress", "TI"],
 ": the true stabilizer rank of ",
 Cell[BoxData[
  StyleBox["t", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "fb110912-25ee-4d37-9d68-751cbc62c7df"],
 " magic states grows like ",
 Cell[BoxData[
  SuperscriptBox["2", 
   StyleBox[
    RowBox[{"\[Alpha]", "t"}], "TI"]]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "7eb4d68a-f895-41f4-91df-926b84c2cb82"],
 " with ",
 Cell[BoxData[
  RowBox[{
   StyleBox["\[Alpha]", "TI"], "\[TildeTilde]", "0.4"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "cf4f6108-ef30-455a-bfdd-2d1585c13b5c"],
 ", far below the naive ",
 Cell[BoxData[
  SuperscriptBox["2", 
   StyleBox["t", "TI"]]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "4b525136-cd6d-46a6-a8ea-a124a3817253"],
 ", but the framework keeps every term, so it is exact for a handful of ",
 Cell[BoxData[
  StyleBox["T", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "f987799a-7b74-4a78-a67c-a80070ab1464"],
 " gates rather than a scalable magic-state simulator, and reaching that \
bound by merging terms is the Bravyi-Gosset program. Second, the frame is \
today closer to a representation than a calculator: it exposes its components \
and its exact state, but it carries no native Pauli-expectation or \
measurement method, and its inner product reconstructs the dense ",
 Cell[BoxData[
  SuperscriptBox["2", 
   StyleBox["n", "TI"]]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "df4e3de8-e1df-435f-9aae-62a373070452"],
 " vector rather than summing the closed-form per-component overlaps. That is \
why the probability above is read off the exact state rather than from the \
rank decomposition directly. Giving the frame component-wise observables, at \
a cost set by the rank rather than by ",
 Cell[BoxData[
  SuperscriptBox["2", 
   StyleBox["n", "TI"]]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "cd87c357-0497-44c0-ba0f-be92bef02cb2"],
 ", is ongoing work."
}], "Text",ExpressionUUID->"d26120c9-9707-4ac7-9504-ee54985b0286"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Clifford channels", "Subsection",ExpressionUUID->"84382f62-f301-4fef-b891-bacbb521e3eb"],

Cell[TextData[{
 "Open-system Clifford dynamics, the maps that send stabilizer states to \
stabilizer states, are encoded by a Boolean Choi tableau in the framework's \
",
 Cell[BoxData["CliffordChannel"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "a18d9dd0-cdb0-4161-8a85-175f8f1cee78"],
 ", following Yashin. The identity channel on ",
 Cell[BoxData[
  StyleBox["n", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "62f2bd7f-f949-4857-bb89-26e3f547c450"],
 " qubits has a tableau of ",
 Cell[BoxData[
  RowBox[{"2", 
   StyleBox["n", "TI"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "5e2e887b-5929-4978-8658-1964399204e2"],
 " rows:"
}], "Text",ExpressionUUID->"5f6faa9e-0f32-4de0-86d1-d6501bf40718"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"CliffordChannel", "[", 
   RowBox[{"\"\<Identity\>\"", ",", " ", "3"}], "]"}], "[", "\"\<Rank\>\"", 
  "]"}]], "Input",
 CellLabel->
  "In[100]:= ",ExpressionUUID->"c4833365-7181-460d-966e-664b0ab34de7"],

Cell[BoxData["6"], "Output",
 CellLabel->
  "Out[100]= ",ExpressionUUID->"d5743a8c-c98d-42a0-a981-2d1bb91c57f0"]
}, Open  ]],

Cell["\<\
A pure stabilizer state is itself a state-preparation Clifford channel, whose \
tableau is the state's stabilizer half. Converting the Bell state to its \
channel recovers its two parity-check rows:\
\>", "Text",ExpressionUUID->"686affc6-550d-4459-8172-4cdf615f2411"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"CliffordChannel", "[", 
    RowBox[{
     RowBox[{"PauliStabilizer", "[", "2", "]"}], "[", 
     RowBox[{"{", 
      RowBox[{"\"\<H\>\"", ",", " ", "\"\<CNOT\>\""}], "}"}], "]"}], "]"}], 
   "[", "\"\<Tableau\>\"", "]"}], " ", "//", " ", "MatrixForm"}]], "Input",
 CellLabel->
  "In[101]:= ",ExpressionUUID->"6aed5a0e-4ffb-4c1f-82ba-a82107e7ab0a"],

Cell[BoxData[
 TagBox[
  RowBox[{"(", "\[NoBreak]", GridBox[{
     {"1", "1", "0", "0", "0"},
     {"0", "0", "1", "1", "0"}
    },
    GridBoxAlignment->{"Columns" -> {{Center}}, "Rows" -> {{Baseline}}},
    GridBoxSpacings->{"Columns" -> {
        Offset[0.27999999999999997`], {
         Offset[0.7]}, 
        Offset[0.27999999999999997`]}, "Rows" -> {
        Offset[0.2], {
         Offset[0.4]}, 
        Offset[0.2]}}], "\[NoBreak]", ")"}],
  Function[BoxForm`e$, 
   MatrixForm[BoxForm`e$]]]], "Output",
 CellLabel->
  "Out[101]= ",ExpressionUUID->"d794b3b5-00f8-418f-aae7-edd2a3287d54"]
}, Open  ]],

Cell[TextData[{
 "Noise stays in the tableau too. A named Pauli channel applied to a \
stabilizer state returns a probability-weighted mixture of stabilizer states, \
each branch an ",
 Cell[BoxData[
  RowBox[{
   StyleBox["O", "TI"], 
   StyleBox["(",
    SpanMaxSize->1], 
   StyleBox["n", "TI"], 
   StyleBox[")",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "b7a7ccf2-5af5-4167-b518-ed836cb0c070"],
 " tableau update rather than a dense density matrix. A bit-flip channel on \
",
 Cell[BoxData[
  TemplateBox[{"0"},
   "Ket"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "9f8c6e78-3d90-4eea-8dc1-8299bf11eeb9"],
 " is the textbook example, ",
 Cell[BoxData[
  TemplateBox[{"0"},
   "Ket"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "54a11b53-e10d-438b-a7f5-99a5a306ebf2"],
 " with probability ",
 Cell[BoxData[
  RowBox[{"1", "-", 
   StyleBox["p", "TI"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "b06971af-cc85-4d46-afb5-0ebf7a4b2446"],
 " and ",
 Cell[BoxData[
  TemplateBox[{"1"},
   "Ket"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "f57af4a6-c825-4f55-a510-ea7918062711"],
 " with probability ",
 Cell[BoxData[
  StyleBox["p", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "24b46457-8854-47b3-b4ce-6886c14fbb46"],
 ":"
}], "Text",ExpressionUUID->"7c11ce24-95e5-4b3a-a510-d0e2ce0f7862"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"{", 
    RowBox[{"#1", ",", " ", 
     RowBox[{"#2", "[", "\"\<Stabilizers\>\"", "]"}]}], "}"}], " ", "&"}], 
  " ", "@@@", " ", 
  RowBox[{
   RowBox[{"QuantumChannel", "[", 
    RowBox[{"\"\<BitFlip\>\"", "[", 
     RowBox[{"1", "/", "10"}], "]"}], "]"}], "[", 
