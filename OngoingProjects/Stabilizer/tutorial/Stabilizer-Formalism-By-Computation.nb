Cell[TextData[{
 "We read off the operator that stabilizes it with the ",
 Cell[BoxData["\"\<Stabilizers\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "c313c44b-18e2-4580-af1b-78670f1a9d42"],
 " property:"
}], "Text",ExpressionUUID->"650dbb72-5f83-431e-b1be-a32b038beca6"],

