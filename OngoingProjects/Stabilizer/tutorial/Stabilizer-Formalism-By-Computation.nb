Cell[TextData[{
 "The GHZ state, measured the same way, forks once and then runs straight. \
The first outcome is a coin, but the entanglement forces the other two, so \
only two histories survive, ",
 Cell[BoxData["000"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "680183a7-c32b-49bc-ac54-114e0ec47092"],
 " and ",
 Cell[BoxData["111"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "384e49ee-53d1-410d-8797-f3d19c128a66"],
 ":"
}], "Text",ExpressionUUID->"3e3714fd-9689-4b26-9429-16052944aaee"],

