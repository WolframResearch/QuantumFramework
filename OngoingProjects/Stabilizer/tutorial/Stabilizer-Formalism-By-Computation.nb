Cell[TextData[{
 "What comes back is an ordinary ",
 Cell[BoxData["QuantumState"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "97b06ffa-a639-4862-9f23-668a3781717a"],
 " object, so a stabilizer state drops straight into the rest of the \
framework. Chaining ",
 Cell[BoxData["\"\<StateVector\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "0fe80f5d-f4b4-4a93-87be-3931f8b70791"],
 " on that object reads off the raw ",
 Cell[BoxData[
  SuperscriptBox["2", 
   StyleBox["n", "TI"]]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "27ae0128-b210-41a0-8928-a86b498717ff"],
 " amplitudes, here the single column ",
 Cell[BoxData[
  TemplateBox[{"0"},
   "Ket"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "175a39b5-beb6-481c-a139-009e67f4b321"],
 ":"
}], "Text",ExpressionUUID->"fa23924c-3e32-4468-9c0e-28d04f487c88"],

