Cell[27695, 829, 610, 15, 36, "Text",ExpressionUUID->"eee82e26-e189-496d-9855-f84962ec84e0"],
Cell[CellGroupData[{
Cell[28330, 848, 147, 2, 29, "Input",ExpressionUUID->"b088fb47-5b9b-405e-bbde-d9daa8a289ca"],
Cell[28480, 852, 7488, 160, 70, "Output",ExpressionUUID->"aca0c263-8e0c-4ae9-963f-ce697f700790"]
}, Open  ]],
