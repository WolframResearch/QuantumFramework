Cell[TextData[{
 "What comes back is an ordinary ",
 Cell[BoxData["QuantumState"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "bbdbf7a9-6f37-4557-b267-8e259aeb001c"],
 " object, so a stabilizer state drops straight into the rest of the \
framework. Chaining ",
 Cell[BoxData["\"\<StateVector\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "3a4883f8-a9ab-4c15-9bde-f9d24e3855bd"],
 " on that object reads off the raw ",
 Cell[BoxData[
  SuperscriptBox["2", 
   StyleBox["n", "TI"]]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "12e72c48-0a2f-4eb3-afc8-8043ce1a664f"],
 " amplitudes, here the single column ",
 Cell[BoxData[
  TemplateBox[{"0"},
   "Ket"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "070db4b2-070c-40d4-a88d-85b6f1ce6a97"],
 ":"
}], "Text",ExpressionUUID->"056bc384-1295-4266-b3d8-9db8d52ee271"],

