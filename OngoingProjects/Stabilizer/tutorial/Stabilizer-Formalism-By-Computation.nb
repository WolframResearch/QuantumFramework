Cell[TextData[{
 "The sign of the first generator is now ",
 Cell[BoxData[
  RowBox[{"1", "-", "2", 
   SubscriptBox[
    StyleBox["s", "TI"], "1"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "bac4e46c-4af9-4f26-9482-63541d96e2b9"],
 ", which is ",
 Cell[BoxData[
  RowBox[{"+", "1"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "d2286170-570b-4862-9c7f-779ad8bc0b42"],
 " at ",
 Cell[BoxData[
  RowBox[{
   SubscriptBox[
    StyleBox["s", "TI"], "1"], "=", "0"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "711e2773-4c72-428a-b083-38db1db964f7"],
 " and ",
 Cell[BoxData[
  RowBox[{"-", "1"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "c5362d81-cd1c-4adb-b7bb-3c81f55e0b30"],
 " at ",
 Cell[BoxData[
  RowBox[{
   SubscriptBox[
    StyleBox["s", "TI"], "1"], "=", "1"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "adf932c8-4251-45bb-b7ad-b860924bb867"],
 ": the formal bit ",
 StyleBox["is", "TI"],
 " the unmade measurement. (The subscript on ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["s", "TI"], 
   StyleBox["k", "TI"]]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "573e1f6d-b91b-4f98-b0a9-270ca1e583f0"],
 " is a running session counter, so measuring again or re-running these cells \
allocates ",
 Cell[BoxData[
  RowBox[{
   SubscriptBox[
    StyleBox["s", "TI"], "2"], ",", 
   SubscriptBox[
    StyleBox["s", "TI"], "3"], ",", "\[Ellipsis]"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "05a45c9c-6918-4691-b1f3-a0053aaad553"],
 ".) Substituting a concrete value resolves it, and the two substitutions \
reproduce the two post-measurement branches exactly:"
}], "Text",ExpressionUUID->"ac8e09f9-93ed-470f-890a-426d1c93eba6"],

