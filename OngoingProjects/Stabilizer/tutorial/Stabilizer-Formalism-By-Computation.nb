Cell[TextData[{
 "We read off the operator that stabilizes it with the ",
 Cell[BoxData["\"\<Stabilizers\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "c0623a4f-da34-4d6b-a77f-d243ca8ecbc6"],
 " property:"
}], "Text",ExpressionUUID->"8008e5ad-18cf-411f-9dae-233fdd9b5e66"],

