Cell[BoxData[
 RowBox[{
  RowBox[{"psiStabilizer", "[", "\"\<StateVector\>\"", "]"}], " ", "//", " ", 
  "Normal"}]], "Input",
 CellLabel->
  "In[37]:= ",ExpressionUUID->"e2d54920-1159-44e9-87ec-dea4e97fb391"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{"-", 
    FractionBox["\[ImaginaryI]", 
     SqrtBox["2"]]}], ",", "0", ",", "0", ",", "0", ",", "0", ",", "0", ",", 
   "0", ",", 
   FractionBox["1", 
    SqrtBox["2"]]}], "}"}]], "Output",
 CellLabel->
  "Out[37]= ",ExpressionUUID->"3380b874-3a92-4810-aca8-35ffcec9f115"]
}, Open  ]],

Cell[TextData[{
 "Rather than chase that phase by hand, compare the two states with the \
framework's ",
 Cell[BoxData["QuantumSimilarity"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "997932c8-2adb-4204-a40d-78cdd310d7ee"],
 ", which is one exactly when they agree up to a global phase:"
}], "Text",ExpressionUUID->"4680a235-1ea6-46d4-9fd4-effe11f72506"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"QuantumSimilarity", "[", 
  RowBox[{"psiSchrodinger", ",", " ", "psiStabilizer"}], "]"}]], "Input",
 CellLabel->
  "In[38]:= ",ExpressionUUID->"00de29a6-9177-4d66-aa18-d4ad261022e3"],

Cell[BoxData["1"], "Output",
 CellLabel->
  "Out[38]= ",ExpressionUUID->"92cf2d4e-a769-4996-aac1-72b1395d217e"]
}, Open  ]],

Cell[TextData[{
 "This is the Gottesman-Knill theorem made concrete: a Clifford circuit on a \
stabilizer input is simulated by propagating ",
 Cell[BoxData[
  StyleBox["n", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "165d77ff-8c5a-470b-9a8f-b71becc4ebea"],
 " generators at ",
 Cell[BoxData[
  RowBox[{
   StyleBox["O", "TI"], 
   StyleBox["(",
    SpanMaxSize->1], 
   StyleBox["n", "TI"], 
   StyleBox[")",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "d3334d57-4040-465c-9e0e-2f688681a6b6"],
 " work per gate, and the state it computes is exactly the one Schr\
\[ODoubleDot]dinger evolution would, with the ",
 Cell[BoxData[
  SuperscriptBox["2", 
   StyleBox["n", "TI"]]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "f3e69d11-85e4-47e8-9e63-dfce52a94ee1"],
 " vector never formed except, here, to check."
}], "Text",ExpressionUUID->"c391cdde-83cd-4656-9b38-d24ff87928d2"],

Cell[TextData[{
 "The construction rests entirely on Clifford conjugation keeping a Pauli a \
Pauli, so it is also clear where it must break. A non-Clifford gate does not \
respect the Pauli group. The ",
 Cell[BoxData[
  StyleBox["T", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "d222efda-aa28-4874-a840-912414818077"],
 " gate commutes with ",
 Cell[BoxData[
  StyleBox["Z", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "45096576-35fc-45d5-879b-5676881f5078"],
 ", but conjugating ",
 Cell[BoxData[
  StyleBox["X", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "8bc45d3f-3681-47f4-a490-4b5543d5f31c"],
 " by it gives a sum. The conjugation ",
 Cell[BoxData[
  RowBox[{
   StyleBox["T", "TI"], 
   StyleBox["X", "TI"], 
   SuperscriptBox[
    StyleBox["T", "TI"], "\[Dagger]"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "592097f4-39ec-40b1-a905-13ab75519c48"],
 " is cleanest as the circuit ",
 Cell[BoxData[
  RowBox[{
   RowBox[{"{", 
    SuperscriptBox[
     StyleBox["T", "TI"], "\[Dagger]"]}], ",", 
   StyleBox["X", "TI"], ",", 
   RowBox[{
    StyleBox["T", "TI"], "}"}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "16980698-1293-4fc4-852e-551d585b8c88"],
 " decomposed into Paulis:"
}], "Text",ExpressionUUID->"15ac01c7-fe75-4899-9e80-668f5821749d"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"ExpToTrig", " ", "@", " ", 
  RowBox[{
   RowBox[{"QuantumCircuitOperator", "[", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"SuperDagger", "[", "\"\<T\>\"", "]"}], ",", " ", "\"\<X\>\"", ",",
       " ", "\"\<T\>\""}], "}"}], "]"}], "[", "\"\<PauliDecompose\>\"", 
   "]"}]}]], "Input",
 CellLabel->
  "In[39]:= ",ExpressionUUID->"8f664588-716f-4c94-afd5-8c3391a29833"],

Cell[BoxData[
 RowBox[{"\[LeftAssociation]", 
  RowBox[{
   RowBox[{"\<\"X\"\>", "\[Rule]", 
    FractionBox["1", 
     SqrtBox["2"]]}], ",", 
   RowBox[{"\<\"Y\"\>", "\[Rule]", 
    FractionBox["1", 
     SqrtBox["2"]]}]}], "\[RightAssociation]"}]], "Output",
 CellLabel->
  "Out[39]= ",ExpressionUUID->"e6260a72-9f1e-4827-91f4-876d50608f96"]
}, Open  ]],

Cell[TextData[{
 "Here ",
 Cell[BoxData[
  RowBox[{
   StyleBox["T", "TI"], 
   StyleBox["X", "TI"], 
   SuperscriptBox[
    StyleBox["T", "TI"], "\[Dagger]"], "=", 
   StyleBox["(",
    SpanMaxSize->1], 
   RowBox[{
    StyleBox["X", "TI"], "+", 
    StyleBox["Y", "TI"]}], 
   StyleBox[")",
    SpanMaxSize->1], "/", 
   SqrtBox["2"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "b9487bea-fc2c-4e93-8580-3fbe8f66c657"],
 " has two terms, not one. A single generator no longer maps to a single \
generator, the group stops being generated by ",
 Cell[BoxData[
  StyleBox["n", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "ce41c908-abbf-4a58-8cbd-20113bcee65a"],
 " Pauli strings, and the cheap representation fails. That failure is not an \
accident of implementation but the edge of the classically tractable world; \
stabilizer frames push a bounded distance past that edge, at a cost that \
grows with the number of non-Clifford gates."
}], "Text",ExpressionUUID->"cdb98b72-9fcf-4ee5-85de-87f80507410c"],

Cell["Entanglement for free: Bell and GHZ", "Section",ExpressionUUID->"78493eab-c9fa-4f03-a707-f4601709737a"],

Cell[TextData[{
 "Entangled states are not special in this language; they are simply \
stabilizer groups whose generators are not single-qubit operators. The Bell \
state ",
 Cell[BoxData[
  TemplateBox[{
    SuperscriptBox["\[CapitalPhi]", "+"]},
   "Ket"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "68d41d9d-5b6e-4cf0-a4d1-ae58202957d2"],
 " is prepared from ",
 Cell[BoxData[
  TemplateBox[{"00"},
   "Ket"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "16f97cad-ae48-4b53-ad90-3db7d38c68fe"],
 " by a Hadamard and a CNOT, and its stabilizer group is generated by ",
 Cell[BoxData[
  StyleBox[
   RowBox[{"X", "X"}], "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "3ec2378f-fc6d-46b6-a3cb-680a1a8d11bf"],
 " and ",
 Cell[BoxData[
  StyleBox[
   RowBox[{"Z", "Z"}], "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "bb35d665-f0af-4a8d-b3d2-80c9290c5447"],
 "."
}], "Text",ExpressionUUID->"ebf33855-02b8-4eaf-83f6-5d491d933706"],

Cell["Build the Bell state:", "Text",ExpressionUUID->"e381f5eb-c021-476f-bde7-72fe0d99296d"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"bell", " ", "=", " ", 
