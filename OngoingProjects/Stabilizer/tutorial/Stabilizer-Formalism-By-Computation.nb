Cell[TextData[{
 "The generators ",
 Cell[BoxData[
  StyleBox[
   RowBox[{"X", "X"}], "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "43c93902-8809-4c91-9689-50df96b62aac"],
 " and ",
 Cell[BoxData[
  StyleBox[
   RowBox[{"Z", "Z"}], "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "13649534-e403-4043-a1eb-dc6a348e75c7"],
 " are the familiar parity checks: the two qubits share an ",
 Cell[BoxData[
  StyleBox["X", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "ecbe3699-7511-479c-a8f4-8eed2bcab6c3"],
 "-parity and a ",
 Cell[BoxData[
  StyleBox["Z", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "bb7f96d4-e8a8-47d2-9ebc-d6e7c494ca84"],
 "-parity, which is precisely what maximal entanglement looks like here. The \
state vector is the textbook one:"
}], "Text",ExpressionUUID->"dcb9a6e9-98c9-4af7-b0d3-3cf0aa438748"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"bell", "[", "\"\<State\>\"", "]"}], "[", "\"\<StateVector\>\"", 
   "]"}], " ", "//", " ", "Normal"}]], "Input",
 CellLabel->
  "In[42]:= ",ExpressionUUID->"c1b4d465-bfd6-49cb-9661-b58f1b349207"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   FractionBox["1", 
    SqrtBox["2"]], ",", "0", ",", "0", ",", 
   FractionBox["1", 
    SqrtBox["2"]]}], "}"}]], "Output",
 CellLabel->
  "Out[42]= ",ExpressionUUID->"f5c9faf4-8d44-44cc-9e0f-fa4ea35f6509"]
}, Open  ]],

Cell[TextData[{
 "Entanglement entropy, normally a Schmidt-decomposition computation that \
blows up with system size, has a closed form for stabilizer states. Fattal \
and collaborators showed that the entanglement entropy across a cut ",
 Cell[BoxData[
  StyleBox["A", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "0027be6f-5d15-4471-a089-411e1687df01"],
 " equals the ",
 Cell[BoxData[
  SubscriptBox["\|01d53d", "2"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "ff119224-8b22-43fa-97a9-7b4564718931"],
 "-rank of the generators restricted to ",
 Cell[BoxData[
  StyleBox["A", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "7a0e80a8-1281-47ba-a98c-08383f32c707"],
 " (for each generator keep only the symplectic columns of the qubits in ",
 Cell[BoxData[
  StyleBox["A", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "b8e4268e-1647-4dad-9144-d1c9e1c468f4"],
 "), minus ",
 Cell[BoxData[
  RowBox[{
   StyleBox["\[LeftBracketingBar]",
    SpanMaxSize->1], 
   StyleBox["A", "TI"], "\[VeryThinSpace]", 
   StyleBox["\[RightBracketingBar]",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "52dc0a28-92ca-4568-9c72-64125e141412"],
 ". The framework computes this with ",
 Cell[BoxData["\"\<Entropy\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "f6af99c5-41fd-4c07-ae73-9c887ae01c23"],
 ", in ",
 Cell[BoxData[
  RowBox[{
   StyleBox["O", "TI"], 
   StyleBox["(",
    SpanMaxSize->1], 
   SuperscriptBox[
    StyleBox["n", "TI"], "3"], 
   StyleBox[")",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "3c5cec77-4233-4b0c-a57b-5a7ec784db9b"],
 " and with no dependence on ",
 Cell[BoxData[
  RowBox[{
   StyleBox["\[LeftBracketingBar]",
    SpanMaxSize->1], 
   StyleBox["A", "TI"], "\[VeryThinSpace]", 
   StyleBox["\[RightBracketingBar]",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "7aa20fb8-21ac-41a4-b9e9-68ac31247161"],
 ". For the Bell state, tracing out one qubit gives one bit of entropy:"
}], "Text",ExpressionUUID->"0e0d47f9-ffb3-4894-8188-d6799c1fbcb8"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"bell", "[", 
  RowBox[{"\"\<Entropy\>\"", ",", " ", 
   RowBox[{"{", "1", "}"}]}], "]"}]], "Input",
 CellLabel->
  "In[43]:= ",ExpressionUUID->"b7baac31-1200-4649-a284-1d7f7ba5d8d6"],

Cell[BoxData["1"], "Output",
 CellLabel->
  "Out[43]= ",ExpressionUUID->"bd7f3cdc-3fe2-4dcc-a44b-7bbd0a7a60d8"]
}, Open  ]],

Cell[TextData[{
 "The payoff is scale. A GHZ state on a thousand qubits is built by one \
Hadamard and a ladder of CNOTs. Build it (the object prints as a compact \
summary, never forming a ",
 Cell[BoxData[
  SuperscriptBox["2", "1000"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "45d8717a-ee57-4ed4-bb95-29560e6e0f33"],
 " vector):"
}], "Text",ExpressionUUID->"c06e89dc-a746-486b-95f6-3d8e0e04c5a0"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"ghz", " ", "=", " ", 
  RowBox[{
   RowBox[{"PauliStabilizer", "[", "1000", "]"}], "[", 
   RowBox[{"Prepend", "[", 
    RowBox[{
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{"\"\<CNOT\>\"", " ", "->", " ", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"q", " ", "-", " ", "1"}], ",", " ", "q"}], "}"}]}], ",", 
       " ", 
       RowBox[{"{", 
        RowBox[{"q", ",", " ", "2", ",", " ", "1000"}], "}"}]}], "]"}], ",", 
     " ", "\"\<H\>\""}], "]"}], "]"}]}]], "Input",
 CellLabel->
  "In[44]:= ",ExpressionUUID->"16cdceff-bb12-4e0c-85f5-46b8285e452f"],

Cell[BoxData[
 TagBox[
  TemplateBox[{
    RowBox[{
      StyleBox[
       TagBox["PauliStabilizer", "SummaryHead"], "NonInterpretableSummary"], 
      StyleBox["[", "NonInterpretableSummary"], 
      DynamicModuleBox[{
       Typeset`open$$ = False, Typeset`embedState$$ = "Ready"}, 
       TemplateBox[{
         TemplateBox[{
           PaneSelectorBox[{False -> GridBox[{{
                 PaneBox[
                  ButtonBox[
                   DynamicBox[
                    FEPrivate`FrontEndResource[
                    "FEBitmaps", "SummaryBoxOpener"]], 
                   ButtonFunction :> (Typeset`open$$ = True), Appearance -> 
                   None, BaseStyle -> {}, Evaluator -> Automatic, Method -> 
                   "Preemptive"], Alignment -> {Center, Center}, ImageSize -> 
                  Dynamic[{
                    Automatic, 
                    3.5 (CurrentValue["FontCapHeight"]/AbsoluteCurrentValue[
                    Magnification])}]], 
                 FrameBox["\"\[ScriptCapitalS]\"", StripOnInput -> False], 
                 GridBox[{{
                    RowBox[{
                    TagBox["\"Qubits: \"", "SummaryItemAnnotation"], 
                    "\[InvisibleSpace]", 
                    TagBox["1000", "SummaryItem"]}]}, {
                    RowBox[{
                    TagBox["\"Generators: \"", "SummaryItemAnnotation"], 
