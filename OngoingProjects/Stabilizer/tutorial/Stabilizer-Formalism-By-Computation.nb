Cell[TextData[{
 "A performance caveat that is also a design lesson. The convenience \
constructor ",
 Cell[BoxData[
  RowBox[{"PauliStabilizer", "[", "circuit", "]"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "be5875b2-40f6-4483-b755-175dc128e125"],
 " converts an arbitrary circuit by Pauli-conjugating each gate through full \
tomography, which is exponential in the qubit count and is meant only for \
tiny circuits. For anything at scale, use the gate-update chain or the \
circuit-list form ",
 Cell[BoxData[
  RowBox[{"ps", "[", "gates", "]"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "c8292c10-f8c7-4dca-8e2e-e66459a70f06"],
 ", which stay in the tableau. The right tool for the job is the difference \
between milliseconds and minutes."
}], "Text",ExpressionUUID->"d4092fbd-8929-433d-91c4-0851c1181880"],

Cell["Error-correcting codes as stabilizer states", "Section",ExpressionUUID->"561124f4-8179-4dae-8a8a-38e3d60b457f"],

Cell[TextData[{
 "Quantum error-correcting codes were the original motivation for the \
formalism: a code is defined by its stabilizer group, and a logical codeword \
is the simultaneous ",
 Cell[BoxData[
  RowBox[{"+", "1"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "b3fefa1c-9e21-4c5e-90ba-06f22c8ab3ec"],
 " eigenstate of the parity checks. The framework ships the canonical \
examples as named codes. The five-qubit perfect code is the smallest code \
that protects one logical qubit against an arbitrary single-qubit error:"
}], "Text",ExpressionUUID->"b2bb3c08-b70b-427b-807f-3db2111e4609"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"code", " ", "=", " ", 
  RowBox[{"PauliStabilizer", "[", "\"\<5QubitCode\>\"", "]"}]}]], "Input",
 CellLabel->
  "In[80]:= ",ExpressionUUID->"cb858461-00bf-408c-88db-5f869c9b2960"],

