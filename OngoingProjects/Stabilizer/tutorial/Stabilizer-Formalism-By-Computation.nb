   RowBox[{"PauliStabilizer", "[", "2", "]"}], "[", 
   RowBox[{"{", 
    RowBox[{"\"\<H\>\"", ",", " ", "\"\<CNOT\>\""}], "}"}], "]"}]}]], "Input",\

