Cell[TextData[{
 "The raw symplectic data is ",
 Cell[BoxData["\"\<Tableau\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "a51812fb-53f0-41ee-bd45-9e4b60085ebe"],
 ", a rank-3 array stacking the ",
 Cell[BoxData[
  StyleBox["X", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "2e889ee5-d14b-4383-be40-4e7aea8d697a"],
 " block above the ",
 Cell[BoxData[
  StyleBox["Z", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "af388cca-88da-4f41-b15b-1428c5c0c8a1"],
 " block (shape ",
 Cell[BoxData[
  RowBox[{"2", "\[Times]", 
   StyleBox["n", "TI"], "\[Times]", "2", 
   StyleBox["n", "TI"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "15f266dd-f270-48ee-bbae-f9e122b760e1"],
 ", here ",
 Cell[BoxData[
  RowBox[{"2", "\[Times]", "2", "\[Times]", "4"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "fc12e123-89bd-402d-852d-0449344ecdd1"],
 ": two blocks, ",
 Cell[BoxData[
  RowBox[{
   StyleBox["n", "TI"], "=", "2"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "9d88b12b-16d9-4d14-a6e3-13d9687b294e"],
 " qubits, ",
 Cell[BoxData[
  RowBox[{"2", 
   StyleBox["n", "TI"], "=", "4"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "355dd04d-0f0f-490e-8edf-eb524246b98d"],
 " rows):"
}], "Text",ExpressionUUID->"4a0d81e0-3940-41f7-b96a-790dcc9bb60f"],

