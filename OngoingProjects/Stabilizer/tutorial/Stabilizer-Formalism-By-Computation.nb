  "In[87]:= ",ExpressionUUID->"cdf2b419-f137-47df-913f-1c17328eb1f8"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"\<\"IIIXXXX\"\>", ",", "\<\"XIXIXIX\"\>", ",", "\<\"IXXIIXX\"\>", 
