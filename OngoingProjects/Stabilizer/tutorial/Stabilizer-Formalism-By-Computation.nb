Cell[TextData[{
 "At twenty qubits the frame carries eight stabilizer terms where the \
amplitudes would need over a million: it is exponentially smaller than the \
state it represents, sized by the magic content alone. That compactness is \
the entire reason stabilizer-rank methods exist, and the relating Pauli on \
each component keeps the superposition phase-coherent, so the frame is also \
",
 StyleBox["exact", "TI"],
 "."
}], "Text",ExpressionUUID->"b393be7d-b332-49df-9536-5135036144bc"],

Cell[TextData[{
 "Being exact, it reaches physics the bare tableau cannot. A single ",
 Cell[BoxData[
  StyleBox["T", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "d974feae-6801-41cb-bbd4-06be0222d760"],
 " on ",
 Cell[BoxData[
  TemplateBox[{"+"},
   "Ket"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "a860dc50-58c9-4d56-b829-b2aeb93beb46"],
 " is the magic state ",
 Cell[BoxData[
  TemplateBox[{
    StyleBox["T", "TI"]},
   "Ket"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "71ff64f6-7496-49d1-93c7-6a82c7c4c570"],
 ", a rank-two frame:"
}], "Text",ExpressionUUID->"cc9df8e2-4da8-4081-87e7-7d9413e6f601"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Tmagic", " ", "=", " ", 
  RowBox[{
   RowBox[{"PauliStabilizer", "[", "1", "]"}], "[", 
   RowBox[{"{", 
    RowBox[{"\"\<H\>\"", ",", " ", "\"\<T\>\""}], "}"}], "]"}]}]], "Input",
 CellLabel->
  "In[97]:= ",ExpressionUUID->"bcd0c2c3-7473-4ffd-9311-714ce22b2a57"],

Cell[BoxData[
 InterpretationBox[
  RowBox[{
   TagBox["StabilizerFrame",
    "SummaryHead"], "[", 
   DynamicModuleBox[{Typeset`open$$ = False, Typeset`embedState$$ = "Ready"}, 
    
    TemplateBox[{
      PaneSelectorBox[{False -> GridBox[{{
            PaneBox[
             ButtonBox[
              DynamicBox[
               FEPrivate`FrontEndResource["FEBitmaps", "SummaryBoxOpener"]], 
              ButtonFunction :> (Typeset`open$$ = True), Appearance -> None, 
              BaseStyle -> {}, Evaluator -> Automatic, Method -> 
              "Preemptive"], Alignment -> {Center, Center}, ImageSize -> 
             Dynamic[{
               Automatic, 
                3.5 (CurrentValue["FontCapHeight"]/AbsoluteCurrentValue[
                 Magnification])}]], 
            FrameBox["\"\[ScriptCapitalF]\"", StripOnInput -> False], 
            GridBox[{{
               RowBox[{
                 TagBox["\"Components: \"", "SummaryItemAnnotation"], 
                 "\[InvisibleSpace]", 
                 TagBox["2", "SummaryItem"]}]}, {
               RowBox[{
                 TagBox["\"Qubits: \"", "SummaryItemAnnotation"], 
                 "\[InvisibleSpace]", 
                 TagBox["1", "SummaryItem"]}]}}, 
             GridBoxAlignment -> {
              "Columns" -> {{Left}}, "Rows" -> {{Automatic}}}, AutoDelete -> 
             False, GridBoxItemSize -> {
              "Columns" -> {{Automatic}}, "Rows" -> {{Automatic}}}, 
             GridBoxSpacings -> {"Columns" -> {{2}}, "Rows" -> {{Automatic}}},
              BaseStyle -> {
              ShowStringCharacters -> False, NumberMarks -> False, 
               PrintPrecision -> 3, ShowSyntaxStyles -> False}]}}, 
          GridBoxAlignment -> {"Columns" -> {{Left}}, "Rows" -> {{Top}}}, 
          AutoDelete -> False, 
          GridBoxItemSize -> {
           "Columns" -> {{Automatic}}, "Rows" -> {{Automatic}}}, 
          BaselinePosition -> {1, 1}], True -> GridBox[{{
            PaneBox[
             ButtonBox[
              DynamicBox[
               FEPrivate`FrontEndResource["FEBitmaps", "SummaryBoxCloser"]], 
              ButtonFunction :> (Typeset`open$$ = False), Appearance -> None, 
              BaseStyle -> {}, Evaluator -> Automatic, Method -> 
              "Preemptive"], Alignment -> {Center, Center}, ImageSize -> 
             Dynamic[{
               Automatic, 
                3.5 (CurrentValue["FontCapHeight"]/AbsoluteCurrentValue[
                 Magnification])}]], 
            FrameBox["\"\[ScriptCapitalF]\"", StripOnInput -> False], 
            GridBox[{{
               RowBox[{
                 TagBox["\"Components: \"", "SummaryItemAnnotation"], 
                 "\[InvisibleSpace]", 
                 TagBox["2", "SummaryItem"]}]}, {
               RowBox[{
                 TagBox["\"Qubits: \"", "SummaryItemAnnotation"], 
                 "\[InvisibleSpace]", 
                 TagBox["1", "SummaryItem"]}]}, {
               RowBox[{
                 TagBox["\"First coefficient: \"", "SummaryItemAnnotation"], 
                 "\[InvisibleSpace]", 
                 TagBox[
                  RowBox[{
                    FractionBox["1", "2"], " ", 
                    RowBox[{"(", 
                    RowBox[{"1", "+", 
                    SuperscriptBox["\[ExponentialE]", 
                    FractionBox[
                    RowBox[{"\[ImaginaryI]", " ", "\[Pi]"}], "4"]]}], ")"}]}],
                   "SummaryItem"]}]}}, 
             GridBoxAlignment -> {
              "Columns" -> {{Left}}, "Rows" -> {{Automatic}}}, AutoDelete -> 
             False, GridBoxItemSize -> {
              "Columns" -> {{Automatic}}, "Rows" -> {{Automatic}}}, 
             GridBoxSpacings -> {"Columns" -> {{2}}, "Rows" -> {{Automatic}}},
              BaseStyle -> {
              ShowStringCharacters -> False, NumberMarks -> False, 
               PrintPrecision -> 3, ShowSyntaxStyles -> False}]}}, 
          GridBoxAlignment -> {"Columns" -> {{Left}}, "Rows" -> {{Top}}}, 
          AutoDelete -> False, 
          GridBoxItemSize -> {
           "Columns" -> {{Automatic}}, "Rows" -> {{Automatic}}}, 
          BaselinePosition -> {1, 1}]}, 
       Dynamic[Typeset`open$$], ImageSize -> Automatic]},
     "SummaryPanel"],
    DynamicModuleValues:>{}], "]"}],
  Wolfram`QuantumFramework`StabilizerFrame[<|
   "Components" -> {{Rational[1, 2] (1 + E^(Complex[0, 
            Rational[1, 4]] Pi)), 
       Wolfram`QuantumFramework`PauliStabilizer[<|
        "PackedX" -> {{0, 1}}, "PackedZ" -> {{1, 0}}, "Signs" -> {1, 1}, 
         "Qubits" -> 1|>]}, {Rational[1, 2] (1 - E^(Complex[0, 
           Rational[1, 4]] Pi)), 
       Wolfram`QuantumFramework`PauliStabilizer[<|
        "PackedX" -> {{0, 1}}, "PackedZ" -> {{1, 0}}, "Signs" -> {1, -1}, 
         "Qubits" -> 1|>]}}, "Paulis" -> {{{0}, {0}, 1}, {{0}, {1}, 1}}|>],
  Editable->False,
  SelectWithContents->True,
  Selectable->False]], "Output",
 CellLabel->
  "Out[97]= ",ExpressionUUID->"3bf48bc0-549c-43a0-9b92-70b0da24f6ed"]
}, Open  ]],

Cell[TextData[{
 "Its two amplitudes have equal magnitude ",
 Cell[BoxData[
  RowBox[{"1", "/", 
   SqrtBox["2"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "f4e70297-c752-4070-ac9f-33e670c9cc30"],
 ", but the second carries the phase ",
 Cell[BoxData[
  RowBox[{"\[Pi]", "/", "4"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "1468ec44-f1b3-489c-8b1d-3adda33ea264"],
 ", the eighth root of unity ",
 Cell[BoxData[
  SuperscriptBox[
   StyleBox["e", "TI"], 
   RowBox[{
    StyleBox["i", "TI"], "\[Pi]", "/", "4"}]]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "b93f24ce-3654-4678-a174-fd4b3d7b1546"],
 " that no stabilizer-state amplitude (those are only ",
 Cell[BoxData[
  RowBox[{"\[PlusMinus]", "1"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "4e638d0a-615d-4cdd-b410-b655edbf5aa9"],
 " and ",
 Cell[BoxData[
  RowBox[{"\[PlusMinus]", 
   StyleBox["i", "TI"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "23f41ad8-1080-4182-b369-3f81e60725de"],
 " times a fixed magnitude) ever has:"
}], "Text",ExpressionUUID->"9907b09a-dba4-448d-85d2-0d0357f56bea"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"Tmagic", "[", "\"\<StateVector\>\"", "]"}], " ", "//", " ", 
   "Normal"}], " ", "//", " ", "FullSimplify"}]], "Input",
 CellLabel->
  "In[98]:= ",ExpressionUUID->"987d7e5b-a1fb-46e0-8497-34fc20f87fc1"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   FractionBox["1", 
    SqrtBox["2"]], ",", 
   RowBox[{
    FractionBox["1", "2"], "+", 
    FractionBox["\[ImaginaryI]", "2"]}]}], "}"}]], "Output",
 CellLabel->
  "Out[98]= ",ExpressionUUID->"53f6d239-cb99-4a3f-8f1c-d117081d1334"]
}, Open  ]],

Cell[TextData[{
 "The entry ",
 Cell[BoxData[
  RowBox[{
   FractionBox["1", "2"], "+", 
   FractionBox[
    StyleBox["i", "TI"], "2"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "1ca67201-0cdf-4792-8e57-6f212e22706c"],
 " is exactly ",
 Cell[BoxData[
  RowBox[{
   SuperscriptBox[
    StyleBox["e", "TI"], 
    RowBox[{
     StyleBox["i", "TI"], "\[Pi]", "/", "4"}]], "/", 
   SqrtBox["2"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "316936ce-98b8-4a40-9a70-9a433347619f"],
 ". Measuring ",
 Cell[BoxData[
  TemplateBox[{
    StyleBox["T", "TI"]},
   "Ket"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "d6cb13fa-d8c5-4110-bcef-c7da997477b9"],
 " in the ",
 Cell[BoxData[
  StyleBox["X", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "b962ac59-8287-4296-a05f-b1039e151fa6"],
 " basis then gives a Born probability no stabilizer state can produce, since \
a Pauli measurement on a stabilizer state yields only ",
 Cell[BoxData["0"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "2055b9b4-9f80-4bff-aae2-9945d7ecf582"],
 ", ",
 Cell[BoxData[
  FractionBox["1", "2"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "715c3f1c-0220-4886-a772-1e6a58bc90d1"],
 ", or ",
 Cell[BoxData["1"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "8a6f8894-af12-4f90-998a-496d54a02d75"],
 ". The frame computes that expectation ",
 StyleBox["natively", "TI"],
 ", by the same closed-form Pauli sandwich the bare tableau uses, one term \
per pair of components, never forming the ",
 Cell[BoxData[
  SuperscriptBox["2", 
   StyleBox["n", "TI"]]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "4e63d8f1-2ff4-4e25-9333-20df7110a8f1"],
 " vector. Read ",
 Cell[BoxData[
  RowBox[{
   StyleBox["\[LeftAngleBracket]",
    SpanMaxSize->1], 
   StyleBox["X", "TI"], "\[VeryThinSpace]", 
   StyleBox["\[RightAngleBracket]",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "d8ecee81-6299-4cbe-9e56-735f52e44ee6"],
 " straight from the frame:"
}], "Text",ExpressionUUID->"0728db3e-53f7-4c15-9511-25462777763a"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"Tmagic", "[", 
   RowBox[{"\"\<Expectation\>\"", ",", " ", "\"\<X\>\""}], "]"}], " ", "//", 
  " ", "FullSimplify"}]], "Input",
 CellLabel->
  "In[99]:= ",ExpressionUUID->"25c3f0ea-e12d-49b0-a19c-7d1cd51a3a30"],

Cell[BoxData[
 FractionBox["1", 
  SqrtBox["2"]]], "Output",
 CellLabel->
  "Out[99]= ",ExpressionUUID->"65561e10-eaa2-4684-a2ae-057117538855"]
}, Open  ]],

Cell[TextData[{
 "The answer is ",
 Cell[BoxData[
  RowBox[{"1", "/", 
   SqrtBox["2"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "33141c47-7044-4f49-a482-b46f63bef369"],
 ", so the Born probability of the ",
 Cell[BoxData[
  RowBox[{"+", "1"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "2006530f-52ce-44a0-9465-5ddb4a6e2b6a"],
 " outcome is ",
 Cell[BoxData[
  RowBox[{
   StyleBox["(",
    SpanMaxSize->1], 
   RowBox[{"1", "+", 
    StyleBox["\[LeftAngleBracket]",
     SpanMaxSize->1], 
    StyleBox["X", "TI"], "\[VeryThinSpace]", 
    StyleBox["\[RightAngleBracket]",
     SpanMaxSize->1]}], 
   StyleBox[")",
    SpanMaxSize->1], "/", "2"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "33c4a0b6-132a-48ef-a915-dc47643cdb74"],
 ":"
}], "Text",ExpressionUUID->"a5aa5c59-6b98-4fb7-92c6-48c0f1bbaff2"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"(", 
    RowBox[{"1", " ", "+", " ", 
     RowBox[{"Tmagic", "[", 
      RowBox[{"\"\<Expectation\>\"", ",", " ", "\"\<X\>\""}], "]"}]}], ")"}], 
   " ", "/", " ", "2"}], " ", "//", " ", "FullSimplify"}]], "Input",
 CellLabel->
  "In[100]:= ",ExpressionUUID->"296d5471-16cb-46a9-b839-33b19a80dd68"],

Cell[BoxData[
 RowBox[{
  FractionBox["1", "4"], " ", 
  RowBox[{"(", 
   RowBox[{"2", "+", 
    SqrtBox["2"]}], ")"}]}]], "Output",
 CellLabel->
  "Out[100]= ",ExpressionUUID->"10ef9168-b8c1-41c6-a375-0ba38232d606"]
}, Open  ]],

Cell[TextData[{
 "The result is ",
 Cell[BoxData[
  RowBox[{
   StyleBox["(",
    SpanMaxSize->1], 
   RowBox[{"2", "+", 
    SqrtBox["2"]}], 
   StyleBox[")",
    SpanMaxSize->1], "/", "4", "\[TildeTilde]", "0.854"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "6ce0add8-6911-4a88-b089-3de74bbbb78a"],
 ", the irrational probability that is the fingerprint of genuine magic, the \
same value the dense state vector gives but now obtained without ever \
materializing it:"
}], "Text",ExpressionUUID->"46f1007f-0ebc-468e-9ed3-3d1ce758a15c"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"(", 
     RowBox[{"1", " ", "+", " ", 
      RowBox[{"Tmagic", "[", 
       RowBox[{"\"\<Expectation\>\"", ",", " ", "\"\<X\>\""}], "]"}]}], ")"}],
     " ", "/", " ", "2"}], " ", "==", " ", 
   RowBox[{
    RowBox[{"Abs", "[", 
     RowBox[{
      RowBox[{"Normalize", "[", 
       RowBox[{"{", 
        RowBox[{"1", ",", " ", "1"}], "}"}], "]"}], " ", ".", " ", 
      RowBox[{"Normal", "[", 
       RowBox[{"Tmagic", "[", "\"\<StateVector\>\"", "]"}], "]"}]}], "]"}], "^",
     "2"}]}], " ", "//", " ", "FullSimplify"}]], "Input",
 CellLabel->
  "In[101]:= ",ExpressionUUID->"39b5ee56-3f2f-4ec7-8b93-77e57297c97f"],

Cell[BoxData["True"], "Output",
 CellLabel->
  "Out[101]= ",ExpressionUUID->"31d77daf-92d7-4890-941b-8eebec02e0ce"]
}, Open  ]],

Cell[TextData[{
 "The frame has carried the computation across the Clifford boundary that the \
tableau alone cannot cross, and answered an observable there at a cost set by \
the rank, not by ",
 Cell[BoxData[
  SuperscriptBox["2", 
   StyleBox["n", "TI"]]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "afef91bc-2f12-4d70-bf64-1f5d07a1f7b3"],
 "."
}], "Text",ExpressionUUID->"4d30c123-d024-4fe5-a250-2dd64cd1161f"],

Cell[TextData[{
 "That same rank decomposition is where the cost lives, and the frame can \
prune it. Each ",
 Cell[BoxData[
  StyleBox["T", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "a1eff153-2002-4f99-ad00-8fef503e4535"],
 " doubles the term count, but the component vectors span a space of \
dimension at most ",
 Cell[BoxData[
  SuperscriptBox["2", 
   StyleBox["n", "TI"]]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "a97b271c-3945-47d5-a139-dab29e1fe35b"],
 ", so a frame routinely carries far more terms than it needs. The ",
 Cell[BoxData["\"\<Compress\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "1dc0f936-e6e3-4e76-a20e-33093e30e81f"],
 " method collapses it onto a maximal linearly independent subset, \
re-expressing the ",
 StyleBox["exact same state", "TI"],
 " on fewer components. Four ",
 Cell[BoxData[
  StyleBox["T", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "88023bce-137c-4ac9-9638-1c30b699efe8"],
 " gates on ",
 Cell[BoxData[
  TemplateBox[{"+"},
   "Ket"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "d7fab5ac-afcf-4ad3-9fe5-202f95812eb7"],
 " build a sixteen-term frame whose span is only two:"
}], "Text",ExpressionUUID->"7509e290-9381-48a2-a849-ec5bfa61e396"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"overMagic", " ", "=", " ", 
   RowBox[{
    RowBox[{"PauliStabilizer", "[", "1", "]"}], "[", 
    RowBox[{"Join", "[", 
     RowBox[{
      RowBox[{"{", "\"\<H\>\"", "}"}], ",", " ", 
      RowBox[{"Table", "[", 
       RowBox[{"\"\<T\>\"", ",", " ", "4"}], "]"}]}], "]"}], "]"}]}], ";"}], "\n", 
 RowBox[{"{", 
  RowBox[{
   RowBox[{"overMagic", "[", "\"\<Length\>\"", "]"}], ",", " ", 
   RowBox[{
    RowBox[{"overMagic", "[", "\"\<Compress\>\"", "]"}], "[", "\"\<Length\>\"",
     "]"}]}], "}"}]}], "Input",
 CellLabel->
  "In[102]:= ",ExpressionUUID->"af1bc0f8-af52-4b1a-b40f-4094c413fdf8"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"16", ",", "2"}], "}"}]], "Output",
 CellLabel->
  "Out[102]= ",ExpressionUUID->"4650e064-14c7-4f96-a679-9076048df3c1"]
}, Open  ]],

Cell["\<\
Sixteen terms collapse to two, the whole reach a single qubit ever had, and \
the state is unchanged:\
\>", "Text",ExpressionUUID->"7d6e2a27-4d3a-415f-873e-9313bd2f48f5"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"overMagic", "[", "\"\<Compress\>\"", "]"}], "[", "\"\<State\>\"", 
   "]"}], " ", "==", " ", 
  RowBox[{"overMagic", "[", "\"\<State\>\"", "]"}]}]], "Input",
 CellLabel->
  "In[103]:= ",ExpressionUUID->"3f4bf3b3-3861-43a4-9561-b2798da4e631"],

Cell[BoxData["True"], "Output",
 CellLabel->
  "Out[103]= ",ExpressionUUID->"295333e7-2978-4773-a745-144953270d45"]
}, Open  ]],

Cell[TextData[{
 "This is a span-dimension cap: exact, bounded by ",
 Cell[BoxData[
  SuperscriptBox["2", 
   StyleBox["n", "TI"]]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "d0e785ba-6616-4a23-9deb-97768ed76355"],
 ", and free. It is ",
 StyleBox["not", "TI"],
 " the optimal stabilizer rank, the Bravyi-Gosset ",
 Cell[BoxData[
  SuperscriptBox["2", 
   StyleBox[
    RowBox[{"\[Alpha]", "t"}], "TI"]]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "7bf0123f-1b43-43e0-b4d3-31be5c6efa47"],
 " with ",
 Cell[BoxData[
  RowBox[{
   StyleBox["\[Alpha]", "TI"], "\[TildeTilde]", "0.4"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "9429c06c-112e-4919-a4f1-d1abff3db15b"],
 " that merges terms no basis can separate; reaching that bound is the \
harder, still-open target. But the purely redundant blow-up is gone."
}], "Text",ExpressionUUID->"98340893-fc9e-4611-94fb-04e36f801fdb"],

Cell[TextData[{
 "For one important family the closed form is sharper still. A circuit of ",
 Cell[BoxData[
  StyleBox["T", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "37de3e74-4f2a-424a-a91d-2e9fbf88bde3"],
 ", ",
 Cell[BoxData[
  StyleBox["S", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "6f8b91bc-ecaf-4e1b-abc0-41fd65171433"],
 ", ",
 Cell[BoxData[
  StyleBox["Z", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "ade1b42d-1446-40da-9ba6-07ebd40d58a2"],
 ", and controlled-",
 Cell[BoxData[
  StyleBox["Z", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "35590153-4207-41fb-afe4-8c94bac0120e"],
 " gates with ",
 StyleBox["no Hadamard", "TI"],
 ", the diagonal or CNOT-dihedral fragment, acting on ",
 Cell[BoxData[
  SuperscriptBox[
   TemplateBox[{"+"},
    "Ket"], 
   RowBox[{"\[CircleTimes]", 
    StyleBox["n", "TI"]}]]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "9b19b505-e91a-4866-a6da-b344db1b3eac"],
 " keeps every qubit value a linear function of the inputs and folds all the \
magic into a single phase polynomial valued in the eighth roots of unity. The \
state is then rank one: any amplitude is one closed-form term, ",
 Cell[BoxData[
  RowBox[{
   RowBox[{
    TemplateBox[{
      StyleBox["y", "TI"]},
     "Bra"], 
    StyleBox["U", "TI"], 
    SuperscriptBox[
     TemplateBox[{"+"},
      "Ket"], 
     RowBox[{"\[CircleTimes]", 
      StyleBox["n", "TI"]}]]}], "=", 
   RowBox[{
    SuperscriptBox["2", 
     RowBox[{"-", 
      StyleBox["n", "TI"], "/", "2"}]], 
    SuperscriptBox[
     StyleBox["\[Omega]", "TI"], 
     RowBox[{"\[CurlyPhi]", 
      StyleBox["(",
       SpanMaxSize->1], 
      StyleBox["y", "TI"], 
      StyleBox[")",
       SpanMaxSize->1]}]]}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "9fc91ee8-9384-4729-a5f0-3d1e852bc7e2"],
 " with ",
 Cell[BoxData[
  RowBox[{
   StyleBox["\[Omega]", "TI"], "=", 
   SuperscriptBox[
    StyleBox["e", "TI"], 
    RowBox[{
     StyleBox["i", "TI"], "\[Pi]", "/", "4"}]]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "b4971bda-fd60-45a3-803a-45cb488a9645"],
 ", computed by a single ",
 Cell[BoxData[
  SubscriptBox["\|01d53d", "2"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "bd1cac93-6af0-4ca1-9e90-d7e9dd8063af"],
 " linear solve, ",
 StyleBox["flat in ", "TI"],
 Cell[BoxData[
  StyleBox["n", "TI"]], "InlineFormula", "TI",
  FontSize->0.9 Inherited,ExpressionUUID->
  "b7bbb015-8a0d-4ee1-a859-f2e92cb41174"],
 ". The stabilizer backend builds this representation on request, with the \
option ",
 Cell[BoxData[
  RowBox[{"\"\<Compress\>\"", " ", "->", " ", "\"\<PhasePolynomial\>\""}]], 
  "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "c58e83df-d193-4077-872b-001fe03021d7"],
 ". Build a diagonal magic circuit on twenty qubits, a ",
 Cell[BoxData[
  StyleBox["T", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "432080b0-2ee7-4baf-84db-3646229fc35d"],
 " on every wire, a ladder of controlled-",
 Cell[BoxData[
  StyleBox["Z", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "c6919638-0aec-4926-b62d-8ad6987b401d"],
 " gates, and one doubly-controlled ",
 Cell[BoxData[
  StyleBox["Z", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "5e5c4204-cef2-4a26-9c6d-acc093aa0bd0"],
 " (written ",
 Cell[BoxData[
  RowBox[{"\"\<C\>\"", "[", 
   RowBox[{
    RowBox[{"\"\<Z\>\"", " ", "->", " ", "3"}], ",", " ", 
    RowBox[{"{", 
     RowBox[{"1", ",", " ", "2"}], "}"}]}], "]"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "1fc8ed1b-6e76-47bb-b85a-d8b38f4491a9"],
 ", a three-qubit diagonal gate the term-by-term frame cannot even represent):"
}], "Text",ExpressionUUID->"da4a3539-4f66-4e6b-af3e-34099aae94f4"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"diagMagic", " ", "=", " ", 
   RowBox[{"QuantumCircuitOperator", "[", 
    RowBox[{"Join", "[", "\n", "   ", 
     RowBox[{
      RowBox[{"Table", "[", 
       RowBox[{
        RowBox[{"\"\<T\>\"", " ", "->", " ", "q"}], ",", " ", 
        RowBox[{"{", 
         RowBox[{"q", ",", " ", "20"}], "}"}]}], "]"}], ",", "\n", "   ", 
      RowBox[{"Table", "[", 
       RowBox[{
        RowBox[{"\"\<CZ\>\"", " ", "->", " ", 
         RowBox[{"{", 
          RowBox[{"q", ",", " ", 
           RowBox[{"q", " ", "+", " ", "1"}]}], "}"}]}], ",", " ", 
        RowBox[{"{", 
         RowBox[{"q", ",", " ", "1", ",", " ", "19"}], "}"}]}], "]"}], ",", 
      "\n", "   ", 
      RowBox[{"{", 
       RowBox[{"\"\<C\>\"", "[", 
        RowBox[{
         RowBox[{"\"\<Z\>\"", " ", "->", " ", "3"}], ",", " ", 
         RowBox[{"{", 
          RowBox[{"1", ",", " ", "2"}], "}"}]}], "]"}], "}"}]}], "]"}], 
    "]"}]}], ";"}], "\n", 
 RowBox[{"pp", " ", "=", " ", 
  RowBox[{"diagMagic", "[", 
   RowBox[{"Method", " ", "->", " ", 
    RowBox[{"{", 
     RowBox[{"\"\<Stabilizer\>\"", ",", " ", 
      RowBox[{"\"\<Compress\>\"", " ", "->", 
       " ", "\"\<PhasePolynomial\>\""}]}], "}"}]}], "]"}]}]}], "Input",
 CellLabel->
  "In[104]:= ",ExpressionUUID->"be886ce3-838b-4e3c-8f82-84775111fe94"],

