Cell[TextData[{
 "The answer is the signed string ",
 Cell[BoxData["\"\<-Z\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "0a1da90f-aa16-4670-8b00-d2b2dae9795b"],
 ", the operator that fixes ",
 Cell[BoxData[
  TemplateBox[{"1"},
   "Ket"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "7fda36eb-7c0d-41e3-9e58-719bc9326c55"],
 ". The sign is part of the stabilizer data, which is exactly why the \
formalism can tell ",
 Cell[BoxData[
  TemplateBox[{"0"},
   "Ket"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "6d685370-a88b-4e02-8e8a-c4ed0bebf1bf"],
 " from ",
 Cell[BoxData[
  TemplateBox[{"1"},
   "Ket"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "b62b67db-78db-4256-90cd-697a1454a36a"],
 " even though the same unsigned ",
 Cell[BoxData[
  StyleBox["Z", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "766ebdf9-732c-437d-8547-21ffa5784c4f"],
 " pins both."
}], "Text",ExpressionUUID->"1a8fb444-b7a3-48c3-ae33-97a2f9e22036"],

Cell[TextData[{
 "A short word of honesty about what the tableau leaves out. The tableau \
tracks the stabilizer group, including the signs, but it is blind to the ",
 StyleBox["overall", "TI"],
 " phase of the state. Reconstructing a state vector from a gate-updated \
tableau is therefore exact only up to a global phase. You can see this by \
acting with ",
 Cell[BoxData[
  StyleBox["Z", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "3941e4a9-f107-46b0-b589-54258aea6ded"],
 " on ",
 Cell[BoxData[
  TemplateBox[{"+"},
   "Ket"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "d711b343-ab61-4c40-adac-ba8efd8a6769"],
 ": physically ",
 Cell[BoxData[
  RowBox[{
   RowBox[{
    StyleBox["Z", "TI"], 
    TemplateBox[{"+"},
     "Ket"]}], "=", 
   TemplateBox[{"-"},
    "Ket"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "c2eaae69-c69d-4e56-bbd2-37a15a23d8fb"],
 ", and the framework returns ",
 Cell[BoxData[
  TemplateBox[{"-"},
   "Ket"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "ab6617d8-c835-4a4c-a25d-9109353d6729"],
 " up to an overall sign."
}], "Text",ExpressionUUID->"cc6d65a6-dc96-4e2a-a47c-33cd6a69c860"],

