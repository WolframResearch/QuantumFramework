Cell[TextData[{
 "The generators ",
 Cell[BoxData[
  StyleBox[
   RowBox[{"X", "X"}], "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "ba45d04c-1a21-474e-a535-e220d6ed4161"],
 " and ",
 Cell[BoxData[
  StyleBox[
   RowBox[{"Z", "Z"}], "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "7817bbab-e1b1-4363-9b43-87364c87239c"],
 " are the familiar parity checks: the two qubits share an ",
 Cell[BoxData[
  StyleBox["X", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "c62ecc2e-700f-4701-ad6c-eaa5f8193772"],
 "-parity and a ",
 Cell[BoxData[
  StyleBox["Z", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "d8ea69cd-2c37-4eff-96d4-ce15f67d2027"],
 "-parity, which is precisely what maximal entanglement looks like here. The \
state vector is the textbook one:"
}], "Text",ExpressionUUID->"9c0790a6-e38e-4ff2-ab12-49d9ceb636d8"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{
