Cell[TextData[{
 "Its five generators are four weight-four checks plus the logical ",
 Cell[BoxData[
  OverscriptBox[
   StyleBox["Z", "TI"], "_"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "bf6d0f7c-6891-4a2b-9be5-e57c5c4b3607"],
 ":"
}], "Text",ExpressionUUID->"d9f46f7a-8267-41d5-9440-b5ffc6290ec7"],

