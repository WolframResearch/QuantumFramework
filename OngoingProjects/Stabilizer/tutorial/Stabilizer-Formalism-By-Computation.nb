 CellLabel->
  "Out[81]= ",ExpressionUUID->"7ce757d2-3864-4021-8a89-f5b2d23cfef8"]
}, Open  ]],

Cell[TextData[{
 "The four cyclic permutations ",
 Cell[BoxData[
  RowBox[{
   StyleBox[
    RowBox[{"X", "Z", "Z", "X", "I"}], "TI"], ",", 
   StyleBox[
    RowBox[{"I", "X", "Z", "Z", "X"}], "TI"], ",", 
   StyleBox[
    RowBox[{"X", "I", "X", "Z", "Z"}], "TI"], ",", 
   StyleBox[
    RowBox[{"Z", "X", "I", "X", "Z"}], "TI"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "fef977f4-5056-49a8-86df-56c72c5e8b82"],
 " are the parity checks; the last generator ",
 Cell[BoxData[
  StyleBox[
   RowBox[{"Z", "Z", "Z", "Z", "Z"}], "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "32d9da49-0b55-4204-9cae-70770e4a6461"],
 " is the logical ",
 Cell[BoxData[
  OverscriptBox[
   StyleBox["Z", "TI"], "_"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "b6c45b85-1bfb-473f-8f03-a6188f4d88b4"],
 ", which fixes ",
 Cell[BoxData[
  TemplateBox[{
    SubscriptBox["0", 
     StyleBox["L", "TI"]]},
   "Ket"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "a8c52b10-c1f1-4100-bff0-9ba1bfb1a28a"],
 " inside the code space. Keep the checks alone:"
}], "Text",ExpressionUUID->"386989fa-467f-4b44-963c-d3a0b7a97493"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"checks", " ", "=", " ", 
  RowBox[{"Most", "[", 
   RowBox[{"code", "[", "\"\<Stabilizers\>\"", "]"}], "]"}]}]], "Input",
 CellLabel->
  "In[82]:= ",ExpressionUUID->"4378f273-80e8-4bfd-a2ba-f22b12e152f5"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"\<\"XZZXI\"\>", ",", "\<\"IXZZX\"\>", ",", "\<\"XIXZZ\"\>", 
   ",", "\<\"ZXIXZ\"\>"}], "}"}]], "Output",
 CellLabel->
  "Out[82]= ",ExpressionUUID->"5939649f-1676-4d81-a479-9c9f4bc2d825"]
}, Open  ]],

Cell[TextData[{
 "A list of four operators is worth only what it can diagnose, and this is \
where the formalism earns its keep. The clean codeword is a ",
 Cell[BoxData[
  RowBox[{"+", "1"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "d6c25348-9e22-4c8c-a10c-6c9f715e790f"],
 " eigenstate of every check, so the four checks all read ",
 Cell[BoxData[
  RowBox[{"+", "1"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "481816c5-3f34-4925-94eb-f27f770c30e1"],
 ". A single-qubit error ",
 Cell[BoxData[
  StyleBox["E", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "ea2f9b3f-68af-4ba2-ae2a-3b09bfe235ad"],
 " commutes or anticommutes with each check, and wherever it anticommutes it \
flips that reading to ",
 Cell[BoxData[
  RowBox[{"-", "1"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "d63f81c7-939c-4ac4-a1c5-1f1611bfb85f"],
 ". The pattern of flips is the ",
 StyleBox["syndrome", "TI"],
 ": a four-bit string, ",
 Cell[BoxData["0"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "29e5a0d7-2fd0-48c3-a428-fa54940fddf7"],
 " for an undisturbed check and ",
 Cell[BoxData["1"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "63485e03-d6f2-484e-a456-f66f26435b70"],
 " for a flipped one."
}], "Text",ExpressionUUID->"ad2c13f4-f5db-4092-9929-e733517eb4e7"],

Cell[BoxData[
 RowBox[{
  RowBox[{"syndrome", "[", "err_", "]"}], " ", ":=", " ", 
  RowBox[{
   RowBox[{"(", 
    RowBox[{"1", " ", "-", " ", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{"code", "[", "err", "]"}], "[", 
         RowBox[{"\"\<Expectation\>\"", ",", " ", "#"}], "]"}], " ", "&"}], 
       " ", "/@", " ", "checks"}], ")"}]}], ")"}], " ", "/", " ", 
   "2"}]}]], "Input",
 CellLabel->
  "In[83]:= ",ExpressionUUID->"ac4820f9-b54d-4334-9c3d-c471f8a0b010"],

Cell["\<\
A bit-flip on qubit 2 anticommutes with the first check alone:\
\>", "Text",ExpressionUUID->"9704d759-be06-46d6-b4ae-56f5a25d379b"],

