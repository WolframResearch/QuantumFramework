Cell[TextData[{
 "Its five generators are four weight-four checks plus the logical ",
 Cell[BoxData[
  OverscriptBox[
   StyleBox["Z", "TI"], "_"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "cde78367-263e-4aba-a1ce-d12389794526"],
 ":"
}], "Text",ExpressionUUID->"08af11ef-96a3-432e-8e76-62a6ac113e4f"],

