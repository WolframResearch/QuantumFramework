Cell[TextData[{
 "Different states are fixed by different operators. The state ",
 Cell[BoxData[
  RowBox[{
   TemplateBox[{"+"},
    "Ket"], "=", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{
      TemplateBox[{"0"},
       "Ket"], "+", 
      TemplateBox[{"1"},
       "Ket"]}], ")"}], "/", 
    SqrtBox["2"]}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "63b0efc8-5904-4ece-9c36-8eb7b9db0e50"],
 " is the ",
 Cell[BoxData[
  RowBox[{"+", "1"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "ec0ce464-339a-4dc4-b769-ec4f4dbeb359"],
 " eigenstate of ",
 Cell[BoxData[
  StyleBox["X", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "78f6c404-ce6e-4d07-b8d3-719abf06d5b5"],
 ", and a Hadamard turns one into the other. Apply ",
 Cell[BoxData[
  StyleBox["H", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "0cf9c27d-c069-4cda-8405-743fa227d42e"],
 " to ",
 Cell[BoxData[
  TemplateBox[{"0"},
   "Ket"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "69d5de1e-57bd-4c4b-945c-223a1d0ea324"],
 " and read the new stabilizer:"
}], "Text",ExpressionUUID->"ea8981b5-c1a2-45f5-ad76-38fbda7c41a2"],

