Cell["\<\
Its amplitudes are the answer the formalism has to reproduce:\
\>", "Text",ExpressionUUID->"21aecba4-7954-4b2b-ba2f-b1d72b8e7e3b"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"psiSchrodinger", "[", "\"\<StateVector\>\"", "]"}], " ", "//", " ",
   "Normal"}]], "Input",
 CellLabel->
  "In[33]:= ",ExpressionUUID->"3e56dc5e-1581-45d6-b268-d769723515cc"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   FractionBox["1", 
    SqrtBox["2"]], ",", "0", ",", "0", ",", "0", ",", "0", ",", "0", ",", "0",
    ",", 
   FractionBox["\[ImaginaryI]", 
    SqrtBox["2"]]}], "}"}]], "Output",
 CellLabel->
  "Out[33]= ",ExpressionUUID->"2ea8ab06-01fa-47ff-ae9d-41eeff3e2d65"]
}, Open  ]],

Cell[TextData[{
 "The state is ",
 Cell[BoxData[
  RowBox[{
   RowBox[{"(", 
    RowBox[{
     TemplateBox[{"000"},
      "Ket"], "+", 
     RowBox[{
      StyleBox["i", "TI"], 
      TemplateBox[{"111"},
       "Ket"]}]}], ")"}], "/", 
   SqrtBox["2"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "34e9a698-d90a-4194-8f77-770beef6c142"],
 ", a GHZ-type state carrying the relative phase the ",
 Cell[BoxData[
  StyleBox["S", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "397979fe-3e98-4e75-b56c-9c54a714e18e"],
 " gate inserted."
}], "Text",ExpressionUUID->"3b7876a6-795f-4824-97be-23b31fc1eb5b"],

Cell[TextData[{
 "Now the Heisenberg picture. Instead of asking where the state goes, ask \
what fixes it. If ",
 Cell[BoxData[
  StyleBox["g", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "e649b544-daff-471d-8752-99d93969d43e"],
 " stabilizes ",
 Cell[BoxData[
  TemplateBox[{
    StyleBox["\[Psi]", "TI"]},
   "Ket"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "436e8f2f-7fc3-4f82-9edc-f725a0f3b4be"],
 ", then after a gate ",
 Cell[BoxData[
  StyleBox["U", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "cf9c5534-05d2-4518-82fc-44925481a873"],
 " the conjugated operator ",
 Cell[BoxData[
  RowBox[{
   StyleBox["U", "TI"], 
   StyleBox["g", "TI"], 
   SuperscriptBox[
    StyleBox["U", "TI"], "\[Dagger]"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "c0042387-4888-4df8-9b6c-3cea01589498"],
 " stabilizes ",
 Cell[BoxData[
  RowBox[{
   StyleBox["U", "TI"], 
   TemplateBox[{
     StyleBox["\[Psi]", "TI"]},
    "Ket"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "1a763f45-f65e-4b7c-9370-e548030b1325"],
 ", because ",
 Cell[BoxData[
  RowBox[{
   RowBox[{
    StyleBox["g", "TI"], 
    TemplateBox[{
      StyleBox["\[Psi]", "TI"]},
     "Ket"]}], "=", 
   TemplateBox[{
     StyleBox["\[Psi]", "TI"]},
    "Ket"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "6f4d97fb-d0db-4865-abc2-98025d8b111e"],
 " gives ",
 Cell[BoxData[
  RowBox[{
   RowBox[{
    RowBox[{
     StyleBox["(",
      SpanMaxSize->1], 
     RowBox[{
      StyleBox["U", "TI"], 
      StyleBox["g", "TI"], 
      SuperscriptBox[
       StyleBox["U", "TI"], "\[Dagger]"]}], 
     StyleBox[")",
      SpanMaxSize->1]}], 
    StyleBox["U", "TI"], 
    TemplateBox[{
      StyleBox["\[Psi]", "TI"]},
     "Ket"]}], "=", 
   RowBox[{
    RowBox[{
     StyleBox["U", "TI"], 
     StyleBox["g", "TI"], 
     TemplateBox[{
       StyleBox["\[Psi]", "TI"]},
      "Ket"]}], "=", 
    RowBox[{
     StyleBox["U", "TI"], 
     TemplateBox[{
       StyleBox["\[Psi]", "TI"]},
      "Ket"]}]}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "3d7c0dd6-099f-49a7-a736-5f6cb2635c34"],
 ". The whole evolution of the state is therefore carried by the conjugation ",
 Cell[BoxData[
  RowBox[{
   StyleBox["g", "TI"], "\[Function]", 
   StyleBox["U", "TI"], 
   StyleBox["g", "TI"], 
   SuperscriptBox[
    StyleBox["U", "TI"], "\[Dagger]"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "b55cb980-7838-4108-817c-56a3e1a06724"],
 " of its generators, and the one fact that makes this cheap is that a \
Clifford sends a Pauli to a Pauli. Take the input generator ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["Z", "TI"], "1"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "96796844-4984-4bc6-b50e-5950b0ca096b"],
 " and conjugate it by the circuit, ",
 Cell[BoxData[
  RowBox[{
   StyleBox["U", "TI"], " ", 
   SubscriptBox[
    StyleBox["Z", "TI"], "1"], " ", 
   SuperscriptBox[
    StyleBox["U", "TI"], "\[Dagger]"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "3342c1fe-0607-40c0-a6ca-b06f1f9638b1"],
 ". Writing that conjugation as a circuit that applies ",
 Cell[BoxData[
  SuperscriptBox[
   StyleBox["U", "TI"], "\[Dagger]"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "e9567244-644e-4660-866f-f64222042d1d"],
 ", then ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["Z", "TI"], "1"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "48c7e440-b5ed-46ea-b4cc-ecd0fbf4c027"],
 ", then ",
 Cell[BoxData[
  StyleBox["U", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "4db32661-5815-40f2-a4ed-a6b3d08b12f9"],
 ", ",
 Cell[BoxData["\"\<PauliDecompose\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "df9ead57-26d0-4c5e-a187-7f3fd255f427"],
 " reads off the result:"
}], "Text",ExpressionUUID->"fb5f876c-4b9c-4428-9ac3-ac9445421bed"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"QuantumCircuitOperator", "[", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"cliffordCircuit", "[", "\"\<Dagger\>\"", "]"}], ",", " ", 
     RowBox[{"\"\<Z\>\"", " ", "->", " ", "1"}], ",", " ", 
     "cliffordCircuit"}], "}"}], "]"}], "[", "\"\<PauliDecompose\>\"", 
  "]"}]], "Input",
 CellLabel->
  "In[34]:= ",ExpressionUUID->"49946d1a-13f4-430d-9e22-fe55cd62521a"],

Cell[BoxData[
 RowBox[{"\[LeftAssociation]", 
  RowBox[{"\<\"XYX\"\>", "\[Rule]", "1"}], "\[RightAssociation]"}]], "Output",\

 CellLabel->
  "Out[34]= ",ExpressionUUID->"685f5f63-782c-4a0b-bea3-66fde38be532"]
}, Open  ]],

Cell[TextData[{
 "The decomposition has a single term, ",
 Cell[BoxData[
  RowBox[{
   SubscriptBox[
    StyleBox["X", "TI"], "1"], 
   SubscriptBox[
    StyleBox["Y", "TI"], "2"], 
   SubscriptBox[
    StyleBox["X", "TI"], "3"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "e03d29f1-bdd4-47a1-81dc-24d1a41c2814"],
 ": the operator never left the Pauli group. One generator went in, one came \
out. That closure is why each tableau update is a fixed local rewrite of a \
few bits rather than a dense matrix multiply."
}], "Text",ExpressionUUID->"bf504f7b-4e02-46f5-8ce0-5591129a78bb"],

Cell[TextData[{
 "Propagating all three input generators ",
 Cell[BoxData[
  RowBox[{
   SubscriptBox[
    StyleBox["Z", "TI"], "1"], ",", 
   SubscriptBox[
    StyleBox["Z", "TI"], "2"], ",", 
   SubscriptBox[
    StyleBox["Z", "TI"], "3"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "8cea5099-bcc9-4dcf-8b47-5db9859bba5f"],
 " this way is exactly what the stabilizer backend does. Running the ",
 StyleBox["same circuit object", "TI"],
 " with ",
 Cell[BoxData[
  RowBox[{"Method", " ", "->", " ", "\"\<Stabilizer\>\""}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "bda2ab64-2625-49c1-8d03-165ef08e2757"],
 " in place of ",
 Cell[BoxData["\"\<Schrodinger\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "2e089150-dd1c-4e9b-9bdb-95a440e318d5"],
 " returns the stabilizer group of the final state, whose first generator is \
the ",
 Cell[BoxData[
  RowBox[{
   SubscriptBox[
    StyleBox["X", "TI"], "1"], 
   SubscriptBox[
    StyleBox["Y", "TI"], "2"], 
   SubscriptBox[
    StyleBox["X", "TI"], "3"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "6fbf3700-7adb-4eef-b4dd-1ea569b0f72f"],
 " we just conjugated by hand:"
}], "Text",ExpressionUUID->"bcf20175-1d7c-4850-a8df-29cc8d7bcb21"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"cliffordCircuit", "[", 
   RowBox[{
    RowBox[{"QuantumState", "[", "\"\<000\>\"", "]"}], ",", " ", 
