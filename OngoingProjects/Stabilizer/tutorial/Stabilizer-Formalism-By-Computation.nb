                 TagBox["\"Edges: \"", "SummaryItemAnnotation"], 
                 "\[InvisibleSpace]", 
                 TagBox["4", "SummaryItem"]}]}, {
               RowBox[{
                 TagBox["\"Graph: \"", "SummaryItemAnnotation"], 
                 "\[InvisibleSpace]", 
                 TagBox[
                  GraphicsBox[
                   NamespaceBox["NetworkGraphics", 
                    DynamicModuleBox[{Typeset`graph = HoldComplete[
                    Graph[{1, 2, 3, 4}, {Null, 
                    SparseArray[
                    Automatic, {4, 4}, 0, {
                    1, {{0, 2, 4, 6, 8}, {{2}, {4}, {1}, {3}, {2}, {4}, {1}, {
                    3}}}, Pattern}]}, {GraphLayout -> "CircularEmbedding"}]]}, 
                    TagBox[
                    GraphicsGroupBox[
                    
                    GraphicsComplexBox[{{-1., 
                    1.0106430996148606`*^-15}, {-7.044813998280222*^-16, 
