Cell[TextData[{
 "What comes back is a rank-one phase-polynomial frame, not a list of ",
 Cell[BoxData[
  SuperscriptBox["2", "20"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "9dbcde28-e4c3-486a-a3d3-06a3b0b7807e"],
 " amplitudes. A single amplitude of this twenty-qubit magic state, where the \
dense vector would need over a million entries, returns exactly and \
essentially instantly:"
}], "Text",ExpressionUUID->"f3b9c4c3-53c4-4ac5-a9ff-5b8390883f02"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"AbsoluteTiming", "[", 
  RowBox[{"pp", "[", 
   RowBox[{"\"\<Amplitude\>\"", ",", " ", 
    RowBox[{"PadRight", "[", 
     RowBox[{
      RowBox[{"{", "1", "}"}], ",", " ", "20"}], "]"}]}], "]"}], 
  "]"}]], "Input",
 CellLabel->
  "In[105]:= ",ExpressionUUID->"654fbc5b-96fa-4f6a-92a2-3efe122981ba"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"0.000175`", ",", 
   FractionBox[
    SuperscriptBox["\[ExponentialE]", 
     FractionBox[
      RowBox[{"\[ImaginaryI]", " ", "\[Pi]"}], "4"]], "1024"]}], 
  "}"}]], "Output",
 CellLabel->
  "Out[105]= ",ExpressionUUID->"a32955fb-e062-4f85-adf7-f667b176f4b2"]
}, Open  ]],

Cell[TextData[{
 "The amplitude is ",
 Cell[BoxData[
  RowBox[{
   SuperscriptBox[
    StyleBox["e", "TI"], 
    RowBox[{
     StyleBox["i", "TI"], "\[Pi]", "/", "4"}]], "/", "1024"}]], 
  "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "192c0357-adb4-41ac-a657-4d475502a3c2"],
 ": magnitude ",
 Cell[BoxData[
  RowBox[{
   SuperscriptBox["2", 
    RowBox[{"-", 
     StyleBox["n", "TI"], "/", "2"}]], "=", 
   SuperscriptBox["2", 
    RowBox[{"-", "10"}]]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "9a239f1e-16b1-4fd2-8817-a136159408c0"],
 " like every amplitude of a flat superposition, carrying the very eighth \
root of unity ",
 Cell[BoxData[
  SuperscriptBox[
   StyleBox["e", "TI"], 
   RowBox[{
    StyleBox["i", "TI"], "\[Pi]", "/", "4"}]]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "f6cf5fc0-67a7-45ce-97ba-7651cc4b9627"],
 " we met in ",
 Cell[BoxData[
  TemplateBox[{
    StyleBox["T", "TI"]},
   "Ket"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "7c10f4ce-907d-497b-98d8-0a5d4eee29ce"],
 ", the signature the diagonal magic wrote into it. The cost is one linear \
solve, independent of ",
 Cell[BoxData[
  StyleBox["n", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "a89a6223-f764-4b91-a0be-0d8f1a0ab09e"],
 ", so the same call answers at fifty or a hundred qubits where no dense \
method runs. The fragment is narrow: an interior Hadamard takes the circuit \
out of it, and the backend then ",
 StyleBox["silently", "TI"],
 " falls back to the ordinary stabilizer path, which evolves ",
 Cell[BoxData[
  SuperscriptBox[
   TemplateBox[{"0"},
    "Ket"], 
   RowBox[{"\[CircleTimes]", 
    StyleBox["n", "TI"]}]]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "46edbf1b-b9e6-4647-b404-34bca654c3d0"],
 " rather than the ",
 Cell[BoxData[
  SuperscriptBox[
   TemplateBox[{"+"},
    "Ket"], 
   RowBox[{"\[CircleTimes]", 
    StyleBox["n", "TI"]}]]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "44186f7b-96d2-47a4-9351-5d0e1bf7ec12"],
 " the phase polynomial assumes. So ",
 Cell[BoxData[
  RowBox[{"\"\<Compress\>\"", " ", "->", " ", "\"\<PhasePolynomial\>\""}]], 
  "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "96936d75-935d-4bf5-85fa-fefaba9b754b"],
 " is a deliberate opt-in for diagonal circuits, not a universal method; \
inside the fragment, the magic is free."
}], "Text",ExpressionUUID->"fce8a103-8d32-45e8-b693-13c230dda63a"],

Cell[TextData[{
 "The honest boundary has moved. The frame is now a ",
 StyleBox["calculator", "TI"],
 ", not only a record: it answers Pauli expectations and amplitudes from its \
components at a cost set by the rank, compresses away redundant terms, and on \
the diagonal fragment collapses to a rank-one closed form flat in ",
 Cell[BoxData[
  StyleBox["n", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "98fb8805-44a7-45e0-9e5b-2e74965643e4"],
 ". Two limitations remain, both under active work. First, ",
 Cell[BoxData["\"\<Compress\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "a4e1caa7-6435-4257-8b2a-4e15fe7e7396"],
 " caps the ",
 StyleBox["span", "TI"],
 " dimension, not the true stabilizer rank; the Bravyi-Gosset ",
 Cell[BoxData[
  SuperscriptBox["2", 
   StyleBox[
    RowBox[{"\[Alpha]", "t"}], "TI"]]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "25f424ba-11f5-4216-8964-f447c53eba73"],
 " compression that merges terms no basis can separate is still the harder, \
open target, so the frame is exact for a moderate number of ",
 Cell[BoxData[
  StyleBox["T", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "260a542e-95bc-49a5-b5d1-7752c053a3dd"],
 " gates rather than a scalable magic simulator. Second, a single gate-built \
frame's state and observables are exact up to one global phase, but the ",
 StyleBox["relative", "TI"],
 " phase between two separately built frames is fixed only up to a gauge, so \
an inner product across distinct gauges recovers the magnitude exactly and \
the phase up to that ambiguity. Within those bounds the frame crosses the \
Clifford boundary and computes there, which is exactly what the bare tableau \
cannot do."
}], "Text",ExpressionUUID->"f74ba61a-9738-4036-a3cd-cedf60b253b5"],

Cell["Clifford channels", "Subsection",ExpressionUUID->"a359f192-ce7e-4794-84b7-c0fae793d3c7"],

Cell[TextData[{
 "Open-system Clifford dynamics, the maps that send stabilizer states to \
stabilizer states, are encoded by a Boolean Choi tableau in the framework's \
",
 Cell[BoxData["CliffordChannel"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "7438bbba-f2a0-4abe-9745-dd45ea6ef2da"],
 ", following Yashin. The identity channel on ",
 Cell[BoxData[
  StyleBox["n", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "a919b3c3-3382-4240-b7a2-55ca7957effe"],
 " qubits has a tableau of ",
 Cell[BoxData[
  RowBox[{"2", 
   StyleBox["n", "TI"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "60493c92-72ee-4eec-b8c0-9a2ec6c8cd37"],
 " rows:"
}], "Text",ExpressionUUID->"333b5bca-60a7-414d-a4e8-a17f32361acc"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"CliffordChannel", "[", 
   RowBox[{"\"\<Identity\>\"", ",", " ", "3"}], "]"}], "[", "\"\<Rank\>\"", 
  "]"}]], "Input",
 CellLabel->
  "In[106]:= ",ExpressionUUID->"7bb95d45-77a1-4490-8992-45cb9594e159"],

Cell[BoxData["6"], "Output",
 CellLabel->
  "Out[106]= ",ExpressionUUID->"bb6e3592-51c2-4776-bbec-a7c007ac32e9"]
}, Open  ]],

Cell["\<\
A pure stabilizer state is itself a state-preparation Clifford channel, whose \
tableau is the state's stabilizer half. Converting the Bell state to its \
channel recovers its two parity-check rows:\
\>", "Text",ExpressionUUID->"9a863d65-c308-4034-a065-82c8c95d5ccf"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"CliffordChannel", "[", 
    RowBox[{
     RowBox[{"PauliStabilizer", "[", "2", "]"}], "[", 
     RowBox[{"{", 
      RowBox[{"\"\<H\>\"", ",", " ", "\"\<CNOT\>\""}], "}"}], "]"}], "]"}], 
   "[", "\"\<Tableau\>\"", "]"}], " ", "//", " ", "MatrixForm"}]], "Input",
 CellLabel->
  "In[107]:= ",ExpressionUUID->"7456bc1b-9851-405f-9858-7ee6d9c1f7f4"],

Cell[BoxData[
 TagBox[
  RowBox[{"(", "\[NoBreak]", GridBox[{
     {"1", "1", "0", "0", "0"},
     {"0", "0", "1", "1", "0"}
    },
    GridBoxAlignment->{"Columns" -> {{Center}}, "Rows" -> {{Baseline}}},
    GridBoxSpacings->{"Columns" -> {
        Offset[0.27999999999999997`], {
         Offset[0.7]}, 
        Offset[0.27999999999999997`]}, "Rows" -> {
        Offset[0.2], {
         Offset[0.4]}, 
        Offset[0.2]}}], "\[NoBreak]", ")"}],
  Function[BoxForm`e$, 
   MatrixForm[BoxForm`e$]]]], "Output",
 CellLabel->
  "Out[107]= ",ExpressionUUID->"8db5b92b-0866-4bda-9760-0f905f2bf1c2"]
}, Open  ]],

Cell[TextData[{
 "Noise stays in the tableau too. A named Pauli channel applied to a \
stabilizer state returns a probability-weighted mixture of stabilizer states, \
each branch an ",
 Cell[BoxData[
  RowBox[{
   StyleBox["O", "TI"], 
   StyleBox["(",
    SpanMaxSize->1], 
   StyleBox["n", "TI"], 
   StyleBox[")",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "6114e2b4-3a78-4442-8ac0-a8432f6f4f92"],
 " tableau update rather than a dense density matrix. A bit-flip channel on \
",
 Cell[BoxData[
  TemplateBox[{"0"},
   "Ket"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "e1a6bf25-ea97-403c-8ec9-9b1495342113"],
 " is the textbook example, ",
 Cell[BoxData[
  TemplateBox[{"0"},
   "Ket"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "dba9155c-baca-408c-97c5-dbe501a2b3ea"],
 " with probability ",
 Cell[BoxData[
  RowBox[{"1", "-", 
   StyleBox["p", "TI"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "c82281d2-101c-4f8e-8fe1-63be5a7989a0"],
 " and ",
 Cell[BoxData[
  TemplateBox[{"1"},
   "Ket"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "84983372-4807-452f-9c50-24dda151eff7"],
 " with probability ",
 Cell[BoxData[
  StyleBox["p", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "60174ddc-c7c2-49e8-86f1-469e7301a2fe"],
 ":"
}], "Text",ExpressionUUID->"1af0739c-c303-444a-9137-0f110c784640"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"{", 
    RowBox[{"#1", ",", " ", 
     RowBox[{"#2", "[", "\"\<Stabilizers\>\"", "]"}]}], "}"}], " ", "&"}], 
  " ", "@@@", " ", 
  RowBox[{
   RowBox[{"QuantumChannel", "[", 
    RowBox[{"\"\<BitFlip\>\"", "[", 
     RowBox[{"1", "/", "10"}], "]"}], "]"}], "[", 
   RowBox[{"PauliStabilizer", "[", "1", "]"}], "]"}]}]], "Input",
 CellLabel->
  "In[108]:= ",ExpressionUUID->"0a1b5d7b-9db1-4a3a-8803-467d6e015cb4"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     FractionBox["9", "10"], ",", 
     RowBox[{"{", "\<\"Z\"\>", "}"}]}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{
     FractionBox["1", "10"], ",", 
     RowBox[{"{", "\<\"-Z\"\>", "}"}]}], "}"}]}], "}"}]], "Output",
 CellLabel->
  "Out[108]= ",ExpressionUUID->"51303499-a59a-49d6-8589-a49b117b31dc"]
}, Open  ]],

Cell[TextData[{
 "The two branches are stabilized by ",
 Cell[BoxData[
  RowBox[{"+", 
   StyleBox["Z", "TI"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "f210972e-78be-4e23-a71b-4209c92cb8c0"],
 " and ",
 Cell[BoxData[
  RowBox[{"-", 
   StyleBox["Z", "TI"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "b11dd6a7-49a9-42ea-9b7e-922a5d8c5929"],
 ", the ",
 Cell[BoxData[
  TemplateBox[{"0"},
   "Ket"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "629e4dae-7b15-443b-a542-51cd850aaeb5"],
 " and ",
 Cell[BoxData[
  TemplateBox[{"1"},
   "Ket"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "498922db-74ff-4569-b526-9661888834cc"],
 " of a classical bit flip, with weights ",
 Cell[BoxData[
  RowBox[{"9", "/", "10"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "1896add8-f428-4709-8480-821039abff17"],
 " and ",
 Cell[BoxData[
  RowBox[{"1", "/", "10"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "137ee08a-ebc2-4fcc-990b-268211511f74"],
 "."
}], "Text",ExpressionUUID->"ab2185a0-b6fb-4882-b4eb-66975f233f70"],

Cell[TextData[{
 "These heads, together with ",
 Cell[BoxData["PauliStabilizer"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "45dfa7f1-1932-4f29-8840-a3cdbb145e0e"],
 " and ",
 Cell[BoxData["StabilizerFrame"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "34cf82ec-b185-4acf-9937-8dca142fae56"],
 ", let one stay in the tableau picture for states, codes, graph-state \
surgery, magic accounting, and noise, inside the same object model as the \
rest of the framework."
}], "Text",ExpressionUUID->"ad20ceaf-ac30-4efe-a9be-9645f90bb5ac"],

Cell["An honest comparison with other packages", "Section",ExpressionUUID->"8abbc72c-a781-4819-9740-cf5a8ab2cf9b"],

Cell["\<\
The stabilizer simulators built for raw throughput are Stim, a C++ engine, \
and QuantumClifford.jl, a Julia package; both are excellent and both are \
narrower in scope than a general quantum framework. The fair question is \
two-sided: how close is the framework on the task they specialize in, and \
what does it offer that they do not.\
\>", "Text",ExpressionUUID->"2eb32080-4128-4f7f-bfc1-f4b732b9e8a2"],

Cell["\<\
On gate-folding throughput the gap is now a small constant factor. The \
figures here are the measured wall-clock for an identical Clifford stream on \
an Apple M2 Pro, measured June 2026 from the framework's own bottleneck \
audit, with Stim for reference; treat them as a dated snapshot, not a \
guarantee:\
\>", "Text",ExpressionUUID->"4852e7a9-0bf6-48a8-83cc-031f3876818b"],

Cell[BoxData[GridBox[{
   {Cell["qubits (gates)", "TableText",
     FontWeight->Bold,ExpressionUUID->"a68eea30-ebb5-435e-a329-eeab20da0376"],
     Cell["QuantumFramework", "TableText",
     FontWeight->Bold,ExpressionUUID->"dfd30e10-8f26-47e8-9563-40beed7ef61e"],
     Cell["Stim", "TableText",
     FontWeight->Bold,ExpressionUUID->"c0425d19-90d2-43c9-8cdf-09b639f5b3cb"],
     Cell["ratio", "TableText",
     FontWeight->Bold,ExpressionUUID->"b58a10cf-139b-43ea-b164-6c1362a5f733"]},
   {Cell["100 (2k)", "TableText",ExpressionUUID->
     "43bcbe35-3f71-4c87-93bd-6dbe277bb0ae"], Cell[
    "2.6 ms", "TableText",ExpressionUUID->
     "185f5ed1-2245-4740-a86c-e10ab89deb3c"], Cell[
    "1.03 ms", "TableText",ExpressionUUID->
     "9c6d4169-98bf-438d-bc7b-3fc7f0e760e9"], Cell[
    "2.5x", "TableText",ExpressionUUID->
     "68450702-d5da-4d28-854a-5be158ba99b1"]},
   {Cell["500 (10k)", "TableText",ExpressionUUID->
     "c2228d3d-5a24-46fe-b035-ea7e95702210"], Cell[
    "26.2 ms", "TableText",ExpressionUUID->
     "a74ffe29-95a9-442e-8007-567750bbcc20"], Cell[
    "5.14 ms", "TableText",ExpressionUUID->
     "211991bd-21d8-4fdb-94c8-95e70d2e615e"], Cell[
    "5.1x", "TableText",ExpressionUUID->
     "f91f6320-5fd3-41b1-8567-16439c36eee1"]},
   {Cell["1000 (20k)", "TableText",ExpressionUUID->
     "26dc9afc-6fc7-4352-bec7-1aac976e20f5"], Cell[
    "58.0 ms", "TableText",ExpressionUUID->
     "9744804d-393c-4d84-b7e4-144db19f91d6"], Cell[
    "10.9 ms", "TableText",ExpressionUUID->
     "5d683e83-041c-44af-9f87-83531e8e14f5"], Cell[
    "5.3x", "TableText",ExpressionUUID->
     "49a48b92-04fe-417f-9b19-eef4b4eb008a"]}
  },
  GridBoxAlignment->{"Columns" -> {{Left}}, "Rows" -> {{Baseline}}},
  GridBoxDividers->{"Columns" -> {{None}}, "Rows" -> {{True}}},
  GridBoxSpacings->{"Columns" -> {{1.5}}, "Rows" -> {{0.7}}}]], "Text",Express\
ionUUID->"042665f2-c4a4-4ade-b3b8-60210c092c3b"],

Cell["\<\
At a thousand qubits the framework also runs ahead of QuantumClifford.jl on \
the same stream (58.0 ms against 108.4 ms). The remaining gap to Stim is SIMD \
lane width, Stim packs 256-bit vector lanes against the framework's 62-bit \
machine words, plus a small per-gate circuit-encoding pass; it is a constant \
factor, not an algorithmic deficit. Getting there took compiling the gate \
fold to a single C kernel: the gate-by-gate interpreted path is 15 to 30 \
times slower, around 74, 402, and 955 ms at 100, 500, and 1000 qubits.\
\>", "Text",ExpressionUUID->"0ea329a6-d40c-423c-bf57-562bcf977b4a"],

Cell["What the framework offers that the dedicated engines do not:", "Text",ExpressionUUID->"628f09ec-fa89-42ac-b16a-b0d4705dfc3f"],

Cell[TextData[{
 StyleBox["Symbolic signs", "TI"],
 ". Outcomes can be carried as formal symbols through a circuit (the SymPhase \
method), so a single traversal serves arbitrarily many samples and the \
correlations between outcomes come out as explicit polynomials; in the \
dedicated engines the same device propagates Pauli faults to syndromes, which \
is the sampling bottleneck the technique was built to break."
}], "Item",ExpressionUUID->"16c355ac-8b84-4435-8ba3-b56070e45976"],

Cell[TextData[{
 StyleBox["Exact arithmetic", "TI"],
 ". Coefficients, signs, and the random-Clifford sampler use exact rationals, \
so seeded output is bit-reproducible and there is no floating-point drift."
}], "Item",ExpressionUUID->"d3491e85-9c22-457a-a508-b4b62f2c0779"],

Cell[TextData[{
 StyleBox["One object model", "TI"],
 ". A ",
 Cell[BoxData["PauliStabilizer"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "1d393c06-db21-47bb-8307-03d8498c9939"],
 " converts to a ",
 Cell[BoxData["QuantumState"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "6eec6e7d-c7b2-4660-813e-3466b4da75f6"],
 ", a ",
 Cell[BoxData["QuantumOperator"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "8a8c76a3-8033-4079-a1d5-756551423209"],
 ", a ",
 Cell[BoxData["QuantumCircuitOperator"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "2d77c65f-0054-4fc0-b280-321b779a45f3"],
 ", or a ",
 Cell[BoxData["QuantumChannel"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "8b3c4e53-cbc3-4fbc-a7eb-4d0220e83286"],
 ", so a stabilizer subroutine drops into a larger simulation that also uses \
dense states, density matrices, Lindblad evolution, or phase-space methods, \
without leaving the language."
}], "Item",ExpressionUUID->"595cd595-ebea-40cf-9921-d36e16dba0ad"],

Cell[TextData[{
 StyleBox["Breadth of heads", "TI"],
 ". Graph states with local complementation, stabilizer frames for magic \
accounting, and Clifford channels for open-system Clifford dynamics are \
first-class objects, not features one bolts on."
}], "Item",ExpressionUUID->"2108e80f-cdb9-4a0a-9dc2-98f3a85201a2"],

Cell["Where the framework genuinely trails, stated plainly:", "Text",ExpressionUUID->"d37e8cbc-514a-4544-8a99-3bcc40ddc898"],

Cell[TextData[{
 "It is a constant factor (roughly ",
 Cell[BoxData["2.5"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "80ebd736-b74c-450e-808d-1c1dc24f0653"],
 " to ",
 Cell[BoxData[
  RowBox[{"5.3", "\[Times]"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "59221ef1-6847-45e5-b5ad-6fa70acc66bb"],
 ") behind Stim on pure gate throughput, because Stim packs wider SIMD \
lanes."
}], "Item",ExpressionUUID->"94b9ccf3-c869-4c7e-8604-16aa83c8184a"],

Cell["\<\
It has no constant-cost bulk Pauli-frame sampler, the trick that makes Stim's \
shot-by-shot sampling so cheap.\
\>", "Item",ExpressionUUID->"4ccc326d-a36e-4aa8-8114-0525bc1166c1"],

Cell[TextData[{
 "Constructing a ",
 Cell[BoxData["QuantumCircuitOperator"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "a1c5678c-9979-4ade-8665-400cc753b3c9"],
 " with ",
 Cell[BoxData[
  SuperscriptBox["10", "4"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "cdf86769-e987-4a64-98e6-65034589ef97"],
 " or more gates carries host-framework overhead; for long streams one should \
hand the gate-spec list to ",
 Cell[BoxData[
  RowBox[{"ps", "[", "gates", "]"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "dad856b8-413b-4895-baec-e7f206c2740b"],
 " directly."
}], "Item",ExpressionUUID->"1643b9d9-c792-479b-b4f7-b90cfb0c0145"],

Cell["\<\
Reconstructing an exact state vector from a gate-updated tableau, or from a \
gate-built stabilizer frame, is correct up to a single global phase, which is \
never observable; only the relative phase between two separately-built \
objects is gauge-limited.\
\>", "Item",ExpressionUUID->"a7648874-c085-4b2b-82cb-2a8bc1f24360"],

Cell["\<\
The summary is the one a physicist would want: for raw Clifford throughput \
the specialized engines are a few times faster, and if that is the only thing \
one needs, they are the right tool. For stabilizer simulation that has to \
interoperate with the rest of a quantum-mechanics toolkit, carry symbols, \
stay exact, and reach into codes, graph states, magic, and channels, the \
framework buys all of that for a small constant in speed.\
\>", "Text",ExpressionUUID->"3f55920e-31d1-49bd-9d8a-6dad8af0a251"],

Cell["Where this leaves us", "Section",ExpressionUUID->"831a8a60-3b67-4e7a-a57f-b6f1584daf3f"],

Cell[TextData[{
 "We built the stabilizer formalism from one idea, that a state is named by \
what fixes it, and rode it from a single qubit to a thousand. Along the way \
the concrete tools were: ",
 Cell[BoxData["PauliStabilizer"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "62dc331d-8fdc-4aa1-8f02-a5861b5b4e81"],
 " for states, codes, and the tableau; the gate-update methods and the \
circuit-list form ",
 Cell[BoxData[
  RowBox[{"ps", "[", "gates", "]"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "89ec6d8f-043f-4944-be0a-a7cdb0468567"],
 " for Clifford evolution; ",
 Cell[BoxData["\"\<M\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "6a8b939c-72da-48fc-bdad-5568308d00f4"],
 ", ",
 Cell[BoxData["\"\<Expectation\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "48c3b9c0-73be-4937-b8a6-97fee8298c43"],
 ", and ",
 Cell[BoxData["\"\<SymbolicMeasure\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "6f44dc07-462a-41fb-afd1-0ac1ffd404d0"],
 " for measurement; ",
 Cell[BoxData["\"\<Entropy\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "1d5d1cdf-5a0d-4820-bbf8-f5ed9344d191"],
 " for entanglement; ",
 Cell[BoxData[
  RowBox[{"PauliStabilizer", "[", 
   RowBox[{"\"\<Random\>\"", "[", "n", "]"}], "]"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "5a8fc909-8a22-4a07-9fae-39452ac7122b"],
 " for sampling; and ",
 Cell[BoxData["GraphState"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "94ad892d-d1ba-408c-91e3-e1d54606455d"],
 ", ",
 Cell[BoxData["StabilizerFrame"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "b1068cda-ee45-4868-b25d-6db62eb43c07"],
 ", and ",
 Cell[BoxData["CliffordChannel"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "d7450440-e097-47fe-b4f8-67c979f4175e"],
 " for the frontier."
}], "Text",ExpressionUUID->"331628d2-a0dc-4b9b-a59e-49e72043b196"],

Cell[TextData[{
 "The natural next steps are the ones the formalism opens onto: syndrome \
decoding on the codes of the error-correction section, stabilizer-rank \
simulation of magic-rich circuits via the frame, and Clifford-channel models \
of realistic noise. Each is a short extension of the computations in this \
document, and each stays, as long as it can, inside the ",
 Cell[BoxData[
  RowBox[{
   StyleBox["O", "TI"], 
   StyleBox["(",
    SpanMaxSize->1], 
   SuperscriptBox[
    StyleBox["n", "TI"], "2"], 
   StyleBox[")",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "39f0d75e-933c-470a-a6d7-366ec1afbc56"],
 " tableau that makes the whole subject tractable."
}], "Text",ExpressionUUID->"47e0109c-813a-4aa7-aad6-91e66d204250"],

Cell[TextData[{
 "The key references underpinning the implementation are ",
 ButtonBox["Gottesman's stabilizer-codes thesis (1997)",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://arxiv.org/abs/quant-ph/9705052"], None}],
 ", ",
 ButtonBox["Aaronson and Gottesman on the tableau and its measurement update \
(2004)",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://arxiv.org/abs/quant-ph/0406196"], None}],
 ", ",
 ButtonBox["Fattal and collaborators on stabilizer entanglement entropy \
(2004)",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://arxiv.org/abs/quant-ph/0406168"], None}],
 ", ",
 ButtonBox["Anders and Briegel on graph states and local complementation \
(2005)",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://arxiv.org/abs/quant-ph/0504117"], None}],
 ", ",
 ButtonBox["Koenig and Smolin on the random-Clifford sampler (2014)",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://arxiv.org/abs/1406.2170"], None}],
 ", ",
 ButtonBox["Garcia and Markov on stabilizer frames (2015)",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://arxiv.org/abs/1712.03554"], None}],
 ", ",
 ButtonBox["Fang and Ying on symbolic phases (2023)",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://arxiv.org/abs/2311.03906"], None}],
 ", and ",
 ButtonBox["Yashin on Clifford channels (2025)",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://arxiv.org/abs/2504.14101"], None}],
 "."
}], "Text",ExpressionUUID->"505b0547-2b87-4c31-9256-1e0b3aba9ddf"]
},
