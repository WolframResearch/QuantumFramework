   ",", "\<\"ZZZZZZZ\"\>"}], "}"}]], "Output",
 CellLabel->
  "Out[87]= ",ExpressionUUID->"a09de1e6-9c91-4e01-9c56-647648d57dc1"]
}, Open  ]],

Cell[TextData[{
 "The first three generators are pure ",
 Cell[BoxData[
  StyleBox["X", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "e5aefb04-1f08-4646-bc88-9f933f80f8b7"],
 " checks and the next three pure ",
 Cell[BoxData[
  StyleBox["Z", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "9e1bfa9d-8550-492e-ac6e-2c3ce4f9f5f7"],
 " checks, the defining CSS structure; the seventh is again the logical ",
 Cell[BoxData[
  OverscriptBox[
   StyleBox["Z", "TI"], "_"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "a3c2244f-a0de-4a20-a13a-b9d79b16e8a3"],
 ". The ",
 Cell[BoxData[
  StyleBox["Z", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "474083cf-65f5-4b83-bcc6-a0e6b650ab77"],
 "-checks catch bit-flips and the ",
 Cell[BoxData[
  StyleBox["X", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "2ea29bba-71c0-4746-a6a6-afd5bdbf71ed"],
 "-checks catch phase-flips, the two error types handled by separate, \
commuting halves of one tableau."
}], "Text",ExpressionUUID->"89dc8e7f-be36-409a-b9fe-a9cd21a9359b"]
}, Open  ]],

Cell[CellGroupData[{

Cell["The frontier: graph states, magic, and channels", "Section",ExpressionUUID->"ce8c56f2-f66e-471d-ba4d-82043e7af3b3"],

Cell["\<\
Three directions take the formalism to the edge of current research, and the \
framework has a head for each. This section gives each one enough room to \
compute with, not just name.\
\>", "Text",ExpressionUUID->"1f4e122c-507e-47c4-a6bd-fb5c7597d3c3"],

Cell[CellGroupData[{

Cell["Graph states", "Subsection",ExpressionUUID->"b40c779c-e7b4-4574-a5fb-3d42b35acef6"],

Cell[TextData[{
 "A theorem of Van den Nest and others says every stabilizer state is \
local-Clifford-equivalent to a ",
 StyleBox["graph state", "TI"],
 ": place ",
 Cell[BoxData[
  TemplateBox[{"+"},
   "Ket"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "3dd2bdb1-5900-41d4-ad7e-1a67242a358f"],
 " on each vertex of a graph and apply a controlled-",
 Cell[BoxData[
  StyleBox["Z", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "de53a68e-0e8b-488e-9cad-82bd69c21a9a"],
 " along each edge. Its stabilizer at vertex ",
 Cell[BoxData[
  StyleBox["i", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "2f9c8a4b-8907-49e5-ad31-b63eeda3bd37"],
 " is ",
 Cell[BoxData[
  RowBox[{
   SubscriptBox[
    StyleBox["X", "TI"], 
    StyleBox["i", "TI"]], 
   UnderscriptBox["\[Product]", 
    RowBox[{
     StyleBox["j", "TI"], "\[Tilde]", 
     StyleBox["i", "TI"]}],
    LimitsPositioning->False], 
   SubscriptBox[
    StyleBox["Z", "TI"], 
    StyleBox["j", "TI"]]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "c74a65f4-9704-4763-87af-51fd328ea15d"],
 ". Build the graph state on a 4-cycle:"
}], "Text",ExpressionUUID->"42d1e661-e0ee-484c-b41b-86ead6f64c46"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"gs", " ", "=", " ", 
  RowBox[{"GraphState", "[", 
   RowBox[{"CycleGraph", "[", "4", "]"}], "]"}]}]], "Input",
 CellLabel->
  "In[88]:= ",ExpressionUUID->"4b12d259-5bae-4983-9765-c835c4705bce"],

Cell[BoxData[
 InterpretationBox[
  RowBox[{
   TagBox["GraphState",
    "SummaryHead"], "[", 
   DynamicModuleBox[{Typeset`open$$ = False, Typeset`embedState$$ = "Ready"}, 
    
    TemplateBox[{
      PaneSelectorBox[{False -> GridBox[{{
            PaneBox[
