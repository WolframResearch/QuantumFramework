Cell[TextData[{
 "The answer is the signed string ",
 Cell[BoxData["\"\<-Z\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "d3cc7e1b-fe0a-4f08-8713-fa4f5180efed"],
 ", the operator that fixes ",
 Cell[BoxData[
  TemplateBox[{"1"},
   "Ket"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "1b93c828-9070-4e72-90d7-54017202cc96"],
 ". The sign is part of the stabilizer data, which is exactly why the \
formalism can tell ",
 Cell[BoxData[
  TemplateBox[{"0"},
   "Ket"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "27f6b3e6-2433-4887-8d05-46056dd38ebf"],
 " from ",
 Cell[BoxData[
  TemplateBox[{"1"},
   "Ket"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "bf8a882b-230a-475b-b392-6a0fa479324c"],
 " even though the same unsigned ",
 Cell[BoxData[
  StyleBox["Z", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "ee5965d3-9154-46a8-9b7c-2c96b3f854fb"],
 " pins both."
}], "Text",ExpressionUUID->"9b8e4c41-ad6e-46a5-bb5f-2a6bd9b08d44"],

Cell[TextData[{
 "A short word of honesty about what the tableau leaves out. The tableau \
tracks the stabilizer group, including the signs, but it is blind to the ",
 StyleBox["overall", "TI"],
 " phase of the state. Reconstructing a state vector from a gate-updated \
tableau is therefore exact only up to a global phase. You can see this by \
acting with ",
 Cell[BoxData[
  StyleBox["Z", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "5b29ae3f-465e-4fc1-a8e1-5fcb06ba76d2"],
 " on ",
 Cell[BoxData[
  TemplateBox[{"+"},
   "Ket"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "bf5bc39c-3afa-46ec-ba1e-7195de2f1b45"],
 ": physically ",
 Cell[BoxData[
  RowBox[{
   RowBox[{
    StyleBox["Z", "TI"], 
    TemplateBox[{"+"},
     "Ket"]}], "=", 
   TemplateBox[{"-"},
    "Ket"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "03b27e67-9786-405a-b329-0b3b964daa58"],
 ", and the framework returns ",
 Cell[BoxData[
  TemplateBox[{"-"},
   "Ket"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "21daef0d-4fdd-4eae-a73a-8bcf0a1b1cfb"],
 " up to an overall sign."
}], "Text",ExpressionUUID->"d4469c94-3aca-432e-abe9-87e6ae4b0fa0"],

