Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"\<\"XYX\"\>", ",", "\<\"ZZI\"\>", ",", "\<\"IZZ\"\>"}], 
  "}"}]], "Output",
 CellLabel->
  "Out[35]= ",ExpressionUUID->"b332ff78-5b76-4e5c-b549-ce3803274b32"]
}, Open  ]],

Cell[TextData[{
 "The two pictures must describe the same physics, and they do. Materialize \
the state from the final generators (the formalism's ",
 Cell[BoxData["\"\<State\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "ac58db35-ee25-43fc-8adc-66a02ec78aa4"],
 "):"
}], "Text",ExpressionUUID->"6b2394cd-49c8-4145-bae1-74b528256f9c"],

