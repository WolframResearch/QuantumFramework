Cell[TextData[{
 "The answer is the signed string ",
 Cell[BoxData["\"\<-Z\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "ec3d7471-a7da-47e8-8369-0511c0f00a16"],
 ", the operator that fixes ",
 Cell[BoxData[
  TemplateBox[{"1"},
   "Ket"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "53abe869-bf93-4b29-a9e1-60da27c8168a"],
 ". The sign is part of the stabilizer data, which is exactly why the \
formalism can tell ",
 Cell[BoxData[
  TemplateBox[{"0"},
   "Ket"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "c7f11454-962c-4536-8fba-639e769cd0ea"],
 " from ",
 Cell[BoxData[
  TemplateBox[{"1"},
   "Ket"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "1f951ce8-83e9-4660-b82f-15ca3a2f4267"],
 " even though the same unsigned ",
 Cell[BoxData[
  StyleBox["Z", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "14583f28-370b-4535-81a4-6b2bf7bf749a"],
 " pins both."
}], "Text",ExpressionUUID->"a2f9f17d-8ec5-437c-a717-d4091aad201b"],

Cell[TextData[{
 "A short word of honesty about what the tableau leaves out. The tableau \
tracks the stabilizer group, including the signs, but it is blind to the ",
 StyleBox["overall", "TI"],
 " phase of the state. Reconstructing a state vector from a gate-updated \
tableau is therefore exact only up to a global phase. You can see this by \
acting with ",
 Cell[BoxData[
  StyleBox["Z", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "01497242-0838-41e8-a368-c74c4c8c7097"],
 " on ",
 Cell[BoxData[
  TemplateBox[{"+"},
   "Ket"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "54f7f554-f21e-4a4c-9844-a594c506202a"],
 ": physically ",
 Cell[BoxData[
  RowBox[{
   RowBox[{
    StyleBox["Z", "TI"], 
    TemplateBox[{"+"},
     "Ket"]}], "=", 
   TemplateBox[{"-"},
    "Ket"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "272763df-14af-4295-98c6-3dbcbecb8be4"],
 ", and the framework returns ",
 Cell[BoxData[
  TemplateBox[{"-"},
   "Ket"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "c7512a9b-b67b-4a06-ac85-ff1ea9f7ef6b"],
 " up to an overall sign."
}], "Text",ExpressionUUID->"20bba6b0-6e0f-4437-9d99-d57d6e83ab10"],

