   FractionBox["1", "2"], ",", "0", ",", "0", ",", 
   FractionBox["1", "2"], ",", "0", ",", 
   FractionBox["1", "2"], ",", 
   FractionBox["1", "2"], ",", "0"}], "}"}]], "Output",
 CellLabel->
