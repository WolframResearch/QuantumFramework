Cell[TextData[{
 "Four of the eight amplitudes are ",
 Cell[BoxData[
  RowBox[{"1", "/", "2"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "2abba027-0f20-45ed-bfb6-8a9e96c5b686"],
 " and the rest vanish. Read the support directly off the state vector, the \
bit-strings whose amplitude is nonzero:"
}], "Text",ExpressionUUID->"01ac974d-d292-428b-8050-9a5129516a76"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"support", " ", "=", " ", 
  RowBox[{
   RowBox[{"Select", "[", 
    RowBox[{
     RowBox[{"AssociationThread", "[", 
      RowBox[{
       RowBox[{"Tuples", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"0", ",", " ", "1"}], "}"}], ",", " ", "3"}], "]"}], ",", 
       " ", 
       RowBox[{"Normal", "[", 
        RowBox[{
         RowBox[{"psAffineDemo", "[", "\"\<State\>\"", "]"}], 
         "[", "\"\<StateVector\>\"", "]"}], "]"}]}], "]"}], ",", " ", 
     RowBox[{
      RowBox[{"#", " ", "!=", " ", "0"}], " ", "&"}]}], "]"}], " ", "//", " ",
    "Keys"}]}]], "Input",
 CellLabel->
  "In[27]:= ",ExpressionUUID->"21cc48c7-2e7d-4e1a-ab47-33799dce999e"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"0", ",", "0", ",", "0"}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{"0", ",", "1", ",", "1"}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{"1", ",", "0", ",", "1"}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{"1", ",", "1", ",", "0"}], "}"}]}], "}"}]], "Output",
 CellLabel->
  "Out[27]= ",ExpressionUUID->"a6e2e661-f1c1-4c54-81ee-2ebe8a026548"]
}, Open  ]],

Cell[TextData[{
 "These four strings are exactly the even-parity ones. Taking the parity ",
 Cell[BoxData[
  RowBox[{
   SubscriptBox[
    StyleBox["x", "TI"], "1"], "\[CirclePlus]", 
   SubscriptBox[
    StyleBox["x", "TI"], "2"], "\[CirclePlus]", 
   SubscriptBox[
    StyleBox["x", "TI"], "3"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "3749b116-5c8b-4612-af8c-98f1d2440909"],
 " of each, as a sum mod 2, confirms it:"
}], "Text",ExpressionUUID->"57f19eb2-7251-48d4-8a65-a1cca5cb9b80"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"Mod", "[", 
    RowBox[{
     RowBox[{"Total", "[", "#", "]"}], ",", " ", "2"}], "]"}], " ", "&"}], 
  " ", "/@", " ", "support"}]], "Input",
 CellLabel->
  "In[28]:= ",ExpressionUUID->"955a883c-3095-4d69-a9a7-846062740429"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"0", ",", "0", ",", "0", ",", "0"}], "}"}]], "Output",
 CellLabel->
  "Out[28]= ",ExpressionUUID->"0117cca3-bf18-4c3e-bae3-0e181147ae82"]
}, Open  ]],

Cell[TextData[{
 "Every parity vanishes, so the support is the two-dimensional subspace of ",
 Cell[BoxData[
  SubsuperscriptBox["\|01d53d", "2", "3"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "707f64aa-6cb0-49af-a176-ec8f35a3e74e"],
 " cut out by the generator ",
 Cell[BoxData[
  StyleBox[
   RowBox[{"Z", "Z", "Z"}], "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "8f733b7a-9774-4c03-b678-28f56b0da19b"],
 ". That ",
 Cell[BoxData[
  StyleBox[
   RowBox[{"Z", "Z", "Z"}], "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "40526cab-0d2d-456c-b266-26243953c76b"],
 " really sits in the stabilizer group shows up as a ",
 Cell[BoxData[
  RowBox[{"+", "1"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "d55908cd-1909-49c7-8558-6e184071c851"],
 " expectation value:"
}], "Text",ExpressionUUID->"c91269e9-e703-47d4-a164-73bab5272a5c"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"psAffineDemo", "[", 
  RowBox[{"\"\<Expectation\>\"", ",", " ", "\"\<ZZZ\>\""}], "]"}]], "Input",
 CellLabel->
  "In[29]:= ",ExpressionUUID->"b3f0d6dc-f044-4c64-b72e-43fb6004c701"],

Cell[BoxData["1"], "Output",
 CellLabel->
  "Out[29]= ",ExpressionUUID->"e1faaceb-5bf6-4061-8206-e2ce9e6e01cc"]
}, Open  ]],

Cell[TextData[{
 "That is the whole anatomy of a stabilizer state: a uniform superposition \
over a coset, with the relative signs fixed by the generator signs. The \
exponential compression is now intuitive: naming the subspace and the signs \
costs ",
 Cell[BoxData[
  RowBox[{
   StyleBox["O", "TI"], 
   StyleBox["(",
    SpanMaxSize->1], 
   SuperscriptBox[
    StyleBox["n", "TI"], "2"], 
   StyleBox[")",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "773d638e-6df1-464a-8e90-4fcfe01916cf"],
 " bits, while listing the amplitudes costs ",
 Cell[BoxData[
  SuperscriptBox["2", 
   StyleBox["n", "TI"]]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "fa590f2c-b056-4b9f-822e-abce648a55bb"],
 "."
}], "Text",ExpressionUUID->"5f68a1a8-d2b0-47e7-b27e-827416a769ec"],

Cell[TextData[{
 "Why is any of this fast? Because of what a ",
 StyleBox["Clifford", "TI"],
 " gate is: precisely a unitary that conjugates every Pauli to a Pauli, that \
is, an element of the normalizer of the Pauli group. The Hadamard, the phase \
gate ",
 Cell[BoxData[
  StyleBox["S", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "bbfb90ff-6670-4656-b9eb-047d4ffed4f6"],
 ", and CNOT generate the whole Clifford group, and they are exactly the \
gates the tableau handles. Updating the state therefore means updating each \
generator, ",
 Cell[BoxData[
  RowBox[{
   StyleBox["g", "TI"], "\[Function]", 
   StyleBox["U", "TI"], 
   StyleBox["g", "TI"], 
   SuperscriptBox[
    StyleBox["U", "TI"], "\[Dagger]"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "49e6cd7e-c69a-43c2-abe0-9556911bba76"],
 ", which is a fixed local rewrite of two bits and a sign per affected qubit. \
This is the content of the Gottesman-Knill theorem: a circuit of Clifford \
gates on a stabilizer input can be simulated in time polynomial in ",
 Cell[BoxData[
  StyleBox["n", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "456284a8-5f5f-4009-84f2-81fbec0dab0e"],
 ", with ",
 Cell[BoxData[
  RowBox[{
   StyleBox["O", "TI"], 
   StyleBox["(",
    SpanMaxSize->1], 
   StyleBox["n", "TI"], 
   StyleBox[")",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "65207e6b-81db-4a3d-af9f-5f1131d3241c"],
 " work per gate, rather than the ",
 Cell[BoxData[
  RowBox[{
   StyleBox["O", "TI"], 
   StyleBox["(",
    SpanMaxSize->1], 
   SuperscriptBox["2", 
    StyleBox["n", "TI"]], 
   StyleBox[")",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "0142212c-1aca-4d65-a8a1-5e784e1e1858"],
 " of dense state-vector evolution. The single-qubit gate methods (",
 Cell[BoxData["\"\<H\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "ee3ac8ce-5f85-4580-a4a9-4922c453291a"],
 ", ",
 Cell[BoxData["\"\<S\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "a17b5474-5ec8-4a95-9653-219c2467803d"],
 ", ",
 Cell[BoxData["\"\<X\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "adc2e63d-31de-4e85-a790-b3292da29363"],
 ", ",
 Cell[BoxData["\"\<Y\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "affaf9ae-bb86-4e63-a773-40402515fa03"],
 ", ",
 Cell[BoxData["\"\<Z\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "301ec499-4f1d-4d2f-a990-33d384f21f43"],
 ", ",
 Cell[BoxData["\"\<V\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "0214aac8-103a-4dbd-8641-e08ed60c432f"],
 " for ",
 Cell[BoxData[
  SqrtBox[
   StyleBox["X", "TI"]]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "6473a006-5fd0-47fa-b5f7-46312d3a471e"],
 ", and ",
 Cell[BoxData[
  RowBox[{"SuperDagger", "[", "\"\<S\>\"", "]"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "1c357ffd-6c41-49d9-89fc-287408e7e3b0"],
 ") and the two-qubit ",
 Cell[BoxData["\"\<CNOT\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "095205c9-5ec8-42b9-a9ad-8ada99a8f7f9"],
 ", ",
 Cell[BoxData["\"\<CZ\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "14fb826d-a18f-4135-9e54-f6fef08c141c"],
 ", ",
 Cell[BoxData["\"\<SWAP\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "6e00a2a4-e8e3-4821-a0d7-50d59f416b25"],
 " each perform exactly that rewrite."
}], "Text",ExpressionUUID->"18cd3ee1-0f90-43c2-a67c-c6036424aaca"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Two pictures of one circuit: Schr\[ODoubleDot]dinger and Heisenberg", \
"Section",ExpressionUUID->"82d0e08d-b4b8-4746-9499-ac98397e83f5"],

Cell[TextData[{
 "That rewrite is worth slowing down on, because it is the whole reason the \
formalism reproduces ordinary quantum mechanics on its domain. The standard \
task is concrete: given a circuit, produce the final state. There are two \
ways to do it. The ",
 StyleBox["Schr\[ODoubleDot]dinger", "TI"],
 " way carries the state vector forward, ",
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     StyleBox["\[Psi]", "TI"]},
    "Ket"], "\[Function]", 
   RowBox[{
    StyleBox["U", "TI"], 
    TemplateBox[{
      StyleBox["\[Psi]", "TI"]},
     "Ket"]}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "f8fce082-b812-478f-95fe-eb10550139aa"],
 ", with ",
 Cell[BoxData[
  SuperscriptBox["2", 
   StyleBox["n", "TI"]]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "965ba130-cd43-4a75-a448-d3e6f61662dc"],
 " amplitudes evolving under ",
 Cell[BoxData[
  RowBox[{
   SuperscriptBox["2", 
    StyleBox["n", "TI"]], "\[Times]", 
   SuperscriptBox["2", 
    StyleBox["n", "TI"]]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "0662feba-a1ce-4375-ad22-ab5ba08c04a7"],
 " matrices. The ",
 StyleBox["Heisenberg", "TI"],
 " way carries the generators forward and never forms the state at all. They \
return the same state, and watching them meet is the clearest way to see what \
the tableau computes."
}], "Text",ExpressionUUID->"e585e22a-e911-4f64-a20b-adcddde1be36"],

Cell[TextData[{
 "Fix a small Clifford circuit on three qubits, with an ",
 Cell[BoxData[
  StyleBox["S", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "841db5c5-10f3-41a8-9872-9aa379b5e351"],
 " gate to make the result nontrivial:"
}], "Text",ExpressionUUID->"0917477a-37d1-44b7-9beb-70bc70dbbd03"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"cliffordCircuit", " ", "=", " ", 
  RowBox[{"QuantumCircuitOperator", "[", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"\"\<H\>\"", " ", "->", " ", "1"}], ",", " ", 
     RowBox[{"\"\<CNOT\>\"", " ", "->", " ", 
      RowBox[{"{", 
       RowBox[{"1", ",", " ", "2"}], "}"}]}], ",", " ", 
     RowBox[{"\"\<S\>\"", " ", "->", " ", "2"}], ",", " ", 
     RowBox[{"\"\<CNOT\>\"", " ", "->", " ", 
      RowBox[{"{", 
       RowBox[{"2", ",", " ", "3"}], "}"}]}]}], "}"}], "]"}]}]], "Input",
 CellLabel->
  "In[30]:= ",ExpressionUUID->"04b02bbb-c67f-453b-9855-c2351b8a56b6"],

