Cell[TextData[{
 "Four of the eight amplitudes are ",
 Cell[BoxData[
  RowBox[{"1", "/", "2"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "104e0c00-7d2c-4f13-a070-fc647ea40569"],
 " and the rest vanish. Read the support directly off the state vector, the \
bit-strings whose amplitude is nonzero:"
}], "Text",ExpressionUUID->"4241c6b4-c3df-4dd8-b19b-c1ecc983aaf8"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"support", " ", "=", " ", 
  RowBox[{
   RowBox[{"Select", "[", 
    RowBox[{
     RowBox[{"AssociationThread", "[", 
      RowBox[{
       RowBox[{"Tuples", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"0", ",", " ", "1"}], "}"}], ",", " ", "3"}], "]"}], ",", 
       " ", 
       RowBox[{"Normal", "[", 
        RowBox[{
         RowBox[{"psAffineDemo", "[", "\"\<State\>\"", "]"}], 
         "[", "\"\<StateVector\>\"", "]"}], "]"}]}], "]"}], ",", " ", 
     RowBox[{
      RowBox[{"#", " ", "!=", " ", "0"}], " ", "&"}]}], "]"}], " ", "//", " ",
    "Keys"}]}]], "Input",
 CellLabel->
  "In[27]:= ",ExpressionUUID->"c1ea510a-11eb-45df-973b-6111418c96f6"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"0", ",", "0", ",", "0"}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{"0", ",", "1", ",", "1"}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{"1", ",", "0", ",", "1"}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{"1", ",", "1", ",", "0"}], "}"}]}], "}"}]], "Output",
 CellLabel->
  "Out[27]= ",ExpressionUUID->"75431dae-97fd-405d-bfbd-e6e64b81632d"]
}, Open  ]],

Cell[TextData[{
 "These four strings are exactly the even-parity ones. Taking the parity ",
 Cell[BoxData[
  RowBox[{
   SubscriptBox[
    StyleBox["x", "TI"], "1"], "\[CirclePlus]", 
   SubscriptBox[
    StyleBox["x", "TI"], "2"], "\[CirclePlus]", 
   SubscriptBox[
    StyleBox["x", "TI"], "3"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "0bad5daf-942a-4de8-be1a-938281ebef8e"],
 " of each, as a sum mod 2, confirms it:"
}], "Text",ExpressionUUID->"f7cc670d-882f-4ef0-a8e3-0d35d2f94085"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"Mod", "[", 
    RowBox[{
     RowBox[{"Total", "[", "#", "]"}], ",", " ", "2"}], "]"}], " ", "&"}], 
  " ", "/@", " ", "support"}]], "Input",
 CellLabel->
  "In[28]:= ",ExpressionUUID->"9fc3a41f-d405-430f-bd8f-c0fff720ddab"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"0", ",", "0", ",", "0", ",", "0"}], "}"}]], "Output",
 CellLabel->
  "Out[28]= ",ExpressionUUID->"6edac1d7-02d3-408c-bbc2-e48da0960988"]
}, Open  ]],

Cell[TextData[{
 "Every parity vanishes, so the support is the two-dimensional subspace of ",
 Cell[BoxData[
  SubsuperscriptBox["\|01d53d", "2", "3"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "fa10d451-3c2c-4aee-bbac-7df71ffdcf30"],
 " cut out by the generator ",
 Cell[BoxData[
  StyleBox[
   RowBox[{"Z", "Z", "Z"}], "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "262e37d5-bcd4-46c7-b7cb-5cea13c93ee7"],
 ". That ",
 Cell[BoxData[
  StyleBox[
   RowBox[{"Z", "Z", "Z"}], "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "84a19ae6-2c5c-4f0e-b908-9b5a8db44211"],
 " really sits in the stabilizer group shows up as a ",
 Cell[BoxData[
  RowBox[{"+", "1"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "41a25bf3-ba4b-4e7c-8174-fcb24c3d7401"],
 " expectation value:"
}], "Text",ExpressionUUID->"114336dd-2819-4155-818b-dc0daa461374"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"psAffineDemo", "[", 
  RowBox[{"\"\<Expectation\>\"", ",", " ", "\"\<ZZZ\>\""}], "]"}]], "Input",
 CellLabel->
  "In[29]:= ",ExpressionUUID->"84c94e0a-51e4-4c4b-94f2-52387153651a"],

Cell[BoxData["1"], "Output",
 CellLabel->
  "Out[29]= ",ExpressionUUID->"91f8935f-4219-482d-8076-6128917ad249"]
}, Open  ]],

Cell[TextData[{
 "That is the whole anatomy of a stabilizer state: a uniform superposition \
over a coset, with the relative signs fixed by the generator signs. The \
exponential compression is now intuitive: naming the subspace and the signs \
costs ",
 Cell[BoxData[
  RowBox[{
   StyleBox["O", "TI"], 
   StyleBox["(",
    SpanMaxSize->1], 
   SuperscriptBox[
    StyleBox["n", "TI"], "2"], 
   StyleBox[")",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "a6761c98-b12b-41e7-9f2c-e807c62ad108"],
 " bits, while listing the amplitudes costs ",
 Cell[BoxData[
  SuperscriptBox["2", 
   StyleBox["n", "TI"]]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "13037152-30eb-4999-aa14-a433de51c94f"],
 "."
}], "Text",ExpressionUUID->"e1f1400d-6202-4071-bb9c-597fbeb05fcc"],

Cell[TextData[{
 "Why is any of this fast? Because of what a ",
 StyleBox["Clifford", "TI"],
 " gate is: precisely a unitary that conjugates every Pauli to a Pauli, that \
is, an element of the normalizer of the Pauli group. The Hadamard, the phase \
gate ",
 Cell[BoxData[
  StyleBox["S", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "3673794f-9a58-48e1-b6bd-a462508927c2"],
 ", and CNOT generate the whole Clifford group, and they are exactly the \
gates the tableau handles. Updating the state therefore means updating each \
generator, ",
 Cell[BoxData[
  RowBox[{
   StyleBox["g", "TI"], "\[Function]", 
   StyleBox["U", "TI"], 
   StyleBox["g", "TI"], 
   SuperscriptBox[
    StyleBox["U", "TI"], "\[Dagger]"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "9a7f9d26-8ed5-40eb-8b7d-b3a526613ce0"],
 ", which is a fixed local rewrite of two bits and a sign per affected qubit. \
This is the content of the Gottesman-Knill theorem: a circuit of Clifford \
gates on a stabilizer input can be simulated in time polynomial in ",
 Cell[BoxData[
  StyleBox["n", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "ec0d4dd4-dfe6-4205-a9ab-254df562cbe7"],
 ", with ",
 Cell[BoxData[
  RowBox[{
   StyleBox["O", "TI"], 
   StyleBox["(",
    SpanMaxSize->1], 
   StyleBox["n", "TI"], 
   StyleBox[")",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "ae6d16f1-10b6-4e0f-b4f4-e363181e2758"],
 " work per gate, rather than the ",
 Cell[BoxData[
  RowBox[{
   StyleBox["O", "TI"], 
   StyleBox["(",
    SpanMaxSize->1], 
   SuperscriptBox["2", 
    StyleBox["n", "TI"]], 
   StyleBox[")",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "0eda9be6-a802-461c-aaf2-14f6fd7dacd9"],
 " of dense state-vector evolution. The single-qubit gate methods (",
 Cell[BoxData["\"\<H\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "3f39973c-2925-42c5-a5e5-ebc2eaacc620"],
 ", ",
 Cell[BoxData["\"\<S\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "439582b6-f9e2-4a75-b890-22a48364e1e7"],
 ", ",
 Cell[BoxData["\"\<X\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "96f2555b-7d2a-4acd-b84f-6f5aebdffba5"],
 ", ",
 Cell[BoxData["\"\<Y\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "1fa2db78-98c4-484e-8d9f-55a4d8f9b2a2"],
 ", ",
 Cell[BoxData["\"\<Z\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "904dd41a-a9ec-4015-8382-7e0c978a5f96"],
 ", ",
 Cell[BoxData["\"\<V\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "108a0aeb-5546-4854-ba28-1fda78b7a24a"],
 " for ",
 Cell[BoxData[
  SqrtBox[
   StyleBox["X", "TI"]]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "26f356e9-9548-4fd4-99fe-228e99a2a24c"],
 ", and ",
 Cell[BoxData[
  RowBox[{"SuperDagger", "[", "\"\<S\>\"", "]"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "30ede3ec-4ad0-495c-bf89-0deaa4ee739b"],
 ") and the two-qubit ",
 Cell[BoxData["\"\<CNOT\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "b469d7cd-21a5-48ef-9980-aad77a4bc011"],
 ", ",
 Cell[BoxData["\"\<CZ\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "0fd72f05-a3c2-4c96-8a54-e045e6f4d7c3"],
 ", ",
 Cell[BoxData["\"\<SWAP\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "65c7cae2-9cbd-4701-b906-e35eda101684"],
 " each perform exactly that rewrite."
}], "Text",ExpressionUUID->"3a61f789-5605-4f12-8359-10683e2bb5ca"],

Cell["Two pictures of one circuit: Schr\[ODoubleDot]dinger and Heisenberg", \
"Section",ExpressionUUID->"74259314-7ba9-412f-9f9f-574afadea070"],

Cell[TextData[{
 "That rewrite is worth slowing down on, because it is the whole reason the \
formalism reproduces ordinary quantum mechanics on its domain. The standard \
task is concrete: given a circuit, produce the final state. There are two \
ways to do it. The ",
 StyleBox["Schr\[ODoubleDot]dinger", "TI"],
 " way carries the state vector forward, ",
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     StyleBox["\[Psi]", "TI"]},
    "Ket"], "\[Function]", 
   RowBox[{
    StyleBox["U", "TI"], 
    TemplateBox[{
      StyleBox["\[Psi]", "TI"]},
     "Ket"]}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "3c2bc607-de6b-4751-88bf-fdbd0b7b4112"],
 ", with ",
 Cell[BoxData[
  SuperscriptBox["2", 
   StyleBox["n", "TI"]]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "d51b46ae-26ac-47a3-bd4b-22cb6c3e138a"],
 " amplitudes evolving under ",
 Cell[BoxData[
  RowBox[{
   SuperscriptBox["2", 
    StyleBox["n", "TI"]], "\[Times]", 
   SuperscriptBox["2", 
    StyleBox["n", "TI"]]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "fe405e18-7e0c-4908-81d7-ffd099dd4603"],
 " matrices. The ",
 StyleBox["Heisenberg", "TI"],
 " way carries the generators forward and never forms the state at all. They \
return the same state, and watching them meet is the clearest way to see what \
the tableau computes."
}], "Text",ExpressionUUID->"4bc2f42e-54d1-403a-ad86-f6926d7f28c5"],

Cell[TextData[{
 "Fix a small Clifford circuit on three qubits, with an ",
 Cell[BoxData[
  StyleBox["S", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "b7d61e0e-beff-4dfe-a636-7f9a04bf18f6"],
 " gate to make the result nontrivial:"
}], "Text",ExpressionUUID->"6e9ebb19-e2af-4ca3-ba4d-ae2e7ba3871d"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"cliffordCircuit", " ", "=", " ", 
  RowBox[{"QuantumCircuitOperator", "[", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"\"\<H\>\"", " ", "->", " ", "1"}], ",", " ", 
     RowBox[{"\"\<CNOT\>\"", " ", "->", " ", 
      RowBox[{"{", 
       RowBox[{"1", ",", " ", "2"}], "}"}]}], ",", " ", 
     RowBox[{"\"\<S\>\"", " ", "->", " ", "2"}], ",", " ", 
     RowBox[{"\"\<CNOT\>\"", " ", "->", " ", 
      RowBox[{"{", 
       RowBox[{"2", ",", " ", "3"}], "}"}]}]}], "}"}], "]"}]}]], "Input",
 CellLabel->
  "In[30]:= ",ExpressionUUID->"c6e86f19-65c0-4f57-afff-33eca75d6bf7"],

