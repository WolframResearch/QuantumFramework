   RowBox[{"1", "\[Rule]", "492"}], ",", 
   RowBox[{"0", "\[Rule]", "508"}]}], "\[RightAssociation]"}]], "Output",
 CellLabel->
  "Out[58]= ",ExpressionUUID->"708a646f-7ada-48f4-8671-397cbec1bd57"]
}, Open  ]],

Cell[TextData[{
 "The second reason is deeper: the formal bits ",
 StyleBox["compose", "TI"],
 ". When a later measurement is forced by the outcomes already taken, its \
result is not a fresh coin but an explicit Boolean function of the earlier \
bits, and the engine records that function instead of discarding it. A parity \
check makes this concrete. Prepare two qubits in ",
 Cell[BoxData[
  TemplateBox[{"+"},
   "Ket"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "ebf77df9-bd0d-4547-8e69-89bcbf0f1170"],
 ", so each carries a fair-coin ",
 Cell[BoxData[
  StyleBox["Z", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "60cc0afe-f3e9-4bcc-8051-11c2d7902ced"],
 "-outcome, then copy their parity onto a third qubit with two ",
 Cell[BoxData["CNOT"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "deb8c40f-1fa9-49c6-b0ad-b5bcd8c453a7"],
 "s:"
}], "Text",ExpressionUUID->"f59393e3-3abb-4c07-8243-26ae4252b21d"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"parityCheck", " ", "=", " ", 
  RowBox[{
   RowBox[{"PauliStabilizer", "[", "3", "]"}], "[", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"\"\<H\>\"", " ", "->", " ", "1"}], ",", " ", 
     RowBox[{"\"\<H\>\"", " ", "->", " ", "2"}], ",", " ", 
     RowBox[{"\"\<CNOT\>\"", " ", "->", " ", 
      RowBox[{"{", 
       RowBox[{"1", ",", " ", "3"}], "}"}]}], ",", " ", 
     RowBox[{"\"\<CNOT\>\"", " ", "->", " ", 
      RowBox[{"{", 
       RowBox[{"2", ",", " ", "3"}], "}"}]}]}], "}"}], "]"}]}]], "Input",
 CellLabel->
  "In[59]:= ",ExpressionUUID->"7dd914e6-8daa-4c53-87df-65430664448a"],

