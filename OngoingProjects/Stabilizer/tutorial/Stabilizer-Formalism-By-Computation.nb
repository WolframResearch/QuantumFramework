                    CapForm["Round"]], 
                    Arrowheads[0.], {
                    
                    ArrowBox[{{1, 2}, {1, 4}, {2, 3}, {3, 4}}, 
                    0.02261146496815286]}}, {
                    Directive[
                    Hue[0.6, 0.5, 1.], 
                    EdgeForm[
                    Directive[
                    GrayLevel[0], 
