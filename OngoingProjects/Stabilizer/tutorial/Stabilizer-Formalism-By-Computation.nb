Cell[TextData[{
 "The single key tells us the ",
 Cell[BoxData[
  StyleBox[
   RowBox[{"Z", "Z"}], "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "af2a9379-dcab-46e9-939e-e2cbcfff33e5"],
 " parity is certain. The same fact, as an expectation value, comes from ",
 Cell[BoxData["\"\<Expectation\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "37b0bece-0ed8-407e-bce0-45ae170e8d9f"],
 ", which tracks the Aaronson-Gottesman ",
 Cell[BoxData[
  StyleBox["i", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "d7c75b75-47a9-4978-bd6d-951966d170b1"],
 "-powers in closed form and returns ",
 Cell[BoxData[
  RowBox[{"\[PlusMinus]", "1"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "3e161711-e3c4-4b25-9627-67a85b96b142"],
 " or ",
 Cell[BoxData["0"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "2b889f66-e943-45cc-8a3b-76b0a9604283"],
 ":"
}], "Text",ExpressionUUID->"d4b4466d-31f3-41b2-b253-8f4e4e2a82c8"],

