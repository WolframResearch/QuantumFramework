Cell[TextData[{
 "Read off its preparation circuit with the ",
 Cell[BoxData["\"\<Circuit\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "055d6e4b-8064-47ec-b7e5-1271eae11984"],
 " property (a hundred-plus-gate object, so we hold it in ",
 Cell[BoxData["prep"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "0bbab569-02ad-47a4-beaa-7ecc2d5368be"],
 " rather than print it):"
}], "Text",ExpressionUUID->"5549f3a5-e874-4f4f-9d83-033fb7f034fb"],

Cell[BoxData[
 RowBox[{
  RowBox[{"prep", " ", "=", " ", 
   RowBox[{"ps10", "[", "\"\<Circuit\>\"", "]"}]}], ";"}]], "Input",
 CellLabel->
  "In[68]:= ",ExpressionUUID->"12edbbd9-6de6-4055-8260-570378a54e19"],

Cell["\<\
then count its gates, which stay polynomial in the number of qubits:\
\>", "Text",ExpressionUUID->"f4ced82b-8950-4aff-92ee-a878c29d7b1d"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Length", " ", "@", " ", 
  RowBox[{"QuantumShortcut", "[", "prep", "]"}]}]], "Input",
 CellLabel->
  "In[69]:= ",ExpressionUUID->"78f90608-d44b-4c9c-9be2-013ef94b164b"],

Cell[BoxData["136"], "Output",
 CellLabel->
  "Out[69]= ",ExpressionUUID->"58cf167d-fc59-4a37-a604-90b2aaf57af4"]
}, Open  ]],

Cell[TextData[{
 "The result is an ordinary ",
 Cell[BoxData["QuantumCircuitOperator"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "cd48acef-45d5-4bcb-8252-cc90f8ad14d8"],
 ". It genuinely builds the state: applied to the all-zeros register it \
reproduces ",
 Cell[BoxData[
  TemplateBox[{
    StyleBox["\[Psi]", "TI"]},
   "Ket"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "3619c93a-cd20-48b0-a1e0-ab6d2af406c2"],
 " exactly. At ten qubits a full ",
 Cell[BoxData["QuantumSimilarity"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "ebd12a79-4b3f-4260-aae6-600fd4013672"],
 " would form a ",
 Cell[BoxData[
  RowBox[{
   SuperscriptBox["2", "10"], "\[Times]", 
   SuperscriptBox["2", "10"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "a7d784b4-ad98-446c-9895-877ef79f8075"],
 " density matrix, so here we take the cheaper direct state-vector overlap, \
whose magnitude is one:"
}], "Text",ExpressionUUID->"a42f99a6-4e14-47d3-98d0-900a71b55196"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Chop", "[", 
  RowBox[{
   RowBox[{"Abs", "[", 
    RowBox[{
     RowBox[{"Conjugate", "[", 
      RowBox[{"Normal", " ", "@", " ", 
       RowBox[{
        RowBox[{"prep", "[", "]"}], "[", "\"\<StateVector\>\"", "]"}]}], 
      "]"}], " ", ".", " ", 
     RowBox[{"Normal", " ", "@", " ", 
      RowBox[{
       RowBox[{"ps10", "[", "\"\<State\>\"", "]"}], "[", "\"\<StateVector\>\"",
        "]"}]}]}], "]"}], " ", "-", " ", "1"}], "]"}]], "Input",
 CellLabel->
  "In[70]:= ",ExpressionUUID->"bbd02572-cd74-4c0f-87a8-7b41c5a454ed"],

Cell[BoxData["0"], "Output",
 CellLabel->
  "Out[70]= ",ExpressionUUID->"115fe6ec-0a63-435c-b3bc-2b0f2977f010"]
}, Open  ]],

Cell["\<\
This inverts gate-folding, which goes from circuit to tableau, and it is the \
workhorse behind code encoders: a code state's preparation circuit is exactly \
its encoding circuit.\
\>", "Text",ExpressionUUID->"303580e1-765e-4ace-8086-a18649b3f2fc"],

Cell[TextData[{
 "For long Clifford circuits the framework folds the entire gate list through \
a single compiled (C) kernel that operates on a bit-packed, generator-major \
tableau, the same data layout the specialized simulators use. Handing the \
whole gate list to ",
 Cell[BoxData[
  RowBox[{"ps", "[", "gates", "]"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "e04f9cde-a8f9-4a53-9404-e3a3898c525e"],
 " folds it in one such pass. First build a four-thousand-gate random \
Clifford stream on two hundred qubits (kept suppressed, since it is four \
thousand gate specs):"
}], "Text",ExpressionUUID->"7f9a5ece-09d1-410a-b474-e557a0dc8146"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"SeedRandom", "[", "1", "]"}], ";"}], "\n", 
 RowBox[{
  RowBox[{"specs", " ", "=", " ", 
   RowBox[{"Table", "[", "\n", "   ", 
    RowBox[{
     RowBox[{"RandomChoice", "[", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"\"\<H\>\"", " ", "->", " ", 
         RowBox[{"RandomInteger", "[", 
          RowBox[{"{", 
           RowBox[{"1", ",", " ", "200"}], "}"}], "]"}]}], ",", " ", 
        RowBox[{"\"\<S\>\"", " ", "->", " ", 
         RowBox[{"RandomInteger", "[", 
          RowBox[{"{", 
           RowBox[{"1", ",", " ", "200"}], "}"}], "]"}]}], ",", "\n", "     ", 
        RowBox[{"\"\<CNOT\>\"", " ", "->", " ", 
         RowBox[{"RandomSample", "[", 
          RowBox[{
           RowBox[{"Range", "[", "200", "]"}], ",", " ", "2"}], "]"}]}]}], 
       "}"}], "]"}], ",", "\n", "   ", 
     RowBox[{"{", "4000", "}"}]}], "]"}]}], ";"}]}], "Input",
 CellLabel->
  "In[71]:= ",ExpressionUUID->"74eea1fe-ac0b-4caf-a31c-a6ceb48df78b"],

Cell["then fold it and watch the wall-clock:", "Text",ExpressionUUID->"532010a5-cca7-4376-8113-f29d5c324b3f"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"AbsoluteTiming", "[", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"PauliStabilizer", "[", "200", "]"}], "[", "specs", "]"}], 
    "[", "\"\<Stabilizers\>\"", "]"}], "[", 
   RowBox[{"[", "1", "]"}], "]"}], "]"}]], "Input",
 CellLabel->
  "In[72]:= ",ExpressionUUID->"a69a17b5-e0f5-42ce-8fee-724f7f1a343b"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
  "0.033494`", 
   ",", "\<\"-\
XYIYZIIZZIXIIZZIYZIZIXYXIXYIXYZZXYXXYIIZZXIXXYIZXYIZYIXIYZZYIIXXZIIXXZYYYZZIXY\
ZIYZIXIYYYYZIXXXYXZZXXXZIIXZIIIIZXYYYXXYXXYXIXXZIZYIXZZXYZZIYIXZXXXIIXZXIYZZYI\
XIXZXXIIZIYIYXIIXIYXYZYZYIXZYIIZXIYIIZIZXZIZ\"\>"}], "}"}]], "Output",
 CellLabel->
  "Out[72]= ",ExpressionUUID->"6dddcdaf-89db-4e10-9cd7-a100bcbb7cbf"]
}, Open  ]],

Cell[TextData[{
 "That is roughly a quarter of a microsecond per gate, flat in the number of \
qubits, because each gate touches only the machine words of its own column. \
The same engine backs the circuit object: a ",
 Cell[BoxData["QuantumCircuitOperator"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "331afc86-9f2f-4f5d-bac8-4af84b3bce1b"],
 " applied with ",
 Cell[BoxData[
  RowBox[{"Method", " ", "->", " ", "\"\<Stabilizer\>\""}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "78ce8eb4-4ae6-4fd9-8394-7515fbdbbd54"],
 " evolves a stabilizer state directly. Build a Bell circuit:"
}], "Text",ExpressionUUID->"bf294e20-9d79-4d3b-89a3-fcf672e29aa1"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"qc", " ", "=", " ", 
  RowBox[{"QuantumCircuitOperator", "[", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"\"\<H\>\"", " ", "->", " ", "1"}], ",", " ", 
     RowBox[{"\"\<CNOT\>\"", " ", "->", " ", 
      RowBox[{"{", 
       RowBox[{"1", ",", " ", "2"}], "}"}]}]}], "}"}], "]"}]}]], "Input",
 CellLabel->
  "In[73]:= ",ExpressionUUID->"a5997488-f02d-42a1-87aa-7bd36c3a1cd6"],

