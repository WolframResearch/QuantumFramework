Cell[TextData[{
 "The four cyclic permutations ",
 Cell[BoxData[
  RowBox[{
   StyleBox[
    RowBox[{"X", "Z", "Z", "X", "I"}], "TI"], ",", 
   StyleBox[
    RowBox[{"I", "X", "Z", "Z", "X"}], "TI"], ",", 
   StyleBox[
    RowBox[{"X", "I", "X", "Z", "Z"}], "TI"], ",", 
   StyleBox[
    RowBox[{"Z", "X", "I", "X", "Z"}], "TI"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "292cb3e9-8dea-4d05-8a24-aa50d940be4d"],
 " are the parity checks; the last generator ",
 Cell[BoxData[
  StyleBox[
   RowBox[{"Z", "Z", "Z", "Z", "Z"}], "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "83e92b4f-84a5-421d-b89b-934fd1975ee1"],
 " is the logical ",
 Cell[BoxData[
  OverscriptBox[
   StyleBox["Z", "TI"], "_"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "5570fa79-3dc2-4b50-b6d4-159a0c07cfed"],
 ", which fixes ",
 Cell[BoxData[
  TemplateBox[{
    SubscriptBox["0", 
     StyleBox["L", "TI"]]},
   "Ket"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "90b80a3d-6bd5-4534-b9ae-160e938511d6"],
 " inside the code space. Keep the checks alone:"
}], "Text",ExpressionUUID->"76a9a2eb-1dbb-49c8-a73c-55d6e64580c9"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"checks", " ", "=", " ", 
  RowBox[{"Most", "[", 
   RowBox[{"code", "[", "\"\<Stabilizers\>\"", "]"}], "]"}]}]], "Input",
 CellLabel->
  "In[82]:= ",ExpressionUUID->"d062a854-f75c-44bc-83c8-488b4a2d343c"],

Cell[BoxData[
 RowBox[{"{", 
