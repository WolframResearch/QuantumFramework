  FontSize->0.9 Inherited,ExpressionUUID->
  "9b4ec3d0-d61b-4903-94c5-334445cd98ad"],
 ", and here a sign appears for the first time: ",
 Cell[BoxData[
  TemplateBox[{"1"},
   "Ket"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "6b4cac23-12b5-4808-92aa-06d96160b906"],
 " is the ",
 Cell[BoxData[
  RowBox[{"+", "1"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "babbfc41-cd8c-46d2-b91e-257b5e6be826"],
 " eigenstate of ",
 Cell[BoxData[
  RowBox[{"-", 
   StyleBox["Z", "TI"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "940b334f-9d62-457a-a831-4456a59ea002"],
 ", not of ",
 Cell[BoxData[
  StyleBox["Z", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "f40cf09c-5332-4eb4-8a45-71ea116b134f"],
 "."
}], "Text",ExpressionUUID->"19f2b08e-9036-4c14-8eaf-149585f512a8"],

