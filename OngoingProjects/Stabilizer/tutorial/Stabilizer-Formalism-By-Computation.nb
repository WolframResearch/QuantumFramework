 CellLabel->
  "Out[82]= ",ExpressionUUID->"1de9fb85-b713-4a80-9c28-6f17094848f5"]
}, Open  ]],

Cell[TextData[{
 "A list of four operators is worth only what it can diagnose, and this is \
where the formalism earns its keep. The clean codeword is a ",
 Cell[BoxData[
  RowBox[{"+", "1"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "65236a7d-c105-41d5-8e22-485d735c2ccc"],
 " eigenstate of every check, so the four checks all read ",
 Cell[BoxData[
  RowBox[{"+", "1"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "5ee2365b-9124-44b6-81ac-4decc073e13b"],
 ". A single-qubit error ",
 Cell[BoxData[
  StyleBox["E", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "de93939c-831b-49e2-92cf-d6d64cc9dd88"],
 " commutes or anticommutes with each check, and wherever it anticommutes it \
flips that reading to ",
 Cell[BoxData[
  RowBox[{"-", "1"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "b167d23a-3883-431e-9cec-67c86d0964ec"],
 ". The pattern of flips is the ",
 StyleBox["syndrome", "TI"],
 ": a four-bit string, ",
 Cell[BoxData["0"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "288e627f-0879-4bc4-bd4f-3f07f139595d"],
 " for an undisturbed check and ",
 Cell[BoxData["1"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "1492b701-61a8-453a-ae66-6034cd8fc02f"],
 " for a flipped one."
}], "Text",ExpressionUUID->"c3919657-7a08-4652-bf26-bf4ea376e1cf"],

Cell[BoxData[
 RowBox[{
  RowBox[{"syndrome", "[", "err_", "]"}], " ", ":=", " ", 
  RowBox[{
   RowBox[{"(", 
    RowBox[{"1", " ", "-", " ", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{"code", "[", "err", "]"}], "[", 
         RowBox[{"\"\<Expectation\>\"", ",", " ", "#"}], "]"}], " ", "&"}], 
       " ", "/@", " ", "checks"}], ")"}]}], ")"}], " ", "/", " ", 
   "2"}]}]], "Input",
 CellLabel->
  "In[83]:= ",ExpressionUUID->"5af4271a-bf15-4722-89cc-74cf483ee15b"],

