Cell[TextData[{
 "The result is a ",
 Cell[BoxData["PauliStabilizer"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "171d43e1-7374-46f3-ba79-2d3f53800a84"],
 ", not a dense state. The stabilizer and Schr\[ODoubleDot]dinger \
constructions land on the same state, as they did on the GHZ circuit; here is \
that check at random, on a 30-gate Clifford circuit. First build the stream \
(suppressed, 30 gate specs):"
}], "Text",ExpressionUUID->"6fcdf58e-4ec4-4795-955d-69dbe87cff53"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"SeedRandom", "[", "7", "]"}], ";"}], "\n", 
 RowBox[{
  RowBox[{"specs2", " ", "=", " ", 
   RowBox[{"Table", "[", "\n", "   ", 
    RowBox[{
     RowBox[{"RandomChoice", "[", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"\"\<H\>\"", " ", "->", " ", 
         RowBox[{"RandomInteger", "[", 
          RowBox[{"{", 
           RowBox[{"1", ",", " ", "4"}], "}"}], "]"}]}], ",", " ", 
        RowBox[{"\"\<S\>\"", " ", "->", " ", 
         RowBox[{"RandomInteger", "[", 
          RowBox[{"{", 
           RowBox[{"1", ",", " ", "4"}], "}"}], "]"}]}], ",", "\n", "     ", 
        RowBox[{"\"\<CNOT\>\"", " ", "->", " ", 
         RowBox[{"RandomSample", "[", 
          RowBox[{
           RowBox[{"Range", "[", "4", "]"}], ",", " ", "2"}], "]"}]}]}], 
       "}"}], "]"}], ",", "\n", "   ", 
     RowBox[{"{", "30", "}"}]}], "]"}]}], ";"}]}], "Input",
 CellLabel->
  "In[76]:= ",ExpressionUUID->"78fab858-8441-4c5d-bce7-251be2b63ea2"],

Cell["Run it densely:", "Text",ExpressionUUID->"8b2d45a6-b9c6-437e-95b5-95df50d8fa76"],

