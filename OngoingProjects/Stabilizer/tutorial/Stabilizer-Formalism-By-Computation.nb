Cell[TextData[{
 "The result is a ",
 Cell[BoxData["PauliStabilizer"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "db26a94d-7ec6-401b-9f81-160a823ecaf8"],
 ", not a dense state. The stabilizer and Schr\[ODoubleDot]dinger \
constructions land on the same state, as they did on the GHZ circuit; here is \
that check at random, on a 30-gate Clifford circuit. First build the stream \
(suppressed, 30 gate specs):"
}], "Text",ExpressionUUID->"10b94853-c2db-4a3a-993b-a1767897df8b"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"SeedRandom", "[", "7", "]"}], ";"}], "\n", 
 RowBox[{
  RowBox[{"specs2", " ", "=", " ", 
   RowBox[{"Table", "[", "\n", "   ", 
    RowBox[{
     RowBox[{"RandomChoice", "[", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"\"\<H\>\"", " ", "->", " ", 
         RowBox[{"RandomInteger", "[", 
          RowBox[{"{", 
           RowBox[{"1", ",", " ", "4"}], "}"}], "]"}]}], ",", " ", 
        RowBox[{"\"\<S\>\"", " ", "->", " ", 
         RowBox[{"RandomInteger", "[", 
          RowBox[{"{", 
           RowBox[{"1", ",", " ", "4"}], "}"}], "]"}]}], ",", "\n", "     ", 
        RowBox[{"\"\<CNOT\>\"", " ", "->", " ", 
         RowBox[{"RandomSample", "[", 
          RowBox[{
           RowBox[{"Range", "[", "4", "]"}], ",", " ", "2"}], "]"}]}]}], 
       "}"}], "]"}], ",", "\n", "   ", 
     RowBox[{"{", "30", "}"}]}], "]"}]}], ";"}]}], "Input",
 CellLabel->
  "In[76]:= ",ExpressionUUID->"f6e15ed2-43a7-412b-b1de-c8fd535bb24d"],

Cell["Run it densely:", "Text",ExpressionUUID->"7faccb5b-edf2-4c3a-8921-5d2ba943fdf0"],

