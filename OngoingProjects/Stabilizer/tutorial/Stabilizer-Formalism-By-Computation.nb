Cell[TextData[{
 "Because ",
 Cell[BoxData[
  StyleBox[
   RowBox[{"Z", "Z", "Z"}], "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "8dac4059-48f9-438b-9299-aa8a709d5afc"],
 " stabilizes the state, the three ",
 Cell[BoxData[
  StyleBox["Z", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "b51288bb-5edc-44f3-a6e1-f6d9048b908d"],
 "-measurements cannot be independent: their signs must multiply to ",
 Cell[BoxData[
  RowBox[{"+", "1"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "1336af45-ecf7-4256-b77e-1f19b179bc26"],
 ", so the outcomes XOR to ",
 Cell[BoxData["0"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "112675d7-58eb-47ab-975f-c3168816ba44"],
 ". Measuring all three symbolically therefore spends only ",
 StyleBox["two", "TI"],
 " fresh bits, one per genuinely random qubit, and leaves the ",
 Cell[BoxData[
  StyleBox[
   RowBox[{"Z", "Z", "Z"}], "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "9347978b-e76b-4934-a21a-b6a66c923dd1"],
 " generator untouched, since the third outcome is already fixed:"
}], "Text",ExpressionUUID->"06e0b3a0-cc99-4f62-b4c8-7ee2ea455e04"],

