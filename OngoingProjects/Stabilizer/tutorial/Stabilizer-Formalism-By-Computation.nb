Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   FractionBox["1", 
    SqrtBox["2"]], ",", 
   RowBox[{
    FractionBox["1", "2"], "+", 
    FractionBox["\[ImaginaryI]", "2"]}]}], "}"}]], "Output",
 CellLabel->
  "Out[98]= ",ExpressionUUID->"440ba118-6451-46fd-a3f6-b8423bd51189"]
}, Open  ]],

Cell[TextData[{
 "The entry ",
 Cell[BoxData[
  RowBox[{
   FractionBox["1", "2"], "+", 
   FractionBox[
    StyleBox["i", "TI"], "2"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "28e33593-ef9c-459f-83e1-868c58ce06cc"],
 " is exactly ",
 Cell[BoxData[
  RowBox[{
   SuperscriptBox[
    StyleBox["e", "TI"], 
    RowBox[{
     StyleBox["i", "TI"], "\[Pi]", "/", "4"}]], "/", 
   SqrtBox["2"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "64216a12-9f51-4908-9559-a92f0f58bb4c"],
 ". Measuring ",
 Cell[BoxData[
  TemplateBox[{
    StyleBox["T", "TI"]},
   "Ket"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "b4adebd0-d56d-4f16-bffd-98f278423795"],
 " in the ",
 Cell[BoxData[
  StyleBox["X", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "5dfcff63-c45e-46f8-8cc5-3b2798a148a1"],
 " basis then gives a Born probability no stabilizer state can produce, since \
a Pauli measurement on a stabilizer state yields only ",
 Cell[BoxData["0"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "b79ad342-46d2-4575-a822-ac362a7f33e4"],
 ", ",
 Cell[BoxData[
  FractionBox["1", "2"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "25240264-f8e4-41ff-8b13-ae09d4c980ba"],
 ", or ",
 Cell[BoxData["1"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "86d4f7c7-ecef-4863-a561-58623bc6827d"],
 ". The frame computes that expectation ",
 StyleBox["natively", "TI"],
 ", by the same closed-form Pauli sandwich the bare tableau uses, one term \
per pair of components, never forming the ",
 Cell[BoxData[
  SuperscriptBox["2", 
   StyleBox["n", "TI"]]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "1b8b4cf0-e1b4-4b40-8d50-5e9cadd42196"],
 " vector. Read ",
 Cell[BoxData[
  RowBox[{
   StyleBox["\[LeftAngleBracket]",
    SpanMaxSize->1], 
   StyleBox["X", "TI"], "\[VeryThinSpace]", 
   StyleBox["\[RightAngleBracket]",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "1b9d6f78-cd65-47f2-b899-329a53acee54"],
 " straight from the frame:"
}], "Text",ExpressionUUID->"ded64ba4-41ed-4f12-880b-79e40857eff9"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"Tmagic", "[", 
   RowBox[{"\"\<Expectation\>\"", ",", " ", "\"\<X\>\""}], "]"}], " ", "//", 
  " ", "FullSimplify"}]], "Input",
 CellLabel->
  "In[99]:= ",ExpressionUUID->"80600c95-7df5-4c91-b4bd-2364199f70d3"],

Cell[BoxData[
 FractionBox["1", 
  SqrtBox["2"]]], "Output",
 CellLabel->
  "Out[99]= ",ExpressionUUID->"d8cfe7e8-ff00-4e85-beb8-601b5ef98c8c"]
}, Open  ]],

Cell[TextData[{
 "The answer is ",
 Cell[BoxData[
  RowBox[{"1", "/", 
   SqrtBox["2"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "7cb76a15-ffa5-42a4-817a-395f0d9adf13"],
 ", so the Born probability of the ",
 Cell[BoxData[
  RowBox[{"+", "1"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "cb165f6b-2ba0-48ba-aca6-82a736697354"],
 " outcome is ",
 Cell[BoxData[
  RowBox[{
   StyleBox["(",
    SpanMaxSize->1], 
   RowBox[{"1", "+", 
    StyleBox["\[LeftAngleBracket]",
     SpanMaxSize->1], 
    StyleBox["X", "TI"], "\[VeryThinSpace]", 
    StyleBox["\[RightAngleBracket]",
     SpanMaxSize->1]}], 
   StyleBox[")",
    SpanMaxSize->1], "/", "2"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "a3924a1b-f1f8-4537-9cdb-e54374555e61"],
 ":"
}], "Text",ExpressionUUID->"78172c2b-d9a2-42dc-9a22-9de9978ee407"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"(", 
    RowBox[{"1", " ", "+", " ", 
     RowBox[{"Tmagic", "[", 
      RowBox[{"\"\<Expectation\>\"", ",", " ", "\"\<X\>\""}], "]"}]}], ")"}], 
   " ", "/", " ", "2"}], " ", "//", " ", "FullSimplify"}]], "Input",
 CellLabel->
  "In[100]:= ",ExpressionUUID->"fc5998e3-325c-4b79-b4c4-2bd16833f69d"],

Cell[BoxData[
 RowBox[{
  FractionBox["1", "4"], " ", 
  RowBox[{"(", 
   RowBox[{"2", "+", 
    SqrtBox["2"]}], ")"}]}]], "Output",
 CellLabel->
  "Out[100]= ",ExpressionUUID->"231719fe-dae3-4151-a4bc-22f0ed94a8ed"]
}, Open  ]],

Cell[TextData[{
 "The result is ",
 Cell[BoxData[
  RowBox[{
   StyleBox["(",
    SpanMaxSize->1], 
   RowBox[{"2", "+", 
    SqrtBox["2"]}], 
   StyleBox[")",
    SpanMaxSize->1], "/", "4", "\[TildeTilde]", "0.854"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "baa8f441-2a5c-4c37-85d1-987657b3dc09"],
 ", the irrational probability that is the fingerprint of genuine magic, the \
same value the dense state vector gives but now obtained without ever \
materializing it:"
}], "Text",ExpressionUUID->"86a35e03-cfe9-4517-b255-b7673dd4e425"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"(", 
     RowBox[{"1", " ", "+", " ", 
      RowBox[{"Tmagic", "[", 
       RowBox[{"\"\<Expectation\>\"", ",", " ", "\"\<X\>\""}], "]"}]}], ")"}],
     " ", "/", " ", "2"}], " ", "==", " ", 
   RowBox[{
    RowBox[{"Abs", "[", 
     RowBox[{
      RowBox[{"Normalize", "[", 
       RowBox[{"{", 
        RowBox[{"1", ",", " ", "1"}], "}"}], "]"}], " ", ".", " ", 
      RowBox[{"Normal", "[", 
       RowBox[{"Tmagic", "[", "\"\<StateVector\>\"", "]"}], "]"}]}], "]"}], "^",
     "2"}]}], " ", "//", " ", "FullSimplify"}]], "Input",
 CellLabel->
  "In[101]:= ",ExpressionUUID->"cffc6f1f-7ec0-4e9a-b338-bceb0264b3ad"],

Cell[BoxData["True"], "Output",
 CellLabel->
  "Out[101]= ",ExpressionUUID->"a5d97d7f-637e-453c-9643-2acb0ee99b04"]
}, Open  ]],

Cell[TextData[{
 "The frame has carried the computation across the Clifford boundary that the \
tableau alone cannot cross, and answered an observable there at a cost set by \
the rank, not by ",
 Cell[BoxData[
  SuperscriptBox["2", 
   StyleBox["n", "TI"]]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "213b5945-ae7d-4e91-8141-67ea518c526e"],
 "."
}], "Text",ExpressionUUID->"033193c2-006c-4cfc-b078-67951b35014c"],

Cell[TextData[{
 "That same rank decomposition is where the cost lives, and the frame can \
prune it. Each ",
 Cell[BoxData[
  StyleBox["T", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "52ed52d4-de02-477e-a95b-e068441b9ed0"],
 " doubles the term count, but the component vectors span a space of \
dimension at most ",
 Cell[BoxData[
  SuperscriptBox["2", 
   StyleBox["n", "TI"]]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "1ee4b516-7327-421c-a100-908bcee0c71d"],
 ", so a frame routinely carries far more terms than it needs. The ",
 Cell[BoxData["\"\<Compress\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "8971aa45-fe75-44b6-96a0-07ed0b055797"],
 " method collapses it onto a maximal linearly independent subset, \
re-expressing the ",
 StyleBox["exact same state", "TI"],
 " on fewer components. Four ",
 Cell[BoxData[
  StyleBox["T", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "c6c57ec7-19fa-4cfa-a529-9e5689e5c76c"],
 " gates on ",
 Cell[BoxData[
  TemplateBox[{"+"},
   "Ket"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "6af9e577-9115-4238-a148-07af99768c9f"],
 " build a sixteen-term frame whose span is only two:"
}], "Text",ExpressionUUID->"b66d8340-0d01-420d-9554-d980a7e13e7f"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"overMagic", " ", "=", " ", 
   RowBox[{
    RowBox[{"PauliStabilizer", "[", "1", "]"}], "[", 
    RowBox[{"Join", "[", 
     RowBox[{
      RowBox[{"{", "\"\<H\>\"", "}"}], ",", " ", 
      RowBox[{"Table", "[", 
       RowBox[{"\"\<T\>\"", ",", " ", "4"}], "]"}]}], "]"}], "]"}]}], ";"}], "\n", 
 RowBox[{"{", 
  RowBox[{
   RowBox[{"overMagic", "[", "\"\<Length\>\"", "]"}], ",", " ", 
   RowBox[{
    RowBox[{"overMagic", "[", "\"\<Compress\>\"", "]"}], "[", "\"\<Length\>\"",
     "]"}]}], "}"}]}], "Input",
 CellLabel->
  "In[102]:= ",ExpressionUUID->"2c2b76cc-030e-4801-ac93-9e16766c0156"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"16", ",", "2"}], "}"}]], "Output",
 CellLabel->
  "Out[102]= ",ExpressionUUID->"9b2c5bed-e73b-4c01-aa57-a3f021a4e65f"]
}, Open  ]],

Cell["\<\
Sixteen terms collapse to two, the whole reach a single qubit ever had, and \
the state is unchanged:\
\>", "Text",ExpressionUUID->"f7926e2a-1bd5-41da-96bb-031fa4abcc83"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"overMagic", "[", "\"\<Compress\>\"", "]"}], "[", "\"\<State\>\"", 
   "]"}], " ", "==", " ", 
  RowBox[{"overMagic", "[", "\"\<State\>\"", "]"}]}]], "Input",
 CellLabel->
  "In[103]:= ",ExpressionUUID->"67435cb2-71ca-4f60-ab93-0a20b41ba4bd"],

Cell[BoxData["True"], "Output",
 CellLabel->
  "Out[103]= ",ExpressionUUID->"402e9d3c-5086-4533-9204-5d00c7564981"]
}, Open  ]],

Cell[TextData[{
 "This is a span-dimension cap: exact, bounded by ",
 Cell[BoxData[
  SuperscriptBox["2", 
   StyleBox["n", "TI"]]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "06f6f3db-cc54-451a-8c1a-fa3975460f89"],
 ", and free. It is ",
 StyleBox["not", "TI"],
 " the optimal stabilizer rank, the Bravyi-Gosset ",
 Cell[BoxData[
  SuperscriptBox["2", 
   StyleBox[
    RowBox[{"\[Alpha]", "t"}], "TI"]]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "ce456541-9977-4a67-9713-0b07320a192e"],
 " with ",
 Cell[BoxData[
  RowBox[{
   StyleBox["\[Alpha]", "TI"], "\[TildeTilde]", "0.4"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "067ca3fa-304a-49eb-b08d-f1a4eb644568"],
 " that merges terms no basis can separate; reaching that bound is the \
harder, still-open target. But the purely redundant blow-up is gone."
}], "Text",ExpressionUUID->"4fc2e2f6-5b8f-41d0-af89-d0cf9ad8b24d"],

Cell[TextData[{
 "For one important family the closed form is sharper still. A circuit of ",
 Cell[BoxData[
  StyleBox["T", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "cec38ea9-1a38-4abf-8862-f04c807b93da"],
 ", ",
 Cell[BoxData[
  StyleBox["S", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "683313f9-45d4-4b6a-b9d8-e35de2f677ef"],
 ", ",
 Cell[BoxData[
  StyleBox["Z", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "a418f2dc-942a-4702-bded-fd18466da7b7"],
 ", and controlled-",
 Cell[BoxData[
  StyleBox["Z", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "cdd6639b-e316-4879-b58e-75a494844e91"],
 " gates with ",
 StyleBox["no Hadamard", "TI"],
 ", the diagonal or CNOT-dihedral fragment, acting on ",
 Cell[BoxData[
  SuperscriptBox[
   TemplateBox[{"+"},
    "Ket"], 
   RowBox[{"\[CircleTimes]", 
    StyleBox["n", "TI"]}]]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "ac7f4988-e1d8-4679-adec-5981ba95a6d1"],
 " keeps every qubit value a linear function of the inputs and folds all the \
magic into a single phase polynomial valued in the eighth roots of unity. The \
state is then rank one: any amplitude is one closed-form term, ",
 Cell[BoxData[
  RowBox[{
   RowBox[{
    TemplateBox[{
      StyleBox["y", "TI"]},
     "Bra"], 
    StyleBox["U", "TI"], 
    SuperscriptBox[
     TemplateBox[{"+"},
      "Ket"], 
     RowBox[{"\[CircleTimes]", 
      StyleBox["n", "TI"]}]]}], "=", 
   RowBox[{
    SuperscriptBox["2", 
     RowBox[{"-", 
      StyleBox["n", "TI"], "/", "2"}]], 
    SuperscriptBox[
     StyleBox["\[Omega]", "TI"], 
     RowBox[{"\[CurlyPhi]", 
      StyleBox["(",
       SpanMaxSize->1], 
      StyleBox["y", "TI"], 
      StyleBox[")",
       SpanMaxSize->1]}]]}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "268f1097-45f3-4bb4-bba9-cf2559fcd0e4"],
 " with ",
 Cell[BoxData[
  RowBox[{
   StyleBox["\[Omega]", "TI"], "=", 
   SuperscriptBox[
    StyleBox["e", "TI"], 
    RowBox[{
     StyleBox["i", "TI"], "\[Pi]", "/", "4"}]]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "b965bb38-000a-4eeb-9ba9-b78a1c2cb868"],
 ", computed by a single ",
 Cell[BoxData[
  SubscriptBox["\|01d53d", "2"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "d4934b93-6f75-45b4-ba2a-77255a37c6a3"],
 " linear solve, ",
 StyleBox["flat in ", "TI"],
 Cell[BoxData[
  StyleBox["n", "TI"]], "InlineFormula", "TI",
  FontSize->0.9 Inherited,ExpressionUUID->
  "144eec73-4310-4eb0-8a44-8ef24436ac15"],
 ". The stabilizer backend builds this representation on request, with the \
option ",
 Cell[BoxData[
  RowBox[{"\"\<Compress\>\"", " ", "->", " ", "\"\<PhasePolynomial\>\""}]], 
  "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "a21cf529-4edd-4e48-9f9e-f0f83f28e30f"],
 ". Build a diagonal magic circuit on twenty qubits, a ",
 Cell[BoxData[
  StyleBox["T", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "38221248-468d-49db-a7a4-99c90cb8c942"],
 " on every wire, a ladder of controlled-",
 Cell[BoxData[
  StyleBox["Z", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "2a9b2cf9-eaa5-447a-92e9-ff4a24da0ba3"],
 " gates, and one doubly-controlled ",
 Cell[BoxData[
  StyleBox["Z", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "909bf97d-c428-484d-8231-bf545840e249"],
 " (written ",
 Cell[BoxData[
  RowBox[{"\"\<C\>\"", "[", 
   RowBox[{
    RowBox[{"\"\<Z\>\"", " ", "->", " ", "3"}], ",", " ", 
    RowBox[{"{", 
     RowBox[{"1", ",", " ", "2"}], "}"}]}], "]"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "f5c95c9f-bbd1-46fb-b499-ad328aba1a1e"],
 ", a three-qubit diagonal gate the term-by-term frame cannot even represent):"
}], "Text",ExpressionUUID->"a23c50df-2f1c-429b-b558-ceb87e9ad1b5"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"diagMagic", " ", "=", " ", 
   RowBox[{"QuantumCircuitOperator", "[", 
    RowBox[{"Join", "[", "\n", "   ", 
     RowBox[{
      RowBox[{"Table", "[", 
       RowBox[{
        RowBox[{"\"\<T\>\"", " ", "->", " ", "q"}], ",", " ", 
        RowBox[{"{", 
         RowBox[{"q", ",", " ", "20"}], "}"}]}], "]"}], ",", "\n", "   ", 
      RowBox[{"Table", "[", 
       RowBox[{
        RowBox[{"\"\<CZ\>\"", " ", "->", " ", 
         RowBox[{"{", 
          RowBox[{"q", ",", " ", 
           RowBox[{"q", " ", "+", " ", "1"}]}], "}"}]}], ",", " ", 
        RowBox[{"{", 
         RowBox[{"q", ",", " ", "1", ",", " ", "19"}], "}"}]}], "]"}], ",", 
      "\n", "   ", 
      RowBox[{"{", 
       RowBox[{"\"\<C\>\"", "[", 
        RowBox[{
         RowBox[{"\"\<Z\>\"", " ", "->", " ", "3"}], ",", " ", 
         RowBox[{"{", 
          RowBox[{"1", ",", " ", "2"}], "}"}]}], "]"}], "}"}]}], "]"}], 
    "]"}]}], ";"}], "\n", 
 RowBox[{"pp", " ", "=", " ", 
  RowBox[{"diagMagic", "[", 
   RowBox[{"Method", " ", "->", " ", 
    RowBox[{"{", 
     RowBox[{"\"\<Stabilizer\>\"", ",", " ", 
      RowBox[{"\"\<Compress\>\"", " ", "->", 
       " ", "\"\<PhasePolynomial\>\""}]}], "}"}]}], "]"}]}]}], "Input",
 CellLabel->
  "In[104]:= ",ExpressionUUID->"fc83d677-6ee8-4735-907a-f23325e96b64"],

