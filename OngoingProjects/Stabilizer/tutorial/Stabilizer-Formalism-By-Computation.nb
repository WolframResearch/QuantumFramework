       Dynamic[Typeset`open$$], ImageSize -> Automatic]},
     "SummaryPanel"],
    DynamicModuleValues:>{}], "]"}],
  Wolfram`QuantumFramework`GraphState[<|
   "Graph" -> Graph[{1, 2, 3, 4}, {Null, 
