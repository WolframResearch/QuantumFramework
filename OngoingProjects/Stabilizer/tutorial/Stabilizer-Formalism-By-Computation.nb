Cell[TextData[{
 "Its amplitudes match the Schr\[ODoubleDot]dinger answer up to a global \
phase, here a factor of ",
 Cell[BoxData[
  StyleBox["i", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "fa49315f-e8bb-4458-97df-cc47170b247e"],
 ":"
}], "Text",ExpressionUUID->"ad2a3686-1f5d-4af3-9478-030a95af881c"],

