Cell[TextData[{
 "The outcomes are exactly ",
 Cell[BoxData[
  RowBox[{
   RowBox[{"{", "0"}], ",", "0", ",", 
   RowBox[{"0", "}"}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "e02a4b3b-d912-4851-b8c8-da066143a2d1"],
 " and ",
 Cell[BoxData[
  RowBox[{
   RowBox[{"{", "1"}], ",", "1", ",", 
   RowBox[{"1", "}"}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "82971119-4319-4900-907e-34a087b88956"],
 ": the GHZ state never returns a split string with some 0s and some 1s, \
which is the perfect three-body correlation. We can also measure a joint \
Pauli observable directly, for instance the parity ",
 Cell[BoxData[
  StyleBox[
   RowBox[{"Z", "Z"}], "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "5e71a169-befd-483f-953e-c0665f32b506"],
 " on the Bell state, which is deterministic and equal to ",
 Cell[BoxData[
  RowBox[{"+", "1"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "68da369e-1fe8-4886-80d3-d10934ed67c9"],
 ":"
}], "Text",ExpressionUUID->"e6b15fec-a417-4759-a523-47179a518254"],

