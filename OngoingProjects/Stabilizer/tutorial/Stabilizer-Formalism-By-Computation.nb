}, Open  ]],

Cell[TextData[{
 "Different states are fixed by different operators. The state ",
 Cell[BoxData[
  RowBox[{
   TemplateBox[{"+"},
    "Ket"], "=", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{
      TemplateBox[{"0"},
       "Ket"], "+", 
      TemplateBox[{"1"},
       "Ket"]}], ")"}], "/", 
    SqrtBox["2"]}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "9e6cd639-11c1-4f3f-9d07-6bb18b32e68b"],
 " is the ",
 Cell[BoxData[
  RowBox[{"+", "1"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "8608077c-472f-4256-954d-7d05d5b2ce5a"],
 " eigenstate of ",
 Cell[BoxData[
  StyleBox["X", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "20855f36-7759-4679-b661-f9456ea6aede"],
 ", and a Hadamard turns one into the other. Apply ",
 Cell[BoxData[
  StyleBox["H", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "c0722560-08cc-4bb8-9466-1f90e5b8b8f2"],
 " to ",
 Cell[BoxData[
  TemplateBox[{"0"},
   "Ket"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "4c51086e-9bb3-46ea-8e30-953d4d9e5998"],
 " and read the new stabilizer:"
}], "Text",ExpressionUUID->"05aab3ce-ab27-4159-88ec-4b5fcd6badd3"],

