}, Open  ]],

Cell[TextData[{
 "The decisive computation is the whole table at once. Run the syndrome over \
all fifteen single-qubit errors, ",
 Cell[BoxData[
  StyleBox["X", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "98a952a9-0f2e-4ba7-b5c7-8b0c7c28bc2d"],
 ", ",
 Cell[BoxData[
  StyleBox["Y", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "8231d1f3-0bc3-4d58-8b42-e37088279346"],
 ", and ",
 Cell[BoxData[
  StyleBox["Z", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "4a15c8dd-a0b9-446b-bb58-8f22f650ded9"],
 " on each of the five qubits:"
}], "Text",ExpressionUUID->"590c8be4-ec1b-4c41-8551-b0b14fe3d792"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"errors", " ", "=", " ", 
   RowBox[{"Flatten", "[", 
    RowBox[{
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"p", " ", "->", " ", "q"}], "}"}], ",", " ", 
       RowBox[{"{", 
        RowBox[{"p", ",", " ", 
         RowBox[{"{", 
          RowBox[{"\"\<X\>\"", ",", " ", "\"\<Y\>\"", ",", " ", "\"\<Z\>\""}],
           "}"}]}], "}"}], ",", " ", 
       RowBox[{"{", 
        RowBox[{"q", ",", " ", "1", ",", " ", "5"}], "}"}]}], "]"}], ",", " ",
      "1"}], "]"}]}], ";"}], "\n", 
 RowBox[{"AssociationMap", "[", 
  RowBox[{"syndrome", ",", " ", "errors"}], "]"}]}], "Input",
 CellLabel->
  "In[85]:= ",ExpressionUUID->"54594dc6-3f44-45e8-9af2-7c0c731426fe"],

