    SqrtBox["2"]]}], "}"}]], "Output",
 CellLabel->
  "Out[14]= ",ExpressionUUID->"ddabe2c8-ae6b-4dbc-bd22-6449d44f11be"]
}, Open  ]],

Cell["\<\
For everything observable, probabilities, expectation values, entanglement, \
the global phase is irrelevant, so this costs us nothing in practice. We flag \
it now because it is the one place where the cheap representation is \
genuinely less informative than the dense one.\
\>", "Text",ExpressionUUID->"c236d76d-4b83-41a7-86e5-c46e9ea35eda"],

Cell["The essentials of the one-qubit picture:", "Text",ExpressionUUID->"c7446674-aac4-489d-9b36-7ed2f99909aa"],

Cell[TextData[{
 "A one-qubit stabilizer state is named by the single Pauli operator that \
fixes it: ",
 Cell[BoxData[
  StyleBox["Z", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "a437f7f9-ae73-4115-98c1-c3fb6ec92f6a"],
 " for ",
 Cell[BoxData[
  TemplateBox[{"0"},
   "Ket"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "299348c4-5380-4abc-9286-f8fd01b2d4c6"],
 ", ",
 Cell[BoxData[
  StyleBox["X", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "9123fd4b-89db-4a88-92a7-120ab07243c5"],
 " for ",
 Cell[BoxData[
  TemplateBox[{"+"},
   "Ket"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "93c796f4-717c-4c3c-b973-ada407a0995a"],
 ", ",
 Cell[BoxData[
  RowBox[{"-", 
   StyleBox["Z", "TI"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "6692289c-798c-4cbe-b83d-c8be3cd253c4"],
 " for ",
 Cell[BoxData[
  TemplateBox[{"1"},
   "Ket"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "d15dabae-2a6f-4a1b-89e2-174f04e998ad"],
 "."
}], "Item",ExpressionUUID->"e83808eb-4358-4539-92b0-383905653596"],

Cell[TextData[{
 Cell[BoxData["PauliStabilizer"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "d347065a-a4a8-4f8d-8feb-a50814dad681"],
 " carries that operator, not the amplitudes; the ",
 Cell[BoxData["\"\<State\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "747087ff-5d74-4079-9512-ae3e84f452d8"],
 " property hands back a full ",
 Cell[BoxData["QuantumState"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "8a0fffb4-f5ef-475d-9d5c-e36a97667ad0"],
 " on demand, and ",
 Cell[BoxData["\"\<StateVector\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "dc6f5434-71e2-44f5-896e-0db7378fb428"],
 " on that object gives the raw ",
 Cell[BoxData[
  SuperscriptBox["2", 
   StyleBox["n", "TI"]]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "67f5c172-7b39-4240-9c57-918678c2f04e"],
 " amplitudes."
}], "Item",ExpressionUUID->"15d0acb8-ec0d-42bc-ac03-00e86b652fd4"],

Cell["\<\
The reconstructed vector is exact up to a global phase, which never affects \
an observable.\
\>", "Item",ExpressionUUID->"9fd4c7b3-911a-412d-aa0e-0d3dfaebf0f2"],

Cell[TextData[{
 "The tableau: ",
 Cell[BoxData[
  StyleBox["n", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "e35a5be2-cce3-4b8c-a100-203fec40f898"],
 " generators instead of ",
 Cell[BoxData[
  SuperscriptBox["2", 
   StyleBox["n", "TI"]]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "c8aae586-de17-49bf-9dcb-0db79db346e6"],
 " amplitudes"
}], "Section",ExpressionUUID->"a9aefd09-396b-41d2-95b4-6db22d3d2f80"],

Cell[TextData[{
 "For ",
 Cell[BoxData[
  StyleBox["n", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "6947dfda-1e8b-4945-977d-f8efee44380a"],
 " qubits the idea scales because the stabilizer group is generated by just \
",
 Cell[BoxData[
  StyleBox["n", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "0eaa8d55-361c-4d0d-86fa-70bb92b95a94"],
 " commuting, independent Pauli strings, and each Pauli string of length ",
 Cell[BoxData[
  StyleBox["n", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "6c636e22-ce7a-4e90-be14-15f8ac739151"],
 " is two bits per qubit: an ",
 Cell[BoxData[
  StyleBox["X", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "970c4317-c89e-4859-ad51-60ab449d3ca2"],
 "-exponent and a ",
 Cell[BoxData[
  StyleBox["Z", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "84af9f80-d04d-40a6-a473-1de2b80420bc"],
 "-exponent, since ",
 Cell[BoxData[
  RowBox[{
   StyleBox["Y", "TI"], "=", 
   StyleBox["i", "TI"], 
   StyleBox["X", "TI"], 
   StyleBox["Z", "TI"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "8e7ec583-49e5-430c-b3bb-85767799aa32"],
 ". So a stabilizer state is a binary matrix of shape ",
 Cell[BoxData[
  RowBox[{
   StyleBox["n", "TI"], "\[Times]", "2", 
   StyleBox["n", "TI"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "eb64bedb-678f-45c1-86e6-1623e04b237b"],
 " together with ",
 Cell[BoxData[
  StyleBox["n", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "c6cde993-3a84-4630-ad74-46560bb14d22"],
 " signs, which is ",
 Cell[BoxData[
  RowBox[{
   StyleBox["O", "TI"], 
   StyleBox["(",
    SpanMaxSize->1], 
   SuperscriptBox[
    StyleBox["n", "TI"], "2"], 
   StyleBox[")",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "3e9c8c6b-4265-48d8-9916-076117ea18da"],
 " bits in place of ",
 Cell[BoxData[
  SuperscriptBox["2", 
   StyleBox["n", "TI"]]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "02fcf307-13e8-48cc-b134-0ffb8c802ba0"],
 " amplitudes. This binary ",
 Cell[BoxData[
  RowBox[{
   StyleBox["(",
    SpanMaxSize->1], 
   RowBox[{
    StyleBox["X", "TI"], "\[VerticalSeparator]", 
    StyleBox["Z", "TI"]}], 
   StyleBox[")",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "71390949-7c5d-43cb-a4e7-b9a2d86151c3"],
 " encoding is the ",
 StyleBox["symplectic representation", "TI"],
 " of the Pauli group."
}], "Text",ExpressionUUID->"a5c95bf2-e4e3-4a37-a890-206ebe78b07a"],

Cell[TextData[{
 "Look at the two-qubit register ",
 Cell[BoxData[
  TemplateBox[{"00"},
   "Ket"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "96143a66-adf7-4718-9609-f4b2eb625621"],
 ". The object itself previews the generators and a tableau grid:"
}], "Text",ExpressionUUID->"5071c686-966d-4b44-a62d-772a9abdca87"],

