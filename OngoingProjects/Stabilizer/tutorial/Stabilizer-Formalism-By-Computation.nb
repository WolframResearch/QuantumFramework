    RowBox[{"\"\<Expectation\>\"", ",", " ", "\"\<XX\>\""}], "]"}], ",", " ", 
   
   RowBox[{"bell", "[", 
    RowBox[{"\"\<Expectation\>\"", ",", " ", "\"\<ZI\>\""}], "]"}]}], 
  "}"}]], "Input",
