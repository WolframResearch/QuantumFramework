Cell[TextData[{
 "What comes back is an ordinary ",
 Cell[BoxData["QuantumState"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "36f3f3d8-e284-4547-826c-9dca5e1d8072"],
 " object, so a stabilizer state drops straight into the rest of the \
framework. Chaining ",
 Cell[BoxData["\"\<StateVector\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "3d225711-99b3-4aff-a3ad-ba4a2d263611"],
 " on that object reads off the raw ",
 Cell[BoxData[
  SuperscriptBox["2", 
   StyleBox["n", "TI"]]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "a2039bb7-5e6d-4994-85c0-731597678031"],
 " amplitudes, here the single column ",
 Cell[BoxData[
  TemplateBox[{"0"},
   "Ket"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "4473f8f6-8908-4794-ad9e-49a524943479"],
 ":"
}], "Text",ExpressionUUID->"ab15129d-e560-4462-97e1-3a8e70457bc6"],

