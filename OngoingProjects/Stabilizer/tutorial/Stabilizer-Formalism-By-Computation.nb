Cell[TextData[{
 "The stabilizers show the structure: two ",
 Cell[BoxData[
  StyleBox["X", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "0553d4a3-015f-469a-8455-4ce66fecbc05"],
 "-type generators, and a single ",
