Cell[TextData[{
 "The raw symplectic data is ",
 Cell[BoxData["\"\<Tableau\>\""], "InlineFormula",ExpressionUUID->
  "8c625b45-5333-4022-b676-c49d91b10cc2"],
 ", a rank-3 array stacking the ",
 Cell[BoxData[
  StyleBox["X", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "a6e5a371-4556-45bf-87e5-1bbc0b114ebf"],
 " block above the ",
 Cell[BoxData[
  StyleBox["Z", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "54d9385a-ff6b-408d-be07-9d409f8043b3"],
 " block (shape ",
 Cell[BoxData[
  RowBox[{"2", "\[Times]", 
   StyleBox["n", "TI"], "\[Times]", "2", 
   StyleBox["n", "TI"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "f7ab5678-a7c3-4e0e-998c-f1ebb8adcbb8"],
 ", here ",
 Cell[BoxData[
  RowBox[{"2", "\[Times]", "2", "\[Times]", "4"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "6e9c090a-c410-440d-b1e1-e9a0c05be8c8"],
 ": two blocks, ",
 Cell[BoxData[
  RowBox[{
   StyleBox["n", "TI"], "=", "2"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "1dc54914-1f6b-4036-ac33-b19486903709"],
 " qubits, ",
 Cell[BoxData[
  RowBox[{"2", 
   StyleBox["n", "TI"], "=", "4"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "6302f735-0d7a-4cef-8e5d-a9bffd4e61fc"],
 " rows):"
}], "Text",ExpressionUUID->"d23b5ba2-25d0-4691-871a-ae8f313c9051"],

