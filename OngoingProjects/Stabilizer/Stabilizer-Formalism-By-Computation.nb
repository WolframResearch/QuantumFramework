Cell[TextData[{
 "The stabilizer flips from ",
 Cell[BoxData[
  StyleBox["Z", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "3f05082e-bdac-4144-899b-ca0a4982da21"],
 " to ",
 Cell[BoxData[
  StyleBox["X", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "2f9484af-089d-4ea6-af38-0c75d7f07ee7"],
 ", the signature of ",
 Cell[BoxData[
  TemplateBox[{"+"},
   "Ket"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "c2cd1d3d-86c1-4139-800a-08f450692af8"],
 ". The state vector confirms it:"
}], "Text",ExpressionUUID->"c3d35afc-a588-4224-b9af-6aa3e3d3f69e"],

