 "."
}], "Item",ExpressionUUID->"ae3b3bbe-05cf-4348-81e9-ce60394c5a51"],

Cell[TextData[{
 StyleBox["Sibling heads", "TI"],
 ": ",
 Cell[BoxData[
 "StabilizerFrame"], "InlineFormula",ExpressionUUID->
  "a6d77a4d-cba5-4a28-8a39-7fc39db0f82c"],
 ", ",
 Cell[BoxData[
 "CliffordChannel"], "InlineFormula",ExpressionUUID->
