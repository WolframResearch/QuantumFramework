Cell[TextData[{
 "Its dimensions confirm the ",
 Cell[BoxData[
  RowBox[{
   RowBox[{"{", "2"}], 
   RowBox[{",", "\[ThinSpace]"}], 
   StyleBox["n", "TI"], 
   RowBox[{",", "\[ThinSpace]"}], 
