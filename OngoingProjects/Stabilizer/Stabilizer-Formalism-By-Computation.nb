Cell[TextData[{
 "Four of the eight amplitudes are ",
 Cell[BoxData[
  RowBox[{"1", "/", "2"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "ffe16d2b-4a56-440c-87d7-bc941616e75b"],
 " and the rest vanish. The support ",
 Cell[BoxData[
  RowBox[{
   RowBox[{"{", "000"}], 
   RowBox[{",", "\[ThinSpace]"}], 
   RowBox[{"011", ",", "101"}], 
   RowBox[{",", "\[ThinSpace]"}], 
   RowBox[{"110", "}"}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "1a8f8db4-9ee2-40f5-affd-a1b091f5cdc9"],
 " is exactly the even-parity strings ",
 Cell[BoxData[
  RowBox[{
   SubscriptBox[
    StyleBox["x", "TI"], "1"], "\[CirclePlus]", 
   SubscriptBox[
    StyleBox["x", "TI"], "2"], "\[CirclePlus]", 
   SubscriptBox[
    StyleBox["x", "TI"], "3"], "=", "0"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "1d33ae0f-2725-4874-b21a-2fc20ad945c5"],
 ", a two-dimensional subspace of ",
 Cell[BoxData[
  SubsuperscriptBox["\|01d53d", "2", "3"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "3ad9e753-38d2-4b19-a201-e96d210d000d"],
 " cut out by the generator ",
 Cell[BoxData[
  StyleBox[
   RowBox[{"Z", "Z", "Z"}], "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "bf8a78bb-054d-4578-8dec-bc0d25e128c4"],
 ". That ",
 Cell[BoxData[
  StyleBox[
   RowBox[{"Z", "Z", "Z"}], "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "2aaa51de-c3a2-4e73-a6c5-4f81465a75a5"],
 " really sits in the stabilizer group shows up as a ",
 Cell[BoxData[
  RowBox[{"+", "1"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "4652e8e8-e208-42c8-93bb-59ac25b6a30a"],
 " expectation value:"
}], "Text",ExpressionUUID->"b4201672-257b-44ae-a2a0-84a53241de36"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"psAffineDemo", "[", 
  RowBox[{"\"\<Expectation\>\"", ",", " ", "\"\<ZZZ\>\""}], "]"}]], "Input",
 CellLabel->
  "In[25]:= ",ExpressionUUID->"cad38450-86ed-4c25-b71b-5d31ec009ef7"],

Cell[BoxData["1"], "Output",
 CellLabel->
  "Out[25]= ",ExpressionUUID->"9fe1c6d0-8ba7-41ce-847a-aa02a122d3cd"]
}, Open  ]],

Cell[TextData[{
 "That is the whole anatomy of a stabilizer state: a uniform superposition \
over a coset, with the relative signs fixed by the generator signs. The \
exponential compression is now intuitive: naming the subspace and the signs \
costs ",
 Cell[BoxData[
  RowBox[{
   StyleBox["O", "TI"], 
   StyleBox["(",
    SpanMaxSize->1], 
   SuperscriptBox[
    StyleBox["n", "TI"], "2"], 
   StyleBox[")",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "1081ce70-5940-4295-af3f-c617bf3e304a"],
 " bits, while listing the amplitudes costs ",
 Cell[BoxData[
  SuperscriptBox["2", 
   StyleBox["n", "TI"]]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "10a17231-9da5-48f7-98c9-25823f934f33"],
 "."
}], "Text",ExpressionUUID->"db6fa518-4734-45b6-b30a-70ddb79cf08c"],

Cell[TextData[{
 "Why is any of this fast? Because of what a ",
 StyleBox["Clifford", "TI"],
 " gate is: precisely a unitary that conjugates every Pauli to a Pauli, that \
is, an element of the normalizer of the Pauli group. The Hadamard, the phase \
gate ",
 Cell[BoxData[
  StyleBox["S", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "f588c9e0-499c-49b0-a41b-110133c85551"],
 ", and CNOT generate the whole Clifford group, and they are exactly the \
gates the tableau handles. Updating the state therefore means updating each \
generator, ",
 Cell[BoxData[
  RowBox[{
   StyleBox["g", "TI"], "\[Function]", 
   StyleBox["U", "TI"], 
   StyleBox["g", "TI"], 
   SuperscriptBox[
    StyleBox["U", "TI"], "\[Dagger]"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "cf189720-961a-4e30-b3b2-fd7e45ec3372"],
 ", which is a fixed local rewrite of two bits and a sign per affected qubit. \
This is the content of the Gottesman-Knill theorem: a circuit of Clifford \
gates on a stabilizer input can be simulated in time polynomial in ",
 Cell[BoxData[
  StyleBox["n", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "06c33824-2645-4215-892d-ccf597971e70"],
 ", with ",
 Cell[BoxData[
  RowBox[{
   StyleBox["O", "TI"], 
   StyleBox["(",
    SpanMaxSize->1], 
   StyleBox["n", "TI"], 
   StyleBox[")",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "0a950cb8-89e8-4ab1-9091-3d7f23f6f7b9"],
 " work per gate, rather than the ",
 Cell[BoxData[
  RowBox[{
   StyleBox["O", "TI"], 
   StyleBox["(",
    SpanMaxSize->1], 
   SuperscriptBox["2", 
    StyleBox["n", "TI"]], 
   StyleBox[")",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "026c7191-f4ba-41b0-9e44-0d90fb1f6d1f"],
 " of dense state-vector evolution. The single-qubit gate methods (",
 Cell[BoxData["\"\<H\>\""], "InlineFormula",ExpressionUUID->
  "84dd29cc-3e35-495b-8f4e-2ec30002254e"],
 ", ",
 Cell[BoxData["\"\<S\>\""], "InlineFormula",ExpressionUUID->
  "33fe2ff1-3440-4701-945c-71972d09a3cc"],
 ", ",
 Cell[BoxData["\"\<X\>\""], "InlineFormula",ExpressionUUID->
  "06ab8de0-d724-40f7-8cb2-4a7a1f670e16"],
 ", ",
 Cell[BoxData["\"\<Y\>\""], "InlineFormula",ExpressionUUID->
  "bec9c9d0-39dd-46f3-aefa-fba4aad028af"],
 ", ",
 Cell[BoxData["\"\<Z\>\""], "InlineFormula",ExpressionUUID->
  "51853c29-855b-4482-b6af-3dc7c422dbf7"],
 ", ",
 Cell[BoxData["\"\<V\>\""], "InlineFormula",ExpressionUUID->
  "56084573-4a9b-4e3f-9b93-b1a0895b6ae6"],
 " for ",
 Cell[BoxData[
  SqrtBox[
   StyleBox["X", "TI"]]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "c5955888-a46c-4534-aa79-921a32e4df73"],
 ", and ",
 Cell[BoxData[
  RowBox[{"SuperDagger", "[", "\"\<S\>\"", "]"}]], "InlineFormula",
  ExpressionUUID->"ecb5beb4-6968-4382-a899-63858051639c"],
 ") and the two-qubit ",
 Cell[BoxData["\"\<CNOT\>\""], "InlineFormula",ExpressionUUID->
  "823c4e56-5cb6-4d53-b599-b007294c9911"],
 ", ",
 Cell[BoxData["\"\<CZ\>\""], "InlineFormula",ExpressionUUID->
  "cb51e233-bc8d-4ad5-b43e-aea8ba3def31"],
 ", ",
 Cell[BoxData["\"\<SWAP\>\""], "InlineFormula",ExpressionUUID->
  "4a9c11b0-19d7-4994-b115-7e4dcea60483"],
 " each perform exactly that rewrite."
}], "Text",ExpressionUUID->"2146af30-d140-4919-8920-d4b581ac3a68"],

Cell["Two pictures of one circuit: Schr\[ODoubleDot]dinger and Heisenberg", \
"Section",ExpressionUUID->"0108e013-c5c3-4ae4-976e-7c5d0a2bfedc"],

Cell[TextData[{
 "That rewrite is worth slowing down on, because it is the whole reason the \
formalism reproduces ordinary quantum mechanics on its domain. The standard \
task is concrete: given a circuit, produce the final state. There are two \
ways to do it. The ",
 StyleBox["Schr\[ODoubleDot]dinger", "TI"],
 " way carries the state vector forward, ",
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     StyleBox["\[Psi]", "TI"]},
    "Ket"], "\[Function]", 
   RowBox[{
    StyleBox["U", "TI"], 
    TemplateBox[{
      StyleBox["\[Psi]", "TI"]},
     "Ket"]}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "36392ff0-1f9c-422b-9668-5c579282315e"],
 ", with ",
 Cell[BoxData[
  SuperscriptBox["2", 
   StyleBox["n", "TI"]]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "96a0bf42-fd62-47ab-9570-12b9c615b142"],
 " amplitudes evolving under ",
 Cell[BoxData[
  RowBox[{
   SuperscriptBox["2", 
    StyleBox["n", "TI"]], "\[Times]", 
   SuperscriptBox["2", 
    StyleBox["n", "TI"]]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "2f1d686e-9c4a-4191-aa63-80ce1f0288de"],
 " matrices. The ",
 StyleBox["Heisenberg", "TI"],
 " way carries the generators forward and never forms the state at all. They \
return the same state, and watching them meet is the clearest way to see what \
the tableau computes."
}], "Text",ExpressionUUID->"0f4b5152-517f-4b00-b173-71cf318ea3fc"],

Cell[TextData[{
 "Fix a small Clifford circuit on three qubits, with an ",
 Cell[BoxData[
  StyleBox["S", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "dab57a03-73fe-4b3c-884b-7030f1582c97"],
 " gate to make the result nontrivial:"
}], "Text",ExpressionUUID->"d6d3cdba-13cd-4c77-b286-b470b4286abf"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"cliffordCircuit", " ", "=", " ", 
  RowBox[{"QuantumCircuitOperator", "[", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"\"\<H\>\"", " ", "->", " ", "1"}], ",", " ", 
     RowBox[{"\"\<CNOT\>\"", " ", "->", " ", 
      RowBox[{"{", 
       RowBox[{"1", ",", " ", "2"}], "}"}]}], ",", " ", 
     RowBox[{"\"\<S\>\"", " ", "->", " ", "2"}], ",", " ", 
     RowBox[{"\"\<CNOT\>\"", " ", "->", " ", 
      RowBox[{"{", 
       RowBox[{"2", ",", " ", "3"}], "}"}]}]}], "}"}], "]"}]}]], "Input",
 CellLabel->
  "In[26]:= ",ExpressionUUID->"86518625-2db1-4e82-821b-a2d542954c7c"],

