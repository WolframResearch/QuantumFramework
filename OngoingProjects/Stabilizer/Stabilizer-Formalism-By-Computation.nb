Cell[TextData[{
 "The same move with ",
 Cell[BoxData[
  StyleBox["X", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "03bac1f9-ee3e-4fdb-b427-91fbeead37ff"],
 " in place of ",
 Cell[BoxData[
  StyleBox["H", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "c6e30b54-c35b-4190-bc6d-852f3e3f9ec4"],
 " carries ",
 Cell[BoxData[
  TemplateBox[{"0"},
   "Ket"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "5667afe9-fa71-405d-a778-ef737986e574"],
 " to ",
 Cell[BoxData[
  TemplateBox[{"1"},
   "Ket"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "b56584ec-fe02-4297-a5f9-238cf5295364"],
 ", and here a sign appears for the first time: ",
 Cell[BoxData[
  TemplateBox[{"1"},
   "Ket"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "8ca426a9-91af-44f9-b70e-b63dedbe1f28"],
 " is the ",
 Cell[BoxData[
  RowBox[{"+", "1"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "75946515-e2a0-4b88-8067-b353a9f3a700"],
 " eigenstate of ",
 Cell[BoxData[
  RowBox[{"-", 
   StyleBox["Z", "TI"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "d8dd6d71-17ed-499f-ba76-607b6b399d5c"],
 ", not of ",
 Cell[BoxData[
  StyleBox["Z", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "a9065201-8bba-40cb-a1f6-c1fa20d46139"],
 "."
}], "Text",ExpressionUUID->"bc535401-18f9-4788-866a-2d335a4e35ce"],

