Cell[TextData[{
 "We read off the operator that stabilizes it with the ",
 Cell[BoxData["\"\<Stabilizers\>\""], "InlineFormula",ExpressionUUID->
  "a1fa2c13-f22c-4111-86e9-dfae372ef85c"],
 " property:"
}], "Text",ExpressionUUID->"11f65957-a07f-425b-8f30-73bec8fc8bd6"],

