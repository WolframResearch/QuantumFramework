Cell[TextData[{
 "The generators ",
 Cell[BoxData[
  StyleBox[
   RowBox[{"X", "X"}], "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "d41ac050-21da-4d65-99bd-0e15feae4faa"],
 " and ",
 Cell[BoxData[
  StyleBox[
   RowBox[{"Z", "Z"}], "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "5a06df95-d046-4cc6-bc07-a4af638358ec"],
 " are the familiar parity checks: the two qubits share an ",
 Cell[BoxData[
  StyleBox["X", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "ecb23e5b-1c71-4c8e-b4b2-507a35ab342b"],
 "-parity and a ",
 Cell[BoxData[
  StyleBox["Z", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "3978d73b-81f3-4b03-b030-d2dac10bf210"],
 "-parity, which is precisely what maximal entanglement looks like here. The \
state vector is the textbook one:"
}], "Text",ExpressionUUID->"ff99331f-ad8e-4697-8046-a0e7f9cdfb9f"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{
