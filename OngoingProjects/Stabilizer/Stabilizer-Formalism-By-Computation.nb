  RowBox[{
   RowBox[{
    RowBox[{"PauliStabilizer", "[", "1", "]"}], "[", "\"\<State\>\"", "]"}], 
   "[", "\"\<StateVector\>\"", "]"}], " ", "//", " ", "Normal"}]], "Input",
 CellLabel->"In[7]:= ",ExpressionUUID->"67c28653-8846-4bd9-b245-b002668d2f22"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"1", ",", "0"}], "}"}]], "Output",
 CellLabel->"Out[7]= ",ExpressionUUID->"8c62e66c-68bd-4558-9d16-9edbe3e05a03"]
}, Open  ]],

Cell[TextData[{
 "Different states are fixed by different operators. The state ",
 Cell[BoxData[
  RowBox[{
   TemplateBox[{"+"},
    "Ket"], "=", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{
      TemplateBox[{"0"},
       "Ket"], "+", 
      TemplateBox[{"1"},
       "Ket"]}], ")"}], "/", 
    SqrtBox["2"]}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "1ea7f65b-5693-4b8a-83d5-7d744b16e410"],
 " is the ",
 Cell[BoxData[
  RowBox[{"+", "1"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "ebae0087-bd4c-4b5f-a80a-7f7489609165"],
 " eigenstate of ",
 Cell[BoxData[
  StyleBox["X", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "3bae378b-d752-42bd-9700-72e7bd5998f7"],
 ", and a Hadamard turns one into the other. Apply ",
 Cell[BoxData[
  StyleBox["H", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "021fa8b8-0db1-4784-b576-fece9c207184"],
 " to ",
 Cell[BoxData[
  TemplateBox[{"0"},
   "Ket"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "ba872d9a-ad16-48a6-95f5-e7f5b87527d9"],
 " and read the new stabilizer:"
}], "Text",ExpressionUUID->"4f4f76cb-4afe-4e8c-bbf8-d2d5e3045194"],

