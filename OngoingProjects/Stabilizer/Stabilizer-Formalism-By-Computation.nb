 CellLabel->
  "Out[68]= ",ExpressionUUID->"92187290-cd90-4ea2-9502-4ba55094aafc"]
}, Open  ]],

Cell[TextData[{
 "A performance caveat that is also a design lesson. The convenience \
constructor ",
 Cell[BoxData[
  RowBox[{"PauliStabilizer", "[", "circuit", "]"}]], "InlineFormula",
  ExpressionUUID->"4564da8f-8f90-45a0-a694-3e1e57bbf15b"],
 " converts an arbitrary circuit by Pauli-conjugating each gate through full \
tomography, which is exponential in the qubit count and is meant only for \
tiny circuits. For anything at scale, use the gate-update chain or the \
circuit-list form ",
 Cell[BoxData[
  RowBox[{"ps", "[", "gates", "]"}]], "InlineFormula",ExpressionUUID->
  "b5f7b6f3-e746-46a6-a821-29df1ae13a1d"],
 ", which stay in the tableau. The right tool for the job is the difference \
between milliseconds and minutes."
}], "Text",ExpressionUUID->"9862597c-d51e-48b7-b62e-c057e6f28723"],

Cell["Error-correcting codes as stabilizer states", "Section",ExpressionUUID->"9735dd79-379d-48af-841c-67cc6b57e4e5"],

Cell[TextData[{
 "Quantum error-correcting codes were the original motivation for the \
formalism: a code is defined by its stabilizer group, and a logical codeword \
is the simultaneous ",
 Cell[BoxData[
  RowBox[{"+", "1"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "ccabbb82-9dcf-44a9-adc4-e099ecaa57f2"],
 " eigenstate of the parity checks. The framework ships the canonical \
examples as named codes. The five-qubit perfect code is generated by four \
weight-four checks plus the logical ",
 Cell[BoxData[
  OverscriptBox[
   StyleBox["Z", "TI"], "_"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "8b7b983d-e1e3-4586-be4c-ad50344a7b87"],
 ":"
}], "Text",ExpressionUUID->"1d05cba6-7eff-4fb0-b9ae-6ac7ccaa717e"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"PauliStabilizer", "[", "\"\<5QubitCode\>\"", "]"}], 
  "[", "\"\<Stabilizers\>\"", "]"}]], "Input",
 CellLabel->
  "In[69]:= ",ExpressionUUID->"76dee110-b0bd-46f4-a95b-9705dbac8187"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"\<\"XZZXI\"\>", ",", "\<\"IXZZX\"\>", ",", "\<\"XIXZZ\"\>", 
   ",", "\<\"ZXIXZ\"\>", ",", "\<\"ZZZZZ\"\>"}], "}"}]], "Output",
 CellLabel->
  "Out[69]= ",ExpressionUUID->"5ee72256-2fc6-4e68-a117-8c8b82220b1d"]
}, Open  ]],

Cell[TextData[{
 "The four cyclic permutations ",
 Cell[BoxData[
  RowBox[{
   StyleBox[
    RowBox[{"X", "Z", "Z", "X", "I"}], "TI"], 
   RowBox[{",", "\[ThinSpace]"}], 
   StyleBox[
    RowBox[{"I", "X", "Z", "Z", "X"}], "TI"], 
   RowBox[{",", "\[ThinSpace]"}], 
   StyleBox[
    RowBox[{"X", "I", "X", "Z", "Z"}], "TI"], 
   RowBox[{",", "\[ThinSpace]"}], 
   StyleBox[
    RowBox[{"Z", "X", "I", "X", "Z"}], "TI"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "6b9a1881-5792-46ab-948d-8d2ebe082ca8"],
 " are the parity checks whose syndrome diagnoses any single-qubit error: the \
code has distance three, so it corrects one. The final ",
 Cell[BoxData[
  StyleBox[
   RowBox[{"Z", "Z", "Z", "Z", "Z"}], "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "71e225fb-b961-48f3-9fd3-6a8b4930c2c9"],
 " selects the logical ",
 Cell[BoxData[
  TemplateBox[{
    SubscriptBox["0", 
     StyleBox["L", "TI"]]},
   "Ket"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "8ca82727-f642-4e4a-9d7e-154cbbf53fd1"],
 " within the code space. The Steane code, the CSS code built from the \
classical ",
 Cell[BoxData[
  RowBox[{
   StyleBox["[",
    SpanMaxSize->1], 
   RowBox[{"7", ",", "4"}], 
   StyleBox["]",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "1f382e10-298d-4199-a855-40a6e0cf6d84"],
 " Hamming code, separates cleanly into ",
 Cell[BoxData[
  StyleBox["X", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "0ac9c7b2-94b3-48dc-b227-4bba20b8d30f"],
 "-type and ",
 Cell[BoxData[
  StyleBox["Z", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "ae4e48f8-f26e-4675-a40a-55dec6070d28"],
 "-type checks:"
}], "Text",ExpressionUUID->"aceec881-4207-4959-bc67-87263930c176"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"PauliStabilizer", "[", "\"\<SteaneCode\>\"", "]"}], 
  "[", "\"\<Stabilizers\>\"", "]"}]], "Input",
 CellLabel->
  "In[70]:= ",ExpressionUUID->"d98c5aea-a5d3-4c60-9a83-a4018399d314"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"\<\"IIIXXXX\"\>", ",", "\<\"XIXIXIX\"\>", ",", "\<\"IXXIIXX\"\>", 
   ",", "\<\"IIIZZZZ\"\>", ",", "\<\"ZIZIZIZ\"\>", ",", "\<\"IZZIIZZ\"\>", 
   ",", "\<\"ZZZZZZZ\"\>"}], "}"}]], "Output",
 CellLabel->
  "Out[70]= ",ExpressionUUID->"2e4607f7-c286-4ba3-9565-c25cb05afe2e"]
}, Open  ]],

Cell[TextData[{
 "The first three generators are pure ",
 Cell[BoxData[
  StyleBox["X", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "d03bc00f-0cce-4f96-ad4d-d085b441f9bc"],
 " checks and the next three pure ",
 Cell[BoxData[
  StyleBox["Z", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "6a535f9e-b9cf-441b-9ebf-2ab67a1b5f71"],
 " checks, the defining CSS structure; the seventh is again the logical ",
 Cell[BoxData[
  OverscriptBox[
   StyleBox["Z", "TI"], "_"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "5a235016-5f95-4afa-a2ba-add4cda9fae0"],
 ". Measuring these generators on an encoded state is exactly the syndrome \
extraction of the previous section, and because each is a Pauli string, the \
measurement stays in the tableau."
}], "Text",ExpressionUUID->"57a1d585-f661-4585-ab08-bd3bdf529ab5"],

Cell["The frontier: graph states, magic, and channels", "Section",ExpressionUUID->"ac9ec9d9-98ce-4708-834d-18b0f244549a"],

Cell["\<\
Three directions take the formalism to the edge of current research, and the \
framework has a head for each. This section gives each one enough room to \
compute with, not just name.\
\>", "Text",ExpressionUUID->"bf384972-9188-4f57-9708-6add8548e384"],

Cell["Graph states", "Subsection",ExpressionUUID->"c8c2ce2e-52af-4917-a15e-6822b2828154"],

Cell[TextData[{
 "A theorem of Van den Nest and others says every stabilizer state is \
local-Clifford-equivalent to a ",
 StyleBox["graph state", "TI"],
 ": place ",
 Cell[BoxData[
  TemplateBox[{"+"},
   "Ket"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "3bfeb8cf-525a-4cf3-a268-04b2187d0096"],
 " on each vertex of a graph and apply a controlled-",
 Cell[BoxData[
  StyleBox["Z", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "3f63f844-5d4c-45a0-a26b-7d0514d63100"],
 " along each edge. Its stabilizer at vertex ",
 Cell[BoxData[
  StyleBox["i", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "ccb6b37d-6051-44e2-a085-f92b7d67bbea"],
 " is ",
 Cell[BoxData[
  RowBox[{
   SubscriptBox[
    StyleBox["X", "TI"], 
    StyleBox["i", "TI"]], 
   UnderscriptBox["\[Product]", 
    RowBox[{
     StyleBox["j", "TI"], "\[Tilde]", 
     StyleBox["i", "TI"]}]], 
   SubscriptBox[
    StyleBox["Z", "TI"], 
    StyleBox["j", "TI"]]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "700cbc40-c8a6-43ef-8c00-c57877191719"],
 ". Build the graph state on a 4-cycle:"
}], "Text",ExpressionUUID->"75516a56-e8fd-46e1-9938-60bfaf4b072b"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"gs", " ", "=", " ", 
  RowBox[{"GraphState", "[", 
   RowBox[{"CycleGraph", "[", "4", "]"}], "]"}]}]], "Input",
 CellLabel->
  "In[71]:= ",ExpressionUUID->"7f0a2556-4c07-4487-a2d0-9b718ceaf2cd"],

Cell[BoxData[
 InterpretationBox[
  RowBox[{
   TagBox["GraphState",
    "SummaryHead"], "[", 
   DynamicModuleBox[{Typeset`open$$ = False, Typeset`embedState$$ = "Ready"}, 
    
    TemplateBox[{
      PaneSelectorBox[{False -> GridBox[{{
            PaneBox[
             ButtonBox[
              DynamicBox[
               FEPrivate`FrontEndResource["FEBitmaps", "SummaryBoxOpener"]], 
              ButtonFunction :> (Typeset`open$$ = True), Appearance -> None, 
              BaseStyle -> {}, Evaluator -> Automatic, Method -> 
              "Preemptive"], Alignment -> {Center, Center}, ImageSize -> 
             Dynamic[{
               Automatic, 
                3.5 (CurrentValue["FontCapHeight"]/AbsoluteCurrentValue[
                 Magnification])}]], 
            FrameBox["\"\[ScriptCapitalG]\"", StripOnInput -> False], 
            GridBox[{{
               RowBox[{
                 TagBox["\"Vertices: \"", "SummaryItemAnnotation"], 
                 "\[InvisibleSpace]", 
                 TagBox["4", "SummaryItem"]}]}, {
               RowBox[{
                 TagBox["\"Edges: \"", "SummaryItemAnnotation"], 
