Cell[TextData[{
 "The single key tells us the ",
 Cell[BoxData[
  StyleBox[
   RowBox[{"Z", "Z"}], "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "f59a0bc2-6509-41a9-bf8e-df328e610447"],
 " parity is certain. The same fact, as an expectation value, comes from ",
 Cell[BoxData["\"\<Expectation\>\""], "InlineFormula",ExpressionUUID->
  "b9d849fa-aa57-4060-bd3d-1cd856a5edfd"],
 ", which tracks the Aaronson-Gottesman ",
 Cell[BoxData[
  StyleBox["i", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "050ed344-c628-47ff-8441-93a36c947a75"],
 "-powers in closed form and returns ",
 Cell[BoxData[
  RowBox[{"\[PlusMinus]", "1"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "4be2ee8e-a4b4-4fec-b961-11d3a852563b"],
 " or ",
 Cell[BoxData["0"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "6c57d892-b9db-458c-8605-a287c3e4d066"],
 ":"
}], "Text",ExpressionUUID->"6d38db79-c1d3-46ca-84ff-f001fa891e83"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{"bell", "[", 
    RowBox[{"\"\<Expectation\>\"", ",", " ", "\"\<ZZ\>\""}], "]"}], ",", " ", 
   
   RowBox[{"bell", "[", 
    RowBox[{"\"\<Expectation\>\"", ",", " ", "\"\<XX\>\""}], "]"}], ",", " ", 
   
   RowBox[{"bell", "[", 
    RowBox[{"\"\<Expectation\>\"", ",", " ", "\"\<ZI\>\""}], "]"}]}], 
  "}"}]], "Input",
 CellLabel->
  "In[35]:= ",ExpressionUUID->"409320a9-9bbe-44ed-b713-b99a5f3e3001"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"1", ",", "1", ",", "0"}], "}"}]], "Output",
 CellLabel->
  "Out[35]= ",ExpressionUUID->"f348d7bf-fef3-4408-8332-2c9826828f46"]
}, Open  ]],

Cell[TextData[{
 "The parities ",
 Cell[BoxData[
  StyleBox[
   RowBox[{"Z", "Z"}], "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "944f1f7c-8075-4923-be46-69dacf22a06b"],
 " and ",
 Cell[BoxData[
  StyleBox[
   RowBox[{"X", "X"}], "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "6d370e9d-4367-4177-a918-b21f574c71ca"],
 " are certain (",
 Cell[BoxData[
  RowBox[{"+", "1"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "53c6382b-cded-4462-b454-b012644715d8"],
 "), while a single-qubit ",
 Cell[BoxData[
  StyleBox["Z", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "f7566c37-faa5-4aec-9858-b1fa762b8afa"],
 " is maximally uncertain (",
 Cell[BoxData["0"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "571bbaf0-e4b4-466d-a65a-60841356ce83"],
 "), the hallmark of an entangled state whose marginals are maximally mixed."
}], "Text",ExpressionUUID->"1039a82c-a644-44c7-9240-60bf4af4f2b8"],

Cell[TextData[{
 "There is a more efficient way to handle many shots, and it exposes \
something the branching picture hides. The Association ",
 Cell[BoxData[
  RowBox[{"ps", "[", 
   RowBox[{"\"\<M\>\"", ",", " ", "q"}], "]"}]], "InlineFormula",
  ExpressionUUID->"7e00c1c8-0268-463c-ad3b-1cd3bdfc703e"],
 " is the honest per-shot view, but it scales badly: a circuit with ",
 Cell[BoxData[
  StyleBox["r", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "ae727552-b169-465f-8f46-4046d834d983"],
 " random measurements has a tree of up to ",
 Cell[BoxData[
  SuperscriptBox["2", 
   StyleBox["r", "TI"]]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "e1f2533d-b786-4aed-a528-91af48502f23"],
 " outcome branches, so gathering statistics that way means either expanding \
the whole tree or re-traversing the circuit once per sample. The SymPhase \
technique of Fang and Ying replaces the branching with bookkeeping. The \
circuit is traversed ",
 StyleBox["once", "TI"],
 ", and each unresolved random outcome is recorded as a fresh formal bit ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["s", "TI"], 
   StyleBox["k", "TI"]]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "36693813-3a74-46ae-b789-810be1728632"],
 " written into a sign, leaving the state a single ",
 Cell[BoxData[
 "PauliStabilizer"], "InlineFormula",ExpressionUUID->
  "0c6c9a9e-f055-48af-af1f-99d6e599290c"],
 ". A symbolic ",
 Cell[BoxData[
  StyleBox["Z", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "7a667dd7-c633-4732-8ea7-878c286ba239"],
 "-measurement of Bell qubit 1 introduces one such bit:"
}], "Text",ExpressionUUID->"0683fcd2-9dd8-450d-b43d-7ee2e86f7b16"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"sm", " ", "=", " ", 
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{"PauliStabilizer", "[", "2", "]"}], "[", 
      RowBox[{"\"\<H\>\"", ",", " ", "1"}], "]"}], "[", 
     RowBox[{"\"\<CNOT\>\"", ",", " ", "1", ",", " ", "2"}], "]"}], "[", 
    RowBox[{"\"\<SymbolicMeasure\>\"", ",", " ", "1"}], "]"}]}], 
  ";"}], "\n", 
 RowBox[{"sm", "[", "\"\<Stabilizers\>\"", "]"}]}], "Input",
 CellLabel->
  "In[36]:= ",ExpressionUUID->"ccdd0b99-7408-4b45-9818-b9936eef6e99"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"\<\"1 - 2*\[FormalS][1]*ZI\"\>", ",", "\<\"ZZ\"\>"}], 
  "}"}]], "Output",
 CellLabel->
  "Out[36]= ",ExpressionUUID->"6a288fff-5bd3-41f8-9eb5-4eb22f298b17"]
}, Open  ]],

Cell[TextData[{
 "The sign of the first generator is now ",
 Cell[BoxData[
  RowBox[{"1", "-", "2", 
   SubscriptBox[
    StyleBox["s", "TI"], "1"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "f47fb2ea-7f85-42d7-bd27-c5ab47b05ba5"],
 ", which is ",
 Cell[BoxData[
  RowBox[{"+", "1"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "0021285c-c8e4-4371-ba56-ae2528f09cb2"],
 " at ",
 Cell[BoxData[
  RowBox[{
   SubscriptBox[
    StyleBox["s", "TI"], "1"], "=", "0"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "6c41f9b8-ae83-4ef2-9b72-34e69540b0b9"],
 " and ",
 Cell[BoxData[
  RowBox[{"-", "1"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "459b199f-c60d-498c-884d-45f14836d59b"],
 " at ",
 Cell[BoxData[
  RowBox[{
   SubscriptBox[
    StyleBox["s", "TI"], "1"], "=", "1"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "6f607503-fc5d-4a3f-8fd3-fbe128560c6c"],
 ": the formal bit ",
 StyleBox["is", "TI"],
 " the unmade measurement. Substituting a concrete value resolves it, and the \
two substitutions give exactly the two branches we saw above:"
}], "Text",ExpressionUUID->"94d44324-7504-45cd-bead-217c840e5c94"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{
    RowBox[{"sm", "[", 
     RowBox[{"\"\<SubstituteOutcomes\>\"", ",", " ", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"\[FormalS]", "[", "1", "]"}], " ", "->", " ", "0"}], "}"}]}],
      "]"}], "[", "\"\<Stabilizers\>\"", "]"}], ",", "\n", " ", 
   RowBox[{
    RowBox[{"sm", "[", 
     RowBox[{"\"\<SubstituteOutcomes\>\"", ",", " ", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"\[FormalS]", "[", "1", "]"}], " ", "->", " ", "1"}], "}"}]}],
      "]"}], "[", "\"\<Stabilizers\>\"", "]"}]}], "}"}]], "Input",
 CellLabel->
  "In[37]:= ",ExpressionUUID->"17a48063-d648-433c-969f-dc796c34cda7"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"\<\"ZI\"\>", ",", "\<\"ZZ\"\>"}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{"\<\"-ZI\"\>", ",", "\<\"ZZ\"\>"}], "}"}]}], "}"}]], "Output",
 CellLabel->
  "Out[37]= ",ExpressionUUID->"7956d373-f7ec-43a7-b0ae-fdd26f151fe2"]
}, Open  ]],

Cell[TextData[{
 "The first reason to care is that the single symbolic traversal then serves \
arbitrarily many shots. The ",
 Cell[BoxData["\"\<SampleOutcomes\>\""], "InlineFormula",ExpressionUUID->
  "19b4e58e-e4b7-4962-ad11-32da2f5ec099"],
 " property draws samples by substituting random bits for the formal ones, \
never re-running the ",
 Cell[BoxData[
 "H"], "InlineFormula",ExpressionUUID->"2782cec6-9516-422a-8b5f-7fb7fd3c562d"],
 "-",
 Cell[BoxData[
 "CNOT"], "InlineFormula",ExpressionUUID->
  "7b7ee2ea-7dee-4a7c-99e4-fa75e6969b38"],
 " circuit; a thousand shots of the qubit-1 outcome come out a fair coin:"
}], "Text",ExpressionUUID->"06a4471e-00c2-4031-9d79-62c7fd323cab"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"SeedRandom", "[", "7", "]"}], ";"}], "\n", 
 RowBox[{"Counts", "[", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"(", 
      RowBox[{"1", " ", "-", " ", 
       RowBox[{
        RowBox[{"#", "[", "\"\<StabilizerSigns\>\"", "]"}], "[", 
        RowBox[{"[", "1", "]"}], "]"}]}], ")"}], " ", "/", " ", "2"}], " ", 
    "&"}], " ", "/@", " ", 
   RowBox[{"sm", "[", 
    RowBox[{"\"\<SampleOutcomes\>\"", ",", " ", "1000"}], "]"}]}], 
  "]"}]}], "Input",
 CellLabel->
  "In[38]:= ",ExpressionUUID->"fbae1378-33f6-4655-b852-933ac97f4185"],

Cell[BoxData[
 RowBox[{"\[LeftAssociation]", 
  RowBox[{
   RowBox[{"1", "\[Rule]", "492"}], ",", 
   RowBox[{"0", "\[Rule]", "508"}]}], "\[RightAssociation]"}]], "Output",
 CellLabel->
  "Out[38]= ",ExpressionUUID->"0f62f01d-5ac0-4d5b-b493-0c11d6477276"]
}, Open  ]],

Cell[TextData[{
 "The second reason is that the formal bits thread through the ",
 StyleBox["rest", "TI"],
 " of the circuit, so correlations between outcomes are carried into the \
samples rather than discarded with the branch structure. Measure all three \
qubits of the GHZ state symbolically, sample a thousand shots, and read off \
the bit-strings: every shot is ",
 Cell[BoxData["000"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "e1a37efa-d5fe-448c-ae37-abbac52b1b84"],
 " or ",
 Cell[BoxData["111"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "0f66030e-81bf-47f2-aa5f-aacd57e043ca"],
 ", the perfect three-body correlation, reproduced from one traversal."
}], "Text",ExpressionUUID->"35dbe24f-6e85-49bc-b629-1ddfb056f006"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"readBits", "[", "ps_", "]"}], " ", ":=", " ", 
   RowBox[{"IntegerDigits", "[", 
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{"FirstPosition", "[", 
        RowBox[{
         RowBox[{"Normal", "[", 
          RowBox[{
           RowBox[{"ps", "[", "\"\<State\>\"", "]"}], 
           "[", "\"\<StateVector\>\"", "]"}], "]"}], ",", " ", 
         RowBox[{"x_", " ", "/;", " ", 
          RowBox[{"x", " ", "!=", " ", "0"}]}]}], "]"}], "[", 
       RowBox[{"[", "1", "]"}], "]"}], " ", "-", " ", "1"}], ",", " ", "2", ",",
      " ", 
     RowBox[{"ps", "[", "\"\<Qubits\>\"", "]"}]}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"smGHZ", " ", "=", " ", 
   RowBox[{"ghz3", "[", 
    RowBox[{"\"\<SymbolicMeasure\>\"", ",", " ", 
     RowBox[{"{", 
      RowBox[{"1", ",", " ", "2", ",", " ", "3"}], "}"}]}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"SeedRandom", "[", "7", "]"}], ";"}], "\n", 
 RowBox[{"Counts", "[", 
  RowBox[{"readBits", " ", "/@", " ", 
   RowBox[{"smGHZ", "[", 
    RowBox[{"\"\<SampleOutcomes\>\"", ",", " ", "1000"}], "]"}]}], 
  "]"}]}], "Input",
 CellLabel->
  "In[39]:= ",ExpressionUUID->"6b07c089-cd55-403b-905c-61ac7ce7dfb2"],

Cell[BoxData[
 RowBox[{"\[LeftAssociation]", 
  RowBox[{
   RowBox[{
    RowBox[{"{", 
     RowBox[{"1", ",", "1", ",", "1"}], "}"}], "\[Rule]", "492"}], ",", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"0", ",", "0", ",", "0"}], "}"}], "\[Rule]", "508"}]}], 
  "\[RightAssociation]"}]], "Output",
 CellLabel->
  "Out[39]= ",ExpressionUUID->"29cab2bf-fd5c-4d3f-a191-d624cd4f6471"]
}, Open  ]],

Cell["\<\
This is the payoff of carrying symbols instead of branching: the circuit \
traversal is paid for once, and any number of correlated shots then follow by \
cheap substitution. It is the in-language, exact-arithmetic cousin of the \
bulk Pauli-frame samplers the dedicated engines use for the same purpose, \
which the closing comparison returns to.\
\>", "Text",ExpressionUUID->"27feb8a2-61d9-4e70-84f8-2d5f0590dfd8"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Scaling up: random Cliffords and compiled circuits", "Section",ExpressionUUID->"93075dd3-47c7-400b-afb1-66302f6d2109"],

Cell[TextData[{
 "Sampling a Clifford operation uniformly at random is a basic primitive for \
randomized benchmarking and for probing the typical entanglement of \
stabilizer states. The framework implements the Bravyi-Maslov construction \
via the Koenig-Smolin Mallows-distribution sampler, exposed as ",
 Cell[BoxData[
  RowBox[{"PauliStabilizer", "[", 
   RowBox[{"\"\<Random\>\"", "[", "n", "]"}], "]"}]], "InlineFormula",
  ExpressionUUID->"8c48e57d-106c-49d7-9c9d-eaa1e62fe6b5"],
 ". Sampling a random 200-qubit Clifford state and confirming it is a genuine \
stabilizer state is immediate:"
}], "Text",ExpressionUUID->"79d45862-1b5f-4793-afbf-2b69b2f84686"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"SeedRandom", "[", "42", "]"}], ";"}], "\n", 
 RowBox[{"AbsoluteTiming", "[", 
  RowBox[{"StabilizerStateQ", "[", 
   RowBox[{"PauliStabilizer", "[", 
    RowBox[{"\"\<Random\>\"", "[", "200", "]"}], "]"}], "]"}], 
  "]"}]}], "Input",
 CellLabel->
  "In[40]:= ",ExpressionUUID->"5c1fdbdb-5387-4132-9774-3a2b39560284"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"0.072329`", ",", "True"}], "}"}]], "Output",
 CellLabel->
  "Out[40]= ",ExpressionUUID->"359943f6-82af-4cbf-8ce8-fe822f49cda2"]
}, Open  ]],

Cell[TextData[{
 "That random state arrives as a bare tableau, with no circuit attached. The ",
 Cell[BoxData["\"\<Circuit\>\""], "InlineFormula",ExpressionUUID->
  "936e325e-c95b-4ecf-8b0b-09e8db43018d"],
 " property hands one back: an explicit Clifford circuit that prepares the \
state from ",
 Cell[BoxData[
  TemplateBox[{
    RowBox[{"0", "\[Ellipsis]", "0"}]},
   "Ket"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "9e81c007-90ab-4ca5-9f1e-61f12b59cc94"],
 ", by the Aaronson-Gottesman canonical decomposition. Unlike the membership \
test above, this direction has real cost: the synthesis is ",
 Cell[BoxData[
  RowBox[{
   StyleBox["O", "TI"], 
   StyleBox["(",
    SpanMaxSize->1], 
   SuperscriptBox[
    StyleBox["n", "TI"], "3"], 
   StyleBox[")",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "b0e7e9a6-ba45-45bc-8442-8c9e436b7450"],
 " gates and is ",
 StyleBox["not", "TI"],
 " length-minimized, so it is a moderate-",
 Cell[BoxData[
  StyleBox["n", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "09361330-eb22-48e7-81ba-dbe207111b22"],
 " tool rather than a thousand-qubit one. On a ten-qubit random Clifford it \
is immediate, and the gate count stays polynomial:"
}], "Text",ExpressionUUID->"853a2c7a-32f8-4a6c-8b74-56d60d2a4b7d"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"SeedRandom", "[", "11", "]"}], ";"}], "\n", 
 RowBox[{
  RowBox[{"ps10", " ", "=", " ", 
   RowBox[{"PauliStabilizer", "[", 
    RowBox[{"\"\<Random\>\"", "[", "10", "]"}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"prep", " ", "=", " ", 
   RowBox[{"ps10", "[", "\"\<Circuit\>\"", "]"}]}], ";"}], "\n", 
 RowBox[{"{", 
  RowBox[{
   RowBox[{"Head", "[", "prep", "]"}], ",", " ", 
   RowBox[{"Length", " ", "@", " ", 
    RowBox[{"QuantumShortcut", "[", "prep", "]"}]}]}], "}"}]}], "Input",
 CellLabel->
  "In[41]:= ",ExpressionUUID->"bac0ff46-02cb-4ffc-b3ad-fe904470622d"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"QuantumCircuitOperator", ",", "136"}], "}"}]], "Output",
 CellLabel->
  "Out[41]= ",ExpressionUUID->"8e9765f6-712d-4a65-93fe-9cb57d18c5d2"]
}, Open  ]],

Cell[TextData[{
 "The result is an ordinary ",
 Cell[BoxData[
 "QuantumCircuitOperator"], "InlineFormula",ExpressionUUID->
  "f139c69a-64f3-400d-bc4c-e2ca5f5b0309"],
 ". It genuinely builds the state: applied to the all-zeros register it \
reproduces ",
 Cell[BoxData[
  TemplateBox[{
    StyleBox["\[Psi]", "TI"]},
   "Ket"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "316675d5-7fa7-4f7d-98db-63fd4f6d3ea3"],
 " exactly, so the overlap with the original has unit magnitude (the one ",
 Cell[BoxData[
  SuperscriptBox["2", 
   StyleBox["n", "TI"]]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "ed6ef199-5512-491c-bc84-c1ea29756610"],
 " materialization here is only the check)."
}], "Text",ExpressionUUID->"ed155643-5dcc-4299-875d-acd1a0a8d9e7"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Chop", "[", 
  RowBox[{
   RowBox[{"Abs", "[", 
    RowBox[{
     RowBox[{"Conjugate", "[", 
      RowBox[{"Normal", " ", "@", " ", 
       RowBox[{
        RowBox[{"prep", "[", "]"}], "[", "\"\<StateVector\>\"", "]"}]}], 
      "]"}], " ", ".", " ", 
     RowBox[{"Normal", " ", "@", " ", 
      RowBox[{
       RowBox[{"ps10", "[", "\"\<State\>\"", "]"}], "[", "\"\<StateVector\>\"",
        "]"}]}]}], "]"}], " ", "-", " ", "1"}], "]"}]], "Input",
 CellLabel->
  "In[42]:= ",ExpressionUUID->"2fbb8cc2-1fc8-4f85-83f4-1516ede830bd"],

Cell[BoxData["0"], "Output",
 CellLabel->
  "Out[42]= ",ExpressionUUID->"bf3a92b2-0be0-4656-9887-8424bfa5d05e"]
}, Open  ]],

Cell["\<\
This is the inverse of the gate-folding below, which goes from circuit to \
tableau, and it is the workhorse behind code encoders: a code state's \
preparation circuit is exactly its encoding circuit.\
\>", "Text",ExpressionUUID->"14814c0d-3c59-4371-86aa-ee061a2a2192"],

Cell[TextData[{
 "For long Clifford circuits the framework folds the entire gate list through \
a single compiled (C) kernel that operates on a bit-packed, generator-major \
tableau, the same data layout the specialized simulators use. The method is \
",
 Cell[BoxData[
  RowBox[{"ps", "[", 
   RowBox[{"\"\<ApplyCircuit\>\"", ",", " ", "gates"}], "]"}]], 
  "InlineFormula",ExpressionUUID->"ad18edfd-87d2-46f6-b428-13e2990fb530"],
 ". Run a four-thousand-gate random Clifford stream on two hundred qubits and \
watch the wall-clock:"
}], "Text",ExpressionUUID->"59bf09c5-b609-4d24-89ac-0ecd93c67b6c"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"SeedRandom", "[", "1", "]"}], ";"}], "\n", 
 RowBox[{
  RowBox[{"specs", " ", "=", " ", 
   RowBox[{"Table", "[", "\n", "   ", 
    RowBox[{
     RowBox[{"RandomChoice", "[", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"\"\<H\>\"", " ", "->", " ", 
         RowBox[{"RandomInteger", "[", 
          RowBox[{"{", 
           RowBox[{"1", ",", " ", "200"}], "}"}], "]"}]}], ",", " ", 
        RowBox[{"\"\<S\>\"", " ", "->", " ", 
         RowBox[{"RandomInteger", "[", 
          RowBox[{"{", 
           RowBox[{"1", ",", " ", "200"}], "}"}], "]"}]}], ",", "\n", "     ", 
        RowBox[{"\"\<CNOT\>\"", " ", "->", " ", 
         RowBox[{"RandomSample", "[", 
          RowBox[{
           RowBox[{"Range", "[", "200", "]"}], ",", " ", "2"}], "]"}]}]}], 
       "}"}], "]"}], ",", "\n", "   ", 
     RowBox[{"{", "4000", "}"}]}], "]"}]}], ";"}], "\n", 
 RowBox[{"AbsoluteTiming", "[", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"PauliStabilizer", "[", "200", "]"}], "[", 
     RowBox[{"\"\<ApplyCircuit\>\"", ",", " ", "specs"}], "]"}], 
    "[", "\"\<Stabilizers\>\"", "]"}], "[", 
   RowBox[{"[", "1", "]"}], "]"}], "]"}]}], "Input",
 CellLabel->
  "In[43]:= ",ExpressionUUID->"ee54e6cf-53d4-4c43-8788-cecd0ae949bc"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
  "0.030667`", 
   ",", "\<\"-\
XYIYZIIZZIXIIZZIYZIZIXYXIXYIXYZZXYXXYIIZZXIXXYIZXYIZYIXIYZZYIIXXZIIXXZYYYZZIXY\
ZIYZIXIYYYYZIXXXYXZZXXXZIIXZIIIIZXYYYXXYXXYXIXXZIZYIXZZXYZZIYIXZXXXIIXZXIYZZYI\
XIXZXXIIZIYIYXIIXIYXYZYZYIXZYIIZXIYIIZIZXZIZ\"\>"}], "}"}]], "Output",
 CellLabel->
  "Out[43]= ",ExpressionUUID->"46b14188-4590-45f3-b9eb-42332bda4a22"]
}, Open  ]],

Cell[TextData[{
 "That is roughly a quarter of a microsecond per gate, flat in the number of \
qubits, because each gate touches only the machine words of its own column. \
The same engine backs the circuit object: a ",
 Cell[BoxData[
 "QuantumCircuitOperator"], "InlineFormula",ExpressionUUID->
  "9bd6fdf9-398e-41e4-9f1a-5cd84c7a1b91"],
 " applied with ",
 Cell[BoxData[
  RowBox[{"Method", " ", "->", " ", "\"\<Stabilizer\>\""}]], "InlineFormula",
  ExpressionUUID->"821bce0e-de8e-4174-8ec6-d558d544adb3"],
 " evolves a stabilizer state directly. Build a Bell circuit and run it \
through the stabilizer backend:"
}], "Text",ExpressionUUID->"6b635b47-167f-43f4-aadf-346ef80c111f"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"qc", " ", "=", " ", 
   RowBox[{"QuantumCircuitOperator", "[", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"\"\<H\>\"", " ", "->", " ", "1"}], ",", " ", 
      RowBox[{"\"\<CNOT\>\"", " ", "->", " ", 
       RowBox[{"{", 
        RowBox[{"1", ",", " ", "2"}], "}"}]}]}], "}"}], "]"}]}], 
  ";"}], "\n", 
 RowBox[{
  RowBox[{"r", " ", "=", " ", 
   RowBox[{"qc", "[", 
    RowBox[{
     RowBox[{"QuantumState", "[", "\"\<00\>\"", "]"}], ",", " ", 
     RowBox[{"Method", " ", "->", " ", "\"\<Stabilizer\>\""}]}], "]"}]}], 
  ";"}], "\n", 
 RowBox[{"{", 
  RowBox[{
   RowBox[{"Head", "[", "r", "]"}], ",", " ", 
   RowBox[{"r", "[", "\"\<Stabilizers\>\"", "]"}]}], "}"}]}], "Input",
 CellLabel->
  "In[44]:= ",ExpressionUUID->"34081f51-dad4-43cb-b143-b5bfacd3d691"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"PauliStabilizer", ",", 
   RowBox[{"{", 
    RowBox[{"\<\"XX\"\>", ",", "\<\"ZZ\"\>"}], "}"}]}], "}"}]], "Output",
 CellLabel->
  "Out[44]= ",ExpressionUUID->"a755f6d2-f3fd-41f6-9e99-aeae247bc713"]
}, Open  ]],

Cell[TextData[{
 "The result is a ",
 Cell[BoxData[
 "PauliStabilizer"], "InlineFormula",ExpressionUUID->
  "894db67b-d3b8-4d58-b763-45e0213a7c7b"],
 ", not a dense state, and it agrees with the brute-force statevector path up \
to the global phase discussed earlier. Confirm the agreement on a random \
30-gate Clifford circuit by comparing the overlap magnitude:"
}], "Text",ExpressionUUID->"8dd916d1-e651-4763-8d2c-52c64cd3c422"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"SeedRandom", "[", "7", "]"}], ";"}], "\n", 
 RowBox[{
  RowBox[{"specs2", " ", "=", " ", 
   RowBox[{"Table", "[", "\n", "   ", 
    RowBox[{
     RowBox[{"RandomChoice", "[", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"\"\<H\>\"", " ", "->", " ", 
         RowBox[{"RandomInteger", "[", 
          RowBox[{"{", 
           RowBox[{"1", ",", " ", "4"}], "}"}], "]"}]}], ",", " ", 
        RowBox[{"\"\<S\>\"", " ", "->", " ", 
         RowBox[{"RandomInteger", "[", 
          RowBox[{"{", 
           RowBox[{"1", ",", " ", "4"}], "}"}], "]"}]}], ",", "\n", "     ", 
        RowBox[{"\"\<CNOT\>\"", " ", "->", " ", 
         RowBox[{"RandomSample", "[", 
          RowBox[{
           RowBox[{"Range", "[", "4", "]"}], ",", " ", "2"}], "]"}]}]}], 
       "}"}], "]"}], ",", "\n", "   ", 
     RowBox[{"{", "30", "}"}]}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"dense", " ", "=", " ", 
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{"QuantumCircuitOperator", "[", "specs2", "]"}], "[", 
      RowBox[{
       RowBox[{"QuantumState", "[", "\"\<0000\>\"", "]"}], ",", " ", 
       RowBox[{"Method", " ", "->", " ", "\"\<Schrodinger\>\""}]}], "]"}], 
     "[", "\"\<StateVector\>\"", "]"}], " ", "//", " ", "Normal"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"stab", " ", "=", " ", 
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{"PauliStabilizer", "[", "4", "]"}], "[", 
       RowBox[{"\"\<ApplyCircuit\>\"", ",", " ", "specs2"}], "]"}], 
      "[", "\"\<State\>\"", "]"}], "[", "\"\<StateVector\>\"", "]"}], " ", "//",
     " ", "Normal"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"Chop", "[", 
   RowBox[{
    RowBox[{"Abs", "[", 
     RowBox[{
      RowBox[{"Conjugate", "[", "dense", "]"}], " ", ".", " ", "stab"}], 
     "]"}], " ", "-", " ", "1"}], "]"}], " ", "==", " ", "0"}]}], "Input",
 CellLabel->
  "In[45]:= ",ExpressionUUID->"9eec3122-65a7-4c1f-b172-c91374c14785"],

Cell[BoxData["True"], "Output",
 CellLabel->
  "Out[45]= ",ExpressionUUID->"c7a93a9b-ad96-493b-948b-29f2b1203f27"]
}, Open  ]],

Cell[TextData[{
 "A performance caveat that is also a design lesson. The convenience \
constructor ",
 Cell[BoxData[
  RowBox[{"PauliStabilizer", "[", "circuit", "]"}]], "InlineFormula",
  ExpressionUUID->"6a829bce-6ac8-4495-9db7-eda52a1486ce"],
 " converts an arbitrary circuit by Pauli-conjugating each gate through full \
tomography, which is exponential in the qubit count and is meant only for \
tiny circuits. For anything at scale, use the gate-update chain or ",
 Cell[BoxData["\"\<ApplyCircuit\>\""], "InlineFormula",ExpressionUUID->
  "f58dbd38-6497-4eee-8b79-bccba65321ce"],
 ", which stay in the tableau. The right tool for the job is the difference \
between milliseconds and minutes."
}], "Text",ExpressionUUID->"877b2043-5fe6-4951-b6c6-8d25b095a5c0"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Error-correcting codes as stabilizer states", "Section",ExpressionUUID->"9df16860-d4c8-4fc9-9a04-3172eaba6ee0"],

Cell[TextData[{
 "Quantum error-correcting codes were the original motivation for the \
formalism: a code is defined by its stabilizer group, and a logical codeword \
is the simultaneous ",
 Cell[BoxData[
  RowBox[{"+", "1"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "1f05ef21-daac-483c-b9be-e3b0fb73e078"],
 " eigenstate of the parity checks. The framework ships the canonical \
examples as named codes. The five-qubit perfect code is generated by four \
weight-four checks plus the logical ",
 Cell[BoxData[
  OverscriptBox[
   StyleBox["Z", "TI"], "_"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "a7b1c3d1-1651-4c50-9e30-c128e9bae940"],
 ":"
}], "Text",ExpressionUUID->"788c17bc-5470-4424-94dc-faa67a3801a6"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"PauliStabilizer", "[", "\"\<5QubitCode\>\"", "]"}], 
  "[", "\"\<Stabilizers\>\"", "]"}]], "Input",
 CellLabel->
  "In[46]:= ",ExpressionUUID->"35acc177-aef3-47f7-9172-3d7e452e7df0"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"\<\"XZZXI\"\>", ",", "\<\"IXZZX\"\>", ",", "\<\"XIXZZ\"\>", 
   ",", "\<\"ZXIXZ\"\>", ",", "\<\"ZZZZZ\"\>"}], "}"}]], "Output",
 CellLabel->
  "Out[46]= ",ExpressionUUID->"7672164b-f2ec-436a-9e86-ad4003b6b933"]
}, Open  ]],

Cell[TextData[{
 "The four cyclic permutations ",
 Cell[BoxData[
  RowBox[{
   StyleBox[
    RowBox[{"X", "Z", "Z", "X", "I"}], "TI"], 
   RowBox[{",", "\[ThinSpace]"}], 
   StyleBox[
    RowBox[{"I", "X", "Z", "Z", "X"}], "TI"], 
   RowBox[{",", "\[ThinSpace]"}], 
   StyleBox[
    RowBox[{"X", "I", "X", "Z", "Z"}], "TI"], 
   RowBox[{",", "\[ThinSpace]"}], 
   StyleBox[
    RowBox[{"Z", "X", "I", "X", "Z"}], "TI"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "02564ba5-0955-438a-a78f-5c4431b9dd5d"],
 " are the parity checks that detect any single-qubit error, and the final ",
 Cell[BoxData[
  StyleBox[
   RowBox[{"Z", "Z", "Z", "Z", "Z"}], "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "6aabcb13-1041-4255-9f2c-22df7d6afbc4"],
 " selects the logical ",
 Cell[BoxData[
  TemplateBox[{
    SubscriptBox["0", 
     StyleBox["L", "TI"]]},
   "Ket"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "351c3461-3a61-43eb-8548-982110ed47ba"],
 " within the code space. The Steane code, the CSS code built from the \
classical ",
 Cell[BoxData[
  RowBox[{
   StyleBox["[",
    SpanMaxSize->1], 
   RowBox[{"7", ",", "4"}], 
   StyleBox["]",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "d8eb18df-4349-4b12-b790-dcfbdb11dda5"],
 " Hamming code, separates cleanly into ",
 Cell[BoxData[
  StyleBox["X", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "8b200413-9b26-45fd-8c76-1a544f9e740e"],
 "-type and ",
 Cell[BoxData[
  StyleBox["Z", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "5043fafc-8008-4044-a9a3-3188a2d99d9e"],
 "-type checks:"
}], "Text",ExpressionUUID->"1ef2506d-9e8e-4be8-b022-500a7ef82e18"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"PauliStabilizer", "[", "\"\<SteaneCode\>\"", "]"}], 
  "[", "\"\<Stabilizers\>\"", "]"}]], "Input",
 CellLabel->
  "In[47]:= ",ExpressionUUID->"f92a3f79-fc4e-4551-b1fc-875e9f30c77b"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"\<\"IIIXXXX\"\>", ",", "\<\"XIXIXIX\"\>", ",", "\<\"IXXIIXX\"\>", 
   ",", "\<\"IIIZZZZ\"\>", ",", "\<\"ZIZIZIZ\"\>", ",", "\<\"IZZIIZZ\"\>", 
   ",", "\<\"ZZZZZZZ\"\>"}], "}"}]], "Output",
 CellLabel->
  "Out[47]= ",ExpressionUUID->"a6c311ca-73ae-4a2d-af06-26c8b8bf0238"]
}, Open  ]],

Cell[TextData[{
 "The first three generators are pure ",
 Cell[BoxData[
  StyleBox["X", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "8070555a-be58-4c09-92c2-b878d0f1c033"],
 " checks and the next three pure ",
 Cell[BoxData[
  StyleBox["Z", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "118e7811-20c9-43ff-97ef-ec6c323b4fd9"],
 " checks, the defining CSS structure; the seventh is again the logical ",
 Cell[BoxData[
  OverscriptBox[
   StyleBox["Z", "TI"], "_"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "87ec0060-3ab1-49b7-84b5-07684b0bcd2a"],
 ". Measuring these generators on an encoded state is exactly the syndrome \
extraction of the previous section, and because each is a Pauli string, the \
measurement stays in the tableau."
}], "Text",ExpressionUUID->"499574cb-a566-4c8d-bfdf-326860f880a1"]
}, Open  ]],

Cell[CellGroupData[{

Cell["The frontier: graph states, magic, and channels", "Section",ExpressionUUID->"796ebedf-042b-4e78-8957-6d0f25533913"],

Cell["\<\
Three directions take the formalism to the edge of current research, and the \
framework has a head for each.\
\>", "Text",ExpressionUUID->"a64b8314-4015-48e3-880f-0f33ec83bc57"],

Cell[TextData[{
 "First, ",
 StyleBox["graph states", "TI"],
 ". A theorem of Van den Nest and others says every stabilizer state is \
local-Clifford-equivalent to a graph state, the state built by placing ",
 Cell[BoxData[
  TemplateBox[{"+"},
   "Ket"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "8477df3f-6489-47b8-9f76-caff456cf0c8"],
 " on each vertex of a graph and applying a controlled-",
 Cell[BoxData[
  StyleBox["Z", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "4368eb2b-fbc0-4e2d-970d-a484ca055020"],
 " along each edge. Its stabilizer at vertex ",
 Cell[BoxData[
  StyleBox["i", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "c436c3cf-a3d6-4576-90b3-27a464a6d9cb"],
 " is ",
 Cell[BoxData[
  RowBox[{
   SubscriptBox[
    StyleBox["X", "TI"], 
    StyleBox["i", "TI"]], 
   UnderscriptBox["\[Product]", 
    RowBox[{
     StyleBox["j", "TI"], "\[Tilde]", 
     StyleBox["i", "TI"]}]], 
   SubscriptBox[
    StyleBox["Z", "TI"], 
    StyleBox["j", "TI"]]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "62cedd4e-806a-4857-ba5c-328fbd7902b2"],
 ". Build the graph state on a 4-cycle and read its generators:"
}], "Text",ExpressionUUID->"3dfb3f0d-11d9-4e7c-9c5a-0c1d75beccf6"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"gs", " ", "=", " ", 
   RowBox[{"GraphState", "[", 
    RowBox[{"CycleGraph", "[", "4", "]"}], "]"}]}], ";"}], "\n", 
 RowBox[{"gs", "[", "\"\<Stabilizers\>\"", "]"}]}], "Input",
 CellLabel->
  "In[48]:= ",ExpressionUUID->"538367d9-9595-4898-bf30-8b6eba7106f9"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"\<\"XZIZ\"\>", ",", "\<\"ZXZI\"\>", ",", "\<\"IZXZ\"\>", 
   ",", "\<\"ZIZX\"\>"}], "}"}]], "Output",
 CellLabel->
  "Out[48]= ",ExpressionUUID->"136f0363-8fde-4be6-8118-89c4e6db6d82"]
}, Open  ]],

Cell[TextData[{
 "Each generator is an ",
 Cell[BoxData[
  StyleBox["X", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "3f72e5e6-7591-4be6-9a47-9d75861dfd4a"],
 " on one vertex dressed by ",
 Cell[BoxData[
  StyleBox["Z", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "a81dda3a-f2e6-4c25-9a0d-91174d53f7cb"],
 " on its neighbors, the cluster-state structure. The operation that \
generates the local-Clifford equivalence class is ",
 StyleBox["local complementation", "TI"],
 ", which toggles the edges among the neighbors of a chosen vertex; here it \
is [",
 Cell[BoxData[
 "LocalComplement"], "InlineFormula",ExpressionUUID->
  "6f567eb5-fdfd-4d98-b794-b880de69a7e9"],
 "]. Local-complementing the center of a triangle, for example, deletes the \
edge between its two neighbors:"
}], "Text",ExpressionUUID->"16d8383b-4360-4515-b521-f88312a96d34"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"EdgeList", "[", 
  RowBox[{"LocalComplement", "[", 
   RowBox[{
    RowBox[{"CompleteGraph", "[", "3", "]"}], ",", " ", "1"}], "]"}], 
  "]"}]], "Input",
 CellLabel->
  "In[49]:= ",ExpressionUUID->"f4f53a34-5294-4a43-90d8-7cccd036fe6e"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{"1", "\[UndirectedEdge]", "2"}], ",", 
   RowBox[{"1", "\[UndirectedEdge]", "3"}]}], "}"}]], "Output",
 CellLabel->
  "Out[49]= ",ExpressionUUID->"d9f06c25-8ef7-430b-944a-f08a23efbe8d"]
}, Open  ]],

Cell[TextData[{
 "Second, ",
 StyleBox["magic and stabilizer rank", "TI"],
 ". Clifford gates keep us inside the stabilizer world; a non-Clifford gate \
such as ",
 Cell[BoxData[
  StyleBox["T", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "7efbd8f6-e3a0-4ef0-be6a-66a81ca0b0ea"],
 " does not. The framework represents a state that has left the stabilizer \
manifold as a [",
 Cell[BoxData[
 "StabilizerFrame"], "InlineFormula",ExpressionUUID->
  "fbe2b954-8336-44b8-abee-5a2b1e5b3b44"],
 "], a superposition ",
 Cell[BoxData[
  RowBox[{
   UnderscriptBox["\[Sum]", 
    StyleBox["i", "TI"]], 
   RowBox[{
    SubscriptBox[
     StyleBox["c", "TI"], 
     StyleBox["i", "TI"]], 
    TemplateBox[{
      SubscriptBox[
       StyleBox["s", "TI"], 
       StyleBox["i", "TI"]]},
     "Ket"]}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "334a95ca-d8ea-491d-a86b-34193bde628b"],
 " of stabilizer states, and each ",
 Cell[BoxData[
  StyleBox["T", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "a4c61267-7094-49a4-b4ab-b7e93e353b6d"],
 " gate doubles the number of terms. The number of terms is the ",
 StyleBox["stabilizer rank", "TI"],
 ", the quantity that controls the cost of classically simulating magic, in \
the sense of Bravyi and Gosset. Apply three ",
 Cell[BoxData[
  StyleBox["T", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "5690cf81-f81d-4fd5-81ee-df58da0a2aca"],
 " gates and count the terms:"
}], "Text",ExpressionUUID->"cf78b7de-308a-4541-9d90-065f46935746"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{"PauliStabilizer", "[", "3", "]"}], "[", 
        RowBox[{"\"\<H\>\"", ",", " ", "1"}], "]"}], "[", 
       RowBox[{"\"\<H\>\"", ",", " ", "2"}], "]"}], "[", 
      RowBox[{"\"\<H\>\"", ",", " ", "3"}], "]"}], "[", 
     RowBox[{"\"\<T\>\"", ",", " ", "1"}], "]"}], "[", 
    RowBox[{"\"\<T\>\"", ",", " ", "2"}], "]"}], "[", 
   RowBox[{"\"\<T\>\"", ",", " ", "3"}], "]"}], "[", "\"\<Length\>\"", 
  "]"}]], "Input",
 CellLabel->
  "In[50]:= ",ExpressionUUID->"20ab2aa3-bbd4-41f7-8729-d29a684eb3d6"],

Cell[BoxData["8"], "Output",
 CellLabel->
  "Out[50]= ",ExpressionUUID->"1833fe92-28c8-4f6f-82be-62d8c6a508b5"]
}, Open  ]],

Cell[TextData[{
 "The frame has grown from one term to ",
 Cell[BoxData[
  RowBox[{
   SuperscriptBox["2", "3"], "=", "8"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "81719ebe-5e83-493f-835d-2e77f9a1b6fb"],
 ", the exponential cost of magic made concrete. The frame is the right \
object for counting and for stabilizer-rank methods; reconstructing its dense \
state vector inherits the per-component global-phase ambiguity, so use it as \
a combinatorial tool rather than for exact amplitude readout."
}], "Text",ExpressionUUID->"182e5457-4b97-472d-92a7-7ab966f485b0"],

Cell[TextData[{
 "Third, ",
 StyleBox["Clifford channels", "TI"],
 ". Open-system Clifford dynamics, the maps that send stabilizer states to \
stabilizer states, are encoded by a Boolean Choi tableau in the framework's [",
 Cell[BoxData[
 "CliffordChannel"], "InlineFormula",ExpressionUUID->
  "c835d0ba-6b34-41bc-a635-7f105cbd0131"],
 "], following Yashin. The identity channel on two qubits has a rank equal to \
twice the qubit count:"
}], "Text",ExpressionUUID->"44c3b6bf-adf5-4afe-ba6b-e6dbcb4f1b5b"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"CliffordChannel", "[", 
   RowBox[{"\"\<Identity\>\"", ",", " ", "2"}], "]"}], "[", "\"\<Rank\>\"", 
  "]"}]], "Input",
 CellLabel->
  "In[51]:= ",ExpressionUUID->"d82f5aae-4d17-4672-bc0a-888b8eef9746"],

Cell[BoxData["4"], "Output",
 CellLabel->
  "Out[51]= ",ExpressionUUID->"741539e4-5fd7-42bf-b0cb-ec3fb6bfdf5d"]
}, Open  ]],

Cell["\<\
A pure stabilizer state is itself a (state-preparation) Clifford channel, \
whose tableau is the state's stabilizer half. Converting the Bell state to \
its channel tableau recovers its two parity-check rows:\
\>", "Text",ExpressionUUID->"230ef695-f198-49c3-a490-38d1da0398b7"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"CliffordChannel", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"PauliStabilizer", "[", "2", "]"}], "[", 
      RowBox[{"\"\<H\>\"", ",", " ", "1"}], "]"}], "[", 
     RowBox[{"\"\<CNOT\>\"", ",", " ", "1", ",", " ", "2"}], "]"}], "]"}], 
   "[", "\"\<Tableau\>\"", "]"}], " ", "//", " ", "MatrixForm"}]], "Input",
 CellLabel->
  "In[52]:= ",ExpressionUUID->"8b3f6025-eb3f-4f90-8a92-457a040b33a6"],

Cell[BoxData[
 TagBox[
  RowBox[{"(", "\[NoBreak]", GridBox[{
     {"1", "1", "0", "0", "0"},
     {"0", "0", "1", "1", "0"}
    },
    GridBoxAlignment->{"Columns" -> {{Center}}, "Rows" -> {{Baseline}}},
    GridBoxSpacings->{"Columns" -> {
        Offset[0.27999999999999997`], {
         Offset[0.7]}, 
        Offset[0.27999999999999997`]}, "Rows" -> {
        Offset[0.2], {
         Offset[0.4]}, 
        Offset[0.2]}}], "\[NoBreak]", ")"}],
  Function[BoxForm`e$, 
   MatrixForm[BoxForm`e$]]]], "Output",
 CellLabel->
  "Out[52]= ",ExpressionUUID->"3d59ba3e-86e3-4454-ab96-b3370efd78de"]
}, Open  ]],

Cell[TextData[{
 "These three heads, together with ",
 Cell[BoxData[
 "PauliStabilizer"], "InlineFormula",ExpressionUUID->
  "28d6d744-befb-405a-b9cf-2a5af9d88844"],
 " and ",
 Cell[BoxData[
 "StabilizerFrame"], "InlineFormula",ExpressionUUID->
  "89c5ba62-4fa9-428c-8e83-a77ebb9f60d0"],
 ", let one stay in the tableau picture for states, codes, graph-state \
surgery, magic accounting, and noise, inside the same object model as the \
rest of the framework."
}], "Text",ExpressionUUID->"4298b388-932e-461c-8104-77398f9e6c79"]
}, Open  ]],

Cell[CellGroupData[{

Cell["An honest comparison with other packages", "Section",ExpressionUUID->"7ae99b85-d40d-469f-a229-7c506eb16d42"],

Cell["\<\
The stabilizer simulators built for raw throughput are Stim, a C++ engine, \
and QuantumClifford.jl, a Julia package; both are excellent and both are \
narrower in scope than a general quantum framework. The fair question is \
two-sided: how close is the framework on the task they specialize in, and \
what does it offer that they do not.\
\>", "Text",ExpressionUUID->"ba09bd74-8cc0-42d1-99c6-2fb97244de62"],

Cell["\<\
On gate-folding throughput the gap is now a small constant factor. The \
figures below are the measured wall-clock for an identical Clifford stream on \
an Apple M2 Pro, from the framework's own bottleneck audit at repository \
HEAD, with Stim for reference:\
\>", "Text",ExpressionUUID->"de13b5b9-1881-4090-bae4-7aaf0819670c"],

Cell[BoxData[GridBox[{
   {Cell["qubits (gates)", "TableText",
     FontWeight->Bold,ExpressionUUID->"f90f1642-1a02-4658-a492-7fcf8167ff17"],
     Cell["QuantumFramework", "TableText",
     FontWeight->Bold,ExpressionUUID->"889a51fa-468b-45be-a4ca-96a8d978b5a8"],
     Cell["Stim", "TableText",
     FontWeight->Bold,ExpressionUUID->"43a35190-a678-4ebe-9525-784010142548"],
     Cell["ratio", "TableText",
     FontWeight->Bold,ExpressionUUID->"7a5c0136-72f9-4d10-bec1-76deb717887f"]},
   {Cell["100 (2k)", "TableText",ExpressionUUID->
     "84c3ecc3-1c4c-4533-976b-b360030fb81e"], Cell[
    "2.6 ms", "TableText",ExpressionUUID->
     "46a55468-4db2-4abf-b637-dd9ffcdbd841"], Cell[
    "1.03 ms", "TableText",ExpressionUUID->
     "0adf0e77-4df4-462c-b02d-5b4fcd3ccbb1"], Cell[
    "2.5x", "TableText",ExpressionUUID->
     "271499eb-324d-4685-b75c-d42abe119875"]},
   {Cell["500 (10k)", "TableText",ExpressionUUID->
     "0858f9a2-fe93-44cd-b2f2-c9ba56c34568"], Cell[
    "26.2 ms", "TableText",ExpressionUUID->
     "b293f967-ee5f-4b1c-a760-bb80cf09808c"], Cell[
    "5.14 ms", "TableText",ExpressionUUID->
     "e4da4166-6b1e-4e9a-9d73-ed960a48e1d1"], Cell[
    "5.1x", "TableText",ExpressionUUID->
     "222771e5-7628-4f8d-940f-ea0f44958c2c"]},
   {Cell["1000 (20k)", "TableText",ExpressionUUID->
     "4b5c4cad-efdb-4841-aeb0-ffd6436ac16a"], Cell[
    "58.0 ms", "TableText",ExpressionUUID->
     "dc2afb2e-c92a-4548-ab6a-73cd85e4cc43"], Cell[
    "10.9 ms", "TableText",ExpressionUUID->
     "b02655f8-aedd-47d6-a448-cca03ce3cf0d"], Cell[
    "5.3x", "TableText",ExpressionUUID->
     "93677645-d4b0-403a-b356-2c4c98a81a53"]}
  },
  GridBoxAlignment->{"Columns" -> {{Left}}, "Rows" -> {{Baseline}}},
  GridBoxDividers->{"Columns" -> {{None}}, "Rows" -> {{True}}},
  GridBoxSpacings->{"Columns" -> {{1.5}}, "Rows" -> {{0.7}}}]], "Text",Express\
ionUUID->"3d6034a3-e25f-4df7-a50f-145c4f36c466"],

Cell[TextData[{
 "At a thousand qubits the framework also runs ahead of QuantumClifford.jl on \
the same stream (58.0 ms against 108.4 ms). The remaining gap to Stim is SIMD \
lane width, Stim packs 256-bit vector lanes against the framework's 62-bit \
machine words, plus a small per-gate circuit-encoding pass; it is a constant \
factor, not an algorithmic deficit. Getting there took compiling the gate \
fold to a single C kernel: the earlier interpreted path was roughly ",
 Cell[BoxData[
  SuperscriptBox["10", "3"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "f546fea5-898a-4e31-ac58-59a2c952e5cb"],
 " times slower, around 74, 402, and 955 ms at the three sizes above."
}], "Text",ExpressionUUID->"10c6f77d-50e7-4a10-b02c-28ba63013f72"],

Cell["What the framework offers that the dedicated engines do not:", "Text",ExpressionUUID->"6dba4b6e-14ab-4882-8d26-47bdbefaaf5c"],

Cell[TextData[{
 StyleBox["Symbolic signs", "TI"],
 ". Outcomes can be carried as formal symbols through a circuit (the SymPhase \
method), so a single traversal serves arbitrarily many samples, and outcome \
correlations are explicit polynomials."
}], "Item",ExpressionUUID->"396919da-4791-46c1-8445-48c3192d8a87"],

Cell[TextData[{
 StyleBox["Exact arithmetic", "TI"],
 ". Coefficients, signs, and the random-Clifford sampler use exact rationals, \
so seeded output is bit-reproducible and there is no floating-point drift."
}], "Item",ExpressionUUID->"94b8d8bd-2504-4448-a4d9-38618626c0ba"],

Cell[TextData[{
 StyleBox["One object model", "TI"],
 ". A ",
 Cell[BoxData[
 "PauliStabilizer"], "InlineFormula",ExpressionUUID->
  "1739e9a2-fde9-4b25-bbc4-263ab35a862a"],
 " converts to a ",
 Cell[BoxData[
 "QuantumState"], "InlineFormula",ExpressionUUID->
  "c7cb1739-9bca-4877-a08f-4f698405f957"],
 ", a ",
 Cell[BoxData[
 "QuantumOperator"], "InlineFormula",ExpressionUUID->
  "7e990917-3cd6-435f-bb52-e0095cba98de"],
 ", a ",
 Cell[BoxData[
 "QuantumCircuitOperator"], "InlineFormula",ExpressionUUID->
  "1ba984ba-5a86-49bc-ad5d-3a9d15a0f51c"],
 ", or a ",
 Cell[BoxData[
 "QuantumChannel"], "InlineFormula",ExpressionUUID->
  "4cbb4d95-7fa6-43be-a481-1fa3b9d83966"],
 ", so a stabilizer subroutine drops into a larger simulation that also uses \
dense states, density matrices, Lindblad evolution, or phase-space methods, \
without leaving the language."
}], "Item",ExpressionUUID->"5a8ef909-12df-4972-b634-d6d846232ac9"],

Cell[TextData[{
 StyleBox["Breadth of heads", "TI"],
 ". Graph states with local complementation, stabilizer frames for magic \
accounting, and Clifford channels for open-system Clifford dynamics are \
first-class objects, not features one bolts on."
}], "Item",ExpressionUUID->"0635e12f-b136-4b7b-bb59-5c9bff2620ab"],

Cell["Where the framework genuinely trails, stated plainly:", "Text",ExpressionUUID->"66c3b359-c545-405e-8e8c-267ba4d13e24"],

Cell[TextData[{
 "It is a constant factor (roughly ",
 Cell[BoxData["2.5"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "5fc71a5d-2298-4fe9-91e6-1ad02519f9b9"],
 " to ",
 Cell[BoxData[
  RowBox[{"5.3", "\[Times]"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "4fdce80e-8313-48a1-a300-e809f140c528"],
 ") behind Stim on pure gate throughput, for the lane-width reason above."
}], "Item",ExpressionUUID->"25851ea9-e1dc-46de-92b2-b1606f446f9b"],

Cell["\<\
It has no constant-cost bulk Pauli-frame sampler, the trick that makes Stim's \
shot-by-shot sampling so cheap.\
\>", "Item",ExpressionUUID->"b75f0da8-3395-4588-9058-7c1e5d620a19"],

Cell[TextData[{
 "Constructing a ",
 Cell[BoxData[
 "QuantumCircuitOperator"], "InlineFormula",ExpressionUUID->
  "313d9feb-740e-4dd9-a360-46574ffa8744"],
 " with ",
 Cell[BoxData[
  SuperscriptBox["10", "4"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "3d284759-7114-408b-acb1-bacfd2031591"],
 " or more gates carries host-framework overhead; for long streams one should \
call ",
 Cell[BoxData["\"\<ApplyCircuit\>\""], "InlineFormula",ExpressionUUID->
  "abe885bd-f9e8-4aa6-be22-bc40974d0943"],
 " on a gate-spec list directly."
}], "Item",ExpressionUUID->"01ba4064-f00c-4dcb-a328-19c5effbee54"],

Cell["\<\
Reconstructing an exact state vector from a gate-updated tableau or a \
stabilizer frame is correct only up to a global (or per-component) phase.\
\>", "Item",ExpressionUUID->"6e310e1b-0a06-47ad-8296-f85c01cfc5a5"],

Cell["\<\
The summary is the one a physicist would want: for raw Clifford throughput \
the specialized engines are a few times faster, and if that is the only thing \
one needs, they are the right tool. For stabilizer simulation that has to \
interoperate with the rest of a quantum-mechanics toolkit, carry symbols, \
stay exact, and reach into codes, graph states, magic, and channels, the \
framework buys all of that for a small constant in speed.\
\>", "Text",ExpressionUUID->"cf422cf3-a246-42cf-9934-4ab706f27ec9"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Where this leaves us", "Section",ExpressionUUID->"254223ca-c0dc-4061-95b7-f865b404762a"],

Cell[TextData[{
 "We built the stabilizer formalism from one idea, that a state is named by \
what fixes it, and rode it from a single qubit to a thousand. Along the way \
the concrete tools were: ",
 Cell[BoxData[
 "PauliStabilizer"], "InlineFormula",ExpressionUUID->
  "83843183-4579-46e6-8d3c-5fedce158d3a"],
 " for states, codes, and the tableau; the gate-update methods and ",
 Cell[BoxData["\"\<ApplyCircuit\>\""], "InlineFormula",ExpressionUUID->
  "3a62c136-5ba1-4d95-b866-658b827df376"],
 " for Clifford evolution; ",
 Cell[BoxData["\"\<M\>\""], "InlineFormula",ExpressionUUID->
  "425bc209-507d-4ba3-81f8-b68295a8033d"],
 ", ",
 Cell[BoxData["\"\<Expectation\>\""], "InlineFormula",ExpressionUUID->
  "bfa8ff46-7269-4a43-abb3-2b54d390058e"],
 ", and ",
 Cell[BoxData["\"\<SymbolicMeasure\>\""], "InlineFormula",ExpressionUUID->
  "b6515713-3b18-45e5-9b03-298dfde54828"],
 " for measurement; ",
 Cell[BoxData["\"\<Entropy\>\""], "InlineFormula",ExpressionUUID->
  "fee69197-8b02-4fc4-bfe5-a60c0cb6063a"],
 " for entanglement; ",
 Cell[BoxData[
  RowBox[{"PauliStabilizer", "[", 
   RowBox[{"\"\<Random\>\"", "[", "n", "]"}], "]"}]], "InlineFormula",
  ExpressionUUID->"e53c85d5-9de0-4738-b30a-5fbe184270df"],
 " for sampling; and ",
 Cell[BoxData[
 "GraphState"], "InlineFormula",ExpressionUUID->
  "214b15cf-5123-4a5d-9e48-9932884dfcb7"],
 ", ",
 Cell[BoxData[
 "StabilizerFrame"], "InlineFormula",ExpressionUUID->
  "a9bf8461-330c-4d43-b236-25fba7298f81"],
 ", and ",
 Cell[BoxData[
 "CliffordChannel"], "InlineFormula",ExpressionUUID->
  "a8aed577-f14d-4d2f-b000-f572368abde8"],
 " for the frontier."
}], "Text",ExpressionUUID->"0c022a7d-dea6-405c-8140-2ccbb1f404ab"],

Cell[TextData[{
 "The natural next steps are the ones the formalism opens onto: syndrome \
decoding on the codes of the error-correction section, stabilizer-rank \
simulation of magic-rich circuits via the frame, and Clifford-channel models \
of realistic noise. Each is a short extension of the computations above, and \
each stays, as long as it can, inside the ",
 Cell[BoxData[
  RowBox[{
   StyleBox["O", "TI"], 
   StyleBox["(",
    SpanMaxSize->1], 
   SuperscriptBox[
    StyleBox["n", "TI"], "2"], 
   StyleBox[")",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "09e78010-e268-43f9-b1b5-5ad501339b1b"],
 " tableau that makes the whole subject tractable."
}], "Text",ExpressionUUID->"1c5a6387-9b25-4bb0-b4df-6d0b61118af6"],

Cell["\<\
The key references underpinning the implementation are Gottesman's \
stabilizer-codes thesis (1997), Aaronson and Gottesman on the tableau and its \
measurement update (2004), Fattal and collaborators on stabilizer \
entanglement entropy (2004), Anders and Briegel on graph states and local \
complementation (2005), Koenig and Smolin on the random-Clifford sampler \
(2014), Garcia and Markov on stabilizer frames (2015), Fang and Ying on \
symbolic phases (2023), and Yashin on Clifford channels (2025).\
\>", "Text",ExpressionUUID->"d29cb338-5d7e-4798-8a47-07ab2eaef7bd"]
}, Open  ]]
}, Open  ]]
},
