Cell["What we have established:", "Text",ExpressionUUID->"172025c1-f199-4536-9b46-56bd385b2876"],

Cell[TextData[{
 "An entangled stabilizer state is one whose generators are multi-qubit Pauli \
strings; Bell is ",
 Cell[BoxData[
  RowBox[{
   StyleBox["\[LeftAngleBracket]",
    SpanMaxSize->1], 
   RowBox[{
    StyleBox[
     RowBox[{"X", "X"}], "TI"], 
    RowBox[{",", "\[ThinSpace]"}], 
    StyleBox[
     RowBox[{"Z", "Z"}], "TI"]}], "\[VeryThinSpace]", 
   StyleBox["\[RightAngleBracket]",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "684cf20a-38a6-45b5-8b50-f315c5c22168"],
 "."
}], "Item",ExpressionUUID->"6d4042ea-e0b4-457d-8b6f-6563f3025464"],

Cell[TextData[{
 "Entanglement entropy is an ",
 Cell[BoxData[
  SubscriptBox["\|01d53d", "2"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "7f70eb67-0e42-4d5d-b4f7-7d7643486230"],
 " rank, computable at ",
 Cell[BoxData[
  RowBox[{
   StyleBox["n", "TI"], "=", "1000"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "0eeb258b-3dca-4a80-b2cf-cbf63edfa7af"],
 " in milliseconds."
}], "Item",ExpressionUUID->"f3175588-f626-4a91-b6b0-9aa8c56d1972"],

Cell[TextData[{
 "The cost of all this is ",
 Cell[BoxData[
  RowBox[{
   StyleBox["O", "TI"], 
   StyleBox["(",
    SpanMaxSize->1], 
   SuperscriptBox[
    StyleBox["n", "TI"], "2"], 
   StyleBox[")",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "920aa09a-3172-4c40-bb7c-890b3d0cc352"],
 " storage and ",
 Cell[BoxData[
  RowBox[{
   StyleBox["O", "TI"], 
   StyleBox["(",
    SpanMaxSize->1], 
   SuperscriptBox[
    StyleBox["n", "TI"], "3"], 
   StyleBox[")",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "501be3d4-9b1a-468f-aa74-674c1016064f"],
 " for the rank, never ",
 Cell[BoxData[
  RowBox[{
   StyleBox["O", "TI"], 
   StyleBox["(",
    SpanMaxSize->1], 
   SuperscriptBox["2", 
    StyleBox["n", "TI"]], 
   StyleBox[")",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "1757dc68-4474-44bd-83e1-13a2680ef64a"],
 "."
}], "Item",ExpressionUUID->"b7581fef-49d1-4ea2-96d0-4708b89077db"],

Cell["Measurement: randomness, back-action, and correlation", "Section",ExpressionUUID->"f452cd07-6e33-4125-ab93-5d407b359c29"],

Cell[TextData[{
 "Measurement is where the destabilizers earn their keep. Measuring ",
 Cell[BoxData[
  StyleBox["Z", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "33e2762a-a126-4add-a4df-db90d380b902"],
 " on qubit ",
 Cell[BoxData[
  StyleBox["a", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "10a5c33b-d8c1-4d05-9bf7-e8d2f8aa4a55"],
 " splits into two cases. If ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["Z", "TI"], 
   StyleBox["a", "TI"]]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "f85b1ad6-1f83-40ca-8f16-6be0f538e7c3"],
 " commutes with every stabilizer, then ",
 Cell[BoxData[
  RowBox[{"\[PlusMinus]", 
   SubscriptBox[
    StyleBox["Z", "TI"], 
    StyleBox["a", "TI"]]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "e42dc716-a692-450c-922a-17dd2d4076a2"],
 " already lies in the stabilizer group: the outcome is ",
 StyleBox["deterministic", "TI"],
 ", the state is unchanged, and the bit is the sign of the generator product \
that equals ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["Z", "TI"], 
   StyleBox["a", "TI"]]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "ab0e5e75-bb75-4c7a-8f5e-b631a145dbc6"],
 ", which the destabilizers locate in ",
 Cell[BoxData[
  RowBox[{
   StyleBox["O", "TI"], 
   StyleBox["(",
    SpanMaxSize->1], 
   SuperscriptBox[
    StyleBox["n", "TI"], "2"], 
   StyleBox[")",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "152f71bd-35af-4946-aac8-7f32d78f6eb5"],
 ". If instead some stabilizer anticommutes with ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["Z", "TI"], 
   StyleBox["a", "TI"]]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "39a3e85a-03bc-4f47-9ab4-5fc59ba01192"],
 ", the outcome is a fair coin, and the post-measurement state follows from a \
sequence of Aaronson-Gottesman row sums into one anticommuting generator, \
with a destabilizer as scratch. Either way the work is ",
 Cell[BoxData[
  RowBox[{
   StyleBox["O", "TI"], 
   StyleBox["(",
    SpanMaxSize->1], 
   SuperscriptBox[
    StyleBox["n", "TI"], "2"], 
   StyleBox[")",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "4ed66a78-c12f-499c-ab20-9ca4cc1c956c"],
 ", never ",
 Cell[BoxData[
  RowBox[{
   StyleBox["O", "TI"], 
   StyleBox["(",
    SpanMaxSize->1], 
   SuperscriptBox["2", 
    StyleBox["n", "TI"]], 
   StyleBox[")",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "9584c0e6-8262-4689-9ead-78050420322d"],
 "."
}], "Text",ExpressionUUID->"f9580efa-61b3-49ed-9335-32b79efc18db"],

Cell["\<\
A measurement on a stabilizer state returns an association from outcome to \
post-state. For the Bell state, measuring qubit 1 is random, so both branches \
appear:\
\>", "Text",ExpressionUUID->"8627a1a7-79df-4ff3-ba34-f39c14473a6d"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"bell", "[", 
  RowBox[{"\"\<M\>\"", ",", " ", "1"}], "]"}]], "Input",
 CellLabel->
  "In[43]:= ",ExpressionUUID->"ae047469-6e24-417d-9fa5-8f30932eb78c"],

