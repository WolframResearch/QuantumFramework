Cell[BoxData[
 RowBox[{
  RowBox[{"GraphState", "[", 
   RowBox[{"PathGraph", "[", 
    RowBox[{"Range", "[", "3", "]"}], "]"}], "]"}], "[", "\"\<Stabilizers\>\"",
   "]"}]], "Input",
 CellLabel->
  "In[74]:= ",ExpressionUUID->"78865d77-6d4c-499a-af9e-7bf4cbaa9438"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"\<\"XZI\"\>", ",", "\<\"ZXZ\"\>", ",", "\<\"IZX\"\>"}], 
  "}"}]], "Output",
 CellLabel->
  "Out[74]= ",ExpressionUUID->"6fac6ed0-5e7c-4f60-ae3e-aa3c89e4ac05"]
}, Open  ]],

Cell[TextData[{
 "The operation that moves through the local-Clifford equivalence class is ",
 StyleBox["local complementation", "TI"],
 ", which toggles the edges among the neighbors of a chosen vertex; here it \
is [",
 Cell[BoxData[
 "LocalComplement"], "InlineFormula",ExpressionUUID->
  "48145296-bc72-4451-9245-21c23d88bf32"],
 "]. Local-complementing the 4-cycle at vertex 1 adds the edge between its \
two neighbors:"
}], "Text",ExpressionUUID->"cf2bdd69-00aa-4ed5-afe4-638bb6f4e21d"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"EdgeList", "[", 
  RowBox[{"LocalComplement", "[", 
   RowBox[{
    RowBox[{"CycleGraph", "[", "4", "]"}], ",", " ", "1"}], "]"}], 
  "]"}]], "Input",
 CellLabel->
  "In[75]:= ",ExpressionUUID->"81c2d179-6fd7-45e0-a2c6-d3e9c6d24dff"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{"1", "\[UndirectedEdge]", "2"}], ",", 
   RowBox[{"1", "\[UndirectedEdge]", "4"}], ",", 
   RowBox[{"2", "\[UndirectedEdge]", "3"}], ",", 
   RowBox[{"2", "\[UndirectedEdge]", "4"}], ",", 
   RowBox[{"3", "\[UndirectedEdge]", "4"}]}], "}"}]], "Output",
 CellLabel->
  "Out[75]= ",ExpressionUUID->"4e859f57-f8bf-4914-a42c-a75e1d8e7a24"]
}, Open  ]],

Cell["\<\
The graph is updated correctly, but the accompanying single-qubit Clifford \
corrections, the vertex operators that would make the equivalence exact at \
the state level, are not yet tracked. Use this for graph surgery rather than \
for exact state identity.\
\>", "Text",ExpressionUUID->"969d0d11-de05-414c-b61c-dcd87c2c7b07"],

Cell["Magic and stabilizer rank", "Subsection",ExpressionUUID->"80856a7c-9525-408a-b316-87411488b104"],

Cell[TextData[{
 "Clifford gates keep us inside the stabilizer world; a non-Clifford gate \
such as ",
 Cell[BoxData[
  StyleBox["T", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "40c87580-02a2-48b5-adbd-666862ec5e09"],
 " does not. The framework represents a state that has left the stabilizer \
manifold as a [",
 Cell[BoxData[
 "StabilizerFrame"], "InlineFormula",ExpressionUUID->
  "23ea41cf-ecb5-4abf-b3f9-b56a2b678ccd"],
 "], a superposition ",
 Cell[BoxData[
  RowBox[{
   UnderscriptBox["\[Sum]", 
    StyleBox["i", "TI"]], 
   RowBox[{
    SubscriptBox[
     StyleBox["c", "TI"], 
     StyleBox["i", "TI"]], 
    TemplateBox[{
      SubscriptBox[
       StyleBox["s", "TI"], 
       StyleBox["i", "TI"]]},
     "Ket"]}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "9bfc936e-6b59-41d0-aa7b-c56c085afb13"],
 " of stabilizer states. As the Heisenberg section showed, ",
 Cell[BoxData[
  StyleBox["T", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "dde46c14-67dc-45e9-8969-82011111726c"],
 " turns one Pauli into a sum of two, and at the state level that means each ",
 Cell[BoxData[
  StyleBox["T", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "735a0557-b8ea-4ca2-a6d7-2023dc83153b"],
 " gate at most ",
 StyleBox["doubles", "TI"],
 " the number of stabilizer terms. The term count is the ",
 StyleBox["stabilizer rank", "TI"],
 ", the quantity that controls the cost of classically simulating magic, in \
the sense of Bravyi and Gosset. Watch it double, gate by gate. A helper \
reports the term count, with a bare ",
 Cell[BoxData[
 "PauliStabilizer"], "InlineFormula",ExpressionUUID->
  "8756a588-40c1-48e0-a271-c6ed0ba4e5a5"],
 " counting as rank 1 and a frame as its component count:"
}], "Text",ExpressionUUID->"2edae567-5dad-4dd6-8c82-61fd17100476"],

Cell[BoxData[
 RowBox[{
  RowBox[{"stabRank", "[", "x_", "]"}], " ", ":=", " ", 
  RowBox[{"If", "[", 
   RowBox[{
    RowBox[{
     RowBox[{"Head", "[", "x", "]"}], " ", "===", " ", "StabilizerFrame"}], ",",
     " ", 
    RowBox[{"x", "[", "\"\<Length\>\"", "]"}], ",", " ", "1"}], 
   "]"}]}]], "Input",
 CellLabel->
  "In[76]:= ",ExpressionUUID->"d5f1db06-c225-4149-a437-f8942e427436"],

Cell[TextData[{
 "Apply ",
 Cell[BoxData[
  StyleBox["k", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "f6dda90c-6cbb-44a4-be54-10270983dd5d"],
 " successive ",
 Cell[BoxData[
  StyleBox["T", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "85fac827-e622-426e-8cf0-4af11ef92021"],
 " gates to ",
 Cell[BoxData[
  TemplateBox[{"+"},
   "Ket"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "5fa98aaf-9489-4af1-ad84-7cfc7c8c7355"],
 " and tabulate the rank:"
}], "Text",ExpressionUUID->"5cb8fe0d-774b-44c7-9165-3ee7ca101fe6"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Table", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"k", ",", " ", 
     RowBox[{"stabRank", "[", 
      RowBox[{
       RowBox[{"PauliStabilizer", "[", "1", "]"}], "[", 
       RowBox[{"Join", "[", 
        RowBox[{
         RowBox[{"{", "\"\<H\>\"", "}"}], ",", " ", 
         RowBox[{"Table", "[", 
          RowBox[{"\"\<T\>\"", ",", " ", "k"}], "]"}]}], "]"}], "]"}], 
      "]"}]}], "}"}], ",", " ", 
   RowBox[{"{", 
    RowBox[{"k", ",", " ", "0", ",", " ", "5"}], "}"}]}], "]"}]], "Input",
 CellLabel->
  "In[77]:= ",ExpressionUUID->"d405edf5-8ca6-43ca-ac3b-a7c2ae936ccb"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"0", ",", "1"}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{"1", ",", "2"}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{"2", ",", "4"}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{"3", ",", "8"}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{"4", ",", "16"}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{"5", ",", "32"}], "}"}]}], "}"}]], "Output",
 CellLabel->
  "Out[77]= ",ExpressionUUID->"fe50ab70-6455-428d-8312-170f98889c89"]
}, Open  ]],

Cell[TextData[{
 "The rank goes ",
 Cell[BoxData[
  RowBox[{
   RowBox[{"1", ",", "2", ",", "4"}], 
   RowBox[{",", "\[ThinSpace]"}], "\[Ellipsis]", 
   RowBox[{",", "\[ThinSpace]"}], 
   SuperscriptBox["2", 
    StyleBox["k", "TI"]]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "416e7b1f-bec3-4d81-beb3-874d5a9f018d"],
 ": the exponential cost of magic made concrete, and the reason a ",
 Cell[BoxData[
  StyleBox["T", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "7975a601-d4cf-4c67-a130-0199838775fd"],
 "-rich circuit is hard where a Clifford circuit is easy. The frame is not \
only a counting object. Because each component carries the Pauli that relates \
it coherently to a shared reference, its dense state vector is exact, \
matching the brute-force statevector up to a single global phase. Build the \
one-",
 Cell[BoxData[
  StyleBox["T", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "a8cca1d8-0e0c-4b0e-94b5-773fe481ca60"],
 " frame:"
}], "Text",ExpressionUUID->"67b615e2-8823-4ef3-9bb4-8539c56def36"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"frame", " ", "=", " ", 
  RowBox[{
   RowBox[{"PauliStabilizer", "[", "2", "]"}], "[", 
   RowBox[{"{", 
    RowBox[{"\"\<H\>\"", ",", " ", "\"\<T\>\""}], "}"}], "]"}]}]], "Input",
 CellLabel->
  "In[78]:= ",ExpressionUUID->"5fa066de-df3f-4ba9-abb7-2df213bf7e20"],

