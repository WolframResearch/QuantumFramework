Cell[TextData[{
 "The single key tells us the ",
 Cell[BoxData[
  StyleBox[
   RowBox[{"Z", "Z"}], "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "974a9ec3-beea-4b63-8da7-3bad77c6a162"],
 " parity is certain. The same fact, as an expectation value, comes from ",
 Cell[BoxData["\"\<Expectation\>\""], "InlineFormula",ExpressionUUID->
  "ea609ff6-b8c0-4978-9f1e-becf8ff1c940"],
 ", which tracks the Aaronson-Gottesman ",
 Cell[BoxData[
  StyleBox["i", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "655645fd-742a-459d-b33b-05877004b5d9"],
 "-powers in closed form and returns ",
 Cell[BoxData[
  RowBox[{"\[PlusMinus]", "1"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "e7861b39-0fd9-4a45-a764-d1ffdf76f967"],
 " or ",
 Cell[BoxData["0"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "1c0c3653-0e39-48d7-a144-14795c04eb1f"],
 ":"
}], "Text",ExpressionUUID->"50407a73-9b17-41e3-a8e6-bb97654ade65"],

