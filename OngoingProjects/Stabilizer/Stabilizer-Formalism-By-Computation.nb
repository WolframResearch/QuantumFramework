                 TagBox["\"Destabilizers: \"", "SummaryItemAnnotation"], 
                 "\[InvisibleSpace]", 
                 TagBox[
                  RowBox[{"{", "\"X\"", "}"}], "SummaryItem"]}]}, {
               RowBox[{
                 TagBox["\"Tableau: \"", "SummaryItemAnnotation"], 
                 "\[InvisibleSpace]", 
                 TagBox[
                  TemplateBox[{
                    TagBox[
                    
                    GridBox[{{"\"\""}, {"\"-\""}}, 
                    GridBoxAlignment -> {"Columns" -> {{Left}}}, 
                    DefaultBaseStyle -> "Column", 
                    GridBoxItemSize -> {
                    "Columns" -> {{Automatic}}, "Rows" -> {{Automatic}}}], 
                    "Column"], 
                    TagBox[
                    RowBox[{"(", "\[NoBreak]", 
                    GridBox[{{
                    TagBox[
                    
                    GridBox[{{"1", "0"}, {"0", "1"}}, AutoDelete -> False, 
                    GridBoxDividers -> {
                    "ColumnsIndexed" -> {2 -> True}, 
                    "RowsIndexed" -> {2 -> True}}, 
                    GridBoxItemSize -> {
                    "Columns" -> {{Automatic}}, "Rows" -> {{Automatic}}}], 
                    "Grid"]}}, RowSpacings -> 1, ColumnSpacings -> 1, 
                    RowAlignments -> Baseline, ColumnAlignments -> Center], 
                    "\[NoBreak]", ")"}], 
                    Function[BoxForm`e$, 
                    MatrixForm[BoxForm`e$]]]}, "RowDefault"], 
                  "SummaryItem"]}]}}, AutoDelete -> False, 
             BaseStyle -> {
              ShowStringCharacters -> False, NumberMarks -> False, 
               PrintPrecision -> 3, ShowSyntaxStyles -> False}, 
             GridBoxAlignment -> {
              "Columns" -> {{Left}}, "Rows" -> {{Automatic}}}, 
             GridBoxItemSize -> {
              "Columns" -> {{Automatic}}, "Rows" -> {{Automatic}}}, 
             GridBoxSpacings -> {
              "Columns" -> {{2}}, "Rows" -> {{Automatic}}}]}}, AutoDelete -> 
          False, BaselinePosition -> {1, 1}, 
          GridBoxAlignment -> {"Columns" -> {{Left}}, "Rows" -> {{Top}}}, 
          GridBoxItemSize -> {
           "Columns" -> {{Automatic}}, "Rows" -> {{Automatic}}}]}, 
       Dynamic[Typeset`open$$], ImageSize -> Automatic]},
     "SummaryPanel"],
    DynamicModuleValues:>{}], "]"}],
  Wolfram`QuantumFramework`PauliStabilizer[<|
   "PackedX" -> {{1, 0}}, "PackedZ" -> {{0, 1}}, "Signs" -> {1, -1}, "Qubits" -> 
    1|>],
  Editable->False,
  SelectWithContents->True,
  Selectable->False]], "Output",
 CellLabel->
  "Out[10]= ",ExpressionUUID->"a75c6cf6-c524-4ce5-bb76-b32fc799c624"]
}, Open  ]],

Cell["Reading off the stabilizer makes the sign explicit:", "Text",ExpressionUUID->"9e371196-4a7b-4c7c-8a21-58235cee932d"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"PauliStabilizer", "[", "1", "]"}], "[", 
   RowBox[{"\"\<X\>\"", ",", " ", "1"}], "]"}], "[", "\"\<Stabilizers\>\"", 
  "]"}]], "Input",
 CellLabel->
  "In[11]:= ",ExpressionUUID->"2d371b45-535a-4010-b97b-4b6fb9745d2d"],

Cell[BoxData[
 RowBox[{"{", "\<\"-Z\"\>", "}"}]], "Output",
 CellLabel->
  "Out[11]= ",ExpressionUUID->"e2665c65-a10a-4c45-8db6-14cca754e855"]
}, Open  ]],

Cell[TextData[{
 "The answer is the signed string ",
 Cell[BoxData["\"\<-Z\>\""], "InlineFormula",ExpressionUUID->
  "1b8fc829-7e1e-46fb-9145-d92aefdf94f2"],
 ", the operator that fixes ",
 Cell[BoxData[
  TemplateBox[{"1"},
   "Ket"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "0bdf26b7-dd2b-4e03-a5fc-706f5583969d"],
 ". The sign is part of the stabilizer data, which is exactly why the \
formalism can tell ",
 Cell[BoxData[
  TemplateBox[{"0"},
   "Ket"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "cba40c54-061c-4a77-9a19-cfcd5c636230"],
 " from ",
 Cell[BoxData[
  TemplateBox[{"1"},
   "Ket"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "01b13118-ad16-4d3b-9eea-94a247d17a3e"],
 " even though the same unsigned ",
 Cell[BoxData[
  StyleBox["Z", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "8808ec7c-1782-4204-94e5-7060196013cb"],
 " pins both."
}], "Text",ExpressionUUID->"bf6ab9aa-48ef-404a-bbe8-7fa2c5da9930"],

Cell[TextData[{
 "A short word of honesty that will matter later. The tableau tracks the \
stabilizer group, including the signs, but it is blind to the ",
 StyleBox["overall", "TI"],
 " phase of the state. Reconstructing a state vector from a gate-updated \
tableau is therefore exact only up to a global phase. You can see this by \
acting with ",
 Cell[BoxData[
  StyleBox["Z", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "be642a8b-ca7d-42c1-abb1-357985c76df9"],
 " on ",
 Cell[BoxData[
  TemplateBox[{"+"},
   "Ket"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "ee71dcf7-b200-4ad6-bddb-5520a82d9b80"],
 ": physically ",
 Cell[BoxData[
  RowBox[{
   RowBox[{
    StyleBox["Z", "TI"], 
    TemplateBox[{"+"},
     "Ket"]}], "=", 
   TemplateBox[{"-"},
    "Ket"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "ca5ebb92-e5c3-44eb-abc9-f19fddeac1b5"],
 ", and the framework returns ",
 Cell[BoxData[
  TemplateBox[{"-"},
   "Ket"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "202eae9d-860a-4352-9c87-54d7f82cdc85"],
 " up to an overall sign."
}], "Text",ExpressionUUID->"41c27100-19f9-4b34-8b16-dca50ee5af70"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{"PauliStabilizer", "[", "1", "]"}], "[", 
      RowBox[{"\"\<H\>\"", ",", " ", "1"}], "]"}], "[", 
     RowBox[{"\"\<Z\>\"", ",", " ", "1"}], "]"}], "[", "\"\<State\>\"", "]"}],
    "[", "\"\<StateVector\>\"", "]"}], " ", "//", " ", "Normal"}]], "Input",
 CellLabel->
  "In[12]:= ",ExpressionUUID->"2cc80c08-1611-47b7-8099-e4a0140ea6a7"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{"-", 
    FractionBox["1", 
     SqrtBox["2"]]}], ",", 
   FractionBox["1", 
    SqrtBox["2"]]}], "}"}]], "Output",
 CellLabel->
  "Out[12]= ",ExpressionUUID->"27093286-129c-4776-90af-deee0b6868f6"]
}, Open  ]],

Cell["\<\
For everything observable, probabilities, expectation values, entanglement, \
the global phase is irrelevant, so this costs us nothing in practice. We flag \
it now because it is the one place where the cheap representation is \
genuinely less informative than the dense one.\
\>", "Text",ExpressionUUID->"34389af0-fb92-46e3-8556-7102290166be"],

Cell[TextData[{
 "Finally, \"being a stabilizer state\" is a decidable property of an object, \
not of a raw vector. The predicate [",
 Cell[BoxData[
 "StabilizerStateQ"], "InlineFormula",ExpressionUUID->
  "ff1cee78-663c-4b50-b2d6-a43bf1204da9"],
 "] answers ",
 Cell[BoxData[
 "True"], "InlineFormula",ExpressionUUID->
  "cbd755b1-1d2f-4be7-9a43-0e1a8ef7ad47"],
 " for a ",
 Cell[BoxData[
 "PauliStabilizer"], "InlineFormula",ExpressionUUID->
  "9d6a1800-9ebb-4d7b-87a5-e0be41635ec2"],
 " and declines a bare ",
 Cell[BoxData[
 "QuantumState"], "InlineFormula",ExpressionUUID->
  "f33c749c-fdd7-424f-b335-93635ce81c34"],
 ", because deciding stabilizer-ness from amplitudes alone requires ",
 Cell[BoxData[
  SuperscriptBox["4", 
   StyleBox["n", "TI"]]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "65826f1c-8a86-497a-99f2-f6e5dea6b547"],
 " tomography:"
}], "Text",ExpressionUUID->"5246b878-ef79-47e3-ad74-48d602b1265d"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{"StabilizerStateQ", "[", 
    RowBox[{"PauliStabilizer", "[", "1", "]"}], "]"}], ",", " ", 
   RowBox[{"StabilizerStateQ", "[", 
    RowBox[{"QuantumState", "[", "\"\<+\>\"", "]"}], "]"}]}], "}"}]], "Input",\

 CellLabel->
  "In[13]:= ",ExpressionUUID->"d74c4449-68df-4811-bae7-f5ca90492101"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"True", ",", "False"}], "}"}]], "Output",
 CellLabel->
  "Out[13]= ",ExpressionUUID->"3c313469-fe4c-490c-a98d-dcce76d05566"]
}, Open  ]],

Cell["Before moving on, the essentials so far:", "Text",ExpressionUUID->"2731a66f-fe53-4af7-9cf2-ad978d9ffe12"],

Cell[TextData[{
 "A one-qubit stabilizer state is named by the single Pauli operator that \
fixes it: ",
 Cell[BoxData[
  StyleBox["Z", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "f2edbd94-140b-45fe-8a61-491d1cf17762"],
 " for ",
 Cell[BoxData[
  TemplateBox[{"0"},
   "Ket"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "0a42d65f-f635-4771-98e0-ffa5abb26d0d"],
 ", ",
 Cell[BoxData[
  StyleBox["X", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "ef73c746-22e7-4080-a4cf-58b57296ad6d"],
 " for ",
 Cell[BoxData[
  TemplateBox[{"+"},
   "Ket"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "bb05728c-388d-4f38-bce9-38cdd5d42ad5"],
 ", ",
 Cell[BoxData[
  RowBox[{"-", 
   StyleBox["Z", "TI"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "52e27e30-5a28-473f-a2e1-1bf98aa79124"],
 " for ",
 Cell[BoxData[
  TemplateBox[{"1"},
   "Ket"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "016c84ff-e32c-44ff-b2f4-eba057ba3568"],
 "."
}], "Item",ExpressionUUID->"9c96bdb4-dcea-44f2-9dbc-4dac5660f06f"],

Cell[TextData[{
 Cell[BoxData[
 "PauliStabilizer"], "InlineFormula",ExpressionUUID->
  "88b011f5-4f2f-4d47-a67c-a799724a5175"],
 " carries that operator, not the amplitudes; the ",
 Cell[BoxData["\"\<State\>\""], "InlineFormula",ExpressionUUID->
  "b22d1133-282a-4002-8cb5-ff04f505aaf3"],
 " property hands back a full ",
 Cell[BoxData[
 "QuantumState"], "InlineFormula",ExpressionUUID->
  "0012c1c6-74b0-4690-b104-cdbbacdeb870"],
 " on demand, and ",
 Cell[BoxData["\"\<StateVector\>\""], "InlineFormula",ExpressionUUID->
  "593e0137-e6c7-4cbd-9ccd-9221c98334dd"],
 " on that object gives the raw ",
 Cell[BoxData[
  SuperscriptBox["2", 
   StyleBox["n", "TI"]]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "f1b68e25-49ad-4415-a310-19f7d1862b33"],
 " amplitudes."
}], "Item",ExpressionUUID->"05ea8de9-2308-44fd-a6c6-a836be987aca"],

Cell["\<\
The reconstructed vector is exact up to a global phase, which never affects \
an observable.\
\>", "Item",ExpressionUUID->"1aa6c50e-be87-4683-a755-c31e13e330f4"]
}, Open  ]],

Cell[CellGroupData[{

Cell[TextData[{
 "The tableau: ",
 Cell[BoxData[
  StyleBox["n", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "35394472-6c5e-46e1-bb8d-7041dc759978"],
 " generators instead of ",
 Cell[BoxData[
  SuperscriptBox["2", 
   StyleBox["n", "TI"]]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "42f31dec-eca3-4f3c-84da-bbb034c40eef"],
 " amplitudes"
}], "Section",ExpressionUUID->"fe849f2b-d2bb-4da5-9e8e-931771e76e16"],

Cell[TextData[{
 "For ",
 Cell[BoxData[
  StyleBox["n", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "72d3a136-d646-4146-aeea-4c4afc616686"],
 " qubits the idea scales because the stabilizer group is generated by just \
",
 Cell[BoxData[
  StyleBox["n", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "be087907-53f3-4aa6-9a7a-85eae7409f95"],
 " commuting, independent Pauli strings, and each Pauli string of length ",
 Cell[BoxData[
  StyleBox["n", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "7b81b00a-1253-445b-8c34-3ca8ee43981b"],
 " is two bits per qubit: an ",
 Cell[BoxData[
  StyleBox["X", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "db80186b-025b-4e78-b736-77b05ab6b5c7"],
 "-exponent and a ",
 Cell[BoxData[
  StyleBox["Z", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "405ad31b-44b8-4d94-a416-b1a9267bbe98"],
 "-exponent, since ",
 Cell[BoxData[
  RowBox[{
   StyleBox["Y", "TI"], "=", 
   StyleBox["i", "TI"], 
   StyleBox["X", "TI"], 
   StyleBox["Z", "TI"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "e24e8dab-30b5-4378-9009-a167771ac590"],
 ". So a stabilizer state is a binary matrix of shape ",
 Cell[BoxData[
  RowBox[{
   StyleBox["n", "TI"], "\[Times]", "2", 
   StyleBox["n", "TI"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "59454372-4182-4454-bc11-91d39497adb8"],
 " together with ",
 Cell[BoxData[
  StyleBox["n", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "09135ad9-df4d-4bab-8d78-6fe1ad599a00"],
 " signs, which is ",
 Cell[BoxData[
  RowBox[{
   StyleBox["O", "TI"], 
   StyleBox["(",
    SpanMaxSize->1], 
   SuperscriptBox[
    StyleBox["n", "TI"], "2"], 
   StyleBox[")",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "9bc537de-3ee2-446f-bd00-eefdf184b996"],
 " bits in place of ",
 Cell[BoxData[
  SuperscriptBox["2", 
   StyleBox["n", "TI"]]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "c35b4ce6-f91e-4b12-97ec-71434cac9487"],
 " amplitudes. This binary ",
 Cell[BoxData[
  RowBox[{
   StyleBox["(",
    SpanMaxSize->1], 
   RowBox[{
    StyleBox["X", "TI"], "\[VerticalSeparator]", 
    StyleBox["Z", "TI"]}], 
   StyleBox[")",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "19287c6f-fe80-42a4-a1bb-76843a79d050"],
 " encoding is the ",
 StyleBox["symplectic representation", "TI"],
 " of the Pauli group."
}], "Text",ExpressionUUID->"c3295bd2-49d4-4294-88c5-7fffdaead400"],

Cell[TextData[{
 "Look at the two-qubit register ",
 Cell[BoxData[
  TemplateBox[{"00"},
   "Ket"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "4626a866-b07a-4a95-a949-d08a46491ea1"],
 ". The object itself previews the generators and a tableau grid:"
}], "Text",ExpressionUUID->"ea3efc11-7afb-46e8-b3d0-2851672a20b2"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"PauliStabilizer", "[", "2", "]"}]], "Input",
 CellLabel->
  "In[14]:= ",ExpressionUUID->"69f2ffa5-26bc-4ed3-b179-21d6e2c86015"],

