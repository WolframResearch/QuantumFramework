  "InlineFormula",ExpressionUUID->"855e3fc5-afb3-4670-a926-b27cca6ec6fe"],
 ", ",
 Cell[BoxData[
  RowBox[{"ps", "[", 
   RowBox[{"\"\<SymbolicMeasure\>\"", ",", " ", "q"}], "]"}]], 
  "InlineFormula",ExpressionUUID->"4869ecfb-a1d1-41e5-9567-3cf1332c5457"],
 "."
}], "Item",ExpressionUUID->"2898bf94-5ad0-4902-b69f-fa2f3bac6ae8"],

Cell[TextData[{
 StyleBox["Entanglement entropy", "TI"],
 " across a cut: ",
 Cell[BoxData[
  RowBox[{"ps", "[", 
   RowBox[{"\"\<Entropy\>\"", ",", " ", 
    RowBox[{"{", 
     RowBox[{"1", ",", " ", "2"}], "}"}]}], "]"}]], "InlineFormula",
