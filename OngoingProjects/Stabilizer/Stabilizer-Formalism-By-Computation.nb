Cell["\<\
Then draw a thousand shots and tally the bit-strings: only the two correlated \
outcomes ever appear.\
\>", "Text",ExpressionUUID->"dd7e58a1-ef30-400c-a027-b9778eb4cc9d"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"SeedRandom", "[", "7", "]"}], ";"}], "\n", 
 RowBox[{"Counts", "[", 
  RowBox[{"readBits", " ", "/@", " ", 
   RowBox[{"smGHZ", "[", 
    RowBox[{"\"\<SampleOutcomes\>\"", ",", " ", "1000"}], "]"}]}], 
  "]"}]}], "Input",
 CellLabel->
  "In[54]:= ",ExpressionUUID->"8f06a79e-39b4-4dbe-97a4-548cc6cf6f6f"],

Cell[BoxData[
 RowBox[{"\[LeftAssociation]", 
  RowBox[{
   RowBox[{
    RowBox[{"{", 
     RowBox[{"1", ",", "1", ",", "1"}], "}"}], "\[Rule]", "492"}], ",", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"0", ",", "0", ",", "0"}], "}"}], "\[Rule]", "508"}]}], 
  "\[RightAssociation]"}]], "Output",
 CellLabel->
  "Out[54]= ",ExpressionUUID->"81485bc8-e075-45d8-9cf4-e9099c9c4714"]
}, Open  ]],

Cell["\<\
This is the payoff of carrying symbols instead of branching: the circuit \
traversal is paid for once, and any number of correlated shots then follow by \
cheap substitution. It is the in-language, exact-arithmetic cousin of the \
bulk Pauli-frame samplers the dedicated engines use for the same purpose, \
which the closing comparison returns to.\
\>", "Text",ExpressionUUID->"3a662e04-c428-477b-bfb5-30253e0da5d5"],

Cell["Scaling up: random Cliffords and compiled circuits", "Section",ExpressionUUID->"1c7dd9cc-cbb7-4174-b990-d9faf3edc7ec"],

Cell[TextData[{
 "Sampling a Clifford operation uniformly at random is a basic primitive for \
randomized benchmarking and for probing the typical entanglement of \
stabilizer states. The framework implements the Bravyi-Maslov construction \
via the Koenig-Smolin Mallows-distribution sampler, exposed as ",
 Cell[BoxData[
  RowBox[{"PauliStabilizer", "[", 
   RowBox[{"\"\<Random\>\"", "[", "n", "]"}], "]"}]], "InlineFormula",
  ExpressionUUID->"7f4b83b5-1638-4627-aabe-bc6ecbfa3fdc"],
 ". Sampling a random 200-qubit Clifford state and confirming it is a genuine \
stabilizer state is immediate:"
}], "Text",ExpressionUUID->"2e117137-e44c-4e3e-8188-d506d9fab6d2"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"SeedRandom", "[", "42", "]"}], ";"}], "\n", 
 RowBox[{"AbsoluteTiming", "[", 
  RowBox[{"StabilizerStateQ", "[", 
   RowBox[{"PauliStabilizer", "[", 
    RowBox[{"\"\<Random\>\"", "[", "200", "]"}], "]"}], "]"}], 
  "]"}]}], "Input",
 CellLabel->
  "In[55]:= ",ExpressionUUID->"c03b8fc3-b044-4a24-8f76-00190f42398e"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"0.075663`", ",", "True"}], "}"}]], "Output",
 CellLabel->
  "Out[55]= ",ExpressionUUID->"3ed0dbcb-4937-486e-a2fc-92038acb201d"]
}, Open  ]],

Cell[TextData[{
 "That random state arrives as a bare tableau, with no circuit attached. The ",
 Cell[BoxData["\"\<Circuit\>\""], "InlineFormula",ExpressionUUID->
  "ab6c65e0-ea62-4697-a09d-534124260e1b"],
 " property hands one back: an explicit Clifford circuit that prepares the \
state from ",
 Cell[BoxData[
  TemplateBox[{
    RowBox[{"0", "\[Ellipsis]", "0"}]},
   "Ket"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "2ea529dc-acde-493f-a79b-691ac867b33e"],
 ", by the Aaronson-Gottesman canonical decomposition. Unlike the membership \
test above, this direction has real cost: the synthesis is ",
 Cell[BoxData[
  RowBox[{
   StyleBox["O", "TI"], 
   StyleBox["(",
    SpanMaxSize->1], 
   SuperscriptBox[
    StyleBox["n", "TI"], "3"], 
   StyleBox[")",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "9bc9f09b-ba38-494a-808e-eabdf79f2d30"],
 " gates and is ",
 StyleBox["not", "TI"],
 " length-minimized, so it is a moderate-",
 Cell[BoxData[
  StyleBox["n", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "645f6eec-31e6-473d-b60b-31d0cc3ce582"],
 " tool rather than a thousand-qubit one. On a ten-qubit random Clifford it \
is immediate. Sample one:"
}], "Text",ExpressionUUID->"32008b34-e41e-499a-9d78-88fcdda38e4a"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"SeedRandom", "[", "11", "]"}], ";"}], "\n", 
 RowBox[{"ps10", " ", "=", " ", 
  RowBox[{"PauliStabilizer", "[", 
   RowBox[{"\"\<Random\>\"", "[", "10", "]"}], "]"}]}]}], "Input",
 CellLabel->
  "In[56]:= ",ExpressionUUID->"aba7b6a9-1059-46ce-8c6d-4c491c6beb17"],

