 RowBox[{"{", 
  RowBox[{"\<\"1 - 2*\[FormalS][1]*ZI\"\>", ",", "\<\"ZZ\"\>"}], 
  "}"}]], "Output",
 CellLabel->
  "Out[49]= ",ExpressionUUID->"46046bc5-9dd7-40b3-a20f-f3eca9c59765"]
}, Open  ]],

Cell[TextData[{
 "The sign of the first generator is now ",
 Cell[BoxData[
  RowBox[{"1", "-", "2", 
   SubscriptBox[
    StyleBox["s", "TI"], "1"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "be80e78a-6409-401e-bda2-72898909288d"],
 ", which is ",
 Cell[BoxData[
  RowBox[{"+", "1"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "8955762e-e1e7-4443-b4e2-edc7afccac78"],
 " at ",
 Cell[BoxData[
  RowBox[{
   SubscriptBox[
    StyleBox["s", "TI"], "1"], "=", "0"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "97daf722-0329-402a-967f-f00b22a52eb4"],
 " and ",
 Cell[BoxData[
  RowBox[{"-", "1"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "97bc720d-dd94-43bf-ae8f-4c04086dd216"],
 " at ",
 Cell[BoxData[
  RowBox[{
   SubscriptBox[
    StyleBox["s", "TI"], "1"], "=", "1"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "c85ed56d-b507-4d18-bb36-e6e70a48fd11"],
 ": the formal bit ",
 StyleBox["is", "TI"],
 " the unmade measurement. (The subscript on ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["s", "TI"], 
   StyleBox["k", "TI"]]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "a4741ce7-346e-4151-ac94-8ffa443037db"],
 " is a running session counter, so measuring again or re-running these cells \
allocates ",
 Cell[BoxData[
  RowBox[{
   SubscriptBox[
    StyleBox["s", "TI"], "2"], 
   RowBox[{",", "\[ThinSpace]"}], 
   SubscriptBox[
    StyleBox["s", "TI"], "3"], 
   RowBox[{",", "\[ThinSpace]"}], "\[Ellipsis]"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "0555751a-91ff-4db3-9a5f-5d1f006ebee9"],
 ".) Substituting a concrete value resolves it, and the two substitutions \
give exactly the two branches we saw above:"
}], "Text",ExpressionUUID->"2765f53e-80c4-4d4f-bf57-1a07b05b638e"],

