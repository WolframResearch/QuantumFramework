Cell[TextData[{
 "The raw symplectic data is ",
 Cell[BoxData["\"\<Tableau\>\""], "InlineFormula",ExpressionUUID->
  "22bb8cad-da1b-4d64-85b7-04d84a983933"],
 ", a rank-3 array stacking the ",
 Cell[BoxData[
  StyleBox["X", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "098782af-f738-46bd-b40d-7bec53f4cd01"],
 " block above the ",
 Cell[BoxData[
  StyleBox["Z", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "4d97e01b-e2b2-43ff-ae4b-b9d840c15420"],
 " block (shape ",
 Cell[BoxData[
  RowBox[{"2", "\[Times]", 
   StyleBox["n", "TI"], "\[Times]", "2", 
   StyleBox["n", "TI"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "8de09427-ec21-4564-bcdd-635d5b1cc78c"],
 ", here ",
 Cell[BoxData[
  RowBox[{"2", "\[Times]", "2", "\[Times]", "4"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "a26881d9-2ae4-4475-9551-d5f31083596a"],
 ": two blocks, ",
 Cell[BoxData[
  RowBox[{
   StyleBox["n", "TI"], "=", "2"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "801d4c9e-000d-4b91-beff-6d10c50114b8"],
 " qubits, ",
 Cell[BoxData[
  RowBox[{"2", 
   StyleBox["n", "TI"], "=", "4"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "721eef04-39a4-4189-ab2a-da1c574ae86c"],
 " rows):"
}], "Text",ExpressionUUID->"81b40209-714b-4d53-b5e1-674a62bcf2f6"],

