Cell[TextData[{
 "Each generator is an ",
 Cell[BoxData[
  StyleBox["X", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "33ff9ee4-f37d-4c29-96d7-91a65e83580f"],
 " on one vertex dressed by ",
 Cell[BoxData[
  StyleBox["Z", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "a92bde90-eb49-4df9-8a9e-a7ea66a2578f"],
 " on its neighbors, the cluster-state structure. A graph state is an \
ordinary stabilizer state, so it converts to a ",
 Cell[BoxData[
 "PauliStabilizer"], "InlineFormula",ExpressionUUID->
  "a94832e3-1e6d-43a1-80e1-b4b608973deb"],
 " and answers the same questions. The 4-cycle cluster carries two bits of \
entanglement across the cut ",
 Cell[BoxData[
  RowBox[{
   RowBox[{"{", "1"}], 
   RowBox[{",", "\[ThinSpace]"}], 
   RowBox[{"2", "}", "\[VerticalSeparator]", "{", "3"}], 
   RowBox[{",", "\[ThinSpace]"}], 
   RowBox[{"4", "}"}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "7610dad9-5c6a-46e2-a033-e8b0523fea63"],
 ", one per edge crossing it:"
}], "Text",ExpressionUUID->"bfd5f3ba-362d-44bc-abf5-8f595b6566b5"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{"StabilizerStateQ", "[", 
    RowBox[{"gs", "[", "\"\<PauliStabilizer\>\"", "]"}], "]"}], ",", " ", 
   RowBox[{
    RowBox[{"gs", "[", "\"\<PauliStabilizer\>\"", "]"}], "[", 
    RowBox[{"\"\<Entropy\>\"", ",", " ", 
     RowBox[{"{", 
      RowBox[{"1", ",", " ", "2"}], "}"}]}], "]"}]}], "}"}]], "Input",
 CellLabel->
  "In[73]:= ",ExpressionUUID->"df13c714-e6e9-47fb-b962-aa4cc15e1e64"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"True", ",", "2"}], "}"}]], "Output",
 CellLabel->
  "Out[73]= ",ExpressionUUID->"9940f5a4-d1d6-4466-bde7-7c854cee0a92"]
}, Open  ]],

Cell[TextData[{
 "The graph is a far more compact record than the tableau when the state is \
sparse. A path graph gives the one-dimensional cluster state of \
measurement-based computation, each generator a local ",
 Cell[BoxData[
  StyleBox[
   RowBox[{"X", "Z"}], "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "ed65879e-7603-416c-a484-218a9439be39"],
 " pattern:"
}], "Text",ExpressionUUID->"a0d9dfc0-6899-4fe9-8767-a8d15d5ac10c"],

