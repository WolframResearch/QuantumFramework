Cell[TextData[{
 "What comes back is an ordinary ",
 Cell[BoxData[
 "QuantumState"], "InlineFormula",ExpressionUUID->
  "42b1dcba-f934-41cf-850e-41ac9de3d07d"],
 " object, so a stabilizer state drops straight into the rest of the \
framework. Chaining ",
 Cell[BoxData["\"\<StateVector\>\""], "InlineFormula",ExpressionUUID->
  "5785705b-845e-49ad-8cd8-132c832a5d0f"],
 " on that object reads off the raw ",
 Cell[BoxData[
  SuperscriptBox["2", 
   StyleBox["n", "TI"]]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "3719e794-b0b9-4c9e-813d-6e6972f8fca9"],
 " amplitudes, here the single column ",
 Cell[BoxData[
  TemplateBox[{"0"},
   "Ket"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "3aa6dc23-2ed7-450e-821d-92f1495dd3e0"],
 ":"
}], "Text",ExpressionUUID->"28c403e6-cfe5-47c8-9490-0ed5d942a341"],

