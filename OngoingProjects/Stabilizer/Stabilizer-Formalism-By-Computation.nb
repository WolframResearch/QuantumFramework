   "]"}], " ", "//", " ", "Normal"}]], "Input",
 CellLabel->
  "In[38]:= ",ExpressionUUID->"670a67b0-6135-4f91-acd2-5f65b2d51a46"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   FractionBox["1", 
    SqrtBox["2"]], ",", "0", ",", "0", ",", 
   FractionBox["1", 
    SqrtBox["2"]]}], "}"}]], "Output",
 CellLabel->
  "Out[38]= ",ExpressionUUID->"228b9456-f7c0-451a-a560-b483f4f9530b"]
}, Open  ]],

Cell[TextData[{
 "Entanglement entropy, normally a Schmidt-decomposition computation that \
blows up with system size, has a closed form for stabilizer states. Fattal \
and collaborators showed that the entanglement entropy across a cut ",
 Cell[BoxData[
  StyleBox["A", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "c9f101ea-33d0-4695-b400-b12a092b1ddf"],
 " equals the ",
 Cell[BoxData[
  SubscriptBox["\|01d53d", "2"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "e0a6fdf9-225f-4280-949a-52c579a35d15"],
 "-rank of the generators restricted to ",
 Cell[BoxData[
  StyleBox["A", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "4917fc66-78bb-4906-94cc-9805d12d9292"],
 " (for each generator keep only the symplectic columns of the qubits in ",
 Cell[BoxData[
  StyleBox["A", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "2a606a93-b2ea-4d7c-89d2-19d852fd230c"],
 "), minus ",
 Cell[BoxData[
  RowBox[{
   StyleBox["\[LeftBracketingBar]",
    SpanMaxSize->1], 
   StyleBox["A", "TI"], "\[VeryThinSpace]", 
   StyleBox["\[RightBracketingBar]",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "86250c2c-60c9-4387-afc1-c25fb0f50454"],
 ". The framework computes this with ",
 Cell[BoxData["\"\<Entropy\>\""], "InlineFormula",ExpressionUUID->
  "21013051-f70e-4492-913b-bac1bf2fa93a"],
 ", in ",
 Cell[BoxData[
  RowBox[{
   StyleBox["O", "TI"], 
   StyleBox["(",
    SpanMaxSize->1], 
   SuperscriptBox[
    StyleBox["n", "TI"], "3"], 
   StyleBox[")",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "01c1d9b3-3fdb-45f0-b827-3d7210d4d7ca"],
 " and with no dependence on ",
 Cell[BoxData[
  RowBox[{
   StyleBox["\[LeftBracketingBar]",
    SpanMaxSize->1], 
   StyleBox["A", "TI"], "\[VeryThinSpace]", 
   StyleBox["\[RightBracketingBar]",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "8b1607ea-2e37-4f65-9766-0b21a9c07a3a"],
 ". For the Bell state, tracing out one qubit gives one bit of entropy:"
}], "Text",ExpressionUUID->"fe9fa052-b6e2-4db6-ab6e-ac97f77307f6"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"bell", "[", 
  RowBox[{"\"\<Entropy\>\"", ",", " ", 
   RowBox[{"{", "1", "}"}]}], "]"}]], "Input",
 CellLabel->
  "In[39]:= ",ExpressionUUID->"f78c36b1-3195-4f5a-ab43-e51a00f7ad39"],

Cell[BoxData["1"], "Output",
 CellLabel->
  "Out[39]= ",ExpressionUUID->"3e36bb89-9935-46eb-b59d-f89c5a176291"]
}, Open  ]],

Cell[TextData[{
 "The payoff is scale. A GHZ state on a thousand qubits is built by one \
Hadamard and a ladder of CNOTs. Build it (the object prints as a compact \
summary, never forming a ",
 Cell[BoxData[
  SuperscriptBox["2", "1000"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "3550a091-bbdf-4e05-b1ac-ab686dbb0768"],
 " vector):"
}], "Text",ExpressionUUID->"a3151d7c-654c-46ba-b030-a7832bac53f3"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"ghz", " ", "=", " ", 
  RowBox[{
   RowBox[{"PauliStabilizer", "[", "1000", "]"}], "[", 
   RowBox[{"Prepend", "[", 
    RowBox[{
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{"\"\<CNOT\>\"", " ", "->", " ", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"q", " ", "-", " ", "1"}], ",", " ", "q"}], "}"}]}], ",", 
       " ", 
       RowBox[{"{", 
        RowBox[{"q", ",", " ", "2", ",", " ", "1000"}], "}"}]}], "]"}], ",", 
     " ", "\"\<H\>\""}], "]"}], "]"}]}]], "Input",
 CellLabel->
  "In[40]:= ",ExpressionUUID->"58cafb55-49a8-4b4b-978c-c070a5c5f0bf"],

