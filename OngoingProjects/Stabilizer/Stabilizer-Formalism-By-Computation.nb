Cell[TextData[{
 "The single key tells us the ",
 Cell[BoxData[
  StyleBox[
   RowBox[{"Z", "Z"}], "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "a2ab8ab7-50b1-4be9-a844-d0f858245d28"],
 " parity is certain. The same fact, as an expectation value, comes from ",
 Cell[BoxData["\"\<Expectation\>\""], "InlineFormula",ExpressionUUID->
  "5a51b889-9ab6-4b5c-9974-d3bdf820c0d4"],
 ", which tracks the Aaronson-Gottesman ",
 Cell[BoxData[
  StyleBox["i", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "52db5c24-a77a-4402-86f1-f7a5fdf16eaa"],
 "-powers in closed form and returns ",
 Cell[BoxData[
  RowBox[{"\[PlusMinus]", "1"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "ec5d1512-06e0-41b4-a445-7a6553107878"],
 " or ",
 Cell[BoxData["0"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "49a66982-8a56-4f5b-bc4c-07c356349ff2"],
 ":"
}], "Text",ExpressionUUID->"49d9bce7-c211-4bcb-b2ec-5c578c4ef293"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{"bell", "[", 
    RowBox[{"\"\<Expectation\>\"", ",", " ", "\"\<ZZ\>\""}], "]"}], ",", " ", 
   
   RowBox[{"bell", "[", 
    RowBox[{"\"\<Expectation\>\"", ",", " ", "\"\<XX\>\""}], "]"}], ",", " ", 
   
   RowBox[{"bell", "[", 
    RowBox[{"\"\<Expectation\>\"", ",", " ", "\"\<ZI\>\""}], "]"}]}], 
  "}"}]], "Input",
 CellLabel->
  "In[47]:= ",ExpressionUUID->"93e727a9-450d-4698-a9ed-567154221dc4"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"1", ",", "1", ",", "0"}], "}"}]], "Output",
 CellLabel->
  "Out[47]= ",ExpressionUUID->"d6100446-b18d-4c14-8014-e9b60d8fa539"]
}, Open  ]],

Cell[TextData[{
 "The parities ",
 Cell[BoxData[
  StyleBox[
   RowBox[{"Z", "Z"}], "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "264a1e94-53d8-4c76-a715-0cc214930b97"],
 " and ",
 Cell[BoxData[
  StyleBox[
   RowBox[{"X", "X"}], "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "0afc9070-8333-4458-97a7-f82c9a70bb47"],
 " are certain (",
 Cell[BoxData[
  RowBox[{"+", "1"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "2ce3e76f-4276-4b3e-86ca-3bb2571b5015"],
 "), while a single-qubit ",
 Cell[BoxData[
  StyleBox["Z", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "ab548ae5-117d-4435-8ced-7deaf70f73c6"],
 " is maximally uncertain (",
 Cell[BoxData["0"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "dbadb6b2-f9fb-4e32-aec5-fb941ae00882"],
 "), the hallmark of an entangled state whose marginals are maximally mixed."
}], "Text",ExpressionUUID->"624d2bfc-3dfd-4f25-b941-922332d5b1cb"],

Cell[TextData[{
 "There is a more efficient way to handle many shots, and it exposes \
something the branching picture hides. The Association ",
 Cell[BoxData[
  RowBox[{"ps", "[", 
   RowBox[{"\"\<M\>\"", ",", " ", "q"}], "]"}]], "InlineFormula",
  ExpressionUUID->"a76c2337-53e4-4216-910f-34ada65e82ba"],
 " is the honest per-shot view, but it scales badly: a circuit with ",
 Cell[BoxData[
  StyleBox["r", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "3b4bd871-c56b-41c0-8ed9-eae85d29f0de"],
 " random measurements has a tree of up to ",
 Cell[BoxData[
  SuperscriptBox["2", 
   StyleBox["r", "TI"]]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "ab001f1e-9227-4672-98f4-9b57b9bb2a15"],
 " outcome branches, so gathering statistics that way means either expanding \
the whole tree or re-traversing the circuit once per sample. The SymPhase \
technique of Fang and Ying replaces the branching with bookkeeping. The \
circuit is traversed ",
 StyleBox["once", "TI"],
 ", and each unresolved random outcome is recorded as a fresh formal bit ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["s", "TI"], 
   StyleBox["k", "TI"]]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "a043d0a3-88c3-4669-a1a7-a014ca861ff6"],
 " written into a sign, leaving the state a single ",
 Cell[BoxData[
 "PauliStabilizer"], "InlineFormula",ExpressionUUID->
  "7dd301a7-f672-4470-bf78-1ad0eb019f59"],
 ". A symbolic ",
 Cell[BoxData[
  StyleBox["Z", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "99edbf41-345b-4d6e-9038-272823393bfc"],
 "-measurement of Bell qubit 1 introduces one such bit:"
}], "Text",ExpressionUUID->"e85b4a08-ba39-4a57-ac12-4efa93ffff0b"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"sm", " ", "=", " ", 
