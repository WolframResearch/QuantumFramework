}, Open  ]],

Cell[TextData[{
 "Different states are fixed by different operators. The state ",
 Cell[BoxData[
  RowBox[{
   TemplateBox[{"+"},
    "Ket"], "=", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{
      TemplateBox[{"0"},
       "Ket"], "+", 
      TemplateBox[{"1"},
       "Ket"]}], ")"}], "/", 
    SqrtBox["2"]}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "0e27dfaa-c4e4-4b5f-8792-86858b2bc958"],
 " is the ",
 Cell[BoxData[
  RowBox[{"+", "1"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "03511c35-b787-489d-a446-c2ecae99e628"],
 " eigenstate of ",
 Cell[BoxData[
  StyleBox["X", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "72705c4b-b292-4056-83c4-c5786e275138"],
 ", and a Hadamard turns one into the other. Apply ",
 Cell[BoxData[
  StyleBox["H", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "9adb5c01-9f64-4aad-b999-08688cb94d84"],
 " to ",
 Cell[BoxData[
  TemplateBox[{"0"},
   "Ket"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "b093da0c-50e0-4375-a3b5-50188d7f49e9"],
 " and read the new stabilizer:"
}], "Text",ExpressionUUID->"83a28dcf-40bc-46d5-a98a-ac3b18255702"],

