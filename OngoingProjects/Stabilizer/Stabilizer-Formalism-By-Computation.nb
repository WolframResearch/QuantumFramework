  "fc3f7a19-55c4-4520-a62a-b8240707709b"],
 "."
}], "Item",ExpressionUUID->"cf4c624a-8029-42ed-9e17-3443c2f72fe9"],

Cell[TextData[{
 StyleBox["Measure", "TI"],
 ": ",
 Cell[BoxData[
  RowBox[{"ps", "[", 
   RowBox[{"\"\<M\>\"", ",", " ", "q"}], "]"}]], "InlineFormula",
