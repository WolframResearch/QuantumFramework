}, Open  ]],

Cell[TextData[{
 "The parities ",
 Cell[BoxData[
  StyleBox[
   RowBox[{"Z", "Z"}], "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "5aefe2d9-bb82-464f-9062-5d3f485bc2b0"],
 " and ",
 Cell[BoxData[
  StyleBox[
   RowBox[{"X", "X"}], "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "49daa438-6d3d-46e7-a09d-665878aeebe7"],
 " are certain (",
 Cell[BoxData[
  RowBox[{"+", "1"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "5080ef41-8f07-4456-a6e6-62f388990e87"],
 "), while a single-qubit ",
 Cell[BoxData[
  StyleBox["Z", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "6dd204e8-b1fe-4e1f-a2fa-3958eded687f"],
 " is maximally uncertain (",
 Cell[BoxData["0"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "636b1611-7cb3-4477-b3ed-9d0cdc94d403"],
 "), the hallmark of an entangled state whose marginals are maximally mixed."
}], "Text",ExpressionUUID->"d03a1655-7164-4937-ab88-1fde27cfd5c8"],

Cell[TextData[{
 "There is a more efficient way to handle many shots. Rather than branch the \
state at every random measurement and re-traverse the circuit per sample, the \
SymPhase technique of Fang and Ying carries the unresolved outcomes as fresh \
formal symbols in the signs, so one traversal serves all samples. A symbolic ",
 Cell[BoxData[
  StyleBox["Z", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "27c46152-8713-4013-a38c-b37bdc6ea094"],
 "-measurement of Bell qubit 1 introduces a formal outcome symbol:"
}], "Text",ExpressionUUID->"03697448-4d8f-480e-b74b-a31cf8081746"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"sm", " ", "=", " ", 
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{"PauliStabilizer", "[", "2", "]"}], "[", 
      RowBox[{"\"\<H\>\"", ",", " ", "1"}], "]"}], "[", 
     RowBox[{"\"\<CNOT\>\"", ",", " ", "1", ",", " ", "2"}], "]"}], "[", 
    RowBox[{"\"\<SymbolicMeasure\>\"", ",", " ", "1"}], "]"}]}], 
  ";"}], "\n", 
 RowBox[{"sm", "[", "\"\<Stabilizers\>\"", "]"}]}], "Input",
 CellLabel->
  "In[24]:= ",ExpressionUUID->"41ac32d5-ec57-48de-972d-7914cc917610"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"\<\"1 - 2*\[FormalS][1]*ZI\"\>", ",", "\<\"ZZ\"\>"}], 
  "}"}]], "Output",
 CellLabel->
  "Out[24]= ",ExpressionUUID->"1f6080fb-24d1-427f-8040-6da5c4d5c523"]
}, Open  ]],

Cell[TextData[{
 "The sign of the first generator now carries the formal symbol ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["s", "TI"], "1"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "c807213a-4a3d-47ab-8208-ed15862503d9"],
 ". Substituting a concrete outcome resolves the state, and the two \
substitutions give exactly the two branches we saw above:"
}], "Text",ExpressionUUID->"3e0af831-69e4-456a-b10c-9a3b7a23f9db"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{
    RowBox[{"sm", "[", 
     RowBox[{"\"\<SubstituteOutcomes\>\"", ",", " ", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"\[FormalS]", "[", "1", "]"}], " ", "->", " ", "0"}], "}"}]}],
      "]"}], "[", "\"\<Stabilizers\>\"", "]"}], ",", "\n", " ", 
   RowBox[{
    RowBox[{"sm", "[", 
     RowBox[{"\"\<SubstituteOutcomes\>\"", ",", " ", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"\[FormalS]", "[", "1", "]"}], " ", "->", " ", "1"}], "}"}]}],
      "]"}], "[", "\"\<Stabilizers\>\"", "]"}]}], "}"}]], "Input",
 CellLabel->
  "In[25]:= ",ExpressionUUID->"02479e32-bcec-4ea5-9f9a-9559f18a370c"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"\<\"ZI\"\>", ",", "\<\"ZZ\"\>"}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{"\<\"-ZI\"\>", ",", "\<\"ZZ\"\>"}], "}"}]}], "}"}]], "Output",
 CellLabel->
  "Out[25]= ",ExpressionUUID->"3b74645f-bdc2-4f5e-b9bd-9e470d524f17"]
}, Open  ]],

Cell["Scaling up: random Cliffords and compiled circuits", "Section",ExpressionUUID->"77671083-034a-4bf9-99b4-915da25451a5"],

Cell[TextData[{
 "Sampling a Clifford operation uniformly at random is a basic primitive for \
randomized benchmarking and for probing the typical entanglement of \
stabilizer states. The framework implements the Bravyi-Maslov construction \
via the Koenig-Smolin Mallows-distribution sampler, exposed as ",
 Cell[BoxData[
  RowBox[{"PauliStabilizer", "[", 
   RowBox[{"\"\<Random\>\"", "[", "n", "]"}], "]"}]], "InlineFormula",
  ExpressionUUID->"5bc5d43c-91bf-4a96-b69e-946bf28ceb43"],
 ". Sampling a random 200-qubit Clifford state and confirming it is a genuine \
stabilizer state is immediate:"
}], "Text",ExpressionUUID->"34f98efa-198b-45ca-a0ad-a22c4264bc27"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"SeedRandom", "[", "42", "]"}], ";"}], "\n", 
 RowBox[{"AbsoluteTiming", "[", 
  RowBox[{"StabilizerStateQ", "[", 
   RowBox[{"PauliStabilizer", "[", 
    RowBox[{"\"\<Random\>\"", "[", "200", "]"}], "]"}], "]"}], 
  "]"}]}], "Input",
 CellLabel->
  "In[26]:= ",ExpressionUUID->"2778381e-d07d-45a1-ae17-771fe4f00ad2"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"0.075375`", ",", "True"}], "}"}]], "Output",
 CellLabel->
  "Out[26]= ",ExpressionUUID->"1947501c-89de-4fb0-8e7d-c815e0fadacf"]
}, Open  ]],

Cell[TextData[{
 "For long Clifford circuits the framework folds the entire gate list through \
a single compiled (C) kernel that operates on a bit-packed, generator-major \
tableau, the same data layout the specialized simulators use. The method is \
",
 Cell[BoxData[
  RowBox[{"ps", "[", 
   RowBox[{"\"\<ApplyCircuit\>\"", ",", " ", "gates"}], "]"}]], 
  "InlineFormula",ExpressionUUID->"df98bb6a-a22f-4430-ba45-896f5b5419a1"],
 ". Run a four-thousand-gate random Clifford stream on two hundred qubits and \
watch the wall-clock:"
}], "Text",ExpressionUUID->"6f79a7cd-b3e9-4de8-8a3a-a97569bb6a11"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"SeedRandom", "[", "1", "]"}], ";"}], "\n", 
 RowBox[{
  RowBox[{"specs", " ", "=", " ", 
   RowBox[{"Table", "[", "\n", "   ", 
    RowBox[{
     RowBox[{"RandomChoice", "[", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"\"\<H\>\"", " ", "->", " ", 
         RowBox[{"RandomInteger", "[", 
          RowBox[{"{", 
           RowBox[{"1", ",", " ", "200"}], "}"}], "]"}]}], ",", " ", 
        RowBox[{"\"\<S\>\"", " ", "->", " ", 
         RowBox[{"RandomInteger", "[", 
          RowBox[{"{", 
           RowBox[{"1", ",", " ", "200"}], "}"}], "]"}]}], ",", "\n", "     ", 
        RowBox[{"\"\<CNOT\>\"", " ", "->", " ", 
         RowBox[{"RandomSample", "[", 
          RowBox[{
           RowBox[{"Range", "[", "200", "]"}], ",", " ", "2"}], "]"}]}]}], 
       "}"}], "]"}], ",", "\n", "   ", 
     RowBox[{"{", "4000", "}"}]}], "]"}]}], ";"}], "\n", 
 RowBox[{"AbsoluteTiming", "[", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"PauliStabilizer", "[", "200", "]"}], "[", 
     RowBox[{"\"\<ApplyCircuit\>\"", ",", " ", "specs"}], "]"}], 
    "[", "\"\<Stabilizers\>\"", "]"}], "[", 
   RowBox[{"[", "1", "]"}], "]"}], "]"}]}], "Input",
 CellLabel->
  "In[27]:= ",ExpressionUUID->"f6a36f95-a108-4c98-8ff5-1b6392182987"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
  "1.069458`", 
   ",", "\<\"-\
XYIYZIIZZIXIIZZIYZIZIXYXIXYIXYZZXYXXYIIZZXIXXYIZXYIZYIXIYZZYIIXXZIIXXZYYYZZIXY\
ZIYZIXIYYYYZIXXXYXZZXXXZIIXZIIIIZXYYYXXYXXYXIXXZIZYIXZZXYZZIYIXZXXXIIXZXIYZZYI\
XIXZXXIIZIYIYXIIXIYXYZYZYIXZYIIZXIYIIZIZXZIZ\"\>"}], "}"}]], "Output",
 CellLabel->
  "Out[27]= ",ExpressionUUID->"256684fa-db10-4f16-8029-ff55641be4ac"]
}, Open  ]],

Cell[TextData[{
 "That is roughly a quarter of a microsecond per gate, flat in the number of \
qubits, because each gate touches only the machine words of its own column. \
The same engine backs the circuit object: a ",
 Cell[BoxData[
 "QuantumCircuitOperator"], "InlineFormula",ExpressionUUID->
  "74df334b-4960-4927-b254-38d6e2d41d74"],
 " applied with ",
 Cell[BoxData[
  RowBox[{"Method", " ", "->", " ", "\"\<Stabilizer\>\""}]], "InlineFormula",
  ExpressionUUID->"022c6282-5559-4760-9056-8ddbe9b0c90b"],
 " evolves a stabilizer state directly. Build a Bell circuit and run it \
through the stabilizer backend:"
}], "Text",ExpressionUUID->"9f0a44ad-61bf-4147-b82e-ab66fb631f7a"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"qc", " ", "=", " ", 
   RowBox[{"QuantumCircuitOperator", "[", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"\"\<H\>\"", " ", "->", " ", "1"}], ",", " ", 
      RowBox[{"\"\<CNOT\>\"", " ", "->", " ", 
       RowBox[{"{", 
        RowBox[{"1", ",", " ", "2"}], "}"}]}]}], "}"}], "]"}]}], 
  ";"}], "\n", 
 RowBox[{
  RowBox[{"r", " ", "=", " ", 
   RowBox[{"qc", "[", 
    RowBox[{
     RowBox[{"QuantumState", "[", "\"\<00\>\"", "]"}], ",", " ", 
     RowBox[{"Method", " ", "->", " ", "\"\<Stabilizer\>\""}]}], "]"}]}], 
  ";"}], "\n", 
 RowBox[{"{", 
  RowBox[{
   RowBox[{"Head", "[", "r", "]"}], ",", " ", 
   RowBox[{"r", "[", "\"\<Stabilizers\>\"", "]"}]}], "}"}]}], "Input",
 CellLabel->
  "In[28]:= ",ExpressionUUID->"f70c8c56-cc3c-40ba-8abf-5f5fe53834ad"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"PauliStabilizer", ",", 
   RowBox[{"{", 
    RowBox[{"\<\"XX\"\>", ",", "\<\"ZZ\"\>"}], "}"}]}], "}"}]], "Output",
 CellLabel->
  "Out[28]= ",ExpressionUUID->"efa712ff-3efe-4baf-9a49-8b4bb7306abb"]
}, Open  ]],

Cell[TextData[{
 "The result is a ",
 Cell[BoxData[
 "PauliStabilizer"], "InlineFormula",ExpressionUUID->
  "29b95ef5-4850-442c-8d23-ecf30eb5b958"],
 ", not a dense state, and it agrees with the brute-force statevector path up \
to the global phase discussed earlier. Confirm the agreement on a random \
30-gate Clifford circuit by comparing the overlap magnitude:"
}], "Text",ExpressionUUID->"21a24258-7239-4563-9d57-f4d4e4405844"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"SeedRandom", "[", "7", "]"}], ";"}], "\n", 
 RowBox[{
  RowBox[{"specs2", " ", "=", " ", 
   RowBox[{"Table", "[", "\n", "   ", 
    RowBox[{
     RowBox[{"RandomChoice", "[", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"\"\<H\>\"", " ", "->", " ", 
         RowBox[{"RandomInteger", "[", 
          RowBox[{"{", 
           RowBox[{"1", ",", " ", "4"}], "}"}], "]"}]}], ",", " ", 
        RowBox[{"\"\<S\>\"", " ", "->", " ", 
         RowBox[{"RandomInteger", "[", 
          RowBox[{"{", 
           RowBox[{"1", ",", " ", "4"}], "}"}], "]"}]}], ",", "\n", "     ", 
        RowBox[{"\"\<CNOT\>\"", " ", "->", " ", 
         RowBox[{"RandomSample", "[", 
          RowBox[{
           RowBox[{"Range", "[", "4", "]"}], ",", " ", "2"}], "]"}]}]}], 
       "}"}], "]"}], ",", "\n", "   ", 
     RowBox[{"{", "30", "}"}]}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"dense", " ", "=", " ", 
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{"QuantumCircuitOperator", "[", "specs2", "]"}], "[", 
      RowBox[{
       RowBox[{"QuantumState", "[", "\"\<0000\>\"", "]"}], ",", " ", 
       RowBox[{"Method", " ", "->", " ", "\"\<Schrodinger\>\""}]}], "]"}], 
     "[", "\"\<StateVector\>\"", "]"}], " ", "//", " ", "Normal"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"stab", " ", "=", " ", 
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{"PauliStabilizer", "[", "4", "]"}], "[", 
       RowBox[{"\"\<ApplyCircuit\>\"", ",", " ", "specs2"}], "]"}], 
      "[", "\"\<State\>\"", "]"}], "[", "\"\<StateVector\>\"", "]"}], " ", "//",
     " ", "Normal"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"Chop", "[", 
   RowBox[{
    RowBox[{"Abs", "[", 
     RowBox[{
      RowBox[{"Conjugate", "[", "dense", "]"}], " ", ".", " ", "stab"}], 
     "]"}], " ", "-", " ", "1"}], "]"}], " ", "==", " ", "0"}]}], "Input",
 CellLabel->
  "In[29]:= ",ExpressionUUID->"554e00b2-8486-4f3a-b7ff-aab7805857f8"],

Cell[BoxData["True"], "Output",
 CellLabel->
  "Out[29]= ",ExpressionUUID->"5d1b396c-9c04-442e-979a-409f0c535a3f"]
}, Open  ]],

Cell[TextData[{
 "A performance caveat that is also a design lesson. The convenience \
constructor ",
 Cell[BoxData[
  RowBox[{"PauliStabilizer", "[", "circuit", "]"}]], "InlineFormula",
  ExpressionUUID->"412aaa84-c29f-4431-826e-4a4919632388"],
 " converts an arbitrary circuit by Pauli-conjugating each gate through full \
tomography, which is exponential in the qubit count and is meant only for \
tiny circuits. For anything at scale, use the gate-update chain or ",
 Cell[BoxData["\"\<ApplyCircuit\>\""], "InlineFormula",ExpressionUUID->
  "7668850a-9834-43cf-b598-52e34b861ddc"],
 ", which stay in the tableau. The right tool for the job is the difference \
between milliseconds and minutes."
}], "Text",ExpressionUUID->"b629050f-50e1-439c-b0fa-5a5b50ddadbe"],

Cell["Error-correcting codes as stabilizer states", "Section",ExpressionUUID->"d56e4067-6024-4098-8a06-42b8581bcb9a"],

Cell[TextData[{
 "Quantum error-correcting codes were the original motivation for the \
formalism: a code is defined by its stabilizer group, and a logical codeword \
is the simultaneous ",
 Cell[BoxData[
  RowBox[{"+", "1"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "d50d6611-616e-4e2f-b97f-35d613ed4ae9"],
 " eigenstate of the parity checks. The framework ships the canonical \
examples as named codes. The five-qubit perfect code is generated by four \
weight-four checks plus the logical ",
 Cell[BoxData[
  OverscriptBox[
   StyleBox["Z", "TI"], "_"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "1e7f4ef6-a390-4d6c-9cc2-f23147859c1e"],
 ":"
}], "Text",ExpressionUUID->"bbe1c06e-1e18-49fa-9611-4c5e9e575999"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"PauliStabilizer", "[", "\"\<5QubitCode\>\"", "]"}], 
  "[", "\"\<Stabilizers\>\"", "]"}]], "Input",
 CellLabel->
  "In[30]:= ",ExpressionUUID->"09495afb-8f6f-483c-9749-5157c2b20f27"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"\<\"XZZXI\"\>", ",", "\<\"IXZZX\"\>", ",", "\<\"XIXZZ\"\>", 
   ",", "\<\"ZXIXZ\"\>", ",", "\<\"ZZZZZ\"\>"}], "}"}]], "Output",
 CellLabel->
  "Out[30]= ",ExpressionUUID->"f56eca50-44a0-4562-b316-82a53f0079ea"]
}, Open  ]],

Cell[TextData[{
 "The four cyclic permutations ",
 Cell[BoxData[
  RowBox[{
   StyleBox[
    RowBox[{"X", "Z", "Z", "X", "I"}], "TI"], 
   RowBox[{",", "\[ThinSpace]"}], 
   StyleBox[
    RowBox[{"I", "X", "Z", "Z", "X"}], "TI"], 
   RowBox[{",", "\[ThinSpace]"}], 
   StyleBox[
    RowBox[{"X", "I", "X", "Z", "Z"}], "TI"], 
   RowBox[{",", "\[ThinSpace]"}], 
   StyleBox[
    RowBox[{"Z", "X", "I", "X", "Z"}], "TI"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "3a36ef8f-e51d-48df-9887-e81c782fdf7c"],
 " are the parity checks that detect any single-qubit error, and the final ",
 Cell[BoxData[
  StyleBox[
   RowBox[{"Z", "Z", "Z", "Z", "Z"}], "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "c3d7459d-7226-42e2-b59b-00bdd7a58482"],
 " selects the logical ",
 Cell[BoxData[
  TemplateBox[{
    SubscriptBox["0", 
     StyleBox["L", "TI"]]},
   "Ket"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "f2e0ee25-2e4f-46d5-89fa-4949980d1ef0"],
 " within the code space. The Steane code, the CSS code built from the \
classical ",
 Cell[BoxData[
  RowBox[{
   StyleBox["[",
    SpanMaxSize->1], 
   RowBox[{"7", ",", "4"}], 
   StyleBox["]",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "3c6d254b-ee88-4b46-a33d-b0d104bc1ac8"],
 " Hamming code, separates cleanly into ",
 Cell[BoxData[
  StyleBox["X", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "5f4e8f84-c19f-49fe-b18e-c0f069852040"],
 "-type and ",
 Cell[BoxData[
  StyleBox["Z", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "ef6d57a3-0d81-4fc0-b80a-8a58c4a3c285"],
 "-type checks:"
}], "Text",ExpressionUUID->"a56ce629-586b-4325-bb61-afa68c41dbf4"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"PauliStabilizer", "[", "\"\<SteaneCode\>\"", "]"}], 
  "[", "\"\<Stabilizers\>\"", "]"}]], "Input",
 CellLabel->
  "In[31]:= ",ExpressionUUID->"9235937f-68f7-4dbf-9262-37bff66e2421"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"\<\"IIIXXXX\"\>", ",", "\<\"XIXIXIX\"\>", ",", "\<\"IXXIIXX\"\>", 
   ",", "\<\"IIIZZZZ\"\>", ",", "\<\"ZIZIZIZ\"\>", ",", "\<\"IZZIIZZ\"\>", 
   ",", "\<\"ZZZZZZZ\"\>"}], "}"}]], "Output",
 CellLabel->
  "Out[31]= ",ExpressionUUID->"44ba09f7-683b-4814-8d8e-8acc845ff1cb"]
}, Open  ]],

Cell[TextData[{
 "The first three generators are pure ",
 Cell[BoxData[
  StyleBox["X", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "57a1a3a2-cf28-4c1e-8ab4-5b99da4fdc8d"],
 " checks and the next three pure ",
 Cell[BoxData[
  StyleBox["Z", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "9f7a3967-a99b-4d6d-8c73-4c079651e92a"],
 " checks, the defining CSS structure; the seventh is again the logical ",
 Cell[BoxData[
  OverscriptBox[
   StyleBox["Z", "TI"], "_"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "9dab7987-24f9-42d7-955e-59528bd41892"],
 ". Measuring these generators on an encoded state is exactly the syndrome \
extraction of the previous section, and because each is a Pauli string, the \
measurement stays in the tableau."
}], "Text",ExpressionUUID->"2c193213-9e9a-40da-8694-22df1497ffef"],

Cell["The frontier: graph states, magic, and channels", "Section",ExpressionUUID->"9d334517-044b-4a9c-918d-acc830436e89"],

Cell["\<\
Three directions take the formalism to the edge of current research, and the \
framework has a head for each.\
\>", "Text",ExpressionUUID->"75f90404-c840-4b22-b97d-7911e582c3e9"],

Cell[TextData[{
 "First, ",
 StyleBox["graph states", "TI"],
 ". A theorem of Van den Nest and others says every stabilizer state is \
local-Clifford-equivalent to a graph state, the state built by placing ",
 Cell[BoxData[
  TemplateBox[{"+"},
   "Ket"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "224c6f03-d185-4cd5-91dd-0324177106db"],
 " on each vertex of a graph and applying a controlled-",
 Cell[BoxData[
  StyleBox["Z", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "29347bbf-8bcc-494e-844a-6ebe1e744283"],
 " along each edge. Its stabilizer at vertex ",
 Cell[BoxData[
  StyleBox["i", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "262e5674-b76f-41cf-b4f1-e3f9bf556747"],
 " is ",
 Cell[BoxData[
  RowBox[{
   SubscriptBox[
    StyleBox["X", "TI"], 
    StyleBox["i", "TI"]], 
   UnderscriptBox["\[Product]", 
    RowBox[{
     StyleBox["j", "TI"], "\[Tilde]", 
     StyleBox["i", "TI"]}]], 
   SubscriptBox[
    StyleBox["Z", "TI"], 
    StyleBox["j", "TI"]]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "85e4baa2-b126-46ee-8dac-f8fddf21f725"],
 ". Build the graph state on a 4-cycle and read its generators:"
}], "Text",ExpressionUUID->"6a629e37-f2f5-47ea-98ac-c84e6e45e873"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"gs", " ", "=", " ", 
   RowBox[{"GraphState", "[", 
    RowBox[{"CycleGraph", "[", "4", "]"}], "]"}]}], ";"}], "\n", 
 RowBox[{"gs", "[", "\"\<Stabilizers\>\"", "]"}]}], "Input",
 CellLabel->
  "In[32]:= ",ExpressionUUID->"56a270c8-2304-47fc-a200-bf8635a27f61"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"\<\"XZIZ\"\>", ",", "\<\"ZXZI\"\>", ",", "\<\"IZXZ\"\>", 
   ",", "\<\"ZIZX\"\>"}], "}"}]], "Output",
 CellLabel->
  "Out[32]= ",ExpressionUUID->"988b9f0e-3edb-4dfc-a960-2d4130737f74"]
}, Open  ]],

Cell[TextData[{
 "Each generator is an ",
 Cell[BoxData[
  StyleBox["X", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "f1ce654e-30d6-4f9e-b526-0090725bad65"],
 " on one vertex dressed by ",
 Cell[BoxData[
  StyleBox["Z", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "76dfae23-de4b-4d3f-8704-65faffb22409"],
 " on its neighbors, the cluster-state structure. The operation that \
generates the local-Clifford equivalence class is ",
 StyleBox["local complementation", "TI"],
 ", which toggles the edges among the neighbors of a chosen vertex; here it \
is [",
 Cell[BoxData[
 "LocalComplement"], "InlineFormula",ExpressionUUID->
  "da6533f8-87ad-49cd-9fbc-fe993fe72fda"],
 "]. Local-complementing the center of a triangle, for example, deletes the \
edge between its two neighbors:"
}], "Text",ExpressionUUID->"7db250f0-e0e6-4b2a-8425-f2f394c67ee6"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"EdgeList", "[", 
  RowBox[{"LocalComplement", "[", 
   RowBox[{
    RowBox[{"CompleteGraph", "[", "3", "]"}], ",", " ", "1"}], "]"}], 
  "]"}]], "Input",
 CellLabel->
  "In[33]:= ",ExpressionUUID->"7b4bba2a-0a47-4769-b2bb-02a96c773272"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{"1", "\[UndirectedEdge]", "2"}], ",", 
   RowBox[{"1", "\[UndirectedEdge]", "3"}]}], "}"}]], "Output",
 CellLabel->
  "Out[33]= ",ExpressionUUID->"d8a71b22-ab61-4b95-b01f-ce8d9fe3d104"]
}, Open  ]],

Cell[TextData[{
 "Second, ",
 StyleBox["magic and stabilizer rank", "TI"],
 ". Clifford gates keep us inside the stabilizer world; a non-Clifford gate \
such as ",
 Cell[BoxData[
  StyleBox["T", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "cd75b4a7-98c7-429e-b326-4bf1459fad4a"],
 " does not. The framework represents a state that has left the stabilizer \
manifold as a [",
 Cell[BoxData[
 "StabilizerFrame"], "InlineFormula",ExpressionUUID->
  "b251d208-5a5c-400f-82aa-12a7686a41d5"],
 "], a superposition ",
 Cell[BoxData[
  RowBox[{
   UnderscriptBox["\[Sum]", 
    StyleBox["i", "TI"]], 
   RowBox[{
    SubscriptBox[
     StyleBox["c", "TI"], 
     StyleBox["i", "TI"]], 
    TemplateBox[{
      SubscriptBox[
       StyleBox["s", "TI"], 
       StyleBox["i", "TI"]]},
     "Ket"]}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "ad7b600e-f604-4ff2-940b-95cdb55e612b"],
 " of stabilizer states, and each ",
 Cell[BoxData[
  StyleBox["T", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "5a340ef6-61d2-400d-97fe-f38131a1aa0e"],
 " gate doubles the number of terms. The number of terms is the ",
 StyleBox["stabilizer rank", "TI"],
 ", the quantity that controls the cost of classically simulating magic, in \
the sense of Bravyi and Gosset. Apply three ",
 Cell[BoxData[
  StyleBox["T", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "dc25f081-c947-4892-9b37-db1cadfe7a60"],
 " gates and count the terms:"
}], "Text",ExpressionUUID->"6295814e-b24c-4602-a840-7ce49047e804"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{"PauliStabilizer", "[", "3", "]"}], "[", 
        RowBox[{"\"\<H\>\"", ",", " ", "1"}], "]"}], "[", 
       RowBox[{"\"\<H\>\"", ",", " ", "2"}], "]"}], "[", 
      RowBox[{"\"\<H\>\"", ",", " ", "3"}], "]"}], "[", 
     RowBox[{"\"\<T\>\"", ",", " ", "1"}], "]"}], "[", 
    RowBox[{"\"\<T\>\"", ",", " ", "2"}], "]"}], "[", 
   RowBox[{"\"\<T\>\"", ",", " ", "3"}], "]"}], "[", "\"\<Length\>\"", 
  "]"}]], "Input",
 CellLabel->
  "In[34]:= ",ExpressionUUID->"6c965ce0-9a1b-4fe5-9308-275b3efd3f77"],

Cell[BoxData["8"], "Output",
 CellLabel->
  "Out[34]= ",ExpressionUUID->"5ea50992-f2c7-4ee7-b534-27ff8de9ea1d"]
}, Open  ]],

Cell[TextData[{
 "The frame has grown from one term to ",
 Cell[BoxData[
  RowBox[{
   SuperscriptBox["2", "3"], "=", "8"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "ba8febc4-7e1a-4a6e-8cc7-089a2b37ae75"],
 ", the exponential cost of magic made concrete. The frame is the right \
object for counting and for stabilizer-rank methods; reconstructing its dense \
state vector inherits the per-component global-phase ambiguity, so use it as \
a combinatorial tool rather than for exact amplitude readout."
}], "Text",ExpressionUUID->"cf175367-c1e0-4a7c-ae42-558f258f28e7"],

Cell[TextData[{
 "Third, ",
 StyleBox["Clifford channels", "TI"],
 ". Open-system Clifford dynamics, the maps that send stabilizer states to \
stabilizer states, are encoded by a Boolean Choi tableau in the framework's [",
 Cell[BoxData[
 "CliffordChannel"], "InlineFormula",ExpressionUUID->
  "546567b8-ba43-4e63-81cb-847d30e7df44"],
 "], following Yashin. The identity channel on two qubits has a rank equal to \
twice the qubit count:"
}], "Text",ExpressionUUID->"feb48741-4a25-49c7-9c72-5f4bcd8b216e"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"CliffordChannel", "[", 
   RowBox[{"\"\<Identity\>\"", ",", " ", "2"}], "]"}], "[", "\"\<Rank\>\"", 
  "]"}]], "Input",
 CellLabel->
  "In[35]:= ",ExpressionUUID->"94c3beb8-9c01-40c5-951d-c743ccff9c95"],

Cell[BoxData["4"], "Output",
 CellLabel->
  "Out[35]= ",ExpressionUUID->"b1ec4934-30f8-4bc8-b49f-a31ed30e418b"]
}, Open  ]],

Cell["\<\
A pure stabilizer state is itself a (state-preparation) Clifford channel, \
whose tableau is the state's stabilizer half. Converting the Bell state to \
its channel tableau recovers its two parity-check rows:\
\>", "Text",ExpressionUUID->"1581cb23-8da5-43b4-b1b4-1906441d7bd0"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"CliffordChannel", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"PauliStabilizer", "[", "2", "]"}], "[", 
      RowBox[{"\"\<H\>\"", ",", " ", "1"}], "]"}], "[", 
     RowBox[{"\"\<CNOT\>\"", ",", " ", "1", ",", " ", "2"}], "]"}], "]"}], 
   "[", "\"\<Tableau\>\"", "]"}], " ", "//", " ", "MatrixForm"}]], "Input",
 CellLabel->
  "In[36]:= ",ExpressionUUID->"24b0ed4d-45d9-48c1-b4d7-a239bdae2c2c"],

Cell[BoxData[
 TagBox[
  RowBox[{"(", "\[NoBreak]", GridBox[{
     {"1", "1", "0", "0", "0"},
     {"0", "0", "1", "1", "0"}
    },
    GridBoxAlignment->{"Columns" -> {{Center}}, "Rows" -> {{Baseline}}},
    GridBoxSpacings->{"Columns" -> {
        Offset[0.27999999999999997`], {
         Offset[0.7]}, 
        Offset[0.27999999999999997`]}, "Rows" -> {
        Offset[0.2], {
         Offset[0.4]}, 
        Offset[0.2]}}], "\[NoBreak]", ")"}],
  Function[BoxForm`e$, 
   MatrixForm[BoxForm`e$]]]], "Output",
 CellLabel->
  "Out[36]= ",ExpressionUUID->"6c69449d-3879-474b-9d53-3860ca296af3"]
}, Open  ]],

Cell[TextData[{
 "These three heads, together with ",
 Cell[BoxData[
 "PauliStabilizer"], "InlineFormula",ExpressionUUID->
  "1f6dfa22-bf2c-4692-a355-7d8b6fbd1a4d"],
 " and ",
 Cell[BoxData[
 "StabilizerFrame"], "InlineFormula",ExpressionUUID->
  "aa699053-6b26-4aac-b26d-a69dd777eb0c"],
 ", let one stay in the tableau picture for states, codes, graph-state \
surgery, magic accounting, and noise, inside the same object model as the \
rest of the framework."
}], "Text",ExpressionUUID->"1a830e97-86de-44c1-baa3-e696cdc03e4e"],

Cell["An honest comparison with other packages", "Section",ExpressionUUID->"0419ff7b-da46-4aeb-b0dc-a1f02b1fa0e6"],

Cell["\<\
The stabilizer simulators built for raw throughput are Stim, a C++ engine, \
and QuantumClifford.jl, a Julia package; both are excellent and both are \
narrower in scope than a general quantum framework. The fair question is \
two-sided: how close is the framework on the task they specialize in, and \
what does it offer that they do not.\
\>", "Text",ExpressionUUID->"7c38e088-9f0e-42fa-8acd-7a9639121df5"],

Cell["\<\
On gate-folding throughput the gap is now a small constant factor. The \
figures below are the measured wall-clock for an identical Clifford stream on \
an Apple M2 Pro, from the framework's own bottleneck audit at repository \
HEAD, with Stim for reference:\
\>", "Text",ExpressionUUID->"f52a6b58-ed54-4361-ae1f-3662fe89c747"],

Cell[BoxData[GridBox[{
   {Cell["qubits (gates)", "TableText",
     FontWeight->Bold,ExpressionUUID->"e4ad03c8-6da3-48f9-a23f-9e5b3b1a0ce0"],
     Cell["QuantumFramework", "TableText",
     FontWeight->Bold,ExpressionUUID->"55ad14ac-9435-4883-925b-bb75e0cedda8"],
     Cell["Stim", "TableText",
     FontWeight->Bold,ExpressionUUID->"d9b05adf-4a92-40b4-8348-9b56cc0d51a8"],
     Cell["ratio", "TableText",
     FontWeight->Bold,ExpressionUUID->"3f8021d7-5e79-4a7c-98b1-610ca0c5b392"]},
   {Cell["100 (2k)", "TableText",ExpressionUUID->
     "7f23479c-d5b3-4a9d-b0ae-778ff722eb1f"], Cell[
    "2.6 ms", "TableText",ExpressionUUID->
     "6ac8098e-9a96-4540-9a64-ebd41551bf86"], Cell[
    "1.03 ms", "TableText",ExpressionUUID->
     "44fa0543-113a-4f4b-8e3b-8adb101e2f4e"], Cell[
    "2.5x", "TableText",ExpressionUUID->
     "503f8d7e-e449-4dd2-a076-c0aa7a8a3571"]},
   {Cell["500 (10k)", "TableText",ExpressionUUID->
     "bb72b8a0-4613-433e-b767-60c663cb22db"], Cell[
    "26.2 ms", "TableText",ExpressionUUID->
     "4bdfaffd-a562-4db1-970e-9f97ad73e292"], Cell[
    "5.14 ms", "TableText",ExpressionUUID->
     "3ecdee53-8af8-4cd3-9899-fd745d6a455a"], Cell[
    "5.1x", "TableText",ExpressionUUID->
     "16570238-b696-41ff-8c06-af3d43cf2cf2"]},
   {Cell["1000 (20k)", "TableText",ExpressionUUID->
     "5355e939-58b2-4020-aeb8-94a1cbdbe003"], Cell[
    "58.0 ms", "TableText",ExpressionUUID->
     "fad06d62-f966-448e-9980-49ce94c5a372"], Cell[
    "10.9 ms", "TableText",ExpressionUUID->
     "413d9db3-5c37-4364-afcf-3297ba1e51fb"], Cell[
    "5.3x", "TableText",ExpressionUUID->
     "e0f5315c-c54a-43b6-b9d0-dadb61e074fd"]}
  },
  GridBoxAlignment->{"Columns" -> {{Left}}, "Rows" -> {{Baseline}}},
  GridBoxDividers->{"Columns" -> {{None}}, "Rows" -> {{True}}},
  GridBoxSpacings->{"Columns" -> {{1.5}}, "Rows" -> {{0.7}}}]], "Text",Express\
ionUUID->"7cff9ad3-2733-49a0-8ffb-d350f7f05f39"],

Cell[TextData[{
 "At a thousand qubits the framework also runs ahead of QuantumClifford.jl on \
the same stream (58.0 ms against 108.4 ms). The remaining gap to Stim is SIMD \
lane width, Stim packs 256-bit vector lanes against the framework's 62-bit \
machine words, plus a small per-gate circuit-encoding pass; it is a constant \
factor, not an algorithmic deficit. Getting there took compiling the gate \
fold to a single C kernel: the earlier interpreted path was roughly ",
 Cell[BoxData[
  SuperscriptBox["10", "3"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "fb42e9ce-e5f0-45b6-a208-7a5c5bdf67af"],
 " times slower, around 74, 402, and 955 ms at the three sizes above."
}], "Text",ExpressionUUID->"653771f6-3fe1-4d72-bb23-2424b80728e8"],

Cell["What the framework offers that the dedicated engines do not:", "Text",ExpressionUUID->"5b6f0bfd-66de-4be5-adaa-ddfabfe9f1c9"],

Cell[TextData[{
 StyleBox["Symbolic signs", "TI"],
 ". Outcomes can be carried as formal symbols through a circuit (the SymPhase \
method), so a single traversal serves arbitrarily many samples, and outcome \
correlations are explicit polynomials."
}], "Item",ExpressionUUID->"b5587457-18f6-466a-b1d6-67cc2c13c7b0"],

Cell[TextData[{
 StyleBox["Exact arithmetic", "TI"],
 ". Coefficients, signs, and the random-Clifford sampler use exact rationals, \
so seeded output is bit-reproducible and there is no floating-point drift."
}], "Item",ExpressionUUID->"c50997d8-ded1-4f13-99ab-3a2a87c99f1c"],

Cell[TextData[{
 StyleBox["One object model", "TI"],
 ". A ",
 Cell[BoxData[
 "PauliStabilizer"], "InlineFormula",ExpressionUUID->
  "93c7efbe-e980-4328-8da9-b6e31a9c84c9"],
 " converts to a ",
 Cell[BoxData[
 "QuantumState"], "InlineFormula",ExpressionUUID->
  "a309977f-3e23-464a-b6f7-05ec9538c067"],
 ", a ",
 Cell[BoxData[
 "QuantumOperator"], "InlineFormula",ExpressionUUID->
  "da04fe1e-c7db-4759-ae10-523ffcdedb03"],
 ", a ",
 Cell[BoxData[
 "QuantumCircuitOperator"], "InlineFormula",ExpressionUUID->
  "ca07b24b-70c2-46b9-8736-76e7e4130d1a"],
 ", or a ",
 Cell[BoxData[
 "QuantumChannel"], "InlineFormula",ExpressionUUID->
  "2545a16e-55a3-48ce-a733-4eac851d2246"],
 ", so a stabilizer subroutine drops into a larger simulation that also uses \
dense states, density matrices, Lindblad evolution, or phase-space methods, \
without leaving the language."
}], "Item",ExpressionUUID->"1ae70f1f-9acd-453f-8bee-46991092c8b8"],

Cell[TextData[{
 StyleBox["Breadth of heads", "TI"],
 ". Graph states with local complementation, stabilizer frames for magic \
accounting, and Clifford channels for open-system Clifford dynamics are \
first-class objects, not features one bolts on."
}], "Item",ExpressionUUID->"34296fa4-07f0-4805-a0b9-da38da50f4a1"],

Cell["Where the framework genuinely trails, stated plainly:", "Text",ExpressionUUID->"e1740655-a470-40af-b417-190a541e5402"],

Cell[TextData[{
 "It is a constant factor (roughly ",
 Cell[BoxData["2.5"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "33bddb3c-bb58-4d24-a2dd-dabad8da399f"],
 " to ",
 Cell[BoxData[
  RowBox[{"5.3", "\[Times]"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "bacdad91-1182-41a7-8c4a-2d7fcb24557f"],
 ") behind Stim on pure gate throughput, for the lane-width reason above."
}], "Item",ExpressionUUID->"feca5b92-b390-41f5-82ba-f5bdd3f9755a"],

Cell["\<\
It has no constant-cost bulk Pauli-frame sampler, the trick that makes Stim's \
shot-by-shot sampling so cheap.\
\>", "Item",ExpressionUUID->"51e0c5ac-c68c-4835-a9d9-df6cdf37f455"],

Cell[TextData[{
 "Constructing a ",
 Cell[BoxData[
 "QuantumCircuitOperator"], "InlineFormula",ExpressionUUID->
  "c38a9fd1-20d2-4ffa-aea8-2f566aeaafa5"],
 " with ",
 Cell[BoxData[
  SuperscriptBox["10", "4"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "77309550-f124-4424-a493-66251aa07e0b"],
 " or more gates carries host-framework overhead; for long streams one should \
call ",
 Cell[BoxData["\"\<ApplyCircuit\>\""], "InlineFormula",ExpressionUUID->
  "832fa2bf-96d2-4dd8-9eed-6c0efe6e9dc5"],
 " on a gate-spec list directly."
}], "Item",ExpressionUUID->"5b0617e6-a864-497e-a3c5-d830a823f29e"],

Cell["\<\
Reconstructing an exact state vector from a gate-updated tableau or a \
stabilizer frame is correct only up to a global (or per-component) phase.\
\>", "Item",ExpressionUUID->"7eab5e52-b127-4dbb-a35b-8825024f1d94"],

Cell["\<\
The summary is the one a physicist would want: for raw Clifford throughput \
the specialized engines are a few times faster, and if that is the only thing \
one needs, they are the right tool. For stabilizer simulation that has to \
interoperate with the rest of a quantum-mechanics toolkit, carry symbols, \
stay exact, and reach into codes, graph states, magic, and channels, the \
framework buys all of that for a small constant in speed.\
\>", "Text",ExpressionUUID->"22d41342-b399-4152-9d71-46ef767fbe23"],

Cell["Where this leaves us", "Section",ExpressionUUID->"06eead52-6fe7-4813-9007-505b668b27b8"],

Cell[TextData[{
 "We built the stabilizer formalism from one idea, that a state is named by \
what fixes it, and rode it from a single qubit to a thousand. Along the way \
the concrete tools were: ",
 Cell[BoxData[
 "PauliStabilizer"], "InlineFormula",ExpressionUUID->
  "5354e5a4-8865-47f6-94ac-fdea20017bac"],
 " for states, codes, and the tableau; the gate-update methods and ",
 Cell[BoxData["\"\<ApplyCircuit\>\""], "InlineFormula",ExpressionUUID->
  "f67860a0-e829-48e6-b396-8b03c1b7f4af"],
 " for Clifford evolution; ",
 Cell[BoxData["\"\<M\>\""], "InlineFormula",ExpressionUUID->
  "5b32ef7b-622b-4240-9a7c-ff91ac25c23c"],
 ", ",
 Cell[BoxData["\"\<Expectation\>\""], "InlineFormula",ExpressionUUID->
  "5ba832c9-ac2e-436b-8cfd-3d7dfb5c0a9c"],
 ", and ",
 Cell[BoxData["\"\<SymbolicMeasure\>\""], "InlineFormula",ExpressionUUID->
  "d6562ff9-75b0-4f70-abbe-1d2254bfd532"],
 " for measurement; ",
 Cell[BoxData["\"\<Entropy\>\""], "InlineFormula",ExpressionUUID->
  "cf15c40d-629d-49aa-aa82-6db27c093224"],
 " for entanglement; ",
 Cell[BoxData[
  RowBox[{"PauliStabilizer", "[", 
   RowBox[{"\"\<Random\>\"", "[", "n", "]"}], "]"}]], "InlineFormula",
  ExpressionUUID->"c6cae08b-d817-4aa3-b668-ce23cac5c87b"],
 " for sampling; and ",
 Cell[BoxData[
 "GraphState"], "InlineFormula",ExpressionUUID->
  "643fd804-6aa7-45a0-8bf1-4849960565e5"],
 ", ",
 Cell[BoxData[
 "StabilizerFrame"], "InlineFormula",ExpressionUUID->
  "01fa5a0f-d1eb-4662-9fdb-538070e0643a"],
 ", and ",
 Cell[BoxData[
 "CliffordChannel"], "InlineFormula",ExpressionUUID->
  "8433cd2b-19f7-4f7b-a29b-1e77597da826"],
 " for the frontier."
}], "Text",ExpressionUUID->"ee2f1544-7890-49c4-bfdf-c01ee94ebff4"],

Cell[TextData[{
 "The natural next steps are the ones the formalism opens onto: syndrome \
decoding on the codes of the error-correction section, stabilizer-rank \
simulation of magic-rich circuits via the frame, and Clifford-channel models \
of realistic noise. Each is a short extension of the computations above, and \
each stays, as long as it can, inside the ",
 Cell[BoxData[
  RowBox[{
   StyleBox["O", "TI"], 
   StyleBox["(",
    SpanMaxSize->1], 
   SuperscriptBox[
    StyleBox["n", "TI"], "2"], 
   StyleBox[")",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "b33d5b9d-2d1e-4dd1-b49c-ce16838de68f"],
 " tableau that makes the whole subject tractable."
}], "Text",ExpressionUUID->"f90313f8-eed7-4fd3-8b09-a2479f968ef0"],

Cell["\<\
The key references underpinning the implementation are Gottesman's \
stabilizer-codes thesis (1997), Aaronson and Gottesman on the tableau and its \
measurement update (2004), Fattal and collaborators on stabilizer \
entanglement entropy (2004), Anders and Briegel on graph states and local \
complementation (2005), Koenig and Smolin on the random-Clifford sampler \
(2014), Garcia and Markov on stabilizer frames (2015), Fang and Ying on \
symbolic phases (2023), and Yashin on Clifford channels (2025).\
\>", "Text",ExpressionUUID->"0fd7cee9-9c2a-4b6a-94a2-91b7e6621b00"]
},
CreateCellID->True,
FrontEndVersion->"15.0 for Mac OS X ARM (64-bit) (February 17, 2026)",
StyleDefinitions->"Default.nb",
ExpressionUUID->"4f3201c1-7b4b-4c03-a848-236e55a537da"
]
