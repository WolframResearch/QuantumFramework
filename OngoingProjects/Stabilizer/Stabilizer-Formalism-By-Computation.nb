 "."
}], "Item",ExpressionUUID->"32f6fb5b-6ef7-47c4-84c4-ee1b0e57595a"],

Cell[TextData[{
 StyleBox["Entanglement entropy", "TI"],
 " across a cut: ",
 Cell[BoxData[
