}, Open  ]],

Cell[TextData[{
 "The first reason to care is that the single symbolic traversal then serves \
arbitrarily many shots. The ",
 Cell[BoxData["\"\<SampleOutcomes\>\""], "InlineFormula",ExpressionUUID->
  "fd8af0ec-68cb-4efc-9791-62037ef28f8c"],
 " property draws samples by substituting random bits for the formal ones, \
never re-running the ",
 Cell[BoxData[
 "H"], "InlineFormula",ExpressionUUID->"bf5c045a-f904-4fac-a841-89573f6a0418"],
 "-",
 Cell[BoxData[
 "CNOT"], "InlineFormula",ExpressionUUID->
  "42c972da-8452-4d80-81dd-938daf6eeb22"],
 " circuit; a thousand shots of the qubit-1 outcome come out a fair coin:"
}], "Text",ExpressionUUID->"fb8f202d-1021-46e1-ad43-a5945841a2ed"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"SeedRandom", "[", "7", "]"}], ";"}], "\n", 
 RowBox[{"Counts", "[", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"(", 
      RowBox[{"1", " ", "-", " ", 
       RowBox[{
        RowBox[{"#", "[", "\"\<StabilizerSigns\>\"", "]"}], "[", 
        RowBox[{"[", "1", "]"}], "]"}]}], ")"}], " ", "/", " ", "2"}], " ", 
    "&"}], " ", "/@", " ", 
   RowBox[{"sm", "[", 
    RowBox[{"\"\<SampleOutcomes\>\"", ",", " ", "1000"}], "]"}]}], 
  "]"}]}], "Input",
 CellLabel->
  "In[51]:= ",ExpressionUUID->"b867efc8-5235-4cb3-b284-7a00f92b21be"],

Cell[BoxData[
 RowBox[{"\[LeftAssociation]", 
  RowBox[{
   RowBox[{"1", "\[Rule]", "492"}], ",", 
   RowBox[{"0", "\[Rule]", "508"}]}], "\[RightAssociation]"}]], "Output",
 CellLabel->
  "Out[51]= ",ExpressionUUID->"6914f888-55be-4257-913b-b7664ccb45d9"]
}, Open  ]],

Cell[TextData[{
 "The second reason is that the formal bits thread through the ",
 StyleBox["rest", "TI"],
 " of the circuit, so correlations between outcomes are carried into the \
samples rather than discarded with the branch structure. Measure all three \
qubits of the GHZ state symbolically, sample a thousand shots, and read off \
the bit-strings: every shot is ",
 Cell[BoxData["000"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "1bf27504-de7a-4fdb-a6a3-79c4f90c7491"],
 " or ",
 Cell[BoxData["111"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "438d003a-5c03-4f57-99e6-3b633c45f6da"],
 ", the perfect three-body correlation, reproduced from one traversal."
}], "Text",ExpressionUUID->"3f48e8b9-2c75-46c6-8574-94dc07ab72e4"],

Cell["\<\
A small helper reads the bit-string a sample collapses to, by locating its \
one nonzero amplitude:\
\>", "Text",ExpressionUUID->"8587d014-ffa9-4a5e-96f1-7756bacebdd0"],

Cell[BoxData[
 RowBox[{
  RowBox[{"readBits", "[", "ps_", "]"}], " ", ":=", " ", 
  RowBox[{"IntegerDigits", "[", 
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{"FirstPosition", "[", 
       RowBox[{
        RowBox[{"Normal", "[", 
         RowBox[{
          RowBox[{"ps", "[", "\"\<State\>\"", "]"}], 
          "[", "\"\<StateVector\>\"", "]"}], "]"}], ",", " ", 
        RowBox[{"x_", " ", "/;", " ", 
         RowBox[{"x", " ", "!=", " ", "0"}]}]}], "]"}], "[", 
      RowBox[{"[", "1", "]"}], "]"}], " ", "-", " ", "1"}], ",", " ", "2", ",",
     " ", 
    RowBox[{"ps", "[", "\"\<Qubits\>\"", "]"}]}], "]"}]}]], "Input",
 CellLabel->
  "In[52]:= ",ExpressionUUID->"29f606a3-63d9-4a84-9cca-b1789faf0eb9"],

Cell["Measure all three qubits symbolically, in one traversal:", "Text",ExpressionUUID->"4f54b34a-49a9-4a31-b599-f5b238ce7b4d"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"smGHZ", " ", "=", " ", 
  RowBox[{"ghz3", "[", 
   RowBox[{"\"\<SymbolicMeasure\>\"", ",", " ", 
    RowBox[{"{", 
     RowBox[{"1", ",", " ", "2", ",", " ", "3"}], "}"}]}], "]"}]}]], "Input",
 CellLabel->
  "In[53]:= ",ExpressionUUID->"cbcb1894-df80-4814-b1c4-10bc91d4a357"],

Cell[BoxData[
 InterpretationBox[
  RowBox[{
   TagBox["PauliStabilizer",
    "SummaryHead"], "[", 
   DynamicModuleBox[{Typeset`open$$ = False, Typeset`embedState$$ = "Ready"}, 
    
