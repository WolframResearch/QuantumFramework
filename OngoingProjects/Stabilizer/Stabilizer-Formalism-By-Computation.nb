Cell["Reading off the stabilizer makes the sign explicit:", "Text",ExpressionUUID->"52f77505-6ad5-4df8-a4ef-aa6bef2861bb"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"PauliStabilizer", "[", "1", "]"}], "[", 
   RowBox[{"\"\<X\>\"", ",", " ", "1"}], "]"}], "[", "\"\<Stabilizers\>\"", 
  "]"}]], "Input",
 CellLabel->
  "In[11]:= ",ExpressionUUID->"45cc7fe5-2303-466d-9300-e7ea4437ff22"],

Cell[BoxData[
 RowBox[{"{", "\<\"-Z\"\>", "}"}]], "Output",
 CellLabel->
  "Out[11]= ",ExpressionUUID->"1e3348b9-f5f3-4b4f-9682-a25caf8a501e"]
}, Open  ]],

Cell[TextData[{
 "The answer is the signed string ",
 Cell[BoxData["\"\<-Z\>\""], "InlineFormula",ExpressionUUID->
  "28bca7fe-4af9-48b7-bb98-0fa4e8fe8328"],
 ", the operator that fixes ",
 Cell[BoxData[
  TemplateBox[{"1"},
   "Ket"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "25f30511-4ed9-467a-b5e2-1d903f93a076"],
 ". The sign is part of the stabilizer data, which is exactly why the \
formalism can tell ",
 Cell[BoxData[
  TemplateBox[{"0"},
   "Ket"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "a5f5f66c-9b36-462d-bfc3-f32fdf1bc8d2"],
 " from ",
 Cell[BoxData[
  TemplateBox[{"1"},
   "Ket"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "26893b98-3d0c-4073-9b33-ccf74c198bb2"],
 " even though the same unsigned ",
 Cell[BoxData[
  StyleBox["Z", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "db1f0c9b-4b83-4940-b2aa-185b6fb3913b"],
 " pins both."
}], "Text",ExpressionUUID->"1baac915-3109-4a0e-910a-993ab7de8a34"],

Cell[TextData[{
 "A short word of honesty that will matter later. The tableau tracks the \
stabilizer group, including the signs, but it is blind to the ",
 StyleBox["overall", "TI"],
 " phase of the state. Reconstructing a state vector from a gate-updated \
tableau is therefore exact only up to a global phase. You can see this by \
acting with ",
 Cell[BoxData[
  StyleBox["Z", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "9f499b0a-910e-41cf-8568-54b96403f5d5"],
 " on ",
 Cell[BoxData[
  TemplateBox[{"+"},
   "Ket"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "4b2bf83c-7677-4b7a-b2ad-c6ac0570b11b"],
 ": physically ",
 Cell[BoxData[
  RowBox[{
   RowBox[{
    StyleBox["Z", "TI"], 
    TemplateBox[{"+"},
     "Ket"]}], "=", 
   TemplateBox[{"-"},
    "Ket"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "34613a1d-28ef-4f70-876c-ecc6acb8a034"],
 ", and the framework returns ",
 Cell[BoxData[
  TemplateBox[{"-"},
   "Ket"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "ebe0fbc3-eb5c-4dd9-9927-7d7bcdcd94c9"],
 " up to an overall sign."
}], "Text",ExpressionUUID->"ad4c3bf9-b011-4668-bf38-132f727b1718"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"PauliStabilizer", "[", "1", "]"}], "[", 
     RowBox[{"{", 
      RowBox[{"\"\<H\>\"", ",", " ", "\"\<Z\>\""}], "}"}], "]"}], 
    "[", "\"\<State\>\"", "]"}], "[", "\"\<StateVector\>\"", "]"}], " ", "//",
   " ", "Normal"}]], "Input",
 CellLabel->
  "In[12]:= ",ExpressionUUID->"13aa6528-a90c-4b3a-8960-a7c584613147"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{"-", 
    FractionBox["1", 
     SqrtBox["2"]]}], ",", 
   FractionBox["1", 
    SqrtBox["2"]]}], "}"}]], "Output",
 CellLabel->
  "Out[12]= ",ExpressionUUID->"00480a78-eaa2-43f9-82d9-2dd6017084ce"]
}, Open  ]],

Cell["\<\
For everything observable, probabilities, expectation values, entanglement, \
the global phase is irrelevant, so this costs us nothing in practice. We flag \
it now because it is the one place where the cheap representation is \
genuinely less informative than the dense one.\
\>", "Text",ExpressionUUID->"d14d5df3-05c4-477f-a187-1012f56fd837"],

Cell["Before moving on, the essentials so far:", "Text",ExpressionUUID->"96dd9b2b-a802-40e1-b195-4282e9e8fa71"],

Cell[TextData[{
 "A one-qubit stabilizer state is named by the single Pauli operator that \
fixes it: ",
 Cell[BoxData[
  StyleBox["Z", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "f29bdce6-9707-467d-b96f-c6e3a18434a7"],
 " for ",
 Cell[BoxData[
  TemplateBox[{"0"},
   "Ket"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "bdb014ef-0687-432f-86af-ac32ed513927"],
 ", ",
 Cell[BoxData[
  StyleBox["X", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "bdf32864-2576-46fa-b562-8a47ccb64782"],
 " for ",
 Cell[BoxData[
  TemplateBox[{"+"},
   "Ket"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "389e8d05-fbeb-467d-b168-5aa65d3d8333"],
 ", ",
 Cell[BoxData[
  RowBox[{"-", 
   StyleBox["Z", "TI"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "300f17c1-9242-4f9e-9b88-0472d9811805"],
 " for ",
 Cell[BoxData[
  TemplateBox[{"1"},
   "Ket"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "72854bec-0b47-4bd6-833a-71eb8d94e14e"],
 "."
}], "Item",ExpressionUUID->"bce0b4c9-780e-4d20-b67a-21c5d1b02685"],

Cell[TextData[{
 Cell[BoxData[
 "PauliStabilizer"], "InlineFormula",ExpressionUUID->
  "7e689bb6-7951-4632-af01-9aa1ca82dbb2"],
 " carries that operator, not the amplitudes; the ",
 Cell[BoxData["\"\<State\>\""], "InlineFormula",ExpressionUUID->
  "4b0f16d0-8149-469c-8b8f-1c712265bf31"],
 " property hands back a full ",
 Cell[BoxData[
 "QuantumState"], "InlineFormula",ExpressionUUID->
  "0927515a-3de3-484c-9223-1dca166bedb3"],
 " on demand, and ",
 Cell[BoxData["\"\<StateVector\>\""], "InlineFormula",ExpressionUUID->
  "896a66d1-8fae-4cd0-bb07-623ccdbcf2f0"],
 " on that object gives the raw ",
 Cell[BoxData[
  SuperscriptBox["2", 
   StyleBox["n", "TI"]]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "08d82e36-7070-49c4-8082-140b05a5acc1"],
 " amplitudes."
}], "Item",ExpressionUUID->"e8695582-4aee-47f5-ae71-53cbc86e74ad"],

Cell["\<\
The reconstructed vector is exact up to a global phase, which never affects \
an observable.\
\>", "Item",ExpressionUUID->"cf81d25d-96ef-4b26-a02f-b8ad76b61a5d"],

Cell[TextData[{
 "The tableau: ",
 Cell[BoxData[
  StyleBox["n", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "792c5014-8f7e-4a84-81e3-2a689c983f74"],
 " generators instead of ",
 Cell[BoxData[
  SuperscriptBox["2", 
   StyleBox["n", "TI"]]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "8c8b9b9d-8310-44f7-aecd-7a48be8c98b0"],
 " amplitudes"
}], "Section",ExpressionUUID->"bd03b409-a76e-4087-b995-d5597d92d68b"],

Cell[TextData[{
 "For ",
 Cell[BoxData[
  StyleBox["n", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "c83748d4-490b-427e-9914-7348e5a1c0b7"],
 " qubits the idea scales because the stabilizer group is generated by just \
",
 Cell[BoxData[
  StyleBox["n", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "543b39b5-19df-47a7-86aa-e741a742284c"],
 " commuting, independent Pauli strings, and each Pauli string of length ",
 Cell[BoxData[
  StyleBox["n", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "7aba5cfc-32d8-41a2-8226-d4e28d48c7c4"],
 " is two bits per qubit: an ",
 Cell[BoxData[
  StyleBox["X", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "3551dcfb-da08-477b-a623-d43364378428"],
 "-exponent and a ",
 Cell[BoxData[
  StyleBox["Z", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "96c2e94a-dfd4-4430-87d4-fc1a79c9cc64"],
 "-exponent, since ",
 Cell[BoxData[
  RowBox[{
   StyleBox["Y", "TI"], "=", 
   StyleBox["i", "TI"], 
   StyleBox["X", "TI"], 
   StyleBox["Z", "TI"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "cd6d85b7-e073-4af7-a195-142d9acc2b0f"],
 ". So a stabilizer state is a binary matrix of shape ",
 Cell[BoxData[
  RowBox[{
   StyleBox["n", "TI"], "\[Times]", "2", 
   StyleBox["n", "TI"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "d8a00c1e-f506-4dd5-87f4-f0c24b533eed"],
 " together with ",
 Cell[BoxData[
  StyleBox["n", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "7f093b36-4b34-4fc7-a5c2-3ab939c96003"],
 " signs, which is ",
 Cell[BoxData[
  RowBox[{
   StyleBox["O", "TI"], 
   StyleBox["(",
    SpanMaxSize->1], 
   SuperscriptBox[
    StyleBox["n", "TI"], "2"], 
   StyleBox[")",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "2130e7d6-5b28-4701-aa09-43515f58798e"],
 " bits in place of ",
 Cell[BoxData[
  SuperscriptBox["2", 
   StyleBox["n", "TI"]]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "d415097d-267a-437f-868a-997350418105"],
 " amplitudes. This binary ",
 Cell[BoxData[
  RowBox[{
   StyleBox["(",
    SpanMaxSize->1], 
   RowBox[{
    StyleBox["X", "TI"], "\[VerticalSeparator]", 
    StyleBox["Z", "TI"]}], 
   StyleBox[")",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "65e3e8e4-e959-40f4-93ad-f97d1a420281"],
 " encoding is the ",
 StyleBox["symplectic representation", "TI"],
 " of the Pauli group."
}], "Text",ExpressionUUID->"dfa0084f-0a71-4d46-a17f-27a000d713e1"],

Cell[TextData[{
 "Look at the two-qubit register ",
 Cell[BoxData[
  TemplateBox[{"00"},
   "Ket"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "79306697-2492-4d5a-8b20-38c1ad075b15"],
 ". The object itself previews the generators and a tableau grid:"
}], "Text",ExpressionUUID->"4811359d-69e8-4d47-b34a-f3547b704d1f"],

