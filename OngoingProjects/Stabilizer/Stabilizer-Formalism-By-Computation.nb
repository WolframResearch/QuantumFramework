}, Open  ]],

Cell[TextData[{
 "There is a subtlety worth pausing on: the framework stores ",
 Cell[BoxData[
  RowBox[{"2", 
   StyleBox["n", "TI"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "4628b1cb-d1a2-4bdd-a4aa-c17f22c298dc"],
 " rows, not ",
 Cell[BoxData[
  StyleBox["n", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "2141ef01-6fc7-47dd-8aa3-eec9aa3098c7"],
 ". The lower ",
 Cell[BoxData[
  StyleBox["n", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "2a01f13c-3a28-460a-9854-570b21afb321"],
 " rows are the ",
 StyleBox["stabilizer", "TI"],
 " generators proper; the upper ",
 Cell[BoxData[
  StyleBox["n", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "09a94855-d82f-4790-b555-b4f64240ba6f"],
 " are ",
 StyleBox["destabilizer", "TI"],
 " generators, a symplectic-dual partner basis introduced by Aaronson and \
Gottesman. The destabilizers cost nothing asymptotically and turn measurement \
from a search into an ",
 Cell[BoxData[
  RowBox[{
   StyleBox["O", "TI"], 
   StyleBox["(",
    SpanMaxSize->1], 
   StyleBox["n", "TI"], 
   StyleBox[")",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "3efc533d-7565-4f00-9403-8b27de325aea"],
 " update, as we will see. The framework labels every row as a signed Pauli \
string through ",
 Cell[BoxData["\"\<PauliStrings\>\""], "InlineFormula",ExpressionUUID->
  "08e34e07-c545-4248-9166-c679cf1096c2"],
 ":"
}], "Text",ExpressionUUID->"98fb255a-d346-474c-a771-71f4689f25d4"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"PauliStabilizer", "[", "2", "]"}], "[", "\"\<PauliStrings\>\"", 
  "]"}]], "Input",
 CellLabel->
  "In[17]:= ",ExpressionUUID->"10fde461-6644-4457-8c25-aec96f4085f9"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"\<\"ZI\"\>", ",", "\<\"IZ\"\>", ",", "\<\"XI\"\>", 
   ",", "\<\"IX\"\>"}], "}"}]], "Output",
 CellLabel->
  "Out[17]= ",ExpressionUUID->"ddb91254-bc78-4df1-984e-00df56b16cf8"]
}, Open  ]],

Cell[TextData[{
 "The first ",
 Cell[BoxData[
  StyleBox["n", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "79279765-f9bc-4344-bd82-7c6c7f5fc89d"],
 " entries here are the stabilizers (",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["Z", "TI"], "1"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "5af09ebd-ee9c-4b87-883e-e00354849398"],
 ", ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["Z", "TI"], "2"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "92a64ba7-b558-4a08-9853-6702d39c1ff2"],
 ") and the last ",
 Cell[BoxData[
  StyleBox["n", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "602b3ae6-d10a-4012-92ef-07a1372f7c76"],
 " are their destabilizer partners (",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["X", "TI"], "1"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "1fed8f8b-2ae5-46c4-96c2-1b8c1eea3e6c"],
 ", ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["X", "TI"], "2"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "0784c69c-655f-47f2-be12-857b106780c0"],
 "), which anticommute with the matching stabilizer and commute with all the \
others."
}], "Text",ExpressionUUID->"6ac6799a-066b-4d69-aca5-9857d1ae1c57"],

Cell[TextData[{
 "The header promised that these ",
 Cell[BoxData[
  StyleBox["n", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "dadf5a16-2a51-426e-8b2d-888250a541bb"],
 " generators ",
 StyleBox["are", "TI"],
 " the state, so the inverse map back to the ",
 Cell[BoxData[
  SuperscriptBox["2", 
   StyleBox["n", "TI"]]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "72802dd5-b0ab-4f72-8e6c-21cc6e2d0751"],
 " amplitudes should be explicit, and it is. A stabilizer state is the \
simultaneous ",
 Cell[BoxData[
  RowBox[{"+", "1"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "21ed1509-fee3-4d01-8f8b-0a8d4f402516"],
 " eigenvector of its generators. Equivalently, the projector onto their \
joint ",
 Cell[BoxData[
  RowBox[{"+", "1"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "ef000ec9-15f9-4e9c-bafb-4b5ba10d7d02"],
 " eigenspace,"
}], "Text",ExpressionUUID->"4043d08f-ac8b-4f0a-b4db-e0c7124f96f1"],

Cell[BoxData[
 PaneBox[
  RowBox[{
   RowBox[{
    StyleBox["P", "TI"], "\[ThickSpace]", "=", "\[ThickSpace]", 
    UnderscriptBox["\[Product]", 
     StyleBox["i", "TI"]], 
    FractionBox[
     RowBox[{"\|01d7d9", "+", 
      SubscriptBox[
       StyleBox["s", "TI"], 
       StyleBox["i", "TI"]], " ", 
      SubscriptBox[
       StyleBox["g", "TI"], 
       StyleBox["i", "TI"]]}], "2"]}], 
   RowBox[{",", "\[ThinSpace]"}]}],
  Alignment->Center,
  ImageSize->Full]], "DisplayFormula",ExpressionUUID->"667e9d4e-bc0c-4c59-\
a261-61a5c6160de4"],

Cell[TextData[{
 "is rank one, ",
 Cell[BoxData[
  RowBox[{
   StyleBox["P", "TI"], "=", 
   RowBox[{
    TemplateBox[{
      StyleBox["\[Psi]", "TI"]},
     "Ket"], 
    TemplateBox[{
      StyleBox["\[Psi]", "TI"]},
     "Bra"]}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "54d01b4b-9695-45a0-99d0-6c9890b4019b"],
 ", so any nonzero column of ",
 Cell[BoxData[
  StyleBox["P", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "e4ba76c1-35e8-4efd-9637-237e0dd1491d"],
 " is the state up to normalization. Here ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["g", "TI"], 
   StyleBox["i", "TI"]]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "aa25c8e6-3dcb-43ad-b1a6-089d907ce33d"],
 " is the ",
 Cell[BoxData[
  StyleBox["i", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "a678449e-71d2-41d2-961c-4082ac8819f3"],
 "-th stabilizer generator as a ",
 Cell[BoxData[
  RowBox[{
   SuperscriptBox["2", 
    StyleBox["n", "TI"]], "\[Times]", 
   SuperscriptBox["2", 
    StyleBox["n", "TI"]]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "12df1164-022c-4e64-91a3-b2642def6a67"],
 " Pauli matrix and ",
 Cell[BoxData[
  RowBox[{
   RowBox[{
    SubscriptBox[
     StyleBox["s", "TI"], 
     StyleBox["i", "TI"]], "\[Element]", "{", "+", "1"}], 
   RowBox[{",", "\[ThinSpace]"}], 
   RowBox[{"-", "1", "}"}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "825d21c2-08d0-4bf5-870f-f6eb4d97cc5a"],
 " its sign, both read off the tableau (the ",
 Cell[BoxData["\"\<Stabilizers\>\""], "InlineFormula",ExpressionUUID->
  "f6813649-8b51-48cd-86c6-97abae242080"],
 " strings above). Building ",
 Cell[BoxData[
  StyleBox["P", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "a52fb285-4891-4ffd-9a45-2f140f630338"],
 " and taking its nonzero column reconstructs ",
 Cell[BoxData[
  TemplateBox[{"00"},
   "Ket"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "922f5f20-3d42-4d1a-9d8c-03f3f58e90fc"],
 " by hand:"
}], "Text",ExpressionUUID->"54bda584-5b9d-4805-89a4-80c6dee83c36"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"genMatrix", "[", "s_String", "]"}], " ", ":=", " ", 
   RowBox[{
    RowBox[{"If", "[", 
     RowBox[{
      RowBox[{"StringStartsQ", "[", 
       RowBox[{"s", ",", " ", "\"\<-\>\""}], "]"}], ",", " ", 
      RowBox[{"-", "1"}], ",", " ", "1"}], "]"}], " ", "*", "\n", "   ", 
    RowBox[{"Fold", "[", 
     RowBox[{"KroneckerProduct", ",", " ", 
      RowBox[{
       RowBox[{"Characters", "[", 
        RowBox[{"StringDelete", "[", 
         RowBox[{"s", ",", " ", "\"\<-\>\""}], "]"}], "]"}], " ", "/.", "\n", 
       "     ", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"\"\<I\>\"", " ", "->", " ", 
          RowBox[{"PauliMatrix", "[", "0", "]"}]}], ",", " ", 
         RowBox[{"\"\<X\>\"", " ", "->", " ", 
          RowBox[{"PauliMatrix", "[", "1", "]"}]}], ",", " ", 
         RowBox[{"\"\<Y\>\"", " ", "->", " ", 
          RowBox[{"PauliMatrix", "[", "2", "]"}]}], ",", " ", 
         RowBox[{"\"\<Z\>\"", " ", "->", " ", 
          RowBox[{"PauliMatrix", "[", "3", "]"}]}]}], "}"}]}]}], "]"}]}]}], 
  ";"}], "\n", 
 RowBox[{
  RowBox[{"codeProjector", " ", "=", " ", 
   RowBox[{"Dot", " ", "@@", " ", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{"(", 
         RowBox[{
          RowBox[{"IdentityMatrix", "[", "4", "]"}], " ", "+", " ", 
          RowBox[{"genMatrix", "[", "#", "]"}]}], ")"}], " ", "/", " ", "2"}],
        " ", "&"}], " ", "/@", " ", 
      RowBox[{
       RowBox[{"PauliStabilizer", "[", "2", "]"}], "[", "\"\<Stabilizers\>\"",
        "]"}]}], ")"}]}]}], ";"}], "\n", 
 RowBox[{"reconstructed", " ", "=", " ", 
  RowBox[{"Normalize", " ", "@", " ", 
   RowBox[{"First", " ", "@", " ", 
    RowBox[{"Select", "[", 
     RowBox[{
      RowBox[{"Transpose", "[", "codeProjector", "]"}], ",", " ", 
      RowBox[{
       RowBox[{"AnyTrue", "[", 
        RowBox[{"#", ",", " ", 
         RowBox[{
          RowBox[{"#", " ", "!=", " ", "0"}], " ", "&"}]}], "]"}], " ", 
       "&"}]}], "]"}]}]}]}]}], "Input",
 CellLabel->
  "In[18]:= ",ExpressionUUID->"59bc8756-fabd-4248-9647-1f18ad7b9c22"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"1", ",", "0", ",", "0", ",", "0"}], "}"}]], "Output",
 CellLabel->
  "Out[18]= ",ExpressionUUID->"73efa335-7aa6-4fcb-9970-7247193899c3"]
}, Open  ]],

Cell[TextData[{
 "This is exactly the vector the ",
 Cell[BoxData["\"\<State\>\""], "InlineFormula",ExpressionUUID->
  "6eec4df6-ab38-4986-81fe-593319d3fd9c"],
 " property returns, the ",
 Cell[BoxData[
  RowBox[{
   StyleBox["O", "TI"], 
   StyleBox["(",
    SpanMaxSize->1], 
   SuperscriptBox["2", 
    StyleBox["n", "TI"]], 
   StyleBox[")",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "aa17e5b1-7128-4370-99b8-4601e50cd41a"],
 " computation the cheap representation exists to postpone:"
}], "Text",ExpressionUUID->"1c25bd01-db08-4bc3-acb7-fa289811ed90"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"reconstructed", " ", "===", " ", 
  RowBox[{"(", 
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{"PauliStabilizer", "[", "2", "]"}], "[", "\"\<State\>\"", "]"}],
      "[", "\"\<StateVector\>\"", "]"}], " ", "//", " ", "Normal"}], 
   ")"}]}]], "Input",
 CellLabel->
  "In[19]:= ",ExpressionUUID->"d7719f32-eef5-4710-85a3-d16fb474433d"],

Cell[BoxData["True"], "Output",
 CellLabel->
  "Out[19]= ",ExpressionUUID->"3f11dfe9-4d0d-4e48-a761-7ea10d9c75af"]
}, Open  ]],

Cell[TextData[{
 "The construction is not special to product states: the same lines turn the \
two generators ",
 Cell[BoxData[
  StyleBox[
   RowBox[{"X", "X"}], "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "dc274fcf-fd45-4c82-91aa-6dad0ebf76ea"],
 " and ",
 Cell[BoxData[
  StyleBox[
   RowBox[{"Z", "Z"}], "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "e08403ba-0a2e-4b76-80dd-0ec136cfec99"],
 " into the entangled Bell amplitudes ",
 Cell[BoxData[
  RowBox[{
   StyleBox["(",
    SpanMaxSize->1], 
   RowBox[{"1", ",", "0", ",", "0", ",", "1"}], 
   StyleBox[")",
    SpanMaxSize->1], "/", 
   SqrtBox["2"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "8724bbfe-9807-4cba-b75e-818947ee9e04"],
 ", the state the next section builds from gates."
}], "Text",ExpressionUUID->"6c996589-c36a-42df-af87-f0c516d5841c"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Normalize", " ", "@", " ", 
  RowBox[{"First", " ", "@", " ", 
   RowBox[{"Select", "[", "\n", "   ", 
    RowBox[{
     RowBox[{"Transpose", "[", 
      RowBox[{"Dot", " ", "@@", " ", 
       RowBox[{"(", 
        RowBox[{
         RowBox[{
          RowBox[{
           RowBox[{"(", 
            RowBox[{
             RowBox[{"IdentityMatrix", "[", "4", "]"}], " ", "+", " ", 
             RowBox[{"genMatrix", "[", "#", "]"}]}], ")"}], " ", "/", " ", 
           "2"}], " ", "&"}], " ", "/@", " ", 
         RowBox[{"{", 
          RowBox[{"\"\<XX\>\"", ",", " ", "\"\<ZZ\>\""}], "}"}]}], ")"}]}], 
      "]"}], ",", "\n", "   ", 
     RowBox[{
      RowBox[{"AnyTrue", "[", 
       RowBox[{"#", ",", " ", 
        RowBox[{
         RowBox[{"#", " ", "!=", " ", "0"}], " ", "&"}]}], "]"}], " ", 
      "&"}]}], "\n", "]"}]}]}]], "Input",
 CellLabel->
  "In[20]:= ",ExpressionUUID->"432d4eb1-687c-47ee-b8d5-f75e8fa5b018"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   FractionBox["1", 
    SqrtBox["2"]], ",", "0", ",", "0", ",", 
   FractionBox["1", 
    SqrtBox["2"]]}], "}"}]], "Output",
 CellLabel->
  "Out[20]= ",ExpressionUUID->"6f835c0d-8ec2-4e57-9f5e-95f304cf8c97"]
}, Open  ]],

Cell[TextData[{
 "Why is any of this fast? Because a Clifford gate, by definition, conjugates \
Pauli operators to Pauli operators. Updating the state therefore means \
updating each generator, ",
 Cell[BoxData[
  RowBox[{
   StyleBox["g", "TI"], "\[Function]", 
   StyleBox["U", "TI"], 
   StyleBox["g", "TI"], 
   SuperscriptBox[
    StyleBox["U", "TI"], "\[Dagger]"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "0b85c8e0-03dc-47a2-93cd-9ce45dd02742"],
 ", which is a fixed local rewrite of two bits and a sign per affected qubit. \
This is the content of the Gottesman-Knill theorem: a circuit of Clifford \
gates on a stabilizer input can be simulated in time polynomial in ",
 Cell[BoxData[
  StyleBox["n", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "64a142cd-9e95-4131-a06f-763d0e91278c"],
 ", with ",
 Cell[BoxData[
  RowBox[{
   StyleBox["O", "TI"], 
   StyleBox["(",
    SpanMaxSize->1], 
   StyleBox["n", "TI"], 
   StyleBox[")",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "193368f0-5f39-43a7-a388-a967f85be5ed"],
 " work per gate, rather than the ",
 Cell[BoxData[
  RowBox[{
   StyleBox["O", "TI"], 
   StyleBox["(",
    SpanMaxSize->1], 
   SuperscriptBox["2", 
    StyleBox["n", "TI"]], 
   StyleBox[")",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "cb43566f-5efc-4f2e-962a-46be04d4bec1"],
 " of dense state-vector evolution. The single-qubit gate methods (",
 Cell[BoxData["\"\<H\>\""], "InlineFormula",ExpressionUUID->
  "cb1a997b-fdcd-41ce-86e0-d8e44cc54277"],
 ", ",
 Cell[BoxData["\"\<S\>\""], "InlineFormula",ExpressionUUID->
  "c8221822-0871-4506-bba0-aa57732a3fe2"],
 ", ",
 Cell[BoxData["\"\<X\>\""], "InlineFormula",ExpressionUUID->
  "0bdcbf4a-dcb7-486e-a752-4e330f95d3ec"],
 ", ",
 Cell[BoxData["\"\<Y\>\""], "InlineFormula",ExpressionUUID->
  "811eb1c9-547a-4f2b-89a6-89b39b08ab08"],
 ", ",
 Cell[BoxData["\"\<Z\>\""], "InlineFormula",ExpressionUUID->
  "38c5884e-6153-4139-a42d-23a7fcacbedf"],
 ", ",
 Cell[BoxData["\"\<V\>\""], "InlineFormula",ExpressionUUID->
  "e7e30a15-0657-4695-9d52-abb3f5543b03"],
 " for ",
 Cell[BoxData[
  SqrtBox[
   StyleBox["X", "TI"]]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "4838decb-f4bf-4fd7-b0f7-60ffaf931501"],
 ", and ",
 Cell[BoxData[
  RowBox[{"SuperDagger", "[", "\"\<S\>\"", "]"}]], "InlineFormula",
  ExpressionUUID->"816dc667-8e8d-4d28-b968-e2a3b030c211"],
 ") and the two-qubit ",
 Cell[BoxData["\"\<CNOT\>\""], "InlineFormula",ExpressionUUID->
  "313d2d2f-d5ef-498a-980c-69b4ebf041fa"],
 ", ",
 Cell[BoxData["\"\<CZ\>\""], "InlineFormula",ExpressionUUID->
  "21420402-69ae-420d-b73e-52bf67203661"],
 ", ",
 Cell[BoxData["\"\<SWAP\>\""], "InlineFormula",ExpressionUUID->
  "0eaf9e74-0843-462e-a003-191465f75915"],
 " each perform exactly that rewrite."
}], "Text",ExpressionUUID->"6803ccc9-25fb-4d66-b380-708ab529ee21"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Two pictures of one circuit: Schr\[ODoubleDot]dinger and Heisenberg", \
"Section",ExpressionUUID->"53ab5324-6aba-490a-9113-e499c03ec408"],

Cell[TextData[{
 "That rewrite is worth slowing down on, because it is the whole reason the \
formalism reproduces ordinary quantum mechanics on its domain. The standard \
task is concrete: given a circuit, produce the final state. There are two \
ways to do it. The ",
 StyleBox["Schr\[ODoubleDot]dinger", "TI"],
 " way carries the state vector forward, ",
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     StyleBox["\[Psi]", "TI"]},
    "Ket"], "\[Function]", 
   RowBox[{
    StyleBox["U", "TI"], 
    TemplateBox[{
      StyleBox["\[Psi]", "TI"]},
     "Ket"]}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "b5536de8-95e7-4fdb-8e30-0d011ee6cd1a"],
 ", with ",
 Cell[BoxData[
  SuperscriptBox["2", 
   StyleBox["n", "TI"]]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "0b37b5da-4862-4b66-be02-32f97fae8e75"],
 " amplitudes evolving under ",
 Cell[BoxData[
  RowBox[{
   SuperscriptBox["2", 
    StyleBox["n", "TI"]], "\[Times]", 
   SuperscriptBox["2", 
    StyleBox["n", "TI"]]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "bb34e388-0df9-4dfb-8fd5-26d9736fb916"],
 " matrices. The ",
 StyleBox["Heisenberg", "TI"],
 " way carries the generators forward and never forms the state at all. They \
return the same state, and watching them meet is the clearest way to see what \
the tableau computes."
}], "Text",ExpressionUUID->"3ca9e9be-6861-469f-88b5-f904285772fb"],

Cell[TextData[{
 "Fix a small Clifford circuit on three qubits, with an ",
 Cell[BoxData[
  StyleBox["S", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "a5c3124b-a8c7-4bd2-b9bc-c07297df8af1"],
 " gate to make the result nontrivial."
}], "Text",ExpressionUUID->"28f79b6b-a4c6-45ed-86a9-58c5f0159760"],

Cell[BoxData[
 RowBox[{
  RowBox[{"cliffordCircuit", " ", "=", " ", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"\"\<H\>\"", " ", "->", " ", "1"}], ",", " ", 
     RowBox[{"\"\<CNOT\>\"", " ", "->", " ", 
      RowBox[{"{", 
       RowBox[{"1", ",", " ", "2"}], "}"}]}], ",", " ", 
     RowBox[{"\"\<S\>\"", " ", "->", " ", "2"}], ",", " ", 
     RowBox[{"\"\<CNOT\>\"", " ", "->", " ", 
      RowBox[{"{", 
       RowBox[{"2", ",", " ", "3"}], "}"}]}]}], "}"}]}], ";"}]], "Input",
 CellLabel->
  "In[21]:= ",ExpressionUUID->"ee54e9e6-4122-48bb-8e6b-c1c2ad3973c7"],

Cell[TextData[{
 "In the Schr\[ODoubleDot]dinger picture we propagate ",
 Cell[BoxData[
  TemplateBox[{"000"},
   "Ket"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "cf3d51cc-4d5b-4476-b41a-7950f08171f8"],
 " through the circuit and read off the amplitudes. This is the answer the \
formalism has to reproduce:"
}], "Text",ExpressionUUID->"32cdefdb-a30c-4ff8-97b0-d03449419f28"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"psiSchrodinger", " ", "=", " ", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"QuantumCircuitOperator", "[", "cliffordCircuit", "]"}], "[", 
     RowBox[{
      RowBox[{"QuantumState", "[", "\"\<000\>\"", "]"}], ",", " ", 
      RowBox[{"Method", " ", "->", " ", "\"\<Schrodinger\>\""}]}], "]"}], 
    "[", "\"\<StateVector\>\"", "]"}], " ", "//", " ", "Normal"}]}]], "Input",\

 CellLabel->
  "In[22]:= ",ExpressionUUID->"5a2464e0-926c-48c9-984d-1d6eaea393d8"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   FractionBox["1", 
    SqrtBox["2"]], ",", "0", ",", "0", ",", "0", ",", "0", ",", "0", ",", "0",
    ",", 
   FractionBox["\[ImaginaryI]", 
    SqrtBox["2"]]}], "}"}]], "Output",
 CellLabel->
  "Out[22]= ",ExpressionUUID->"e73d77d2-b66d-433e-8272-169b4aaea856"]
}, Open  ]],

Cell[TextData[{
 "The state is ",
 Cell[BoxData[
  RowBox[{
   RowBox[{"(", 
    RowBox[{
     TemplateBox[{"000"},
      "Ket"], "+", 
     RowBox[{
      StyleBox["i", "TI"], 
      TemplateBox[{"111"},
       "Ket"]}]}], ")"}], "/", 
   SqrtBox["2"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "f3923090-69ff-4a9e-8396-6b4bfab60a11"],
 ", a GHZ state carrying the relative phase the ",
 Cell[BoxData[
  StyleBox["S", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "bcf1032a-12e9-43a2-abe1-7b921a39cbe8"],
 " gate inserted."
}], "Text",ExpressionUUID->"286eaad6-d020-4009-85ca-746eea9dfa61"],

Cell[TextData[{
 "Now the Heisenberg picture. Instead of asking where the state goes, ask \
what fixes it. If ",
 Cell[BoxData[
  StyleBox["g", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "548738fc-3fc4-4576-97ac-05449e69c90f"],
 " stabilizes ",
 Cell[BoxData[
  TemplateBox[{
    StyleBox["\[Psi]", "TI"]},
   "Ket"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "0effe974-8b1e-49dc-a510-c31dcde5be55"],
 ", then after a gate ",
 Cell[BoxData[
  StyleBox["U", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "cc23c454-ef9f-400b-9549-37516de14efc"],
 " the conjugated operator ",
 Cell[BoxData[
  RowBox[{
   StyleBox["U", "TI"], 
   StyleBox["g", "TI"], 
   SuperscriptBox[
    StyleBox["U", "TI"], "\[Dagger]"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "0e737427-d886-4f72-8030-12887a7fbe4e"],
 " stabilizes ",
 Cell[BoxData[
  RowBox[{
   StyleBox["U", "TI"], 
   TemplateBox[{
     StyleBox["\[Psi]", "TI"]},
    "Ket"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "a69c6fce-5647-461a-85bd-1d285d3671b7"],
 ", because ",
 Cell[BoxData[
  RowBox[{
   RowBox[{
    StyleBox["g", "TI"], 
    TemplateBox[{
      StyleBox["\[Psi]", "TI"]},
     "Ket"]}], "=", 
   TemplateBox[{
     StyleBox["\[Psi]", "TI"]},
    "Ket"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "6e91dcb4-c061-4224-bfee-0f05e9cd1d44"],
 " gives ",
 Cell[BoxData[
  RowBox[{
   RowBox[{
    RowBox[{
     StyleBox["(",
      SpanMaxSize->1], 
     RowBox[{
      StyleBox["U", "TI"], 
      StyleBox["g", "TI"], 
      SuperscriptBox[
       StyleBox["U", "TI"], "\[Dagger]"]}], 
     StyleBox[")",
      SpanMaxSize->1]}], 
    StyleBox["U", "TI"], 
    TemplateBox[{
      StyleBox["\[Psi]", "TI"]},
     "Ket"]}], "=", 
   RowBox[{
    RowBox[{
     StyleBox["U", "TI"], 
     StyleBox["g", "TI"], 
     TemplateBox[{
       StyleBox["\[Psi]", "TI"]},
      "Ket"]}], "=", 
    RowBox[{
     StyleBox["U", "TI"], 
     TemplateBox[{
       StyleBox["\[Psi]", "TI"]},
      "Ket"]}]}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "f4841568-5231-4981-b6b3-6e1e709b07f6"],
 ". The whole evolution of the state is therefore carried by the conjugation ",
 Cell[BoxData[
  RowBox[{
   StyleBox["g", "TI"], "\[Function]", 
   StyleBox["U", "TI"], 
   StyleBox["g", "TI"], 
   SuperscriptBox[
    StyleBox["U", "TI"], "\[Dagger]"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "b34aadf8-fb76-47fd-9d99-4ec30b40e8cb"],
 " of its generators, and the one fact that makes this cheap is that a \
Clifford sends a Pauli to a Pauli. Take the input generator ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["Z", "TI"], "1"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "634efaaa-63cb-46d9-9fb5-80ea4213448f"],
 ", conjugate it by the circuit's unitary, and decompose the result into \
Paulis:"
}], "Text",ExpressionUUID->"72dde38e-4927-45a0-925a-e1926b3cd823"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"circuitU", " ", "=", " ", 
   RowBox[{
    RowBox[{
     RowBox[{"QuantumCircuitOperator", "[", "cliffordCircuit", "]"}], 
     "[", "\"\<QuantumOperator\>\"", "]"}], "[", "\"\<Matrix\>\"", "]"}]}], 
  ";"}], "\n", 
 RowBox[{
  RowBox[{"QuantumOperator", "[", 
   RowBox[{"circuitU", " ", ".", " ", 
    RowBox[{"genMatrix", "[", "\"\<ZII\>\"", "]"}], " ", ".", " ", 
    RowBox[{"ConjugateTranspose", "[", "circuitU", "]"}]}], "]"}], 
  "[", "\"\<PauliDecompose\>\"", "]"}]}], "Input",
 CellLabel->
  "In[23]:= ",ExpressionUUID->"7179c13e-e4e2-4f0a-809b-a1d0eb62f068"],

Cell[BoxData[
 RowBox[{"\[LeftAssociation]", 
  RowBox[{"\<\"XYX\"\>", "\[Rule]", "1"}], "\[RightAssociation]"}]], "Output",\

 CellLabel->
  "Out[23]= ",ExpressionUUID->"7cb666cb-f56d-40af-8065-ecec189856d4"]
}, Open  ]],

Cell[TextData[{
 "The decomposition has a single term, ",
 Cell[BoxData[
  RowBox[{
   SubscriptBox[
    StyleBox["X", "TI"], "1"], 
   SubscriptBox[
    StyleBox["Y", "TI"], "2"], 
   SubscriptBox[
    StyleBox["X", "TI"], "3"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "0e0e6dca-6a81-41b8-98c1-093359609862"],
 ": the operator never left the Pauli group. One generator went in, one came \
out. That closure is why the tableau update of the previous section is a \
fixed local rewrite of a few bits rather than a dense matrix multiply."
}], "Text",ExpressionUUID->"6b1dc8c0-bef2-4657-b660-61440e7a6320"],

Cell[TextData[{
 "Propagating all three input generators ",
 Cell[BoxData[
  RowBox[{
   SubscriptBox[
    StyleBox["Z", "TI"], "1"], 
   RowBox[{",", "\[ThinSpace]"}], 
   SubscriptBox[
    StyleBox["Z", "TI"], "2"], 
   RowBox[{",", "\[ThinSpace]"}], 
   SubscriptBox[
    StyleBox["Z", "TI"], "3"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "f1a59a0d-a442-4e52-a6bb-01e3d7e7395b"],
 " this way is exactly what ",
 Cell[BoxData["\"\<ApplyCircuit\>\""], "InlineFormula",ExpressionUUID->
  "e93b53b7-d304-4822-a43c-eef8d572978f"],
 " does, and the result is the stabilizer group of the final state. Its first \
generator is the ",
 Cell[BoxData[
  RowBox[{
   SubscriptBox[
    StyleBox["X", "TI"], "1"], 
   SubscriptBox[
    StyleBox["Y", "TI"], "2"], 
   SubscriptBox[
    StyleBox["X", "TI"], "3"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "5dd719af-c9f5-48de-b7c2-a6975c6659d7"],
 " we just conjugated by hand:"
}], "Text",ExpressionUUID->"c272ef1d-c3f5-4b59-928c-89097ecdc4ea"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"PauliStabilizer", "[", "3", "]"}], "[", 
   RowBox[{"\"\<ApplyCircuit\>\"", ",", " ", "cliffordCircuit"}], "]"}], 
  "[", "\"\<Stabilizers\>\"", "]"}]], "Input",
 CellLabel->
  "In[24]:= ",ExpressionUUID->"4e2b21bd-d062-4e9a-94b5-8149ce979492"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"\<\"XYX\"\>", ",", "\<\"ZZI\"\>", ",", "\<\"IZZ\"\>"}], 
  "}"}]], "Output",
 CellLabel->
  "Out[24]= ",ExpressionUUID->"1efaa60b-478d-497e-a01b-a4011f7e2c11"]
}, Open  ]],

Cell[TextData[{
 "The two pictures must describe the same physics, and they do. Materialize \
the state from the final generators (the formalism's ",
 Cell[BoxData["\"\<State\>\""], "InlineFormula",ExpressionUUID->
  "04d7d60e-2e8c-4474-a45d-9ef7f0593798"],
 ") and overlap it with the Schr\[ODoubleDot]dinger answer: the magnitude is \
one, so the states are equal up to the global phase the tableau drops."
}], "Text",ExpressionUUID->"32129007-70e7-450d-b583-62ae7b16605f"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"psiStabilizer", " ", "=", " ", 
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{"PauliStabilizer", "[", "3", "]"}], "[", 
       RowBox[{"\"\<ApplyCircuit\>\"", ",", " ", "cliffordCircuit"}], "]"}], 
      "[", "\"\<State\>\"", "]"}], "[", "\"\<StateVector\>\"", "]"}], " ", "//",
     " ", "Normal"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"Chop", "[", 
   RowBox[{
    RowBox[{"Abs", "[", 
     RowBox[{
      RowBox[{"Conjugate", "[", "psiSchrodinger", "]"}], " ", ".", " ", 
      "psiStabilizer"}], "]"}], " ", "-", " ", "1"}], "]"}], " ", "==", " ", 
  "0"}]}], "Input",
 CellLabel->
  "In[25]:= ",ExpressionUUID->"0d30b422-78e8-476d-9124-6c0fbeb108a8"],

Cell[BoxData["True"], "Output",
 CellLabel->
  "Out[25]= ",ExpressionUUID->"57c32058-a369-4292-8e67-db0870e153d6"]
}, Open  ]],

Cell[TextData[{
 "This is the Gottesman-Knill theorem made concrete: a Clifford circuit on a \
stabilizer input is simulated by propagating ",
 Cell[BoxData[
  StyleBox["n", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "84f31db8-e629-460c-b643-783d703c5149"],
 " generators at ",
 Cell[BoxData[
  RowBox[{
   StyleBox["O", "TI"], 
   StyleBox["(",
    SpanMaxSize->1], 
   StyleBox["n", "TI"], 
   StyleBox[")",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "07864706-3c00-4d4b-a639-5dc49645fc1e"],
 " work per gate, and the state it computes is exactly the one Schr\
\[ODoubleDot]dinger evolution would, with the ",
 Cell[BoxData[
  SuperscriptBox["2", 
   StyleBox["n", "TI"]]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "705da77b-f65e-4357-8604-9ebdd05c4bc8"],
 " vector never formed except, here, to check."
}], "Text",ExpressionUUID->"f0152973-c366-4e33-888e-6d6aa4d2d867"],

Cell[TextData[{
 "The construction rests entirely on Clifford conjugation keeping a Pauli a \
Pauli, so it is also clear where it must break. A non-Clifford gate does not \
respect the Pauli group. The ",
 Cell[BoxData[
  StyleBox["T", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "cc7c9f42-dcce-4c6a-881e-1c08fc3953ba"],
 " gate commutes with ",
 Cell[BoxData[
  StyleBox["Z", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "3bae291e-388a-43b9-a589-3c17bdf15a32"],
 ", but conjugating ",
 Cell[BoxData[
  StyleBox["X", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "2897af33-e7eb-49b3-932d-6d34d7614282"],
 " by it gives a sum:"
}], "Text",ExpressionUUID->"84dd2377-d389-431f-bb02-bc68843d4818"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"Tgate", " ", "=", " ", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"1", ",", " ", "0"}], "}"}], ",", " ", 
     RowBox[{"{", 
      RowBox[{"0", ",", " ", 
       RowBox[{"Exp", "[", 
        RowBox[{"I", " ", 
         RowBox[{"Pi", "/", "4"}]}], "]"}]}], "}"}]}], "}"}]}], ";"}], "\n", 
 RowBox[{"ExpToTrig", " ", "@", " ", 
  RowBox[{
   RowBox[{"QuantumOperator", "[", 
    RowBox[{"Tgate", " ", ".", " ", 
     RowBox[{"genMatrix", "[", "\"\<X\>\"", "]"}], " ", ".", " ", 
     RowBox[{"ConjugateTranspose", "[", "Tgate", "]"}]}], "]"}], 
   "[", "\"\<PauliDecompose\>\"", "]"}]}]}], "Input",
 CellLabel->
  "In[26]:= ",ExpressionUUID->"3a4b08db-bd6f-4d45-8f5a-e4e7ebc15721"],

Cell[BoxData[
 RowBox[{"\[LeftAssociation]", 
  RowBox[{
   RowBox[{"\<\"X\"\>", "\[Rule]", 
    FractionBox["1", 
     SqrtBox["2"]]}], ",", 
   RowBox[{"\<\"Y\"\>", "\[Rule]", 
    FractionBox["1", 
     SqrtBox["2"]]}]}], "\[RightAssociation]"}]], "Output",
 CellLabel->
  "Out[26]= ",ExpressionUUID->"9f4cc177-6816-4c38-9024-fc2a1e7cbd7b"]
}, Open  ]],

Cell[TextData[{
 "Here ",
 Cell[BoxData[
  RowBox[{
   StyleBox["T", "TI"], 
   StyleBox["X", "TI"], 
   SuperscriptBox[
    StyleBox["T", "TI"], "\[Dagger]"], "=", 
   StyleBox["(",
    SpanMaxSize->1], 
   RowBox[{
    StyleBox["X", "TI"], "+", 
    StyleBox["Y", "TI"]}], 
   StyleBox[")",
    SpanMaxSize->1], "/", 
   SqrtBox["2"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "dfad1738-0fc4-415b-99c0-fc4c9e28fc84"],
 " has two terms, not one. A single generator no longer maps to a single \
generator, the group stops being generated by ",
 Cell[BoxData[
  StyleBox["n", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "386ef4bd-46c6-4188-a646-6c689695f4af"],
 " Pauli strings, and the cheap representation fails. That failure is not an \
accident of implementation but the edge of the classically tractable world; \
the frontier section returns to how far one can push past it with stabilizer \
frames."
}], "Text",ExpressionUUID->"6ab13623-ab70-4d64-bd07-c3a64f71df6e"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Entanglement for free: Bell and GHZ", "Section",ExpressionUUID->"12ca8759-cd48-477f-a130-acf6c01a60ad"],

Cell[TextData[{
 "Entangled states are not special in this language; they are simply \
stabilizer groups whose generators are not single-qubit operators. The Bell \
state ",
 Cell[BoxData[
  TemplateBox[{
    SuperscriptBox["\[CapitalPhi]", "+"]},
   "Ket"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "897c6ae7-1473-4059-a8f7-fac2db890f41"],
 " is prepared from ",
 Cell[BoxData[
  TemplateBox[{"00"},
   "Ket"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "83efd5cf-1e08-496a-8d01-45f692fb0ee1"],
 " by a Hadamard and a CNOT, and its stabilizer group is generated by ",
 Cell[BoxData[
  StyleBox[
   RowBox[{"X", "X"}], "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "72559594-86ee-4523-81b3-8cb21ea5802d"],
 " and ",
 Cell[BoxData[
  StyleBox[
   RowBox[{"Z", "Z"}], "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "c1f7c4b4-80bf-4333-b027-986c78528693"],
 "."
}], "Text",ExpressionUUID->"6742a0b8-7a9f-4d67-83fc-95dfcee5515b"],

Cell["Build the Bell state and read its generators:", "Text",ExpressionUUID->"217df4a3-9b9f-44c1-9014-6b1337a39db2"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"bell", " ", "=", " ", 
   RowBox[{
    RowBox[{
     RowBox[{"PauliStabilizer", "[", "2", "]"}], "[", 
     RowBox[{"\"\<H\>\"", ",", " ", "1"}], "]"}], "[", 
    RowBox[{"\"\<CNOT\>\"", ",", " ", "1", ",", " ", "2"}], "]"}]}], ";"}], "\n", 
 RowBox[{"bell", "[", "\"\<Stabilizers\>\"", "]"}]}], "Input",
 CellLabel->
  "In[27]:= ",ExpressionUUID->"ef8b4b0f-337b-4435-baf9-48a3140fcfe8"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"\<\"XX\"\>", ",", "\<\"ZZ\"\>"}], "}"}]], "Output",
 CellLabel->
  "Out[27]= ",ExpressionUUID->"f92fdc0d-b7c8-4f37-a71d-cec71fc4905d"]
}, Open  ]],

Cell[TextData[{
 "The generators ",
 Cell[BoxData[
  StyleBox[
   RowBox[{"X", "X"}], "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "fceeb283-d23a-460f-b35f-e0f6e7617297"],
 " and ",
 Cell[BoxData[
  StyleBox[
   RowBox[{"Z", "Z"}], "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "1c08e9fe-30af-4828-8f68-ecc401e6f57d"],
 " are the familiar parity checks: the two qubits share an ",
 Cell[BoxData[
  StyleBox["X", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "1ec2cf15-ee66-4c5d-81dd-828aa3fa26e0"],
 "-parity and a ",
 Cell[BoxData[
  StyleBox["Z", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "36331e13-8ca4-4657-9cd0-92a40b6c9ca8"],
 "-parity, which is precisely what maximal entanglement looks like here. The \
state vector is the textbook one:"
}], "Text",ExpressionUUID->"d8e813ba-041b-49ab-82e4-65c97fe8ca76"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"bell", "[", "\"\<State\>\"", "]"}], "[", "\"\<StateVector\>\"", 
   "]"}], " ", "//", " ", "Normal"}]], "Input",
 CellLabel->
  "In[28]:= ",ExpressionUUID->"7a8105ce-7791-4a51-bb1a-3e727043e1db"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   FractionBox["1", 
    SqrtBox["2"]], ",", "0", ",", "0", ",", 
   FractionBox["1", 
    SqrtBox["2"]]}], "}"}]], "Output",
 CellLabel->
  "Out[28]= ",ExpressionUUID->"40dd9ee9-cc8c-45c2-8c91-ee0773defbbc"]
}, Open  ]],

Cell[TextData[{
 "Entanglement entropy, normally a Schmidt-decomposition computation that \
blows up with system size, has a closed form for stabilizer states. Fattal \
and collaborators showed that the entanglement entropy across a cut ",
 Cell[BoxData[
  StyleBox["A", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "2ca65c83-504b-4f87-879e-4235ad3058e0"],
 " equals the ",
 Cell[BoxData[
  SubscriptBox["\|01d53d", "2"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "c45f252f-e5b2-438b-9643-63b0497b8365"],
 "-rank of the generators restricted to ",
 Cell[BoxData[
  StyleBox["A", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "9f731dd6-639a-471f-996a-4d716627d779"],
 ", minus ",
 Cell[BoxData[
  RowBox[{
   StyleBox["\[LeftBracketingBar]",
    SpanMaxSize->1], 
   StyleBox["A", "TI"], "\[VeryThinSpace]", 
   StyleBox["\[RightBracketingBar]",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "6bbe3641-d278-49b0-8076-50fa82be2390"],
 ". The framework computes this with ",
 Cell[BoxData["\"\<Entropy\>\""], "InlineFormula",ExpressionUUID->
  "d3345853-0017-40e1-92ac-914be327f40d"],
 ", in ",
 Cell[BoxData[
  RowBox[{
   StyleBox["O", "TI"], 
   StyleBox["(",
    SpanMaxSize->1], 
   SuperscriptBox[
    StyleBox["n", "TI"], "3"], 
   StyleBox[")",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "f3b1a5a1-9bfc-4fd1-aaa1-2c4a66b48aba"],
 " and with no dependence on ",
 Cell[BoxData[
  RowBox[{
   StyleBox["\[LeftBracketingBar]",
    SpanMaxSize->1], 
   StyleBox["A", "TI"], "\[VeryThinSpace]", 
   StyleBox["\[RightBracketingBar]",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "9d3bb662-f83c-4250-a0f8-b582c383962c"],
 ". For the Bell state, tracing out one qubit gives one bit of entropy:"
}], "Text",ExpressionUUID->"03761d06-8da5-4a74-8384-5eb051d7c47a"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"bell", "[", 
  RowBox[{"\"\<Entropy\>\"", ",", " ", 
   RowBox[{"{", "1", "}"}]}], "]"}]], "Input",
 CellLabel->
  "In[29]:= ",ExpressionUUID->"409db1b5-8fe0-4427-9547-4935a75e6bca"],

Cell[BoxData["1"], "Output",
 CellLabel->
  "Out[29]= ",ExpressionUUID->"44c3a1a3-a69a-4544-a1aa-358eaa1275d5"]
}, Open  ]],

Cell[TextData[{
 "The payoff is scale. A GHZ state on a thousand qubits is built by one \
Hadamard and a ladder of CNOTs, and its single-qubit entanglement entropy is \
still one bit, computed without ever forming a ",
 Cell[BoxData[
  SuperscriptBox["2", "1000"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "15ab7434-7f0f-4c91-866c-cd247a575f1b"],
 " vector:"
}], "Text",ExpressionUUID->"85ea2aa8-a7bf-4524-b81f-cbc56f77b863"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"ghz", " ", "=", " ", 
   RowBox[{"Fold", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"#1", "[", 
       RowBox[{"\"\<CNOT\>\"", ",", " ", 
        RowBox[{"#2", " ", "-", " ", "1"}], ",", " ", "#2"}], "]"}], " ", 
      "&"}], ",", " ", 
     RowBox[{
      RowBox[{"PauliStabilizer", "[", "1000", "]"}], "[", 
      RowBox[{"\"\<H\>\"", ",", " ", "1"}], "]"}], ",", " ", 
     RowBox[{"Range", "[", 
      RowBox[{"2", ",", " ", "1000"}], "]"}]}], "]"}]}], ";"}], "\n", 
 RowBox[{"{", 
  RowBox[{
   RowBox[{"ghz", "[", "\"\<Qubits\>\"", "]"}], ",", " ", 
   RowBox[{"ghz", "[", 
    RowBox[{"\"\<Entropy\>\"", ",", " ", 
     RowBox[{"{", "1", "}"}]}], "]"}]}], "}"}]}], "Input",
 CellLabel->
  "In[30]:= ",ExpressionUUID->"5ccb6760-a58e-43d0-83d5-b378a449caa1"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"1000", ",", "1"}], "}"}]], "Output",
 CellLabel->
  "Out[30]= ",ExpressionUUID->"107679e1-af35-4f93-9744-6fe87f81175c"]
}, Open  ]],

Cell["\<\
Time the entropy of a 500-qubit GHZ state to see that it is essentially \
instantaneous:\
\>", "Text",ExpressionUUID->"62a20b64-9dde-4806-ad85-6482cfbd608f"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"AbsoluteTiming", "[", 
  RowBox[{"ghz", "[", 
   RowBox[{"\"\<Entropy\>\"", ",", " ", 
    RowBox[{"{", "1", "}"}]}], "]"}], "]"}]], "Input",
 CellLabel->
  "In[31]:= ",ExpressionUUID->"5de7b204-622b-4656-80ce-3a21a5797867"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"0.053556`", ",", "1"}], "}"}]], "Output",
 CellLabel->
  "Out[31]= ",ExpressionUUID->"c3a65322-21d2-4f5d-a603-96f0a667a145"]
}, Open  ]],

Cell["What we have established:", "Text",ExpressionUUID->"aad5444a-f1b8-47a6-84ee-4d16a12af31c"],

Cell[TextData[{
 "An entangled stabilizer state is one whose generators are multi-qubit Pauli \
strings; Bell is ",
 Cell[BoxData[
  RowBox[{
   StyleBox["\[LeftAngleBracket]",
    SpanMaxSize->1], 
   RowBox[{
    StyleBox[
     RowBox[{"X", "X"}], "TI"], 
    RowBox[{",", "\[ThinSpace]"}], 
    StyleBox[
     RowBox[{"Z", "Z"}], "TI"]}], "\[VeryThinSpace]", 
   StyleBox["\[RightAngleBracket]",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "fb67faa3-57ce-406f-8e97-225b38b3083a"],
 "."
}], "Item",ExpressionUUID->"9004f77f-df38-4ced-ad65-3edd4999b155"],

Cell[TextData[{
 "Entanglement entropy is an ",
 Cell[BoxData[
  SubscriptBox["\|01d53d", "2"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "8d36fbe7-8567-47e2-ab01-3127cabe06a3"],
 " rank, computable at ",
 Cell[BoxData[
  RowBox[{
   StyleBox["n", "TI"], "=", "1000"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "d089649a-45f4-448a-86cb-fb49877fc822"],
 " in milliseconds."
}], "Item",ExpressionUUID->"c3450801-3ab6-4c10-b2f9-db9acf0b6b6c"],

Cell[TextData[{
 "The cost of all this is ",
 Cell[BoxData[
  RowBox[{
   StyleBox["O", "TI"], 
   StyleBox["(",
    SpanMaxSize->1], 
   SuperscriptBox[
    StyleBox["n", "TI"], "2"], 
   StyleBox[")",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "b75cca58-c38c-464f-b36d-69bfffef4b11"],
 " storage and ",
 Cell[BoxData[
  RowBox[{
   StyleBox["O", "TI"], 
   StyleBox["(",
    SpanMaxSize->1], 
   SuperscriptBox[
    StyleBox["n", "TI"], "3"], 
   StyleBox[")",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "7632f9c1-f203-4275-b754-0b315b8077d9"],
 " for the rank, never ",
 Cell[BoxData[
  RowBox[{
   StyleBox["O", "TI"], 
   StyleBox["(",
    SpanMaxSize->1], 
   SuperscriptBox["2", 
    StyleBox["n", "TI"]], 
   StyleBox[")",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "f4d7a954-1d3c-4f46-884f-35adcc47fca6"],
 "."
}], "Item",ExpressionUUID->"25fded61-4f08-435e-bae6-9f07ce29e7f9"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Measurement: randomness, back-action, and correlation", "Section",ExpressionUUID->"80a85d84-dd90-4dcf-b328-b6705b6315bc"],

Cell[TextData[{
 "Measurement is where the destabilizers earn their keep. Measuring ",
 Cell[BoxData[
  StyleBox["Z", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "fdb5c347-b412-41c5-b543-5b889bf3fc56"],
 " on qubit ",
 Cell[BoxData[
  StyleBox["a", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "1bafa66a-ce2b-4451-a919-97ad713d56fa"],
 " splits into two cases. If ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["Z", "TI"], 
   StyleBox["a", "TI"]]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "ce21d7de-69b4-4c62-bd95-6f3b594ce84f"],
 " commutes with every stabilizer, the outcome is ",
 StyleBox["deterministic", "TI"],
 " and the state is unchanged; the outcome bit is read off by multiplying \
together the stabilizers that overlap ",
 Cell[BoxData[
  StyleBox["a", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "f55ebf0c-5c4f-4aaa-8dcb-d20ca1f66e76"],
 ". If some stabilizer anticommutes with ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["Z", "TI"], 
   StyleBox["a", "TI"]]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "8a2449f0-1998-4294-b908-ac6df664c03e"],
 ", the outcome is a fair coin, and the post-measurement state is obtained by \
a single Aaronson-Gottesman row update that uses one destabilizer as scratch \
space. Either way the work is ",
 Cell[BoxData[
  RowBox[{
   StyleBox["O", "TI"], 
   StyleBox["(",
    SpanMaxSize->1], 
   SuperscriptBox[
    StyleBox["n", "TI"], "2"], 
   StyleBox[")",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "ff8eabde-a90b-4e17-80e8-ecf10d228957"],
 ", never ",
 Cell[BoxData[
  RowBox[{
   StyleBox["O", "TI"], 
   StyleBox["(",
    SpanMaxSize->1], 
   SuperscriptBox["2", 
    StyleBox["n", "TI"]], 
   StyleBox[")",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "31b313c2-adc8-45e2-9ce5-5799037a40b0"],
 "."
}], "Text",ExpressionUUID->"d1fc0efc-ef30-4ad0-8f0a-e7075905bfb5"],

Cell["\<\
A measurement on a stabilizer state returns an association from outcome to \
post-state. For the Bell state, measuring qubit 1 is random, so both branches \
appear:\
\>", "Text",ExpressionUUID->"bdb6a3f1-8bbc-42d2-9213-eff9ba777cdd"],

