Cell[TextData[{
 "We read off the operator that stabilizes it with the ",
 Cell[BoxData["\"\<Stabilizers\>\""], "InlineFormula",ExpressionUUID->
  "9d690939-6a59-4463-b8b3-d20ba6a55502"],
 " property:"
}], "Text",ExpressionUUID->"afc89ffb-3c04-41da-810a-cfbb59ef5b0c"],

