Cell[TextData[{
 "The outcomes are exactly ",
 Cell[BoxData[
  RowBox[{
   RowBox[{"{", "0"}], 
   RowBox[{",", "\[ThinSpace]"}], "0", 
   RowBox[{",", "\[ThinSpace]"}], 
   RowBox[{"0", "}"}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "056e7a26-9097-4699-bf71-a2a8007e92e6"],
 " and ",
 Cell[BoxData[
  RowBox[{
   RowBox[{"{", "1"}], 
   RowBox[{",", "\[ThinSpace]"}], "1", 
   RowBox[{",", "\[ThinSpace]"}], 
   RowBox[{"1", "}"}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "d2d18f8c-37f0-405e-bc57-5e93d5043192"],
 ": the GHZ state never returns a split string with some 0s and some 1s, \
which is the perfect three-body correlation. We can also measure a joint \
Pauli observable directly, for instance the parity ",
 Cell[BoxData[
  StyleBox[
   RowBox[{"Z", "Z"}], "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "a0e9d049-2cc5-4281-ae2a-b90e5236a98b"],
 " on the Bell state, which is deterministic and equal to ",
 Cell[BoxData[
  RowBox[{"+", "1"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "2b8f5829-5004-4ae3-91e4-81e721dab4a4"],
 ":"
}], "Text",ExpressionUUID->"ac76e2fc-3d7e-463e-8fa8-91bf8bf0ac6f"],

