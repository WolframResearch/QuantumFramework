 RowBox[{
  RowBox[{"SeedRandom", "[", "7", "]"}], ";"}], "\n", 
 RowBox[{
  RowBox[{"specs2", " ", "=", " ", 
   RowBox[{"Table", "[", "\n", "   ", 
    RowBox[{
     RowBox[{"RandomChoice", "[", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"\"\<H\>\"", " ", "->", " ", 
         RowBox[{"RandomInteger", "[", 
          RowBox[{"{", 
           RowBox[{"1", ",", " ", "4"}], "}"}], "]"}]}], ",", " ", 
        RowBox[{"\"\<S\>\"", " ", "->", " ", 
         RowBox[{"RandomInteger", "[", 
          RowBox[{"{", 
           RowBox[{"1", ",", " ", "4"}], "}"}], "]"}]}], ",", "\n", "     ", 
        RowBox[{"\"\<CNOT\>\"", " ", "->", " ", 
         RowBox[{"RandomSample", "[", 
          RowBox[{
           RowBox[{"Range", "[", "4", "]"}], ",", " ", "2"}], "]"}]}]}], 
       "}"}], "]"}], ",", "\n", "   ", 
     RowBox[{"{", "30", "}"}]}], "]"}]}], ";"}]}], "Input",
 CellLabel->
  "In[65]:= ",ExpressionUUID->"c273444a-99a7-4e1b-8963-02da1a5f2c78"],

