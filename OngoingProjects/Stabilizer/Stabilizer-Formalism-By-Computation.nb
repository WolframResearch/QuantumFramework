Cell[TextData[{
 "The same move with ",
 Cell[BoxData[
  StyleBox["X", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "5e07d8a3-a559-4a2d-898e-b0aa4813da2a"],
 " in place of ",
 Cell[BoxData[
  StyleBox["H", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "59ca2d59-5dda-4a6c-a0b5-a4c0d6c9c0a1"],
 " carries ",
