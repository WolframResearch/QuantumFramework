Cell[TextData[{
 "The same content flattened to a binary matrix is easier to read: the ",
 Cell[BoxData[
  StyleBox["X", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "125f4611-a631-4586-9aef-c6869fed3b08"],
 " rows on top, the ",
 Cell[BoxData[
  StyleBox["Z", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "a0947ef7-4a45-4438-9d1e-99f756d4e1a8"],
 " rows below, the ",
 Cell[BoxData[
  RowBox[{"2", 
   StyleBox["n", "TI"], "\[Times]", "2", 
   StyleBox["n", "TI"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "50f6a6c0-4f93-4cef-8edf-feb1d4167817"],
 " identity for ",
 Cell[BoxData[
  TemplateBox[{"00"},
   "Ket"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "c18587fb-7f41-40e4-aaa7-a8e5afcc4bc5"],
 ":"
}], "Text",ExpressionUUID->"60d957ea-933e-4344-b15e-3cdf7aa170e9"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"PauliStabilizer", "[", "2", "]"}], "[", "\"\<Matrix\>\"", "]"}], 
  " ", "//", " ", "MatrixForm"}]], "Input",
 CellLabel->
  "In[16]:= ",ExpressionUUID->"94d398a0-194b-4ee2-bf21-93ce06eff781"],

