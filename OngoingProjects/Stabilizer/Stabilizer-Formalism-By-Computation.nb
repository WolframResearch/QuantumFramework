  "InlineFormula",ExpressionUUID->"bcdcec88-f757-49f9-b7c8-5f42e5ec9c05"],
 "."
}], "Item",ExpressionUUID->"653d59fe-d052-44c9-a146-e1e111075d34"],

Cell[TextData[{
 StyleBox["Fold a whole circuit", "TI"],
 " in one compiled pass: ",
 Cell[BoxData[
  RowBox[{"ps", "[", 
   RowBox[{"\"\<ApplyCircuit\>\"", ",", " ", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"\"\<H\>\"", " ", "->", " ", "1"}], ",", " ", 
      RowBox[{"\"\<CNOT\>\"", " ", "->", " ", 
       RowBox[{"{", 
        RowBox[{"1", ",", " ", "2"}], "}"}]}], ",", " ", "..."}], "}"}]}], 
   "]"}]], "InlineFormula",ExpressionUUID->
  "1231c7d8-c908-40e3-97fe-d49b9fa295c3"],
 "."
}], "Item",ExpressionUUID->"7af1d4e3-5da2-4ded-8f19-e8d608f00a4f"],

Cell[TextData[{
 StyleBox["Inspect", "TI"],
 ": ",
 Cell[BoxData[
