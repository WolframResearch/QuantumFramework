}, Open  ]],

Cell[TextData[{
 "The state is ",
 Cell[BoxData[
  RowBox[{
   RowBox[{"(", 
    RowBox[{
     TemplateBox[{"000"},
      "Ket"], "+", 
     RowBox[{
      StyleBox["i", "TI"], 
      TemplateBox[{"111"},
       "Ket"]}]}], ")"}], "/", 
   SqrtBox["2"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "8bddfc73-bf4f-483f-bc79-30053990e27d"],
 ", a GHZ-type state carrying the relative phase the ",
 Cell[BoxData[
  StyleBox["S", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "c0b5cad1-f26f-47e0-9172-657c50b5daf5"],
 " gate inserted."
}], "Text",ExpressionUUID->"bc9d249e-49c7-441f-8501-fa7f9851e7b5"],

Cell[TextData[{
 "Now the Heisenberg picture. Instead of asking where the state goes, ask \
what fixes it. If ",
 Cell[BoxData[
  StyleBox["g", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "641b0bad-820c-4309-81bf-ffa337e8f7f9"],
 " stabilizes ",
 Cell[BoxData[
  TemplateBox[{
    StyleBox["\[Psi]", "TI"]},
   "Ket"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "33dc2a61-ab85-41cf-9135-46bbcdcfbce4"],
 ", then after a gate ",
 Cell[BoxData[
  StyleBox["U", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "4cd64020-63bd-40c0-98ca-0a7e8caf7208"],
 " the conjugated operator ",
 Cell[BoxData[
  RowBox[{
   StyleBox["U", "TI"], 
   StyleBox["g", "TI"], 
   SuperscriptBox[
    StyleBox["U", "TI"], "\[Dagger]"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "24d51594-b2be-41b5-bee5-cc07c781f404"],
 " stabilizes ",
 Cell[BoxData[
  RowBox[{
   StyleBox["U", "TI"], 
   TemplateBox[{
     StyleBox["\[Psi]", "TI"]},
    "Ket"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "84f6e5c0-b084-410f-bb2a-2ba3102036f5"],
 ", because ",
 Cell[BoxData[
  RowBox[{
   RowBox[{
    StyleBox["g", "TI"], 
    TemplateBox[{
      StyleBox["\[Psi]", "TI"]},
     "Ket"]}], "=", 
   TemplateBox[{
     StyleBox["\[Psi]", "TI"]},
    "Ket"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "6809c3be-0dce-4b03-992a-095cbdff0111"],
 " gives ",
 Cell[BoxData[
  RowBox[{
   RowBox[{
    RowBox[{
     StyleBox["(",
      SpanMaxSize->1], 
     RowBox[{
      StyleBox["U", "TI"], 
      StyleBox["g", "TI"], 
      SuperscriptBox[
       StyleBox["U", "TI"], "\[Dagger]"]}], 
     StyleBox[")",
      SpanMaxSize->1]}], 
    StyleBox["U", "TI"], 
    TemplateBox[{
      StyleBox["\[Psi]", "TI"]},
     "Ket"]}], "=", 
   RowBox[{
    RowBox[{
     StyleBox["U", "TI"], 
     StyleBox["g", "TI"], 
     TemplateBox[{
       StyleBox["\[Psi]", "TI"]},
      "Ket"]}], "=", 
    RowBox[{
     StyleBox["U", "TI"], 
     TemplateBox[{
       StyleBox["\[Psi]", "TI"]},
      "Ket"]}]}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "e4e49bfa-a251-43b2-bafb-ba487f854d9d"],
 ". The whole evolution of the state is therefore carried by the conjugation ",
 Cell[BoxData[
  RowBox[{
   StyleBox["g", "TI"], "\[Function]", 
   StyleBox["U", "TI"], 
   StyleBox["g", "TI"], 
   SuperscriptBox[
    StyleBox["U", "TI"], "\[Dagger]"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "ed2b2b39-7838-4c4f-9e26-80a55f2f9b83"],
 " of its generators, and the one fact that makes this cheap is that a \
Clifford sends a Pauli to a Pauli. Take the input generator ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["Z", "TI"], "1"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "8e3c6ed6-333e-41ab-a6bb-9f1f10a4f768"],
 " and conjugate it by the circuit, ",
 Cell[BoxData[
  RowBox[{
   StyleBox["U", "TI"], " ", 
   SubscriptBox[
    StyleBox["Z", "TI"], "1"], " ", 
   SuperscriptBox[
    StyleBox["U", "TI"], "\[Dagger]"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "ac896d13-6887-436d-ae7b-f13c722db995"],
 ". Writing that conjugation as a circuit that applies ",
 Cell[BoxData[
  SuperscriptBox[
   StyleBox["U", "TI"], "\[Dagger]"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "42c97f7c-4f02-4597-a97c-af99265e009f"],
 ", then ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["Z", "TI"], "1"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "db1f7a20-e5bb-4c08-a1a4-1dd3b69b6b88"],
 ", then ",
 Cell[BoxData[
  StyleBox["U", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "b8d2364d-6d99-4da1-baa0-6730783fb03a"],
 " (the same conjugation-as-a-circuit idiom the ",
 Cell[BoxData[
  StyleBox["T", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "8676170d-78fe-47ba-bc50-8fbcb624ec34"],
 " example below uses), ",
 Cell[BoxData["\"\<PauliDecompose\>\""], "InlineFormula",ExpressionUUID->
  "19ec3b76-c65e-48fa-8c0f-2ae888f90fde"],
 " reads off the result:"
}], "Text",ExpressionUUID->"05fc1e87-ca44-48f9-a48b-cf47058e4cee"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"QuantumCircuitOperator", "[", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"cliffordCircuit", "[", "\"\<Dagger\>\"", "]"}], ",", " ", 
     RowBox[{"\"\<Z\>\"", " ", "->", " ", "1"}], ",", " ", 
     "cliffordCircuit"}], "}"}], "]"}], "[", "\"\<PauliDecompose\>\"", 
  "]"}]], "Input",
 CellLabel->
  "In[30]:= ",ExpressionUUID->"5de8e189-bd55-45ad-8099-5aeab9fb4bc2"],

Cell[BoxData[
 RowBox[{"\[LeftAssociation]", 
  RowBox[{"\<\"XYX\"\>", "\[Rule]", "1"}], "\[RightAssociation]"}]], "Output",\

 CellLabel->
  "Out[30]= ",ExpressionUUID->"d21107d5-47a0-420d-9a10-6894e7484d12"]
}, Open  ]],

Cell[TextData[{
 "The decomposition has a single term, ",
 Cell[BoxData[
  RowBox[{
   SubscriptBox[
    StyleBox["X", "TI"], "1"], 
   SubscriptBox[
    StyleBox["Y", "TI"], "2"], 
   SubscriptBox[
    StyleBox["X", "TI"], "3"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "269701df-34f1-45e3-a8cb-752e305f719e"],
 ": the operator never left the Pauli group. One generator went in, one came \
out. That closure is why the tableau update of the previous section is a \
fixed local rewrite of a few bits rather than a dense matrix multiply."
}], "Text",ExpressionUUID->"4d9e1992-6066-488d-ae0e-14cd417f9d60"],

Cell[TextData[{
 "Propagating all three input generators ",
 Cell[BoxData[
  RowBox[{
   SubscriptBox[
    StyleBox["Z", "TI"], "1"], 
   RowBox[{",", "\[ThinSpace]"}], 
   SubscriptBox[
    StyleBox["Z", "TI"], "2"], 
   RowBox[{",", "\[ThinSpace]"}], 
   SubscriptBox[
    StyleBox["Z", "TI"], "3"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "202ce8b2-4391-4902-a194-86d857ee721f"],
 " this way is exactly what the stabilizer backend does. Running the ",
 StyleBox["same circuit object", "TI"],
 " with ",
 Cell[BoxData[
  RowBox[{"Method", " ", "->", " ", "\"\<Stabilizer\>\""}]], "InlineFormula",
  ExpressionUUID->"c8788358-362b-44cd-a0fc-91a3aa6bde30"],
 " in place of ",
 Cell[BoxData["\"\<Schrodinger\>\""], "InlineFormula",ExpressionUUID->
  "13092a16-3dc8-4a7f-b132-69a33d314e8b"],
 " returns the stabilizer group of the final state, whose first generator is \
the ",
 Cell[BoxData[
  RowBox[{
   SubscriptBox[
    StyleBox["X", "TI"], "1"], 
   SubscriptBox[
    StyleBox["Y", "TI"], "2"], 
   SubscriptBox[
    StyleBox["X", "TI"], "3"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "e936a0da-9a7c-43b8-a76c-162f2c847d16"],
 " we just conjugated by hand:"
}], "Text",ExpressionUUID->"e765d2e7-79d2-4e99-ade6-642aa7b82891"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"cliffordCircuit", "[", 
   RowBox[{
    RowBox[{"QuantumState", "[", "\"\<000\>\"", "]"}], ",", " ", 
    RowBox[{"Method", " ", "->", " ", "\"\<Stabilizer\>\""}]}], "]"}], 
  "[", "\"\<Stabilizers\>\"", "]"}]], "Input",
 CellLabel->
  "In[31]:= ",ExpressionUUID->"86fdfac7-cbd8-408a-bc85-e4e060c4edaa"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"\<\"XYX\"\>", ",", "\<\"ZZI\"\>", ",", "\<\"IZZ\"\>"}], 
  "}"}]], "Output",
 CellLabel->
