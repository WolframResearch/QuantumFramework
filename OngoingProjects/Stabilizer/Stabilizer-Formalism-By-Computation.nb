Cell[TextData[{
 "The two values are the post-measurement stabilizer states for outcomes ",
 Cell[BoxData["0"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "ac427cc5-f88c-443a-b8b2-0a9f6b9ec5d2"],
 " and ",
 Cell[BoxData["1"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "8a118834-b152-4d9f-a873-42a128d13e06"],
 "; their signs differ, which is the collapse. The correlation that makes the \
Bell state interesting shows up when we measure ",
 StyleBox["every", "TI"],
 " qubit of a GHZ state: only the all-zeros and all-ones strings have nonzero \
probability."
}], "Text",ExpressionUUID->"8a209fae-98b8-411f-be43-d7f9d9acb296"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"ghz3", " ", "=", " ", 
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{"PauliStabilizer", "[", "3", "]"}], "[", 
      RowBox[{"\"\<H\>\"", ",", " ", "1"}], "]"}], "[", 
     RowBox[{"\"\<CNOT\>\"", ",", " ", "1", ",", " ", "2"}], "]"}], "[", 
    RowBox[{"\"\<CNOT\>\"", ",", " ", "2", ",", " ", "3"}], "]"}]}], ";"}], "\n", 
 RowBox[{"Keys", "[", 
  RowBox[{"ghz3", "[", 
   RowBox[{"\"\<M\>\"", ",", " ", 
    RowBox[{"{", 
     RowBox[{"1", ",", " ", "2", ",", " ", "3"}], "}"}]}], "]"}], 
  "]"}]}], "Input",
 CellLabel->
  "In[33]:= ",ExpressionUUID->"832003af-0799-4148-ab7a-60f270c9a5ab"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"0", ",", "0", ",", "0"}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{"1", ",", "1", ",", "1"}], "}"}]}], "}"}]], "Output",
 CellLabel->
  "Out[33]= ",ExpressionUUID->"bc517b42-acec-4546-972e-3431d9524fdf"]
}, Open  ]],

Cell[TextData[{
 "The outcomes are exactly ",
 Cell[BoxData[
  RowBox[{
   RowBox[{"{", "0"}], 
   RowBox[{",", "\[ThinSpace]"}], "0", 
   RowBox[{",", "\[ThinSpace]"}], 
   RowBox[{"0", "}"}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "fb004adc-3676-44cd-ae6f-7deb5a0ab99e"],
 " and ",
 Cell[BoxData[
  RowBox[{
   RowBox[{"{", "1"}], 
   RowBox[{",", "\[ThinSpace]"}], "1", 
   RowBox[{",", "\[ThinSpace]"}], 
   RowBox[{"1", "}"}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "da15a891-2261-4c8d-bcd9-339f82771700"],
 ": the GHZ state never returns a mixed string, which is the perfect \
three-body correlation. We can also measure a joint Pauli observable \
directly, for instance the parity ",
 Cell[BoxData[
  StyleBox[
   RowBox[{"Z", "Z"}], "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "e9a6a2cb-4105-4071-aef0-7b0a4cb59b80"],
 " on the Bell state, which is deterministic and equal to ",
 Cell[BoxData[
  RowBox[{"+", "1"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "e82a369e-b65a-4916-b60b-329f48806fac"],
 ":"
}], "Text",ExpressionUUID->"299768d7-2fcc-4785-8d0f-929098965b9c"],

