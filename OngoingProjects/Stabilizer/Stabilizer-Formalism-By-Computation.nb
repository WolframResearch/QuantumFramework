Cell[TextData[{
 "The two values are the post-measurement stabilizer states for outcomes ",
 Cell[BoxData["0"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "87f042e1-510a-4a04-828a-5c8e0c82ff91"],
 " and ",
 Cell[BoxData["1"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "164d1510-04a1-47b4-afe8-f2dc157b8e70"],
 "; their signs differ, which is the collapse. The correlation that makes the \
Bell state interesting shows up when we measure ",
 StyleBox["every", "TI"],
 " qubit of a GHZ state: only the all-zeros and all-ones strings have nonzero \
probability."
}], "Text",ExpressionUUID->"cde68f6a-ec09-4c2e-bc5b-19f15398f8fe"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"ghz3", " ", "=", " ", 
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{"PauliStabilizer", "[", "3", "]"}], "[", 
      RowBox[{"\"\<H\>\"", ",", " ", "1"}], "]"}], "[", 
     RowBox[{"\"\<CNOT\>\"", ",", " ", "1", ",", " ", "2"}], "]"}], "[", 
    RowBox[{"\"\<CNOT\>\"", ",", " ", "2", ",", " ", "3"}], "]"}]}], ";"}], "\n", 
 RowBox[{"Keys", "[", 
  RowBox[{"ghz3", "[", 
   RowBox[{"\"\<M\>\"", ",", " ", 
    RowBox[{"{", 
     RowBox[{"1", ",", " ", "2", ",", " ", "3"}], "}"}]}], "]"}], 
  "]"}]}], "Input",
 CellLabel->
  "In[21]:= ",ExpressionUUID->"f02bf0ed-13f3-4e79-90ba-779c2fbe1b63"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"0", ",", "0", ",", "0"}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{"1", ",", "1", ",", "1"}], "}"}]}], "}"}]], "Output",
 CellLabel->
  "Out[21]= ",ExpressionUUID->"440e7b76-b648-4ee4-8c96-2a9c591626f6"]
}, Open  ]],

Cell[TextData[{
 "The outcomes are exactly ",
 Cell[BoxData[
  RowBox[{
   RowBox[{"{", "0"}], 
   RowBox[{",", "\[ThinSpace]"}], "0", 
   RowBox[{",", "\[ThinSpace]"}], 
   RowBox[{"0", "}"}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "4d9716c8-b55c-4a19-9353-b42a948cb322"],
 " and ",
 Cell[BoxData[
  RowBox[{
   RowBox[{"{", "1"}], 
   RowBox[{",", "\[ThinSpace]"}], "1", 
   RowBox[{",", "\[ThinSpace]"}], 
   RowBox[{"1", "}"}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "0789ef1e-c357-4e5a-a9a1-7c301a621922"],
 ": the GHZ state never returns a mixed string, which is the perfect \
three-body correlation. We can also measure a joint Pauli observable \
directly, for instance the parity ",
 Cell[BoxData[
  StyleBox[
   RowBox[{"Z", "Z"}], "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "1515caab-bb3f-42bc-baf9-60eb1652fe6f"],
 " on the Bell state, which is deterministic and equal to ",
 Cell[BoxData[
  RowBox[{"+", "1"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "80e155c5-0177-43b8-a7f0-ff4f7d356fe8"],
 ":"
}], "Text",ExpressionUUID->"3e6e7de4-4fc0-4468-8076-d9f2fe8f8f84"],

