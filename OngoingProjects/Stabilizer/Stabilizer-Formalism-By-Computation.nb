Cell[TextData[{
 "Read off its preparation circuit with the ",
 Cell[BoxData["\"\<Circuit\>\""], "InlineFormula",ExpressionUUID->
  "2d97321a-8e84-4496-ab47-088a97aebda4"],
 " property (a hundred-plus-gate object, so we hold it in ",
 Cell[BoxData[
 "prep"], "InlineFormula",ExpressionUUID->
  "20e97ea1-b73d-4fdb-80e9-0b6cc27703f1"],
 " rather than print it):"
}], "Text",ExpressionUUID->"59ecab23-8c47-400c-b7ba-e593d2e51f62"],

Cell[BoxData[
 RowBox[{
  RowBox[{"prep", " ", "=", " ", 
   RowBox[{"ps10", "[", "\"\<Circuit\>\"", "]"}]}], ";"}]], "Input",
 CellLabel->
  "In[57]:= ",ExpressionUUID->"849cafd9-6acb-4587-b378-5ac52c97cd63"],

Cell["then confirm its head and polynomial gate count:", "Text",ExpressionUUID->"c13241c1-199b-4f98-88f6-46258239a480"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{"Head", "[", "prep", "]"}], ",", " ", 
   RowBox[{"Length", " ", "@", " ", 
    RowBox[{"QuantumShortcut", "[", "prep", "]"}]}]}], "}"}]], "Input",
 CellLabel->
  "In[58]:= ",ExpressionUUID->"4acf1226-05e4-4fd7-a9d1-db976652a382"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"QuantumCircuitOperator", ",", "136"}], "}"}]], "Output",
 CellLabel->
  "Out[58]= ",ExpressionUUID->"dd378abd-4ee0-460d-b258-cf6a64f9a2b2"]
}, Open  ]],

Cell[TextData[{
 "The result is an ordinary ",
 Cell[BoxData[
 "QuantumCircuitOperator"], "InlineFormula",ExpressionUUID->
  "d3accdb9-a4cc-48dc-b30a-094bac0b20dd"],
 ". It genuinely builds the state: applied to the all-zeros register it \
reproduces ",
 Cell[BoxData[
  TemplateBox[{
    StyleBox["\[Psi]", "TI"]},
   "Ket"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "cfbbaba3-f53e-4cc3-a1c0-0b0ed9ac6c70"],
 " exactly. At ten qubits a full ",
 Cell[BoxData[
 "QuantumSimilarity"], "InlineFormula",ExpressionUUID->
  "c5a1bda3-ae33-4219-862a-99faedc6fd59"],
 " would form a ",
 Cell[BoxData[
  RowBox[{
   SuperscriptBox["2", "10"], "\[Times]", 
   SuperscriptBox["2", "10"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "b5eb2dcb-36ca-4252-8a48-81f06fa34892"],
 " density matrix, so here we take the cheaper direct state-vector overlap, \
whose magnitude is one:"
}], "Text",ExpressionUUID->"b46f2ab1-3e14-42a1-96c0-215770c8e42c"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Chop", "[", 
  RowBox[{
   RowBox[{"Abs", "[", 
    RowBox[{
     RowBox[{"Conjugate", "[", 
      RowBox[{"Normal", " ", "@", " ", 
       RowBox[{
        RowBox[{"prep", "[", "]"}], "[", "\"\<StateVector\>\"", "]"}]}], 
      "]"}], " ", ".", " ", 
     RowBox[{"Normal", " ", "@", " ", 
      RowBox[{
       RowBox[{"ps10", "[", "\"\<State\>\"", "]"}], "[", "\"\<StateVector\>\"",
        "]"}]}]}], "]"}], " ", "-", " ", "1"}], "]"}]], "Input",
 CellLabel->
  "In[59]:= ",ExpressionUUID->"0e5e7e44-f573-4a4a-acfe-8d6cd6b66649"],

Cell[BoxData["0"], "Output",
 CellLabel->
  "Out[59]= ",ExpressionUUID->"f28b09a2-0f49-419e-83e3-a54a4e75a013"]
}, Open  ]],

Cell["\<\
This is the inverse of the gate-folding below, which goes from circuit to \
tableau, and it is the workhorse behind code encoders: a code state's \
preparation circuit is exactly its encoding circuit.\
\>", "Text",ExpressionUUID->"51682be8-de0b-4a35-a242-98f9dafb70ee"],

Cell[TextData[{
 "For long Clifford circuits the framework folds the entire gate list through \
a single compiled (C) kernel that operates on a bit-packed, generator-major \
tableau, the same data layout the specialized simulators use. Handing the \
whole gate list to ",
 Cell[BoxData[
  RowBox[{"ps", "[", "gates", "]"}]], "InlineFormula",ExpressionUUID->
  "dcc06069-8da5-4e21-8b3f-d0b860a999f8"],
 " folds it in one such pass. First build a four-thousand-gate random \
Clifford stream on two hundred qubits (kept suppressed, since it is four \
thousand gate specs):"
}], "Text",ExpressionUUID->"aef5234b-5d0c-46a5-9d79-c1af401f84a4"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"SeedRandom", "[", "1", "]"}], ";"}], "\n", 
 RowBox[{
  RowBox[{"specs", " ", "=", " ", 
   RowBox[{"Table", "[", "\n", "   ", 
    RowBox[{
     RowBox[{"RandomChoice", "[", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"\"\<H\>\"", " ", "->", " ", 
         RowBox[{"RandomInteger", "[", 
          RowBox[{"{", 
           RowBox[{"1", ",", " ", "200"}], "}"}], "]"}]}], ",", " ", 
        RowBox[{"\"\<S\>\"", " ", "->", " ", 
         RowBox[{"RandomInteger", "[", 
          RowBox[{"{", 
           RowBox[{"1", ",", " ", "200"}], "}"}], "]"}]}], ",", "\n", "     ", 
        RowBox[{"\"\<CNOT\>\"", " ", "->", " ", 
         RowBox[{"RandomSample", "[", 
          RowBox[{
           RowBox[{"Range", "[", "200", "]"}], ",", " ", "2"}], "]"}]}]}], 
       "}"}], "]"}], ",", "\n", "   ", 
     RowBox[{"{", "4000", "}"}]}], "]"}]}], ";"}]}], "Input",
 CellLabel->
  "In[60]:= ",ExpressionUUID->"edcd8512-c1f8-4347-bee9-83641ec26346"],

Cell["then fold it and watch the wall-clock:", "Text",ExpressionUUID->"924a130b-5e85-4737-a11d-c3d4cbb40a5d"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"AbsoluteTiming", "[", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"PauliStabilizer", "[", "200", "]"}], "[", "specs", "]"}], 
    "[", "\"\<Stabilizers\>\"", "]"}], "[", 
   RowBox[{"[", "1", "]"}], "]"}], "]"}]], "Input",
 CellLabel->
  "In[61]:= ",ExpressionUUID->"bd5af8d4-de50-4294-8d09-30c428046594"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
  "0.034515`", 
   ",", "\<\"-\
XYIYZIIZZIXIIZZIYZIZIXYXIXYIXYZZXYXXYIIZZXIXXYIZXYIZYIXIYZZYIIXXZIIXXZYYYZZIXY\
ZIYZIXIYYYYZIXXXYXZZXXXZIIXZIIIIZXYYYXXYXXYXIXXZIZYIXZZXYZZIYIXZXXXIIXZXIYZZYI\
XIXZXXIIZIYIYXIIXIYXYZYZYIXZYIIZXIYIIZIZXZIZ\"\>"}], "}"}]], "Output",
 CellLabel->
  "Out[61]= ",ExpressionUUID->"780754b3-52f3-418d-ac67-a18ce58b4d98"]
}, Open  ]],

Cell[TextData[{
 "That is roughly a quarter of a microsecond per gate, flat in the number of \
qubits, because each gate touches only the machine words of its own column. \
The same engine backs the circuit object: a ",
 Cell[BoxData[
 "QuantumCircuitOperator"], "InlineFormula",ExpressionUUID->
  "8b7e1040-99e5-4a25-a359-797c84e7cf38"],
 " applied with ",
 Cell[BoxData[
  RowBox[{"Method", " ", "->", " ", "\"\<Stabilizer\>\""}]], "InlineFormula",
  ExpressionUUID->"316211fc-07c0-4c23-bc0b-b3657aed5467"],
 " evolves a stabilizer state directly. Build a Bell circuit:"
}], "Text",ExpressionUUID->"0d951f81-6ad6-42dc-a879-31d116112b94"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"qc", " ", "=", " ", 
  RowBox[{"QuantumCircuitOperator", "[", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"\"\<H\>\"", " ", "->", " ", "1"}], ",", " ", 
     RowBox[{"\"\<CNOT\>\"", " ", "->", " ", 
      RowBox[{"{", 
       RowBox[{"1", ",", " ", "2"}], "}"}]}]}], "}"}], "]"}]}]], "Input",
 CellLabel->
  "In[62]:= ",ExpressionUUID->"c4b05f54-092b-4172-9909-f39ebb19e47d"],

