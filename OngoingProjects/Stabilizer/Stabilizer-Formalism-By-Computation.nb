Cell["Its generators now carry the formal outcome in a sign:", "Text",ExpressionUUID->"b18dcee7-0fbd-4384-aa06-d73878f6130f"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"sm", "[", "\"\<Stabilizers\>\"", "]"}]], "Input",
 CellLabel->
  "In[49]:= ",ExpressionUUID->"ec49e62a-4340-49be-853c-04a3571e9f9e"],

