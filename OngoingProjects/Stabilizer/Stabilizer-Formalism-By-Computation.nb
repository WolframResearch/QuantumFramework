Cell[TextData[{
 "Its amplitudes match the Schr\[ODoubleDot]dinger answer up to a global \
phase, here a factor of ",
 Cell[BoxData[
  StyleBox["i", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "e2a1b9f3-d237-4396-af70-a8c3f660dc87"],
 ":"
}], "Text",ExpressionUUID->"574ab825-3c24-4d7b-be3f-3cfafabe1086"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"psiStabilizer", "[", "\"\<StateVector\>\"", "]"}], " ", "//", " ", 
  "Normal"}]], "Input",
 CellLabel->
  "In[33]:= ",ExpressionUUID->"68cc4f00-b541-4a8c-a3a1-82231569daf9"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{"-", 
    FractionBox["\[ImaginaryI]", 
     SqrtBox["2"]]}], ",", "0", ",", "0", ",", "0", ",", "0", ",", "0", ",", 
   "0", ",", 
   FractionBox["1", 
    SqrtBox["2"]]}], "}"}]], "Output",
 CellLabel->
  "Out[33]= ",ExpressionUUID->"8d820039-591f-4479-a311-c099808a7e55"]
}, Open  ]],

Cell[TextData[{
 "Rather than chase that phase by hand, compare the two states with the \
framework's ",
 Cell[BoxData[
 "QuantumSimilarity"], "InlineFormula",ExpressionUUID->
  "b3ea33d4-a4ff-4df5-a3cf-b64a165f0698"],
 ", which is one exactly when they agree up to a global phase:"
}], "Text",ExpressionUUID->"3f1419cb-80a0-41e5-a915-9e6bbd8baa60"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"QuantumSimilarity", "[", 
  RowBox[{"psiSchrodinger", ",", " ", "psiStabilizer"}], "]"}]], "Input",
 CellLabel->
  "In[34]:= ",ExpressionUUID->"263c5085-5e03-44f1-90e2-285af1ba8dca"],

Cell[BoxData["1"], "Output",
 CellLabel->
  "Out[34]= ",ExpressionUUID->"fcbd8ac4-e99e-4a35-a2e4-3a865e2ae26f"]
}, Open  ]],

Cell[TextData[{
 "This is the Gottesman-Knill theorem made concrete: a Clifford circuit on a \
stabilizer input is simulated by propagating ",
 Cell[BoxData[
  StyleBox["n", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "52f06388-7446-4e06-901b-c52200df0afc"],
 " generators at ",
 Cell[BoxData[
  RowBox[{
   StyleBox["O", "TI"], 
   StyleBox["(",
    SpanMaxSize->1], 
   StyleBox["n", "TI"], 
   StyleBox[")",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "44ff1cde-8b4c-41d4-b2ec-a216db6b9929"],
 " work per gate, and the state it computes is exactly the one Schr\
\[ODoubleDot]dinger evolution would, with the ",
 Cell[BoxData[
  SuperscriptBox["2", 
   StyleBox["n", "TI"]]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "9d4b9b4a-9a61-423e-b1f2-964a06bf296d"],
 " vector never formed except, here, to check."
}], "Text",ExpressionUUID->"0ea66f70-54e0-4c77-b8f5-0fdc4616ffa7"],

Cell[TextData[{
 "The construction rests entirely on Clifford conjugation keeping a Pauli a \
Pauli, so it is also clear where it must break. A non-Clifford gate does not \
respect the Pauli group. The ",
 Cell[BoxData[
  StyleBox["T", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "d314c199-3519-4fa8-aa59-570bb2220521"],
 " gate commutes with ",
 Cell[BoxData[
  StyleBox["Z", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "39682142-e74e-4333-9a40-284b66df29f8"],
 ", but conjugating ",
 Cell[BoxData[
  StyleBox["X", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "9aefbef7-dbe3-4eb1-905f-af4e640d66e1"],
 " by it gives a sum. The conjugation ",
 Cell[BoxData[
  RowBox[{
   StyleBox["T", "TI"], 
   StyleBox["X", "TI"], 
   SuperscriptBox[
    StyleBox["T", "TI"], "\[Dagger]"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "95aceb66-17e1-42fb-aa4e-e490bd85573a"],
 " is cleanest as the circuit ",
 Cell[BoxData[
  RowBox[{
   RowBox[{"{", 
    SuperscriptBox[
     StyleBox["T", "TI"], "\[Dagger]"]}], 
   RowBox[{",", "\[ThinSpace]"}], 
   StyleBox["X", "TI"], 
   RowBox[{",", "\[ThinSpace]"}], 
   RowBox[{
    StyleBox["T", "TI"], "}"}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "75ba6988-62b8-41c1-83e9-cfb73b7647ab"],
 " decomposed into Paulis:"
}], "Text",ExpressionUUID->"40491c2b-e970-48aa-bcde-edbe050efc5b"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"ExpToTrig", " ", "@", " ", 
  RowBox[{
   RowBox[{"QuantumCircuitOperator", "[", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"SuperDagger", "[", "\"\<T\>\"", "]"}], ",", " ", "\"\<X\>\"", ",",
       " ", "\"\<T\>\""}], "}"}], "]"}], "[", "\"\<PauliDecompose\>\"", 
   "]"}]}]], "Input",
 CellLabel->
  "In[35]:= ",ExpressionUUID->"54448dee-dec5-4601-b7c2-8bc35a65a05c"],

Cell[BoxData[
 RowBox[{"\[LeftAssociation]", 
  RowBox[{
   RowBox[{"\<\"X\"\>", "\[Rule]", 
    FractionBox["1", 
     SqrtBox["2"]]}], ",", 
   RowBox[{"\<\"Y\"\>", "\[Rule]", 
    FractionBox["1", 
     SqrtBox["2"]]}]}], "\[RightAssociation]"}]], "Output",
 CellLabel->
  "Out[35]= ",ExpressionUUID->"dbc33d3b-8d01-4265-8d27-6b0584fd4faf"]
}, Open  ]],

Cell[TextData[{
 "Here ",
 Cell[BoxData[
  RowBox[{
   StyleBox["T", "TI"], 
   StyleBox["X", "TI"], 
   SuperscriptBox[
    StyleBox["T", "TI"], "\[Dagger]"], "=", 
   StyleBox["(",
    SpanMaxSize->1], 
   RowBox[{
    StyleBox["X", "TI"], "+", 
    StyleBox["Y", "TI"]}], 
   StyleBox[")",
    SpanMaxSize->1], "/", 
   SqrtBox["2"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "14ab896a-a9d8-4cf5-8f20-2eaf44cfb24b"],
 " has two terms, not one. A single generator no longer maps to a single \
generator, the group stops being generated by ",
 Cell[BoxData[
  StyleBox["n", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "a4a1ed3f-585d-493b-a525-5b8ebf795f93"],
 " Pauli strings, and the cheap representation fails. That failure is not an \
accident of implementation but the edge of the classically tractable world; \
the frontier section returns to how far one can push past it with stabilizer \
frames."
}], "Text",ExpressionUUID->"2b3629df-a0e7-412b-9de0-6e0ea7db8861"],

Cell["Entanglement for free: Bell and GHZ", "Section",ExpressionUUID->"a30fecc1-d6b4-4676-a884-95ba43f87489"],

Cell[TextData[{
 "Entangled states are not special in this language; they are simply \
stabilizer groups whose generators are not single-qubit operators. The Bell \
state ",
 Cell[BoxData[
  TemplateBox[{
    SuperscriptBox["\[CapitalPhi]", "+"]},
   "Ket"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "4402ce88-c90d-40c9-ad0f-def4f5a7b37d"],
 " is prepared from ",
 Cell[BoxData[
  TemplateBox[{"00"},
   "Ket"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "fa1580b1-38b5-48f8-b5d0-97e14ceeb8f7"],
 " by a Hadamard and a CNOT, and its stabilizer group is generated by ",
 Cell[BoxData[
  StyleBox[
   RowBox[{"X", "X"}], "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "ee7629a2-9b3a-445b-8501-6bf759cd7578"],
 " and ",
 Cell[BoxData[
  StyleBox[
   RowBox[{"Z", "Z"}], "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "4fb1fcd3-cd6b-43fd-bcdc-8dbc5dc506c1"],
 "."
}], "Text",ExpressionUUID->"380b90cc-d055-487f-819e-99f3fc839381"],

Cell["Build the Bell state:", "Text",ExpressionUUID->"58ee5d63-7f10-4301-985b-0bd2280695c9"],

