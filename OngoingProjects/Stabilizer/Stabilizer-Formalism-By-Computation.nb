}, Open  ]],

Cell[TextData[{
 "The stabilizer flips from ",
 Cell[BoxData[
  StyleBox["Z", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "0aa5e59a-b6a7-46e1-a7ef-a38ae44f7f50"],
 " to ",
 Cell[BoxData[
  StyleBox["X", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "7d5b286a-5520-49d4-8045-98525e91516e"],
 ", the signature of ",
 Cell[BoxData[
  TemplateBox[{"+"},
   "Ket"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "2e190cb5-d1fb-4524-8023-0a362522a7cc"],
 ". The state vector confirms it:"
}], "Text",ExpressionUUID->"239aab85-b8d5-4383-9493-5a80867b7469"],

