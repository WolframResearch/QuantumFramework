Cell[TextData[{
 "What comes back is an ordinary ",
 Cell[BoxData[
 "QuantumState"], "InlineFormula",ExpressionUUID->
  "e9c8861d-a0a5-45a9-af96-6280898c2828"],
 " object, so a stabilizer state drops straight into the rest of the \
framework. Chaining ",
 Cell[BoxData["\"\<StateVector\>\""], "InlineFormula",ExpressionUUID->
  "9d21aed8-1fdb-4b37-89c3-dbc668ca798a"],
 " on that object reads off the raw ",
 Cell[BoxData[
  SuperscriptBox["2", 
   StyleBox["n", "TI"]]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "5657df0c-d126-4286-902d-2b9224eb78f3"],
 " amplitudes, here the single column ",
 Cell[BoxData[
  TemplateBox[{"0"},
   "Ket"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "eac72e32-4c79-4198-bb7d-44b756bea2ba"],
 ":"
}], "Text",ExpressionUUID->"83bd4c56-1d8f-4058-a35d-fc44b2b1a984"],

