}, Open  ]],

Cell[TextData[{
 "The two pictures must describe the same physics, and they do. Materialize \
the state from the final generators (the formalism's ",
 Cell[BoxData["\"\<State\>\""], "InlineFormula",ExpressionUUID->
  "2910987e-c3b9-4405-bf4e-c4a5edd52add"],
 "):"
}], "Text",ExpressionUUID->"c7d899f3-1b76-42f9-af6c-54c4153ce0e9"],

