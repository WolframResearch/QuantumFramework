Cell[TextData[{
 "The answer is the single Pauli string ",
 Cell[BoxData["\"\<Z\>\""], "InlineFormula",ExpressionUUID->
  "f981dec5-0449-4e51-bdd1-71cf74153bf5"],
 ", exactly as the chalkboard argument predicted. The ",
 Cell[BoxData["\"\<State\>\""], "InlineFormula",ExpressionUUID->
  "8b665d85-a091-461c-ba02-67836f5c85e1"],
 " property is the bridge back to the rest of the framework: it materializes \
the stabilizer object into a full ",
 Cell[BoxData[
 "QuantumState"], "InlineFormula",ExpressionUUID->
  "684ec646-3606-4309-8409-e4bc6a636e03"],
 ", at the cost of the ",
 Cell[BoxData[
  SuperscriptBox["2", 
   StyleBox["n", "TI"]]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "fc6bf93f-4b09-4758-9950-2d0944cd0205"],
 " blow-up the formalism exists to avoid."
}], "Text",ExpressionUUID->"c0a98a21-9fad-4e28-84a4-ca04f8cf9684"],

