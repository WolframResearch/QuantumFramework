             GridBoxAlignment -> {
              "Columns" -> {{Left}}, "Rows" -> {{Automatic}}}, AutoDelete -> 
             False, GridBoxItemSize -> {
              "Columns" -> {{Automatic}}, "Rows" -> {{Automatic}}}, 
             GridBoxSpacings -> {"Columns" -> {{2}}, "Rows" -> {{Automatic}}},
              BaseStyle -> {
              ShowStringCharacters -> False, NumberMarks -> False, 
               PrintPrecision -> 3, ShowSyntaxStyles -> False}]}}, 
          GridBoxAlignment -> {"Columns" -> {{Left}}, "Rows" -> {{Top}}}, 
          AutoDelete -> False, 
          GridBoxItemSize -> {
           "Columns" -> {{Automatic}}, "Rows" -> {{Automatic}}}, 
          BaselinePosition -> {1, 1}]}, 
       Dynamic[Typeset`open$$], ImageSize -> Automatic]},
     "SummaryPanel"],
    DynamicModuleValues:>{}], "]"}],
  Wolfram`QuantumFramework`PauliStabilizer[<|
   "Signs" -> {1, 1}, "Tableau" -> {{{1, 0}}, {{0, 1}}}|>],
  Editable->False,
  SelectWithContents->True,
  Selectable->False]], "Output",
 CellLabel->"Out[4]= ",ExpressionUUID->"1ae40bd4-3001-478c-b066-de7777723139"]
}, Open  ]],

Cell[TextData[{
 "We read off the operator that stabilizes it with the ",
 Cell[BoxData["\"\<Stabilizers\>\""], "InlineFormula",ExpressionUUID->
  "aee2ac6d-6b7b-4dd8-b8e9-1d001cd40245"],
 " property:"
}], "Text",ExpressionUUID->"f0679ab5-8ada-4b53-b1f6-1c9c5b4badeb"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"PauliStabilizer", "[", "1", "]"}], "[", "\"\<Stabilizers\>\"", 
  "]"}]], "Input",
 CellLabel->"In[5]:= ",ExpressionUUID->"b13f2983-575e-4a19-b2b9-1c7da65de9c1"],

Cell[BoxData[
 RowBox[{"{", "\<\"Z\"\>", "}"}]], "Output",
 CellLabel->"Out[5]= ",ExpressionUUID->"c88d66dd-a5a9-4479-965c-598c0f0e6b5c"]
}, Open  ]],

Cell[TextData[{
 "The answer is the single Pauli string ",
 Cell[BoxData["\"\<Z\>\""], "InlineFormula",ExpressionUUID->
  "500351e7-0318-4e59-a2ad-4c97c1b42379"],
 ", exactly as the chalkboard argument predicted. We can always materialize \
the underlying state vector to check ourselves, at the cost of the ",
 Cell[BoxData[
  SuperscriptBox["2", 
   StyleBox["n", "TI"]]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "c583f1c7-2964-44dc-b6b0-83af3e4633cc"],
 " blow-up the formalism exists to avoid:"
}], "Text",ExpressionUUID->"2d1d5bbf-72fb-479b-bd13-d8ad55f18d3d"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"PauliStabilizer", "[", "1", "]"}], "[", "\"\<State\>\"", "]"}], 
   "[", "\"\<StateVector\>\"", "]"}], " ", "//", " ", "Normal"}]], "Input",
 CellLabel->"In[6]:= ",ExpressionUUID->"6f8369d2-c6e7-4cab-82af-9b7418387d20"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"1", ",", "0"}], "}"}]], "Output",
 CellLabel->"Out[6]= ",ExpressionUUID->"b570f65b-7d4b-4e07-a01e-81ccfcef8f08"]
}, Open  ]],

Cell[TextData[{
 "Different states are fixed by different operators. The state ",
 Cell[BoxData[
  RowBox[{
   TemplateBox[{"+"},
    "Ket"], "=", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{
      TemplateBox[{"0"},
       "Ket"], "+", 
      TemplateBox[{"1"},
       "Ket"]}], ")"}], "/", 
    SqrtBox["2"]}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "0048b711-dc23-4afd-9f4f-dacf52541515"],
 " is the ",
 Cell[BoxData[
  RowBox[{"+", "1"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "1c9e96af-ae7f-4c23-b0e0-100c9b4ed2d8"],
 " eigenstate of ",
 Cell[BoxData[
  StyleBox["X", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "1302e377-a927-4bcb-840e-0cbabc72279c"],
 ", and a Hadamard turns one into the other. Apply ",
 Cell[BoxData[
  StyleBox["H", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "7b1f2623-2d2f-46f9-aef1-bd4e23d0d5da"],
 " to ",
 Cell[BoxData[
  TemplateBox[{"0"},
   "Ket"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "650ea071-085e-41a1-8b9b-10d0bcd826f3"],
 " and read the new stabilizer:"
}], "Text",ExpressionUUID->"512a4dc9-af0a-47bc-b356-6fedf8fb121f"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"PauliStabilizer", "[", "1", "]"}], "[", 
   RowBox[{"\"\<H\>\"", ",", " ", "1"}], "]"}], "[", "\"\<Stabilizers\>\"", 
  "]"}]], "Input",
 CellLabel->"In[7]:= ",ExpressionUUID->"000534be-7532-4377-9e18-70fe5e5dcd88"],

Cell[BoxData[
 RowBox[{"{", "\<\"X\"\>", "}"}]], "Output",
 CellLabel->"Out[7]= ",ExpressionUUID->"d4635505-e5cb-4996-8382-c5280f085e51"]
}, Open  ]],

Cell[TextData[{
 "The stabilizer flips from ",
 Cell[BoxData[
  StyleBox["Z", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "bfb4d9a9-f35a-49a6-a3dc-ff763de54483"],
 " to ",
 Cell[BoxData[
  StyleBox["X", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "705a00aa-c07c-4391-b34f-7424ec1448bb"],
 ", the signature of ",
 Cell[BoxData[
  TemplateBox[{"+"},
   "Ket"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "1c434ab9-fa43-47e5-ac65-55205fc8f69b"],
 ". The state vector confirms it:"
}], "Text",ExpressionUUID->"f746dcc2-cec9-4a8b-b326-48ef5bcb8f89"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"PauliStabilizer", "[", "1", "]"}], "[", 
     RowBox[{"\"\<H\>\"", ",", " ", "1"}], "]"}], "[", "\"\<State\>\"", "]"}],
    "[", "\"\<StateVector\>\"", "]"}], " ", "//", " ", "Normal"}]], "Input",
 CellLabel->"In[8]:= ",ExpressionUUID->"9d9e7bdb-fd59-460a-8a98-d27678762fd7"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   FractionBox["1", 
    SqrtBox["2"]], ",", 
   FractionBox["1", 
    SqrtBox["2"]]}], "}"}]], "Output",
 CellLabel->"Out[8]= ",ExpressionUUID->"5d95c93d-d8b9-4726-841d-f0ba1191f705"]
}, Open  ]],

Cell[TextData[{
 "A short word of honesty that will matter later. The tableau tracks the \
stabilizer group, including the signs, but it is blind to the ",
 StyleBox["overall", "TI"],
 " phase of the state. Reconstructing a state vector from a gate-updated \
tableau is therefore exact only up to a global phase. You can see this by \
acting with ",
 Cell[BoxData[
  StyleBox["Z", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "ce4fad67-6c14-4532-96f8-3d598da12499"],
 " on ",
 Cell[BoxData[
  TemplateBox[{"+"},
   "Ket"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "43a01a4c-6154-4903-81af-d8e6c5030c55"],
 ": physically ",
 Cell[BoxData[
  RowBox[{
   RowBox[{
    StyleBox["Z", "TI"], 
    TemplateBox[{"+"},
     "Ket"]}], "=", 
   TemplateBox[{"-"},
    "Ket"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "fc3272be-d611-4c62-b282-48d3da0af19a"],
 ", and the framework returns ",
 Cell[BoxData[
  TemplateBox[{"-"},
   "Ket"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "a525b98b-43ae-4d5e-ac3e-65fa405c958e"],
 " up to an overall sign."
}], "Text",ExpressionUUID->"6aea6f5c-dc02-4f14-a7ce-74e77e78b12b"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{"PauliStabilizer", "[", "1", "]"}], "[", 
      RowBox[{"\"\<H\>\"", ",", " ", "1"}], "]"}], "[", 
     RowBox[{"\"\<Z\>\"", ",", " ", "1"}], "]"}], "[", "\"\<State\>\"", "]"}],
    "[", "\"\<StateVector\>\"", "]"}], " ", "//", " ", "Normal"}]], "Input",
 CellLabel->"In[9]:= ",ExpressionUUID->"41514436-c538-4951-afc1-ae822c7a6af2"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{"-", 
    FractionBox["1", 
     SqrtBox["2"]]}], ",", 
   FractionBox["1", 
    SqrtBox["2"]]}], "}"}]], "Output",
 CellLabel->"Out[9]= ",ExpressionUUID->"d975f2bc-940e-4d79-b19a-1d4a27f24328"]
}, Open  ]],

Cell["\<\
For everything observable, probabilities, expectation values, entanglement, \
the global phase is irrelevant, so this costs us nothing in practice. We flag \
it now because it is the one place where the cheap representation is \
genuinely less informative than the dense one.\
\>", "Text",ExpressionUUID->"fec102e6-2f23-4b4f-9915-db64e647250e"],

Cell[TextData[{
 "Finally, \"being a stabilizer state\" is a decidable property of an object, \
not of a raw vector. The predicate [",
 Cell[BoxData[
 "StabilizerStateQ"], "InlineFormula",ExpressionUUID->
  "78e6acc7-a14e-41d1-9be8-134960948b8c"],
 "] answers ",
 Cell[BoxData[
 "True"], "InlineFormula",ExpressionUUID->
  "533cbb33-a0c0-4044-bc41-4ae37cd09b0c"],
 " for a ",
 Cell[BoxData[
 "PauliStabilizer"], "InlineFormula",ExpressionUUID->
  "df3e9622-b952-479c-831a-427ce0e4ba68"],
 " and declines a bare ",
 Cell[BoxData[
 "QuantumState"], "InlineFormula",ExpressionUUID->
  "ffc2487e-defc-49d8-ad4c-3011c7b646b7"],
 ", because deciding stabilizer-ness from amplitudes alone requires ",
 Cell[BoxData[
  SuperscriptBox["4", 
   StyleBox["n", "TI"]]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "9c1dff29-e933-4c84-b86a-46a94b8b7b25"],
 " tomography:"
}], "Text",ExpressionUUID->"309c532d-7a7d-445b-8e3e-ffade3aeb07d"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{"StabilizerStateQ", "[", 
    RowBox[{"PauliStabilizer", "[", "1", "]"}], "]"}], ",", " ", 
   RowBox[{"StabilizerStateQ", "[", 
    RowBox[{"QuantumState", "[", "\"\<+\>\"", "]"}], "]"}]}], "}"}]], "Input",\

 CellLabel->
  "In[10]:= ",ExpressionUUID->"eac5c948-6fbe-4129-b394-35783b4af076"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"True", ",", "False"}], "}"}]], "Output",
 CellLabel->
  "Out[10]= ",ExpressionUUID->"21f119ff-e0b4-4c84-8ccc-070ff5512259"]
}, Open  ]],

Cell["Before moving on, the essentials so far:", "Text",ExpressionUUID->"5f736da5-3d71-4d54-a7eb-d88f407834b6"],

Cell[TextData[{
 "A one-qubit stabilizer state is named by the single Pauli operator that \
fixes it: ",
 Cell[BoxData[
  StyleBox["Z", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "d1a4cbd7-fb9a-4677-8867-f18f61d5819e"],
 " for ",
 Cell[BoxData[
  TemplateBox[{"0"},
   "Ket"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "7a2c3e69-1776-4c7a-93f5-5f237e1c009f"],
 ", ",
 Cell[BoxData[
  StyleBox["X", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "18baf77e-edde-48c6-9608-b25af9938569"],
 " for ",
 Cell[BoxData[
  TemplateBox[{"+"},
   "Ket"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "32232f6f-e6ed-43d4-be95-adfc333c816a"],
 ", ",
 Cell[BoxData[
  RowBox[{"-", 
   StyleBox["Z", "TI"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "0051bdca-c7b0-4c80-812b-a54bd78ae86b"],
 " for ",
 Cell[BoxData[
  TemplateBox[{"1"},
   "Ket"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "a00b654e-69cf-404e-a8e2-ef684c02aed1"],
 "."
}], "Item",ExpressionUUID->"3bb4f0e4-625b-49ed-b802-d6f78e12a7da"],

Cell[TextData[{
 Cell[BoxData[
 "PauliStabilizer"], "InlineFormula",ExpressionUUID->
  "5b694d08-7d57-4927-8d3e-ba6179199177"],
 " carries that operator, not the amplitudes; ",
 Cell[BoxData["\"\<State\>\""], "InlineFormula",ExpressionUUID->
  "dd9e71d2-93ac-4fd2-87ec-7ec5fc63506c"],
 " materializes the vector on demand."
}], "Item",ExpressionUUID->"3e28f1e1-5436-4b16-bf15-4b7fbabd1351"],

Cell["\<\
The reconstructed vector is exact up to a global phase, which never affects \
an observable.\
\>", "Item",ExpressionUUID->"3b81ded4-830d-4b26-9865-ab9484bd26c0"],

Cell[TextData[{
 "The tableau: ",
 Cell[BoxData[
  StyleBox["n", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "079376cd-06cd-4b8b-a206-19bf0017eb74"],
 " generators instead of ",
 Cell[BoxData[
  SuperscriptBox["2", 
   StyleBox["n", "TI"]]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "30ee1b59-6ebb-4de9-9d38-1a8b2ca3ef53"],
 " amplitudes"
}], "Section",ExpressionUUID->"5bc11986-5011-47c4-a31b-1bac7322cc32"],

Cell[TextData[{
 "For ",
 Cell[BoxData[
  StyleBox["n", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "fcaba505-0d9f-4827-b096-05649ef108ca"],
 " qubits the idea scales because the stabilizer group is generated by just \
",
 Cell[BoxData[
  StyleBox["n", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "06eac813-7aa8-42c5-a17d-8727a718bfe0"],
 " commuting, independent Pauli strings, and each Pauli string of length ",
 Cell[BoxData[
  StyleBox["n", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "c50c8de5-27e3-4afd-b0e8-9bcacc0e173c"],
 " is two bits per qubit: an ",
 Cell[BoxData[
  StyleBox["X", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "640f6cac-376d-48e2-858b-5517df89f0fa"],
 "-exponent and a ",
 Cell[BoxData[
  StyleBox["Z", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "603ea7b2-6ef6-422c-9713-9fc034968a46"],
 "-exponent, since ",
 Cell[BoxData[
  RowBox[{
   StyleBox["Y", "TI"], "=", 
   StyleBox["i", "TI"], 
   StyleBox["X", "TI"], 
   StyleBox["Z", "TI"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "5b26e642-90f5-4659-a9a5-4d9de6cc6c79"],
 ". So a stabilizer state is a binary matrix of shape ",
 Cell[BoxData[
  RowBox[{
   StyleBox["n", "TI"], "\[Times]", "2", 
   StyleBox["n", "TI"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "14821e3f-df08-4efd-9031-5e348e66c780"],
 " together with ",
 Cell[BoxData[
  StyleBox["n", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "b02e4940-61e3-4b66-a77b-17cd3764c176"],
 " signs, which is ",
 Cell[BoxData[
  RowBox[{
   StyleBox["O", "TI"], 
   StyleBox["(",
    SpanMaxSize->1], 
   SuperscriptBox[
    StyleBox["n", "TI"], "2"], 
   StyleBox[")",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "d94b9938-5447-42b4-9a6b-068f2aa2c811"],
 " bits in place of ",
 Cell[BoxData[
  SuperscriptBox["2", 
   StyleBox["n", "TI"]]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "ec51ca25-361a-4514-855b-c5d5dfccce9f"],
 " amplitudes. This binary ",
 Cell[BoxData[
  RowBox[{
   StyleBox["(",
    SpanMaxSize->1], 
   RowBox[{
    StyleBox["X", "TI"], "\[VerticalSeparator]", 
    StyleBox["Z", "TI"]}], 
   StyleBox[")",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "b5d22947-81fc-48a2-85b8-300f95a0d9fc"],
 " encoding is the ",
 StyleBox["symplectic representation", "TI"],
 " of the Pauli group."
}], "Text",ExpressionUUID->"050836e0-124f-43a5-a0e8-f564331a8720"],

Cell[TextData[{
 "Look at the two-qubit register ",
 Cell[BoxData[
  TemplateBox[{"00"},
   "Ket"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "3af62160-acfc-49ec-8d8d-663836b65b77"],
 ". The object itself previews the generators and a tableau grid:"
}], "Text",ExpressionUUID->"d8285cde-b106-4f41-a421-a519dc120aa3"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"PauliStabilizer", "[", "2", "]"}]], "Input",
 CellLabel->
  "In[11]:= ",ExpressionUUID->"3926fd09-d1b7-4a61-8346-d4da59ebfd9c"],

