Cell[TextData[{
 "Quench the product state ",
 Cell[BoxData[
  RowBox[{"\[LeftBracketingBar]", "01", 
   AdjustmentBox["\[RightAngleBracket]",
    BoxMargins->{{-0.2, 0}, {0, 0}}]}]], "InlineFormula",ExpressionUUID->
  "d8bbf91c-63d1-4be8-ace5-c6df3b70db90"],
 " under it and display the state at time ",
 Cell[BoxData[
  StyleBox["t", "TI"]], "InlineFormula",ExpressionUUID->
  "b66dee43-f989-4f08-a2bd-d22a8c11eebc"],
 ":"
}], "Text",ExpressionUUID->"f5dedeb5-00f8-48f7-91fc-1dcc2e01912e"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"st", " ", "=", " ", 
   RowBox[{"QuantumEvolve", "[", 
    RowBox[{"H", ",", " ", 
     RowBox[{"QuantumState", "[", "\"\<01\>\"", "]"}]}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"FullSimplify", "[", "st", "]"}], " ", "//", " ", 
  "TraditionalForm"}]}], "Input",
 CellLabel->
  "In[218]:=",ExpressionUUID->"b3597386-0e2c-4b28-ad61-8ff328541352"],

Cell[BoxData[
 FormBox[
  InterpretationBox[
   TooltipBox[
    StyleBox[
     RowBox[{
      RowBox[{
       SuperscriptBox["\[ExponentialE]", 
        RowBox[{"\[ImaginaryI]", " ", "J", " ", "\[FormalT]"}]], " ", 
       RowBox[{"cos", "(", 
        RowBox[{"2", " ", "J", " ", "\[FormalT]"}], ")"}]}], 
      FormBox[
       InterpretationBox[
        StyleBox[
         TemplateBox[{
           RowBox[{
             FormBox["0", TraditionalForm], "\[InvisibleSpace]", 
             FormBox["1", TraditionalForm]}]},
          "Ket"],
         FontWeight->"Plain"],
        Wolfram`QuantumFramework`QuditName[{0, 1}, "Dual" -> False]],
       TraditionalForm], 
      RowBox[{
       RowBox[{"-", "\[ImaginaryI]"}], " ", 
       SuperscriptBox["\[ExponentialE]", 
        RowBox[{"\[ImaginaryI]", " ", "J", " ", "\[FormalT]"}]], " ", 
       RowBox[{"sin", "(", 
        RowBox[{"2", " ", "J", " ", "\[FormalT]"}], ")"}]}], 
      FormBox[
       InterpretationBox[
        StyleBox[
         TemplateBox[{
           RowBox[{
             FormBox["1", TraditionalForm], "\[InvisibleSpace]", 
             FormBox["0", TraditionalForm]}]},
          "Ket"],
         FontWeight->"Plain"],
        Wolfram`QuantumFramework`QuditName[{1, 0}, "Dual" -> False]],
       TraditionalForm]}],
     ShowStringCharacters->False],
    TagBox[
     GridBox[{{
        RowBox[{"J", " ", 
          RowBox[{"(", 
            RowBox[{
              TemplateBox[{"\"X\"", 
                RowBox[{"\[CircleTimes]", "2"}]}, "Superscript", SyntaxForm -> 
               SuperscriptBox], "+", 
              TemplateBox[{"\"Y\"", 
                RowBox[{"\[CircleTimes]", "2"}]}, "Superscript", SyntaxForm -> 
               SuperscriptBox], "+", 
              TemplateBox[{"\"Z\"", 
                RowBox[{"\[CircleTimes]", "2"}]}, "Superscript", SyntaxForm -> 
               SuperscriptBox]}], ")"}]}]}, {
        TemplateBox[{"\"QuantumState: \"", 
          RowBox[{
            RowBox[{"{", "}"}], "\[Rule]", 
            RowBox[{"{", 
              RowBox[{"2", ",", "2"}], "}"}]}]}, "RowDefault"]}}, 
      GridBoxAlignment -> {"Columns" -> {{Center}}}, DefaultBaseStyle -> 
      "Column", 
      GridBoxItemSize -> {
       "Columns" -> {{Automatic}}, "Rows" -> {{Automatic}}}], "Column"]],
   Wolfram`QuantumFramework`QuantumState[
   SparseArray[
    Automatic, {4}, 0, {
     1, {{0, 2}, {{2}, {3}}}, {
      E^(Complex[0, 1] \[FormalT] $CellContext`J) 
       Cos[2 \[FormalT] $CellContext`J], Complex[0, -1] 
       E^(Complex[0, 1] \[FormalT] $CellContext`J) 
       Sin[2 \[FormalT] $CellContext`J]}}], 
    Wolfram`QuantumFramework`QuantumBasis[<|
     "Input" -> Wolfram`QuantumFramework`QuditBasis[<|{
           
           Wolfram`QuantumFramework`QuditName[\[FormalCapitalI], "Dual" -> 
            False], 1} -> 1|>], "Output" -> 
      Wolfram`QuantumFramework`QuditBasis[<|{
           Wolfram`QuantumFramework`QuditName[0, "Dual" -> False], 1} -> 
         SparseArray[Automatic, {2}, 0, {1, {{0, 1}, {{1}}}, {1}}], {
           Wolfram`QuantumFramework`QuditName[1, "Dual" -> False], 1} -> 
         SparseArray[Automatic, {2}, 0, {1, {{0, 1}, {{2}}}, {1}}], {
           Wolfram`QuantumFramework`QuditName[0, "Dual" -> False], 2} -> 
         SparseArray[Automatic, {2}, 0, {1, {{0, 1}, {{1}}}, {1}}], {
           Wolfram`QuantumFramework`QuditName[1, "Dual" -> False], 2} -> 
         SparseArray[Automatic, {2}, 0, {1, {{0, 1}, {{2}}}, {1}}]|>], 
      "Picture" -> "Schrodinger", 
      "Label" -> $CellContext`J (Superscript["X", 
          CircleTimes[2]] + Superscript["Y", 
          CircleTimes[2]] + Superscript["Z", 
          CircleTimes[2]]), "ParameterSpec" -> {{\[FormalT], 0, 1}}|>]]], 
  TraditionalForm]], "Output",
 CellChangeTimes->{3.990277411810006*^9},
 CellLabel->"Out[219]//TraditionalForm=",
 CellID->1168836365,ExpressionUUID->"d67f2b19-e256-486d-adf0-0cca759e64e9"]
}, Open  ]],

Cell[TextData[{
 "The evolved ket displays in closed form: the excitation oscillates \
coherently between ",
 Cell[BoxData[
  RowBox[{"\[LeftBracketingBar]", "01", 
   AdjustmentBox["\[RightAngleBracket]",
    BoxMargins->{{-0.2, 0}, {0, 0}}]}]], "InlineFormula",ExpressionUUID->
  "bcc4cc05-c049-4339-bc3c-ea0b391a6523"],
 " and ",
 Cell[BoxData[
  RowBox[{"\[LeftBracketingBar]", "10", 
   AdjustmentBox["\[RightAngleBracket]",
    BoxMargins->{{-0.2, 0}, {0, 0}}]}]], "InlineFormula",ExpressionUUID->
  "1f28da48-9834-4d8c-8291-ee306c726ce9"],
 " at angular frequency ",
 Cell[BoxData[
  RowBox[{"2", 
   StyleBox["J", "TI"]}]], "InlineFormula",ExpressionUUID->
  "24276a8f-4dd7-48e4-9051-f630ea5aabc1"],
 ", inside an overall phase ",
 Cell[BoxData[
  SuperscriptBox[
   StyleBox["e", "TI"], 
   StyleBox[
    RowBox[{"i", "J", "t"}], "TI"]]], "InlineFormula",ExpressionUUID->
  "0cf0b916-ef56-4e1f-82c2-0ef773ed71c4"],
 ". Now read off the ",
 StyleBox["entanglement entropy of one qubit as a function of time",
  FontWeight->"Bold"],
 ", a derived, nonlinear quantity:"
}], "Text",ExpressionUUID->"f3a49e22-4e22-48bb-821a-b996a67f5cae"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"s", " ", "=", " ", 
  RowBox[{"FullSimplify", "[", 
   RowBox[{
    RowBox[{
     RowBox[{"QuantumPartialTrace", "[", 
      RowBox[{"st", ",", " ", 
       RowBox[{"{", "2", "}"}]}], "]"}], "[", "\"\<VonNeumannEntropy\>\"", 
     "]"}], ",", " ", 
    RowBox[{
     RowBox[{"\[FormalT]", " ", "J"}], " ", "\[Element]", " ", "Reals"}]}], 
   "]"}]}]], "Input",
 CellLabel->
  "In[220]:=",ExpressionUUID->"ea0b7945-2a2e-47d7-8f9a-3047f4639e0f"],

Cell[BoxData[
 TemplateBox[{
   FractionBox[
    RowBox[{
      RowBox[{
        RowBox[{"-", "2"}], " ", 
        SuperscriptBox[
         RowBox[{"Cos", "[", 
           RowBox[{"2", " ", "\[FormalT]", " ", "J"}], "]"}], "2"], " ", 
        RowBox[{"Log", "[", 
          SuperscriptBox[
           RowBox[{"Cos", "[", 
             RowBox[{"2", " ", "\[FormalT]", " ", "J"}], "]"}], "2"], "]"}]}],
       "+", 
      RowBox[{
        RowBox[{"(", 
          RowBox[{
            RowBox[{"-", "1"}], "+", 
            RowBox[{"Cos", "[", 
              RowBox[{"4", " ", "\[FormalT]", " ", "J"}], "]"}]}], ")"}], " ", 
        RowBox[{"Log", "[", 
          SuperscriptBox[
           RowBox[{"Sin", "[", 
             RowBox[{"2", " ", "\[FormalT]", " ", "J"}], "]"}], "2"], 
          "]"}]}]}], 
    RowBox[{"Log", "[", "4", "]"}]], "\"b\"", "bits", "\"Bits\""},
  "Quantity"]], "Output",
 CellChangeTimes->{3.990277415185422*^9},
 CellLabel->"Out[220]=",
 CellID->363131879,ExpressionUUID->"caac41be-5b2b-4a33-a65f-acb473b1a348"]
}, Open  ]],

Cell[TextData[{
 "QF returns the ",
 StyleBox["entire curve as a formula in ",
  FontWeight->"Bold"],
 Cell[BoxData[
  StyleBox["t", "TI"]], "InlineFormula",
  FontWeight->"Bold",ExpressionUUID->"38b5fb4c-9a8e-4586-9130-4e4930241a2e"],
 StyleBox[" and ",
  FontWeight->"Bold"],
 Cell[BoxData[
  StyleBox["J", "TI"]], "InlineFormula",
  FontWeight->"Bold",ExpressionUUID->"c051bbe7-ac42-4fed-b2a7-5572025d965d"],
 ": the binary entropy of the two oscillating populations, zero whenever the \
state is a product, a full bit at the Bell points, periodic with the exchange \
oscillation. Because it is a formula, it can be differentiated, expanded, or \
solved in closed form, and the same approach extends to larger symbolic spin \
chains."
}], "Text",ExpressionUUID->"cfdaf6f1-5eb0-4779-a766-6d39b99d4e90"],

Cell[TextData[{
 "Plot it (at ",
 Cell[BoxData[
  RowBox[{
   StyleBox["J", "TI"], "=", "1"}]], "InlineFormula",ExpressionUUID->
  "f5eb1043-fe03-4242-9b2d-ca57c3fb4576"],
 "):"
}], "Text",ExpressionUUID->"9c808e37-0fb6-4b27-bdf5-dd35b6603146"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Plot", "[", 
  RowBox[{
   RowBox[{"s", " ", "/.", " ", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"J", " ", "->", " ", "1"}], ",", " ", 
      RowBox[{"\[FormalT]", " ", "->", " ", "t"}]}], "}"}]}], ",", " ", 
   RowBox[{"{", 
    RowBox[{"t", ",", " ", "0", ",", " ", "Pi"}], "}"}], ",", "\n", "  ", 
   RowBox[{"Frame", " ", "->", " ", "True"}], ",", " ", 
   RowBox[{"FrameLabel", " ", "->", " ", 
    RowBox[{"{", 
     RowBox[{"\"\<time  J t\>\"", ",", 
      " ", "\"\<entanglement entropy  S(t)  [bits]\>\""}], "}"}]}], ",", 
   RowBox[{"GridLines", "->", "Automatic"}], ",", 
   RowBox[{"AspectRatio", "->", 
    RowBox[{"1", "/", "2"}]}]}], "]"}]], "Input",
