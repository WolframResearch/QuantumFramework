Cell[CellGroupData[{

Cell["Claim 2: One object model spans all of quantum theory", "Section",ExpressionUUID->"144ff212-a13a-46a7-9a5f-b5750c211ae1"],

Cell[TextData[{
 StyleBox["Key feature:",
  FontWeight->"Bold"],
 " QF gives you whole ",
 StyleBox["categories", "TI"],
 " of object beyond unitary gates: open systems, generalized measurements, \
continuous-variable optics, phase space, stabilizer states, and state \
estimation. Two quiet generalities run underneath the whole model: every \
object carries its basis, and every object lives in any finite dimension. The \
point is ",
 StyleBox["scope", "TI"],
 ", the range of quantum theory QF represents as objects you compute with \
directly."
}], "Text",ExpressionUUID->"85aa4440-9405-4e33-a837-8d579d24f430"],

Cell[CellGroupData[{

Cell["An open-system object: a quantum channel", "Subsection",ExpressionUUID->"d2e9c1b7-5e48-4b0d-a4f9-468a372ad07e"],

Cell[TextData[{
 "A noise process is its own object, a ",
 Cell[BoxData[
 "QuantumChannel"], "InlineFormula",ExpressionUUID->
  "877b19ca-2c8b-47bb-a8a9-76c9ae066e9d"],
 ", not a gate. Take a generic pure qubit on the Bloch sphere, polar angle ",
 Cell[BoxData[
  StyleBox["\[Theta]", "TI"]], "InlineFormula",ExpressionUUID->
  "3e600c64-7808-4033-be97-97c09c0756e1"],
 " and azimuth ",
 Cell[BoxData[
  StyleBox["\[Phi]", "TI"]], "InlineFormula",ExpressionUUID->
  "f079748c-e44b-4740-a8e9-b141bd2ed223"],
 ", and confirm it is pure through the purity ",
 Cell[BoxData[
  RowBox[{
   StyleBox["Tr",
    FontSlant->"Plain"], "[", 
   SuperscriptBox[
    StyleBox["\[Rho]", "TI"], "2"], "]"}]], "InlineFormula",ExpressionUUID->
  "7bed2160-328d-473d-b25f-2ab9474fc5ae"],
 ", which equals ",
 Cell[BoxData[
 "1"], "InlineFormula",ExpressionUUID->"5126ce8e-a179-4dee-903f-096d049d1fc6"],
 " exactly for a pure state and drops below ",
 Cell[BoxData[
 "1"], "InlineFormula",ExpressionUUID->"0c2ddf84-1004-491f-9115-753825c7f402"],
 " for a mixed one:"
}], "Text",ExpressionUUID->"59695b0b-74f5-4de6-b9f5-7183f84292c9"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"psi", " ", "=", " ", 
   RowBox[{"QuantumState", "[", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"Cos", "[", 
       RowBox[{"\[Theta]", "/", "2"}], "]"}], ",", " ", 
      RowBox[{
       RowBox[{"Exp", "[", 
        RowBox[{"I", " ", "\[Phi]"}], "]"}], " ", 
       RowBox[{"Sin", "[", 
        RowBox[{"\[Theta]", "/", "2"}], "]"}]}]}], "}"}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"psi", "[", "\"\<Purity\>\"", "]"}], " ", "//", " ", 
  "FullSimplify"}]}], "Input",
 CellLabel->
  "In[222]:=",ExpressionUUID->"0ce1f886-1c45-4a8e-9b5b-6afab3ee5f79"],

Cell[BoxData["1"], "Output",
 CellChangeTimes->{3.99027742911694*^9},
 CellLabel->"Out[223]=",
 CellID->1622704268,ExpressionUUID->"a69454de-0c9d-4174-9fa1-8ed3a7e1bc13"]
}, Open  ]],

Cell[TextData[{
 "The purity is ",
 Cell[BoxData[
 "1"], "InlineFormula",ExpressionUUID->"c86f5369-64c8-46aa-9604-1521876ad6ec"],
 ", as it must be for any pure state."
}], "Text",ExpressionUUID->"296d6377-8774-45ab-a642-ca571aadb3ab"],

Cell[TextData[{
 "Send it through amplitude damping and ask how much purity is lost, as an \
exact function of the damping rate ",
 Cell[BoxData[
  StyleBox["\[Gamma]", "TI"]], "InlineFormula",ExpressionUUID->
  "e6ebe40f-9b23-4791-9809-2c2d46ae7f29"],
 " and the state:"
}], "Text",ExpressionUUID->"f5426262-2dde-40df-9dd3-019f4be5cf1b"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"FullSimplify", "[", 
  RowBox[{
   RowBox[{
    RowBox[{"psi", "[", "\"\<Purity\>\"", "]"}], " ", "-", " ", 
    RowBox[{
     RowBox[{
      RowBox[{"QuantumChannel", "[", 
       RowBox[{"\"\<AmplitudeDamping\>\"", "[", "\[Gamma]", "]"}], "]"}], "[",
       "psi", "]"}], "[", "\"\<Purity\>\"", "]"}]}], ",", "\n", "  ", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"\[Theta]", " ", "\[Element]", " ", "Reals"}], ",", " ", 
     RowBox[{"\[Phi]", " ", "\[Element]", " ", "Reals"}], ",", " ", 
     RowBox[{"0", " ", "<=", " ", "\[Gamma]", " ", "<=", " ", "1"}]}], 
    "}"}]}], "]"}]], "Input",
 CellLabel->
  "In[224]:=",ExpressionUUID->"9ab8d7bb-9b58-4447-8b72-6282f768b6c5"],

Cell[BoxData[
 RowBox[{
  RowBox[{"-", "2"}], " ", 
  RowBox[{"(", 
   RowBox[{
    RowBox[{"-", "1"}], "+", "\[Gamma]"}], ")"}], " ", "\[Gamma]", " ", 
  SuperscriptBox[
   RowBox[{"Sin", "[", 
    FractionBox["\[Theta]", "2"], "]"}], "4"]}]], "Output",
 CellChangeTimes->{3.990277431339905*^9},
 CellLabel->"Out[224]=",
 CellID->535572857,ExpressionUUID->"f77af214-0629-461b-bd94-348594fb2617"]
}, Open  ]],

Cell[TextData[{
 "The purity loss returns exactly as ",
 Cell[BoxData[
  RowBox[{"2", " ", 
   StyleBox["\[Gamma]", "TI"], "(", 
   RowBox[{"1", "-", 
    StyleBox["\[Gamma]", "TI"]}], ")", " ", 
   SuperscriptBox[
    StyleBox["sin",
     FontSlant->"Plain"], "4"], "\[ThinSpace]", 
   FractionBox[
    StyleBox["\[Theta]", "TI"], "2"]}]], "InlineFormula",ExpressionUUID->
  "9d8d7197-64fc-473e-8621-b5a593411cee"],
 ". The pure input has become mixed: irreversible, non-unitary dynamics \
captured directly as a channel object. The loss depends only on ",
 Cell[BoxData[
  StyleBox["\[Gamma]", "TI"]], "InlineFormula",ExpressionUUID->
  "561d7837-5bfb-4684-ac22-e8a08ecc6e0f"],
 " and the excited-state weight ",
 Cell[BoxData[
  RowBox[{
   SuperscriptBox[
    StyleBox["sin",
     FontSlant->"Plain"], "2"], "\[ThinSpace]", "(", 
   RowBox[{
    StyleBox["\[Theta]", "TI"], "/", "2"}], ")"}]], "InlineFormula",
  ExpressionUUID->"9740f419-d970-47fb-9237-d03af9f9309e"],
 ", never on the azimuth ",
 Cell[BoxData[
  StyleBox["\[Phi]", "TI"]], "InlineFormula",ExpressionUUID->
  "a4be28e3-0a8b-4b0e-995b-1a74c7084a30"],
 ", and it vanishes at ",
 Cell[BoxData[
  RowBox[{
   StyleBox["\[Gamma]", "TI"], "=", "0"}]], "InlineFormula",ExpressionUUID->
  "c2bc92a4-1ca8-488d-8bc4-3c8709be0d02"],
 " (no damping), at ",
 Cell[BoxData[
  RowBox[{
   StyleBox["\[Gamma]", "TI"], "=", "1"}]], "InlineFormula",ExpressionUUID->
  "f118a424-4866-48a5-84a3-d550e8f09ad2"],
 " (fully relaxed to the pure ground state), and at ",
 Cell[BoxData[
  RowBox[{
   StyleBox["\[Theta]", "TI"], "=", "0"}]], "InlineFormula",ExpressionUUID->
  "eb354851-f368-4e94-a7c1-6f02cb09b5b0"],
 " (",
 Cell[BoxData[
  RowBox[{"\[LeftBracketingBar]", "0", 
   AdjustmentBox["\[RightAngleBracket]",
    BoxMargins->{{-0.2, 0}, {0, 0}}]}]], "InlineFormula",ExpressionUUID->
  "37369367-ae02-4c7f-8e9e-7af3274a7d45"],
 ", which damping leaves untouched)."
}], "Text",ExpressionUUID->"0f81099f-eac8-47fa-91df-fcb73d3ac8e2"]
}, Open  ]],

Cell[CellGroupData[{

Cell["\<\
The master equation, solved once for every state and every rate\
\>", "Subsection",ExpressionUUID->"30f3becc-dbaa-4292-9a68-b35fb2939e8d"],

Cell[TextData[{
 "A channel is one snapshot of decoherence; the full dynamics is the Lindblad \
master equation, ",
 Cell[BoxData[
  RowBox[{
   RowBox[{
    OverscriptBox[
     StyleBox["\[Rho]", "TI"], "."], "=", "-", 
    StyleBox["i", "TI"], "[", 
    RowBox[{
     StyleBox["H", "TI"], 
     RowBox[{",", "\[ThinSpace]"}], 
     StyleBox["\[Rho]", "TI"]}], "]", "+", 
    UnderscriptBox["\[Sum]", 
     StyleBox["i", "TI"]], 
    SubscriptBox[
     StyleBox["\[Gamma]", "TI"], 
     StyleBox["i", "TI"]], 
    StyleBox["(",
     Magnification->1.2], 
    SubscriptBox[
     StyleBox["L", "TI"], 
     StyleBox["i", "TI"]], 
    StyleBox["\[Rho]", "TI"], 
    SubsuperscriptBox[
     StyleBox["L", "TI"], 
     StyleBox["i", "TI"], "\[Dagger]"], "-", 
    FractionBox["1", "2"], "{", 
    SubsuperscriptBox[
     StyleBox["L", "TI"], 
     StyleBox["i", "TI"], "\[Dagger]"], 
    SubscriptBox[
     StyleBox["L", "TI"], 
     StyleBox["i", "TI"]]}], 
   RowBox[{",", "\[ThinSpace]"}], 
   RowBox[{
    StyleBox["\[Rho]", "TI"], "}", 
    StyleBox[")",
     Magnification->1.2]}]}]], "InlineFormula",ExpressionUUID->
  "c2cb4314-ce75-44bc-8d2b-836d8b2c9ffa"],
 ", and ",
 Cell[BoxData[
 "QuantumEvolve"], "InlineFormula",ExpressionUUID->
  "341eef83-172b-4dce-9c5a-c5c819627de1"],
 " solves it ",
 StyleBox["symbolically", "TI"],
 ". Hand it a density matrix whose four entries are symbols and rates that \
stay symbols, and one solve answers for every qubit experiment at once. Set \
the physical region, the decay operator ",
 Cell[BoxData[
  RowBox[{
   SubscriptBox[
    StyleBox["\[Sigma]", "TI"], "-"], "=", "\[LeftBracketingBar]", "0", 
   AdjustmentBox["\[RightAngleBracket]",
    BoxMargins->{{-0.2, 0}, {0, 0}}], 
   AdjustmentBox["\[LeftAngleBracket]",
    BoxMargins->{{0, -0.2}, {0, 0}}], "1", "\[RightBracketingBar]"}]], 
  "InlineFormula",ExpressionUUID->"8eaf5d39-6fe6-494e-9e2d-fe63a7a84416"],
 " (written as its matrix so it empties the excited state), and the \
all-states-at-once ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["\[Rho]", "TI"], "0"]], "InlineFormula",ExpressionUUID->
  "c5f320f9-ad29-4660-9cea-b49b382501d2"],
 ":"
}], "Text",ExpressionUUID->"1b31a09f-9b86-46fe-8415-30ea381031af"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"$Assumptions", " ", "=", " ", 
   RowBox[{
    RowBox[{"\[Gamma]1", " ", ">", " ", "0"}], " ", "&&", " ", 
    RowBox[{"\[Gamma]\[Phi]", " ", ">=", " ", "0"}], " ", "&&", " ", 
    RowBox[{"\[CapitalOmega]", " ", "\[Element]", " ", "Reals"}], " ", "&&", 
    " ", 
    RowBox[{"t", " ", ">=", " ", "0"}]}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"\[Sigma]m", " ", "=", " ", 
   RowBox[{"QuantumOperator", "[", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"0", ",", " ", "1"}], "}"}], ",", " ", 
      RowBox[{"{", 
       RowBox[{"0", ",", " ", "0"}], "}"}]}], "}"}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"\[Rho]0", " ", "=", " ", 
   RowBox[{"QuantumState", "[", 
    RowBox[{"Array", "[", 
     RowBox[{"\[Rho]", ",", " ", 
      RowBox[{"{", 
       RowBox[{"2", ",", " ", "2"}], "}"}]}], "]"}], "]"}]}], ";"}]}], "Input",\

 CellLabel->
  "In[225]:=",ExpressionUUID->"1ea53be4-6cab-4a84-b41c-c92e99176540"],

Cell[TextData[{
 "Solve the master equation for a qubit with level splitting ",
 Cell[BoxData[
 "\[CapitalOmega]"], "InlineFormula",ExpressionUUID->
  "80e1433c-88ad-4917-985a-cef9c78e21dd"],
 ", energy relaxation at ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["\[Gamma]", "TI"], "1"]], "InlineFormula",ExpressionUUID->
  "3d793528-96d3-41f0-baed-dc9361f1f6f0"],
 " (jump operator ",
 Cell[BoxData[
  RowBox[{
   SqrtBox[
    SubscriptBox[
     StyleBox["\[Gamma]", "TI"], "1"]], " ", 
   SubscriptBox[
    StyleBox["\[Sigma]", "TI"], "-"]}]], "InlineFormula",ExpressionUUID->
  "4a6a24fb-0c52-4dfc-8065-db6a2a0afcd3"],
 "), and pure dephasing at ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["\[Gamma]", "TI"], 
   StyleBox["\[Phi]", "TI"]]], "InlineFormula",ExpressionUUID->
  "aa069581-7e64-467c-839f-db52f9d834d4"],
 " (jump operator ",
 Cell[BoxData[
  RowBox[{
   SqrtBox[
    SubscriptBox[
     StyleBox["\[Gamma]", "TI"], 
     StyleBox["\[Phi]", "TI"]]], " ", 
   StyleBox["Z", "TI"]}]], "InlineFormula",ExpressionUUID->
  "da1f4e66-e0f9-4e2b-be5c-bb42715f3741"],
 "):"
}], "Text",ExpressionUUID->"2524e827-f5c5-4c6d-90d3-28a9cfff9437"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"\[Rho]t", " ", "=", " ", 
   RowBox[{"QuantumEvolve", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"\[CapitalOmega]", "/", "2"}], " ", 
      RowBox[{"QuantumOperator", "[", "\"\<Z\>\"", "]"}]}], ",", "\n", "   ", 
     
     RowBox[{"{", 
      RowBox[{
       RowBox[{
        RowBox[{"Sqrt", "[", "\[Gamma]1", "]"}], " ", "\[Sigma]m"}], ",", " ", 
       RowBox[{
        RowBox[{"Sqrt", "[", "\[Gamma]\[Phi]", "]"}], " ", 
        RowBox[{"QuantumOperator", "[", "\"\<Z\>\"", "]"}]}]}], "}"}], ",", 
     " ", "\[Rho]0", ",", " ", "t"}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"FullSimplify", " ", "/@", " ", 
   RowBox[{"Normal", "[", 
    RowBox[{
     RowBox[{"\[Rho]t", "[", "\"\<Computational\>\"", "]"}], 
     "[", "\"\<DensityMatrix\>\"", "]"}], "]"}]}], " ", "//", " ", 
  "MatrixForm"}]}], "Input",
 CellLabel->
  "In[228]:=",ExpressionUUID->"b68237de-5ff9-4a60-ad19-908dbc0b4956"],

Cell[BoxData[
 TagBox[
  RowBox[{"(", "\[NoBreak]", GridBox[{
     {
      RowBox[{
       RowBox[{"\[Rho]", "[", 
        RowBox[{"1", ",", "1"}], "]"}], "+", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{"1", "-", 
          SuperscriptBox["\[ExponentialE]", 
           RowBox[{
            RowBox[{"-", "t"}], " ", "\[Gamma]1"}]]}], ")"}], " ", 
        RowBox[{"\[Rho]", "[", 
         RowBox[{"2", ",", "2"}], "]"}]}]}], 
      RowBox[{
       SuperscriptBox["\[ExponentialE]", 
        RowBox[{
         RowBox[{"-", 
          FractionBox["1", "2"]}], " ", "t", " ", 
         RowBox[{"(", 
          RowBox[{"\[Gamma]1", "+", 
           RowBox[{"4", " ", "\[Gamma]\[Phi]"}], "+", 
           RowBox[{"2", " ", "\[ImaginaryI]", " ", "\[CapitalOmega]"}]}], 
          ")"}]}]], " ", 
       RowBox[{"\[Rho]", "[", 
        RowBox[{"1", ",", "2"}], "]"}]}]},
     {
      RowBox[{
       SuperscriptBox["\[ExponentialE]", 
        RowBox[{
         RowBox[{"-", 
          FractionBox["1", "2"]}], " ", "t", " ", 
         RowBox[{"(", 
          RowBox[{"\[Gamma]1", "+", 
           RowBox[{"4", " ", "\[Gamma]\[Phi]"}], "-", 
           RowBox[{"2", " ", "\[ImaginaryI]", " ", "\[CapitalOmega]"}]}], 
          ")"}]}]], " ", 
       RowBox[{"\[Rho]", "[", 
        RowBox[{"2", ",", "1"}], "]"}]}], 
      RowBox[{
       SuperscriptBox["\[ExponentialE]", 
        RowBox[{
         RowBox[{"-", "t"}], " ", "\[Gamma]1"}]], " ", 
       RowBox[{"\[Rho]", "[", 
        RowBox[{"2", ",", "2"}], "]"}]}]}
    },
    GridBoxAlignment->{"Columns" -> {{Center}}, "Rows" -> {{Baseline}}},
    GridBoxSpacings->{"Columns" -> {
        Offset[0.27999999999999997`], {
         Offset[0.7]}, 
        Offset[0.27999999999999997`]}, "Rows" -> {
        Offset[0.2], {
         Offset[0.4]}, 
        Offset[0.2]}}], "\[NoBreak]", ")"}],
  Function[BoxForm`e$, 
   MatrixForm[BoxForm`e$]]]], "Output",
 CellChangeTimes->{3.9902774387781343`*^9},
 CellLabel->"Out[229]//MatrixForm=",
 CellID->981040873,ExpressionUUID->"ec7c1fab-2dd2-4d35-ae32-c96e5e3cd2c4"]
}, Open  ]],

Cell["\<\
The matrix returns exactly as the complete relaxation law for an arbitrary \
qubit:\
\>", "Text",ExpressionUUID->"292dd4c3-0208-4136-86e2-dd5d282506c3"],

Cell[BoxData[
 PaneBox[
  RowBox[{
   StyleBox["\[Rho]", "TI"], "(", 
   StyleBox["t", "TI"], ")", "=", "(", GridBox[{
     {
      RowBox[{
       SubscriptBox[
        StyleBox["\[Rho]", "TI"], "11"], "+", "(", 
       RowBox[{"1", "-", 
        SuperscriptBox[
         StyleBox["e", "TI"], 
         RowBox[{"-", 
          SubscriptBox[
           StyleBox["\[Gamma]", "TI"], "1"], 
          StyleBox["t", "TI"]}]]}], ")", 
       SubscriptBox[
        StyleBox["\[Rho]", "TI"], "22"]}], 
      RowBox[{
       SubscriptBox[
        StyleBox["\[Rho]", "TI"], "12"], " ", 
       SuperscriptBox[
        StyleBox["e", "TI"], 
        RowBox[{"-", "(", 
         RowBox[{
          FractionBox[
           SubscriptBox[
            StyleBox["\[Gamma]", "TI"], "1"], "2"], "+", "2", 
          SubscriptBox[
           StyleBox["\[Gamma]", "TI"], 
           StyleBox["\[Phi]", "TI"]], "+", 
          StyleBox["i", "TI"], "\[CapitalOmega]"}], ")", 
         StyleBox["t", "TI"]}]]}]},
     {
      RowBox[{
       SubscriptBox[
        StyleBox["\[Rho]", "TI"], "21"], " ", 
       SuperscriptBox[
        StyleBox["e", "TI"], 
        RowBox[{"-", "(", 
         RowBox[{
          FractionBox[
           SubscriptBox[
            StyleBox["\[Gamma]", "TI"], "1"], "2"], "+", "2", 
          SubscriptBox[
           StyleBox["\[Gamma]", "TI"], 
           StyleBox["\[Phi]", "TI"]], "-", 
          StyleBox["i", "TI"], "\[CapitalOmega]"}], ")", 
         StyleBox["t", "TI"]}]]}], 
      RowBox[{
       SubscriptBox[
        StyleBox["\[Rho]", "TI"], "22"], " ", 
       SuperscriptBox[
        StyleBox["e", "TI"], 
        RowBox[{"-", 
         SubscriptBox[
          StyleBox["\[Gamma]", "TI"], "1"], 
         StyleBox["t", "TI"]}]]}]}
    }], ")"}],
  Alignment->Center,
  ImageSize->Full]], "DisplayFormula",ExpressionUUID->"a0b34dec-e605-4aa5-\
a91d-7458264be930"],

Cell[TextData[{
 "The excited population empties at ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["\[Gamma]", "TI"], "1"]], "InlineFormula",ExpressionUUID->
  "f9e2ebb1-130b-48aa-89a5-a2abe37d2de7"],
 ", the lost weight lands on the ground state, and the coherence precesses at \
",
 Cell[BoxData[
 "\[CapitalOmega]"], "InlineFormula",ExpressionUUID->
  "86c5431d-01e6-48aa-86ee-dc9380864b6e"],
 " while decaying at ",
 Cell[BoxData[
  RowBox[{
   SubscriptBox["\[CapitalGamma]", "2"], "=", 
   FractionBox[
    SubscriptBox[
     StyleBox["\[Gamma]", "TI"], "1"], "2"], "+", "2", 
   SubscriptBox[
    StyleBox["\[Gamma]", "TI"], 
    StyleBox["\[Phi]", "TI"]]}]], "InlineFormula",ExpressionUUID->
  "2d9753c5-fbf8-4aeb-a72f-610d9bc63ecb"],
 ": every experiment on every qubit, in one matrix. With ",
 Cell[BoxData[
  RowBox[{
   SubscriptBox[
    StyleBox["T", "TI"], "1"], "=", "1", "/", 
   SubscriptBox[
    StyleBox["\[Gamma]", "TI"], "1"]}]], "InlineFormula",ExpressionUUID->
  "ea8bb078-73aa-4c70-9afb-00e178c63f83"],
 " and ",
 Cell[BoxData[
  RowBox[{
   SubscriptBox[
    StyleBox["T", "TI"], "2"], "=", "1", "/", 
   SubscriptBox["\[CapitalGamma]", "2"]}]], "InlineFormula",ExpressionUUID->
  "151e2c0e-7cd5-4451-9ed9-31e2500d75db"],
 " read off the exponents, the textbook bound between the two times is now a \
theorem about this solution:"
}], "Text",ExpressionUUID->"c58d6636-2251-4063-8e34-b78f4a49f4e1"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Reduce", "[", 
  RowBox[{"ForAll", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"\[Gamma]1", ",", " ", "\[Gamma]\[Phi]"}], "}"}], ",", " ", 
    RowBox[{
     RowBox[{"\[Gamma]1", " ", ">", " ", "0"}], " ", "&&", " ", 
     RowBox[{"\[Gamma]\[Phi]", " ", ">=", " ", "0"}]}], ",", " ", 
    RowBox[{
     RowBox[{"1", "/", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{"\[Gamma]1", "/", "2"}], " ", "+", " ", 
        RowBox[{"2", " ", "\[Gamma]\[Phi]"}]}], ")"}]}], " ", "<=", " ", 
     RowBox[{"2", "/", "\[Gamma]1"}]}]}], "]"}], "]"}]], "Input",
 CellLabel->
  "In[230]:=",ExpressionUUID->"ef8d936c-9d24-4dc2-ac4b-56c953f68e30"],

Cell[BoxData["True"], "Output",
 CellChangeTimes->{3.9902774418471937`*^9},
 CellLabel->"Out[230]=",
 CellID->1996433241,ExpressionUUID->"7dee520a-6e0e-46e6-a018-a3afab6f9708"]
}, Open  ]],

Cell[TextData[{
 "The reduction returns ",
 Cell[BoxData[
 "True"], "InlineFormula",ExpressionUUID->
  "ec36af18-2c2f-4131-a71f-1e768e21883a"],
 ": ",
 Cell[BoxData[
  RowBox[{
   SubscriptBox[
    StyleBox["T", "TI"], "2"], "\[LessEqual]", "2", 
   SubscriptBox[
    StyleBox["T", "TI"], "1"]}]], "InlineFormula",ExpressionUUID->
  "00220435-453b-4bf6-b754-d7388663d82d"],
 " holds for every admissible rate pair, handed over by the computation \
rather than quoted from a textbook, and the same ",
 Cell[BoxData[
 "Reduce"], "InlineFormula",ExpressionUUID->
  "5a8663ef-13e5-45de-85d9-98d321c267e8"],
 " asked for equality returns ",
 Cell[BoxData[
  RowBox[{
   SubscriptBox[
    StyleBox["\[Gamma]", "TI"], 
    StyleBox["\[Phi]", "TI"]], "=", "0"}]], "InlineFormula",ExpressionUUID->
  "930c291e-e1a3-4cb2-9fc7-e0e83aae0c31"],
 " (verified): the famous factor of two is saturated exactly when dephasing \
vanishes."
}], "Text",ExpressionUUID->"0704c2e6-984c-4eb8-a573-6566045a938f"]
}, Open  ]],

Cell[CellGroupData[{

Cell["A generalized measurement: a POVM", "Subsection",ExpressionUUID->"76aedba7-019f-4dba-871d-d501354a086a"],

Cell[TextData[{
 "Real detectors are not always projective. A POVM is a set of positive \
effects ",
 Cell[BoxData[
  RowBox[{"{", 
   SubscriptBox[
    StyleBox["E", "TI"], 
    StyleBox["i", "TI"]], "}"}]], "InlineFormula",ExpressionUUID->
  "5e104763-43b2-4ab4-be7c-e54b893a023d"],
 " summing to the identity, ",
 Cell[BoxData[
  RowBox[{
   UnderscriptBox["\[Sum]", 
    StyleBox["i", "TI"]], 
   SubscriptBox[
    StyleBox["E", "TI"], 
    StyleBox["i", "TI"]], "=", 
   StyleBox["I", "TI"]}]], "InlineFormula",ExpressionUUID->
  "1dffaf27-604c-4649-9704-b35fcb57a179"],
 ", with outcome probabilities given by the Born rule ",
 Cell[BoxData[
  RowBox[{
   SubscriptBox[
    StyleBox["p", "TI"], 
    StyleBox["i", "TI"]], "=", 
   StyleBox["Tr",
    FontSlant->"Plain"], "[", 
   RowBox[{
    StyleBox["\[Rho]", "TI"], " ", 
    SubscriptBox[
     StyleBox["E", "TI"], 
     StyleBox["i", "TI"]]}], "]"}]], "InlineFormula",ExpressionUUID->
  "38eea43a-f42e-4d40-998d-88553a7f29de"],
 "; build one from your own effects with ",
 Cell[BoxData[
  RowBox[{"QuantumMeasurementOperator", "[", 
   RowBox[{"{", 
    RowBox[{"E1", ",", " ", "E2", ",", " ", "..."}], "}"}], "]"}]], 
  "InlineFormula",ExpressionUUID->"4edbe3b5-476c-4004-b9f6-1f125b425997"],
 ". A ",
 StyleBox["symmetric informationally complete", "TI"],
 " POVM is the maximally symmetric case: ",
 Cell[BoxData[
  SuperscriptBox[
   StyleBox["d", "TI"], "2"]], "InlineFormula",ExpressionUUID->
  "fd0eed3c-0f4e-406f-864d-2c252a9d9c4a"],
 " rank-one effects ",
 Cell[BoxData[
  RowBox[{
   SubscriptBox[
    StyleBox["E", "TI"], 
    StyleBox["i", "TI"]], "=", 
   FractionBox["1", 
    StyleBox["d", "TI"]], "\[LeftBracketingBar]", 
   SubscriptBox[
    StyleBox["\[Psi]", "TI"], 
    StyleBox["i", "TI"]], 
   AdjustmentBox["\[RightAngleBracket]",
    BoxMargins->{{-0.2, 0}, {0, 0}}], 
   AdjustmentBox["\[LeftAngleBracket]",
    BoxMargins->{{0, -0.2}, {0, 0}}], 
   SubscriptBox[
    StyleBox["\[Psi]", "TI"], 
    StyleBox["i", "TI"]], "\[RightBracketingBar]"}]], "InlineFormula",
  ExpressionUUID->"f69a5fc9-b6ec-4357-8580-5720afdc6b94"],
 " with equal pairwise overlaps ",
 Cell[BoxData[
  RowBox[{
   SuperscriptBox[
    RowBox[{"\[LeftBracketingBar]", 
     RowBox[{
      AdjustmentBox["\[LeftAngleBracket]",
       BoxMargins->{{0, -0.2}, {0, 0}}], 
      SubscriptBox[
       StyleBox["\[Psi]", "TI"], 
       StyleBox["i", "TI"]], 
      AdjustmentBox["\[RightBracketingBar]",
       BoxMargins->{{0, -0.2}, {0, 0}}], 
      SubscriptBox[
       StyleBox["\[Psi]", "TI"], 
       StyleBox["j", "TI"]], 
      AdjustmentBox["\[RightAngleBracket]",
       BoxMargins->{{-0.2, 0}, {0, 0}}]}], "\[RightBracketingBar]"}], "2"], "=", 
   FractionBox["1", 
    RowBox[{
     StyleBox["d", "TI"], "+", "1"}]]}]], "InlineFormula",ExpressionUUID->
  "8407273c-bd41-470e-83dd-e84fabdeebd4"],
 ", four outcomes on a two-level system, pointing along the vertices of a \
tetrahedron in the Bloch ball. Measure the generic Bloch qubit ",
 Cell[BoxData[
  StyleBox["\[Psi]", "TI"]], "InlineFormula",ExpressionUUID->
  "412f68e6-6a6d-421b-8334-12e048bfdcf5"],
 " from the channel example, the Born rule applied symbolically to all four \
effects:"
}], "Text",ExpressionUUID->"a6b49067-d863-40a5-8a9a-8e2f823eeb56"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"sic", " ", "=", " ", 
   RowBox[{
   "QuantumMeasurementOperator", "[", "\"\<TetrahedronSICPOVM\>\"", "]"}]}], 
  ";"}], "\n", 
 RowBox[{"probs", " ", "=", " ", 
  RowBox[{"FullSimplify", "[", 
   RowBox[{"ComplexExpand", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"Tr", "[", 
       RowBox[{
        RowBox[{"psi", "[", "\"\<DensityMatrix\>\"", "]"}], " ", ".", " ", 
        RowBox[{"Normal", "[", "#", "]"}]}], "]"}], " ", "&"}], " ", "/@", 
     " ", 
     RowBox[{"sic", "[", "\"\<POVMElements\>\"", "]"}]}], "]"}], 
   "]"}]}]}], "Input",
 CellLabel->
  "In[231]:=",ExpressionUUID->"86310735-7731-41d9-905f-e20e4ffe9308"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{
    FractionBox["1", "4"], " ", 
    RowBox[{"(", 
     RowBox[{"1", "+", 
      RowBox[{"Cos", "[", "\[Theta]", "]"}]}], ")"}]}], ",", 
   RowBox[{
    FractionBox["1", "12"], " ", 
    RowBox[{"(", 
     RowBox[{"3", "-", 
      RowBox[{"Cos", "[", "\[Theta]", "]"}], "-", 
      RowBox[{
       SqrtBox["2"], " ", 
       RowBox[{"Sin", "[", "\[Theta]", "]"}], " ", 
       RowBox[{"(", 
        RowBox[{
         RowBox[{"Cos", "[", "\[Phi]", "]"}], "+", 
         RowBox[{
          SqrtBox["3"], " ", 
          RowBox[{"Sin", "[", "\[Phi]", "]"}]}]}], ")"}]}]}], ")"}]}], ",", 
   RowBox[{
    FractionBox["1", "12"], " ", 
    RowBox[{"(", 
     RowBox[{"3", "-", 
      RowBox[{"Cos", "[", "\[Theta]", "]"}], "-", 
      RowBox[{
       SqrtBox["2"], " ", 
       RowBox[{"Cos", "[", "\[Phi]", "]"}], " ", 
       RowBox[{"Sin", "[", "\[Theta]", "]"}]}], "+", 
      RowBox[{
       SqrtBox["6"], " ", 
       RowBox[{"Sin", "[", "\[Theta]", "]"}], " ", 
       RowBox[{"Sin", "[", "\[Phi]", "]"}]}]}], ")"}]}], ",", 
   RowBox[{
    FractionBox["1", "12"], " ", 
    RowBox[{"(", 
     RowBox[{"3", "-", 
      RowBox[{"Cos", "[", "\[Theta]", "]"}], "+", 
      RowBox[{"2", " ", 
       SqrtBox["2"], " ", 
       RowBox[{"Cos", "[", "\[Phi]", "]"}], " ", 
       RowBox[{"Sin", "[", "\[Theta]", "]"}]}]}], ")"}]}]}], "}"}]], "Output",\

 CellChangeTimes->{3.990277510528927*^9},
 CellLabel->"Out[232]=",
 CellID->658589039,ExpressionUUID->"207a4508-52ef-4f05-b1e6-c46b1f71a16f"]
}, Open  ]],

Cell[TextData[{
 "The four probabilities return exactly as ",
 Cell[BoxData[
  RowBox[{
   SubscriptBox[
    StyleBox["p", "TI"], 
    StyleBox["i", "TI"]], "=", 
   FractionBox["1", "4"], 
   StyleBox["(",
    Magnification->1.2], "1", "+", 
   OverscriptBox[
    StyleBox["r", "TI"], "^"], 
   StyleBox["\[CenterDot]", "TI"], 
   SubscriptBox[
    OverscriptBox[
     StyleBox["n", "TI"], "^"], 
    StyleBox["i", "TI"]], 
   StyleBox[")",
    Magnification->1.2]}]], "InlineFormula",ExpressionUUID->
  "1cb5af9c-22b1-4922-a091-529b3f98ae47"],
 ", the first reading ",
 Cell[BoxData[
  FractionBox[
   RowBox[{"1", "+", 
    StyleBox["cos",
     FontSlant->"Plain"], "\[ThinSpace]", 
    StyleBox["\[Theta]", "TI"]}], "4"]], "InlineFormula",ExpressionUUID->
  "a89ba3d3-4fa5-4f52-baa7-45116f870ff8"],
 " and the others ",
 Cell[BoxData[
  RowBox[{
   FractionBox["1", "12"], 
   StyleBox["(",
    Magnification->1.2], "3", "-", 
   StyleBox["cos",
    FontSlant->"Plain"], "\[ThinSpace]", 
   StyleBox["\[Theta]", "TI"], "+", 
   SqrtBox["2"], " ", 
   StyleBox["sin",
    FontSlant->"Plain"], "\[ThinSpace]", 
   StyleBox["\[Theta]", "TI"], " ", "(", "\[Ellipsis]", ")", 
   StyleBox[")",
    Magnification->1.2]}]], "InlineFormula",ExpressionUUID->
  "a272f8d1-8084-45bb-b0ee-abdb24f02c7f"],
 " along the remaining tetrahedron directions ",
 Cell[BoxData[
  SubscriptBox[
   OverscriptBox[
    StyleBox["n", "TI"], "^"], 
   StyleBox["i", "TI"]]], "InlineFormula",ExpressionUUID->
  "65a25cc7-53df-4465-a24b-bbba7e184061"],
 ", with ",
 Cell[BoxData[
  OverscriptBox[
   StyleBox["r", "TI"], "^"]], "InlineFormula",ExpressionUUID->
  "27f55b43-fdd9-4a25-a986-ea2a5a5de3df"],
 " the state's Bloch vector; they sum to ",
 Cell[BoxData[
 "1"], "InlineFormula",ExpressionUUID->"0c0a959c-c499-4910-9a8a-ba1bed5de304"],
 " identically (verified). Pin the state to the north pole and the general \
formulas collapse to numbers:"
}], "Text",ExpressionUUID->"c2873348-431d-4fe0-b6f9-4f737f2e849e"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"probs", " ", "/.", " ", 
  RowBox[{"\[Theta]", " ", "->", " ", "0"}]}]], "Input",
 CellLabel->
  "In[250]:=",ExpressionUUID->"f1c6dce0-198a-4e8c-a25d-b35905cbdcf1"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   FractionBox["1", "2"], ",", 
   FractionBox["1", "6"], ",", 
   FractionBox["1", "6"], ",", 
   FractionBox["1", "6"]}], "}"}]], "Output",
 CellChangeTimes->{3.9902779088592052`*^9},
 CellLabel->"Out[250]=",
 CellID->1849338758,ExpressionUUID->"41a7aeb7-d14d-4ffb-9222-ab22ae2a71a4"]
}, Open  ]],

Cell[TextData[{
 "The distribution collapses to simple rationals: ",
 Cell[BoxData[
  RowBox[{"\[LeftBracketingBar]", "0", 
   AdjustmentBox["\[RightAngleBracket]",
    BoxMargins->{{-0.2, 0}, {0, 0}}]}]], "InlineFormula",ExpressionUUID->
  "cd1d4c8f-6951-4980-bfc2-10a132fbc739"],
 " puts a half on the tetrahedron vertex nearest the pole and a sixth on each \
of the other three. And because the SIC is ",
 StyleBox["informationally complete", "TI"],
 ", these four probabilities are not merely statistics of the state, they ",
 StyleBox["are",
  FontWeight->"Bold"],
 " the state: ",
 Cell[BoxData[
  StyleBox["\[Theta]", "TI"]], "InlineFormula",ExpressionUUID->
  "736e345d-bf1e-438d-9a99-0c5d017be130"],
 " and ",
 Cell[BoxData[
  StyleBox["\[Phi]", "TI"]], "InlineFormula",ExpressionUUID->
  "7f823990-85f5-411b-816a-7fba9716b3bc"],
 " can be solved back from them, which is what makes SIC measurements the \
natural alphabet of tomography."
}], "Text",ExpressionUUID->"e362aa1c-4303-4c53-b518-7e371390cfd1"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Continuous-variable quantum optics", "Subsection",ExpressionUUID->"1254af5c-bc38-43de-8d19-815036baeffc"],

Cell[TextData[{
 "Bosonic Fock space, not qubits. The second-order coherence at zero delay, \
",
 Cell[BoxData[
  RowBox[{
   SuperscriptBox[
    StyleBox["g", "TI"], 
    RowBox[{"(", "2", ")"}]], "(", "0", ")", "=", 
   FractionBox[
    RowBox[{
     AdjustmentBox["\[LeftAngleBracket]",
      BoxMargins->{{0, -0.2}, {0, 0}}], 
     RowBox[{
      SuperscriptBox[
       StyleBox["a", "TI"], "\[Dagger]"], 
      SuperscriptBox[
       StyleBox["a", "TI"], "\[Dagger]"], 
      StyleBox["a", "TI"], " ", 
      StyleBox["a", "TI"]}], 
     AdjustmentBox["\[RightAngleBracket]",
      BoxMargins->{{-0.2, 0}, {0, 0}}]}], 
    SuperscriptBox[
     RowBox[{
      AdjustmentBox["\[LeftAngleBracket]",
       BoxMargins->{{0, -0.2}, {0, 0}}], 
      RowBox[{
       SuperscriptBox[
        StyleBox["a", "TI"], "\[Dagger]"], 
       StyleBox["a", "TI"]}], 
      AdjustmentBox["\[RightAngleBracket]",
       BoxMargins->{{-0.2, 0}, {0, 0}}]}], "2"]], "=", 
   FractionBox[
    RowBox[{
     AdjustmentBox["\[LeftAngleBracket]",
      BoxMargins->{{0, -0.2}, {0, 0}}], 
     RowBox[{
      StyleBox["n", "TI"], "(", 
      RowBox[{
       StyleBox["n", "TI"], "-", "1"}], ")"}], 
     AdjustmentBox["\[RightAngleBracket]",
      BoxMargins->{{-0.2, 0}, {0, 0}}]}], 
    SuperscriptBox[
     RowBox[{
      AdjustmentBox["\[LeftAngleBracket]",
       BoxMargins->{{0, -0.2}, {0, 0}}], 
      StyleBox["n", "TI"], 
      AdjustmentBox["\[RightAngleBracket]",
       BoxMargins->{{-0.2, 0}, {0, 0}}]}], "2"]]}]], "InlineFormula",
  ExpressionUUID->"9b87e92c-fb0f-4b16-ba5c-2702d6c97423"],
 ", is the normalized chance of detecting two photons at once; it sorts light \
by photon statistics, antibunched (",
 Cell[BoxData[
  RowBox[{"<", "1"}]], "InlineFormula",ExpressionUUID->
  "16393869-b02a-45cf-b1b1-1083fa324fc3"],
 ", nonclassical), coherent (",
 Cell[BoxData[
  RowBox[{"=", "1"}]], "InlineFormula",ExpressionUUID->
  "278592fe-440d-496c-b52d-37faecba8607"],
 "), and bunched thermal (",
 Cell[BoxData[
  RowBox[{">", "1"}]], "InlineFormula",ExpressionUUID->
  "6da93daf-7522-4a0f-a7b2-b8dae4f95995"],
 ")."
}], "Text",ExpressionUUID->"0c999c90-fedd-489b-870b-bc42db435177"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"g2s", " ", "=", " ", 
  RowBox[{"<|", 
   RowBox[{
    RowBox[{"\"\<Fock\>\"", " ", "->", " ", 
     RowBox[{"G2Coherence", "[", 
      RowBox[{"FockState", "[", "1", "]"}], "]"}]}], ",", " ", 
    RowBox[{"\"\<Coherent\>\"", " ", "->", " ", 
     RowBox[{"G2Coherence", "[", 
      RowBox[{
       RowBox[{"CoherentState", "[", "20", "]"}], "[", "1.5", "]"}], "]"}]}], 
    ",", "\n", "  ", 
    RowBox[{"\"\<Thermal\>\"", " ", "->", " ", 
     RowBox[{"G2Coherence", "[", 
      RowBox[{"ThermalState", "[", 
       RowBox[{"1.0", ",", " ", "20"}], "]"}], "]"}]}]}], "|>"}]}]], "Input",
 CellLabel->
