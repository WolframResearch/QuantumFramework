Cell[TextData[{
 "The result is a ",
 Cell[BoxData[
 "QuantumMeasurement"], "InlineFormula",ExpressionUUID->
  "f2606121-2f13-4eb9-b925-b3eb90ca1943"],
 " with probabilities ",
 Cell[BoxData[
  FractionBox["1", "2"]], "InlineFormula",ExpressionUUID->
  "ce074517-3ddd-4181-bba6-6781f79678b2"],
 " at ",
 Cell[BoxData[
 "000"], "InlineFormula",ExpressionUUID->
  "76339109-06fc-40b5-9778-999452809410"],
 " and ",
 Cell[BoxData[
  FractionBox["1", "2"]], "InlineFormula",ExpressionUUID->
  "17def537-b7cd-4c8e-ac65-c0c7f9efae22"],
 " at ",
 Cell[BoxData[
 "111"], "InlineFormula",ExpressionUUID->
  "42e7eb7f-d448-4483-80e4-c70273517946"],
 ". Once the job completes, the hardware outcome comes back as the ",
 StyleBox["same kind of ",
  FontWeight->"Bold"],
 Cell[BoxData["QuantumMeasurement"], "InlineFormula",
  FontWeight->"Bold",ExpressionUUID->"5fdd5516-5ece-44d5-9d96-df7c2a1b9242"],
 StyleBox[" object",
  FontWeight->"Bold"],
 ", decoded into the same qubit order:"
}], "Text",ExpressionUUID->"4fd46f0b-d8ec-40e2-b997-92fc58e5d647"],

