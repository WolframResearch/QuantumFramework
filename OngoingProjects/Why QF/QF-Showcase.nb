            FractionBox[
             RowBox[{"\[Pi]", " ", 
              SuperscriptBox["\[CapitalDelta]", "2"]}], 
             RowBox[{"8", " ", "v"}]], ")"}]}], ")"}]}]]}], 
      FractionBox[
       RowBox[{
        SuperscriptBox["2", 
         RowBox[{
          RowBox[{"-", 
           FractionBox["1", "2"]}], "-", 
          FractionBox[
           RowBox[{"\[ImaginaryI]", " ", 
            SuperscriptBox["\[CapitalDelta]", "2"]}], 
           RowBox[{"8", " ", "v"}]]}]], " ", 
        RowBox[{"(", 
         RowBox[{
          RowBox[{"\[ImaginaryI]", " ", 
           SuperscriptBox["2", 
            RowBox[{
             FractionBox["1", "2"], "+", 
             FractionBox[
              RowBox[{"\[ImaginaryI]", " ", 
               SuperscriptBox["\[CapitalDelta]", "2"]}], 
              RowBox[{"4", " ", "v"}]]}]], " ", 
           TemplateBox[{
             FractionBox[
              RowBox[{"\[ImaginaryI]", " ", 
                SuperscriptBox["\[CapitalDelta]", "2"]}], 
              RowBox[{"8", " ", "v"}]]},
            "Gamma"], " ", 
