  "In[266]:=",ExpressionUUID->"f94e45f5-ea8c-4bc5-96ca-668fdbf4b89b"],

Cell[BoxData[
 FormBox[
  InterpretationBox[
   TooltipBox[
    StyleBox[
     FormBox[
      InterpretationBox[
       StyleBox[
        TemplateBox[{
          RowBox[{
            FormBox[
             TemplateBox[{"\"J\"", 
               InterpretationBox[
                InterpretationBox[
                 StyleBox[
                 "1", ShowStringCharacters -> True, NumberMarks -> True], 
                 InputForm[1], Editable -> True, AutoDelete -> True], 2], 
               "\"x\""}, "Subsuperscript", SyntaxForm -> SubsuperscriptBox], 
             TraditionalForm]}]},
         "Ket"],
        FontWeight->"Plain"],
       Wolfram`QuantumFramework`QuditName[
        Subsuperscript["J", 
         Interpretation[
          InputForm[1], 2], "x"], "Dual" -> False]],
      TraditionalForm],
     ShowStringCharacters->False],
    TagBox[
     GridBox[{{"\"JX\""}, {
        TemplateBox[{"\"QuantumState: \"", 
          RowBox[{
            RowBox[{"{", "}"}], "\[Rule]", 
            RowBox[{"{", "3", "}"}]}]}, "RowDefault"]}}, 
      GridBoxAlignment -> {"Columns" -> {{Center}}}, DefaultBaseStyle -> 
      "Column", 
      GridBoxItemSize -> {
       "Columns" -> {{Automatic}}, "Rows" -> {{Automatic}}}], "Column"]],
   Wolfram`QuantumFramework`QuantumState[
   SparseArray[Automatic, {3}, 0, {1, {{0, 1}, {{3}}}, {1}}], 
    Wolfram`QuantumFramework`QuantumBasis[<|
     "Input" -> Wolfram`QuantumFramework`QuditBasis[<|{
           
           Wolfram`QuantumFramework`QuditName[\[FormalCapitalI], "Dual" -> 
            False], 1} -> 1|>], "Output" -> 
      Wolfram`QuantumFramework`QuditBasis[<|{
           Wolfram`QuantumFramework`QuditName[
            Subsuperscript["J", 
             Interpretation[
              InputForm[-1], -2], "x"], "Dual" -> False], 1} -> 
         SparseArray[
          Automatic, {3}, 0, {
           1, {{0, 3}, {{1}, {2}, {3}}}, {
            Rational[1, 2], -2^Rational[-1, 2], Rational[1, 2]}}], {
           Wolfram`QuantumFramework`QuditName[
            Subsuperscript["J", 
             Interpretation[
              InputForm[0], 0], "x"], "Dual" -> False], 1} -> 
         SparseArray[
          Automatic, {3}, 0, {
           1, {{0, 2}, {{1}, {3}}}, {
            2^Rational[-1, 2], -2^Rational[-1, 2]}}], {
           Wolfram`QuantumFramework`QuditName[
            Subsuperscript["J", 
             Interpretation[
              InputForm[1], 2], "x"], "Dual" -> False], 1} -> 
         SparseArray[
          Automatic, {3}, 0, {
           1, {{0, 3}, {{1}, {2}, {3}}}, {
            Rational[1, 2], 2^Rational[-1, 2], Rational[1, 2]}}]|>], 
      "Picture" -> "Schrodinger", "Label" -> "JX", "ParameterSpec" -> {}|>]]],
   TraditionalForm]], "Output",
 CellChangeTimes->{3.9902780701326847`*^9},
 CellLabel->"Out[267]//TraditionalForm=",
 CellID->777057509,ExpressionUUID->"39ab9ade-225d-46c4-af87-a6813ad22d43"]
}, Open  ]],

Cell[TextData[{
 "The state renders as the single ket ",
 Cell[BoxData[
  RowBox[{"\[LeftBracketingBar]", 
   SubsuperscriptBox[
    StyleBox["J", "TI"], "1", 
    StyleBox["x", "TI"]], 
   AdjustmentBox["\[RightAngleBracket]",
    BoxMargins->{{-0.2, 0}, {0, 0}}]}]], "InlineFormula",ExpressionUUID->
  "69cb0c70-57bb-47a3-8cf7-e5cedd6a6334"],
 ". Re-express it in the computational (",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["J", "TI"], 
   StyleBox["z", "TI"]]], "InlineFormula",ExpressionUUID->
  "ed218d52-f524-45ee-a16f-f9ae83c3a9dc"],
 ") basis:"
}], "Text",ExpressionUUID->"66f906b6-8f75-4087-a0e5-65d2f2a9da40"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"mxZ", " ", "=", " ", 
   RowBox[{"QuantumState", "[", 
    RowBox[{"mx", ",", " ", 
     RowBox[{"\"\<Computational\>\"", "[", "3", "]"}]}], "]"}]}], ";"}], "\n", 
 RowBox[{"mxZ", " ", "//", " ", "TraditionalForm"}]}], "Input",
