  "In[268]:=",ExpressionUUID->"979eff44-9339-435f-bcfe-fe40f3e0ff39"],

Cell[BoxData[
 FormBox[
  InterpretationBox[
   TooltipBox[
    StyleBox[
     RowBox[{
      RowBox[{
       FractionBox["1", "2"], 
