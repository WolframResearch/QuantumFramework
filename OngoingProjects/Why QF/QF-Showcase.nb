     StyleBox["t", "TI"], ")"}]}], "=", 
   RowBox[{"(", GridBox[{
      {
       RowBox[{
        SuperscriptBox[
         StyleBox["e", "TI"], 
         RowBox[{"-", 
          StyleBox["i", "TI"], 
          StyleBox["\[Omega]", "TI"], 
          StyleBox["t", "TI"], "/", "2"}]], "(", 
        RowBox[{
         StyleBox["cos",
          FontSlant->"Plain"], "\[ThinSpace]", 
         FractionBox[
          RowBox[{
           SubscriptBox["\[CapitalOmega]", 
            StyleBox["R", "TI"]], 
           StyleBox["t", "TI"]}], "2"], "+", 
         StyleBox["i", "TI"], 
         FractionBox[
          StyleBox["\[Delta]", "TI"], 
          SubscriptBox["\[CapitalOmega]", 
           StyleBox["R", "TI"]]], 
         StyleBox["sin",
          FontSlant->"Plain"], "\[ThinSpace]", 
         FractionBox[
          RowBox[{
           SubscriptBox["\[CapitalOmega]", 
            StyleBox["R", "TI"]], 
           StyleBox["t", "TI"]}], "2"]}], ")"}], 
       RowBox[{"-", " ", 
        StyleBox["i", "TI"], " ", 
        SuperscriptBox[
         StyleBox["e", "TI"], 
         RowBox[{"-", 
          StyleBox["i", "TI"], 
          StyleBox["\[Omega]", "TI"], 
          StyleBox["t", "TI"], "/", "2"}]], " ", 
        FractionBox["\[CapitalOmega]", 
         SubscriptBox["\[CapitalOmega]", 
          StyleBox["R", "TI"]]], 
        StyleBox["sin",
         FontSlant->"Plain"], "\[ThinSpace]", 
        FractionBox[
         RowBox[{
          SubscriptBox["\[CapitalOmega]", 
           StyleBox["R", "TI"]], 
          StyleBox["t", "TI"]}], "2"]}]},
      {
       RowBox[{"-", " ", 
        StyleBox["i", "TI"], " ", 
        SuperscriptBox[
         StyleBox["e", "TI"], 
         RowBox[{
          StyleBox["i", "TI"], 
          StyleBox["\[Omega]", "TI"], 
          StyleBox["t", "TI"], "/", "2"}]], " ", 
        FractionBox["\[CapitalOmega]", 
         SubscriptBox["\[CapitalOmega]", 
          StyleBox["R", "TI"]]], 
        StyleBox["sin",
