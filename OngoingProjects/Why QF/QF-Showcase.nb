 RowBox[{"-", "0.31825199045791325`"}]], "Output",
 CellChangeTimes->{3.990277939728716*^9},
 CellLabel->"Out[254]=",
 CellID->1038832997,ExpressionUUID->"00a7220b-b119-49c4-b7dc-6630617732c3"]
