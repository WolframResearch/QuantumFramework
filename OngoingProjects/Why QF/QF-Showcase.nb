             "Gamma"], " ", 
            RowBox[{"(", 
             RowBox[{
              RowBox[{
               RowBox[{"(", 
                RowBox[{"1", "+", "\[ImaginaryI]"}], ")"}], " ", "\[FormalT]",
                " ", 
               SqrtBox["v"], " ", 
               TemplateBox[{
                 RowBox[{"-", 
                   FractionBox[
                    RowBox[{"\[ImaginaryI]", " ", 
                    SuperscriptBox["\[CapitalDelta]", "2"]}], 
                    RowBox[{"4", " ", "v"}]]}], 
