              RowBox[{"4", " ", "v"}]], 
             RowBox[{
               SuperscriptBox[
                RowBox[{"(", 
                  RowBox[{"-", "1"}], ")"}], 
                RowBox[{"3", "/", "4"}]], " ", "\[FormalT]", " ", 
               SqrtBox["v"]}]},
            "ParabolicCylinderD"]}], "+", 
          RowBox[{"2", " ", 
           TemplateBox[{
