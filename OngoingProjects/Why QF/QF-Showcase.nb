Cell[CellGroupData[{

Cell["A phase-space quasi-probability", "Subsection",ExpressionUUID->"5516dd63-6d38-43de-a8f4-e2c01b2bf82c"],

Cell[TextData[{
 "The Wigner function is the phase-space quasi-probability ",
 Cell[BoxData[
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{
        StyleBox["W", "TI"], 
        RowBox[{"(", 
         RowBox[{
          StyleBox["x", "TI"], 
          RowBox[{",", "\[ThinSpace]"}], 
          StyleBox["p", "TI"]}], ")"}]}], "=", 
       RowBox[{
        FractionBox["1", "\[Pi]"], 
        RowBox[{"\[Integral]", 
         RowBox[{
          AdjustmentBox["\[LeftAngleBracket]",
           BoxMargins->{{0, -0.2}, {0, 0}}], 
          RowBox[{
           StyleBox["x", "TI"], "-", 
           StyleBox["y", "TI"]}], " "}]}]}]}], "\[RightBracketingBar]"}], " ", 
     StyleBox["\[Rho]", "TI"], " ", 
     RowBox[{"\[LeftBracketingBar]", " ", 
      RowBox[{
       StyleBox["x", "TI"], "+", 
       StyleBox["y", "TI"]}]}]}], 
    AdjustmentBox["\[RightAngleBracket]",
     BoxMargins->{{-0.2, 0}, {0, 0}}]}], " ", 
   SuperscriptBox[
    StyleBox["e", "TI"], 
    RowBox[{"2", 
     StyleBox["i", "TI"], 
     StyleBox["p", "TI"], 
     StyleBox["y", "TI"]}]], " ", 
   StyleBox["d", "TI"], 
   StyleBox["y", "TI"]}]], "InlineFormula",ExpressionUUID->
  "a5b2984b-c1fb-46ad-a389-561f3a4424a2"],
 ". It integrates to ",
 Cell[BoxData[
 "1"], "InlineFormula",ExpressionUUID->"b62147f6-7b7b-4d89-bb32-6993841ff314"],
 " like a probability density but, unlike one, can go ",
 StyleBox["negative",
  FontWeight->"Bold"],
 ", and that negativity is a signature of nonclassicality with no classical \
or gate-circuit analogue."
}], "Text",ExpressionUUID->"60e1b565-76af-43ce-9819-83ffbee78d42"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"w", " ", "=", " ", 
