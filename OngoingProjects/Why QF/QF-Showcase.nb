                  SqrtBox["v"]}]},
               "HermiteH"]}], ")"}]}]}], ")"}]}], 
        RowBox[{"\[Pi]", " ", "\[CapitalDelta]", " ", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{"csch", "(", 
            FractionBox[
             RowBox[{"\[Pi]", " ", 
