Cell[TextData[{
 "The result is a ",
 Cell[BoxData[
 "Hypergraph"], "InlineFormula",ExpressionUUID->
  "b70b8590-4b5f-467b-a114-c40d27ef7c31"],
 " with thirteen hyperedges, one per tensor, the three ",
 Cell[BoxData[
  RowBox[{"\[LeftBracketingBar]", "0", 
   AdjustmentBox["\[RightAngleBracket]",
    BoxMargins->{{-0.2, 0}, {0, 0}}]}]], "InlineFormula",ExpressionUUID->
  "ed0e7488-3450-4ed5-a740-c8098f10f4e8"],
 " states and the ten gates, drawn over the network's indices: the \
tensor-contraction picture of the same circuit, in which contracting two \
tensors is the merging of two hyperedges."
}], "Text",ExpressionUUID->"b83ca6c3-06d7-458d-806a-00c693c60eaf"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["Claim 5: Open, inspectable, and an interoperability hub", "Section",ExpressionUUID->"812d78c5-eec9-4b46-b6db-1c5d9bef3c82"],

Cell[TextData[{
 StyleBox["Key feature:",
  FontWeight->"Bold"],
 " openness runs in both directions. Inward, the simulation engine is not a \
black box: its central algorithmic choice is exposed as an option. Outward, a \
QF object can ",
 StyleBox["leave", "TI"],
 " QF for the rest of the ecosystem, and foreign circuits can ",
 StyleBox["enter", "TI"],
 " it; ",
 Cell[BoxData[
 "QuantumQASM"], "InlineFormula",ExpressionUUID->
  "6ab8b457-d3df-409f-949c-7e6fe6e527b6"],
 " is the single OpenQASM door, and it runs in pure Wolfram Language with no \
external account."
}], "Text",ExpressionUUID->"c98bd063-9827-47c6-825b-557ca9717135"],

Cell[CellGroupData[{

Cell["Steer the engine: the tensor-network contraction path", "Subsection",ExpressionUUID->"3a3c8383-f50c-49cc-8db8-b81423f03a12"],

Cell[TextData[{
 "Applying a circuit is, by default, a tensor-network contraction, and the ",
 StyleBox["order", "TI"],
 " of the pairwise contractions decides the cost: every step produces an \
intermediate tensor, the expense is set by the largest intermediate the order \
ever creates (in matrix-product language, the bond dimension it forces you to \
carry), and a poor order can be exponentially more expensive than a good one \
on the very same network. QF exposes that choice as a ",
 Cell[BoxData[
 "Method"], "InlineFormula",ExpressionUUID->
  "caae3640-1677-4046-bb30-1d77aa4e757f"],
 " sub-option: ",
 Cell[BoxData[
  RowBox[{"\"\<Path\>\"", " ", "->", " ", "\"\<Greedy\>\""}]], 
  "InlineFormula",ExpressionUUID->"5ff75214-532c-4327-8633-040df597edc6"],
 " or ",
 Cell[BoxData["\"\<Optimal\>\""], "InlineFormula",ExpressionUUID->
  "6761fe4e-9448-46c2-abd4-103820df15ec"],
 " (with the cost objectives ",
 Cell[BoxData["\"\<flops\>\""], "InlineFormula",ExpressionUUID->
  "e00719c6-22cb-4ad0-abae-c6ae7822b854"],
 ", ",
 Cell[BoxData["\"\<size\>\""], "InlineFormula",ExpressionUUID->
  "c89e5523-2529-4893-b702-ce43ab75f863"],
 ", ",
 Cell[BoxData["\"\<write\>\""], "InlineFormula",ExpressionUUID->
  "b84fd242-5425-484b-80d9-6233c5dd4fc2"],
 ", ",
 Cell[BoxData["\"\<combo\>\""], "InlineFormula",ExpressionUUID->
  "4d1bed54-3462-4052-89b9-4b6c24e3604d"],
 "), or an explicit list of pairwise contractions. Apply a 10-qubit GHZ \
circuit through a greedily chosen path and read the nonzero amplitudes:"
}], "Text",ExpressionUUID->"106c8bf8-d2ec-4230-8843-aa8c7db5067e"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"ghz", " ", "=", " ", 
   RowBox[{"QuantumCircuitOperator", "[", 
    RowBox[{"\"\<GHZ\>\"", "[", "10", "]"}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"psi", " ", "=", " ", 
   RowBox[{"ghz", "[", 
    RowBox[{
     RowBox[{"QuantumState", "[", 
      RowBox[{"\"\<Register\>\"", "[", "10", "]"}], "]"}], ",", " ", 
     RowBox[{"Method", " ", "->", " ", 
      RowBox[{"{", 
       RowBox[{"\"\<TensorNetwork\>\"", ",", " ", 
        RowBox[{"\"\<Path\>\"", " ", "->", " ", "\"\<Greedy\>\""}]}], 
       "}"}]}]}], "]"}]}], ";"}], "\n", 
 RowBox[{"Most", " ", "@", " ", 
  RowBox[{"ArrayRules", " ", "@", " ", 
   RowBox[{"psi", "[", "\"\<StateVector\>\"", "]"}]}]}]}], "Input",
 CellLabel->
  "In[311]:=",ExpressionUUID->"777a0deb-4072-4378-9282-34f6b930e272"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{
    RowBox[{"{", "1", "}"}], "\[Rule]", 
    FractionBox["1", 
     SqrtBox["2"]]}], ",", 
   RowBox[{
    RowBox[{"{", "1024", "}"}], "\[Rule]", 
    FractionBox["1", 
     SqrtBox["2"]]}]}], "}"}]], "Output",
 CellChangeTimes->{3.990278172983324*^9},
 CellLabel->"Out[313]=",
 CellID->1950757312,ExpressionUUID->"d9feeb1f-a733-463f-b599-147d26c4a734"]
}, Open  ]],

Cell[TextData[{
 "The state returns with exactly two nonzero amplitudes, ",
 Cell[BoxData[
  RowBox[{"{", "1", "}", "\[Rule]", 
   FractionBox["1", 
    SqrtBox["2"]]}]], "InlineFormula",ExpressionUUID->
  "47b64119-0485-4e39-8a4e-59dc299ce3bb"],
 " and ",
 Cell[BoxData[
  RowBox[{"{", "1024", "}", "\[Rule]", 
   FractionBox["1", 
    SqrtBox["2"]]}]], "InlineFormula",ExpressionUUID->
  "55dc06e1-4bc4-4c01-8b28-b5392ee335db"],
 ", that is ",
 Cell[BoxData[
  SuperscriptBox[
   RowBox[{"\[LeftBracketingBar]", "0", 
    AdjustmentBox["\[RightAngleBracket]",
     BoxMargins->{{-0.2, 0}, {0, 0}}]}], 
   RowBox[{"\[CircleTimes]", "10"}]]], "InlineFormula",ExpressionUUID->
  "7359d3e1-fcd8-4d39-b1bc-37c0c0fa2998"],
 " and ",
 Cell[BoxData[
  SuperscriptBox[
   RowBox[{"\[LeftBracketingBar]", "1", 
    AdjustmentBox["\[RightAngleBracket]",
     BoxMargins->{{-0.2, 0}, {0, 0}}]}], 
   RowBox[{"\[CircleTimes]", "10"}]]], "InlineFormula",ExpressionUUID->
  "184a0ef0-33b8-4758-9344-967a17a92104"],
 ": the GHZ state, computed through an explicitly steered contraction."
}], "Text",ExpressionUUID->"794e041e-3d1d-48de-9b4b-b9c2c0a86367"],

Cell["\<\
The plan itself is an inspectable object. Pull the circuit's tensor network, \
compute the greedy path, and draw the contraction as a tree, each node an \
intermediate tensor labeled by its dimensions:\
\>", "Text",ExpressionUUID->"d591176b-7c8c-4a10-a0ee-d050c125297d"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"net", " ", "=", " ", 
   RowBox[{"ghz", "[", "\"\<TensorNetwork\>\"", "]"}]}], ";"}], "\n", 
 RowBox[{"ContractionTree", "[", 
  RowBox[{
   RowBox[{"TensorNetworkContraction", "[", 
    RowBox[{"net", ",", " ", 
     RowBox[{"GreedyContractionPath", "[", "net", "]"}]}], "]"}], ",", " ", 
   RowBox[{"\"\<Labels\>\"", " ", "->", " ", "\"\<Dimensions\>\""}]}], 
  "]"}]}], "Input",
 CellLabel->
  "In[314]:=",ExpressionUUID->"68eaad41-71ef-47a2-8502-e595f77d5241"],

