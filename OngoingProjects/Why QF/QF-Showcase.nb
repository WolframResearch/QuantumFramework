Cell["Maximize it exactly:", "Text",
 CellID->226904791,ExpressionUUID->"21d2cca8-d9f6-4571-a117-3b626cab6333"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Maximize", "[", 
  RowBox[{"landscape", ",", " ", 
   RowBox[{"{", 
    RowBox[{"\[Theta]", ",", " ", "\[Gamma]"}], "}"}]}], "]"}]], "Input",
 CellLabel->
  "In[216]:=",ExpressionUUID->"a4031ff7-2667-4578-bf65-03b2583a7535"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"2", ",", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"\[Theta]", "\[Rule]", 
      RowBox[{
       RowBox[{
        RowBox[{"-", "5"}], " ", "\[Pi]"}], "-", 
       RowBox[{"ArcTan", "[", 
        FractionBox["1", 
         SqrtBox["2"]], "]"}]}]}], ",", 
     RowBox[{"\[Gamma]", "\[Rule]", 
      RowBox[{
       RowBox[{"-", "2"}], " ", 
       RowBox[{"(", 
        RowBox[{
         RowBox[{"24", " ", "\[Pi]"}], "-", 
         RowBox[{"ArcTan", "[", 
          TemplateBox[<|"icon" -> "Root", "small" -> InterpretationBox[
              StyleBox[
               TemplateBox[{"\"-3.15\"", 
                 DynamicBox[
                  FEPrivate`FrontEndResource[
                  "FEExpressions", "NumericalApproximationElider"]]}, 
                "RowDefault"], ShowStringCharacters -> 
               False], \
-3.14626436994197256069583090720698237419`15.954589770191003, Editable -> 
              False], "approx" -> -3.1462643699419726`, "interp" -> 
            InterpretationBox["", 
              Root[1 - 10 #^2 + #^4& , 1, 0]], "head" -> "Root", "big" -> 
            RowBox[{
               RowBox[{"1", "-", 
                 RowBox[{"10", " ", 
                   SuperscriptBox["#1", "2"]}], "+", 
                 SuperscriptBox["#1", "4"]}], "&"}], "degree" -> "4", 
            "shortDegree" -> "4", "number" -> 1|>,
           "NumericalApproximationInterp"], "]"}]}], ")"}]}]}]}], "}"}]}], 
  "}"}]], "Output",
 CellChangeTimes->{3.990277404159931*^9},
 CellLabel->"Out[216]=",
 CellID->1861215881,ExpressionUUID->"4833d442-f4ed-4447-89c9-d775308a6287"]
}, Open  ]],

Cell[TextData[{
 "The maximum returns as exactly ",
 Cell[BoxData[
 "2"], "InlineFormula",ExpressionUUID->"abbed81a-e66d-4c06-a9d7-92df786ef65f"],
 ", with the optimal angles as closed-form algebraic numbers, and it equals \
",
 Cell[BoxData[
  RowBox[{"FindMaximumCut", "[", "g", "]"}]], "InlineFormula",ExpressionUUID->
  "55c87526-8edc-4219-b004-cbaf1ddce883"],
 ": because the landscape is exact, the variational optimum ",
 StyleBox["provably", "TI"],
 " equals the true cut value, the same way a symbolic VQE expectation lands \
exactly on a Hamiltonian's eigenvalue rather than merely near it."
}], "Text",ExpressionUUID->"2ab21208-12f8-4fc3-ab85-ac08e6d48ee6"]
}, Open  ]],

Cell[CellGroupData[{

Cell["The payoff: a full many-body computation in closed form", "Subsection",ExpressionUUID->"e4520fa2-ce27-4f3f-93f7-e1289d0479eb"],

Cell[TextData[{
 "The same machinery scales to a genuine many-body computation. Build the \
2-qubit Heisenberg Hamiltonian ",
 Cell[BoxData[
  RowBox[{
   StyleBox["H", "TI"], "=", 
   StyleBox["J", "TI"], " ", "(", 
   RowBox[{
    StyleBox["X", "TI"], 
    StyleBox["X", "TI"], "+", 
    StyleBox["Y", "TI"], 
    StyleBox["Y", "TI"], "+", 
    StyleBox["Z", "TI"], 
    StyleBox["Z", "TI"]}], ")"}]], "InlineFormula",ExpressionUUID->
  "523b9e44-1f6d-4082-978d-96cd1d562c86"],
 " symbolically (Hamiltonian simulation, the workhorse application of a \
quantum computer):"
}], "Text",ExpressionUUID->"5af353ad-8548-4bcb-9131-2f36c36b4a30"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"H", " ", "=", " ", 
  RowBox[{"J", " ", 
   RowBox[{"(", 
    RowBox[{
     RowBox[{"QuantumOperator", "[", "\"\<XX\>\"", "]"}], " ", "+", " ", 
     RowBox[{"QuantumOperator", "[", "\"\<YY\>\"", "]"}], " ", "+", " ", 
     RowBox[{"QuantumOperator", "[", "\"\<ZZ\>\"", "]"}]}], 
    ")"}]}]}]], "Input",
 CellChangeTimes->{{3.990277408339759*^9, 3.990277408982637*^9}},
 CellLabel->
  "In[217]:=",ExpressionUUID->"4fd6eaab-0661-43d7-af37-9a0324689ea5"],

Cell[BoxData[
 InterpretationBox[
  RowBox[{
   TagBox["QuantumOperator",
    "SummaryHead"], "[", 
   DynamicModuleBox[{Typeset`open$$ = False, Typeset`embedState$$ = "Ready"}, 
    
    TemplateBox[{
      PaneSelectorBox[{False -> GridBox[{{
            PaneBox[
             ButtonBox[
              DynamicBox[
               FEPrivate`FrontEndResource["FEBitmaps", "SummaryBoxOpener"]], 
              ButtonFunction :> (Typeset`open$$ = True), Appearance -> None, 
              BaseStyle -> {}, Evaluator -> Automatic, Method -> 
              "Preemptive"], Alignment -> {Center, Center}, ImageSize -> 
             Dynamic[{
               Automatic, 
                3.5 (CurrentValue["FontCapHeight"]/AbsoluteCurrentValue[
                 Magnification])}]], 
            TagBox[
             TooltipBox[
              GraphicsBox[
               RasterBox[CompressedData["
1:eJxTTMoPSmVmYGBggWIQ22Z77JEJtm/t+xzzdh6aeNFeUVW4xln+vD2p4oac
rT+s1r23n3d7xQUFlnf2Kx8KMdcWvcKp/tSXBV9K9d7bK6Vv7vwj8M5eZd0+
yYM7X9hPW1iZ2uj13j7Q7tAzxU9v7Y2q2VZq33hBsntwmYPLXmr5i1RxAHeL
ttw=
                "], {{0, 0}, {4, 4}}, {0, 1}], {
               DisplayFunction -> Identity, PlotRange -> All, 
                PlotInteractivity :> True, 
                DefaultBaseStyle -> {"PlotGraphics", "Graphics"}, 
                DisplayFunction -> Identity, PlotInteractivity :> True, 
                DefaultBaseStyle -> {"PlotGraphics", "Graphics"}, Background -> 
                RGBColor[1, 1, 1, 0], DisplayFunction -> Identity, Frame -> 
                False, FrameLabel -> {None, None}, 
                FrameTicks -> {{None, None}, {None, None}}, GridLinesStyle -> 
                Directive[
                  GrayLevel[0.5, 0.4]], ImageSize -> 
                Dynamic[{
                  Automatic, 
                   3.5 (CurrentValue["FontCapHeight"]/AbsoluteCurrentValue[
                    Magnification])}], 
                Method -> {
                 "GridLinesInFront" -> True, "DefaultBoundaryStyle" -> 
                  Automatic, 
                  "DefaultGraphicsInteraction" -> {
                   "Version" -> 1.2, "TrackMousePosition" -> {True, False}, 
                    "Effects" -> {
                    "Highlight" -> {"ratio" -> 2}, 
                    "HighlightPoint" -> {"ratio" -> 2}, 
                    "Droplines" -> {
                    "freeformCursorMode" -> True, 
                    "placement" -> {"x" -> "All", "y" -> "None"}}}}, 
                  "DefaultPlotStyle" -> Automatic}, PlotRangeClipping -> 
                True}], 
              RowBox[{"J", " ", 
                RowBox[{"(", 
                  RowBox[{
                    TemplateBox[{"\"X\"", 
                    RowBox[{"\[CircleTimes]", "2"}]}, "Superscript", 
                    SyntaxForm -> SuperscriptBox], "+", 
                    TemplateBox[{"\"Y\"", 
                    RowBox[{"\[CircleTimes]", "2"}]}, "Superscript", 
                    SyntaxForm -> SuperscriptBox], "+", 
                    TemplateBox[{"\"Z\"", 
                    RowBox[{"\[CircleTimes]", "2"}]}, "Superscript", 
                    SyntaxForm -> SuperscriptBox]}], ")"}]}]], 
             Annotation[#, $CellContext`J (Superscript["X", 
                 CircleTimes[2]] + Superscript["Y", 
                 CircleTimes[2]] + Superscript["Z", 
                 CircleTimes[2]]), "Tooltip"]& ], 
            GridBox[{{
               TagBox[
                TemplateBox[{"\"Pure\"", "\" \"", "\"map\""}, "RowDefault"], 
                "SummaryItem"], ""}, {
               RowBox[{
                 TagBox["\"Dimension: \"", "SummaryItemAnnotation"], 
                 "\[InvisibleSpace]", 
                 TagBox[
                  TemplateBox[{"4", "\"\[RightArrow]\"", "4"}, "RowDefault"], 
                  "SummaryItem"]}], 
               RowBox[{
                 TagBox["\"Order: \"", "SummaryItemAnnotation"], 
                 "\[InvisibleSpace]", 
                 TagBox[
                  TemplateBox[{
                    RowBox[{"{", 
                    RowBox[{"1", ",", "2"}], "}"}], "\"\[RightArrow]\"", 
                    RowBox[{"{", 
                    RowBox[{"1", ",", "2"}], "}"}]}, "RowDefault"], 
