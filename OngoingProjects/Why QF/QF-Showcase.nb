Cell[TextData[{
 "Verified: ",
 Cell[BoxData[
  RowBox[{
   StyleBox["W", "TI"], "(", 
   RowBox[{"0", ",", "0"}], ")", "=", "-", "0.318", "<", "0"}]], 
  "InlineFormula",ExpressionUUID->"ef4f2bdc-8eff-48a8-80cc-572e85d53ff5"],
 ". The single photon has a negative dip at the origin. The whole surface \
plots directly:"
}], "Text",ExpressionUUID->"3a4293cf-a21e-47b2-9650-b8bee14da636"],

