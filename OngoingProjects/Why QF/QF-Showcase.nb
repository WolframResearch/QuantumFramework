Cell[TextData[{
 "Because the field direction turns, ",
 Cell[BoxData[
  StyleBox["H", "TI"]], "InlineFormula",ExpressionUUID->
  "fd6bb524-7a91-46bb-855e-81019d854ec8"],
 " does ",
 StyleBox["not commute with itself at different times",
  FontWeight->"Bold"],
 ", so the propagator is not simply ",
 Cell[BoxData[
  SuperscriptBox[
   StyleBox["e", "TI"], 
   RowBox[{"-", 
    StyleBox["i", "TI"], "\[Integral]", 
    StyleBox["H", "TI"], " ", 
    StyleBox["d", "TI"], 
    StyleBox["t", "TI"]}]]], "InlineFormula",ExpressionUUID->
  "18d336ca-0837-4c31-8537-d54f1e9e6987"],
 "; it needs genuine time-ordering. Check the non-commutativity directly:"
}], "Text",ExpressionUUID->"03f5a5e4-5f57-4817-89f2-48b5e36ff691"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"Hm", "[", "t_", "]"}], " ", ":=", " ", 
   RowBox[{
    RowBox[{"Normal", "[", 
     RowBox[{"H", "[", "\"\<Matrix\>\"", "]"}], "]"}], " ", "/.", " ", 
    RowBox[{"\[FormalT]", " ", "->", " ", "t"}]}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"Commutator", "[", 
   RowBox[{
    RowBox[{"Hm", "[", "t1", "]"}], ",", " ", 
    RowBox[{"Hm", "[", "t2", "]"}], ",", " ", "Dot"}], "]"}], "//", 
  "FullSimplify"}]}], "Input",
 CellChangeTimes->{{3.990277194580695*^9, 3.990277220330101*^9}},
 CellLabel->
  "In[189]:=",ExpressionUUID->"e21e5916-6442-4811-9bf7-9e77cf8f6681"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{
      RowBox[{"-", 
       FractionBox["1", "2"]}], " ", "\[ImaginaryI]", " ", 
      SuperscriptBox["\[CapitalOmega]", "2"], " ", 
      RowBox[{"Sin", "[", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{"t1", "-", "t2"}], ")"}], " ", "\[Omega]"}], "]"}]}], ",", 
     RowBox[{
      FractionBox["1", "2"], " ", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{"-", 
         SuperscriptBox["\[ExponentialE]", 
          RowBox[{
           RowBox[{"-", "\[ImaginaryI]"}], " ", "t1", " ", "\[Omega]"}]]}], "+", 
        SuperscriptBox["\[ExponentialE]", 
         RowBox[{
          RowBox[{"-", "\[ImaginaryI]"}], " ", "t2", " ", "\[Omega]"}]]}], 
       ")"}], " ", "\[CapitalOmega]", " ", "\[Omega]0"}]}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{
      FractionBox["1", "2"], " ", 
      RowBox[{"(", 
       RowBox[{
        SuperscriptBox["\[ExponentialE]", 
         RowBox[{"\[ImaginaryI]", " ", "t1", " ", "\[Omega]"}]], "-", 
        SuperscriptBox["\[ExponentialE]", 
         RowBox[{"\[ImaginaryI]", " ", "t2", " ", "\[Omega]"}]]}], ")"}], " ",
       "\[CapitalOmega]", " ", "\[Omega]0"}], ",", 
     RowBox[{
      FractionBox["1", "2"], " ", "\[ImaginaryI]", " ", 
      SuperscriptBox["\[CapitalOmega]", "2"], " ", 
      RowBox[{"Sin", "[", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{"t1", "-", "t2"}], ")"}], " ", "\[Omega]"}], "]"}]}]}], 
    "}"}]}], "}"}]], "Output",
 CellChangeTimes->{{3.990277186630921*^9, 3.99027722089203*^9}},
 CellLabel->"Out[190]=",
 CellID->1432722573,ExpressionUUID->"0b7d3415-2c9a-4cd0-9502-cf1e63b5252c"]
}, Open  ]],

Cell[TextData[{
 "The commutator is nonzero, its diagonal carrying ",
 Cell[BoxData[
  RowBox[{"\[MinusPlus]", 
   FractionBox[
    StyleBox["i", "TI"], "2"], 
   SuperscriptBox["\[CapitalOmega]", "2"], 
   StyleBox["sin",
    FontSlant->"Plain"]}]], "InlineFormula",ExpressionUUID->
  "31b5f3b1-4c76-4b9c-9f88-19c1954e6c81"],
 ": this is the genuinely hard, time-ordered case, not a disguised static \
problem."
}], "Text",ExpressionUUID->"f8ca38ae-95aa-43c7-a3a0-fc1ab7dcdc64"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Its propagator, in closed form", "Subsection",ExpressionUUID->"af0d146e-662c-43ed-b2df-75788b6c83f4"],

Cell[TextData[{
 Cell[BoxData[
 "QuantumEvolve"], "InlineFormula",ExpressionUUID->
  "1b94ea9d-31c7-48ff-8dee-91bfdf747033"],
 " integrates the time-dependent Schrodinger equation ",
 Cell[BoxData[
  RowBox[{
   StyleBox["i", "TI"], " ", 
   SubscriptBox["\[PartialD]", 
    StyleBox["t", "TI"]], 
   StyleBox["U", "TI"], "=", 
   StyleBox["H", "TI"], "(", 
   StyleBox["t", "TI"], ")", " ", 
   StyleBox["U", "TI"]}]], "InlineFormula",ExpressionUUID->
  "7551c54e-3ba6-4d31-a17f-1128384bbab9"],
 " and returns the propagator ",
 Cell[BoxData[
  RowBox[{
   StyleBox["U", "TI"], "(", 
   StyleBox["t", "TI"], ")"}]], "InlineFormula",ExpressionUUID->
  "ec0bbe2d-bf65-4209-9a78-4a7312585c59"],
 " symbolically. (Verified here: ",
 Cell[BoxData[
  RowBox[{
   StyleBox["U", "TI"], "(", "0", ")", "=", 
   StyleBox["I", "TI"]}]], "InlineFormula",ExpressionUUID->
  "33cf3b07-1fb6-4b46-a538-ddef037e0a8c"],
 " and ",
 Cell[BoxData[
  RowBox[{
   StyleBox["i", "TI"], " ", 
   SuperscriptBox[
    StyleBox["U", "TI"], "\[Prime]"], "(", 
   StyleBox["t", "TI"], ")", "-", 
   StyleBox["H", "TI"], "(", 
   StyleBox["t", "TI"], ")", " ", 
   StyleBox["U", "TI"], "(", 
   StyleBox["t", "TI"], ")", "=", "0"}]], "InlineFormula",ExpressionUUID->
  "905ee927-8942-4c58-8c67-2d3b162524a4"],
 " exactly.)"
}], "Text",ExpressionUUID->"5a1acfa6-3a84-41af-81a9-43ecae2a48f8"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"U", " ", "=", " ", 
  RowBox[{"QuantumEvolve", "[", 
   RowBox[{"H", ",", " ", "None"}], "]"}]}]], "Input",
 CellChangeTimes->{3.990277286942513*^9},
 CellLabel->
  "In[191]:=",ExpressionUUID->"1a532c0f-794d-4107-a5d9-ac9666c60bcd"],

