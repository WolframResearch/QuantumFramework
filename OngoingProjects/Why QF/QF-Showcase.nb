Cell[BoxData[
 FormBox[
  RowBox[{"(", "\[NoBreak]", GridBox[{
     {
      RowBox[{
       SuperscriptBox["\[ExponentialE]", 
        RowBox[{
         RowBox[{"-", 
          FractionBox["1", "4"]}], " ", "\[ImaginaryI]", " ", 
         SuperscriptBox["\[FormalT]", "2"], " ", "v"}]], " ", 
       TemplateBox[{
         FractionBox[
          RowBox[{"\[ImaginaryI]", " ", 
            SuperscriptBox["\[CapitalDelta]", "2"]}], 
          RowBox[{"8", " ", "v"}]], 
