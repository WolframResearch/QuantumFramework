}, Open  ]],

Cell[TextData[{
 "The same state spreads into a three-term superposition over the ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["J", "TI"], 
   StyleBox["z", "TI"]]], "InlineFormula",ExpressionUUID->
  "1362060a-1727-4d0a-8a75-2d508e6a56c3"],
 " levels: one ket in its own basis, a sum in the other. The named operator \
",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["J", "TI"], 
   StyleBox["x", "TI"]]], "InlineFormula",ExpressionUUID->
  "b9932ed2-6c0b-43a5-b537-0122ad64b1e1"],
 " is itself stored in its ",
 StyleBox["own", "TI"],
 " eigenbasis, so the expectation ",
 Cell[BoxData[
  RowBox[{
   AdjustmentBox["\[LeftAngleBracket]",
    BoxMargins->{{0, -0.2}, {0, 0}}], 
   SubscriptBox[
    StyleBox["J", "TI"], 
    StyleBox["x", "TI"]], 
   AdjustmentBox["\[RightAngleBracket]",
    BoxMargins->{{-0.2, 0}, {0, 0}}], "=", 
   AdjustmentBox["\[LeftAngleBracket]",
    BoxMargins->{{0, -0.2}, {0, 0}}], 
   StyleBox["\[Psi]", "TI"], "\[RightBracketingBar]", 
   SubscriptBox[
    StyleBox["J", "TI"], 
    StyleBox["x", "TI"]], "\[LeftBracketingBar]", 
   StyleBox["\[Psi]", "TI"], 
   AdjustmentBox["\[RightAngleBracket]",
    BoxMargins->{{-0.2, 0}, {0, 0}}]}]], "InlineFormula",ExpressionUUID->
  "3523ab9c-36bc-4883-a349-c249fcc1fe29"],
 " mixes three declared bases at once; compute it from both representations \
of the state:"
}], "Text",ExpressionUUID->"65c2ee71-2e78-4e53-b01a-f5ae1173f51d"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"<|", 
  RowBox[{
   RowBox[{"\"\<JX basis\>\"", " ", "->", " ", 
    RowBox[{
     RowBox[{
      RowBox[{"mx", "[", "\"\<Dagger\>\"", "]"}], "[", 
      RowBox[{
       RowBox[{"QuantumOperator", "[", 
        RowBox[{"\"\<JX\>\"", "[", "1", "]"}], "]"}], "[", "mx", "]"}], "]"}],
      "[", "\"\<Scalar\>\"", "]"}]}], ",", "\n", "  ", 
   RowBox[{"\"\<Computational basis\>\"", " ", "->", " ", 
    RowBox[{
     RowBox[{
      RowBox[{"mxZ", "[", "\"\<Dagger\>\"", "]"}], "[", 
      RowBox[{
       RowBox[{"QuantumOperator", "[", 
        RowBox[{"\"\<JX\>\"", "[", "1", "]"}], "]"}], "[", "mxZ", "]"}], 
      "]"}], "[", "\"\<Scalar\>\"", "]"}]}]}], "|>"}]], "Input",
 CellLabel->
  "In[270]:=",ExpressionUUID->"8a9a6a64-125d-4663-a584-7b912bf5d543"],

Cell[BoxData[
 RowBox[{"\[LeftAssociation]", 
  RowBox[{
   RowBox[{"\<\"JX basis\"\>", "\[Rule]", "1"}], ",", 
   RowBox[{"\<\"Computational basis\"\>", "\[Rule]", "1"}]}], 
  "\[RightAssociation]"}]], "Output",
 CellChangeTimes->{3.990278073531925*^9},
 CellLabel->"Out[270]=",
 CellID->1934394735,ExpressionUUID->"397f8559-ee47-4bb9-9baf-3f43eb220b00"]
}, Open  ]],

Cell[TextData[{
 "Both entries return as ",
 Cell[BoxData[
  RowBox[{
   AdjustmentBox["\[LeftAngleBracket]",
    BoxMargins->{{0, -0.2}, {0, 0}}], 
   SubscriptBox[
    StyleBox["J", "TI"], 
    StyleBox["x", "TI"]], 
   AdjustmentBox["\[RightAngleBracket]",
    BoxMargins->{{-0.2, 0}, {0, 0}}], "=", "1"}]], "InlineFormula",
  ExpressionUUID->"6d61f178-208a-443d-aefd-bc5cf6d64c7d"],
 ": the state in either coordinate system, the operator in a third, and QF \
reconciled them all; the invariant survives every change of coordinates."
}], "Text",ExpressionUUID->"b3fabe2e-849b-4d0f-ad46-5b7be46ba7e1"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Any finite dimension: a spin-1 qutrit and a five-site ring", \
"Subsection",ExpressionUUID->"c736cf59-faff-404f-a437-da66a1761cba"],

Cell[TextData[{
 "A spin-1 particle, an NV-center defect for instance, is a genuine \
three-level system. Build its zero-field-splitting Hamiltonian ",
 Cell[BoxData[
  RowBox[{
   StyleBox["H", "TI"], "=", "2", 
   StyleBox["d", "TI"], " ", 
   SubsuperscriptBox[
    StyleBox["J", "TI"], 
    StyleBox["z", "TI"], "2"], "+", 
   StyleBox["e", "TI"], " ", "(", 
   RowBox[{
    SubsuperscriptBox[
     StyleBox["J", "TI"], 
     StyleBox["x", "TI"], "2"], "-", 
    SubsuperscriptBox[
     StyleBox["J", "TI"], 
     StyleBox["y", "TI"], "2"]}], ")"}]], "InlineFormula",ExpressionUUID->
  "e617275b-a503-4968-bd4f-7064f16adae6"],
 " from QF's native spin-1 operators, with both couplings left symbolic:"
}], "Text",ExpressionUUID->"82d5d2b5-6aec-4742-b7b6-2729a09d1b19"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"{", 
    RowBox[{"Jx", ",", " ", "Jy", ",", " ", "Jz"}], "}"}], " ", "=", " ", 
   RowBox[{"QuantumOperator", " ", "/@", " ", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"\"\<JX\>\"", "[", "1", "]"}], ",", " ", 
      RowBox[{"\"\<JY\>\"", "[", "1", "]"}], ",", " ", 
      RowBox[{"\"\<JZ\>\"", "[", "1", "]"}]}], "}"}]}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"H", " ", "=", " ", 
   RowBox[{
    RowBox[{"2", " ", "\[FormalD]", " ", 
     RowBox[{"Jz", "^", "2"}]}], " ", "+", " ", 
    RowBox[{"\[FormalE]", " ", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{"Jx", "^", "2"}], " ", "-", " ", 
       RowBox[{"Jy", "^", "2"}]}], ")"}]}]}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"H", "[", "\"\<Matrix\>\"", "]"}], " ", "//", " ", 
  "MatrixForm"}]}], "Input",
 CellLabel->
  "In[271]:=",ExpressionUUID->"efb7f075-1506-4146-a06a-421f4b8760c1"],

Cell[BoxData[
 TagBox[
  RowBox[{"(", "\[NoBreak]", GridBox[{
     {
      RowBox[{"\[FormalD]", "+", 
       FractionBox["\[FormalE]", "2"]}], "0", 
      RowBox[{"\[FormalD]", "+", 
       FractionBox["\[FormalE]", "2"]}]},
     {"0", 
      RowBox[{
       RowBox[{"2", " ", "\[FormalD]"}], "-", "\[FormalE]"}], "0"},
     {
      RowBox[{"\[FormalD]", "+", 
       FractionBox["\[FormalE]", "2"]}], "0", 
      RowBox[{"\[FormalD]", "+", 
       FractionBox["\[FormalE]", "2"]}]}
    },
    GridBoxAlignment->{"Columns" -> {{Center}}, "Rows" -> {{Baseline}}},
    GridBoxSpacings->{"Columns" -> {
        Offset[0.27999999999999997`], {
         Offset[0.7]}, 
        Offset[0.27999999999999997`]}, "Rows" -> {
        Offset[0.2], {
         Offset[0.4]}, 
        Offset[0.2]}}], "\[NoBreak]", ")"}],
  Function[BoxForm`e$, 
   MatrixForm[
   SparseArray[
    Automatic, {3, 3}, 0, {
     1, {{0, 2, 3, 5}, {{1}, {3}, {2}, {1}, {3}}}, {\[FormalD] + 
       Rational[1, 2] \[FormalE], \[FormalD] + Rational[1, 2] \[FormalE], 
       2 \[FormalD] - \[FormalE], \[FormalD] + 
       Rational[1, 2] \[FormalE], \[FormalD] + 
       Rational[1, 2] \[FormalE]}}]]]]], "Output",
 CellChangeTimes->{3.9902780763964252`*^9},
 CellLabel->"Out[273]//MatrixForm=",
 CellID->2130413123,ExpressionUUID->"d430b982-6dea-44ee-b3f6-2fd66fdc2926"]
}, Open  ]],

Cell[TextData[{
 "The operator returns fully symbolic, and its matrix displays in the basis \
the algebra carried along, the ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["J", "TI"], 
   StyleBox["x", "TI"]]], "InlineFormula",ExpressionUUID->
  "dece5ad1-a498-4718-968b-e3ba4dd86e1f"],
 " eigenbasis: the couplings stay symbols, and the coordinates stay attached \
to the object."
}], "Text",ExpressionUUID->"f2457c78-9a57-41b4-9bcc-8e20a771083e"],

Cell[TextData[{
 "A Hamiltonian is simplest in its energy eigenbasis, and the operator hands \
over its own eigenvectors. Build a basis from them and read ",
 Cell[BoxData[
  StyleBox["H", "TI"]], "InlineFormula",ExpressionUUID->
  "2668f32b-425a-4eb4-b2f7-86c9af75be3e"],
 " there:"
}], "Text",ExpressionUUID->"175c9c67-8a47-4078-94fe-fdbff6366631"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"QuantumOperator", "[", 
      RowBox[{"H", ",", " ", 
       RowBox[{"QuantumBasis", "[", 
        RowBox[{"H", "[", "\"\<Eigenvectors\>\"", "]"}], "]"}]}], "]"}], 
     "[", "\"\<Matrix\>\"", "]"}], " ", "//", " ", "Normal"}], " ", "//", " ",
    "FullSimplify"}], "//", "MatrixForm"}]], "Input",
 CellChangeTimes->{{3.990278083994626*^9, 3.990278085408736*^9}},
 CellLabel->
  "In[275]:=",ExpressionUUID->"09afd7a4-0c6a-431d-a2b6-6e5ca4dfe581"],

Cell[BoxData[
 TagBox[
  RowBox[{"(", "\[NoBreak]", GridBox[{
     {"0", "0", "0"},
     {"0", 
      RowBox[{
       RowBox[{"2", " ", "\[FormalD]"}], "-", "\[FormalE]"}], "0"},
     {"0", "0", 
      RowBox[{
       RowBox[{"2", " ", "\[FormalD]"}], "+", "\[FormalE]"}]}
    },
    GridBoxAlignment->{"Columns" -> {{Center}}, "Rows" -> {{Baseline}}},
    GridBoxSpacings->{"Columns" -> {
        Offset[0.27999999999999997`], {
         Offset[0.7]}, 
        Offset[0.27999999999999997`]}, "Rows" -> {
        Offset[0.2], {
         Offset[0.4]}, 
        Offset[0.2]}}], "\[NoBreak]", ")"}],
  Function[BoxForm`e$, 
   MatrixForm[BoxForm`e$]]]], "Output",
 CellChangeTimes->{{3.990278080173812*^9, 3.990278085731887*^9}},
 CellLabel->"Out[275]//MatrixForm=",
 CellID->1880966305,ExpressionUUID->"cbefc5f7-6cd8-425a-bd12-70f024928919"]
}, Open  ]],

Cell[TextData[{
 "The matrix returns exactly as ",
 Cell[BoxData[
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{
      StyleBox["diag",
       FontSlant->"Plain"], 
      StyleBox["(",
       Magnification->1.2], "0"}], 
     RowBox[{",", "\[ThinSpace]"}], " ", "2", 
     StyleBox["d", "TI"]}], "-", 
    RowBox[{
     StyleBox["e", "TI"], 
     RowBox[{",", "\[ThinSpace]"}], " ", "2", 
     StyleBox["d", "TI"]}], "+", 
    StyleBox["e", "TI"]}], 
   StyleBox[")",
    Magnification->1.2]}]], "InlineFormula",ExpressionUUID->
  "a1d0bc10-169c-4cef-b507-f1a56827c3b0"],
 ": the zero-field-split spectrum in closed form, symbols intact. Building a \
basis from an object's own eigenvectors works in any dimension, and the spin-",
 Cell[BoxData[
  StyleBox["j", "TI"]], "InlineFormula",ExpressionUUID->
  "326631f8-2311-4961-8093-6b615ed6d792"],
 " operators ship natively for every ",
 Cell[BoxData[
  StyleBox["j", "TI"]], "InlineFormula",ExpressionUUID->
  "ad5330aa-a9a7-4bf8-bdd3-883264218e33"],
 "."
}], "Text",ExpressionUUID->"3669ddc1-7ad4-4c40-9ca9-321f8fa6b3e2"],

Cell[TextData[{
 "Dimension need not be a power of two either. A particle hopping on an ",
 Cell[BoxData[
  StyleBox["N", "TI"]], "InlineFormula",ExpressionUUID->
  "f1ff2007-af25-4616-8243-e162f37801f7"],
 "-site ring lives in an ",
 Cell[BoxData[
  StyleBox["N", "TI"]], "InlineFormula",ExpressionUUID->
  "9e19ee12-4392-4c0d-ba95-2fad986b4202"],
 "-dimensional Hilbert space, here ",
 Cell[BoxData[
  RowBox[{
   StyleBox["N", "TI"], "=", "5"}]], "InlineFormula",ExpressionUUID->
  "3f403ba3-46ed-4ead-a83f-13f0b873008d"],
 "; its hopping Hamiltonian is sparse in the site basis but, by Bloch's \
theorem, diagonal in the momentum (Fourier) basis:"
}], "Text",ExpressionUUID->"dbc38b1e-abf1-440c-b77e-51ad80cda441"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"n", " ", "=", " ", "5"}], ";"}], "\n", 
 RowBox[{
  RowBox[{"ring", " ", "=", " ", 
   RowBox[{"-", 
    RowBox[{"Table", "[", 
     RowBox[{
      RowBox[{"Boole", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"Mod", "[", 
          RowBox[{
           RowBox[{"i", " ", "-", " ", "j"}], ",", " ", "n"}], "]"}], " ", "==",
          " ", "1"}], " ", "||", " ", 
        RowBox[{
         RowBox[{"Mod", "[", 
          RowBox[{
           RowBox[{"j", " ", "-", " ", "i"}], ",", " ", "n"}], "]"}], " ", "==",
          " ", "1"}]}], "]"}], ",", " ", 
      RowBox[{"{", 
       RowBox[{"i", ",", " ", "n"}], "}"}], ",", " ", 
      RowBox[{"{", 
       RowBox[{"j", ",", " ", "n"}], "}"}]}], "]"}]}]}], ";"}], "\n", 
 RowBox[{"Normal", " ", "@", " ", 
  RowBox[{"Chop", " ", "@", " ", 
   RowBox[{"N", " ", "@", " ", 
    RowBox[{"Diagonal", "[", 
     RowBox[{
      RowBox[{"QuantumOperator", "[", 
       RowBox[{
        RowBox[{"QuantumOperator", "[", "ring", "]"}], ",", " ", 
        RowBox[{"QuantumBasis", "[", 
         RowBox[{"\"\<Fourier\>\"", "[", "n", "]"}], "]"}]}], "]"}], 
      "[", "\"\<Matrix\>\"", "]"}], "]"}]}]}]}]}], "Input",
 CellLabel->
  "In[276]:=",ExpressionUUID->"5afb27c5-45fc-4f34-8891-455c826dc1f5"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{"-", "2.000000000000001`"}], ",", 
   RowBox[{"-", "0.6180339887498949`"}], ",", "1.6180339887498951`", ",", 
   "1.6180339887498951`", ",", 
   RowBox[{"-", "0.6180339887498949`"}]}], "}"}]], "Output",
 CellChangeTimes->{3.990278091822192*^9},
 CellLabel->"Out[278]=",
 CellID->1991847215,ExpressionUUID->"40e8b2a9-4103-4080-bb6a-c0c23e43ced0"]
}, Open  ]],

Cell[TextData[{
 "The diagonal returns exactly the tight-binding dispersion ",
 Cell[BoxData[
  RowBox[{
   StyleBox["E", "TI"], "(", 
   StyleBox["k", "TI"], ")", "=", "-", "2", 
   StyleBox["cos",
    FontSlant->"Plain"], "\[ThinSpace]", "(", 
   RowBox[{"2", "\[Pi]", 
    StyleBox["k", "TI"], "/", 
    StyleBox["N", "TI"]}], ")"}]], "InlineFormula",ExpressionUUID->
  "1619be08-0f02-436e-a6b3-2b19aebed10d"],
 " at the five Bloch momenta, and the off-diagonal terms vanish: a five-level \
system, diagonalized by a named basis the same way a qubit would be."
}], "Text",ExpressionUUID->"ea29660e-ff53-43ae-926e-6f7a6045f6f5"]
}, Open  ]],

Cell[CellGroupData[{

Cell["A stabilizer state: the state as its symmetry group", "Subsection",ExpressionUUID->"ee10ab98-7364-4cbe-8111-a5ca216e1b49"],

Cell[TextData[{
 "The model also spans ",
 StyleBox["representations", "TI"],
 ": a stabilizer state is stored not as ",
 Cell[BoxData[
  SuperscriptBox["2", 
   StyleBox["n", "TI"]]], "InlineFormula",ExpressionUUID->
  "72e04788-764a-43e2-b8c0-09cccaeaf668"],
 " amplitudes but as the group of Pauli operators that fix it, its stabilizer \
generators, kept in a binary symplectic tableau. Build the GHZ state in this \
representation and read its generators:"
}], "Text",ExpressionUUID->"49f9e299-45a2-4db5-b589-e2e2405675b4"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"ps", " ", "=", " ", 
   RowBox[{"PauliStabilizer", "[", "\"\<GHZ\>\"", "]"}]}], ";"}], "\n", 
 RowBox[{"ps", "[", "\"\<PauliForm\>\"", "]"}]}], "Input",
 CellLabel->
  "In[279]:=",ExpressionUUID->"4e1774ec-94ca-4c72-be49-7d21e77bcaee"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"\<\"XXX\"\>", ",", "\<\"ZZI\"\>", ",", "\<\"IZZ\"\>"}], 
  "}"}]], "Output",
 CellChangeTimes->{3.990278097069687*^9},
 CellLabel->"Out[280]=",
 CellID->1403068363,ExpressionUUID->"1354498f-0f07-4d13-b1cf-163614e5e12b"]
}, Open  ]],

Cell[TextData[{
 "Three Pauli strings return and determine the eight-amplitude state \
completely. This is the Gottesman-Knill representation, in which a Clifford \
gate is a constant-size rewrite of the tableau rather than a ",
 Cell[BoxData[
  RowBox[{
   SuperscriptBox["2", 
    StyleBox["n", "TI"]], "\[Times]", 
   SuperscriptBox["2", 
    StyleBox["n", "TI"]]}]], "InlineFormula",ExpressionUUID->
  "09bde25d-0109-48a5-b87d-197bf942d415"],
 " matrix product."
}], "Text",ExpressionUUID->"9f269235-b91e-4f81-81e9-981c85fb6eb2"],

Cell["\<\
Pauli expectations are closed-form algebra on the generators, with no state \
vector anywhere:\
\>", "Text",ExpressionUUID->"7142353b-a15a-42db-8856-9ec1a52ce794"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"<|", 
  RowBox[{
   RowBox[{"\"\<XXX\>\"", " ", "->", " ", 
    RowBox[{"ps", "[", 
     RowBox[{"\"\<Expectation\>\"", ",", " ", "\"\<XXX\>\""}], "]"}]}], ",", 
   " ", 
   RowBox[{"\"\<ZZI\>\"", " ", "->", " ", 
    RowBox[{"ps", "[", 
     RowBox[{"\"\<Expectation\>\"", ",", " ", "\"\<ZZI\>\""}], "]"}]}], ",", 
   " ", 
   RowBox[{"\"\<ZII\>\"", " ", "->", " ", 
    RowBox[{"ps", "[", 
     RowBox[{"\"\<Expectation\>\"", ",", " ", "\"\<ZII\>\""}], "]"}]}]}], 
  "|>"}]], "Input",
 CellLabel->
  "In[281]:=",ExpressionUUID->"0008d1e2-9427-42d4-b3bf-d82c0e988216"],

Cell[BoxData[
 RowBox[{"\[LeftAssociation]", 
  RowBox[{
   RowBox[{"\<\"XXX\"\>", "\[Rule]", "1"}], ",", 
   RowBox[{"\<\"ZZI\"\>", "\[Rule]", "1"}], ",", 
   RowBox[{"\<\"ZII\"\>", "\[Rule]", "0"}]}], 
  "\[RightAssociation]"}]], "Output",
 CellChangeTimes->{3.990278099074086*^9},
 CellLabel->"Out[281]=",
 CellID->1044262965,ExpressionUUID->"1744c8bd-14de-4439-8c83-a9f69d88e000"]
}, Open  ]],

Cell[TextData[{
 "The two stabilizers return deterministically ",
 Cell[BoxData[
  RowBox[{"+", "1"}]], "InlineFormula",ExpressionUUID->
  "399118f6-0cd0-499b-87e8-70cd47fe1671"],
 ", while the unstabilized single-qubit ",
 Cell[BoxData[
  StyleBox["Z", "TI"]], "InlineFormula",ExpressionUUID->
  "e144107c-caff-4560-8bdb-6d74b87534f7"],
 " is exactly unbiased, all read off by ",
 Cell[BoxData[
  SubscriptBox["\|01d53d", "2"]], "InlineFormula",ExpressionUUID->
  "becdd585-4791-417f-ba2c-35a15e14fb92"],
 " phase tracking."
}], "Text",ExpressionUUID->"6bbf648f-4332-4f89-b29a-986bdd6d2925"],

Cell[TextData[{
 "The payoff of the representation is scale. Stream twenty thousand random \
Clifford gates onto a thousand qubits, a state whose amplitude vector would \
need ",
 Cell[BoxData[
  SuperscriptBox["2", "1000"]], "InlineFormula",ExpressionUUID->
  "be96d20e-5e6f-43e3-9b97-00f8c12c002f"],
 " entries, and time the evolution:"
}], "Text",ExpressionUUID->"d91eb60a-be7f-4571-8d33-faa8b077a68d"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"SeedRandom", "[", "1", "]"}], ";", " ", 
  RowBox[{"n", " ", "=", " ", "1000"}], ";"}], "\n", 
 RowBox[{
  RowBox[{"gates", " ", "=", " ", 
   RowBox[{"Flatten", " ", "@", " ", 
    RowBox[{"Table", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{"\"\<H\>\"", " ", "->", " ", 
         RowBox[{"RandomInteger", "[", 
          RowBox[{"{", 
           RowBox[{"1", ",", " ", "n"}], "}"}], "]"}]}], ",", " ", 
        RowBox[{"\"\<CNOT\>\"", " ", "->", " ", 
         RowBox[{"RandomSample", "[", 
          RowBox[{
           RowBox[{"Range", "[", "n", "]"}], ",", " ", "2"}], "]"}]}], ",", 
        " ", 
        RowBox[{"\"\<S\>\"", " ", "->", " ", 
         RowBox[{"RandomInteger", "[", 
          RowBox[{"{", 
           RowBox[{"1", ",", " ", "n"}], "}"}], "]"}]}]}], "}"}], ",", " ", 
      RowBox[{"{", "6666", "}"}]}], "]"}]}]}], ";"}], "\n", 
 RowBox[{"First", " ", "@", " ", 
  RowBox[{"AbsoluteTiming", "[", 
   RowBox[{
    RowBox[{"big", " ", "=", " ", 
     RowBox[{
      RowBox[{"PauliStabilizer", "[", "n", "]"}], "[", 
      RowBox[{"\"\<ApplyCircuit\>\"", ",", " ", "gates"}], "]"}]}], ";"}], 
   "]"}]}]}], "Input",
 CellLabel->
  "In[282]:=",ExpressionUUID->"d46064a5-c9d9-4b33-8030-c164e1182c83"],

Cell[BoxData["1.174751`"], "Output",
 CellChangeTimes->{3.990278103280974*^9},
 CellLabel->"Out[284]=",
 CellID->268791307,ExpressionUUID->"ba2538da-057d-4e3d-b6a7-7dd7dd531354"]
}, Open  ]],

Cell[TextData[{
 "The whole gate stream folds in about half a second (",
 Cell[BoxData[
 "0.47"], "InlineFormula",ExpressionUUID->
  "9e555b67-5037-4887-b87c-d8fc283d2ed9"],
 " s in this run): ",
 Cell[BoxData[
 "ApplyCircuit"], "InlineFormula",ExpressionUUID->
  "29b81512-2f68-4872-8dca-f48b59080dbb"],
 " runs the tableau updates through one compiled kernel, so the cost per gate \
is microseconds and independent of the ",
 Cell[BoxData[
  SuperscriptBox["2", 
   StyleBox["n", "TI"]]], "InlineFormula",ExpressionUUID->
  "4a5a9dfc-3ec0-4072-8886-1c5eaf2884f0"],
 " that never gets built. The bipartite entanglement entropy across the \
half-chain cut is then a closed form, ",
 Cell[BoxData[
  RowBox[{
   StyleBox["S", "TI"], "(", 
   StyleBox["A", "TI"], ")", "=", 
   SubscriptBox[
    StyleBox["rank",
     FontSlant->"Plain"], 
    SubscriptBox["\|01d53d", "2"]], "\[ThinSpace]", "(", 
   RowBox[{
    StyleBox[
     RowBox[{
     "generators", "\[NonBreakingSpace]", "restricted", "\[NonBreakingSpace]",
       "to", "\[NonBreakingSpace]"}],
     FontSlant->"Plain"], 
    StyleBox["A", "TI"]}], ")", "-", "\[LeftBracketingBar]", 
   StyleBox["A", "TI"], "\[RightBracketingBar]"}]], "InlineFormula",
  ExpressionUUID->"1ded8b17-3c8b-4a5a-b0b7-887e3527fb37"],
 " (",
 ButtonBox["Fattal et al. 2004",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://arxiv.org/abs/quant-ph/0406168"], None}],
 "), exact at any qubit count:"
}], "Text",ExpressionUUID->"3dd9a106-3c19-4ce8-9ea8-6ad9dfdd377e"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"big", "[", 
  RowBox[{"\"\<Entropy\>\"", ",", " ", 
   RowBox[{"Range", "[", 
    RowBox[{"n", "/", "2"}], "]"}]}], "]"}]], "Input",
 CellLabel->
  "In[285]:=",ExpressionUUID->"e9396752-bd01-4730-831e-f76ad8fe71cf"],

Cell[BoxData["496"], "Output",
 CellChangeTimes->{3.990278108379594*^9},
 CellLabel->"Out[285]=",
 CellID->276937537,ExpressionUUID->"c384f67b-c1f3-4ff2-8c5d-c60339ea5d90"]
}, Open  ]],

Cell[TextData[{
 "The entropy returns as exactly ",
 Cell[BoxData[
 "496"], "InlineFormula",ExpressionUUID->
  "49b2e740-f13d-4127-bf6f-0663162c76ad"],
 " ebits of a possible ",
 Cell[BoxData[
 "500"], "InlineFormula",ExpressionUUID->
  "a266a076-57e8-4243-80fb-d2506b9d1251"],
 ": the random circuit has driven the chain to near-maximal, Page-like \
entanglement, and the value is an exact integer from an ",
 Cell[BoxData[
  SubscriptBox["\|01d53d", "2"]], "InlineFormula",ExpressionUUID->
  "e0061c5d-f47e-4f67-bf01-9ec7239b72b3"],
 " rank, not an estimate. The formalism's boundary is first-class too: a \
non-Clifford gate (",
 Cell[BoxData[
  StyleBox["T", "TI"]], "InlineFormula",ExpressionUUID->
  "caf85a17-ae03-4103-94c0-5bec3fdd3541"],
 ", or a general phase) steps outside the stabilizer group, and QF answers \
with a ",
 Cell[BoxData[
 "StabilizerFrame"], "InlineFormula",ExpressionUUID->
  "3104ad45-e9d8-4bfb-89c5-06ac3beb25b2"],
 ", a superposition of stabilizer states, rather than a wrong answer."
}], "Text",ExpressionUUID->"2238de40-fb7e-4af8-b323-03f8f4c55061"]
}, Open  ]],

Cell[CellGroupData[{

Cell["State estimation: tomography from measured counts", "Subsection",ExpressionUUID->"a595e864-dcc8-433c-9a8e-1e755f559f96"],

Cell[TextData[{
 "Tomography is the inverse of measurement: recover an unknown state from the \
statistics of measurements in several bases, and it is part of the same \
object model. The three qubit Pauli bases ",
 Cell[BoxData[
  RowBox[{
   StyleBox["X", "TI"], 
   RowBox[{",", "\[ThinSpace]"}], 
   StyleBox["Y", "TI"], 
   RowBox[{",", "\[ThinSpace]"}], 
   StyleBox["Z", "TI"]}]], "InlineFormula",ExpressionUUID->
  "aec3c212-5768-4cb2-a181-d8482c2772e5"],
 " are mutually unbiased and together informationally complete, so their \
outcome frequencies pin down the density matrix (",
 ButtonBox["Adamson and Steinberg 2010",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://arxiv.org/abs/0808.0944"], None}],
 "). QF runs the whole loop. First, simulate ",
 Cell[BoxData[
 "2000"], "InlineFormula",ExpressionUUID->
  "5b3c872b-2651-4a64-8f00-9aec7a925052"],
 " measurement shots of an unknown state in each of the three bases:"
}], "Text",ExpressionUUID->"f5459c2c-f725-4ac0-8082-29256ce1c0f6"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"SeedRandom", "[", "42", "]"}], ";"}], "\n", 
 RowBox[{
  RowBox[{"true", " ", "=", " ", 
   RowBox[{"QuantumState", "[", 
    RowBox[{"N", " ", "@", " ", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"Cos", "[", 
        RowBox[{"Pi", "/", "6"}], "]"}], ",", " ", 
       RowBox[{
        RowBox[{"Sin", "[", 
         RowBox[{"Pi", "/", "6"}], "]"}], " ", 
        RowBox[{"Exp", "[", 
         RowBox[{"I", " ", 
          RowBox[{"Pi", "/", "4"}]}], "]"}]}]}], "}"}]}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"data", " ", "=", " ", 
   RowBox[{"QuantumMeasurementSimulation", "[", 
    RowBox[{"true", ",", " ", 
     RowBox[{"QuantumMeasurementOperator", " ", "/@", " ", 
      RowBox[{"{", 
       RowBox[{"\"\<X\>\"", ",", " ", "\"\<Y\>\"", ",", " ", "\"\<Z\>\""}], 
       "}"}]}], ",", " ", "2000"}], "]"}]}], ";"}], "\n", 
 RowBox[{"Values", "[", "data", "]"}]}], "Input",
 CellLabel->
  "In[286]:=",ExpressionUUID->"dc1c2f76-1183-4c3b-8b0d-198bfccb5caf"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"1605", ",", "395"}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{"1620", ",", "380"}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{"1504", ",", "496"}], "}"}]}], "}"}]], "Output",
 CellChangeTimes->{3.9902781126249*^9},
 CellLabel->"Out[289]=",
 CellID->1874289229,ExpressionUUID->"1132b14c-d3b0-4134-9be1-51fe2e250599"]
}, Open  ]],

Cell[TextData[{
 "Three pairs of counts return, one per basis, the ",
 Cell[BoxData[
  StyleBox["X", "TI"]], "InlineFormula",ExpressionUUID->
  "b4a441dd-1f4c-4f8f-b8c7-f94115fe80a2"],
 " measurement giving ",
 Cell[BoxData[
 "1605"], "InlineFormula",ExpressionUUID->
  "2283feba-23b1-47fb-ae9d-328e72976a01"],
 " \"",
 Cell[BoxData["+"], "InlineFormula",ExpressionUUID->
  "e3aac3f3-8b10-46b2-a00b-653e00a1e978"],
 "\" against ",
 Cell[BoxData[
 "395"], "InlineFormula",ExpressionUUID->
  "7bc5593f-48cf-448c-bd2f-77babbcf3c38"],
 " \"",
 Cell[BoxData["-"], "InlineFormula",ExpressionUUID->
  "0b76df3d-f2a9-4cde-bb28-8bb00e337226"],
 "\" and so on: multinomially-sampled tallies, all a real experiment ever \
sees."
}], "Text",ExpressionUUID->"6b134b0b-ef3a-41ab-940f-a0858c1a1f2f"],

Cell["\<\
Now hand the counts to the estimator, which does linear inversion followed by \
maximum-likelihood, and read the reconstructed density matrix:\
\>", "Text",ExpressionUUID->"45de5af5-5633-431f-b273-5025f9b8c3cc"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"est", " ", "=", " ", 
   RowBox[{"QuantumStateEstimate", "[", "data", "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"est", "[", "\"\<MaximumLikelihoodState\>\"", "]"}], 
    "[", "\"\<DensityMatrix\>\"", "]"}], " ", "//", " ", "Normal"}], " ", "//",
   " ", "Chop"}]}], "Input",
 CellLabel->
  "In[290]:=",ExpressionUUID->"ec487b03-e8f0-4f6d-9f2f-03ce044f92bd"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"0.7514422909036321`", ",", 
     RowBox[{"0.301830527771225`", "\[VeryThinSpace]", "-", 
      RowBox[{"0.3093139292862141`", " ", "\[ImaginaryI]"}]}]}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"0.301830527771225`", "\[VeryThinSpace]", "+", 
      RowBox[{"0.3093139292862141`", " ", "\[ImaginaryI]"}]}], ",", 
     "0.24855770909636793`"}], "}"}]}], "}"}]], "Output",
 CellChangeTimes->{3.990278114725716*^9},
 CellLabel->"Out[291]=",
 CellID->1643309065,ExpressionUUID->"df92793a-bade-400f-8ae9-8743ebb1bd6a"]
}, Open  ]],

Cell[TextData[{
 "The recovered ",
 Cell[BoxData[
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{
         StyleBox["\[Rho]", "TI"], "\[TildeTilde]", "{", "{", "0.751"}], 
        RowBox[{",", "\[ThinSpace]"}], " ", "0.302"}], "-", 
       RowBox[{"0.309", " ", 
        StyleBox["i", "TI"]}]}], "}"}], 
     RowBox[{",", "\[ThinSpace]"}], 
     RowBox[{"{", "0.302", "+", "0.309", " ", 
      StyleBox["i", "TI"]}], 
     RowBox[{",", "\[ThinSpace]"}], " ", "0.249"}], "}"}], "}"}]], 
  "InlineFormula",ExpressionUUID->"edfb9c82-78a1-4cff-bba1-d5e33a8f92ee"],
 ", against the true ",
 Cell[BoxData[
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{"{", "{", "0.75"}], 
      RowBox[{",", "\[ThinSpace]"}], " ", "0.306"}], "-", 
     RowBox[{"0.306", " ", 
      StyleBox["i", "TI"]}]}], "}"}], 
   RowBox[{",", "\[ThinSpace]"}], 
   RowBox[{"\[Ellipsis]", "}"}]}]], "InlineFormula",ExpressionUUID->
  "de8e7ec9-dd7b-4c91-aacf-ed4c95ba5f81"],
 ". To score the reconstruction, compute its fidelity ",
 Cell[BoxData[
  RowBox[{
   StyleBox["F", "TI"], "(", 
   RowBox[{
    StyleBox["\[Rho]", "TI"], 
    RowBox[{",", "\[ThinSpace]"}], 
    StyleBox["\[Sigma]", "TI"]}], ")", "=", 
   StyleBox["Tr",
    FontSlant->"Plain"], 
   SqrtBox[
    RowBox[{
     SqrtBox[
      StyleBox["\[Rho]", "TI"]], " ", 
     StyleBox["\[Sigma]", "TI"], " ", 
     SqrtBox[
      StyleBox["\[Rho]", "TI"]]}]]}]], "InlineFormula",ExpressionUUID->
  "8c80da51-d4fc-4a40-9114-8e7250c51041"],
 " to the state we started from, equal to ",
 Cell[BoxData[
 "1"], "InlineFormula",ExpressionUUID->"e39e006e-7978-41cc-9ffd-3b1ed3532e87"],
 " exactly when the two states coincide:"
}], "Text",ExpressionUUID->"4661e14e-daed-441d-a9e3-73f092af1aa4"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"QuantumSimilarity", "[", 
  RowBox[{"true", ",", " ", 
   RowBox[{"est", "[", "\"\<MaximumLikelihoodState\>\"", "]"}]}], 
  "]"}]], "Input",
 CellLabel->
  "In[292]:=",ExpressionUUID->"f7c51675-bec5-4e06-a01a-1736ce6c2e11"],

Cell[BoxData["0.9999845824721824`"], "Output",
 CellChangeTimes->{3.9902781191349077`*^9},
 CellLabel->"Out[292]=",
 CellID->1128167220,ExpressionUUID->"26f88b1c-774b-423d-a085-f94923697845"]
}, Open  ]],

Cell[TextData[{
 "The fidelity returns as ",
 Cell[BoxData[
  RowBox[{"\[TildeTilde]", "0.99998"}]], "InlineFormula",ExpressionUUID->
  "7bce342b-1dd0-406e-af56-bc54277229a6"],
 ": the unknown state recovered from finite, noisy synthetic data, using \
nothing but counts in three bases. Past these unitary measurement bases the \
same basis engine continues into the over-complete operator frames, where ",
 Cell[BoxData[
  SuperscriptBox[
   StyleBox["B", "TI"], 
   RowBox[{"-", "1"}]]], "InlineFormula",ExpressionUUID->
  "4a19323f-a69e-44c9-8a93-4bca2a320212"],
 " becomes a dual frame and a state turns into a probability vector, the \
mechanism behind the SIC measurement above."
}], "Text",ExpressionUUID->"1bf76fa6-32fe-4215-8839-d9269efab01a"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["\<\
Claim 3: A quantum object is an ordinary Wolfram Language expression\
\>", "Section",ExpressionUUID->"44488b27-fdb8-4a3c-816e-5320d4b177da"],

Cell[TextData[{
 StyleBox["Key feature:",
  FontWeight->"Bold"],
 " a QF object is a symbolic expression like any other in the language, with \
no separate runtime or data format behind it. That is the whole trick: the \
same ",
 Cell[BoxData[
  RowBox[{"obj", "[", "\"\<...\>\"", "]"}]], "InlineFormula",ExpressionUUID->
  "0e3f7b52-9a5e-4da9-94cb-ecab99010837"],
 " dispatch and the same built-in functions (",
 Cell[BoxData[
 "Plot"], "InlineFormula",ExpressionUUID->
  "81a40184-284d-404e-ab3f-9a871699a3b6"],
 ", ",
 Cell[BoxData[
 "Reduce"], "InlineFormula",ExpressionUUID->
  "9b1a02c2-c1fd-4f30-b0af-59ae1cf85048"],
 ", ",
 Cell[BoxData[
 "NProbability"], "InlineFormula",ExpressionUUID->
  "43d8c058-31a7-4aab-9adb-d66deecb003a"],
 ", \[Ellipsis]) apply to it directly, with nothing to convert or export \
first. Each example below is a different WL operation flowing through a QF \
object."
}], "Text",ExpressionUUID->"5316ec29-3421-42c5-8b79-9bde69e96c70"],

Cell[CellGroupData[{

Cell["Property dispatch: one object, many questions", "Subsection",ExpressionUUID->"c6f16330-ec56-4662-91e5-eb5df6c092f4"],

Cell[TextData[{
 "Ask one object many questions, get answers, no extra packages: here the \
purity ",
 Cell[BoxData[
  RowBox[{
   StyleBox["Tr",
    FontSlant->"Plain"], "[", 
   SuperscriptBox[
    StyleBox["\[Rho]", "TI"], "2"], "]"}]], "InlineFormula",ExpressionUUID->
  "126d8002-01ed-4e20-9226-07c4bc647ccc"],
 ", the von Neumann entropy ",
 Cell[BoxData[
  RowBox[{
   StyleBox["S", "TI"], "=", "-", 
   StyleBox["Tr",
    FontSlant->"Plain"], "[", 
   RowBox[{
    StyleBox["\[Rho]", "TI"], 
    SubscriptBox[
     StyleBox["log",
      FontSlant->"Plain"], "2"], "\[ThinSpace]", 
    StyleBox["\[Rho]", "TI"]}], "]"}]], "InlineFormula",ExpressionUUID->
  "91e3f4df-7b81-47f4-b843-6cc966ddcf87"],
 ", whether the state is entangled, and the concurrence ",
 Cell[BoxData[
  StyleBox["C", "TI"]], "InlineFormula",ExpressionUUID->
  "3248cf1d-9ac6-4a78-81de-f4893b4db5ef"],
 " (a ",
 Cell[BoxData[
 "0"], "InlineFormula",ExpressionUUID->"9ce48113-b463-4136-b67e-5b0ab3da9493"],
 "-to-",
 Cell[BoxData[
 "1"], "InlineFormula",ExpressionUUID->"3bffcb84-3a9a-43dd-baba-bfa98edd2ba3"],
 " entanglement measure, maximal for a Bell state)."
}], "Text",ExpressionUUID->"3ae3d273-1a5b-433e-86bb-d2c43fc006f4"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"bell", " ", "=", " ", 
   RowBox[{"QuantumState", "[", "\"\<Bell\>\"", "]"}]}], ";"}], "\n", 
 RowBox[{"<|", 
  RowBox[{
   RowBox[{"\"\<Purity\>\"", " ", "->", " ", 
    RowBox[{"bell", "[", "\"\<Purity\>\"", "]"}]}], ",", " ", 
   RowBox[{"\"\<Entropy\>\"", " ", "->", " ", 
    RowBox[{"bell", "[", "\"\<VonNeumannEntropy\>\"", "]"}]}], ",", "\n", 
   "  ", 
   RowBox[{"\"\<EntangledQ\>\"", " ", "->", " ", 
    RowBox[{"QuantumEntangledQ", "[", "bell", "]"}]}], ",", " ", 
   RowBox[{"\"\<Concurrence\>\"", " ", "->", " ", 
    RowBox[{"QuantumEntanglementMonotone", "[", 
     RowBox[{"bell", ",", " ", "\"\<Concurrence\>\""}], "]"}]}]}], 
  "|>"}]}], "Input",
 CellLabel->
  "In[293]:=",ExpressionUUID->"12013fb6-8df8-47bf-b575-5cc3fe8af690"],

Cell[BoxData[
 RowBox[{"\[LeftAssociation]", 
  RowBox[{
   RowBox[{"\<\"Purity\"\>", "\[Rule]", "1"}], ",", 
   RowBox[{"\<\"Entropy\"\>", "\[Rule]", 
    TemplateBox[{"0", "\"b\"", "bits", "\"Bits\""},
     "Quantity"]}], ",", 
   RowBox[{"\<\"EntangledQ\"\>", "\[Rule]", "True"}], ",", 
   RowBox[{"\<\"Concurrence\"\>", "\[Rule]", "1"}]}], 
  "\[RightAssociation]"}]], "Output",
 CellChangeTimes->{3.990278124267015*^9},
 CellLabel->"Out[294]=",
 CellID->1627738775,ExpressionUUID->"05d47028-98f2-45bf-a90c-cf548b7e518e"]
}, Open  ]],

Cell["\<\
The answers return self-labeled: the state is pure, carries zero global \
entropy, is entangled, and has maximal concurrence, four facts off one object.\
\>", "Text",ExpressionUUID->"4c7bfbad-fe7e-4c73-bc6f-625f4238900d"],

Cell[TextData[{
 "The same dispatch returns ",
 StyleBox["closed forms",
  FontWeight->"Bold"],
 " when the state carries a symbol. A Werner state's purity and entropy as \
exact functions of ",
 Cell[BoxData[
  StyleBox["p", "TI"]], "InlineFormula",ExpressionUUID->
  "cb9b494c-dc87-46fa-ad11-592dc5473971"],
 ":"
}], "Text",ExpressionUUID->"063cd9f3-4b9d-4a9b-a96a-81409526de4f"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"w", " ", "=", " ", 
   RowBox[{"QuantumState", "[", 
    RowBox[{"\"\<Werner\>\"", "[", 
     RowBox[{"p", ",", " ", "2"}], "]"}], "]"}]}], ";"}], "\n", 
 RowBox[{"Simplify", " ", "/@", " ", 
  RowBox[{"<|", 
   RowBox[{
    RowBox[{"\"\<Purity\>\"", " ", "->", " ", 
     RowBox[{"w", "[", "\"\<Purity\>\"", "]"}]}], ",", " ", 
    RowBox[{"\"\<Entropy\>\"", " ", "->", " ", 
     RowBox[{"w", "[", "\"\<VonNeumannEntropy\>\"", "]"}]}]}], 
   "|>"}]}]}], "Input",
 CellLabel->
  "In[295]:=",ExpressionUUID->"7cfcee2a-2c5e-4ff9-8821-7cbb8f71fc1e"],

Cell[BoxData[
 RowBox[{"\[LeftAssociation]", 
  RowBox[{
   RowBox[{"\<\"Purity\"\>", "\[Rule]", 
    RowBox[{"Abs", "[", 
     RowBox[{"1", "-", 
      RowBox[{"2", " ", "p"}], "+", 
      FractionBox[
       RowBox[{"4", " ", 
        SuperscriptBox["p", "2"]}], "3"]}], "]"}]}], ",", 
   RowBox[{"\<\"Entropy\"\>", "\[Rule]", 
    TemplateBox[{
      FractionBox[
       RowBox[{
         RowBox[{
           RowBox[{"(", 
             RowBox[{
               RowBox[{"-", "1"}], "+", "p"}], ")"}], " ", 
           RowBox[{"Log", "[", 
             RowBox[{"1", "-", "p"}], "]"}]}], "-", 
         RowBox[{"p", " ", 
           RowBox[{"Log", "[", 
             FractionBox["p", "3"], "]"}]}]}], 
       RowBox[{"Log", "[", "2", "]"}]], "\"b\"", "bits", "\"Bits\""},
     "Quantity"]}]}], "\[RightAssociation]"}]], "Output",
 CellChangeTimes->{3.990278127118236*^9},
 CellLabel->"Out[296]=",
 CellID->1145089168,ExpressionUUID->"1f3c36c0-50cd-4498-94d1-67f1783aa875"]
}, Open  ]],

Cell[TextData[{
 "Both come back as closed forms in the mixing parameter: the purity is ",
 Cell[BoxData[
  RowBox[{
   AdjustmentBox["|",
    BoxMargins->{{-0.2, -0.2}, {0, 0}}], " ", 
   RowBox[{"1", "-", 
    RowBox[{"2", 
     StyleBox["p", "TI"]}], "+", 
    FractionBox[
     RowBox[{"4", 
      SuperscriptBox[
       StyleBox["p", "TI"], "2"]}], "3"]}], " ", 
   AdjustmentBox["|",
    BoxMargins->{{-0.2, -0.2}, {0, 0}}]}]], "InlineFormula",ExpressionUUID->
  "f0d22345-6504-4f8d-a792-c0741fb72cb7"],
 " and the entropy is ",
 Cell[BoxData[
  RowBox[{
   StyleBox["S", "TI"], "(", 
   StyleBox["p", "TI"], ")", "=", 
   StyleBox["[",
    Magnification->1.2], "(", 
   RowBox[{
    StyleBox["p", "TI"], "-", "1"}], ")", 
   StyleBox["log",
    FontSlant->"Plain"], "\[ThinSpace]", "(", 
   RowBox[{"1", "-", 
    StyleBox["p", "TI"]}], ")", "-", 
   StyleBox["p", "TI"], 
   StyleBox["log",
    FontSlant->"Plain"], "\[ThinSpace]", 
   FractionBox[
    StyleBox["p", "TI"], "3"], 
   StyleBox["]",
    Magnification->1.2], "/", 
   StyleBox["log",
    FontSlant->"Plain"], "\[ThinSpace]", "2"}]], "InlineFormula",
  ExpressionUUID->"8e8bc4d0-eb07-4ba9-a56a-d80e955a9409"],
 " bits."
}], "Text",ExpressionUUID->"fac341f2-e7cd-41a4-9853-34d4bbeb1e26"]
}, Open  ]],

Cell[CellGroupData[{

Cell[TextData[{
 "Dispatch returns WL data: a Hamiltonian as an ",
 Cell[BoxData[
 "Association"], "InlineFormula",ExpressionUUID->
  "87d869b6-bb33-4d77-9c3d-1b766c87a335"],
 " of Pauli strings"
}], "Subsection",ExpressionUUID->"b956f40e-ff04-422e-8da9-a38aaee77368"],

Cell[TextData[{
 "A property can hand back a structured Wolfram Language container. A \
variational quantum eigensolver writes a Hamiltonian as a sum of Pauli \
strings, ",
 Cell[BoxData[
  RowBox[{
   StyleBox["H", "TI"], "=", 
   UnderscriptBox["\[Sum]", 
    StyleBox["\[Alpha]", "TI"]], 
   SubscriptBox[
    StyleBox["h", "TI"], 
    StyleBox["\[Alpha]", "TI"]], 
   SubscriptBox[
    StyleBox["P", "TI"], 
    StyleBox["\[Alpha]", "TI"]]}]], "InlineFormula",ExpressionUUID->
  "60bb7f70-6b97-4ff9-b838-bc02ea93b6fd"],
 " with ",
 Cell[BoxData[
  RowBox[{
   RowBox[{
    SubscriptBox[
     StyleBox["P", "TI"], 
     StyleBox["\[Alpha]", "TI"]], "\[Element]", "{", 
    StyleBox["I", "TI"]}], 
   RowBox[{",", "\[ThinSpace]"}], 
   StyleBox["X", "TI"], 
   RowBox[{",", "\[ThinSpace]"}], 
   StyleBox["Y", "TI"], 
   RowBox[{",", "\[ThinSpace]"}], 
   RowBox[{
    StyleBox["Z", "TI"], 
    SuperscriptBox["}", 
     RowBox[{"\[CircleTimes]", 
      StyleBox["n", "TI"]}]]}]}]], "InlineFormula",ExpressionUUID->
  "b42fa136-9d28-4f27-bdf0-d2d0d48e17d2"],
 ", and measures each string in its own eigenbasis; commuting strings share a \
measurement setting (",
 ButtonBox["Gokhale et al. 2020",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://arxiv.org/abs/2012.04001"], None}],
 "). Take the hydrogen-molecule Hamiltonian in its two-qubit form as a plain \
numeric matrix and ask for that decomposition:"
}], "Text",ExpressionUUID->"29c7a9de-e85a-4b93-b50e-3e7a209cb20c"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"H2", " ", "=", " ", 
   RowBox[{"QuantumOperator", "[", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"0.", ",", " ", "0", ",", " ", "0", ",", " ", "0"}], "}"}], ",",
       " ", 
      RowBox[{"{", 
       RowBox[{"0", ",", " ", 
        RowBox[{"-", "0.2738"}], ",", " ", "0.182", ",", " ", "0"}], "}"}], ",",
       "\n", "                      ", 
      RowBox[{"{", 
       RowBox[{"0", ",", " ", "0.182", ",", " ", 
        RowBox[{"-", "1.8302"}], ",", " ", "0"}], "}"}], ",", " ", 
      RowBox[{"{", 
       RowBox[{"0", ",", " ", "0", ",", " ", "0", ",", " ", "0.1824"}], 
       "}"}]}], "}"}], "]"}]}], ";"}], "\n", 
 RowBox[{"H2", "[", "\"\<PauliDecompose\>\"", "]"}]}], "Input",
 CellLabel->
  "In[297]:=",ExpressionUUID->"36d2df56-2662-4461-a0f2-bf686ff5501b"],

Cell[BoxData[
 RowBox[{"\[LeftAssociation]", 
  RowBox[{
   RowBox[{"\<\"XX\"\>", "\[Rule]", 
    RowBox[{"0.091`", "\[VeryThinSpace]", "+", 
     RowBox[{"0.`", " ", "\[ImaginaryI]"}]}]}], ",", 
   RowBox[{"\<\"YY\"\>", "\[Rule]", 
    RowBox[{"0.091`", "\[VeryThinSpace]", "+", 
     RowBox[{"0.`", " ", "\[ImaginaryI]"}]}]}], ",", 
   RowBox[{"\<\"ZZ\"\>", "\[Rule]", 
    RowBox[{"0.5716`", "\[VeryThinSpace]", "+", 
     RowBox[{"0.`", " ", "\[ImaginaryI]"}]}]}], ",", 
   RowBox[{"\<\"ZI\"\>", "\[Rule]", 
    RowBox[{"0.3435`", "\[VeryThinSpace]", "+", 
     RowBox[{"0.`", " ", "\[ImaginaryI]"}]}]}], ",", 
   RowBox[{"\<\"IZ\"\>", "\[Rule]", 
    RowBox[{
     RowBox[{"-", "0.4347`"}], "+", 
     RowBox[{"0.`", " ", "\[ImaginaryI]"}]}]}], ",", 
   RowBox[{"\<\"II\"\>", "\[Rule]", 
    RowBox[{
     RowBox[{"-", "0.48040000000000005`"}], "+", 
     RowBox[{"0.`", " ", "\[ImaginaryI]"}]}]}]}], 
  "\[RightAssociation]"}]], "Output",
 CellChangeTimes->{3.990278132782452*^9},
 CellLabel->"Out[298]=",
 CellID->1564833821,ExpressionUUID->"69b5cae5-d980-4e17-8dc0-80542e73f7f6"]
}, Open  ]],

Cell[TextData[{
 "The dense matrix comes back as the ",
 Cell[BoxData[
 "Association"], "InlineFormula",ExpressionUUID->
  "987643b7-63a1-44e6-b2b2-90ed939a7ccd"],
 " ",
 Cell[BoxData[
  RowBox[{"-", "0.4804", " ", 
   StyleBox["I", "TI"], 
   StyleBox["I", "TI"], "+", "0.3435", " ", 
   StyleBox["Z", "TI"], 
   StyleBox["I", "TI"], "-", "0.4347", " ", 
   StyleBox["I", "TI"], 
   StyleBox["Z", "TI"], "+", "0.5716", " ", 
   StyleBox["Z", "TI"], 
   StyleBox["Z", "TI"], "+", "0.091", " ", 
   StyleBox["X", "TI"], 
   StyleBox["X", "TI"], "+", "0.091", " ", 
   StyleBox["Y", "TI"], 
   StyleBox["Y", "TI"]}]], "InlineFormula",ExpressionUUID->
  "a04034b7-d8ac-4316-9440-2d7c78d1bc89"],
 ": the six observables a VQE estimates, in an ordinary key-value container, \
so the measurement grouping itself (the ",
 Cell[BoxData[
  StyleBox["Z", "TI"]], "InlineFormula",ExpressionUUID->
  "fb50a47e-5214-4b86-b0bb-401dc7699a97"],
 " strings share one setting, ",
 Cell[BoxData[
  RowBox[{
   StyleBox["X", "TI"], 
   StyleBox["X", "TI"], "/", 
   StyleBox["Y", "TI"], 
   StyleBox["Y", "TI"]}]], "InlineFormula",ExpressionUUID->
  "ab069d93-9420-47bd-becb-6c04d1d60503"],
 " another) is a ",
 Cell[BoxData[
 "Keys"], "InlineFormula",ExpressionUUID->
  "cb962144-7dd3-47b3-835f-3eefe80a2b2d"],
 "/",
 Cell[BoxData[
 "Select"], "InlineFormula",ExpressionUUID->
  "02073f61-980e-41f0-8024-b0868eac6d18"],
 " computation away."
}], "Text",ExpressionUUID->"b18fe2d2-a27b-4e8d-bdc8-503a62153381"]
}, Open  ]],

Cell[CellGroupData[{

Cell[TextData[{
 "Straight into ",
 Cell[BoxData[
 "Plot"], "InlineFormula",ExpressionUUID->
  "5623a220-2962-4d58-840a-5d9ae67793ed"]
}], "Subsection",ExpressionUUID->"650532ed-a2fa-42ae-a956-9f607e51b99b"],

Cell[TextData[{
 "A QF call goes directly inside a built-in. The concurrence of ",
 Cell[BoxData[
  RowBox[{
   StyleBox["cos",
    FontSlant->"Plain"], "\[ThinSpace]", 
   StyleBox["\[Theta]", "TI"], " ", "\[LeftBracketingBar]", "00", 
   AdjustmentBox["\[RightAngleBracket]",
    BoxMargins->{{-0.2, 0}, {0, 0}}], "+", 
   StyleBox["sin",
    FontSlant->"Plain"], "\[ThinSpace]", 
   StyleBox["\[Theta]", "TI"], " ", "\[LeftBracketingBar]", "11", 
   AdjustmentBox["\[RightAngleBracket]",
    BoxMargins->{{-0.2, 0}, {0, 0}}]}]], "InlineFormula",ExpressionUUID->
  "ac82fca6-517d-4c61-8c92-4e47ee1deb93"],
 " is computed by QF and drawn by the language's own ",
 Cell[BoxData[
 "Plot"], "InlineFormula",ExpressionUUID->
  "c0083884-3442-46a5-8554-1666c967abb9"],
 "."
}], "Text",ExpressionUUID->"34c82f2d-53c2-40a6-b7a7-831d66253b88"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"conc", "[", 
    RowBox[{"t_", "?", "NumericQ"}], "]"}], " ", ":=", " ", 
   RowBox[{"QuantumEntanglementMonotone", "[", "\n", "  ", 
    RowBox[{
     RowBox[{"QuantumState", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{"Cos", "[", "t", "]"}], ",", " ", "0", ",", " ", "0", ",", 
         " ", 
         RowBox[{"Sin", "[", "t", "]"}]}], "}"}], ",", " ", "2"}], "]"}], ",",
      " ", 
     RowBox[{"{", "1", "}"}], ",", " ", "\"\<Concurrence\>\""}], "]"}]}], 
  ";"}], "\n", 
 RowBox[{"Plot", "[", 
  RowBox[{
   RowBox[{"conc", "[", "t", "]"}], ",", " ", 
   RowBox[{"{", 
    RowBox[{"t", ",", " ", "0", ",", " ", 
     RowBox[{"Pi", "/", "2"}]}], "}"}], ",", " ", 
   RowBox[{"Frame", " ", "->", " ", "True"}], ",", "\n", " ", 
   RowBox[{"FrameLabel", " ", "->", " ", 
    RowBox[{"{", 
     RowBox[{"\"\<\[Theta]\>\"", ",", " ", "\"\<Concurrence\>\""}], "}"}]}], ",",
    " ", 
   RowBox[{"PlotTheme", " ", "->", " ", "\"\<Detailed\>\""}]}], 
  "]"}]}], "Input",
 CellLabel->
  "In[299]:=",ExpressionUUID->"09dce6a9-902e-43f3-99b7-e84388356c43"],

