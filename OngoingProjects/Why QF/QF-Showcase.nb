    StyleBox["v", "TI"]], " ", 
   StyleBox["t", "TI"]}]], "InlineFormula",ExpressionUUID->
  "aa3b8a93-cadd-492c-9820-4432141b97fa"],
 ". The whole propagator is built from these solutions of the Weber equation, \
and it checks out as a genuine propagator (numerically ",
 Cell[BoxData[
  RowBox[{
   StyleBox["U", "TI"], "(", "0", ")", "=", 
   StyleBox["I", "TI"]}]], "InlineFormula",ExpressionUUID->
  "9545ef97-7cdb-4613-bd3d-92e54d016e61"],
 ", solves the Schrodinger equation, and is unitary). In the long-time limit \
the asymptotics of these functions collapse to the famous Landau-Zener \
transition probability ",
 Cell[BoxData[
  RowBox[{
   StyleBox["P", "TI"], "=", 
   SuperscriptBox[
    StyleBox["e", "TI"], 
    RowBox[{"-", "\[Pi]", 
     SuperscriptBox["\[CapitalDelta]", "2"], "/", "2", 
     StyleBox["v", "TI"]}]]}]], "InlineFormula",ExpressionUUID->
  "ea4e4be6-9d27-4a08-ab27-b334c2134699"],
 ". This is symbolic evolution reaching past elementary functions to the \
special-function solution the physics demands."
}], "Text",ExpressionUUID->"db69be62-39ed-4d46-8e77-e0c92d52c1c0"]
}, Open  ]],

Cell[CellGroupData[{

Cell[TextData[{
 "Designing the dynamics: recover ",
 Cell[BoxData[
  RowBox[{
   StyleBox["H", "TI"], "(", 
   StyleBox["t", "TI"], ")"}]], "InlineFormula",ExpressionUUID->
  "6ce8a857-eab6-45ae-9fb3-7dce2012c156"],
 " from a target ",
 Cell[BoxData[
  RowBox[{
   StyleBox["U", "TI"], "(", 
   StyleBox["t", "TI"], ")"}]], "InlineFormula",ExpressionUUID->
  "a8866223-28ad-4911-ade5-1a704323e13d"]
}], "Subsection",ExpressionUUID->"466573fb-abd5-431e-946f-6f39d11bbdef"],

Cell[TextData[{
 "The previous examples ",
 StyleBox["solved", "TI"],
 " given Hamiltonians. The inverse is just as symbolic: choose a unitary \
trajectory ",
 Cell[BoxData[
  RowBox[{
   StyleBox["U", "TI"], "(", 
   StyleBox["t", "TI"], ")"}]], "InlineFormula",ExpressionUUID->
  "3856958f-722c-4feb-97d4-f8b658e21472"],
 ", and the Hamiltonian that drives it is ",
 Cell[BoxData[
  RowBox[{
   StyleBox["H", "TI"], "(", 
   StyleBox["t", "TI"], ")", "=", 
   StyleBox["i", "TI"], " ", 
   OverscriptBox[
    StyleBox["U", "TI"], "."], "(", 
   StyleBox["t", "TI"], ")", " ", 
   SuperscriptBox[
    StyleBox["U", "TI"], "\[Dagger]"], "(", 
   StyleBox["t", "TI"], ")"}]], "InlineFormula",ExpressionUUID->
  "8e85fde8-3f93-4afe-886d-59f891e08425"],
 ", the engine behind counterdiabatic driving and shortcuts to adiabaticity. \
Compose the target trajectory from QF's named parametric gates, a \
quadratically chirped ",
 Cell[BoxData[
  StyleBox["Z", "TI"]], "InlineFormula",ExpressionUUID->
  "bfa40708-9a92-4408-9755-55f4923b955d"],
 " rotation following an ",
 Cell[BoxData[
  StyleBox["X", "TI"]], "InlineFormula",ExpressionUUID->
  "056b0842-001b-4da0-bc1a-4f367bc7fdf9"],
 " rotation:"
}], "Text",ExpressionUUID->"52b4ef6e-e0fb-4195-9199-68c89b943d05"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"U", " ", "=", " ", 
  RowBox[{
   RowBox[{"QuantumOperator", "[", 
    RowBox[{"\"\<RZ\>\"", "[", 
     RowBox[{"\[FormalT]", "^", "2"}], "]"}], "]"}], " ", "@", " ", 
   RowBox[{"QuantumOperator", "[", 
    RowBox[{"\"\<RX\>\"", "[", "\[FormalT]", "]"}], "]"}]}]}]], "Input",
 CellChangeTimes->{3.990277365739986*^9},
 CellLabel->
  "In[202]:=",ExpressionUUID->"009cd651-1146-4ce2-be97-2b7c0d6314cc"],

