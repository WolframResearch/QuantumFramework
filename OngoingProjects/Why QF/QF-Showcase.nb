                   SqrtBox["v"]}]},
                "HermiteH"]}], "-", 
              TemplateBox[{
                RowBox[{"1", "-", 
                  FractionBox[
                   RowBox[{"\[ImaginaryI]", " ", 
                    SuperscriptBox["\[CapitalDelta]", "2"]}], 
                   RowBox[{"4", " ", "v"}]]}], 
                RowBox[{
                  RowBox[{"(", 
                    RowBox[{
                    FractionBox["1", "2"], "+", 
                    FractionBox["\[ImaginaryI]", "2"]}], ")"}], " ", 
