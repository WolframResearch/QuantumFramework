Cell[TextData[{
 "QF also returns the closed form: concurrence ",
 Cell[BoxData[
  RowBox[{"=", 
   RowBox[{
    StyleBox["sin",
     FontSlant->"Plain"], "\[ThinSpace]", "(", 
    RowBox[{"2", 
     StyleBox["\[Theta]", "TI"]}], ")"}]}]], "InlineFormula",ExpressionUUID->
  "3eb12d91-99f3-4f88-a682-c4fb77abc4a9"],
 "."
}], "Text",ExpressionUUID->"30401d02-bd9a-4431-b6ec-6f8f9fcbc818"]
}, Open  ]],

Cell[CellGroupData[{

Cell[TextData[{
 "Straight into ",
 Cell[BoxData[
 "Reduce"], "InlineFormula",ExpressionUUID->
  "410b8970-316d-407e-9c26-9772f5749d78"]
}], "Subsection",ExpressionUUID->"16988793-4ee9-41f6-87a3-9a3ccb61e7aa"],

Cell[TextData[{
 "Get the realignment entanglement criterion of a Werner state as a symbolic \
function of ",
 Cell[BoxData[
  StyleBox["p", "TI"]], "InlineFormula",ExpressionUUID->
  "965aff88-fff5-4b82-82be-d5ddfb18f24e"],
 ":"
}], "Text",ExpressionUUID->"63c9b913-5571-4253-a4a1-5b6b3346276a"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"crit", " ", "=", " ", 
  RowBox[{"Simplify", "[", 
   RowBox[{
    RowBox[{"QuantumEntanglementMonotone", "[", 
     RowBox[{
      RowBox[{"QuantumState", "[", 
       RowBox[{"\"\<Werner\>\"", "[", 
        RowBox[{"p", ",", " ", "2"}], "]"}], "]"}], ",", 
      " ", "\"\<Realignment\>\""}], "]"}], ",", " ", 
    RowBox[{"0", " ", "<", " ", "p", " ", "<", " ", "1"}]}], "]"}]}]], "Input",\

 CellLabel->
  "In[301]:=",ExpressionUUID->"36307df1-c62c-48c8-ad3a-1f79857d0a64"],

Cell[BoxData[
 RowBox[{
  FractionBox["1", "2"], " ", 
  RowBox[{"(", 
   RowBox[{
    RowBox[{"-", "1"}], "+", 
    RowBox[{"Abs", "[", 
     RowBox[{"3", "-", 
      RowBox[{"4", " ", "p"}]}], "]"}]}], ")"}]}]], "Output",
 CellChangeTimes->{3.990278142822845*^9},
 CellLabel->"Out[301]=",
 CellID->396933532,ExpressionUUID->"3d5f89e6-41a0-4b9c-b989-4eb378d29da6"]
}, Open  ]],

Cell[TextData[{
 "Feed that QF expression straight into ",
 Cell[BoxData[
 "Reduce"], "InlineFormula",ExpressionUUID->
  "ec3f3e3c-7f83-4954-9399-f31f1af27d4e"],
 " to solve for the entanglement threshold:"
}], "Text",ExpressionUUID->"fc44f2c3-f1f8-402f-abb6-030381e27c70"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Reduce", "[", 
  RowBox[{
   RowBox[{
    RowBox[{"crit", " ", ">", " ", "0"}], " ", "&&", " ", 
    RowBox[{"0", " ", "<", " ", "p", " ", "<", " ", "1"}]}], ",", " ", "p"}], 
  "]"}]], "Input",
 CellLabel->
  "In[302]:=",ExpressionUUID->"f46351eb-2937-4d5c-af41-f9ba9deb3494"],

Cell[BoxData[
 RowBox[{"0", "<", "p", "<", 
  FractionBox["1", "2"]}]], "Output",
 CellChangeTimes->{3.9902781445827713`*^9},
 CellLabel->"Out[302]=",
 CellID->723428253,ExpressionUUID->"2179858c-8108-4b26-9616-8a7070dcf1f9"]
}, Open  ]],

Cell[TextData[{
 "The criterion comes back as ",
 Cell[BoxData[
  FractionBox[
   RowBox[{"\[LeftBracketingBar]", 
    RowBox[{"3", "-", "4", 
     StyleBox["p", "TI"]}], "\[RightBracketingBar]", "-", "1"}], "2"]], 
  "InlineFormula",ExpressionUUID->"08bf6034-abf3-4409-8bb9-f659260c8062"],
 ", and ",
 Cell[BoxData[
 "Reduce"], "InlineFormula",ExpressionUUID->
  "8f39414c-5312-4b39-88e8-6580888a3a06"],
 " turns it into the exact threshold: the Werner state is entangled precisely \
for ",
 Cell[BoxData[
  RowBox[{"0", "<", 
   StyleBox["p", "TI"], "<", 
   FractionBox["1", "2"]}]], "InlineFormula",ExpressionUUID->
  "886c363c-0c2b-4689-bd06-e75ef0bf1c8c"],
 "."
}], "Text",ExpressionUUID->"9178bf3c-953c-401a-aa31-90c4480a65f6"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["Claim 4: Every object draws itself", "Section",ExpressionUUID->"99a77cf0-384f-4eb9-8ad0-7c9b57d14459"],

Cell[TextData[{
 StyleBox["Key feature:",
  FontWeight->"Bold"],
 " visualization is property dispatch, not a separate plotting library. Each \
object exposes plot properties that render through the Wolfram Language \
graphics stack and forward its options, so a publication figure is one call \
on the object it depicts. The catalog is wide: states render as Bloch \
vectors, amplitude and probability charts, and qudit pie and sector wheels \
(",
 Cell[BoxData["\"\<PieChart\>\""], "InlineFormula",ExpressionUUID->
  "5bf8bade-ef5d-4264-8231-c752b10e29d0"],
 ", ",
 Cell[BoxData["\"\<SectorChart\>\""], "InlineFormula",ExpressionUUID->
  "84b326f9-877e-4068-a9c1-a603a0a0df99"],
 "); measurements as outcome histograms; stabilizer states as their binary \
symplectic tableau (",
 Cell[BoxData["\"\<TableauForm\>\""], "InlineFormula",ExpressionUUID->
  "d8df0052-b508-44fb-a80d-1e6e303cbd50"],
 "); circuits as diagrams, tensor-network graphs, and multiway and \
causal-graph views; adiabatic evolutions as spectrum, gap, and coupling plots \
(",
 Cell[BoxData["\"\<EnergySpectrumPlot\>\""], "InlineFormula",ExpressionUUID->
  "5c591eb2-5a4a-4ee8-97fa-d9cb2a5a5de7"],
 ", ",
 Cell[BoxData["\"\<SpectralGapPlot\>\""], "InlineFormula",ExpressionUUID->
  "06d18bfe-456b-4657-9da7-e0fd6e7fdb12"],
 ", ",
 Cell[BoxData["\"\<AdiabaticCouplingPlot\>\""], "InlineFormula",
  ExpressionUUID->"f0e9d60f-7140-4314-9d0c-5981a47cd922"],
 ", ",
 Cell[BoxData["\"\<AdiabaticPathPlot\>\""], "InlineFormula",ExpressionUUID->
  "ce380aae-0d0c-48e4-892c-949373372f23"],
 " in the ",
 Cell[BoxData[
 "QuantumOptimization"], "InlineFormula",ExpressionUUID->
  "d70b72bf-1b27-4f24-9bd4-ea5dc9e23f7d"],
 " sub-package); the underlying ",
 Cell[BoxData[
 "TensorNetwork"], "InlineFormula",ExpressionUUID->
  "6c4bca41-0c38-4fc4-8020-f38f246f2e8e"],
 " also renders as a hypergraph through the TensorNetworks paclet; and the \
phase-space objects of Claim 2 plot as Wigner surfaces. Below, one example \
per object kind."
}], "Text",ExpressionUUID->"823b619b-8022-48ed-a4b0-a1e9300f87c9"],

Cell[CellGroupData[{

Cell["A state on the Bloch sphere", "Subsection",ExpressionUUID->"8a2be543-cbab-4676-87d2-052d98405f2f"],

Cell["A single qubit draws its own Bloch vector:", "Text",ExpressionUUID->"e2aeb878-b768-4264-b67b-9d267f8c2973"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"QuantumState", "[", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"Cos", "[", 
      RowBox[{"Pi", "/", "5"}], "]"}], ",", " ", 
     RowBox[{
      RowBox[{"Sin", "[", 
       RowBox[{"Pi", "/", "5"}], "]"}], " ", 
      RowBox[{"Exp", "[", 
       RowBox[{"I", " ", 
        RowBox[{"Pi", "/", "3"}]}], "]"}]}]}], "}"}], "]"}], 
  "[", "\"\<BlochPlot\>\"", "]"}]], "Input",
 CellLabel->
  "In[303]:=",ExpressionUUID->"3d94f946-d3c4-4175-8b52-fc7c2d42a451"],

