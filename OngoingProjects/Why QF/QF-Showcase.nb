Cell[TextData[{
 "The diagram shows the bra-ket sandwich block by block, the labeled ",
 Cell[BoxData[
 "Prep"], "InlineFormula",ExpressionUUID->
  "b24aa04d-65a8-4498-a758-f798c693196a"],
 "/",
 Cell[BoxData[
 "Cost"], "InlineFormula",ExpressionUUID->
  "15c7ebf2-980a-41e1-8164-09317910147c"],
 "/",
 Cell[BoxData[
 "Mixer"], "InlineFormula",ExpressionUUID->
  "a3f7421f-303d-4757-b83d-46ed651cc462"],
 " layer, the ",
 Cell[BoxData[
 "Hamiltonian"], "InlineFormula",ExpressionUUID->
  "f94c54cb-eb1b-4cc0-9a3e-badead8d4a75"],
 " in the middle, and the daggered layer mirrored on the right: the \
expectation value as a picture. Calling the same object with ",
 Cell[BoxData[
  RowBox[{
   RowBox[{"[", "]"}], "[", "\"\<Scalar\>\"", "]"}]], "InlineFormula",
  ExpressionUUID->"0ccb19b0-e4e9-41c2-95ea-d6f89f1a3f0c"],
 " reads off the number, no manual inner product:"
}], "Text",ExpressionUUID->"8b3f28b9-fb2c-479c-963d-7c2d215b4138"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"landscape", " ", "=", " ", 
  RowBox[{"FullSimplify", "[", 
   RowBox[{
    RowBox[{
     RowBox[{"meanvalue", "[", "]"}], "[", "\"\<Scalar\>\"", "]"}], ",", " ", 
    
    RowBox[{"Element", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"\[Gamma]", ",", " ", "\[Theta]"}], "}"}], ",", " ", "Reals"}],
      "]"}]}], "]"}]}]], "Input",
 CellLabel->
  "In[215]:=",ExpressionUUID->"d4b8a643-a250-4008-82f3-0d7b9fed753e"],

Cell[BoxData[
 RowBox[{
  FractionBox["3", "8"], " ", 
  RowBox[{"(", 
   RowBox[{"3", "+", 
    RowBox[{"Cos", "[", 
     RowBox[{"2", " ", "\[Gamma]"}], "]"}], "+", 
    RowBox[{"2", " ", 
     RowBox[{"Cos", "[", 
      RowBox[{"2", " ", "\[Theta]"}], "]"}], " ", 
     SuperscriptBox[
      RowBox[{"Sin", "[", "\[Gamma]", "]"}], "2"]}], "-", 
    RowBox[{"2", " ", 
     RowBox[{"Sin", "[", 
      RowBox[{"2", " ", "\[Gamma]"}], "]"}], " ", 
     RowBox[{"Sin", "[", 
      RowBox[{"2", " ", "\[Theta]"}], "]"}]}]}], ")"}]}]], "Output",
 CellChangeTimes->{3.9902774027918367`*^9},
 CellLabel->"Out[215]=",
 CellID->707594493,ExpressionUUID->"8d999360-2138-4e39-9bde-9d86fde561cf"]
}, Open  ]],

Cell[TextData[{
 "The exact QAOA energy landscape returns as ",
 Cell[BoxData[
  RowBox[{
   RowBox[{
    RowBox[{
     AdjustmentBox["\[LeftAngleBracket]",
      BoxMargins->{{0, -0.2}, {0, 0}}], 
     SubscriptBox[
      StyleBox["H", "TI"], 
      StyleBox["C", "TI"]], 
     AdjustmentBox["\[RightAngleBracket]",
      BoxMargins->{{-0.2, 0}, {0, 0}}]}], 
    RowBox[{"(", 
     RowBox[{
      StyleBox["\[Gamma]", "TI"], ",", "\[ThinSpace]", 
      StyleBox["\[Theta]", "TI"]}], ")"}]}], "=", 
   RowBox[{
    FractionBox["3", "8"], 
    RowBox[{
     StyleBox["(",
      Magnification->1.2], 
     RowBox[{"3", "+", 
      RowBox[{
       StyleBox["cos",
        FontSlant->"Plain"], "\[ThinSpace]", "2", 
       StyleBox["\[Gamma]", "TI"]}], "+", 
      RowBox[{"2", 
       StyleBox["cos",
        FontSlant->"Plain"], "\[ThinSpace]", "2", 
       StyleBox["\[Theta]", "TI"], " ", 
       SuperscriptBox[
        StyleBox["sin",
         FontSlant->"Plain"], "2"], "\[ThinSpace]", 
       StyleBox["\[Gamma]", "TI"]}], "-", 
      RowBox[{"2", 
       StyleBox["sin",
        FontSlant->"Plain"], "\[ThinSpace]", "2", 
       StyleBox["\[Gamma]", "TI"], " ", 
       StyleBox["sin",
        FontSlant->"Plain"], "\[ThinSpace]", "2", 
       StyleBox["\[Theta]", "TI"]}]}], 
     StyleBox[")",
      Magnification->1.2]}]}]}]], "InlineFormula",ExpressionUUID->
  "17032c86-341f-4863-a89d-4507adcf3ef2"],
 ", a closed form in the two angles. "
}], "Text",
 CellChangeTimes->{
  3.990278496167099*^9},ExpressionUUID->"53d43650-d822-4b7d-854a-\
078e590d3921"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Plot3D", "[", 
  RowBox[{"landscape", ",", 
   RowBox[{"{", 
    RowBox[{"\[Gamma]", ",", "0", ",", 
     RowBox[{"2", "\[Pi]"}]}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{"\[Theta]", ",", "0", ",", 
     RowBox[{"2", "\[Pi]"}]}], "}"}], ",", " ", 
   RowBox[{"PlotRange", " ", "->", " ", "All"}], ",", "\n", "  ", 
   RowBox[{"AxesLabel", " ", "->", " ", 
    RowBox[{"{", 
     RowBox[{"\"\<\[Gamma]\>\"", ",", " ", "\"\<\[Theta]\>\"", ",", 
      " ", "\"\<cost\>\""}], "}"}]}], ",", " ", 
   RowBox[{"ColorFunction", " ", "->", " ", "\"\<TemperatureMap\>\""}], ",", 
   "\n", "  ", 
   RowBox[{"PlotPoints", "->", "50"}]}], "]"}]], "Input",
 CellChangeTimes->{{3.9902784978128967`*^9, 3.9902785490477858`*^9}},
 CellLabel->"In[331]:=",
