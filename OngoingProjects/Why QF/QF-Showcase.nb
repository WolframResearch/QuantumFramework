Cell[TextData[{
 "Differentiate the trajectory ",
 StyleBox["as an operator", "TI"],
 ", ",
 Cell[BoxData[
 "D"], "InlineFormula",ExpressionUUID->"d3c4d598-e360-41ac-856b-3acdbc250603"],
 " acts on the parametric ",
 Cell[BoxData[
 "QuantumOperator"], "InlineFormula",ExpressionUUID->
  "887589d2-8d10-4830-ace0-2921865e569a"],
 " directly, close it with the operator's own ",
 Cell[BoxData[
 "Dagger"], "InlineFormula",ExpressionUUID->
  "43fad0cc-e6c3-441a-ad6b-d17e49809db9"],
 ", and read the control field off each axis with the Pauli decomposition:"
}], "Text",ExpressionUUID->"01368749-68dc-4ea9-b091-a23a7a2ed55b"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"H", " ", "=", " ", 
   RowBox[{"I", " ", 
    RowBox[{
     RowBox[{"D", "[", 
      RowBox[{"U", ",", " ", "\[FormalT]"}], "]"}], " ", "@", " ", 
     RowBox[{"U", "[", "\"\<Dagger\>\"", "]"}]}]}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"FullSimplify", "[", 
    RowBox[{"ComplexExpand", "[", "#", "]"}], "]"}], " ", "&"}], " ", "/@", 
  " ", 
  RowBox[{"H", "[", "\"\<PauliDecompose\>\"", "]"}]}]}], "Input",
 CellLabel->
  "In[203]:=",ExpressionUUID->"b98ca7d1-158d-46d4-8e06-22e87f58d867"],

Cell[BoxData[
 RowBox[{"\[LeftAssociation]", 
  RowBox[{
   RowBox[{"\<\"X\"\>", "\[Rule]", 
    FractionBox[
     RowBox[{"Cos", "[", 
      SuperscriptBox["\[FormalT]", "2"], "]"}], "2"]}], ",", 
   RowBox[{"\<\"Y\"\>", "\[Rule]", 
    FractionBox[
     RowBox[{"Sin", "[", 
      SuperscriptBox["\[FormalT]", "2"], "]"}], "2"]}], ",", 
   RowBox[{"\<\"Z\"\>", "\[Rule]", "\[FormalT]"}], ",", 
   RowBox[{"\<\"I\"\>", "\[Rule]", "0"}]}], "\[RightAssociation]"}]], "Output",\

 CellChangeTimes->{3.990277368797141*^9},
 CellLabel->"Out[204]=",
 CellID->1714784960,ExpressionUUID->"6933cd9b-2a63-45c2-86c4-999660bf0a5d"]
}, Open  ]],

Cell[TextData[{
 "The controls return axis by axis: a linearly growing field ",
 Cell[BoxData[
  StyleBox["t", "TI"]], "InlineFormula",ExpressionUUID->
  "edef4c0d-4cbd-41b8-921a-585ab26eda5b"],
 " on ",
 Cell[BoxData[
  StyleBox["Z", "TI"]], "InlineFormula",ExpressionUUID->
  "1e6b40e5-3eab-4795-8a6b-569f2150ca6b"],
 ", the quadrature pair ",
 Cell[BoxData[
  RowBox[{
   FractionBox["1", "2"], 
   StyleBox["cos",
    FontSlant->"Plain"], "\[ThinSpace]", 
   SuperscriptBox[
    StyleBox["t", "TI"], "2"]}]], "InlineFormula",ExpressionUUID->
  "6d62abaf-fbeb-4d64-9484-b89a32476243"],
 " and ",
 Cell[BoxData[
  RowBox[{
   FractionBox["1", "2"], 
   StyleBox["sin",
    FontSlant->"Plain"], "\[ThinSpace]", 
   SuperscriptBox[
    StyleBox["t", "TI"], "2"]}]], "InlineFormula",ExpressionUUID->
  "d1e998dd-0ae2-4dd0-a443-7f08c80ffbfc"],
 " on ",
 Cell[BoxData[
  StyleBox["X", "TI"]], "InlineFormula",ExpressionUUID->
  "8600e7cc-8410-4123-8d6d-7c0ee6e97a3d"],
 " and ",
 Cell[BoxData[
  StyleBox["Y", "TI"]], "InlineFormula",ExpressionUUID->
  "2d7dc153-eef2-4e28-b721-bad0ea8b8624"],
 ", and a vanishing identity component, traceless as a control should be. \
Together they are the drive ",
 Cell[BoxData[
  RowBox[{
   StyleBox["H", "TI"], "(", 
   StyleBox["t", "TI"], ")", "=", 
   StyleBox["t", "TI"], " ", 
   StyleBox["Z", "TI"], "+", 
   FractionBox["1", "2"], 
   StyleBox["(",
    Magnification->1.2], 
   StyleBox["cos",
    FontSlant->"Plain"], "\[ThinSpace]", 
   SuperscriptBox[
    StyleBox["t", "TI"], "2"], " ", 
   StyleBox["X", "TI"], "+", 
   StyleBox["sin",
    FontSlant->"Plain"], "\[ThinSpace]", 
   SuperscriptBox[
    StyleBox["t", "TI"], "2"], " ", 
   StyleBox["Y", "TI"], 
   StyleBox[")",
    Magnification->1.2]}]], "InlineFormula",ExpressionUUID->
  "a1355fa9-e0d5-4284-8908-28710637169f"],
 " that realizes the chosen evolution, and ",
 Cell[BoxData[
  RowBox[{
   StyleBox["i", "TI"], " ", 
   OverscriptBox[
    StyleBox["U", "TI"], "."], "=", 
   StyleBox["H", "TI"], " ", 
   StyleBox["U", "TI"]}]], "InlineFormula",ExpressionUUID->
  "adce2bb8-faaa-4661-a3cb-c61a8da3784a"],
 " holds identically (verified). You specify the evolution gate by gate; the \
algebra returns the fields to apply on each axis, a closed-form inverse with \
no differential solver involved."
}], "Text",ExpressionUUID->"de1197f8-672b-4496-a89e-abce878df985"]
}, Open  ]],

Cell[CellGroupData[{

Cell["A parametric circuit: QAOA, built entirely from a graph", "Subsection",ExpressionUUID->"21c10a0e-0527-4572-802e-edf5a5efe206"],

Cell[TextData[{
 "QAOA is the canonical parametric circuit for optimization: one layer \
alternates a cost unitary ",
 Cell[BoxData[
  SuperscriptBox[
   StyleBox["e", "TI"], 
   RowBox[{"-", 
    StyleBox["i", "TI"], 
    StyleBox["\[Gamma]", "TI"], 
    SubscriptBox[
     StyleBox["H", "TI"], 
     StyleBox["C", "TI"]]}]]], "InlineFormula",ExpressionUUID->
  "ac4a7717-24f0-4319-b77f-0ff330f83123"],
 " with a mixer ",
 Cell[BoxData[
  SuperscriptBox[
   StyleBox["e", "TI"], 
   RowBox[{"-", 
    StyleBox["i", "TI"], 
    StyleBox["\[Theta]", "TI"], 
    StyleBox["B", "TI"]}]]], "InlineFormula",ExpressionUUID->
  "5f12daee-4983-41b4-8415-dae5b2e21439"],
 ", and we tune the two angles to maximize a classical objective. Everything \
below is ",
 StyleBox["derived from a problem graph", "TI"],
 ", so nothing is hardcoded. Take the triangle, a frustrated instance where \
you cannot cut all three edges, and read off the classical optimum:"
}], "Text",ExpressionUUID->"178ffb04-6acb-4767-a887-5583789bbb53"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"g", " ", "=", " ", 
   RowBox[{"CompleteGraph", "[", "3", "]"}]}], ";"}], "\n", 
 RowBox[{"FindMaximumCut", "[", "g", "]"}]}], "Input",
 CellLabel->
  "In[205]:=",ExpressionUUID->"7d27ca99-0c4f-4984-8097-bc15480c550e"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"2", ",", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"{", "1", "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"2", ",", "3"}], "}"}]}], "}"}]}], "}"}]], "Output",
 CellChangeTimes->{3.9902773743548117`*^9},
 CellLabel->"Out[206]=",
 CellID->420900706,ExpressionUUID->"d90a1b88-a60a-4433-b4e5-42aa891f8641"]
}, Open  ]],

Cell[TextData[{
 "The classical answer is a cut of ",
 Cell[BoxData[
 "2"], "InlineFormula",ExpressionUUID->"851d02b1-36be-4281-ab05-8ce02576a203"],
 " of the ",
 Cell[BoxData[
 "3"], "InlineFormula",ExpressionUUID->"4f47dca8-5134-4064-bc2f-273394e317c4"],
 " edges, one vertex against the other two. Record the vertex count for reuse:"
}], "Text",ExpressionUUID->"4e677494-6be0-403b-b636-ba79eaf427bf"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"n", " ", "=", " ", 
  RowBox[{"VertexCount", "[", "g", "]"}]}]], "Input",
 CellLabel->
  "In[207]:=",ExpressionUUID->"db832ae0-f568-411d-93b0-420edf435325"],

Cell[BoxData["3"], "Output",
 CellChangeTimes->{3.990277375609913*^9},
 CellLabel->"Out[207]=",
 CellID->1222448527,ExpressionUUID->"0391aaea-6d62-4135-acfc-91ad15b107cb"]
}, Open  ]],

Cell[TextData[{
 "The MaxCut cost Hamiltonian ",
 Cell[BoxData[
  RowBox[{
   SubscriptBox[
    StyleBox["H", "TI"], 
    StyleBox["C", "TI"]], "=", 
   UnderscriptBox["\[Sum]", 
    RowBox[{"(", 
     RowBox[{
      StyleBox["i", "TI"], 
      RowBox[{",", "\[ThinSpace]"}], 
      StyleBox["j", "TI"]}], ")"}]], 
   FractionBox[
    RowBox[{"1", "-", 
     SubscriptBox[
      StyleBox["Z", "TI"], 
      StyleBox["i", "TI"]], 
     SubscriptBox[
      StyleBox["Z", "TI"], 
      StyleBox["j", "TI"]]}], "2"]}]], "InlineFormula",ExpressionUUID->
  "635390fe-be6d-4e5d-b7f9-a2ce9a141945"],
 " is assembled straight from the edge list, one ",
 Cell[BoxData[
  RowBox[{"(", 
   RowBox[{"1", "-", 
    SubscriptBox[
     StyleBox["Z", "TI"], 
     StyleBox["i", "TI"]], 
    SubscriptBox[
     StyleBox["Z", "TI"], 
     StyleBox["j", "TI"]]}], ")", "/", "2"}]], "InlineFormula",ExpressionUUID->
  "2d38d8cd-1053-4bdd-bc78-1849169e223f"],
 " term per edge, and carries a label that will name its block in the diagram \
below:"
}], "Text",ExpressionUUID->"51609c82-70f5-416b-b398-aba27e893bf3"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Hc", " ", "=", " ", 
  RowBox[{"QuantumOperator", "[", 
   RowBox[{
    RowBox[{"Total", "[", 
     RowBox[{"With", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"id", " ", "=", " ", 
         RowBox[{
          RowBox[{"QuantumOperator", "[", 
           RowBox[{"StringJoin", "[", 
            RowBox[{"ConstantArray", "[", 
             RowBox[{"\"\<I\>\"", ",", " ", "n"}], "]"}], "]"}], "]"}], "/", 
          "2"}]}], "}"}], ",", "\n", "   ", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{
          RowBox[{"id", " ", "-", " ", 
           RowBox[{"QuantumOperator", "[", 
            RowBox[{
             RowBox[{"\"\<ZZ\>\"", "/", "2"}], ",", " ", "#"}], "]"}]}], " ", 
          "&"}], ")"}], " ", "/@", " ", 
        RowBox[{"(", 
         RowBox[{"List", " ", "@@@", " ", 
          RowBox[{"EdgeList", "[", "g", "]"}]}], ")"}]}]}], "]"}], "]"}], ",",
     " ", 
    RowBox[{"\"\<Label\>\"", " ", "->", " ", "\"\<Hamiltonian\>\""}]}], 
   "]"}]}]], "Input",
 CellChangeTimes->{3.99027737850109*^9},
 CellLabel->
  "In[208]:=",ExpressionUUID->"1168a4b3-ce11-48bb-bbe2-f82e7bb1dcc1"],

