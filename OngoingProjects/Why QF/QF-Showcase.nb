Cell[TextData[{
 "The matrix returns exactly as the lab-frame Rabi propagator, written here \
with the detuning ",
 Cell[BoxData[
  RowBox[{
   StyleBox["\[Delta]", "TI"], "\[Congruent]", 
   StyleBox["\[Omega]", "TI"], "-", 
   SubscriptBox[
    StyleBox["\[Omega]", "TI"], "0"]}]], "InlineFormula",ExpressionUUID->
  "3b2132c4-a9ed-4b25-aac0-eaa99531a63d"],
 " and the generalized Rabi frequency ",
 Cell[BoxData[
  RowBox[{
   SubscriptBox["\[CapitalOmega]", 
    StyleBox["R", "TI"]], "\[Congruent]", 
   SqrtBox[
    RowBox[{
     SuperscriptBox["\[CapitalOmega]", "2"], "+", 
     SuperscriptBox[
      StyleBox["\[Delta]", "TI"], "2"]}]]}]], "InlineFormula",ExpressionUUID->
  "6e0d9352-7e86-439a-aef7-5787aa074ad5"],
 ":"
}], "Text",ExpressionUUID->"0f8f4971-e312-40f5-bd69-d28f7b5d432f"],

