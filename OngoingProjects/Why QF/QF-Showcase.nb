Cell["Not a single qubit index was written by hand.", "Text",ExpressionUUID->"8e4a632b-cdcc-461d-8ce7-e00ae10712af"],

Cell[TextData[{
 "The cost landscape is the expectation ",
 Cell[BoxData[
  RowBox[{
   AdjustmentBox["\[LeftAngleBracket]",
    BoxMargins->{{0, -0.2}, {0, 0}}], 
   StyleBox["\[Psi]", "TI"], "\[RightBracketingBar]", 
   SubscriptBox[
    StyleBox["H", "TI"], 
    StyleBox["C", "TI"]], "\[LeftBracketingBar]", 
   StyleBox["\[Psi]", "TI"], 
   AdjustmentBox["\[RightAngleBracket]",
    BoxMargins->{{-0.2, 0}, {0, 0}}]}]], "InlineFormula",ExpressionUUID->
  "8cbd098e-9718-4120-8b17-8bce8bf359ce"],
 ", and here QF leans on a feature worth naming: ",
 StyleBox["a ",
  FontWeight->"Bold"],
 Cell[BoxData["QuantumCircuitOperator"], "InlineFormula",
  FontWeight->"Bold",ExpressionUUID->"5f39209d-4ba9-46a5-ac33-a2bd3bc3f05c"],
 StyleBox[" can hold states as elements",
  FontWeight->"Bold"],
 ". Composing the prep circuit (the ket), the operator ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["H", "TI"], 
   StyleBox["C", "TI"]]], "InlineFormula",ExpressionUUID->
  "e16fe3aa-8fa5-45f1-8b06-8415774c4c43"],
 ", and the prep circuit's ",
 Cell[BoxData[
  RowBox[{"[", "\"\<Dagger\>\"", "]"}]], "InlineFormula",ExpressionUUID->
  "8397e190-5a27-42bd-80e4-7098c381926f"],
 " (the bra) builds ",
 Cell[BoxData[
  RowBox[{
   AdjustmentBox["\[LeftAngleBracket]",
    BoxMargins->{{0, -0.2}, {0, 0}}], 
   StyleBox["\[Psi]", "TI"], "\[RightBracketingBar]", 
   SubscriptBox[
    StyleBox["H", "TI"], 
    StyleBox["C", "TI"]], "\[LeftBracketingBar]", 
   StyleBox["\[Psi]", "TI"], 
   AdjustmentBox["\[RightAngleBracket]",
    BoxMargins->{{-0.2, 0}, {0, 0}}]}]], "InlineFormula",ExpressionUUID->
  "e139a0a5-2c73-4265-ad50-8341df43e527"],
 " as a ",
 StyleBox["single object", "TI"],
 ", and that object draws itself:"
}], "Text",ExpressionUUID->"702928b8-5ba4-49bc-9fa7-195bddceea20"],

