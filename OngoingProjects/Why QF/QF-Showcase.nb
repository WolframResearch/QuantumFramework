                RowBox[{"4", " ", "v"}]], "-", "1"}], 
             RowBox[{
               RowBox[{"(", 
                 RowBox[{
                   RowBox[{"-", 
                    FractionBox["1", "2"]}], "+", 
                   FractionBox["\[ImaginaryI]", "2"]}], ")"}], " ", 
               "\[FormalT]", " ", 
               SqrtBox["v"]}]},
            "HermiteH"]}], "-", 
          RowBox[{
           TemplateBox[{
             FractionBox[
              RowBox[{"\[ImaginaryI]", " ", 
                SuperscriptBox["\[CapitalDelta]", "2"]}], 
              RowBox[{"4", " ", "v"}]]},
            "Gamma"], " ", 
