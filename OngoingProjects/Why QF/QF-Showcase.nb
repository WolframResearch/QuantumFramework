         RowBox[{
           FractionBox["1", "2"], " ", "\[ImaginaryI]", " ", 
           SuperscriptBox["\[FormalT]", "2"], " ", "v"}]},
        "Hypergeometric1F1"]}], 
      FractionBox[
       RowBox[{
        RadicalBox[
         RowBox[{"-", "1"}], "4"], " ", "\[CapitalDelta]", " ", 
        SuperscriptBox["\[ExponentialE]", 
         RowBox[{
          RowBox[{"-", 
           FractionBox["1", "4"]}], " ", "\[ImaginaryI]", " ", 
          SuperscriptBox["\[FormalT]", "2"], " ", "v"}]], " ", 
        RowBox[{"(", 
         RowBox[{
          RowBox[{
           SuperscriptBox["\[ExponentialE]", 
            RowBox[{
             FractionBox["1", "2"], " ", "\[ImaginaryI]", " ", 
             SuperscriptBox["\[FormalT]", "2"], " ", "v"}]], " ", 
           TemplateBox[{
             FractionBox[
              RowBox[{"\[ImaginaryI]", " ", 
                SuperscriptBox["\[CapitalDelta]", "2"]}], 
              RowBox[{"8", " ", "v"}]]},
            "Gamma"], " ", 
           TemplateBox[{
             RowBox[{"1", "-", 
               FractionBox[
                RowBox[{"\[ImaginaryI]", " ", 
