Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"target", "[", "\"\<CouplingMap\>\"", "]"}]], "Input",
 CellChangeTimes->{3.990278201512867*^9},
 CellLabel->"In[322]:=",
 CellID->1019159219,ExpressionUUID->"940e7525-3520-4f28-83ca-4408b3ca97f7"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"0", ",", "1"}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{"1", ",", "2"}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{"2", ",", "3"}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{"3", ",", "4"}], "}"}]}], "}"}]], "Output",
 CellChangeTimes->{{3.990278197841716*^9, 3.9902782047611513`*^9}},
 CellLabel->"Out[322]=",
 CellID->1396233884,ExpressionUUID->"e8962ded-9527-44ff-a8bf-9325698da737"]
}, Open  ]],

Cell[TextData[{
 "Hand the target to ",
 Cell[BoxData[
 "QuantumQASM"], "InlineFormula",ExpressionUUID->
  "489b31fb-9e4f-4710-a45c-c44262a2ebe8"],
 " as an option, and the circuit is transpiled to that backend's native gates \
and connectivity:"
}], "Text",ExpressionUUID->"31f51fb9-2219-4d3a-ab42-9a7e4b110161"],

Cell[BoxData[
 RowBox[{"QuantumQASM", "[", 
  RowBox[{
   RowBox[{"QuantumCircuitOperator", "[", 
    RowBox[{"\"\<GHZ\>\"", "[", "3", "]"}], "]"}], ",", " ", 
   RowBox[{"\"\<Target\>\"", " ", "->", " ", "target"}]}], "]"}]], "Input",
 CellLabel->
  "In[70]:= ",ExpressionUUID->"65ad656c-7b77-4310-96d4-01a0837ca98b"],

Cell[TextData[{
 "The GHZ circuit comes back rewritten for the device: the Hadamard compiled \
into ",
 Cell[BoxData[
 "rz"], "InlineFormula",ExpressionUUID->
  "bcbebe10-2290-4cdb-b40d-14fc544b0d49"],
 "/",
 Cell[BoxData[
 "sx"], "InlineFormula",ExpressionUUID->
  "d24b68d9-1565-4891-acfc-232c499d4dc2"],
 " rotations, the CNOTs as ",
 Cell[BoxData[
 "cx"], "InlineFormula",ExpressionUUID->
  "2a59831d-2869-486c-b738-a4594cfab579"],
 " on physical qubits ",
 Cell[BoxData[
  RowBox[{"$0", ",", " ", "$1", ",", " ", "$2"}]], "InlineFormula",
  ExpressionUUID->"9492b18f-dec0-4c87-a801-c6d5f8f25816"],
 ", every move allowed by the coupling map."
}], "Text",ExpressionUUID->"68c8480e-d76e-4b27-937c-f2d3aba619bf"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Submit to a real IBM QPU, and compare to the exact result", "Subsection",ExpressionUUID->"69eac840-1349-4e9e-bba8-45df75081188"],

Cell[TextData[{
 "With an IBM account connected through ",
 Cell[BoxData[
  RowBox[{"ServiceConnect", "[", "\"\<IBMQuantumPlatform\>\"", "]"}]], 
  "InlineFormula",ExpressionUUID->"b5a5c953-6d93-4d30-96b8-3fa643738afd"],
 ", ",
 Cell[BoxData[
 "IBMJobSubmit"], "InlineFormula",ExpressionUUID->
  "99df75ac-8980-4f26-8d15-7fd0aae6d769"],
 " sends a circuit to the hardware asynchronously and returns an ",
 Cell[BoxData[
 "IBMJob"], "InlineFormula",ExpressionUUID->
  "6ca305f2-b0cb-41ad-b0ff-c475675924cb"],
 " handle. A QPU job needs a circuit that ",
 StyleBox["ends in a measurement", "TI"],
 "; in QF a list of qubit indices placed in the circuit is exactly that, so \
",
 Cell[BoxData[
  RowBox[{"{", 
   RowBox[{"1", ",", " ", "2", ",", " ", "3"}], "}"}]], "InlineFormula",
  ExpressionUUID->"ec8434a4-ae61-4f94-bd49-79441336f699"],
 " measures all three qubits. Build the measured GHZ circuit, submit it, and \
check the status:"
}], "Text",ExpressionUUID->"511a6cf2-4ada-42d1-831e-c32d5b6263f5"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"qc", " ", "=", " ", 
   RowBox[{"QuantumCircuitOperator", "[", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"\"\<GHZ\>\"", "[", "3", "]"}], ",", " ", 
      RowBox[{"{", 
       RowBox[{"1", ",", " ", "2", ",", " ", "3"}], "}"}]}], "}"}], "]"}]}], 
  ";"}], "\n", 
 RowBox[{"job", " ", "=", " ", 
  RowBox[{"IBMJobSubmit", "[", 
   RowBox[{"qc", ",", " ", "\"\<ibm_fez\>\"", ",", " ", 
    RowBox[{"\"\<Shots\>\"", " ", "->", " ", "4096"}]}], "]"}]}]}], "Input",
 CellChangeTimes->{{3.990278210600404*^9, 3.990278211584588*^9}},
 CellLabel->
  "In[323]:=",ExpressionUUID->"08d237ab-d6c0-458b-b45e-defc7e6821d9"],

