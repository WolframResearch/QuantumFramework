$CellContext`\[CapitalOmega]^2 + 
             2 $CellContext`\[Omega] $CellContext`\[Omega]0 - $CellContext`\
\[Omega]0^2)^Rational[1, 2])) $CellContext`\[Omega] + 
        Complex[0, -1] 
         E^(Rational[1, 2] \[FormalT] (
            Complex[0, -1] $CellContext`\[Omega] + (-$CellContext`\[Omega]^2 - \
$CellContext`\[CapitalOmega]^2 + 
              2 $CellContext`\[Omega] $CellContext`\[Omega]0 - $CellContext`\
\[Omega]0^2)^Rational[1, 2])) $CellContext`\[Omega] + 
        Complex[0, -1] 
         E^(Rational[1, 2] \[FormalT] (
            Complex[0, -1] $CellContext`\[Omega] - (-$CellContext`\[Omega]^2 - \
$CellContext`\[CapitalOmega]^2 + 
             2 $CellContext`\[Omega] $CellContext`\[Omega]0 - $CellContext`\
\[Omega]0^2)^Rational[1, 2])) $CellContext`\[Omega]0 + 
        Complex[0, 1] 
         E^(Rational[1, 2] \[FormalT] (
            Complex[0, -1] $CellContext`\[Omega] + (-$CellContext`\[Omega]^2 - \
$CellContext`\[CapitalOmega]^2 + 
              2 $CellContext`\[Omega] $CellContext`\[Omega]0 - $CellContext`\
\[Omega]0^2)^Rational[1, 2])) $CellContext`\[Omega]0 + 
        E^(Rational[1, 2] \[FormalT] (
            Complex[0, -1] $CellContext`\[Omega] - (-$CellContext`\[Omega]^2 - \
$CellContext`\[CapitalOmega]^2 + 
             2 $CellContext`\[Omega] $CellContext`\[Omega]0 - $CellContext`\
\[Omega]0^2)^
            Rational[
             1, 2])) (-$CellContext`\[Omega]^2 - \
$CellContext`\[CapitalOmega]^2 + 
           2 $CellContext`\[Omega] $CellContext`\[Omega]0 - $CellContext`\
\[Omega]0^2)^Rational[1, 2] + 
        E^(Rational[1, 2] \[FormalT] (
            Complex[0, -1] $CellContext`\[Omega] + (-$CellContext`\[Omega]^2 - \
$CellContext`\[CapitalOmega]^2 + 
              2 $CellContext`\[Omega] $CellContext`\[Omega]0 - $CellContext`\
\[Omega]0^2)^
             Rational[
              1, 2])) (-$CellContext`\[Omega]^2 - \
$CellContext`\[CapitalOmega]^2 + 
           2 $CellContext`\[Omega] $CellContext`\[Omega]0 - $CellContext`\
\[Omega]0^2)^Rational[1, 2])}}], 
    Wolfram`QuantumFramework`QuantumBasis[<|
