                RowBox[{"\[ImaginaryI]", " ", 
                  SuperscriptBox["\[CapitalDelta]", "2"]}], 
                RowBox[{"4", " ", "v"}]]}], 
             RowBox[{
               RowBox[{"(", 
                 RowBox[{
                   FractionBox["1", "2"], "+", 
                   FractionBox["\[ImaginaryI]", "2"]}], ")"}], " ", 
               "\[FormalT]", " ", 
               SqrtBox["v"]}]},
            "HermiteH"]}]}], ")"}]}], 
       RowBox[{
        SqrtBox["2"], " ", "\[Pi]", " ", 
        SqrtBox["v"], " ", 
        RowBox[{"(", 
         RowBox[{
          RowBox[{"csch", "(", 
           FractionBox[
            RowBox[{"\[Pi]", " ", 
             SuperscriptBox["\[CapitalDelta]", "2"]}], 
            RowBox[{"8", " ", "v"}]], ")"}], "-", 
          RowBox[{"sech", "(", 
           FractionBox[
            RowBox[{"\[Pi]", " ", 
             SuperscriptBox["\[CapitalDelta]", "2"]}], 
            RowBox[{"8", " ", "v"}]], ")"}]}], ")"}]}]]},
     {
      RowBox[{"-", 
       FractionBox[
        RowBox[{
         RowBox[{"(", 
          RowBox[{"2", "+", 
           RowBox[{"2", " ", "\[ImaginaryI]"}]}], ")"}], " ", 
         SqrtBox["v"], " ", 
         SuperscriptBox["\[ExponentialE]", 
          RowBox[{
           RowBox[{"-", 
            FractionBox["1", "4"]}], " ", "\[ImaginaryI]", " ", 
           SuperscriptBox["\[FormalT]", "2"], " ", "v"}]], " ", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{
            SuperscriptBox["\[ExponentialE]", 
