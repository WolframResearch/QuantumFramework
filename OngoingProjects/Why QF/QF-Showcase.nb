Cell[TextData[{
 "The ",
 Cell[BoxData[
  SuperscriptBox[
   StyleBox["e", "TI"], 
   RowBox[{"\[MinusPlus]", 
    StyleBox["i", "TI"], 
    StyleBox["\[Omega]", "TI"], 
    StyleBox["t", "TI"], "/", "2"}]]], "InlineFormula",ExpressionUUID->
  "63c20f55-97e8-454c-854a-fe51b158058b"],
 " factors are the rotating-frame phases; the ",
 Cell[BoxData[
  StyleBox["cos",
   FontSlant->"Plain"]], "InlineFormula",ExpressionUUID->
  "380b1b79-77f8-4f4f-9829-ec2cd094a239"],
 " and ",
 Cell[BoxData[
  StyleBox["sin",
   FontSlant->"Plain"]], "InlineFormula",ExpressionUUID->
  "31dc404e-a72b-402b-85b4-a690a9ba3ff3"],
 " of ",
 Cell[BoxData[
  RowBox[{
   SubscriptBox["\[CapitalOmega]", 
    StyleBox["R", "TI"]], 
   StyleBox["t", "TI"], "/", "2"}]], "InlineFormula",ExpressionUUID->
  "c75192f9-f073-4ca2-a733-84026701601d"],
 " are the dressed-state oscillations. The physically meaningful readout is \
the transition probability ",
 Cell[BoxData[
  SuperscriptBox[
   RowBox[{"\[LeftBracketingBar]", 
    RowBox[{
     AdjustmentBox["\[LeftAngleBracket]",
      BoxMargins->{{0, -0.2}, {0, 0}}], "1", "\[RightBracketingBar]", 
     StyleBox["U", "TI"], "(", 
     StyleBox["t", "TI"], ")", "\[LeftBracketingBar]", "0", 
     AdjustmentBox["\[RightAngleBracket]",
      BoxMargins->{{-0.2, 0}, {0, 0}}]}], "\[RightBracketingBar]"}], "2"]], 
  "InlineFormula",ExpressionUUID->"709f21a7-cbc3-41d0-a2bc-95bc4a9b56f6"],
 ":"
}], "Text",ExpressionUUID->"3072a021-1165-4088-a208-8d8d16f4f0d7"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"amp", " ", "=", " ", 
   RowBox[{
    RowBox[{"Normal", "[", 
     RowBox[{"U", "[", "\"\<Matrix\>\"", "]"}], "]"}], "[", 
    RowBox[{"[", 
     RowBox[{"2", ",", " ", "1"}], "]"}], "]"}]}], ";"}], "\n", 
 RowBox[{"Assuming", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{"\[Omega]", " ", "\[Element]", " ", "Reals"}], ",", " ", 
     RowBox[{"\[Omega]0", " ", "\[Element]", " ", "Reals"}], ",", " ", 
     RowBox[{"\[CapitalOmega]", " ", ">", " ", "0"}], ",", " ", 
     RowBox[{"\[FormalT]", " ", "\[Element]", " ", "Reals"}]}], "}"}], ",", 
   "\n", "  ", 
   RowBox[{"FullSimplify", "[", 
    RowBox[{"ComplexExpand", "[", 
     RowBox[{
      RowBox[{"Abs", "[", "amp", "]"}], "^", "2"}], "]"}], "]"}]}], 
  "]"}]}], "Input",
 CellLabel->
  "In[193]:=",ExpressionUUID->"2639da81-eb11-463e-a624-873592bce906"],

Cell[BoxData[
 FractionBox[
  RowBox[{
   SuperscriptBox["\[CapitalOmega]", "2"], " ", 
   SuperscriptBox[
    RowBox[{"Sin", "[", 
     RowBox[{
      FractionBox["1", "2"], " ", "\[FormalT]", " ", 
      SqrtBox[
       RowBox[{
        SuperscriptBox["\[CapitalOmega]", "2"], "+", 
        SuperscriptBox[
         RowBox[{"(", 
          RowBox[{"\[Omega]", "-", "\[Omega]0"}], ")"}], "2"]}]]}], "]"}], 
    "2"]}], 
  RowBox[{
   SuperscriptBox["\[CapitalOmega]", "2"], "+", 
   SuperscriptBox[
    RowBox[{"(", 
