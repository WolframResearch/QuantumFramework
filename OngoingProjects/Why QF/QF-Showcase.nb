Cell[TextData[{
 "The ansatz is built one labeled piece at a time. State prep puts every \
qubit in ",
 Cell[BoxData[
  RowBox[{"\[LeftBracketingBar]", "+", 
   AdjustmentBox["\[RightAngleBracket]",
    BoxMargins->{{-0.2, 0}, {0, 0}}]}]], "InlineFormula",ExpressionUUID->
  "f0077e9f-fd44-4260-b583-ef586ad422b9"],
 ", an equal superposition over all cuts:"
}], "Text",ExpressionUUID->"0d67e3f0-1acf-4191-a081-6fdf4895f5c9"],

