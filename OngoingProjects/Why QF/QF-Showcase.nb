Cell[TextData[{
 "The output is a ",
 Cell[BoxData[
 "Graphics3D"], "InlineFormula",ExpressionUUID->
  "fedabf97-e8c8-40ff-8950-dc3cf0267c6a"],
 " of the sphere with the state's arrow at polar angle ",
 Cell[BoxData[
  RowBox[{"2", "\[Pi]", "/", "5"}]], "InlineFormula",ExpressionUUID->
  "bc29d279-d2cd-47c3-bf22-28263eaa51ac"],
 " and azimuth ",
 Cell[BoxData[
  RowBox[{"\[Pi]", "/", "3"}]], "InlineFormula",ExpressionUUID->
  "ae73ea0c-3bb4-4ab3-926b-ea022f4dafe3"],
 ": the geometry of the state, drawn by the state."
}], "Text",ExpressionUUID->"baff66ab-cb2c-4d83-86fe-fc17b9322b54"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Amplitudes that keep their phases", "Subsection",ExpressionUUID->"abb2f166-9c58-4e05-8bba-aa1b02d436d4"],

Cell[TextData[{
 "A bar chart of probabilities discards the phases; ",
 Cell[BoxData[
 "AmplitudesChart"], "InlineFormula",ExpressionUUID->
  "6fc1281c-5345-422f-8316-b28b7befdb27"],
 " draws the complex amplitudes themselves, heights for magnitudes and colors \
for phases. Chart a GHZ state pushed through a quantum Fourier transform, \
which scrambles two real amplitudes into a phase-rich pattern:"
}], "Text",ExpressionUUID->"1a435cc1-f2d8-4dbd-84ac-ad47593e0608"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"QuantumCircuitOperator", "[", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"\"\<GHZ\>\"", "[", "3", "]"}], ",", " ", 
      RowBox[{"\"\<Fourier\>\"", "[", "3", "]"}]}], "}"}], "]"}], "[", "]"}], 
  "[", 
  RowBox[{"\"\<AmplitudesChart\>\"", ",", " ", 
   RowBox[{"ChartLegends", " ", "->", " ", "Automatic"}]}], "]"}]], "Input",
 CellLabel->
  "In[304]:=",ExpressionUUID->"b675f291-0834-4c87-b630-47ff250987ca"],

