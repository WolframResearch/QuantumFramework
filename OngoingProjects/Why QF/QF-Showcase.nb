Cell[CellGroupData[{

Cell["Every object carries its basis", "Subsection",ExpressionUUID->"8bee684a-197f-41cf-a43f-b4e0bea94130"],

Cell[TextData[{
 "The scope extends inward too: every state, operator, and measurement above \
is stored ",
 StyleBox["together with the basis it is written in", "TI"],
 ". A basis is a stored matrix ",
 Cell[BoxData[
  StyleBox["B", "TI"]], "InlineFormula",ExpressionUUID->
  "dbe7454b-faad-4dc3-a5ab-7175a72604de"],
 " whose rows are the basis vectors in computational coordinates, a change of \
basis is the similarity ",
 Cell[BoxData[
  RowBox[{
   SubscriptBox[
    StyleBox["A", "TI"], "\[ScriptCapitalB]"], "=", 
   SuperscriptBox[
    StyleBox["B", "TI"], 
    RowBox[{"-", "1"}]], 
   StyleBox["A", "TI"], 
   StyleBox["B", "TI"]}]], "InlineFormula",ExpressionUUID->
  "96d4570b-4700-4cf0-985c-459b4a8a96d7"],
 ", and objects written in different bases reconcile automatically through \
the computational frame. About three dozen named bases ship (Bell, Fourier, \
Schwinger, Dirac, Gell-Mann, Wigner, MUB, SIC), and the same engine lowers \
non-computational measurements for OpenQASM export and supplies the magic \
(Bell) basis for two-qubit KAK gate compilation. Watch the representation \
move while the physics stays put: take the qubit ",
 Cell[BoxData[
  RowBox[{"\[LeftBracketingBar]", "+", 
   AdjustmentBox["\[RightAngleBracket]",
    BoxMargins->{{-0.2, 0}, {0, 0}}]}]], "InlineFormula",ExpressionUUID->
  "61f4aeee-eb04-45d6-9c88-804049db8baf"],
 ", the spread-out superposition ",
 Cell[BoxData[
  RowBox[{"(", 
   RowBox[{"\[LeftBracketingBar]", "0", 
    AdjustmentBox["\[RightAngleBracket]",
     BoxMargins->{{-0.2, 0}, {0, 0}}], "+", "\[LeftBracketingBar]", "1", 
    AdjustmentBox["\[RightAngleBracket]",
     BoxMargins->{{-0.2, 0}, {0, 0}}]}], ")", "/", 
   SqrtBox["2"]}]], "InlineFormula",ExpressionUUID->
  "07d33e42-00fb-48c4-8878-821352d47984"],
 " in the computational basis, and write it in the ",
 Cell[BoxData[
  StyleBox["X", "TI"]], "InlineFormula",ExpressionUUID->
  "aaf2027f-bac4-4f71-8704-5f59e2f0f1be"],
 " basis instead:"
}], "Text",ExpressionUUID->"d8eb9315-2d0b-49bc-bf69-b88416a3c817"],

Cell[BoxData[
 RowBox[{
  RowBox[{"QuantumState", "[", 
   RowBox[{
    RowBox[{"QuantumState", "[", "\"\<+\>\"", "]"}], ",", " ", "\"\<X\>\""}], 
   "]"}], " ", "//", " ", "TraditionalForm"}]], "Input",
 CellLabel->
  "In[37]:= ",ExpressionUUID->"3e99273e-3a9b-4c59-88ad-c1bf2258b1b1"],

Cell[TextData[{
 "The state renders as the single ket ",
 Cell[BoxData[
  RowBox[{"\[LeftBracketingBar]", 
   SubscriptBox[
    StyleBox["x", "TI"], "+"], 
   AdjustmentBox["\[RightAngleBracket]",
    BoxMargins->{{-0.2, 0}, {0, 0}}]}]], "InlineFormula",ExpressionUUID->
  "e1474db5-1bbd-452e-b9c5-31663fea45d2"],
 ": in its own eigenbasis ",
 Cell[BoxData[
  RowBox[{"\[LeftBracketingBar]", "+", 
   AdjustmentBox["\[RightAngleBracket]",
    BoxMargins->{{-0.2, 0}, {0, 0}}]}]], "InlineFormula",ExpressionUUID->
  "93de01f5-ed30-462d-952b-966f1f0a9df3"],
 " is one basis vector, not a superposition. Same state, different \
coordinates."
}], "Text",ExpressionUUID->"892a6d19-5a24-4882-b076-bb3451b27703"],

Cell[TextData[{
 "The measurable content is untouched by any such rewriting, and nothing here \
is qubit-bound. Take a spin-1 particle in its ",
 Cell[BoxData[
  RowBox[{
   SubscriptBox[
    StyleBox["m", "TI"], 
    StyleBox["x", "TI"]], "=", "+", "1"}]], "InlineFormula",ExpressionUUID->
  "beb65311-a473-4aba-88e1-086c28b48836"],
 " eigenstate, defined directly in the ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["J", "TI"], 
   StyleBox["x", "TI"]]], "InlineFormula",ExpressionUUID->
  "aecf014c-2d8f-4823-a797-85111cebcd50"],
 " basis:"
}], "Text",ExpressionUUID->"dc4ca23a-16d1-41f7-9ed5-7a14195576fa"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"mx", " ", "=", " ", 
   RowBox[{"QuantumState", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"0", ",", " ", "0", ",", " ", "1"}], "}"}], ",", " ", 
     RowBox[{"\"\<JX\>\"", "[", "1", "]"}]}], "]"}]}], ";"}], "\n", 
 RowBox[{"mx", " ", "//", " ", "TraditionalForm"}]}], "Input",
