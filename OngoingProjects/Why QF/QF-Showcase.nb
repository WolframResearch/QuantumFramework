Cell[TextData[{
 "Eight bars return with equal-magnitude structure but a wheel of distinct \
phase colors keyed by the legend: magnitude ",
 StyleBox["and", "TI"],
 " phase in one figure, the full complex state on display."
}], "Text",ExpressionUUID->"0407b110-517e-4663-86e9-3f4de4f1dd36"]
}, Open  ]],

Cell[CellGroupData[{

Cell["A measurement draws its statistics", "Subsection",ExpressionUUID->"00a5340f-f96f-48fc-aa23-d63ca713a5bd"],

Cell[TextData[{
 "A ",
 Cell[BoxData[
 "QuantumMeasurement"], "InlineFormula",ExpressionUUID->
  "4f110653-de3e-4b1b-a5fc-f52866568c3b"],
 " object charts its own outcome distribution:"
}], "Text",ExpressionUUID->"fdd36b3f-f206-4786-a987-09e969240588"],

Cell[CellGroupData[{

