}, Open  ]],

Cell[TextData[{
 "The result is the textbook Rabi formula, ",
 Cell[BoxData[
  RowBox[{
   SubscriptBox[
    StyleBox["P", "TI"], 
    RowBox[{"0", "\[Rule]", "1"}]], "(", 
   StyleBox["t", "TI"], ")", "=", 
   FractionBox[
    SuperscriptBox["\[CapitalOmega]", "2"], 
    RowBox[{
     SuperscriptBox["\[CapitalOmega]", "2"], "+", 
     SuperscriptBox[
      StyleBox["\[Delta]", "TI"], "2"]}]], " ", 
   SuperscriptBox[
    StyleBox["sin",
     FontSlant->"Plain"], "2"], "\[ThinSpace]", 
   StyleBox["(",
    Magnification->1.2], 
   FractionBox[
    StyleBox["t", "TI"], "2"], 
   SqrtBox[
    RowBox[{
     SuperscriptBox["\[CapitalOmega]", "2"], "+", 
     SuperscriptBox[
      StyleBox["\[Delta]", "TI"], "2"]}]], 
   StyleBox[")",
    Magnification->1.2]}]], "InlineFormula",ExpressionUUID->
  "f5e56b93-d26f-49fd-aea6-9e31b796ea3e"],
 ". On resonance (",
 Cell[BoxData[
  RowBox[{
   StyleBox["\[Omega]", "TI"], "=", 
   SubscriptBox[
    StyleBox["\[Omega]", "TI"], "0"]}]], "InlineFormula",ExpressionUUID->
  "8ba0c759-4eaa-4468-ae8e-739a0cb2dc43"],
 ", so ",
 Cell[BoxData[
  RowBox[{
   StyleBox["\[Delta]", "TI"], "=", "0"}]], "InlineFormula",ExpressionUUID->
  "44ec073e-21c4-4371-83f1-2e94405cae3b"],
 ") this is ",
 Cell[BoxData[
  RowBox[{
   SuperscriptBox[
    StyleBox["sin",
     FontSlant->"Plain"], "2"], "\[ThinSpace]", "(", 
   RowBox[{"\[CapitalOmega]", 
    StyleBox["t", "TI"], "/", "2"}], ")"}]], "InlineFormula",ExpressionUUID->
  "9235dd86-68f6-425a-bd44-ee80f6ed9c6d"],
 ": complete Rabi flopping between ",
 Cell[BoxData[
  RowBox[{"\[LeftBracketingBar]", "0", 
   AdjustmentBox["\[RightAngleBracket]",
    BoxMargins->{{-0.2, 0}, {0, 0}}]}]], "InlineFormula",ExpressionUUID->
  "9e05c4e8-c44c-4c94-822e-76b2ae73ab67"],
 " and ",
 Cell[BoxData[
  RowBox[{"\[LeftBracketingBar]", "1", 
   AdjustmentBox["\[RightAngleBracket]",
    BoxMargins->{{-0.2, 0}, {0, 0}}]}]], "InlineFormula",ExpressionUUID->
  "1ce56050-b670-4367-85e9-b7637cb0a371"],
 ". The oscillation rate ",
 Cell[BoxData[
  SqrtBox[
   RowBox[{
    SuperscriptBox["\[CapitalOmega]", "2"], "+", 
    SuperscriptBox[
     StyleBox["\[Delta]", "TI"], "2"]}]]], "InlineFormula",ExpressionUUID->
  "fd5fe746-3c87-4041-a38a-8ebf7cb4c8d7"],
 " is the generalized Rabi frequency, the dressed-state gap in the rotating \
frame, here recovered as a closed-form function of the drive detuning and \
strength."
}], "Text",ExpressionUUID->"49b7c413-aa69-46e8-9d14-5a2db0d13f81"]
}, Open  ]],

Cell[CellGroupData[{

Cell["When the closed form needs special functions: Landau-Zener", \
"Subsection",ExpressionUUID->"35ef3e1f-69ee-4a83-8f8b-b0372824e35a"],

Cell[TextData[{
 "The rotating-field propagator was elementary, but symbolic evolution is not \
confined to elementary functions. Sweep the energy bias ",
 StyleBox["linearly", "TI"],
 " through an avoided crossing at rate ",
 Cell[BoxData[
  StyleBox["v", "TI"]], "InlineFormula",ExpressionUUID->
  "d1cba89d-f515-4f48-8bc9-f051aaf019a7"],
 " with a constant gap ",
 Cell[BoxData[
 "\[CapitalDelta]"], "InlineFormula",ExpressionUUID->
  "d2586a43-7a25-4d8b-b716-135151f3fbec"],
 ", the Landau-Zener model, again time-dependent and non-commuting:"
}], "Text",ExpressionUUID->"d70a2501-bcaf-4f5c-8d18-3f909aa906e8"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"HLZ", " ", "=", " ", 
  RowBox[{
   RowBox[{"v", " ", 
    RowBox[{"\[FormalT]", "/", "2"}], " ", 
    RowBox[{"QuantumOperator", "[", "\"\<Z\>\"", "]"}]}], " ", "+", " ", 
   RowBox[{
    RowBox[{"\[CapitalDelta]", "/", "2"}], " ", 
    RowBox[{"QuantumOperator", "[", "\"\<X\>\"", "]"}]}]}]}]], "Input",
 CellChangeTimes->{3.99027731169151*^9},
 CellLabel->
  "In[195]:=",ExpressionUUID->"4d635fff-92ae-4eea-a3e1-826ab2433209"],

Cell[BoxData[
 InterpretationBox[
  RowBox[{
   TagBox["QuantumOperator",
    "SummaryHead"], "[", 
   DynamicModuleBox[{Typeset`open$$ = False, Typeset`embedState$$ = "Ready"}, 
    
    TemplateBox[{
      PaneSelectorBox[{False -> GridBox[{{
            PaneBox[
