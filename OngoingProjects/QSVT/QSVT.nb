Cell["\<\
# Optimization:
cost = 1
iter = 0
opt = qml.AdagradOptimizer(0.1)

while cost > 0.5e-4:
    iter += 1
    phi, cost = opt.step_and_cost(loss_func, phi)

    if iter % 10 == 0 or iter == 1:
        print(f\"iter: {iter}, cost: {cost}\")

    if iter > 100:
        print(\"Iteration limit reached!\")
        break

print(f\"Completed Optimization! (final cost: {cost})\")\
\>", "ExternalLanguage",
 CellEvaluationLanguage->"Python",
 CellChangeTimes->{{3.919846228090839*^9, 3.919846228571948*^9}},
 CellLabel->"In[4]:=",ExpressionUUID->"58475d20-2ef8-4800-b151-e73f026c68e3"],

