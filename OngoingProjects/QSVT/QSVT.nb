Cell[TextData[{
 "The extraction of the corresponding block is done by sandwiching the \
auxiliary system with ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{"0"},
    "Ket"], TraditionalForm]],ExpressionUUID->
  "e8ee2a71-3c50-4be0-91c2-e0c0799a8d5d"],
 ", which is equivalent to preparing ancilla as empty register and then \
perform its post-selection using measurement:"
}], "Text",
 CellChangeTimes->{{3.9200233727126923`*^9, 3.9200234227665358`*^9}, {
  3.9200236042332973`*^9, 3.9200236360889874`*^9}, {3.920023673950366*^9, 
