Cell[BoxData[
 RowBox[{
  RowBox[{"realCirc", "=", 
   RowBox[{"QuantumCircuitOperator", "[", 
    RowBox[{"{", 
     RowBox[{"\"\<H\>\"", ",", 
      RowBox[{"QuantumCircuitOperator", "[", 
       RowBox[{"{", 
        RowBox[{"\"\<C\>\"", ",", 
         RowBox[{"QSVT", "[", 
          RowBox[{
           RowBox[{"Transpose", "@", "A"}], ",", "phi"}], "]"}], ",", 
         RowBox[{"{", "}"}], ",", 
         RowBox[{"{", "1", "}"}]}], "}"}], "]"}], ",", 
      RowBox[{"QuantumCircuitOperator", "[", 
       RowBox[{"{", 
        RowBox[{"\"\<C\>\"", ",", 
         RowBox[{
          RowBox[{"QSVT", "[", 
           RowBox[{"A", ",", "phi"}], "]"}], "[", "\"\<Dagger\>\"", "]"}], 
         ",", 
         RowBox[{"{", "1", "}"}]}], "}"}], "]"}], ",", "\"\<H\>\""}], "}"}], 
    "]"}]}], ";"}]], "Input",
 CellChangeTimes->{{3.920056457630649*^9, 3.920056475472114*^9}, {
   3.920056516762148*^9, 3.9200565244437428`*^9}, 
