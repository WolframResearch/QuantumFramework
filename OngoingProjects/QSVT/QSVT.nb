Cell["\<\
In practice it means we can perform multiplication of any normalized vector \
encoded as a state by an arbitrary matrix:\
\>", "Text",
 CellChangeTimes->{{3.920026082482471*^9, 3.92002621328598*^9}, {
  3.920026716608953*^9, 
  3.920026746280183*^9}},ExpressionUUID->"cb5064f2-e557-48b8-b515-\
5d3f9fc8c6d0"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"\[Psi]", "=", 
  RowBox[{"QuantumState", "[", 
