896449fd79d7"],

Cell[BoxData[
 RowBox[{
  RowBox[{"linearSolve", "=", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{"QuantumState", "[", "b", "]"}], "->", 
      RowBox[{"{", "3", "}"}]}], "}"}], "/*", "realCirc"}]}], ";"}]], "Input",\

