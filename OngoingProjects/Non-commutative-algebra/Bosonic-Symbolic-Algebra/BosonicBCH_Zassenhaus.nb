     RowBox[{
      RowBox[{"\[Alpha]", " ", 
       RowBox[{"SuperDagger", "[", "\[FormalA]", "]"}]}], "-", 
      RowBox[{
       RowBox[{"Conjugate", "[", "\[Alpha]", "]"}], " ", "\[FormalA]"}]}], ",", 
     RowBox[{
      RowBox[{"\[Beta]", " ", 
       RowBox[{"SuperDagger", "[", "\[FormalA]", "]"}]}], "-", 
      RowBox[{
