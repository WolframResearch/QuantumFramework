      RowBox[{"\[Alpha]", " ", "a\[Dagger]"}], "-", 
      RowBox[{"\:1fb1", " ", "a"}]}]}], ",", 
    RowBox[{"Y", "=", 
     RowBox[{
      RowBox[{"\[Beta]", " ", "a\[Dagger]"}], "-", 
      RowBox[{"\[Beta]\:0304", " ", "a"}]}]}]}], "*)"}]}], "\[IndentingNewLine]", 
