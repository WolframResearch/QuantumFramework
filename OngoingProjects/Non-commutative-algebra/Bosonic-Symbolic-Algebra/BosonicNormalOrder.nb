Cell[CellGroupData[{
Cell["Bosonic Normal Order", "Title",
 CellChangeTimes->{{3.987505941514866*^9, 
  3.987505948569811*^9}},ExpressionUUID->"073c3db0-1762-9d4a-a5b5-\
b3c64181ac46"],

Cell[CellGroupData[{

Cell["pyBoLaNO setup", "Section",
 CellChangeTimes->{{3.987505951669796*^9, 3.9875059776457005`*^9}, {
  3.987511413885582*^9, 
  3.9875114263977757`*^9}},ExpressionUUID->"51dc7ba0-a70b-3441-a7de-\
3dc8190de2a8"],

Cell["Check version:", "Text",
 CellChangeTimes->{{3.9875279628937416`*^9, 
  3.9875279647816505`*^9}},ExpressionUUID->"f309e6c9-420d-0d40-bd66-\
2fe3fe55e713"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"ExternalEvaluate", "[", 
  RowBox[{"\"\<Python\>\"", 
   ",", "\"\<from importlib.metadata import version; \
version('pybolano')\>\""}], "]"}]], "Input",
 CellChangeTimes->{{3.987527789417158*^9, 3.987527815577711*^9}, {
  3.9875278615271244`*^9, 3.9875279526819496`*^9}},
 CellLabel->"In[1]:=",ExpressionUUID->"47ab4077-8d2e-764d-8a9d-319ebf5bd654"],

Cell[BoxData["\<\"1.0.1\"\>"], "Output",
 CellChangeTimes->{{3.9875278646031303`*^9, 3.9875278881894493`*^9}, {
   3.987527919810095*^9, 3.987527953800188*^9}, 3.9875285441864567`*^9},
 CellLabel->"Out[1]=",ExpressionUUID->"23402f4d-62b1-1041-a138-f40beae3fcad"]
}, Open  ]],

Cell["import pybolano as bl", "ExternalLanguage",
 TaggingRules-><|
  "ExternalEvaluateData" -> <|
    "System" -> "Python", "SessionID" -> "default-python-session", 
     "Evaluator" -> Automatic|>|>,
 CellEvaluationLanguage->"Python",
 CellChangeTimes->{{3.987502927677044*^9, 3.987502948952692*^9}},
 CellLabel->"In[2]:=",ExpressionUUID->"f7b8b2f3-f7b8-d645-ac85-20f100b308a8"],

Cell["\<\
import os

bl.mp_config[\"enable\"] = True
bl.mp_config[\"num_cpus\"] = os.cpu_count()
bl.mp_config[\"min_num_args\"] = 2
bl.mp_config[\"num_cpus\"] = 4\
\>", "ExternalLanguage",
 TaggingRules-><|
  "ExternalEvaluateData" -> <|
    "System" -> "Python", "SessionID" -> "default-python-session", 
     "Evaluator" -> Automatic|>|>,
 CellEvaluationLanguage->"Python",
 CellChangeTimes->{{3.9875029738305836`*^9, 3.987503037674446*^9}},
 CellLabel->"In[3]:=",ExpressionUUID->"ff42fb8c-ae7c-1c4f-8616-af36f78608d0"],

Cell["Symbolic operators in Python:", "Text",
 CellChangeTimes->{{3.9875060405824223`*^9, 
  3.9875060573231144`*^9}},ExpressionUUID->"5887dc33-1cbc-c448-a4ce-\
66b146048f5d"],

Cell["\<\
import sympy as sm
latex = sm.latex # to print as LaTeX code.
b, bd = bl.ops()
b_1, bd_1 = bl.ops(1)
b_2, bd_2 = bl.ops(sm.Symbol(\"2\"))
b_3, bd_3 = bl.ops(sm.Symbol(\"3\"))\
\>", "ExternalLanguage",
 TaggingRules-><|
  "ExternalEvaluateData" -> <|
    "System" -> "Python", "SessionID" -> "default-python-session", 
     "Evaluator" -> Automatic|>|>,
 CellEvaluationLanguage->"Python",
 CellChangeTimes->{{3.987503054686184*^9, 3.9875030959808006`*^9}, {
  3.987503525606737*^9, 3.9875035407281113`*^9}, {3.9875207791509*^9, 
  3.9875208093273773`*^9}},
 CellLabel->"In[4]:=",ExpressionUUID->"91e2fdab-43d0-2c40-897d-c9f45ffeefba"]
}, Open  ]],

Cell[CellGroupData[{

Cell["pyBoLaNO & Mathematica (Normal-ordering)", "Section",
 CellChangeTimes->{{3.987506006601715*^9, 3.987506013081682*^9}, {
   3.987508474401184*^9, 3.9875085051411705`*^9}, 
   3.98751143579562*^9},ExpressionUUID->"daadf049-8aab-a949-b68b-\
d8082c354fb2"],

Cell[CellGroupData[{

Cell["Example 1: Basic test", "Subsection",
 CellChangeTimes->{{3.9875060816387444`*^9, 
  3.9875060921038475`*^9}},ExpressionUUID->"7a98f3a7-8033-b94b-8d58-\
afdf52b6c430"],

Cell[CellGroupData[{

Cell["\<\
latex(
bl.normal_ordering(b * bd * b))\
\>", "ExternalLanguage",
 TaggingRules-><|
  "ExternalEvaluateData" -> <|
    "System" -> "Python", "SessionID" -> "default-python-session", 
     "Evaluator" -> Automatic|>|>,
 CellEvaluationLanguage->"Python",
 CellChangeTimes->{{3.9875036093654556`*^9, 3.987503615054083*^9}, {
  3.98750373225914*^9, 3.987503742880018*^9}, {3.9875086107941723`*^9, 
  3.987508638674055*^9}},
 CellLabel->"In[88]:=",ExpressionUUID->"50b32a18-1628-ab48-aa6a-b9db1479effb"],

Cell[BoxData["\<\"b_{} + {b^\\\\dagger_{}} b_{}^{2}\"\>"], "Output",
 CellChangeTimes->{3.987508639582897*^9},
 CellLabel->"Out[88]=",ExpressionUUID->"40ea601f-956f-c54b-972b-5d3a3bf0af68"]
}, Open  ]],

