 RowBox[{
  RowBox[{"rels", " ", "=", " ", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"Commutator", "[", 
      RowBox[{"\[FormalB]", ",", 
       SuperscriptBox["\[FormalB]", "\[Dagger]"]}], "]"}], "-", "1"}], 
    "}"}]}], ";"}]], "Input",
 CellChangeTimes->{{3.9875055582432632`*^9, 3.9875055939071865`*^9}},
 CellLabel->"In[33]:=",ExpressionUUID->"7951d8d7-38f5-6d4d-ba27-82370726badd"],

