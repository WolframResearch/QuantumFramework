Cell[BoxData[
 RowBox[{
  RowBox[{"OrderBosonicVariables", "[", "vars_List", "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"annihilators", ",", "creators"}], "}"}], ",", 
    "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"annihilators", "=", 
      RowBox[{"Select", "[", 
       RowBox[{"vars", ",", 
        RowBox[{
         RowBox[{"FreeQ", "[", 
          RowBox[{"#", ",", "SuperDagger"}], "]"}], "&"}]}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"creators", "=", 
      RowBox[{"Select", "[", 
       RowBox[{"vars", ",", 
        RowBox[{
         RowBox[{"!", 
          RowBox[{"FreeQ", "[", 
           RowBox[{"#", ",", "SuperDagger"}], "]"}]}], "&"}]}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"Join", "[", 
      RowBox[{
       RowBox[{"ReverseSort", "[", "annihilators", "]"}], ",", 
       RowBox[{"ReverseSort", "[", "creators", "]"}]}], "]"}]}]}], 
   "]"}]}]], "Input",
