Cell[CellGroupData[{

Cell["\<\
import time

start = time.perf_counter()
l=latex(bl.normal_ordering(b_2*b_1*bd_2*bd_1))
end = time.perf_counter()
print(f\"Duration: {end - start:.6f} seconds\")
l\
\>", "ExternalLanguage",
