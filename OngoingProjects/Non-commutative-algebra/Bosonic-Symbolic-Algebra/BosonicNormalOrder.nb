  RowBox[{"ClearAll", "[", 
   RowBox[{
   "BosonicVariables", ",", "OrderBosonicVariables", ",", "BosonicRelations", 
    ",", "GrobnerNormalOrder", ",", "BlasiakNormalOrder", ",", 
    "ParseBlasiakMonomial", ",", "MultiModeBlasiakOrder", ",", 
    "BosonicNormalOrder", ",", "NCPow"}], "]"}], ";"}]], "Input",
 CellChangeTimes->{{3.98752250841774*^9, 3.98752250841774*^9}, {
   3.9875231321196365`*^9, 3.987523138105137*^9}, 3.987523258813179*^9, {
   3.9875235079176903`*^9, 3.987523508377632*^9}, {3.987523543112236*^9, 
   3.987523605361025*^9}},ExpressionUUID->"6f7cb497-20e9-e34f-a379-\
1f2bfb5f690b"],

Cell["Grobner Basis normal order:", "Text",
 CellChangeTimes->{{3.987523608418207*^9, 
  3.9875236230413647`*^9}},ExpressionUUID->"d7670605-9d4f-f24d-835e-\
be7fc72260f1"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"GrobnerNormalOrder", "[", 
     RowBox[{"expr_", ",", "vars_List", ",", "scalars_List"}], "]"}], ":=", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{"orderedVars", "=", 
         RowBox[{"OrderBosonicVariables", "[", "vars", "]"}]}], ",", "rels", ",",
         "alg"}], "}"}], ",", 
      RowBox[{
       RowBox[{"rels", "=", 
        RowBox[{"BosonicRelations", "[", "orderedVars", "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"Length", "[", "scalars", "]"}], ">", "0"}], ",", 
         RowBox[{
          RowBox[{"alg", "=", 
           RowBox[{"NonCommutativeAlgebra", "[", 
            RowBox[{"\"\<ScalarVariables\>\"", "->", "scalars"}], "]"}]}], ";",
           "\[IndentingNewLine]", 
          RowBox[{
           RowBox[{"NonCommutativePolynomialReduce", "[", 
            RowBox[{"expr", ",", "rels", ",", "orderedVars", ",", "alg"}], 
            "]"}], "[", 
           RowBox[{"[", "2", "]"}], "]"}]}], ",", 
         RowBox[{
          RowBox[{"NonCommutativePolynomialReduce", "[", 
           RowBox[{"expr", ",", "rels", ",", "orderedVars"}], "]"}], "[", 
          RowBox[{"[", "2", "]"}], "]"}]}], "]"}]}]}], "]"}]}], ";"}], 
  "\n"}]], "Input",
 CellChangeTimes->{{3.98752250841774*^9, 3.98752250841774*^9}, {
   3.9875231321196365`*^9, 3.987523138105137*^9}, 3.987523258813179*^9, {
   3.9875235079176903`*^9, 3.987523508377632*^9}, {3.987523543112236*^9, 
   3.9875236025784664`*^9}, {3.987523633441286*^9, 
   3.9875236626723576`*^9}},ExpressionUUID->"502faf5f-0a89-6e4a-8e1e-\
82a3aecd91a6"],

Cell["Blasiak engine:", "Text",
 CellChangeTimes->{{3.9875236647622967`*^9, 
  3.987523673582714*^9}},ExpressionUUID->"fcc8943f-6e0c-8449-8b24-\
582aea478889"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
    RowBox[{"Helper", " ", "to", " ", "generate", " ", "safe", " ", "non"}], "-", 
    RowBox[{"commutative", " ", "powers"}]}], "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"NCPow", "[", 
      RowBox[{"base_", ",", "0"}], "]"}], ":=", "1"}], ";"}], "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"NCPow", "[", 
      RowBox[{"base_", ",", "1"}], "]"}], ":=", "base"}], ";"}], "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"NCPow", "[", 
      RowBox[{"base_", ",", "p_"}], "]"}], ":=", 
     RowBox[{"GeneralizedPower", "[", 
      RowBox[{"NonCommutativeMultiply", ",", "base", ",", "p"}], "]"}]}], 
    ";"}], "\n", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"BlasiakNormalOrder", "[", 
      RowBox[{"rList_List", ",", "sList_List", ",", "var_"}], "]"}], ":=", 
     RowBox[{"Module", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{"M", "=", 
          RowBox[{"Length", "[", "rList", "]"}]}], ",", 
         RowBox[{"b", "=", "var"}], ",", 
         RowBox[{"bdag", "=", 
          RowBox[{"SuperDagger", "[", "var", "]"}]}], ",", "d", ",", "Srs", ",",
          "dM", ",", "buildTerm"}], "}"}], ",", 
       RowBox[{
        RowBox[{
         RowBox[{"buildTerm", "[", 
          RowBox[{"coeff_", ",", "p_", ",", "q_"}], "]"}], ":=", 
         RowBox[{"Module", "[", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{
             RowBox[{"bp", "=", 
              RowBox[{"NCPow", "[", 
               RowBox[{"bdag", ",", "p"}], "]"}]}], ",", 
             RowBox[{"bq", "=", 
              RowBox[{"NCPow", "[", 
               RowBox[{"b", ",", "q"}], "]"}]}]}], "}"}], ",", 
           RowBox[{
            RowBox[{"If", "[", 
             RowBox[{
              RowBox[{
               RowBox[{"p", "==", "0"}], "&&", 
               RowBox[{"q", "==", "0"}]}], ",", 
              RowBox[{"Return", "[", "coeff", "]"}]}], "]"}], ";", 
            "\[IndentingNewLine]", 
            RowBox[{"If", "[", 
             RowBox[{
              RowBox[{"p", "==", "0"}], ",", 
              RowBox[{"Return", "[", 
               RowBox[{"coeff", "*", "bq"}], "]"}]}], "]"}], ";", 
            "\[IndentingNewLine]", 
            RowBox[{"If", "[", 
             RowBox[{
              RowBox[{"q", "==", "0"}], ",", 
              RowBox[{"Return", "[", 
               RowBox[{"coeff", "*", "bp"}], "]"}]}], "]"}], ";", 
            "\[IndentingNewLine]", 
            RowBox[{"coeff", "*", 
             RowBox[{"(", 
              RowBox[{"bp", "**", "bq"}], ")"}]}]}]}], "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"d", "[", 
          RowBox[{"l_", ",", "r_", ",", "s_"}], "]"}], ":=", 
         RowBox[{"Sum", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"r", "[", 
             RowBox[{"[", "m", "]"}], "]"}], "-", 
            RowBox[{"s", "[", 
             RowBox[{"[", "m", "]"}], "]"}]}], ",", 
           RowBox[{"{", 
            RowBox[{"m", ",", "1", ",", "l"}], "}"}]}], "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"d", "[", 
          RowBox[{"0", ",", "r_", ",", "s_"}], "]"}], "=", "0"}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"Srs", "[", 
          RowBox[{"k_", ",", "r_", ",", "s_"}], "]"}], ":=", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{"1", "/", 
            RowBox[{"k", "!"}]}], ")"}], "*", 
          RowBox[{"Sum", "[", 
           RowBox[{
            RowBox[{
             RowBox[{"Binomial", "[", 
              RowBox[{"k", ",", "j"}], "]"}], "*", 
             RowBox[{
              RowBox[{"(", 
               RowBox[{"-", "1"}], ")"}], "^", 
              RowBox[{"(", 
               RowBox[{"k", "-", "j"}], ")"}]}], "*", 
             RowBox[{"Product", "[", 
              RowBox[{
               RowBox[{"FactorialPower", "[", 
                RowBox[{
                 RowBox[{
                  RowBox[{"d", "[", 
                   RowBox[{
                    RowBox[{"m", "-", "1"}], ",", "r", ",", "s"}], "]"}], "+",
                   "j"}], ",", 
                 RowBox[{"s", "[", 
                  RowBox[{"[", "m", "]"}], "]"}]}], "]"}], ",", 
               RowBox[{"{", 
                RowBox[{"m", ",", "1", ",", "M"}], "}"}]}], "]"}]}], ",", 
            RowBox[{"{", 
             RowBox[{"j", ",", "0", ",", "k"}], "}"}]}], "]"}]}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"dM", "=", 
         RowBox[{"d", "[", 
          RowBox[{"M", ",", "rList", ",", "sList"}], "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{"dM", ">=", "0"}], ",", 
          RowBox[{"Sum", "[", 
           RowBox[{
            RowBox[{"buildTerm", "[", 
             RowBox[{
              RowBox[{"Srs", "[", 
               RowBox[{"k", ",", "rList", ",", "sList"}], "]"}], ",", 
              RowBox[{"dM", "+", "k"}], ",", "k"}], "]"}], ",", 
            RowBox[{"{", 
             RowBox[{"k", ",", 
              RowBox[{"sList", "[", 
               RowBox[{"[", "1", "]"}], "]"}], ",", 
              RowBox[{"Total", "[", "sList", "]"}]}], "}"}]}], "]"}], ",", 
          RowBox[{"Module", "[", 
           RowBox[{
            RowBox[{"{", 
             RowBox[{
              RowBox[{"rRev", "=", 
               RowBox[{"Reverse", "[", "rList", "]"}]}], ",", 
              RowBox[{"sRev", "=", 
               RowBox[{"Reverse", "[", "sList", "]"}]}]}], "}"}], ",", 
            RowBox[{"Sum", "[", 
             RowBox[{
              RowBox[{"buildTerm", "[", 
               RowBox[{
                RowBox[{"Srs", "[", 
                 RowBox[{"k", ",", "sRev", ",", "rRev"}], "]"}], ",", "k", ",", 
                RowBox[{"k", "-", "dM"}]}], "]"}], ",", 
              RowBox[{"{", 
               RowBox[{"k", ",", 
                RowBox[{"rList", "[", 
                 RowBox[{"[", 
                  RowBox[{"-", "1"}], "]"}], "]"}], ",", 
                RowBox[{"Total", "[", "rList", "]"}]}], "}"}]}], "]"}]}], 
           "]"}]}], "]"}]}]}], "]"}]}], ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"ParseBlasiakMonomial", "[", 
      RowBox[{"expr_", ",", "var_"}], "]"}], ":=", 
     RowBox[{"Module", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{"bdag", "=", 
          RowBox[{"SuperDagger", "[", "var", "]"}]}], ",", "factors", ",", 
         "typed", ",", "blocks", ",", "rList", ",", "sList"}], "}"}], ",", 
       RowBox[{
        RowBox[{"factors", "=", 
         RowBox[{"If", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"Head", "[", "expr", "]"}], "===", 
            "NonCommutativeMultiply"}], ",", 
           RowBox[{"List", "@@", "expr"}], ",", 
           RowBox[{"{", "expr", "}"}]}], "]"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"typed", "=", 
         RowBox[{"Map", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"Which", "[", 
             RowBox[{
              RowBox[{"#", "===", "var"}], ",", 
              RowBox[{"{", 
               RowBox[{"\"\<b\>\"", ",", "1"}], "}"}], ",", 
              RowBox[{"#", "===", "bdag"}], ",", 
              RowBox[{"{", 
               RowBox[{"\"\<bdag\>\"", ",", "1"}], "}"}], ",", 
              RowBox[{"MatchQ", "[", 
               RowBox[{"#", ",", 
                RowBox[{"GeneralizedPower", "[", 
                 RowBox[{"NonCommutativeMultiply", ",", "var", ",", "_"}], 
                 "]"}]}], "]"}], ",", 
              RowBox[{"{", 
               RowBox[{"\"\<b\>\"", ",", 
                RowBox[{"#", "[", 
                 RowBox[{"[", "3", "]"}], "]"}]}], "}"}], ",", 
              RowBox[{"MatchQ", "[", 
               RowBox[{"#", ",", 
                RowBox[{"GeneralizedPower", "[", 
                 RowBox[{"NonCommutativeMultiply", ",", "bdag", ",", "_"}], 
                 "]"}]}], "]"}], ",", 
              RowBox[{"{", 
               RowBox[{"\"\<bdag\>\"", ",", 
                RowBox[{"#", "[", 
                 RowBox[{"[", "3", "]"}], "]"}]}], "}"}], ",", 
              RowBox[{"MatchQ", "[", 
               RowBox[{"#", ",", 
                RowBox[{"Power", "[", 
                 RowBox[{"var", ",", "_"}], "]"}]}], "]"}], ",", 
              RowBox[{"{", 
               RowBox[{"\"\<b\>\"", ",", 
                RowBox[{"#", "[", 
                 RowBox[{"[", "2", "]"}], "]"}]}], "}"}], ",", 
              RowBox[{"MatchQ", "[", 
               RowBox[{"#", ",", 
                RowBox[{"Power", "[", 
                 RowBox[{"bdag", ",", "_"}], "]"}]}], "]"}], ",", 
              RowBox[{"{", 
               RowBox[{"\"\<bdag\>\"", ",", 
                RowBox[{"#", "[", 
                 RowBox[{"[", "2", "]"}], "]"}]}], "}"}], ",", "True", ",", 
              RowBox[{"{", 
               RowBox[{"\"\<unknown\>\"", ",", "0"}], "}"}]}], "]"}], "&"}], ",",
            "factors"}], "]"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{"MemberQ", "[", 
           RowBox[{
            RowBox[{"typed", "[", 
             RowBox[{"[", 
              RowBox[{"All", ",", "1"}], "]"}], "]"}], 
            ",", "\"\<unknown\>\""}], "]"}], ",", 
          RowBox[{
           RowBox[{
           "Print", 
            "[", "\"\<Error: Found unsupported non-ladder terms during \
parsing.\>\"", "]"}], ";", "\[IndentingNewLine]", 
           RowBox[{"Return", "[", "$Failed", "]"}]}]}], "]"}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"blocks", "=", 
         RowBox[{"{", 
          RowBox[{"typed", "[", 
           RowBox[{"[", "1", "]"}], "]"}], "}"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"Do", "[", 
         RowBox[{
          RowBox[{"If", "[", 
           RowBox[{
            RowBox[{
             RowBox[{"typed", "[", 
              RowBox[{"[", 
               RowBox[{"i", ",", "1"}], "]"}], "]"}], "==", 
             RowBox[{"blocks", "[", 
              RowBox[{"[", 
               RowBox[{
                RowBox[{"-", "1"}], ",", "1"}], "]"}], "]"}]}], ",", 
            RowBox[{
             RowBox[{"blocks", "[", 
              RowBox[{"[", 
               RowBox[{
                RowBox[{"-", "1"}], ",", "2"}], "]"}], "]"}], "+=", 
             RowBox[{"typed", "[", 
              RowBox[{"[", 
               RowBox[{"i", ",", "2"}], "]"}], "]"}]}], ",", 
            RowBox[{"AppendTo", "[", 
             RowBox[{"blocks", ",", 
              RowBox[{"typed", "[", 
               RowBox[{"[", "i", "]"}], "]"}]}], "]"}]}], "]"}], ",", 
          RowBox[{"{", 
           RowBox[{"i", ",", "2", ",", 
            RowBox[{"Length", "[", "typed", "]"}]}], "}"}]}], "]"}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"blocks", "[", 
            RowBox[{"[", 
             RowBox[{
              RowBox[{"-", "1"}], ",", "1"}], "]"}], "]"}], 
           "==", "\"\<bdag\>\""}], ",", 
          RowBox[{"AppendTo", "[", 
           RowBox[{"blocks", ",", 
            RowBox[{"{", 
             RowBox[{"\"\<b\>\"", ",", "0"}], "}"}]}], "]"}]}], "]"}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"blocks", "[", 
            RowBox[{"[", 
             RowBox[{"1", ",", "1"}], "]"}], "]"}], "==", "\"\<b\>\""}], ",", 
          RowBox[{"PrependTo", "[", 
           RowBox[{"blocks", ",", 
            RowBox[{"{", 
             RowBox[{"\"\<bdag\>\"", ",", "0"}], "}"}]}], "]"}]}], "]"}], ";",
         "\[IndentingNewLine]", 
        RowBox[{"sList", "=", 
         RowBox[{"Reverse", "[", 
          RowBox[{"blocks", "[", 
           RowBox[{"[", 
            RowBox[{
             RowBox[{"2", ";;", " ", ";;", "2"}], ",", "2"}], "]"}], "]"}], 
          "]"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"rList", "=", 
         RowBox[{"Reverse", "[", 
          RowBox[{"blocks", "[", 
           RowBox[{"[", 
            RowBox[{
             RowBox[{"1", ";;", " ", ";;", "2"}], ",", "2"}], "]"}], "]"}], 
          "]"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"{", 
         RowBox[{"rList", ",", "sList"}], "}"}]}]}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{"MultiModeBlasiakOrder", "[", 
       RowBox[{"exprIn_", ",", "vars_List", ",", "scalars_List"}], "]"}], ":=", 
      RowBox[{"Module", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{
         "expr", ",", "factors", ",", "modeVars", ",", "modePolys", ",", 
          "scalarFactors", ",", "finalExpr", ",", "getOrderWeight"}], "}"}], ",", 
        RowBox[{
         RowBox[{"expr", "=", 
          RowBox[{"exprIn", "//.", 
           RowBox[{"{", 
            RowBox[{
             RowBox[{
              RowBox[{"GeneralizedPower", "[", 
               RowBox[{"NonCommutativeMultiply", ",", 
                RowBox[{"NonCommutativeMultiply", "[", "args__", "]"}], ",", 
                RowBox[{"n_Integer", "?", "Positive"}]}], "]"}], ":>", 
              RowBox[{"NonCommutativeMultiply", "@@", 
               RowBox[{"Flatten", "[", 
                RowBox[{"ConstantArray", "[", 
                 RowBox[{
                  RowBox[{"{", "args", "}"}], ",", "n"}], "]"}], "]"}]}]}], ",", 
             RowBox[{
              RowBox[{"Power", "[", 
               RowBox[{
                RowBox[{"NonCommutativeMultiply", "[", "args__", "]"}], ",", 
                RowBox[{"n_Integer", "?", "Positive"}]}], "]"}], ":>", 
              RowBox[{"NonCommutativeMultiply", "@@", 
               RowBox[{"Flatten", "[", 
                RowBox[{"ConstantArray", "[", 
                 RowBox[{
                  RowBox[{"{", "args", "}"}], ",", "n"}], "]"}], "]"}]}]}]}], 
            "}"}]}]}], ";", "\[IndentingNewLine]", 
         RowBox[{"expr", "=", 
          RowBox[{"expr", "//.", 
           RowBox[{
            RowBox[{"NonCommutativeMultiply", "[", 
             RowBox[{"a___", ",", 
              RowBox[{"NonCommutativeMultiply", "[", "b__", "]"}], ",", 
              "c___"}], "]"}], ":>", 
            RowBox[{"NonCommutativeMultiply", "[", 
             RowBox[{"a", ",", "b", ",", "c"}], "]"}]}]}]}], ";", 
         "\[IndentingNewLine]", 
         RowBox[{"factors", "=", 
          RowBox[{"If", "[", 
           RowBox[{
            RowBox[{
             RowBox[{"Head", "[", "expr", "]"}], "===", 
             "NonCommutativeMultiply"}], ",", 
            RowBox[{"List", "@@", "expr"}], ",", 
            RowBox[{"{", "expr", "}"}]}], "]"}]}], ";", "\[IndentingNewLine]", 
         RowBox[{"scalarFactors", "=", 
          RowBox[{"Select", "[", 
           RowBox[{"factors", ",", 
            RowBox[{
             RowBox[{"FreeQ", "[", 
              RowBox[{"#", ",", 
               RowBox[{"Alternatives", "@@", "vars"}]}], "]"}], "&"}]}], 
           "]"}]}], ";", "\[IndentingNewLine]", 
         RowBox[{"factors", "=", 
          RowBox[{"Select", "[", 
           RowBox[{"factors", ",", 
            RowBox[{
             RowBox[{"!", 
              RowBox[{"FreeQ", "[", 
               RowBox[{"#", ",", 
                RowBox[{"Alternatives", "@@", "vars"}]}], "]"}]}], "&"}]}], 
           "]"}]}], ";", "\[IndentingNewLine]", 
         RowBox[{"modeVars", "=", 
          RowBox[{"Reverse", "[", 
           RowBox[{"Partition", "[", 
            RowBox[{"vars", ",", "2"}], "]"}], "]"}]}], ";", 
         "\[IndentingNewLine]", 
         RowBox[{"modePolys", "=", 
          RowBox[{"Map", "[", 
           RowBox[{
            RowBox[{"Function", "[", 
             RowBox[{"modePair", ",", 
              RowBox[{"Module", "[", 
               RowBox[{
                RowBox[{"{", 
                 RowBox[{
                  RowBox[{"b", "=", 
                   RowBox[{"modePair", "[", 
                    RowBox[{"[", "1", "]"}], "]"}]}], ",", 
                  RowBox[{"bdag", "=", 
                   RowBox[{"modePair", "[", 
                    RowBox[{"[", "2", "]"}], "]"}]}], ",", "modeFactors", ",",
                   "parsed", ",", "rList", ",", "sList"}], "}"}], ",", 
                RowBox[{
                 RowBox[{"modeFactors", "=", 
                  RowBox[{"Select", "[", 
                   RowBox[{"factors", ",", 
                    RowBox[{
                    RowBox[{
                    RowBox[{"!", 
                    RowBox[{"FreeQ", "[", 
                    RowBox[{"#", ",", "b"}], "]"}]}], "||", 
                    RowBox[{"!", 
                    RowBox[{"FreeQ", "[", 
                    RowBox[{"#", ",", "bdag"}], "]"}]}]}], "&"}]}], "]"}]}], ";",
                  "\[IndentingNewLine]", 
                 RowBox[{"If", "[", 
                  RowBox[{
                   RowBox[{
                    RowBox[{"Length", "[", "modeFactors", "]"}], "==", "0"}], 
                   ",", 
                   RowBox[{"Return", "[", "1", "]"}]}], "]"}], ";", 
                 "\[IndentingNewLine]", 
                 RowBox[{"parsed", "=", 
                  RowBox[{"ParseBlasiakMonomial", "[", 
                   RowBox[{
                    RowBox[{"NonCommutativeMultiply", "@@", "modeFactors"}], ",",
                     "b"}], "]"}]}], ";", "\[IndentingNewLine]", 
                 RowBox[{"If", "[", 
                  RowBox[{
                   RowBox[{"parsed", "===", "$Failed"}], ",", 
                   RowBox[{"Return", "[", "$Failed", "]"}]}], "]"}], ";", 
                 "\[IndentingNewLine]", 
                 RowBox[{
                  RowBox[{"{", 
                   RowBox[{"rList", ",", "sList"}], "}"}], "=", "parsed"}], ";",
                  "\[IndentingNewLine]", 
                 RowBox[{"BlasiakNormalOrder", "[", 
                  RowBox[{"rList", ",", "sList", ",", "b"}], "]"}]}]}], 
               "]"}]}], "]"}], ",", "modeVars"}], "]"}]}], ";", 
         "\[IndentingNewLine]", 
         RowBox[{"If", "[", 
          RowBox[{
           RowBox[{"MemberQ", "[", 
            RowBox[{"modePolys", ",", "$Failed"}], "]"}], ",", 
           RowBox[{"Return", "[", "$Failed", "]"}]}], "]"}], ";", 
         "\[IndentingNewLine]", 
         RowBox[{"finalExpr", "=", 
          RowBox[{"Fold", "[", 
           RowBox[{
            RowBox[{
             RowBox[{"If", "[", 
              RowBox[{
