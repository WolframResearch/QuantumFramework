Cell["Example 4: Input with scalar symbols", "Subsection",
 CellChangeTimes->{{3.9875081623553486`*^9, 
  3.9875081796226254`*^9}},ExpressionUUID->"35ebb585-f9c5-7942-b725-\
43b0927fcd0f"],

Cell[CellGroupData[{

Cell["\<\
x = sm.Symbol(\"x\")
latex(
bl.normal_ordering(x * b_1 * x**2 * bd_1**2)
)\
\>", "ExternalLanguage",
 TaggingRules-><|
  "ExternalEvaluateData" -> <|
    "System" -> "Python", "SessionID" -> "default-python-session", 
     "Evaluator" -> Automatic|>|>,
 CellEvaluationLanguage->"Python",
