  3.987510654857378*^9}},ExpressionUUID->"0b2d038b-8974-d84e-b7d2-\
a67047912f28"],

Cell[BoxData[
 RowBox[{
  RowBox[{"BosonicRelations", "[", "vars_List", "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", "pairs", "}"}], ",", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"pairs", "=", 
      RowBox[{"Subsets", "[", 
       RowBox[{"vars", ",", 
        RowBox[{"{", "2", "}"}]}], "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"Map", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{"MatchQ", "[", 
           RowBox[{"#", ",", 
            RowBox[{
             RowBox[{"{", 
              RowBox[{"x_", ",", 
               RowBox[{"SuperDagger", "[", "x_", "]"}]}], "}"}], "|", 
             RowBox[{"{", 
              RowBox[{
               RowBox[{"SuperDagger", "[", "x_", "]"}], ",", "x_"}], 
              "}"}]}]}], "]"}], ",", 
          RowBox[{
           RowBox[{"Commutator", "[", 
            RowBox[{
             RowBox[{"#", "[", 
              RowBox[{"[", "1", "]"}], "]"}], ",", 
             RowBox[{"#", "[", 
              RowBox[{"[", "2", "]"}], "]"}]}], "]"}], "-", "1"}], ",", 
          RowBox[{"Commutator", "[", 
           RowBox[{
            RowBox[{"#", "[", 
             RowBox[{"[", "1", "]"}], "]"}], ",", 
            RowBox[{"#", "[", 
             RowBox[{"[", "2", "]"}], "]"}]}], "]"}]}], "  ", "]"}], "&"}], ",",
        "pairs"}], "]"}]}]}], "]"}]}]], "Input",
 CellChangeTimes->{{3.9875106570707817`*^9, 3.9875106955709*^9}},
