}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"NonCommutativePolynomialReduce", "[", 
   RowBox[{"expr", ",", "rels", ",", "vars"}], "]"}], "[", 
