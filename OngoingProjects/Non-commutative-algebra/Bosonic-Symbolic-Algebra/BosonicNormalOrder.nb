      RowBox[{"{", "}"}]}], "}"}]}], ";"}], "\n"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"BosonicNormalOrder", "[", 
    RowBox[{"expr_", ",", "vars_List", ",", 
     RowBox[{"OptionsPattern", "[", "]"}]}], "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
      "orderedVars", ",", "rels", ",", "scalars", ",", "alg", ",", "result"}],
       "}"}], ",", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"orderedVars", "=", 
       RowBox[{"OrderBosonicVariables", "[", "vars", "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"rels", "=", 
       RowBox[{"BosonicRelations", "[", "orderedVars", "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"scalars", "=", 
       RowBox[{"OptionValue", "[", "\"\<Scalars\>\"", "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"If", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"Length", "[", "scalars", "]"}], ">", "0"}], ",", 
        RowBox[{
         RowBox[{"alg", "=", 
          RowBox[{"NonCommutativeAlgebra", "[", 
           RowBox[{"\"\<ScalarVariables\>\"", "->", "scalars"}], "]"}]}], ";",
          "\[IndentingNewLine]", 
         RowBox[{"result", "=", 
          RowBox[{
           RowBox[{"NonCommutativePolynomialReduce", "[", 
            RowBox[{"expr", ",", "rels", ",", "orderedVars", ",", "alg"}], 
            "]"}], "[", 
           RowBox[{"[", "2", "]"}], "]"}]}], ";"}], ",", 
        RowBox[{
         RowBox[{"result", "=", 
          RowBox[{
           RowBox[{"NonCommutativePolynomialReduce", "[", 
            RowBox[{"expr", ",", "rels", ",", "orderedVars"}], "]"}], "[", 
           RowBox[{"[", "2", "]"}], "]"}]}], ";"}]}], "]"}], ";", 
      "\[IndentingNewLine]", "result"}]}], "]"}]}], ";"}]}], "Input",
