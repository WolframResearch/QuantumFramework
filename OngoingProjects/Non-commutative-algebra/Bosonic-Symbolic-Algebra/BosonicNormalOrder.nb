Cell["Using non-commutative algebra:", "Text",
 CellChangeTimes->{{3.987505611274704*^9, 
  3.987505621044983*^9}},ExpressionUUID->"5adfaede-60d6-ff40-9800-\
80ebc63cd9f0"],

Cell[BoxData[
 RowBox[{
  RowBox[{"vars", " ", "=", " ", 
   RowBox[{"{", 
