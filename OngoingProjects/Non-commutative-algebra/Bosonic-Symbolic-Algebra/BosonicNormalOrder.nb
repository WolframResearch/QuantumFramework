da6e191f0ece"],

Cell[CellGroupData[{

Cell["\<\
import time

start = time.perf_counter()
expr = ((b**5 * bd**5)**10).expand()
x = sm.Symbol(\"x\")
l = latex(bl.normal_ordering(x * b_3 * x**3 * bd_1 * b_2 *bd_3**2*b_2*bd_1**2))
end = time.perf_counter()

print(f\"Duration: {end - start:.6f} seconds\")
l\
\>", "ExternalLanguage",
 TaggingRules-><|
  "ExternalEvaluateData" -> <|
    "System" -> "Python", "SessionID" -> "default-python-session", 
     "Evaluator" -> Automatic|>|>,
 CellEvaluationLanguage->"Python",
 CellChangeTimes->{{3.9875209632584057`*^9, 3.987520992926981*^9}, {
