 CellLabel->"In[95]:=",ExpressionUUID->"bb79dd09-244e-eb43-9a45-de74f34976b8"],

Cell[BoxData["\<\"2 x^{3} {b^\\\\dagger_{1}} + x^{3} {b^\\\\dagger_{1}}^{2} \
b_{1}\"\>"], "Output",
 CellChangeTimes->{3.987508765011141*^9},
 CellLabel->"Out[95]=",ExpressionUUID->"eef4efee-da76-d64c-8ebc-d51f06d7f960"]
}, Open  ]],

