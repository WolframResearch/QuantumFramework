Notebook[{

Cell[CellGroupData[{
Cell["PacletFunctionGraph", "GuideTitle",
 CellID->595721978,ExpressionUUID->"aea2604b-d295-4a16-943e-8242a8a04c9d"],

Cell[TextData[{
 "PacletFunctionGraph introspects any Wolfram Language paclet and produces a \
directed function-relation graph capturing how the paclet's head symbols \
compose. Each public symbol becomes a node; directed edges record which heads \
accept which others as inputs, and which produce which on application. The \
graph is paclet-agnostic \[LongDash] no manual configuration is required for \
predicates, options, or naming conventions: predicate guards like ",
 Cell[BoxData[
  RowBox[{"_", "?", "MyHeadQ"}]], "InlineFormula",ExpressionUUID->
  "9192ca28-d369-47f4-a24b-0462452211a5"],
 " are resolved automatically by walking the predicate's own DownValues."
}], "GuideAbstract",
 CellID->963500335,ExpressionUUID->"34dbc6d6-b124-41b4-b740-6cf04839a859"],

Cell["\<\
The workflow has three steps: build the graph from a paclet path, optionally \
cache it to disk, then query or render. Two paclet-agnostic renderers ship \
for the most common views \[LongDash] a whole-paclet overview and a \
single-symbol neighborhood \[LongDash] and the underlying edge list is \
exposed as a primitive for custom analyses.\
\>", "GuideAbstract",
 CellID->881007594,ExpressionUUID->"466add87-b527-4165-ba12-6e5c689cda45"],

Cell[CellGroupData[{

Cell["", "GuideFunctionsSection",
 CellID->100024402,ExpressionUUID->"a55d28d3-bf01-407b-9f3d-b48c49b0ffa6"],

Cell["Building the graph", "GuideFunctionsSubsection",
 CellID->337615641,ExpressionUUID->"6b8ab96e-c84c-46b3-acc6-2af0233575b2"],

Cell[TextData[{
 Cell[BoxData[
  ButtonBox["BuildFunctionGraph",
   BaseStyle->"Link",
   ButtonData->"paclet:Wolfram/PacletFunctionGraph/ref/BuildFunctionGraph"]], 
  "InlineGuideFunction",ExpressionUUID->
  "7f1c1085-1e04-4cda-b591-3eec80587c2e"],
 " \[LongDash] ",
 "introspect a paclet and emit the function-relation graph as an Association"
}], "GuideText",
 CellID->449441864,ExpressionUUID->"b2593486-08f5-41c2-ad82-53f3481299c1"],

Cell[TextData[{
 Cell[BoxData[
  ButtonBox["LoadFunctionGraph",
   BaseStyle->"Link",
   ButtonData->"paclet:Wolfram/PacletFunctionGraph/ref/LoadFunctionGraph"]], 
  "InlineGuideFunction",ExpressionUUID->
  "024be510-b1a5-4751-8a59-45a7dbeaa76a"],
 " \[LongDash] ",
 "read a previously-built graph from disk in a sandboxed context"
}], "GuideText",
 CellID->435788883,ExpressionUUID->"5c75409f-60f6-46a7-aad0-b7a5fdd98d10"]
}, Open  ]],

