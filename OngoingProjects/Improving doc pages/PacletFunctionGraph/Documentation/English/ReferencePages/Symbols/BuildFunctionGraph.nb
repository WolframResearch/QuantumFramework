Notebook[{

Cell[CellGroupData[{
Cell["BuildFunctionGraph", "ObjectName",
 CellID->675019506,ExpressionUUID->"f9d92f1e-e210-47fa-a704-013324fd7496"],

Cell[TextData[{
 Cell["\t", "ModInfo",ExpressionUUID->
  "932afd24-f8b3-417e-a48f-241f84862b4b"],
 Cell[BoxData[
  RowBox[{
   ButtonBox["BuildFunctionGraph",
    BaseStyle->"Link",
    ButtonData->"paclet:Wolfram/PacletFunctionGraph/ref/BuildFunctionGraph"], 
   "[", 
   StyleBox["path", "TI"], "]"}]], "InlineFormula",ExpressionUUID->
  "c6446901-1fd1-4137-8ddb-4788c4a1ee32"],
 "\[LineSeparator]loads the paclet at ",
 Cell[BoxData[
  StyleBox["path", "TI"]], "InlineFormula",ExpressionUUID->
  "dd808feb-9c0b-4259-8284-47fa14b7d605"],
 ", walks every public symbol's DownValues and SubValues, and returns an \
Association keyed by symbol name. As a side effect, writes the same \
Association to ",
 Cell[BoxData["\"\<path\>\""], "InlineFormula",ExpressionUUID->
  "08d59ea4-9ef1-43da-9465-85e8ce44597c"],
 "/Resources/FunctionGraph.wl.\n",
 Cell["\t", "ModInfo",ExpressionUUID->
  "fe150cbd-457b-499e-ad82-6fd4021b07c9"],
 Cell[BoxData[
  RowBox[{
   ButtonBox["BuildFunctionGraph",
    BaseStyle->"Link",
    ButtonData->"paclet:Wolfram/PacletFunctionGraph/ref/BuildFunctionGraph"], 
   "[", 
   RowBox[{
    StyleBox["path", "TI"], ",", " ", 
    StyleBox["opts", "TI"]}], "]"}]], "InlineFormula",ExpressionUUID->
  "16113fd9-5dee-45dd-a7b1-9026fae8b811"],
 "\[LineSeparator]accepts options that customize introspection, output \
target, and predicate resolution."
}], "Usage",
 CellID->593192022,ExpressionUUID->"9213165b-b182-4ed6-87f6-617c4522ee4d"],

Cell[TextData[{
 "The paclet at ",
 Cell[BoxData[
  StyleBox["path", "TI"]], "InlineFormula",ExpressionUUID->
  "dc58a6b9-e38e-4de0-8cd5-2bfb48e70258"],
 " is loaded into the current kernel via ",
 Cell[BoxData[
 "PacletDirectoryLoad"], "InlineFormula",ExpressionUUID->
  "42ebc692-6749-48ca-aa66-4dfe5bbbd105"],
 " and ",
 Cell[BoxData[
 "Needs"], "InlineFormula",ExpressionUUID->
  "3c5519a8-0582-4474-b746-09011bf95309"],
 ". The list of public symbols is read from the ",
 Cell[BoxData["\"\<Symbols\>\""], "InlineFormula",ExpressionUUID->
  "37cb994f-4830-4ce0-8d0a-6566d01e226e"],
 " field of the paclet's Kernel extension in ",
 Cell[BoxData[
  RowBox[{"PacletInfo", ".", "wl"}]], "InlineFormula",ExpressionUUID->
  "5c776a66-4a4b-4419-a051-c0058b7d4b94"],
 "."
}], "Notes",
 CellID->816796639,ExpressionUUID->"1dffe3fc-e780-41d9-9148-f90923defd52"],

Cell[TextData[{
 "The returned Association has two top-level levels: a ",
 Cell[BoxData["\"\<$Meta\>\""], "InlineFormula",ExpressionUUID->
  "b0df5a67-c1a5-4f9d-8bb9-7c41fca5e760"],
 " entry recording paclet name, version, primary context, timestamp, and any \
generation issues; and one entry per public symbol carrying the symbol's \
per-API record."
}], "Notes",
 CellID->763194896,ExpressionUUID->"90968fcf-124a-41ef-aaeb-b687238d1c86"],

Cell[TextData[{
 "Each per-symbol entry is itself an Association with keys ",
 Cell[BoxData["\"\<Kind\>\""], "InlineFormula",ExpressionUUID->
  "b25b14ec-112c-4815-aa44-2f95202ecfd3"],
 ", ",
 Cell[BoxData["\"\<Accepts\>\""], "InlineFormula",ExpressionUUID->
  "f4cce324-c1e7-4e8d-ba79-a26dc6264f7e"],
 ", ",
 Cell[BoxData["\"\<OperatesOn\>\""], "InlineFormula",ExpressionUUID->
  "34320efa-2f0c-418a-931a-bdd9199d5e39"],
 ", and ",
 Cell[BoxData["\"\<ConsumedBy\>\""], "InlineFormula",ExpressionUUID->
  "a730cd33-3a40-4a30-912e-872116f8cc7e"],
 "."
}], "Notes",
 CellID->552817229,ExpressionUUID->"40f5b567-41e3-49c8-bc40-217f1d33bf72"],

Cell[TextData[{
 Cell[BoxData["\"\<Kind\>\""], "InlineFormula",ExpressionUUID->
  "6f34a78c-ea36-42df-88e2-de7476a7f09c"],
 " is a classification string: ",
 Cell[BoxData["\"\<Constructor\>\""], "InlineFormula",ExpressionUUID->
  "f371a6a3-ce89-41f5-b63f-ce2e90bc4e18"],
 ", ",
 Cell[BoxData["\"\<Operator\>\""], "InlineFormula",ExpressionUUID->
  "d7310c6d-e3dd-4070-aac1-df2099c80ef1"],
 ", ",
 Cell[BoxData["\"\<Transform\>\""], "InlineFormula",ExpressionUUID->
  "1863cf13-bd86-48f9-b204-2424bf0def1d"],
 ", ",
 Cell[BoxData["\"\<Predicate\>\""], "InlineFormula",ExpressionUUID->
  "364e7e29-5b18-49fe-a612-389bc7feedeb"],
 ", ",
 Cell[BoxData["\"\<Distance\>\""], "InlineFormula",ExpressionUUID->
  "ae6a2434-4869-4f0d-a664-4932c2e1c349"],
 ", ",
 Cell[BoxData["\"\<NamedInstance\>\""], "InlineFormula",ExpressionUUID->
  "75cf3842-6eb5-4ff4-8bff-d2e436681808"],
 ", or ",
 Cell[BoxData["\"\<Utility\>\""], "InlineFormula",ExpressionUUID->
  "5bfcd60c-559e-4b6f-bd48-32a59fcf2399"],
 "."
}], "Notes",
 CellID->614759223,ExpressionUUID->"8fe44f67-660f-463e-8e08-4acba9aa42be"],

Cell[TextData[{
 Cell[BoxData["\"\<Accepts\>\""], "InlineFormula",ExpressionUUID->
  "7370b20c-0a06-4702-b24d-1cbfcdb06ac5"],
 " is a list of Associations describing the symbol's first-argument input \
forms. Each entry carries ",
 Cell[BoxData["\"\<Head\>\""], "InlineFormula",ExpressionUUID->
  "7ce12eb1-7ac9-4d71-a58d-888995dd8678"],
 " (the WL head), ",
 Cell[BoxData["\"\<Role\>\""], "InlineFormula",ExpressionUUID->
  "433d8a66-ea1a-4c5b-9893-dad4678f108c"],
 " (semantic role such as ",
 Cell[BoxData["\"\<Primary\>\""], "InlineFormula",ExpressionUUID->
  "1da4c555-8df2-445e-9988-35576768f516"],
 ", ",
 Cell[BoxData["\"\<Mutation\>\""], "InlineFormula",ExpressionUUID->
  "eb2158c9-2671-4959-b840-66bc01c93248"],
 ", or ",
 Cell[BoxData["\"\<Conversion\>\""], "InlineFormula",ExpressionUUID->
  "93d02409-45c3-4632-a229-e908e7a28297"],
 "), and ",
 Cell[BoxData["\"\<Description\>\""], "InlineFormula",ExpressionUUID->
  "40f1aa9b-bc2e-4362-be22-193899a948d9"],
 "."
}], "Notes",
 CellID->398471814,ExpressionUUID->"c18d8e4e-331e-4a44-ab0f-b28d63d98b7b"],

Cell[TextData[{
 Cell[BoxData["\"\<OperatesOn\>\""], "InlineFormula",ExpressionUUID->
  "46e9a0f0-eb6c-4e6d-8da6-421e99201f87"],
 " is ",
 Cell[BoxData[
 "None"], "InlineFormula",ExpressionUUID->
  "1e95427b-1786-488d-b296-604a48795090"],
 " for non-operator symbols. For operator-like heads it is an Association \
mapping target heads to result-head descriptions."
}], "Notes",
 CellID->178488255,ExpressionUUID->"4ca9eade-1b17-42eb-b656-c708db3c6c96"],

Cell[TextData[{
 Cell[BoxData["\"\<ConsumedBy\>\""], "InlineFormula",ExpressionUUID->
  "9286ab86-c18e-42fd-ba3f-b9fea5df31c5"],
 " is a reverse-edge list: every other paclet symbol that takes this one as \
an input."
}], "Notes",
 CellID->237315060,ExpressionUUID->"825034a4-df6a-4d3e-bfae-00d1da9b008f"],

Cell[TextData[{
 "Predicates the paclet uses \[LongDash] such as ",
 Cell[BoxData[
  RowBox[{"_", "?", "QuantumStateQ"}]], "InlineFormula",ExpressionUUID->
  "8ab92101-7f63-4271-9b95-77f88ef8b088"],
 " or ",
 Cell[BoxData[
  RowBox[{"_", "?", "propQ"}]], "InlineFormula",ExpressionUUID->
  "d6e60734-8d6c-4f33-8f64-ee263c8396a0"],
 " \[LongDash] are resolved automatically by walking each predicate's own \
DownValues. No manual configuration is required for any paclet. The \
auto-detector recognizes four LHS/RHS shapes: explicit head blanks, call-form \
patterns, delegated predicates, and ",
 Cell[BoxData[
 "MatchQ"], "InlineFormula",ExpressionUUID->
  "ff3691a4-563c-48a5-9a82-8c3586105459"],
 "-based dispatch."
}], "Notes",
 CellID->129333348,ExpressionUUID->"9b28ca5b-e0d0-4b4f-965b-d91b8f602bbd"],

Cell[TextData[{
 Cell[BoxData[
 "BuildFunctionGraph"], "InlineFormula",ExpressionUUID->
  "090cbe39-9864-4e1e-946f-5a02cea3f923"],
 " returns a ",
 Cell[BoxData[
 "Failure"], "InlineFormula",ExpressionUUID->
  "3a569c8d-afc6-475a-9229-d5ffa239970d"],
 " object",
 " when the paclet path does not exist, when ",
 Cell[BoxData[
  RowBox[{"PacletInfo", ".", "wl"}]], "InlineFormula",ExpressionUUID->
  "33f80547-0930-4eaa-88fb-28013841437e"],
 " is missing or malformed, when the paclet has no Kernel extension, or when \
the paclet's primary context loads zero symbols."
}], "Notes",
 CellID->869339655,ExpressionUUID->"2cd5de95-5f3c-44a1-8539-9ed8fecd7255"],

Cell[TextData[{
 "Issues encountered during generation are NOT surfaced as Messages \
\[LongDash] they are recorded in ",
 Cell[BoxData[
  RowBox[{"$Meta", "[", "\"\<GenerationIssues\>\"", "]"}]], "InlineFormula",
  ExpressionUUID->"fac6f083-fed7-4efa-aba0-cbc7fc7cdd4b"],
 " so a build can complete with partial information."
}], "Notes",
 CellID->392990222,ExpressionUUID->"f59f1763-ac5f-40f8-90de-690234530b5d"],

Cell["The following options can be given:", "Notes",
 CellID->482650468,ExpressionUUID->"3e401d43-3996-4b07-9b12-74fe28566607"],

Cell[BoxData[GridBox[{
   {Cell["", "ModInfo",ExpressionUUID->
     "cc4d78d1-6d1f-49a6-a34a-482f7dd6157d"], Cell[
    "\"OutputFile\"", "TableText",ExpressionUUID->
     "6bc61e4c-9883-4dcd-bdbb-c13e76d2d811"], Cell[
    "Automatic", "TableText",ExpressionUUID->
     "ea877e8a-5621-421d-8ea6-a18642643f2e"], Cell["\<\
path to write the graph to; Automatic resolves to \
<path>/Resources/FunctionGraph.wl\
\>", "TableText",ExpressionUUID->"0012a6ea-053f-414f-84f2-3ce751bc74f4"]},
   {Cell["", "ModInfo",ExpressionUUID->
     "906c7391-40a0-4522-8896-fd81fd49f810"], Cell[
    "\"WriteFile\"", "TableText",ExpressionUUID->
     "2920921b-3f68-47a1-a8bf-171f09d219b3"], Cell[
    "True", "TableText",ExpressionUUID->
     "7e5a1a92-9636-48d6-8ace-5eda8f38b216"], Cell[
    "when False, return the Association without writing to disk", "TableText",
     ExpressionUUID->"4729671b-b5bd-4cb6-85fb-3efcf7350c43"]},
   {Cell["", "ModInfo",ExpressionUUID->
     "a111ee7d-8906-4e72-87ed-715f696fe47d"], Cell[
    "\"Exclude\"", "TableText",ExpressionUUID->
     "70c3cc24-dca0-4c6a-b670-ec48f278abd3"], Cell[
    "{}", "TableText",ExpressionUUID->"3c6dc694-148a-45a3-87e8-65152fa9b8d4"],
     Cell["list of symbol names to skip during introspection", "TableText",
     ExpressionUUID->"3c0e60ee-3597-4701-a280-84662511bffb"]},
   {Cell["", "ModInfo",ExpressionUUID->
     "901513fb-d328-40b6-a65d-bcd77bef104e"], Cell[
    "\"OnlySymbol\"", "TableText",ExpressionUUID->
     "5b282006-d4c0-45d4-abfd-d1563e3b41f1"], Cell[
    "None", "TableText",ExpressionUUID->
     "4d1ec3a1-97e7-4d62-b39c-6ef267afec19"], Cell["\<\
when set to a string, limit introspection to that single symbol\
\>", "TableText",ExpressionUUID->"eb21593e-f8b0-40ba-a6e1-87a9a339d8c1"]},
   {Cell["", "ModInfo",ExpressionUUID->
     "8205f534-aae9-440f-a398-ec7bf8464ff4"], Cell[
    "\"PredicateHeads\"", "TableText",ExpressionUUID->
     "eeb777e3-a21c-40fd-a7c6-b2ceb8f13b91"], Cell[
    "<||>", "TableText",ExpressionUUID->
     "40055ef1-d753-41cb-b871-abbf1197d3a4"], Cell["\<\
extra predicateName -> {Head, ...} entries that override or supplement \
auto-detection\
\>", "TableText",ExpressionUUID->"0c518fe0-1988-4918-bcc7-8830186adbcf"]},
   {Cell["", "ModInfo",ExpressionUUID->
     "bc3326bb-9e2f-4d2b-b602-68763f2a83a1"], Cell[
    "\"KindClassifier\"", "TableText",ExpressionUUID->
     "faeeda35-211a-4a96-ad9c-13e89bc8545b"], Cell[
    "Automatic", "TableText",ExpressionUUID->
     "e6a1c88a-ef5f-4ce3-891a-c998d93938f9"], Cell["\<\
custom Symbol -> Kind classifier; Automatic uses a name-based heuristic\
\>", "TableText",ExpressionUUID->"d84ab755-ce88-4c06-848a-537705e577ed"]}
  },
  GridBoxAlignment->{
   "Columns" -> {{Left}}, "Rows" -> {{Baseline}}}]], "3ColumnTableMod",
 CellID->791664283,ExpressionUUID->"87e3a3a0-4987-452b-9c8c-7ae22bb1bec1"],

