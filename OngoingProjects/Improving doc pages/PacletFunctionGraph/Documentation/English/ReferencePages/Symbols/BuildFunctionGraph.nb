 CellID->592597773,ExpressionUUID->"8e545a7e-aa13-41b3-af86-beb631178891"],

Cell["\<\
For predicates whose heads cannot be inferred from DownValues alone, supply \
them explicitly. Entries supplied here take precedence over auto-detection:\
\>", "ExampleText",
 CellID->804002361,ExpressionUUID->"9de1a8d5-c242-412e-94cf-b3f84dc2ffb9"],

Cell[BoxData[
 RowBox[{
  RowBox[{"BuildFunctionGraph", "[", 
   RowBox[{"qfRoot", ",", "\n", "    ", 
    RowBox[{"\"\<PredicateHeads\>\"", " ", "->", " ", 
     RowBox[{"<|", 
      RowBox[{"\"\<MyExoticPredQ\>\"", " ", "->", " ", 
       RowBox[{"{", 
        RowBox[{"\"\<MyHead1\>\"", ",", " ", "\"\<MyHead2\>\""}], "}"}]}], 
      "|>"}]}], ",", "\n", "    ", 
    RowBox[{"\"\<WriteFile\>\"", " ", "->", " ", "False"}]}], "]"}], 
  ";"}]], "Input",
 CellLabel->"In[1]:=",
 CellID->638685167,ExpressionUUID->"4f82788d-34ed-4100-b48a-3083fafbebcb"]
}, Open  ]]
