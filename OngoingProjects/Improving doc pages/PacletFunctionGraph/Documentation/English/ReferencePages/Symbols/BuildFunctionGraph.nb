Cell[TextData[{
 "The schema written to disk is the same as the in-memory return value \
\[LongDash] ",
 Cell[BoxData[
 "LoadFunctionGraph"], "InlineFormula",ExpressionUUID->
  "74adc1f9-e164-416e-8c64-dd004f8a746a"],
 " round-trips at the key level (head symbols are re-interned in a sandbox \
context on load):"
}], "ExampleText",
 CellID->588330894,ExpressionUUID->"6546e592-634d-4fd3-8dfe-1262ddc3bc3a"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"BuildFunctionGraph", "[", 
   RowBox[{"qfRoot", ",", " ", 
    RowBox[{"\"\<OutputFile\>\"", " ", "->", " ", "\"\</tmp/g.wl\>\""}]}], 
   "]"}], ";"}], "\n", 
 RowBox[{
  RowBox[{"loaded", " ", "=", " ", 
   RowBox[{"LoadFunctionGraph", "[", "\"\</tmp/g.wl\>\"", "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"inMem", "  ", "=", " ", 
   RowBox[{"BuildFunctionGraph", "[", 
    RowBox[{"qfRoot", ",", " ", 
     RowBox[{"\"\<WriteFile\>\"", " ", "->", " ", "False"}]}], "]"}]}], 
  ";"}], "\n", 
 RowBox[{
  RowBox[{"Sort", "@", 
   RowBox[{"Keys", "[", 
    RowBox[{"KeyDrop", "[", 
     RowBox[{"loaded", ",", " ", "\"\<$Meta\>\""}], "]"}], "]"}]}], " ", "===",
   " ", 
  RowBox[{"Sort", "@", 
   RowBox[{"Keys", "[", 
    RowBox[{"KeyDrop", "[", 
     RowBox[{"inMem", ",", " ", "\"\<$Meta\>\""}], "]"}], "]"}]}]}]}], "Input",\

