 CellID->948015644,ExpressionUUID->"5cf426c7-6cea-4bb9-bc2f-9bd95be79bbb"],

Cell[TextData[{
 "Predicates whose dispatch logic is too complex for the heuristics fall back \
to the bare ",
 Cell[BoxData[
 "Symbol"], "InlineFormula",ExpressionUUID->
  "40b0f158-ee32-4814-b516-30aa12e47652"],
 " head and are listed in ",
 Cell[BoxData[
  RowBox[{"$Meta", "[", "\"\<GenerationIssues\>\"", "]"}]], "InlineFormula",
  ExpressionUUID->"d1dc0438-ded3-40e9-8df9-1c4f7e3ff663"],
 ". Use this to audit what auto-detection caught:"
}], "ExampleText",
 CellID->260574504,ExpressionUUID->"8869ddf7-307d-498b-b36d-3bd4c2215e83"],

Cell[BoxData[
 RowBox[{"Tally", "[", 
  RowBox[{"g", "[", 
   RowBox[{"\"\<$Meta\>\"", ",", " ", "\"\<GenerationIssues\>\""}], "]"}], 
  "]"}]], "Input",
 CellLabel->"In[2]:=",
 CellID->633631458,ExpressionUUID->"2da69e9c-2110-4bee-a95e-91f8f5f53bc4"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"\<\"unresolved predicate targetsQ - fallback to Symbol\"\>", ",",
      "1"}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{"\<\"unresolved predicate targetQ - fallback to Symbol\"\>", ",", 
     "1"}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{"\<\"unresolved predicate stateQ - fallback to Symbol\"\>", ",", 
     "5"}], "}"}]}], "}"}]], "Output",
 CellLabel->"Out[2]=",
 CellID->461614459,ExpressionUUID->"4386f2ab-1b84-46ff-b478-b4220c0f463e"]
}, Open  ]],

