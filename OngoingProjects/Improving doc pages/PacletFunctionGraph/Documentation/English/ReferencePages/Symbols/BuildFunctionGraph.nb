Cell[TextData[{
 "Symbols whose DownValues are dispatched purely through ",
 Cell[BoxData[
 "MatchQ"], "InlineFormula",ExpressionUUID->
  "80bb89fe-4da8-4678-9c2b-63b3967d6eae"],
 " on non-head patterns (e.g. ",
 Cell[BoxData[
  RowBox[{
   RowBox[{"Q", "[", "x_", "]"}], " ", ":=", " ", 
   RowBox[{"x", " ", ">", " ", "0"}]}]], "InlineFormula",ExpressionUUID->
  "f8ab823e-df77-4939-b9c4-5c1ca4f7bc69"],
 ") cannot be classified by head and contribute no edges. The symbol still \
appears as a node, but its Accepts list will be sparse."
}], "ExampleText",
 CellID->47118688,ExpressionUUID->"5f54e41d-3197-4a50-beab-3a258d05ec3d"]
}, Open  ]],

