Cell[TextData[{
 Cell[BoxData["\"\<OnlySymbol\>\""], "InlineFormula",ExpressionUUID->
  "6783ae0f-4a7b-40eb-bb6b-340e08150245"],
 " produces a strict subset of the full build's Accepts and OperatesOn for \
that symbol. ConsumedBy differs because the reverse-edge pass over a \
one-symbol graph can't see who consumes it:"
}], "ExampleText",
 CellID->630201173,ExpressionUUID->"cfb161e1-5e0e-4113-93c2-dc16f1b6c3e5"],

