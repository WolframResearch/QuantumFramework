Cell[CellGroupData[{

Cell["Distinctive Features", "ExampleSubsection",
 CellID->358560574,ExpressionUUID->"dac3a174-bade-4199-aaba-4fb6637acf71"],

Cell[TextData[{
 "Auto-detection of paclet predicates is the package's distinguishing \
capability. QuantumFramework defines ",
 Cell[BoxData[
 "QuantumStateQ"], "InlineFormula",ExpressionUUID->
  "a50e2142-0cc2-4b25-bb74-95c847b7f0cd"],
 ", ",
 Cell[BoxData[
 "QuantumOperatorQ"], "InlineFormula",ExpressionUUID->
  "0ffd08db-0114-4b50-af04-6f8cfa8d3137"],
 ", ",
 Cell[BoxData[
 "propQ"], "InlineFormula",ExpressionUUID->
  "1fd9bc2e-ace7-47ab-af93-43ce3a752059"],
 ", ",
 Cell[BoxData[
 "QuantumFrameworkOperatorQ"], "InlineFormula",ExpressionUUID->
  "55da1ffb-102b-4052-a958-2e7734607186"],
 ", and a dozen more \[LongDash] none of them needs to be declared by the \
caller. Look at QuantumDistance's accepted inputs: the ",
 Cell[BoxData[
  RowBox[{"_", "?", "QuantumStateQ"}]], "InlineFormula",ExpressionUUID->
  "e2de150d-5f0a-465f-9926-6c676f844933"],
 " guard was resolved automatically to ",
 Cell[BoxData[
 "QuantumState"], "InlineFormula",ExpressionUUID->
  "49e23968-945a-4b61-a89f-6fc0ad097c97"],
 ":"
}], "ExampleText",
 CellID->528818214,ExpressionUUID->"6b5ffae7-569e-4caf-9d61-ad984d780a6e"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"g", " ", "=", " ", 
   RowBox[{"BuildFunctionGraph", "[", 
    RowBox[{"qfRoot", ",", " ", 
     RowBox[{"\"\<WriteFile\>\"", " ", "->", " ", "False"}]}], "]"}]}], 
  ";"}], "\n", 
 RowBox[{"g", "[", 
  RowBox[{"\"\<QuantumDistance\>\"", ",", " ", "\"\<Accepts\>\""}], 
  "]"}]}], "Input",
 CellLabel->"In[1]:=",
 CellID->381895340,ExpressionUUID->"82984a37-508e-4b8e-a993-a53d0ada21d5"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"\[LeftAssociation]", 
   RowBox[{
    RowBox[{"\<\"Head\"\>", "\[Rule]", "QuantumState"}], ",", 
    RowBox[{"\<\"Description\"\>", "\[Rule]", "\<\"?QuantumStateQ\"\>"}], ",", 
    RowBox[{"\<\"Role\"\>", "\[Rule]", "\<\"Primary\"\>"}]}], 
   "\[RightAssociation]"}], "}"}]], "Output",
 CellLabel->"Out[1]=",
 CellID->722140897,ExpressionUUID->"05b7a265-d13c-40e2-8e54-ddf5bda58ad9"],

