Cell["\<\
Build the function-relation graph for QuantumFramework, return the \
Association in memory without writing to disk, and list the top-level keys:\
\>", "ExampleText",
 CellID->717130041,ExpressionUUID->"c2d7aa46-5bad-4b49-a83a-2bab88cd2dd3"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"qfRoot", " ", "=", " ", 
   RowBox[{
    RowBox[{"PacletObject", "[", "\"\<Wolfram/QuantumFramework\>\"", "]"}], 
    "[", "\"\<Location\>\"", "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"g", " ", "=", " ", 
   RowBox[{"BuildFunctionGraph", "[", 
    RowBox[{"qfRoot", ",", " ", 
     RowBox[{"\"\<WriteFile\>\"", " ", "->", " ", "False"}]}], "]"}]}], 
  ";"}], "\n", 
 RowBox[{"Keys", "[", "g", "]"}]}], "Input",
 CellLabel->"In[1]:=",
 CellID->528883189,ExpressionUUID->"5afc8a3f-d49f-474e-9bf6-265187f9f6b2"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"\<\"$Meta\"\>", ",", "\<\"QuantumBasis\"\>", 
   ",", "\<\"QuantumChannel\"\>", ",", "\<\"QuantumCircuitOperator\"\>", 
   ",", "\<\"QuantumDistance\"\>", ",", "\<\"QuantumEntangledQ\"\>", 
   ",", "\<\"QuantumEntanglementMonotone\"\>", ",", "\<\"QuantumEvolve\"\>", 
   ",", "\<\"QuantumMeasurement\"\>", 
   ",", "\<\"QuantumMeasurementOperator\"\>", 
   ",", "\<\"QuantumMeasurementSimulation\"\>", 
   ",", "\<\"QuantumOperator\"\>", ",", "\<\"QuantumPartialTrace\"\>", 
   ",", "\<\"QuantumPhaseSpaceTransform\"\>", 
   ",", "\<\"QuantumSimilarity\"\>", ",", "\<\"QuantumState\"\>", 
   ",", "\<\"QuantumStateEstimate\"\>", ",", "\<\"QuantumTensorProduct\"\>", 
   ",", "\<\"QuantumWignerTransform\"\>", ",", "\<\"QuditBasis\"\>", 
   ",", "\<\"QuditName\"\>"}], "}"}]], "Output",
 CellLabel->"Out[1]=",
 CellID->395874301,ExpressionUUID->"bb7b2e36-69da-4fb8-8d94-26b40252c19e"],

Cell[BoxData[""], "ExampleDelimiter",
 CellID->517794072,ExpressionUUID->"a16d3842-8720-4aa6-bf14-42ff0c1d013b"],

Cell["Inspect the paclet identity from the metadata:", "ExampleText",
 CellID->502877523,ExpressionUUID->"49ee9b98-07a5-4a4e-8aab-6d6984d23d38"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{"g", "[", 
    RowBox[{"\"\<$Meta\>\"", ",", " ", "\"\<Paclet\>\""}], "]"}], ",", " ", 
   RowBox[{"g", "[", 
    RowBox[{"\"\<$Meta\>\"", ",", " ", "\"\<PacletVersion\>\""}], "]"}]}], 
  "}"}]], "Input",
 CellLabel->"In[1]:=",
 CellID->546026023,ExpressionUUID->"22ac4282-fcb8-44ce-a1af-b7e675089104"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"\<\"Wolfram/QuantumFramework\"\>", ",", "\<\"2.0.0\"\>"}], 
  "}"}]], "Output",
 CellLabel->"Out[1]=",
 CellID->308016438,ExpressionUUID->"d3b059f0-3285-4138-bcca-ad0ba247aa6b"],

Cell[BoxData[""], "ExampleDelimiter",
 CellID->270288873,ExpressionUUID->"b5466262-adc3-4f9a-878b-c7353d538901"],

Cell["\<\
Inspect one symbol's entry. The four-field record summarises the symbol's API \
surface:\
\>", "ExampleText",
 CellID->824157304,ExpressionUUID->"67b22193-61a3-4a76-936b-e0d4ee54e121"],

Cell[BoxData[
 RowBox[{"g", "[", "\"\<QuantumDistance\>\"", "]"}]], "Input",
 CellLabel->"In[1]:=",
 CellID->872523100,ExpressionUUID->"1265ab69-ae8d-4b28-99f3-51018b77a559"],

Cell[BoxData[
 RowBox[{"\[LeftAssociation]", 
  RowBox[{
   RowBox[{"\<\"Kind\"\>", "\[Rule]", "\<\"Distance\"\>"}], ",", 
   RowBox[{"\<\"Accepts\"\>", "\[Rule]", 
    RowBox[{"{", 
     RowBox[{"\[LeftAssociation]", 
      RowBox[{
       RowBox[{"\<\"Head\"\>", "\[Rule]", "QuantumState"}], ",", 
       RowBox[{"\<\"Description\"\>", "\[Rule]", "\<\"?QuantumStateQ\"\>"}], ",", 
       RowBox[{"\<\"Role\"\>", "\[Rule]", "\<\"Primary\"\>"}]}], 
      "\[RightAssociation]"}], "}"}]}], ",", 
   RowBox[{"\<\"OperatesOn\"\>", "\[Rule]", "None"}], ",", 
   RowBox[{"\<\"ConsumedBy\"\>", "\[Rule]", 
    RowBox[{"{", "}"}]}]}], "\[RightAssociation]"}]], "Output",
 CellLabel->"Out[1]=",
 CellID->996305358,ExpressionUUID->"c19ffbc4-f5d3-4616-832c-2c5f7bd73bd0"]
}, Open  ]],

