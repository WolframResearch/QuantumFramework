Cell[BoxData[""], "ExampleDelimiter",
 CellID->4307525,ExpressionUUID->"cc028486-d571-4a62-a9be-14b81d1d3485"],

Cell["\<\
In-memory only \[LongDash] useful for inspection without touching the \
filesystem:\
\>", "ExampleText",
 CellID->963296799,ExpressionUUID->"581eaef2-6128-4d8c-b2c7-c19af9debeb7"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"g", " ", "=", " ", 
   RowBox[{"BuildFunctionGraph", "[", 
    RowBox[{"qfRoot", ",", " ", 
     RowBox[{"\"\<WriteFile\>\"", " ", "->", " ", "False"}]}], "]"}]}], 
  ";"}], "\n", 
 RowBox[{"Length", "[", "g", "]"}]}], "Input",
 CellLabel->"In[2]:=",
 CellID->230149098,ExpressionUUID->"28637d7f-f858-42ff-8b46-49fd1c2fc449"],

Cell[BoxData["21"], "Output",
 CellLabel->"Out[2]=",
 CellID->206272464,ExpressionUUID->"00a3c84c-d875-478b-b8c2-0335330fd087"],

Cell[BoxData[""], "ExampleDelimiter",
