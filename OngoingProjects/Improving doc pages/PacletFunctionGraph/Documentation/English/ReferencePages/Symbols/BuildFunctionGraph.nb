Cell[TextData[{
 "Use ",
 Cell[BoxData["\"\<OnlySymbol\>\""], "InlineFormula",ExpressionUUID->
  "1ae3cc94-f5a9-4156-b875-2e05558ff3ad"],
 " to iterate on a single symbol's signature without re-introspecting the \
whole paclet:"
}], "ExampleText",
 CellID->569603488,ExpressionUUID->"9132cbe3-e890-46ff-90c6-588aa4034f52"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"g", " ", "=", " ", 
   RowBox[{"BuildFunctionGraph", "[", 
    RowBox[{"qfRoot", ",", " ", 
     RowBox[{"\"\<OnlySymbol\>\"", " ", "->", 
      " ", "\"\<QuantumDistance\>\""}], ",", " ", 
     RowBox[{"\"\<WriteFile\>\"", " ", "->", " ", "False"}]}], "]"}]}], 
  ";"}], "\n", 
