Cell[TextData[{
 "The paclet must list its public symbols in the ",
 Cell[BoxData["\"\<Symbols\>\""], "InlineFormula",ExpressionUUID->
  "943cb387-4d1c-4e11-b1ad-21717aabde22"],
 " field of the Kernel extension. Paclets that omit this list produce a graph \
with only ",
 Cell[BoxData["\"\<$Meta\>\""], "InlineFormula",ExpressionUUID->
  "9940db38-8bff-4285-988a-205e5654da2e"],
 "."
}], "ExampleText",
 CellID->262301551,ExpressionUUID->"8dfcd7fb-5d9c-44a0-9247-a0f0c4940307"],

Cell[TextData[{
 "The paclet is loaded with ",
 Cell[BoxData[
 "Needs"], "InlineFormula",ExpressionUUID->
  "285bc510-80e4-44c4-b967-61844c0df6a8"],
 " into the current kernel. If kernel files were modified after a previous \
build, restart the kernel before rebuilding \[LongDash] the existing \
in-kernel definitions are used, not the on-disk source."
}], "ExampleText",
 CellID->844474354,ExpressionUUID->"c36d2d93-ca62-4522-bdf8-271319dbbaeb"],

Cell[TextData[{
 "Generation issues are recorded in ",
 Cell[BoxData[
  RowBox[{"$Meta", "[", "\"\<GenerationIssues\>\"", "]"}]], "InlineFormula",
  ExpressionUUID->"d5748bc1-a2bf-4938-aa0f-7ad798938a7b"],
 ", not surfaced as Messages. Non-empty means some predicates could not be \
auto-resolved:"
}], "ExampleText",
 CellID->310853475,ExpressionUUID->"03f5b0cc-2dfe-4fbf-b8e9-f76f59a3bf75"],

