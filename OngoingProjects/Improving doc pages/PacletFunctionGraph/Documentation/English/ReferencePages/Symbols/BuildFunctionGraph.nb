Cell[TextData[{
 "Query \[OpenCurlyDoubleQuote]which symbols produce a QuantumState?\
\[CloseCurlyDoubleQuote] by filtering the flow edges. ",
 Cell[BoxData[
 "QuantumState"], "InlineFormula",ExpressionUUID->
  "2f3f5a26-28ac-4433-a9a1-57e4371f6e37"],
 " appears in its own producer list \[LongDash] that self-loop is the \
constructor accepting ",
 Cell[BoxData[
 "_QuantumState"], "InlineFormula",ExpressionUUID->
  "1da9eb54-039e-4bfa-9dd5-14b7cc7d853e"],
 " as a mutation input:"
}], "ExampleText",
 CellID->148347712,ExpressionUUID->"faf7631b-1012-4af3-94f4-9fe4087b40bb"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"edges", " ", "=", " ", 
   RowBox[{"PacletFlowEdges", "[", "g", "]"}]}], ";"}], "\n", 
 RowBox[{"producers", " ", "=", " ", 
  RowBox[{"Cases", "[", 
   RowBox[{"edges", ",", " ", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"f_", ",", " ", "\"\<QuantumState\>\""}], "}"}], " ", ":>", " ",
      "f"}]}], "]"}]}]}], "Input",
 CellLabel->"In[2]:=",
 CellID->777066994,ExpressionUUID->"03eeb6c3-03ed-4f41-828a-270deed63fd4"],

