Cell[CellGroupData[{

Cell["Building a Graph object", "ExampleSubsection",
 CellID->231675989,ExpressionUUID->"07f9156e-76c0-4265-b5f0-a9188950fea5"],

Cell[TextData[{
 "Hand the edges to ",
