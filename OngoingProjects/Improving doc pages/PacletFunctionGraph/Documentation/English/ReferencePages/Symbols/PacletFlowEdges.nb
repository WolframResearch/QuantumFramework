Cell[TextData[{
 Cell[BoxData[
 "PacletFlowEdges"], "InlineFormula",ExpressionUUID->
  "b829d819-5bdc-494a-8fef-fbab4de54bbe"],
 " returns deduplicated pairs \[LongDash] each ",
 Cell[BoxData[
  RowBox[{"{", 
   RowBox[{"A", ",", " ", "B"}], "}"}]], "InlineFormula",ExpressionUUID->
  "d5252d9c-dc2f-4211-9ee9-46f69cbc78bf"],
 " appears at most once even if multiple DownValues induce the same edge:"
}], "ExampleText",
 CellID->403012972,ExpressionUUID->"f97442c4-703f-4b13-8744-5e511f9f18a6"],

Cell[BoxData[
 RowBox[{
  RowBox[{"Length", "[", "edges", "]"}], " ", "===", " ", 
  RowBox[{"Length", "[", 
   RowBox[{"DeleteDuplicates", "[", "edges", "]"}], "]"}]}]], "Input",
 CellLabel->"In[1]:=",
 CellID->411014480,ExpressionUUID->"b1bb8d97-8ea5-4cac-afe4-4dbb2e319339"],

Cell[BoxData["True"], "Output",
 CellLabel->"Out[1]=",
 CellID->492502740,ExpressionUUID->"3046ebc0-e22a-417b-87b0-17fdfe4cc95e"],

Cell[BoxData[""], "ExampleDelimiter",
 CellID->525943957,ExpressionUUID->"a53f7aa7-d0f7-4a1f-9f4e-d11cb65df81c"],

Cell[TextData[{
 "Anti-parallel pairs \[LongDash] both ",
 Cell[BoxData[
  RowBox[{"{", 
   RowBox[{"A", ",", " ", "B"}], "}"}]], "InlineFormula",ExpressionUUID->
  "8ab8ad4b-2786-47bd-a5c5-1ef261daa602"],
 " and ",
 Cell[BoxData[
  RowBox[{"{", 
   RowBox[{"B", ",", " ", "A"}], "}"}]], "InlineFormula",ExpressionUUID->
  "021cbbb3-8190-444a-a06b-341a936bc61d"],
 " present \[LongDash] are not collapsed. They represent two distinct flow \
directions and remain separate edges:"
}], "ExampleText",
 CellID->386418624,ExpressionUUID->"c41c76b9-ba2c-4a34-b311-d529a3f2c8f3"],

Cell[BoxData[
 RowBox[{"anti", " ", "=", " ", 
  RowBox[{
   RowBox[{"Select", "[", 
    RowBox[{"edges", ",", " ", 
     RowBox[{
      RowBox[{
       RowBox[{"MemberQ", "[", 
        RowBox[{"edges", ",", " ", 
         RowBox[{"Reverse", "[", "#", "]"}]}], "]"}], " ", "&&", " ", 
       RowBox[{
        RowBox[{"#", "[", 
         RowBox[{"[", "1", "]"}], "]"}], " ", "=!=", " ", 
        RowBox[{"#", "[", 
         RowBox[{"[", "2", "]"}], "]"}]}]}], " ", "&"}]}], "]"}], " ", "//", 
   " ", "Length"}]}]], "Input",
 CellLabel->"In[2]:=",
 CellID->9376972,ExpressionUUID->"68dc14ad-e29f-4ae1-9b8f-f215396a0ec9"],

Cell[BoxData["34"], "Output",
 CellLabel->"Out[2]=",
 CellID->232269417,ExpressionUUID->"5055ec8e-99f1-413d-8d83-54e36a016225"],

Cell[BoxData[""], "ExampleDelimiter",
 CellID->865434192,ExpressionUUID->"cc6d5746-4cef-4970-b9bd-c98537bc78ee"],

Cell[TextData[{
 Cell[BoxData[
 "SymbolNeighborhoodGraph"], "InlineFormula",ExpressionUUID->
  "f38a36d1-7aab-4e10-ac73-d70b8eb8e2ef"],
 " and ",
 Cell[BoxData[
 "PacletOverviewGraph"], "InlineFormula",ExpressionUUID->
  "ded1efa9-a1de-47b4-8a0d-b723a570a654"],
 " consume exactly this edge list. Filtering ",
 Cell[BoxData[
 "PacletFlowEdges"], "InlineFormula",ExpressionUUID->
  "67047d64-ac2d-4195-84ef-781ba343056f"],
 " before passing it in is a way to render a subset:"
}], "ExampleText",
 CellID->681767520,ExpressionUUID->"48272f93-87d9-4efd-8672-a5664437e073"],

Cell[BoxData[
 RowBox[{"Length", "[", 
  RowBox[{"Select", "[", 
   RowBox[{"edges", ",", " ", 
    RowBox[{
     RowBox[{"!", 
      RowBox[{"MemberQ", "[", 
       RowBox[{"#", ",", " ", "\"\<QuantumStateEstimate\>\""}], "]"}]}], " ", 
     "&"}]}], "]"}], "]"}]], "Input",
 CellLabel->"In[3]:=",
 CellID->219404518,ExpressionUUID->"a43fe370-5516-400c-890e-655d46c0835c"],

Cell[BoxData["80"], "Output",
