}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[
 InterpretationBox[Cell[
  "Possible Issues", "ExampleSection",ExpressionUUID->
   "9e9b7c5b-e56a-48de-b22c-5cf88cd76e3b"],
  $Line = 0; Null]], "ExampleSection",
 CellID->868072697,ExpressionUUID->"6a600cf5-79b5-4e7e-9571-1b17aef55f07"],

Cell[TextData[{
 "Sink heads (Distance, Predicate, scalar-returning Transforms) appear as \
edge targets but never as sources. To find them, take ",
 Cell[BoxData[
 "Complement"], "InlineFormula",ExpressionUUID->
  "1f6b732e-7ee8-416f-86e1-9bb936df53af"],
 " of targets and sources."
}], "ExampleText",
 CellID->644712177,ExpressionUUID->"ba70922b-37f3-402d-81a6-a8d6a7e39363"],

Cell["\<\
Isolated paclet symbols \[LongDash] those with no Accepts entries and no \
OperatesOn \[LongDash] do not appear in the edge list at all. Their existence \
is recorded only as keys in the original graph Association.\
\>", "ExampleText",
 CellID->314447040,ExpressionUUID->"32937fcc-17df-4105-80e3-17bcc04c2219"],

Cell[TextData[{
 "Edge directionality follows data flow, not call-graph hierarchy. A symbol \
",
 Cell[BoxData[
 "F"], "InlineFormula",ExpressionUUID->"26cef49c-6e58-4278-b1f7-6b8b6af3307d"],
 " that takes a ",
 Cell[BoxData[
 "QuantumState"], "InlineFormula",ExpressionUUID->
  "c5c0e08e-11aa-4991-93bd-dbaeaba6df09"],
 " as input produces an edge ",
 Cell[BoxData[
  RowBox[{"{", 
   RowBox[{"QuantumState", ",", " ", "F"}], "}"}]], "InlineFormula",
  ExpressionUUID->"4de93ae3-9e6d-4bd5-ae6e-65c58f84b64c"],
 " (state flows into F), even though syntactically the call is ",
 Cell[BoxData[
  RowBox[{"F", "[", 
   RowBox[{"QuantumState", "[", "...", "]"}], "]"}]], "InlineFormula",
  ExpressionUUID->"548ed673-4fc4-4600-9d49-b3163e6d3941"],
 "."
}], "ExampleText",
 CellID->974967832,ExpressionUUID->"757990a6-16bc-4ef1-a2dd-03232f1b7852"]
}, Open  ]]
}, Open  ]],

