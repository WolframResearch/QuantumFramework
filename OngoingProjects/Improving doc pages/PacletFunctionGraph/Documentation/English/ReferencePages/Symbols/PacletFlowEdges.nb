Notebook[{

Cell[CellGroupData[{
Cell["PacletFlowEdges", "ObjectName",
 CellID->987776494,ExpressionUUID->"9d33a211-e460-4772-bd4f-7d88a6f0b20a"],

Cell[TextData[{
 Cell["\t", "ModInfo",ExpressionUUID->
  "ef9e4f11-4e80-4b18-9792-65de07f205a7"],
 Cell[BoxData[
  RowBox[{
   ButtonBox["PacletFlowEdges",
    BaseStyle->"Link",
    ButtonData->"paclet:Wolfram/PacletFunctionGraph/ref/PacletFlowEdges"], "[", 
   StyleBox["graph", "TI"], "]"}]], "InlineFormula",ExpressionUUID->
  "03361e5a-04d2-46a7-a530-934e6423bd5d"],
 "\[LineSeparator]returns a deduplicated list of ",
 Cell[BoxData[
  RowBox[{"{", 
   RowBox[{"from", ",", " ", "to"}], "}"}]], "InlineFormula",ExpressionUUID->
  "1bea8e8e-5ed5-4ee1-aac0-9094cedb17ec"],
 " pairs of paclet head names, each representing a directed flow between two \
paclet objects."
}], "Usage",
 CellID->898947797,ExpressionUUID->"d2c9bc53-ab0a-4bb1-8011-5b3c14215c66"],

Cell[TextData[{
 "Each edge ",
 Cell[BoxData[
  RowBox[{"{", 
   RowBox[{"A", ",", " ", "B"}], "}"}]], "InlineFormula",ExpressionUUID->
  "33f9090a-fd26-40f3-9fed-3a11c98a5065"],
 " in the result means \[OpenCurlyDoubleQuote]data of head ",
 Cell[BoxData[
 "A"], "InlineFormula",ExpressionUUID->"53cd161e-d258-4d62-b101-aacc9e422b4c"],
 " flows into ",
 Cell[BoxData[
 "B"], "InlineFormula",ExpressionUUID->"e1bc671c-7440-4145-a398-b38eb0b56ccc"],
 "\[CloseCurlyDoubleQuote] \[LongDash] either ",
 Cell[BoxData[
 "A"], "InlineFormula",ExpressionUUID->"24bc1cd8-ee68-42cc-bf88-7f24a5089c16"],
 " is one of ",
 Cell[BoxData[
 "B"], "InlineFormula",ExpressionUUID->"2eabdabf-b227-46fe-90a9-0ddc191ec67b"],
 "'s accepted constructor inputs, or ",
 Cell[BoxData[
 "A"], "InlineFormula",ExpressionUUID->"c5d43163-19d9-4211-b9aa-364322bf0c4b"],
 " produces something ",
 Cell[BoxData[
 "B"], "InlineFormula",ExpressionUUID->"9c144418-a71c-4320-b074-50f160d3b792"],
 " consumes."
}], "Notes",
 CellID->585641660,ExpressionUUID->"cdaaaeff-54c2-4bf2-8273-1ce4169e47df"],

Cell[TextData[{
 "Only paclet head symbols appear as endpoints. Built-in heads (",
 Cell[BoxData[
 "Integer"], "InlineFormula",ExpressionUUID->
  "87906877-7f1a-4f63-866c-01a126578294"],
 ", ",
 Cell[BoxData[
 "Real"], "InlineFormula",ExpressionUUID->
  "8b926966-7fd1-45ee-afc3-d7e7bd48890f"],
 ", ",
 Cell[BoxData[
 "List"], "InlineFormula",ExpressionUUID->
  "734a1912-0831-4e64-9ef5-59e180c389b8"],
 ", ",
 Cell[BoxData[
 "String"], "InlineFormula",ExpressionUUID->
  "6b1f01ad-3b98-40f4-8fab-7a0ce862a5ee"],
 ", ",
 Cell[BoxData[
 "Association"], "InlineFormula",ExpressionUUID->
  "20ebe6ca-6b3c-486e-afff-d127fa2158da"],
 ", \[Ellipsis]) are filtered out by design \[LongDash] the graph captures \
object-to-object flow, not scalar dataflow."
}], "Notes",
 CellID->265537985,ExpressionUUID->"3a702b42-4922-4024-a9f8-3d2262a02679"],

Cell[TextData[{
 "Edges are generated from three sources in each symbol's record. For each \
public symbol ",
 Cell[BoxData[
 "F"], "InlineFormula",ExpressionUUID->"40b28da7-8d70-4ff2-9af2-830b27d6f767"],
 " in the graph:"
}], "Notes",
 CellID->979981112,ExpressionUUID->"a627b2f1-3bb5-4c48-a386-ae6289107195"],

Cell[TextData[{
 "(1) for every entry in ",
 Cell[BoxData[
  RowBox[{"F", "[", "\"\<Accepts\>\"", "]"}]], "InlineFormula",ExpressionUUID->
  "0cc5e969-ff74-4b51-93f9-8a7862fc5b24"],
 " whose ",
 Cell[BoxData["\"\<Head\>\""], "InlineFormula",ExpressionUUID->
  "999d9062-7f94-4d3e-a97f-ceb9e3cff0bc"],
 " is another paclet head ",
 Cell[BoxData[
 "H"], "InlineFormula",ExpressionUUID->"d0a8a03c-b201-4a54-bb86-9dc9a2737291"],
 " and whose ",
 Cell[BoxData["\"\<Role\>\""], "InlineFormula",ExpressionUUID->
  "8029e57b-d616-4439-8659-dce4ec03e1e8"],
 " is ",
 Cell[BoxData["\"\<Primary\>\""], "InlineFormula",ExpressionUUID->
  "53d197da-9fd3-410b-8d09-5d3eeb694add"],
 ", ",
 Cell[BoxData["\"\<Mutation\>\""], "InlineFormula",ExpressionUUID->
  "b11d7f54-3ebd-4a27-9923-45f8dbdba69f"],
 ", or ",
 Cell[BoxData["\"\<Conversion\>\""], "InlineFormula",ExpressionUUID->
  "b0780b72-ee31-4f9f-a4ec-d7e360e5ac14"],
 ", emit ",
 Cell[BoxData[
  RowBox[{"{", 
   RowBox[{"H", ",", " ", "F"}], "}"}]], "InlineFormula",ExpressionUUID->
  "50d70628-8f30-4b04-8223-44827fa84ed3"],
 "."
}], "Notes",
 CellID->837218055,ExpressionUUID->"ad8ef940-0359-49bb-bcbf-525c4f44b7fc"],

Cell[TextData[{
 "(2) for each key paclet head ",
 Cell[BoxData[
 "K"], "InlineFormula",ExpressionUUID->"afafafae-1c26-4031-95ae-75ee8b3aa2d4"],
 " in ",
 Cell[BoxData[
  RowBox[{"F", "[", "\"\<OperatesOn\>\"", "]"}]], "InlineFormula",
  ExpressionUUID->"c561c656-73d0-49b3-9dd3-e575c63c73a0"],
 ", emit ",
 Cell[BoxData[
  RowBox[{"{", 
   RowBox[{"K", ",", " ", "F"}], "}"}]], "InlineFormula",ExpressionUUID->
  "9f3aeb2b-661a-445e-bfe3-a4712a412033"],
 " (",
 Cell[BoxData[
 "F"], "InlineFormula",ExpressionUUID->"46f138d4-7c03-4771-8b92-36e36e95bafc"],
 " can be applied to a ",
 Cell[BoxData[
 "K"], "InlineFormula",ExpressionUUID->"1d7257c0-4367-48ce-9e71-8334d4d29fb3"],
 ")."
}], "Notes",
 CellID->459030628,ExpressionUUID->"76780a3a-b8c8-4f6d-aaf9-d7fe2c2c6490"],

Cell[TextData[{
 "(3) for each value paclet head ",
 Cell[BoxData[
 "V"], "InlineFormula",ExpressionUUID->"138b3a75-372e-409c-9c8d-9ecc7b46b354"],
 " in ",
 Cell[BoxData[
  RowBox[{"F", "[", "\"\<OperatesOn\>\"", "]"}]], "InlineFormula",
  ExpressionUUID->"2135d078-d9e7-483a-8935-1dd3a156dd59"],
 ", emit ",
 Cell[BoxData[
  RowBox[{"{", 
   RowBox[{"F", ",", " ", "V"}], "}"}]], "InlineFormula",ExpressionUUID->
  "e6b3c87c-e0b9-4450-a274-e765224bbbf5"],
 " (applying ",
 Cell[BoxData[
 "F"], "InlineFormula",ExpressionUUID->"3027e8ef-8504-4c1f-820b-3572d8d3c94f"],
 " produces a ",
 Cell[BoxData[
 "V"], "InlineFormula",ExpressionUUID->"83f4dfba-2d50-4d7c-abfd-32c5bd19788a"],
 ")."
}], "Notes",
 CellID->437424213,ExpressionUUID->"7a2898a0-9fd9-49e9-a1d5-ed4445cf7a4b"],

Cell[TextData[{
 "Self-loops ",
 Cell[BoxData[
  RowBox[{"{", 
   RowBox[{"F", ",", " ", "F"}], "}"}]], "InlineFormula",ExpressionUUID->
  "2fe6e0d1-7d82-4a4a-8593-a8c17e15af76"],
 " arise naturally when ",
 Cell[BoxData[
 "F"], "InlineFormula",ExpressionUUID->"c9f0431b-730a-4bc3-bf0b-e9c9038b8c7f"],
 " is operator-like and preserves its target type \[LongDash] for instance, \
",
 Cell[BoxData[
 "QuantumOperator"], "InlineFormula",ExpressionUUID->
  "35344e17-37fe-4bef-91b3-c0104eb541e5"],
 " applied to a ",
 Cell[BoxData[
 "QuantumState"], "InlineFormula",ExpressionUUID->
  "d2e3464c-b835-42b2-807d-b525b16f4ff5"],
 " returns a ",
 Cell[BoxData[
 "QuantumState"], "InlineFormula",ExpressionUUID->
  "7e321679-d361-4f51-b12e-7ab36875ded1"],
 ", so a corresponding edge exists in QuantumOperator's ",
 Cell[BoxData[
 "OperatesOn"], "InlineFormula",ExpressionUUID->
  "3a5ec43e-4028-425e-a001-13facad20875"],
 "."
}], "Notes",
 CellID->280391937,ExpressionUUID->"e0106edc-c45d-41b6-b263-2adec3bc7d8c"],

Cell[TextData[{
 Cell[BoxData[
 "PacletFlowEdges"], "InlineFormula",ExpressionUUID->
  "f4bd1cdf-b782-41fd-8ee3-3587f10625df"],
 " is the primitive edge form. The two renderers ",
 Cell[BoxData[
  ButtonBox["SymbolNeighborhoodGraph",
   BaseStyle->"Link",
   ButtonData->
    "paclet:Wolfram/PacletFunctionGraph/ref/SymbolNeighborhoodGraph"]], 
  "InlineFormula",ExpressionUUID->"43b7b335-6be0-46e4-b63c-5f4be63f4fe9"],
 " and ",
 Cell[BoxData[
  ButtonBox["PacletOverviewGraph",
   BaseStyle->"Link",
   ButtonData->"paclet:Wolfram/PacletFunctionGraph/ref/PacletOverviewGraph"]],
   "InlineFormula",ExpressionUUID->"6cd8ccf4-cf2b-4130-9096-d8799309d4fd"],
 " both call ",
 Cell[BoxData[
 "PacletFlowEdges"], "InlineFormula",ExpressionUUID->
  "1f5101f4-b2b8-4334-9e13-40f44c9c9270"],
 " internally; you only need to call it directly when you want the raw edge \
list for custom analysis."
}], "Notes",
 CellID->607001180,ExpressionUUID->"c6a9823e-9b30-4444-bcda-03627a1b4291"],

