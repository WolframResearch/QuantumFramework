Cell[CellGroupData[{

Cell[BoxData[
 InterpretationBox[Cell[
  "Possible Issues", "ExampleSection",ExpressionUUID->
   "9fc7c448-9ccc-4b58-9392-959fb9cfa8d8"],
  $Line = 0; Null]], "ExampleSection",
 CellID->942947524,ExpressionUUID->"8145a54c-9349-43d7-b486-4585fae454a8"],

Cell[TextData[{
 "The focal symbol must be a key in ",
 Cell[BoxData[
  StyleBox["graph", "TI"]], "InlineFormula",ExpressionUUID->
  "52607292-d062-4ba7-9aca-7dac42c6b850"],
 ". Passing a name that is not in the graph produces an isolated \
single-vertex result, not an error."
}], "ExampleText",
 CellID->722921203,ExpressionUUID->"dbaca261-954d-4897-92c7-3da17eab33ff"],

Cell[TextData[{
 "Edge direction is data flow, not call syntax. ",
 Cell[BoxData[
 "QuantumDistance"], "InlineFormula",ExpressionUUID->
  "241751fc-9b6b-413f-ad32-7f39a8961aa4"],
 " consumes states, so the edge points ",
 Cell[BoxData[
 "QuantumState"], "InlineFormula",ExpressionUUID->
  "38490302-7f91-4656-a278-53efa7e400c7"],
 " \[Rule] ",
 Cell[BoxData[
 "QuantumDistance"], "InlineFormula",ExpressionUUID->
  "36bee8ec-afcd-4c66-b817-4443616bede8"],
 " even though the call you write is ",
 Cell[BoxData[
  RowBox[{"QuantumDistance", "[", 
   RowBox[{
    RowBox[{"QuantumState", "[", "...", "]"}], ",", " ", "..."}], "]"}]], 
  "InlineFormula",ExpressionUUID->"f75da622-3cf1-4928-aa23-25ad7f8b470b"],
 "."
}], "ExampleText",
 CellID->877894909,ExpressionUUID->"86adcd21-7477-45cb-82a5-4f56024572be"],

Cell[TextData[{
 "Vertex placement is layout-dependent. The default ",
 Cell[BoxData["\"\<SpringElectricalEmbedding\>\""], "InlineFormula",
  ExpressionUUID->"5c88ceca-0ed8-408a-a3fa-932534fd320f"],
 " is non-deterministic across kernel sessions \[LongDash] the topology is \
preserved, but exact 2D positions may shift. Pin a layout with ",
 Cell[BoxData[
 "GraphLayout"], "InlineFormula",ExpressionUUID->
  "d1da851f-09cf-4e9e-a661-220f1e7d3b27"],
 " or supply ",
 Cell[BoxData[
 "VertexCoordinates"], "InlineFormula",ExpressionUUID->
  "28350909-2b18-4c9b-a42c-667912696083"],
 " for reproducibility."
}], "ExampleText",
 CellID->414336249,ExpressionUUID->"8a97e7af-597e-404e-9f28-1ab91e46154d"]
}, Open  ]]
}, Open  ]],

