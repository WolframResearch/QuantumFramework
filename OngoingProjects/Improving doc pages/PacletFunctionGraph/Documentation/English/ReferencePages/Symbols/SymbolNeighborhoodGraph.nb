Cell[TextData[{
 "The vertex count of the neighborhood graph equals the number of distinct \
heads touching ",
 Cell[BoxData[
  StyleBox["symName", "TI"]], "InlineFormula",ExpressionUUID->
  "38d275b4-75a8-4379-8c29-742b93da556c"],
 ", plus the focal symbol itself if it was not otherwise touched:"
}], "ExampleText",
 CellID->743261503,ExpressionUUID->"09b62ef8-be2d-430d-9e3a-6720ab15fab0"],

Cell[BoxData[
 RowBox[{"VertexCount", "[", 
