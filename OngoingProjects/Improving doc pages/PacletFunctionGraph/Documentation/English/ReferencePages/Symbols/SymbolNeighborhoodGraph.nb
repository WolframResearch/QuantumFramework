Cell[CellGroupData[{
Cell["SymbolNeighborhoodGraph", "ObjectName",
 CellID->625110436,ExpressionUUID->"c72e5d7f-7db2-45ea-93f9-1177e77ee0d3"],

Cell[TextData[{
 Cell["\t", "ModInfo",ExpressionUUID->
  "38078584-800a-46be-bc5b-43630dc9418c"],
 Cell[BoxData[
  RowBox[{
   ButtonBox["SymbolNeighborhoodGraph",
    BaseStyle->"Link",
    ButtonData->
     "paclet:Wolfram/PacletFunctionGraph/ref/SymbolNeighborhoodGraph"], "[", 
   RowBox[{
    StyleBox["graph", "TI"], ",", " ", 
    StyleBox["symName", "TI"]}], "]"}]], "InlineFormula",ExpressionUUID->
  "fb9bba01-ac6a-4ac8-afa4-72657e36c1c7"],
 "\[LineSeparator]renders a directed ",
 Cell[BoxData[
 "Graph"], "InlineFormula",ExpressionUUID->
  "994ecc28-5164-422e-b695-cd56404e6e94"],
 " showing every edge that touches ",
 Cell[BoxData[
  StyleBox["symName", "TI"]], "InlineFormula",ExpressionUUID->
  "5856a174-c0a1-4bec-96ab-2b97ad68f49d"],
 " as source or target. Vertex color encodes ",
 Cell[BoxData[
 "Kind"], "InlineFormula",ExpressionUUID->
  "a54ee47e-a250-41ec-82df-7a1a9d260866"],
 ".\n",
 Cell["\t", "ModInfo",ExpressionUUID->
  "62a0e753-2237-4076-b5aa-aa221da7cb0b"],
 Cell[BoxData[
  RowBox[{
   ButtonBox["SymbolNeighborhoodGraph",
    BaseStyle->"Link",
    ButtonData->
     "paclet:Wolfram/PacletFunctionGraph/ref/SymbolNeighborhoodGraph"], "[", 
   RowBox[{
    StyleBox["graph", "TI"], ",", " ", 
    StyleBox["symName", "TI"], ",", " ", 
    StyleBox["opts", "TI"]}], "]"}]], "InlineFormula",ExpressionUUID->
  "7680cf82-6ef2-45e7-a9f1-05777a449e56"],
 "\[LineSeparator]accepts standard ",
 Cell[BoxData[
 "Graph"], "InlineFormula",ExpressionUUID->
  "bc82242f-4572-4c6d-b7a5-2fa8b88fafc3"],
 " options, which take precedence over the package defaults."
}], "Usage",
 CellID->585826512,ExpressionUUID->"fd0a7389-5614-40b7-a97c-c026423b66f0"],

Cell[TextData[{
 Cell[BoxData[
  StyleBox["graph", "TI"]], "InlineFormula",ExpressionUUID->
  "349579ce-4a24-4f3d-b8b2-40fab8b53519"],
 " is an Association of the form returned by ",
 Cell[BoxData[
  ButtonBox["BuildFunctionGraph",
   BaseStyle->"Link",
   ButtonData->"paclet:Wolfram/PacletFunctionGraph/ref/BuildFunctionGraph"]], 
  "InlineFormula",ExpressionUUID->"08c78962-d554-462f-80c6-b495d2fcd5c6"],
 " or ",
 Cell[BoxData[
  ButtonBox["LoadFunctionGraph",
   BaseStyle->"Link",
   ButtonData->"paclet:Wolfram/PacletFunctionGraph/ref/LoadFunctionGraph"]], 
  "InlineFormula",ExpressionUUID->"8852b0e4-ff0e-4335-acc2-cc82e47fe293"],
 "."
}], "Notes",
 CellID->527322624,ExpressionUUID->"175913ca-d43a-40cb-8790-fa4aad123347"],

Cell[TextData[{
 Cell[BoxData[
  StyleBox["symName", "TI"]], "InlineFormula",ExpressionUUID->
  "828d6f17-a3bd-4c1b-821d-cba546446a90"],
 " is the string name of a paclet head present as a key in ",
 Cell[BoxData[
  StyleBox["graph", "TI"]], "InlineFormula",ExpressionUUID->
  "ac90e094-ce0c-4649-a55e-d365bf42099f"],
 "."
}], "Notes",
 CellID->68245610,ExpressionUUID->"ee007d70-72b5-4655-ac0d-5742a4bd4c2c"],

Cell[TextData[{
 "The displayed neighborhood includes every directed edge of the form ",
 Cell[BoxData[
  RowBox[{"{", 
   RowBox[{"symName", ",", " ", "X"}], "}"}]], "InlineFormula",ExpressionUUID->
  "eb3fcd6a-bfd2-452a-98d8-b93ddc4a7240"],
 " or ",
 Cell[BoxData[
  RowBox[{"{", 
   RowBox[{"X", ",", " ", "symName"}], "}"}]], "InlineFormula",ExpressionUUID->
  "9d81fcd3-6e2e-4396-a7c9-0670d511f6e0"],
 " in ",
 Cell[BoxData[
  ButtonBox["PacletFlowEdges",
   BaseStyle->"Link",
   ButtonData->"paclet:Wolfram/PacletFunctionGraph/ref/PacletFlowEdges"]], 
  "InlineFormula",ExpressionUUID->"88b88d94-d773-4f5e-8616-181c500c66f8"],
 ". Both directions are visible; anti-parallel pairs render as two arrows \
bowing apart."
}], "Notes",
 CellID->709902721,ExpressionUUID->"ceb7257b-969e-45b0-b93b-178180f15b08"],

Cell[TextData[{
 "Vertex face color comes from ",
 Cell[BoxData[
  ButtonBox["$FunctionGraphKindColors",
   BaseStyle->"Link",
   ButtonData->
    "paclet:Wolfram/PacletFunctionGraph/ref/$FunctionGraphKindColors"]], 
  "InlineFormula",ExpressionUUID->"52b371fa-d956-436b-bda1-6718a73e102e"],
 " keyed on each vertex's ",
 Cell[BoxData["\"\<Kind\>\""], "InlineFormula",ExpressionUUID->
  "10099685-ba3e-42d8-b267-d31e9a7e14df"],
 " field. The focal vertex (",
 Cell[BoxData[
  StyleBox["symName", "TI"]], "InlineFormula",ExpressionUUID->
  "647167c4-d3d1-419e-82a7-d6dd3aeb5e1f"],
 ") is drawn with a heavier black border."
}], "Notes",
 CellID->458953984,ExpressionUUID->"a15a6e70-25ab-4bf8-a620-22510e58ff6b"],

Cell[TextData[{
 "The default layout is ",
 Cell[BoxData["\"\<SpringElectricalEmbedding\>\""], "InlineFormula",
  ExpressionUUID->"9c9bb798-96c0-42a1-b130-03a596cb3e2a"],
 ", chosen because typical neighborhoods are small (under 20 vertices) and \
benefit from a force-directed layout. Use ",
 Cell[BoxData[
 "GraphLayout"], "InlineFormula",ExpressionUUID->
  "f9b8229b-922f-4e60-b516-a2b6f9912bbe"],
 " in ",
 Cell[BoxData[
  StyleBox["opts", "TI"]], "InlineFormula",ExpressionUUID->
  "ee026f40-731c-4882-a188-5f4e6885ced6"],
 " to override."
}], "Notes",
 CellID->923700237,ExpressionUUID->"839d64dc-6e90-4d08-a6cc-bb860bc967d4"],

Cell[TextData[{
 "If no edges touch ",
 Cell[BoxData[
  StyleBox["symName", "TI"]], "InlineFormula",ExpressionUUID->
  "f74a2921-3487-47ad-845f-337e41003667"],
 ", the result is a single-vertex Graph containing just ",
 Cell[BoxData[
  StyleBox["symName", "TI"]], "InlineFormula",ExpressionUUID->
  "050e4434-8fdc-444a-83cb-bbbcc2ad2517"],
 "."
}], "Notes",
 CellID->486503990,ExpressionUUID->"30913357-1393-4849-a8a4-08b26d8057ca"],

