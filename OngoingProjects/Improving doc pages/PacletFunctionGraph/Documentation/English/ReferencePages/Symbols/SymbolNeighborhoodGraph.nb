Cell[TextData[{
 Cell[BoxData[
 "EdgeCount"], "InlineFormula",ExpressionUUID->
  "d6f6f5db-c3cb-4b96-82db-8a23564ced79"],
 " equals the number of edges in ",
 Cell[BoxData[
 "PacletFlowEdges"], "InlineFormula",ExpressionUUID->
  "c7cad7ad-a69d-4e17-afc8-013e1cef37a9"],
 " that touch the focal symbol:"
}], "ExampleText",
 CellID->679615844,ExpressionUUID->"629bc0af-2d22-484e-b6a7-caf58f4f1c17"],

Cell[BoxData[
 RowBox[{
  RowBox[{"EdgeCount", "[", 
   RowBox[{"SymbolNeighborhoodGraph", "[", 
    RowBox[{"g", ",", " ", "\"\<QuantumState\>\""}], "]"}], "]"}], " ", "===",
   "\n", "  ", 
  RowBox[{"Length", " ", "@", " ", 
   RowBox[{"Select", "[", 
    RowBox[{
     RowBox[{"PacletFlowEdges", "[", "g", "]"}], ",", " ", 
     RowBox[{
      RowBox[{"MemberQ", "[", 
       RowBox[{"#", ",", " ", "\"\<QuantumState\>\""}], "]"}], " ", "&"}]}], 
    "]"}]}]}]], "Input",
 CellLabel->"In[2]:=",
 CellID->379685606,ExpressionUUID->"d15c1e9c-2d3c-40ec-b135-46beb4b13ca2"],

