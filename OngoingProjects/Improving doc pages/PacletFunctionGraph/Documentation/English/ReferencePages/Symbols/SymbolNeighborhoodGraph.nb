 Cell[BoxData[
 "QuantumOperator"], "InlineFormula",ExpressionUUID->
  "df6380fc-ef2f-4848-aa15-64abc7d53127"],
 " has a self-loop (operator applied to a state yields a state, so \
QuantumOperator preserves itself when composed with QuantumOperator):"
}], "ExampleText",
