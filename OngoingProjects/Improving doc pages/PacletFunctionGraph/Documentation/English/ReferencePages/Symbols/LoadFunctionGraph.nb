Cell[CellGroupData[{
Cell["LoadFunctionGraph", "ObjectName",
 CellID->400767361,ExpressionUUID->"e3a80ee1-85da-40e5-9e42-1dea7f20a4dd"],

Cell[TextData[{
 Cell["\t", "ModInfo",ExpressionUUID->
  "058fff58-be43-4423-8f90-5e4f5828c494"],
 Cell[BoxData[
  RowBox[{
   ButtonBox["LoadFunctionGraph",
    BaseStyle->"Link",
    ButtonData->"paclet:Wolfram/PacletFunctionGraph/ref/LoadFunctionGraph"], "[", 
   StyleBox["file", "TI"], "]"}]], "InlineFormula",ExpressionUUID->
  "46cc7a83-489c-428a-99de-28ae4ce1166b"],
 "\[LineSeparator]reads a function-relation graph previously written by ",
 Cell[BoxData[
  ButtonBox["BuildFunctionGraph",
   BaseStyle->"Link",
   ButtonData->"paclet:Wolfram/PacletFunctionGraph/ref/BuildFunctionGraph"]], 
  "InlineFormula",ExpressionUUID->"f7faf7cb-ad2d-494c-8cbe-6a73facff37f"],
 " and returns the Association."
}], "Usage",
 CellID->595984041,ExpressionUUID->"7630c5ae-0691-44b8-bfe0-3eb0717fa6e1"],

Cell[TextData[{
 Cell[BoxData[
 "LoadFunctionGraph"], "InlineFormula",ExpressionUUID->
  "8436e5b5-d3a6-4f5e-ad77-5bbd983d1f77"],
 " calls ",
 Cell[BoxData[
 "Get"], "InlineFormula",ExpressionUUID->
  "39923605-337e-49e6-82de-46d73e3d9d6b"],
 " on ",
 Cell[BoxData[
  StyleBox["file", "TI"]], "InlineFormula",ExpressionUUID->
  "ffad9e74-ec4b-455f-ab95-0a2aa1228943"],
 " inside a sandboxed ",
 Cell[BoxData[
 "Wolfram`PacletFunctionGraph`Sandbox`"], "InlineFormula",ExpressionUUID->
  "e85fc062-70aa-4736-afcd-094ea33b7a9d"],
 " context. This prevents head names recorded in the graph (e.g. ",
 Cell[BoxData[
 "QuantumState"], "InlineFormula",ExpressionUUID->
  "6dc65a26-2de5-477f-9332-7e79e057bbf6"],
 ") from accidentally interning fresh ",
 Cell[BoxData[
 "Global`"], "InlineFormula",ExpressionUUID->
  "d1ca775f-288a-4743-b0b3-94b9a385ff54"],
 " symbols on load."
}], "Notes",
 CellID->47121820,ExpressionUUID->"4d7642ba-e05b-4aa6-84e4-36728f886b24"],

Cell[TextData[{
 "The returned Association has the same schema as ",
 Cell[BoxData[
 "BuildFunctionGraph"], "InlineFormula",ExpressionUUID->
  "01b6a97c-777a-46d4-b0cb-a7eb0ebda783"],
 "'s in-memory result: a ",
 Cell[BoxData["\"\<$Meta\>\""], "InlineFormula",ExpressionUUID->
  "58274ae7-e47a-43e0-b391-5af291372728"],
 " entry plus one entry per public symbol carrying ",
 Cell[BoxData["\"\<Kind\>\""], "InlineFormula",ExpressionUUID->
  "80aed9f7-b13e-42c5-8974-6f9835829753"],
 ", ",
 Cell[BoxData["\"\<Accepts\>\""], "InlineFormula",ExpressionUUID->
  "39b35ea6-b9ae-44f4-9de0-2f1d2bbaa199"],
 ", ",
 Cell[BoxData["\"\<OperatesOn\>\""], "InlineFormula",ExpressionUUID->
  "77fc5e33-3820-447b-8c51-89faefb5e629"],
 ", and ",
 Cell[BoxData["\"\<ConsumedBy\>\""], "InlineFormula",ExpressionUUID->
  "437d5cee-e5f0-45d0-a6c4-76f1467f8d40"],
 "."
}], "Notes",
 CellID->866054620,ExpressionUUID->"2341995a-f5c1-463b-b9f3-f8e6d3b5a36f"],

Cell[TextData[{
 Cell[BoxData[
 "LoadFunctionGraph"], "InlineFormula",ExpressionUUID->
  "570dc15b-8e09-4fc4-99c1-26f1d4115548"],
 " returns ",
 Cell[BoxData[
 "$Failed"], "InlineFormula",ExpressionUUID->
  "8e1301df-96b0-4964-8d1e-5425bf279be3"],
 " and emits a Message when ",
 Cell[BoxData[
  StyleBox["file", "TI"]], "InlineFormula",ExpressionUUID->
  "08722282-aadf-42f4-a861-9afadcd5a592"],
 " does not exist or does not contain an Association."
}], "Notes",
 CellID->216033925,ExpressionUUID->"5cb7a5e7-31d2-4da0-990c-f353dab01cc0"],

