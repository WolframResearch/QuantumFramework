Cell[TextData[{
 "When the file does not exist, ",
 Cell[BoxData[
 "LoadFunctionGraph"], "InlineFormula",ExpressionUUID->
  "6da6ad4f-c465-4dcb-b95b-fa8aabb3e08a"],
 " emits a Message and returns ",
 Cell[BoxData[
 "$Failed"], "InlineFormula",ExpressionUUID->
  "9e008ba3-78e5-4f4c-9217-6f26bea09ba2"],
 ":"
}], "ExampleText",
 CellID->225364690,ExpressionUUID->"1f4025bb-f148-4e46-8dbf-16e76b65a295"],

