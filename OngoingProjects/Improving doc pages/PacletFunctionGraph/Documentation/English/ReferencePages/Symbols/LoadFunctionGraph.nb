Cell[CellGroupData[{

Cell[BoxData[
 InterpretationBox[Cell[
  "Properties & Relations", "ExampleSection",ExpressionUUID->
   "d36707e0-9020-404b-86aa-8a0ab6e2f4a0"],
  $Line = 0; Null]], "ExampleSection",
 CellID->496396258,ExpressionUUID->"e1be1e26-3b40-4be5-8338-a1cfab1ba903"],

Cell[TextData[{
 "Build, write, then reload \[LongDash] key sets match between the in-memory \
and on-disk forms (head symbols in the loaded version live in the sandbox \
context, so ",
 Cell[BoxData["==="], "InlineFormula",ExpressionUUID->
  "574217fd-c665-4fac-837d-8f31d9220361"],
 " on values is not preserved; key-level equality is):"
}], "ExampleText",
 CellID->487885400,ExpressionUUID->"a883d99c-996d-4316-b528-d5fe5e2c9442"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"BuildFunctionGraph", "[", 
   RowBox[{"\"\</Users/mohammadb/Documents/GitHub/QuantumFramework/\
QuantumFramework\>\"", ",", " ", 
    RowBox[{"\"\<OutputFile\>\"", " ", "->", 
     " ", "\"\</tmp/qf-graph.wl\>\""}]}], "]"}], ";"}], "\n", 
 RowBox[{
  RowBox[{"loaded", " ", "=", " ", 
   RowBox[{"LoadFunctionGraph", "[", "\"\</tmp/qf-graph.wl\>\"", "]"}]}], 
  ";"}], "\n", 
 RowBox[{
  RowBox[{"inMem", "  ", "=", " ", 
   RowBox[{"BuildFunctionGraph", "[", 
    RowBox[{"\"\</Users/mohammadb/Documents/GitHub/QuantumFramework/\
QuantumFramework\>\"", ",", " ", 
     RowBox[{"\"\<WriteFile\>\"", " ", "->", " ", "False"}]}], "]"}]}], 
  ";"}], "\n", 
 RowBox[{
  RowBox[{"Sort", "@", 
   RowBox[{"Keys", "[", "loaded", "]"}]}], " ", "===", " ", 
  RowBox[{"Sort", "@", 
   RowBox[{"Keys", "[", "inMem", "]"}]}]}]}], "Input",
 CellLabel->"In[1]:=",
 CellID->162353430,ExpressionUUID->"06c1e9bf-c43b-407e-9a2a-e205a66c4915"],

Cell[BoxData["True"], "Output",
 CellLabel->"Out[1]=",
 CellID->694863458,ExpressionUUID->"edc5ebe7-14ad-46c8-8ca8-8622d09f178e"],

Cell[BoxData[""], "ExampleDelimiter",
 CellID->784857545,ExpressionUUID->"1a458c4c-0a6a-40a9-9d30-b9cd5cad4c47"],

Cell[TextData[{
 Cell[BoxData[
 "LoadFunctionGraph"], "InlineFormula",ExpressionUUID->
  "633488e1-5953-4cb0-9506-38bd80bd2f50"],
 " is the inverse of writing via ",
 Cell[BoxData[
 "BuildFunctionGraph"], "InlineFormula",ExpressionUUID->
  "eef509e7-a23f-4f5c-b9f7-2e5dece93a56"],
 " \[LongDash] the same graph passes through ",
 Cell[BoxData[
 "Put"], "InlineFormula",ExpressionUUID->
  "ebbccfbc-90a2-4a2a-b971-3f34bbf87ca6"],
 " / ",
 Cell[BoxData[
 "Get"], "InlineFormula",ExpressionUUID->
  "e945b762-635b-4094-95bd-cf02e4d04562"],
 " unchanged structurally:"
}], "ExampleText",
 CellID->957954312,ExpressionUUID->"1588d57a-a57a-4708-9f0a-f593887f579d"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"loaded", " ", "=", " ", 
   RowBox[{"LoadFunctionGraph", "[", "\"\</tmp/qf-graph.wl\>\"", "]"}]}], 
  ";"}], "\n", 
 RowBox[{
  RowBox[{"AssociationQ", "[", "loaded", "]"}], " ", "&&", " ", 
  RowBox[{"KeyExistsQ", "[", 
   RowBox[{"loaded", ",", " ", "\"\<$Meta\>\""}], "]"}]}]}], "Input",
 CellLabel->"In[2]:=",
 CellID->566088157,ExpressionUUID->"87a1d1cd-b151-41b3-b631-5842966d4e20"],

Cell[BoxData["True"], "Output",
 CellLabel->"Out[2]=",
 CellID->956337389,ExpressionUUID->"31a9bdc3-f842-4660-a143-ecce4e9a892d"]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[
 InterpretationBox[Cell[
  "Possible Issues", "ExampleSection",ExpressionUUID->
   "e5e94600-eccc-4011-85fb-6ec85fe7905c"],
  $Line = 0; Null]], "ExampleSection",
 CellID->861575055,ExpressionUUID->"6cad6b51-6284-4d8c-9054-9b016dd98fea"],

Cell[TextData[{
 "Head symbols inside the loaded Association are re-interned in the sandbox \
context, so direct ",
 Cell[BoxData["==="], "InlineFormula",ExpressionUUID->
  "ad9004e0-4990-4195-96a9-7b89ec1c5ae6"],
 " equality with the in-memory result of ",
 Cell[BoxData[
 "BuildFunctionGraph"], "InlineFormula",ExpressionUUID->
  "54710473-96b9-48af-9513-46ea5a006c86"],
 " is not preserved. Compare key sets, or compare per-field with caution."
}], "ExampleText",
 CellID->886649123,ExpressionUUID->"902d0c05-0511-48e3-b5f6-568d76458b46"],

Cell[TextData[{
 Cell[BoxData[
 "LoadFunctionGraph"], "InlineFormula",ExpressionUUID->
  "5b6c6f9e-6797-4899-b5a8-ba9c43ac7a26"],
 " reads bytes \[LongDash] it does not consult the paclet's current kernel \
state. If the paclet's source has changed since the file was written, the \
loaded graph is stale. Rebuild via ",
 Cell[BoxData[
 "BuildFunctionGraph"], "InlineFormula",ExpressionUUID->
  "a227653b-9d06-4444-a644-c8b8b62a488f"],
 " when the paclet's API changes."
}], "ExampleText",
 CellID->658861507,ExpressionUUID->"0090a82d-8db7-4e1e-8fc7-aad4f49237b3"],

Cell[TextData[{
 "The file must have been written by ",
 Cell[BoxData[
 "BuildFunctionGraph"], "InlineFormula",ExpressionUUID->
  "5e645674-f165-45dc-a9bb-d0a652227340"],
 " (or any process emitting the same Association schema). A ",
 Cell[BoxData[
  RowBox[{".", "wl"}]], "InlineFormula",ExpressionUUID->
  "7777348d-138b-494e-a41b-15f4abc96ac7"],
 " file containing arbitrary Wolfram Language code, or a non-Association \
expression, will trigger the ",
 Cell[BoxData[
  RowBox[{"LoadFunctionGraph", "::", "badfile"}]], "InlineFormula",
  ExpressionUUID->"118fdfb2-3214-44ae-a4f0-454690f8ba72"],
 " message."
}], "ExampleText",
 CellID->152219615,ExpressionUUID->"c3a58571-071e-4f26-a280-f2aa67d904a6"]
}, Open  ]]
}, Open  ]],

