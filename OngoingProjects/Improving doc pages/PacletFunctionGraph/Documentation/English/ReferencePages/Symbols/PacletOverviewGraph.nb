Cell[CellGroupData[{
Cell["PacletOverviewGraph", "ObjectName",
 CellID->92618828,ExpressionUUID->"51e21970-8788-42ff-8ccb-0affd1c6fedb"],

Cell[TextData[{
 Cell["\t", "ModInfo",ExpressionUUID->
  "c294082d-4d69-413c-b565-5e6485e38d50"],
 Cell[BoxData[
  RowBox[{
   ButtonBox["PacletOverviewGraph",
    BaseStyle->"Link",
    ButtonData->"paclet:Wolfram/PacletFunctionGraph/ref/PacletOverviewGraph"],
    "[", 
   StyleBox["graph", "TI"], "]"}]], "InlineFormula",ExpressionUUID->
  "4899f559-1fcd-42c1-97b0-a9d0e8d3a915"],
 "\[LineSeparator]renders the full paclet's directed flow graph between all \
paclet head symbols.\n",
 Cell["\t", "ModInfo",ExpressionUUID->
  "432236d1-50ca-42f9-b671-a5da89c05d3f"],
 Cell[BoxData[
  RowBox[{
   ButtonBox["PacletOverviewGraph",
    BaseStyle->"Link",
    ButtonData->"paclet:Wolfram/PacletFunctionGraph/ref/PacletOverviewGraph"],
    "[", 
   RowBox[{
    StyleBox["graph", "TI"], ",", " ", 
    StyleBox["opts", "TI"]}], "]"}]], "InlineFormula",ExpressionUUID->
  "3df9349a-aada-4790-bc8d-6579c3afca73"],
 "\[LineSeparator]accepts ",
 Cell[BoxData["\"\<IncludeIsolated\>\""], "InlineFormula",ExpressionUUID->
  "69489793-26b8-4b22-aaa3-923ca6e05472"],
 " and any standard ",
 Cell[BoxData[
 "Graph"], "InlineFormula",ExpressionUUID->
  "ef964f61-71eb-4290-918e-d02ec8ddb258"],
 " options."
}], "Usage",
 CellID->896787184,ExpressionUUID->"4dd802ec-88c8-413c-9fb7-98627355cce1"],

Cell[TextData[{
 Cell[BoxData[
  StyleBox["graph", "TI"]], "InlineFormula",ExpressionUUID->
  "d23cfcce-35fa-4b12-9273-f82932f3fa72"],
 " is an Association returned by ",
 Cell[BoxData[
  ButtonBox["BuildFunctionGraph",
   BaseStyle->"Link",
   ButtonData->"paclet:Wolfram/PacletFunctionGraph/ref/BuildFunctionGraph"]], 
  "InlineFormula",ExpressionUUID->"133abcab-e367-4026-830b-d03c427356b5"],
 " or ",
 Cell[BoxData[
  ButtonBox["LoadFunctionGraph",
   BaseStyle->"Link",
   ButtonData->"paclet:Wolfram/PacletFunctionGraph/ref/LoadFunctionGraph"]], 
  "InlineFormula",ExpressionUUID->"b26389ca-63b5-42d1-83b6-75db71d7df3c"],
 "."
}], "Notes",
 CellID->151032356,ExpressionUUID->"1fc7aed3-25c7-4796-a317-6c13dcd723bd"],

Cell[TextData[{
 "Every directed edge from ",
 Cell[BoxData[
  ButtonBox["PacletFlowEdges",
   BaseStyle->"Link",
   ButtonData->"paclet:Wolfram/PacletFunctionGraph/ref/PacletFlowEdges"]], 
  "InlineFormula",ExpressionUUID->"76038cff-4413-4cdc-9b8b-7a6561131670"],
 " is included. Vertex face color comes from ",
 Cell[BoxData[
  ButtonBox["$FunctionGraphKindColors",
   BaseStyle->"Link",
   ButtonData->
    "paclet:Wolfram/PacletFunctionGraph/ref/$FunctionGraphKindColors"]], 
  "InlineFormula",ExpressionUUID->"6ad4ff71-4ca9-495f-bbda-a8d41b421caf"],
 " keyed on each vertex's ",
 Cell[BoxData["\"\<Kind\>\""], "InlineFormula",ExpressionUUID->
  "47d610ce-2fba-4b60-a741-534e797fbfcc"],
 ". Operator-like heads cluster among the constructors; Transforms sit \
between; Distance / Predicate heads form sinks at the bottom."
}], "Notes",
 CellID->550752950,ExpressionUUID->"f2237e15-20ba-4b53-a17e-32fc8662b19d"],

Cell[TextData[{
 "The default layout is ",
 Cell[BoxData["\"\<DiscreteSpiralEmbedding\>\""], "InlineFormula",
  ExpressionUUID->"33acfc56-d17e-4f84-b60b-69bc9b43a52b"],
 ", chosen for label legibility on dense paclets. Standard ",
 Cell[BoxData[
 "Graph"], "InlineFormula",ExpressionUUID->
  "86fa75b9-ef40-4014-8655-07e5592eadbc"],
 " options (",
 Cell[BoxData[
 "GraphLayout"], "InlineFormula",ExpressionUUID->
  "2a802315-897d-4e9a-b429-014faf2f9693"],
 ", ",
 Cell[BoxData[
 "ImageSize"], "InlineFormula",ExpressionUUID->
  "7023872e-ca8c-4210-a40d-836a7d66abc7"],
 ", ",
 Cell[BoxData[
 "VertexLabelStyle"], "InlineFormula",ExpressionUUID->
  "472b23e6-8390-44f6-aa56-4829fbbbcd0a"],
 ", \[Ellipsis]) passed via ",
 Cell[BoxData[
  StyleBox["opts", "TI"]], "InlineFormula",ExpressionUUID->
  "10e6fc20-6aa7-40e3-8cd6-e51e1a37ab8e"],
 " take precedence."
}], "Notes",
 CellID->910532365,ExpressionUUID->"186bb293-4bd3-4506-bbbc-21dbb3d8cea3"],

Cell[TextData[{
 "By default, paclet symbols with no flow edges are omitted from the \
rendering \[LongDash] they are pure constants or unused public symbols that \
would float disconnected. To include them, set the ",
 Cell[BoxData["\"\<IncludeIsolated\>\""], "InlineFormula",ExpressionUUID->
  "f1439cef-5a08-41c7-b106-f7bbcf3f4dd9"],
 " option."
}], "Notes",
 CellID->40193438,ExpressionUUID->"b928bc30-7ee7-4f2c-bee1-2e18c5d95719"],

Cell["The following options can be given:", "Notes",
 CellID->642268562,ExpressionUUID->"353a6802-e53e-4f46-8a96-97ff0d830eb5"],

