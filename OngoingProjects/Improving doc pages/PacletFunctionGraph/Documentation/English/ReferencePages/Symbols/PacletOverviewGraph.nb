  $Line = 0; Null]], "ExampleSection",
 CellID->167859628,ExpressionUUID->"dacde8f2-76a2-4edf-938e-182126e5951f"],

Cell[TextData[{
 "Edge count equals the length of ",
 Cell[BoxData[
 "PacletFlowEdges"], "InlineFormula",ExpressionUUID->
  "0e025777-6467-4431-a25a-a944278220c4"],
 " (modulo isolated-vertex filtering, which only affects vertex count):"
}], "ExampleText",
 CellID->762921904,ExpressionUUID->"684483b0-70c0-4a66-8b02-83fe372d8a83"],

Cell[BoxData[
 RowBox[{
  RowBox[{"EdgeCount", "[", 
   RowBox[{"PacletOverviewGraph", "[", "g", "]"}], "]"}], " ", "===", " ", 
  RowBox[{"Length", "[", 
   RowBox[{"PacletFlowEdges", "[", "g", "]"}], "]"}]}]], "Input",
 CellLabel->"In[1]:=",
 CellID->648349955,ExpressionUUID->"1e11ea2c-24db-4fae-87dc-1d29c642a763"],

Cell[BoxData["True"], "Output",
 CellLabel->"Out[1]=",
 CellID->917428069,ExpressionUUID->"a8338fcf-c22b-4d09-bfcc-5d6221a0bfbd"],

Cell[BoxData[""], "ExampleDelimiter",
 CellID->384506881,ExpressionUUID->"f3d0498d-ca82-4235-9efd-eba42f42f2e4"],

Cell["\<\
Vertex count without isolated symbols equals the number of distinct heads \
appearing in any edge:\
\>", "ExampleText",
 CellID->468546946,ExpressionUUID->"1ee33444-83f1-4e09-b105-a9b023c6b743"],

Cell[BoxData[
 RowBox[{
  RowBox[{"VertexCount", "[", 
   RowBox[{"PacletOverviewGraph", "[", "g", "]"}], "]"}], " ", "===", "\n", 
  "  ", 
  RowBox[{"Length", "[", 
   RowBox[{"Union", "[", 
    RowBox[{"Flatten", "[", 
     RowBox[{"PacletFlowEdges", "[", "g", "]"}], "]"}], "]"}], 
   "]"}]}]], "Input",
 CellLabel->"In[2]:=",
 CellID->178662828,ExpressionUUID->"3d01efcf-ac91-49d2-98aa-9579d1965cfe"],

Cell[BoxData["True"], "Output",
 CellLabel->"Out[2]=",
 CellID->694600182,ExpressionUUID->"8714cf46-a8f8-4b31-a86d-fadba0aff11c"]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[
 InterpretationBox[Cell[
  "Possible Issues", "ExampleSection",ExpressionUUID->
   "e1ebcaba-0da4-4361-ad1f-12ca7c6bb507"],
  $Line = 0; Null]], "ExampleSection",
 CellID->511353354,ExpressionUUID->"844eb990-4292-4ff3-8431-781f1273e440"],

Cell[TextData[{
 "Dense paclets produce dense graphs. QuantumFramework's overview has 80 \
edges across 20 vertices \[LongDash] some edge crossings are unavoidable. Use \
",
 Cell[BoxData[
  ButtonBox["SymbolNeighborhoodGraph",
   BaseStyle->"Link",
   ButtonData->
    "paclet:Wolfram/PacletFunctionGraph/ref/SymbolNeighborhoodGraph"]], 
  "InlineFormula",ExpressionUUID->"a92544af-3d16-4c37-bf7c-9f7b841cebc2"],
 " for a focused subgraph view when the overview is too busy."
}], "ExampleText",
 CellID->285418606,ExpressionUUID->"db106441-b348-42a9-beec-8e7413f2fb84"],

Cell[TextData[{
 "The default ",
 Cell[BoxData["\"\<DiscreteSpiralEmbedding\>\""], "InlineFormula",
  ExpressionUUID->"3687b214-798f-4796-adaa-e6205d641427"],
 " was chosen empirically across 13 candidate layouts; it minimizes label \
overlap on QuantumFramework but may not be optimal for other paclets. \
Override ",
 Cell[BoxData[
 "GraphLayout"], "InlineFormula",ExpressionUUID->
  "8c4d7f22-7bb4-4263-8339-6d40796ebaf9"],
 " if a different topology fits better."
}], "ExampleText",
 CellID->626952453,ExpressionUUID->"b5b16c4f-b6a6-4b00-b51e-b2cca5ca2a58"],

Cell[TextData[{
 "Self-loops (a head consumed by itself, e.g. ",
 Cell[BoxData[
 "QuantumOperator"], "InlineFormula",ExpressionUUID->
  "fa00715b-cc85-41eb-8164-109f40f58748"],
 " composing with another QuantumOperator) render as a tight curved arc on \
the vertex. They are not visual noise \[LongDash] they signal closure under \
composition."
}], "ExampleText",
 CellID->912667372,ExpressionUUID->"f68d7824-26f4-462c-824d-6212b15513dc"]
}, Open  ]]
}, Open  ]],

