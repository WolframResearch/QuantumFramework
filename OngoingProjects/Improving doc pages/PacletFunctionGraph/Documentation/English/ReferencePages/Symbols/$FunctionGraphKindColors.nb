  ImageSize->1200,
  PlotLabel->FormBox[
    StyleBox[
    "\"Wolfram/QuantumFramework \[LongDash] paclet flow\"", Bold, 16, 
     StripOnInput -> False], TraditionalForm]]], "Output",
 CellLabel->"Out[1]=",
 CellID->33958368,ExpressionUUID->"04234d60-23e1-46d6-a161-eee9d4673a19"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Customizing the palette", "ExampleSubsection",
 CellID->394629241,ExpressionUUID->"b754de11-8c72-4b2e-939c-4f693274847e"],

Cell["\<\
Override the binding in the current session to retheme. The new palette takes \
effect on the next render call:\
\>", "ExampleText",
 CellID->758236204,ExpressionUUID->"eee16b3b-1020-4aea-8c08-d20ad37929c2"],

Cell[BoxData[
 RowBox[{
  RowBox[{"$FunctionGraphKindColors", " ", "=", " ", 
   RowBox[{"<|", "\n", "    ", 
    RowBox[{
     RowBox[{"\"\<Constructor\>\"", " ", "->", " ", "LightBlue"}], ",", "\n", 
     "    ", 
     RowBox[{"\"\<Operator\>\"", " ", "->", " ", "LightGreen"}], ",", "\n", 
     "    ", 
     RowBox[{"\"\<Transform\>\"", " ", "->", " ", "LightYellow"}], ",", "\n", 
     "    ", 
     RowBox[{"\"\<Predicate\>\"", " ", "->", " ", "LightRed"}], ",", "\n", 
     "    ", 
     RowBox[{"\"\<Distance\>\"", " ", "->", " ", "LightPurple"}], ",", "\n", 
     "    ", 
     RowBox[{"\"\<\>\"", " ", "->", " ", "LightGray"}]}], "\n", "  ", 
    "|>"}]}], ";"}]], "Input",
 CellLabel->"In[1]:=",
 CellID->599157747,ExpressionUUID->"9f7c1dc8-98ea-42b8-b756-c4adb6059463"],

Cell[BoxData[""], "ExampleDelimiter",
 CellID->539131542,ExpressionUUID->"0155994e-f2cc-4679-93f6-7abc468dd4af"],

Cell["Restore the defaults by re-loading the package:", "ExampleText",
 CellID->435849825,ExpressionUUID->"d2df2f07-bc17-4519-b6dd-47f54c722827"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"ClearAll", "[", "$FunctionGraphKindColors", "]"}], ";"}], "\n", 
 RowBox[{
  RowBox[{"Needs", "[", "\"\<Wolfram`PacletFunctionGraph`\>\"", "]"}], 
  ";"}]}], "Input",
 CellLabel->"In[2]:=",
 CellID->759194476,ExpressionUUID->"61a8a345-f9e3-472a-a3e6-47f167afe9d0"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[
 InterpretationBox[Cell[
  "Properties & Relations", "ExampleSection",ExpressionUUID->
   "6e058596-2e25-4240-b942-78b541c7e6b5"],
  $Line = 0; Null]], "ExampleSection",
 CellID->303307889,ExpressionUUID->"1697e922-7ae4-4be6-b4f3-a5d4e57f5a97"],

Cell["\<\
The Association covers every Kind that BuildFunctionGraph might emit:\
\>", "ExampleText",
 CellID->361614227,ExpressionUUID->"e176f1d2-4931-42ef-81ab-86340a31b0ba"],

Cell[BoxData[
 RowBox[{"Keys", "[", "$FunctionGraphKindColors", "]"}]], "Input",
 CellLabel->"In[1]:=",
 CellID->699673564,ExpressionUUID->"63036636-23d0-46a0-8e1b-2be2ecbacada"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"\<\"Constructor\"\>", ",", "\<\"Operator\"\>", 
   ",", "\<\"Transform\"\>", ",", "\<\"Predicate\"\>", 
   ",", "\<\"Distance\"\>", ",", "\<\"NamedInstance\"\>", 
   ",", "\<\"Utility\"\>", ",", "\<\"\"\>"}], "}"}]], "Output",
 CellLabel->"Out[1]=",
 CellID->59047914,ExpressionUUID->"5928d8d9-0dae-44b4-adb2-30ec7f70eb4b"],

Cell[BoxData[""], "ExampleDelimiter",
 CellID->258983801,ExpressionUUID->"20c650ac-e424-4944-a540-4b1dd4fbedce"],

Cell["Look up a Kind that has been observed in a built graph:", "ExampleText",
 CellID->410726034,ExpressionUUID->"bede20a2-e26b-46aa-9e00-5244413ed69f"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"g", " ", "=", " ", 
   RowBox[{"BuildFunctionGraph", "[", 
    RowBox[{"\"\</Users/mohammadb/Documents/GitHub/QuantumFramework/\
QuantumFramework\>\"", ",", " ", 
     RowBox[{"\"\<WriteFile\>\"", " ", "->", " ", "False"}]}], "]"}]}], 
  ";"}], "\n", 
 RowBox[{
  RowBox[{"kinds", " ", "=", " ", 
   RowBox[{"DeleteDuplicates", " ", "@", " ", 
    RowBox[{"Lookup", "[", 
     RowBox[{
      RowBox[{"Values", "[", 
       RowBox[{"KeyDrop", "[", 
        RowBox[{"g", ",", " ", "\"\<$Meta\>\""}], "]"}], "]"}], ",", 
      " ", "\"\<Kind\>\""}], "]"}]}]}], ";"}], "\n", 
 RowBox[{"Lookup", "[", 
  RowBox[{"$FunctionGraphKindColors", ",", " ", "kinds"}], "]"}]}], "Input",
 CellLabel->"In[2]:=",
 CellID->576507602,ExpressionUUID->"56ebb519-4d51-4df8-b208-cb7e283adc41"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   TemplateBox[<|"color" -> RGBColor[0.7, 0.85, 1]|>,
    "RGBColorSwatchTemplate"], ",", 
   TemplateBox[<|"color" -> RGBColor[0.7, 1, 0.7]|>,
    "RGBColorSwatchTemplate"], ",", 
   TemplateBox[<|"color" -> RGBColor[0.9, 0.7, 1]|>,
    "RGBColorSwatchTemplate"], ",", 
   TemplateBox[<|"color" -> RGBColor[1, 0.7, 0.7]|>,
    "RGBColorSwatchTemplate"], ",", 
   TemplateBox[<|"color" -> RGBColor[1, 0.9, 0.6]|>,
    "RGBColorSwatchTemplate"]}], "}"}]], "Output",
 CellLabel->"Out[2]=",
 CellID->193149472,ExpressionUUID->"21ada921-5a9b-495d-808d-0bc9a5a03b4f"]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[
 InterpretationBox[Cell[
  "Possible Issues", "ExampleSection",ExpressionUUID->
   "c7758292-2b53-43b9-8451-73b752806cc5"],
  $Line = 0; Null]], "ExampleSection",
 CellID->394672955,ExpressionUUID->"6e86c74f-cda2-473e-b959-c97ad72cdc82"],

Cell[TextData[{
 Cell[BoxData[
 "$FunctionGraphKindColors"], "InlineFormula",ExpressionUUID->
  "86f354bf-1ac7-40f6-b063-f51b7a44ba84"],
 " is a session-level binding. Modifications via ",
 Cell[BoxData[
 "Set"], "InlineFormula",ExpressionUUID->
  "b45119ce-328a-4b75-87e7-e6f9ebf13a87"],
 " persist for the lifetime of the kernel; re-load the package or reset the \
symbol explicitly to restore defaults."
}], "ExampleText",
 CellID->562492429,ExpressionUUID->"791ad579-5f4e-40e5-b764-67bc9af54ebd"],

Cell[TextData[{
 "When a paclet uses a custom ",
 Cell[BoxData["\"\<KindClassifier\>\""], "InlineFormula",ExpressionUUID->
  "badae809-7f0e-430e-9337-3373ebbe4307"],
 " emitting Kinds not in this Association, vertices get the fallback color ",
 Cell[BoxData[
 "LightGray"], "InlineFormula",ExpressionUUID->
  "56df5864-ce3f-4a73-b53b-1a8754a93817"],
 ". Extend the Association with the new Kinds to assign colors."
}], "ExampleText",
 CellID->66251298,ExpressionUUID->"f171a0d0-2688-4fe7-a481-6d409a43a956"],

Cell[TextData[{
 "The colors are pure ",
 Cell[BoxData[
 "RGBColor"], "InlineFormula",ExpressionUUID->
  "9329b5fb-01b8-4191-9e44-ffff6a4cfa04"],
 " expressions; they cannot be replaced with ",
 Cell[BoxData[
 "GrayLevel"], "InlineFormula",ExpressionUUID->
  "e214a395-954e-4d69-acde-8d9d702eb856"],
 " or ",
 Cell[BoxData[
 "Hue"], "InlineFormula",ExpressionUUID->
  "bde945a4-9ed9-445b-95aa-03aae2e4db90"],
 " without breaking downstream ",
 Cell[BoxData[
 "FaceForm"], "InlineFormula",ExpressionUUID->
  "6d0bcb81-73f0-4701-b8fa-f308dcf79808"],
 " / ",
 Cell[BoxData[
 "EdgeForm"], "InlineFormula",ExpressionUUID->
  "ae4f8ddc-0b4b-4a5c-a0e0-189a0706a875"],
 " expectations in the renderers (those accept any color spec, but mixing \
types in a session can produce inconsistent rendering)."
}], "ExampleText",
 CellID->997767383,ExpressionUUID->"ab66383b-9ff9-4b0b-829b-dc23f8f2c9fb"]
}, Open  ]]
}, Open  ]],

