    TemplateBox[<|"color" -> RGBColor[0.7, 1, 0.7]|>,
     "RGBColorSwatchTemplate"]}], ",", 
   RowBox[{"\<\"Transform\"\>", "\[Rule]", 
    TemplateBox[<|"color" -> RGBColor[1, 0.9, 0.6]|>,
     "RGBColorSwatchTemplate"]}], ",", 
   RowBox[{"\<\"Predicate\"\>", "\[Rule]", 
    TemplateBox[<|"color" -> RGBColor[1, 0.7, 0.7]|>,
     "RGBColorSwatchTemplate"]}], ",", 
   RowBox[{"\<\"Distance\"\>", "\[Rule]", 
    TemplateBox[<|"color" -> RGBColor[0.9, 0.7, 1]|>,
     "RGBColorSwatchTemplate"]}], ",", 
