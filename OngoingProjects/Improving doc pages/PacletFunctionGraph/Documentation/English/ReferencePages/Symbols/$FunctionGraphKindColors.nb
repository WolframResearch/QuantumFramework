Cell[TextData[{
 "The Association is read by ",
 Cell[BoxData[
  ButtonBox["SymbolNeighborhoodGraph",
   BaseStyle->"Link",
   ButtonData->
    "paclet:Wolfram/PacletFunctionGraph/ref/SymbolNeighborhoodGraph"]], 
  "InlineFormula",ExpressionUUID->"648c604a-7a2f-409a-9b62-140aaedafb0a"],
 " and ",
 Cell[BoxData[
  ButtonBox["PacletOverviewGraph",
   BaseStyle->"Link",
   ButtonData->"paclet:Wolfram/PacletFunctionGraph/ref/PacletOverviewGraph"]],
   "InlineFormula",ExpressionUUID->"eefa09cf-39c0-4762-ab85-980a964e70ad"],
 " on every render. To customize, override the binding before invoking the \
renderer."
}], "Notes",
 CellID->480172468,ExpressionUUID->"be26c342-882c-4ca9-8144-99bf86ff3f8e"],

Cell["\<\
The default palette is calibrated for paclets with up to ~10 distinct Kinds. \
Colors are pastel enough to remain legible alongside dark vertex labels.\
\>", "Notes",
 CellID->87851193,ExpressionUUID->"175bf1c0-ff62-45e3-97d7-5d94bce6e763"],

