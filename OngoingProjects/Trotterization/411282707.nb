Cell[TextData[{
 "Note that the 2-norm distance is the same as the ideal error ",
 Cell[BoxData[
  FormBox[
   RowBox[{"(", 
    RowBox[{"\[Epsilon]", "=", 
     RowBox[{"||", 
      RowBox[{
       RowBox[{"u", "(", "t", ")"}], "-", "Trotterized"}], "||", 
      RowBox[{"/", 
       RowBox[{"||", 
        RowBox[{"u", "(", "t", ")"}], "||"}]}]}]}]}], TraditionalForm]]],
 ") since ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"||", 
     RowBox[{"u", "(", "t", ")"}], "||"}], "=", "1"}], TraditionalForm]]],
 "."
}], "Text",
 CellChangeTimes->{{3.876920527448975*^9, 3.876920593933715*^9}}]
}, Open  ]],

