 CellLabel->"In[55]:="],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"tracDis", "=", 
    RowBox[{"Table", "[", 
     RowBox[{
      RowBox[{"With", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"c", "=", 
          RowBox[{"N", "[", 
           RowBox[{"QuantumCircuitOperator", "[", 
            RowBox[{"{", 
             RowBox[{"\"\<Trotterization\>\"", ",", 
              RowBox[{"N", "@", "ops"}], ",", "order", ",", "steps", ",", 
              "1"}], "}"}], "]"}], "]"}]}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"c", "[", "\"\<Gates\>\"", "]"}], ",", 
          RowBox[{"QuantumDistance", "[", 
           RowBox[{
            RowBox[{"QuantumState", "[", 
             RowBox[{"c", "[", "\"\<Matrix\>\"", "]"}], "]"}], ",", "uf", 
            ",", "\"\<Trace\>\""}], "]"}]}], "}"}]}], "]"}], ",", 
      RowBox[{"{", 
       RowBox[{"order", ",", 
        RowBox[{"{", 
         RowBox[{"1", ",", "2", ",", "4"}], "}"}]}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"steps", ",", "1", ",", "10"}], "}"}]}], "]"}]}], ";"}], "//", 
  "AbsoluteTiming"}]], "Input",
 CellChangeTimes->{{3.876790979432076*^9, 3.876791061803018*^9}, {
