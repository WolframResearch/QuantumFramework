(* Beginning of Notebook Content *)
Notebook[{

Cell[CellGroupData[{
Cell["Quantum Systems Engineering, by Computing", "Title",
 CellID->509267359,ExpressionUUID->"4ddb5767-1f00-4973-a411-49eacd07850d"],

Cell[TextData[StyleBox["A Wolfram Language / QuantumFramework companion to \
the Quantum Systems Engineering unit.", "TI"]], "Text",ExpressionUUID->\
"77cd92e1-2d76-4c3e-9b9f-02d849fd1cf9"],

Cell[TextData[{
 "This document walks the entire arc of the unit, from \
Schr\[ODoubleDot]dinger's equation to quantum sensing, but it teaches every \
idea by ",
 StyleBox["building it as a computation you can run, modify, and break",
  FontWeight->"Bold"],
 ". The course is delivered in Python (Qiskit and QuTiP); here we do the same \
physics in the Wolfram QuantumFramework. The conviction is Feynman-flavored: \
if we cannot compute it, we have not really understood it. So every claim \
below is immediately followed by a cell that demonstrates or verifies it, and \
every number you see was produced by running the code, not asserted from a \
formula sheet."
}], "Text",ExpressionUUID->"c69daafd-c839-41ce-b5d8-320e9adb8ce6"],

Cell[TextData[{
 "We start where the course starts, with a particle trapped in a box, and use \
it to motivate the jump from messy calculus to clean linear algebra. We then \
build the engineer's two workhorses, the ",
 StyleBox["qubit",
  FontWeight->"Bold"],
 " and the ",
 StyleBox["quantum harmonic oscillator",
  FontWeight->"Bold"],
 ", drive them with fields, and watch them flop. We scale up to many qubits, \
gates, and circuits; send a state across a channel by teleportation; open the \
system to its environment and watch coherence decay; and finally turn that \
same fragility into a precision ",
 StyleBox["sensor",
  FontWeight->"Bold"],
 ". Four of these sections correspond directly to the four Python labs in the \
unit, and they are flagged as such."
}], "Text",ExpressionUUID->"438be96f-2341-4696-8c34-e9b84a9028eb"],

Cell["\<\
A practical note on how to read this. Evaluate the cells top to bottom, as if \
this were one long laboratory session. Each section is self-contained enough \
to start from, but variables defined earlier are reused. Change the numbers. \
Detune the drive, raise the noise, add a qubit. The framework will tell you \
what happens.\
\>", "Text",ExpressionUUID->"9e84199b-6643-4553-a3bd-c35bf5e2ba71"],

Cell["Setup", "Section",ExpressionUUID->"c72e06ad-cda7-48db-a584-0f956931b617"],

Cell[TextData[{
 "Everything below uses one paclet plus its second-quantization sub-package. \
Load both up front. The sub-package carries the oscillator and quantum-optics \
tools (",
 Cell[BoxData[
 "AnnihilationOperator"], "InlineFormula",ExpressionUUID->
  "a4221494-34bd-468f-adfd-390b9f7d4b9e"],
 ", ",
 Cell[BoxData[
 "FockState"], "InlineFormula",ExpressionUUID->
  "62b553ed-c172-4615-9b46-89659801deae"],
 ", ",
 Cell[BoxData[
 "CoherentState"], "InlineFormula",ExpressionUUID->
  "83d2f969-5333-49f4-9218-3152153a5fac"],
 ", the quadrature operators, ",
 Cell[BoxData[
 "OperatorVariance"], "InlineFormula",ExpressionUUID->
  "9f08c96c-76dd-4e84-8fb6-c6ba8fa986c5"],
 ", ",
 Cell[BoxData[
 "G2Coherence"], "InlineFormula",ExpressionUUID->
  "b7632f79-d680-4d4b-8c05-7a07fae0685d"],
 "); a bare ",
 Cell[BoxData[
 "Needs"], "InlineFormula",ExpressionUUID->
  "c10a691c-9b46-4681-8876-e5d74c583d9b"],
 " of the main context leaves these inert, so we load it now even though it \
is first needed in Part 5."
}], "Text",ExpressionUUID->"6bfd93ad-617f-4a27-97c3-7f70c95904ea"],

Cell[BoxData[{
 RowBox[{"Needs", "[", "\"\<Wolfram`QuantumFramework`\>\"", "]"}], "\n", 
 RowBox[{"Needs", "[", "\"\<Wolfram`QuantumFramework`SecondQuantization`\>\"",
   "]"}]}], "Input",
 CellLabel->"In[1]:= ",ExpressionUUID->"a2ff8729-f27a-4487-8345-70641cff0136"],

Cell[TextData[{
 "The three central objects are ",
 Cell[BoxData[
 "QuantumState"], "InlineFormula",ExpressionUUID->
  "845ca065-0ab6-4809-ae88-3054b9d16593"],
 " (a ket or a density matrix), ",
 Cell[BoxData[
 "QuantumOperator"], "InlineFormula",ExpressionUUID->
  "f3d59d94-2910-429f-8149-0e32619b3846"],
 " (a matrix that acts on states, including Hamiltonians and gates), and ",
 Cell[BoxData[
 "QuantumCircuitOperator"], "InlineFormula",ExpressionUUID->
  "09949597-d21a-4931-b4b5-50332d8c3c6c"],
 " (an ordered list of operations). Each is a ",
 StyleBox["property-carrying object", "TI"],
 ": you ask it questions with ",
 Cell[BoxData[
  RowBox[{"object", "[", "\"\<Property\>\"", "]"}]], "InlineFormula",
  ExpressionUUID->"d07d36ca-9060-43f0-a526-499624fbe4f7"],
 " rather than calling dozens of separate functions. That is the single most \
important habit to build here. When you want the Bloch vector, the purity, \
whether an operator is Hermitian, or a variance, ask the object: ",
 Cell[BoxData[
  RowBox[{"qs", "[", "\"\<BlochVector\>\"", "]"}]], "InlineFormula",
  ExpressionUUID->"ac0a5785-3ff7-43f8-8617-da3e8fddbd6d"],
 ", ",
 Cell[BoxData[
  RowBox[{"qs", "[", "\"\<Purity\>\"", "]"}]], "InlineFormula",ExpressionUUID->
  "3f0e9ab4-dafa-4458-8a3b-bd6b2d1da73b"],
 ", ",
 Cell[BoxData[
  RowBox[{"op", "[", "\"\<HermitianQ\>\"", "]"}]], "InlineFormula",
  ExpressionUUID->"2ac34351-1c33-452c-bb31-fba031aa1df7"],
 ", ",
 Cell[BoxData[
  RowBox[{"OperatorVariance", "[", 
   RowBox[{"qs", ",", " ", "op"}], "]"}]], "InlineFormula",ExpressionUUID->
  "db08266b-7c6d-43d0-8912-b90d00e29602"],
 ". We reach for raw matrices only to ",
 StyleBox["build", "TI"],
 " an operator, never to interrogate one. We will lean on that pattern \
constantly."
}], "Text",ExpressionUUID->"633ca4fd-a129-493a-9de0-dd3a1bf4b4ce"],

Cell["\<\
Part 1 \[LongDash] From wave mechanics to a finite Hilbert space (Lab 1)\
\>", "Section",ExpressionUUID->"bf6724f7-81a6-4d2a-9548-c8e7025c8141"],

Cell[TextData[{
 StyleBox["Course map:",
  FontWeight->"Bold"],
 " Weeks 1 and 3. ",
 StyleBox["This is Lab 1 (particle in a box, finite/infinite well).",
  FontWeight->"Bold"]
}], "Text",
 CellFrame->{{3, 0}, {0, 0}},
 CellMargins->{{40, 10}, {7, 7}},
 CellFrameMargins->10,
 CellFrameColor->GrayLevel[0.55],
 FontSlant->"Italic",
 FontColor->LightDarkSwitched[
   GrayLevel[0.45], 
   GrayLevel[0.65]],
 Background->LightDarkSwitched[
   GrayLevel[0.96], 
   GrayLevel[0.2]],ExpressionUUID->"20d9e56e-ad57-493b-9bd2-11fef8b41e56"],

Cell[TextData[{
 "The course opens with Schr\[ODoubleDot]dinger's equation and the infinite \
square well because it is the simplest place where energy quantization falls \
out of a boundary condition. A particle of mass ",
 Cell[BoxData[
  StyleBox["m", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "10efcb34-9074-4653-9b28-b8194e3978d0"],
 " confined to ",
 Cell[BoxData[
  RowBox[{"0", "\[LessEqual]", 
   StyleBox["x", "TI"], "\[LessEqual]", 
   StyleBox["L", "TI"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "653096f1-a103-404a-9811-6ce1e27554cb"],
 " with infinite walls has stationary states ",
 Cell[BoxData[
  RowBox[{
   SubscriptBox[
    StyleBox["\[Psi]", "TI"], 
    StyleBox["n", "TI"]], 
   StyleBox["(",
    SpanMaxSize->1], 
   StyleBox["x", "TI"], 
   StyleBox[")",
    SpanMaxSize->1], "=", 
   SqrtBox[
    RowBox[{"2", "/", 
     StyleBox["L", "TI"]}]], " ", 
   StyleBox["sin",
    FontSlant->"Plain"], "\[ThinSpace]", 
   StyleBox["(",
    SpanMaxSize->1], 
   RowBox[{
    StyleBox["n", "TI"], "\[Pi]", 
    StyleBox["x", "TI"], "/", 
    StyleBox["L", "TI"]}], 
   StyleBox[")",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "6281d585-a0df-4792-ae22-2d32952d91ac"],
 " and energies ",
 Cell[BoxData[
  RowBox[{
   SubscriptBox[
    StyleBox["E", "TI"], 
    StyleBox["n", "TI"]], "=", 
   SuperscriptBox[
    StyleBox["n", "TI"], "2"], 
   SuperscriptBox["\[Pi]", "2"], 
   SuperscriptBox["\[HBar]", "2"], "/", 
   StyleBox["(",
    SpanMaxSize->1], 
   RowBox[{"2", 
    StyleBox["m", "TI"], 
    SuperscriptBox[
     StyleBox["L", "TI"], "2"]}], 
   StyleBox[")",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "a2ab9be7-d9ab-47b3-8cf5-3b62be62a553"],
 ". The physics worth keeping is the ",
 StyleBox["scaling",
  FontWeight->"Bold"],
 ": the ",
 Cell[BoxData[
  StyleBox["n", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "cba66c25-899c-4032-a971-69d4aff4aec1"],
 "-th level sits at ",
 Cell[BoxData[
  SuperscriptBox[
   StyleBox["n", "TI"], "2"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "2dfc1563-6acf-4394-bb02-8a6f025f07ef"],
 " times the ground energy."
}], "Text",ExpressionUUID->"ffeb9ec7-1a87-4d91-8e19-14e18fc183a1"],

Cell[TextData[{
 "We do not discretize this by hand. The Wolfram Language has a native \
quantum operator for exactly this problem: ",
 Cell[BoxData[
 "SchrodingerPDEComponent"], "InlineFormula",ExpressionUUID->
  "52a64e5c-a751-4a57-bc44-77ff0a758e9d"],
 " assembles the differential operator ",
 Cell[BoxData[
  RowBox[{"-", 
   FractionBox[
    SuperscriptBox["\[HBar]", "2"], 
    RowBox[{"2", 
     StyleBox["m", "TI"]}]], 
   SuperscriptBox["\[Del]", "2"], "+", 
   StyleBox["V", "TI"], 
   StyleBox["(",
    SpanMaxSize->1], 
   StyleBox["x", "TI"], 
   StyleBox[")",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "40be3d0d-5b0a-48e6-bf0b-bf3e65c60428"],
 " from physical parameters, and ",
 Cell[BoxData[
 "NDEigensystem"], "InlineFormula",ExpressionUUID->
  "b0c95833-2410-466a-aaee-bf375f3c7eaa"],
 " finds its eigenvalues and eigenstates under the boundary conditions we \
impose. The infinite walls are a ",
 Cell[BoxData[
 "DirichletCondition"], "InlineFormula",ExpressionUUID->
  "a59458a9-d72b-4f58-9ff9-91940a9eea09"],
 " forcing ",
 Cell[BoxData[
  RowBox[{
   StyleBox["\[Psi]", "TI"], "=", "0"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "0b8ea88e-97de-4488-a552-d60b32557e4b"],
 " at the edges of the box. Set ",
 Cell[BoxData[
  RowBox[{"\[HBar]", "=", 
   StyleBox["m", "TI"], "=", "1"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "48aba6db-077a-4785-82e2-4b35988bee2c"],
 ", ",
 Cell[BoxData[
  RowBox[{
   StyleBox["V", "TI"], "=", "0"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "37b69f3c-1933-4cbb-8182-7ec4b9e53790"],
 " inside, and solve on ",
 Cell[BoxData[
  RowBox[{
   StyleBox["[",
    SpanMaxSize->1], 
   RowBox[{"0", ",", "1"}], 
   StyleBox["]",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "0c8bd675-eb87-4435-9393-cd693dac3600"],
 ":"
}], "Text",ExpressionUUID->"8f6122de-3018-437a-b87c-9fe7f98bf67c"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"Hbox", " ", "=", " ", 
   RowBox[{"SchrodingerPDEComponent", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"\[Psi]", "[", "x", "]"}], ",", " ", 
       RowBox[{"{", "x", "}"}]}], "}"}], ",", "\n", "   ", 
     RowBox[{"<|", 
      RowBox[{
       RowBox[{"\"\<Mass\>\"", " ", "->", " ", "1"}], ",", " ", 
       RowBox[{"\"\<ReducedPlanckConstant\>\"", " ", "->", " ", "1"}], ",", 
       " ", 
       RowBox[{"\"\<SchrodingerPotential\>\"", " ", "->", " ", "0"}]}], 
      "|>"}]}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"{", 
    RowBox[{"energies", ",", " ", "modes"}], "}"}], " ", "=", " ", 
   RowBox[{"NDEigensystem", "[", "\n", "   ", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"Hbox", ",", " ", 
       RowBox[{"DirichletCondition", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"\[Psi]", "[", "x", "]"}], " ", "==", " ", "0"}], ",", " ", 
         "True"}], "]"}]}], "}"}], ",", " ", 
     RowBox[{"\[Psi]", "[", "x", "]"}], ",", " ", 
     RowBox[{"{", 
      RowBox[{"x", ",", " ", "0", ",", " ", "1"}], "}"}], ",", " ", "5"}], 
    "]"}]}], ";"}], "\n", "energies"}], "Input",
 CellLabel->"In[2]:= ",ExpressionUUID->"8d8910a3-5444-4e57-8907-a8cd3c019513"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
  "4.934806367856982`", ",", "19.739474484147934`", ",", "44.41622688824364`",
    ",", "78.97358311901903`", ",", "123.43323782051375`"}], "}"}]], "Output",\

 CellLabel->"Out[2]= ",ExpressionUUID->"846cfdf8-9afd-4b47-b53d-00db605d50ca"]
}, Open  ]],

Cell[TextData[{
 "This returns ",
 Cell[BoxData[
  RowBox[{"{", 
   RowBox[{
   "4.93", ",", " ", "19.74", ",", " ", "44.42", ",", " ", "78.97", ",", " ", 
    "123.43"}], "}"}]], "InlineFormula",ExpressionUUID->
  "fedd9ee9-60e3-4902-817c-93e274155c03"],
 ", matching the exact ",
 Cell[BoxData[
  RowBox[{
   RowBox[{
    SubscriptBox[
     StyleBox["E", "TI"], 
     StyleBox["k", "TI"]], "=", 
    SuperscriptBox[
     StyleBox["k", "TI"], "2"], 
    SuperscriptBox["\[Pi]", "2"], "/", 
    StyleBox["(",
     SpanMaxSize->1], 
    RowBox[{"2", 
     SuperscriptBox[
      StyleBox["L", "TI"], "2"]}], 
    StyleBox[")",
     SpanMaxSize->1], "=", "{", "4.93"}], 
   RowBox[{",", "\[ThinSpace]"}], "19.74", 
   RowBox[{",", "\[ThinSpace]"}], "44.41", 
   RowBox[{",", "\[ThinSpace]"}], "78.96", 
   RowBox[{",", "\[ThinSpace]"}], 
   RowBox[{"123.37", "}"}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "f6742a87-3ac0-4f98-8f30-138620e568ff"],
 " to better than a part in a thousand, with no hand-built matrix anywhere."
}], "Text",ExpressionUUID->"989d80fb-616c-4cee-a3ae-bd891e8fca99"],

Cell[TextData[{
 "The clean physical statement is the ratio. Verify that the levels scale as ",
 Cell[BoxData[
  SuperscriptBox[
   StyleBox["k", "TI"], "2"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "fc83f65a-2cf5-4d2c-a80c-a3317c8114e9"],
 ":"
}], "Text",ExpressionUUID->"cd0770e6-ed12-44b7-bf38-0d652183c0d1"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"energies", "/", 
  RowBox[{"First", "[", "energies", "]"}]}]], "Input",
 CellLabel->"In[3]:= ",ExpressionUUID->"2cd1c7e7-80c8-4b36-b9f2-348c4db08ed0"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
  "1.`", ",", "4.000050460484453`", ",", "9.000601761712506`", ",", 
   "16.00338032175203`", ",", "25.0127823909161`"}], "}"}]], "Output",
 CellLabel->"Out[3]= ",ExpressionUUID->"e3f74dc9-a71f-4733-910d-5a10002a4d8e"]
}, Open  ]],

Cell[TextData[{
 "The result ",
 Cell[BoxData[
  RowBox[{"{", 
   RowBox[{
   "1.", ",", " ", "4.00", ",", " ", "9.00", ",", " ", "16.00", ",", " ", 
    "25.01"}], "}"}]], "InlineFormula",ExpressionUUID->
  "bbf2a746-0966-407b-8ba3-c304a4e7e34a"],
 " is ",
 Cell[BoxData[
  RowBox[{
   RowBox[{"{", "1"}], 
   RowBox[{",", "\[ThinSpace]"}], 
   RowBox[{"4", ",", "9", ",", "16"}], 
   RowBox[{",", "\[ThinSpace]"}], 
   RowBox[{"25", "}"}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "cd04573b-c9cb-4c1d-96aa-14499a510dfa"],
 ". The boundary condition alone forces the ",
 Cell[BoxData[
  SuperscriptBox[
   StyleBox["k", "TI"], "2"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "ac0bd784-e928-4a27-871b-89534e53ce6b"],
 " ladder."
}], "Text",ExpressionUUID->"0f9d430e-e7b4-4458-b7a3-193729a6f06f"],

Cell[TextData[{
 "Each eigenstate is a continuous wavefunction. To bring it into \
QuantumFramework, which works in finite-dimensional Hilbert spaces, sample it \
on a grid and hand the values to a ",
 Cell[BoxData[
 "QuantumState"], "InlineFormula",ExpressionUUID->
  "bf616c8d-847e-4889-b822-d20bee660042"],
 ", which normalizes them into a unit vector:"
}], "Text",ExpressionUUID->"59a35c85-e503-4be2-9b52-bd20d35622fa"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"grid", " ", "=", " ", 
   RowBox[{"Subdivide", "[", 
    RowBox[{"0.", ",", " ", "1.", ",", " ", "64"}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"ground", " ", "=", " ", 
   RowBox[{
    RowBox[{"QuantumState", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"(", 
        RowBox[{
         RowBox[{"modes", "[", 
          RowBox[{"[", "1", "]"}], "]"}], " ", "/.", " ", 
         RowBox[{"x", " ", "->", " ", "#"}]}], ")"}], " ", "&"}], " ", "/@", 
      " ", "grid"}], "]"}], "[", "\"\<Normalize\>\"", "]"}]}], ";"}], "\n", 
 RowBox[{"ground", "[", "\"\<Norm\>\"", "]"}]}], "Input",
 CellLabel->"In[4]:= ",ExpressionUUID->"b707ddcc-cf67-4223-840f-1eb90d384807"],

Cell[BoxData["0.9999999999999999`"], "Output",
 CellLabel->"Out[4]= ",ExpressionUUID->"46fbbc4e-3069-4762-a3fb-6587f29c3d00"]
}, Open  ]],

Cell[TextData[{
 Cell[BoxData[
  RowBox[{"ground", "[", "\"\<Norm\>\"", "]"}]], "InlineFormula",
  ExpressionUUID->"81517544-8ddc-467e-8e47-de7d80138dae"],
 " is ",
 Cell[BoxData[
 "1."], "InlineFormula",ExpressionUUID->
  "dcd6ead7-352e-4053-90ec-0e797eab1465"],
 ": a genuine normalized state, its amplitudes the half-sine ",
 Cell[BoxData[
  RowBox[{
   StyleBox["sin",
    FontSlant->"Plain"], "\[ThinSpace]", 
   StyleBox["(",
    SpanMaxSize->1], 
   RowBox[{"\[Pi]", 
    StyleBox["x", "TI"], "/", 
    StyleBox["L", "TI"]}], 
   StyleBox[")",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "ca2a926f-2581-420a-86e4-ba1c7caf3003"],
 " peaked at the center of the box."
}], "Text",ExpressionUUID->"3bb50c8c-e280-4f6d-8a40-da5052f8056d"],

Cell[TextData[{
 "This is the bridge for the whole unit. A continuous wave-mechanics problem \
was solved natively, and its ground state became a ",
 Cell[BoxData[
 "QuantumState"], "InlineFormula",ExpressionUUID->
  "5665d97d-2894-47fe-a002-c93ddcf98a9f"],
 ". From here on we work in finite-dimensional Hilbert spaces, where the \
language is pure linear algebra. (The finite-well version, where the walls \
are a finite barrier, is ",
 StyleBox["Lab 1",
  FontWeight->"Bold"],
 " at the end.)"
}], "Text",ExpressionUUID->"83601536-c6ee-46d3-8618-ed7641d89e3a"],

Cell["Part 2 \[LongDash] States, observables, and measurement", "Section",ExpressionUUID->"86c2af8f-8fa8-446b-911e-ae238ada5d1f"],

Cell[TextData[{
 StyleBox["Course map:",
  FontWeight->"Bold"],
 " Weeks 2 and 3 (Dirac notation, Hilbert space, observables, the statistical \
interpretation, uncertainty)."
}], "Text",
 CellFrame->{{3, 0}, {0, 0}},
 CellMargins->{{40, 10}, {7, 7}},
 CellFrameMargins->10,
 CellFrameColor->GrayLevel[0.55],
 FontSlant->"Italic",
 FontColor->LightDarkSwitched[
   GrayLevel[0.45], 
   GrayLevel[0.65]],
 Background->LightDarkSwitched[
   GrayLevel[0.96], 
   GrayLevel[0.2]],ExpressionUUID->"33ad2839-5598-4e20-8bb3-3099b3a5dc5d"],

Cell[TextData[{
 "A pure quantum state is a unit vector. The smallest interesting case is the \
qubit, a two-level system. In Dirac notation we write kets like ",
 Cell[BoxData[
  TemplateBox[{"0"},
   "Ket"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "8c471402-dbb4-4bbf-af13-a71b0c2b4802"],
 " and ",
 Cell[BoxData[
  TemplateBox[{"1"},
   "Ket"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "bc3f5bc0-299f-4b3a-8e7e-cbef56678398"],
 " for the computational basis and ",
 Cell[BoxData[
  RowBox[{
   TemplateBox[{"+"},
    "Ket"], "=", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{
      TemplateBox[{"0"},
       "Ket"], "+", 
      TemplateBox[{"1"},
       "Ket"]}], ")"}], "/", 
    SqrtBox["2"]}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "011e9a4e-fbf6-4eb5-8864-1066ac81e901"],
 " for an equal superposition. Build a few and look at one:"
}], "Text",ExpressionUUID->"09710ba5-cb52-4898-a6bc-41ee31d261a2"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"zero", " ", "=", " ", 
   RowBox[{"QuantumState", "[", "\"\<0\>\"", "]"}]}], ";", " ", 
  RowBox[{"one", " ", "=", " ", 
   RowBox[{"QuantumState", "[", "\"\<1\>\"", "]"}]}], ";", " ", 
  RowBox[{"plus", " ", "=", " ", 
   RowBox[{"QuantumState", "[", "\"\<+\>\"", "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"psi", " ", "=", " ", 
   RowBox[{"QuantumState", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"1", ",", " ", "I"}], "}"}], "/", 
     RowBox[{"Sqrt", "[", "2", "]"}]}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"psi", "[", "\"\<StateVector\>\"", "]"}], " ", "//", " ", 
  "Normal"}]}], "Input",
 CellLabel->"In[5]:= ",ExpressionUUID->"23ea506e-d5f0-4186-9927-4180947867d0"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   FractionBox["1", 
    SqrtBox["2"]], ",", 
   FractionBox["\[ImaginaryI]", 
    SqrtBox["2"]]}], "}"}]], "Output",
 CellLabel->"Out[5]= ",ExpressionUUID->"98cec730-9166-42c4-a93e-9a04fc140066"]
}, Open  ]],

Cell[TextData[{
 "This returns ",
 Cell[BoxData[
  RowBox[{
   RowBox[{
    RowBox[{"{", "1", "/", 
     SqrtBox["2"]}], 
    RowBox[{",", "\[ThinSpace]"}], " ", 
    RowBox[{
     StyleBox["i", "TI"], "/", 
     SqrtBox["2"]}]}], "}"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "582adc11-5d69-431f-b292-ff2a2c36e274"],
 ". The state ",
 Cell[BoxData[
 "psi"], "InlineFormula",ExpressionUUID->
  "d2de33ad-0322-4e84-81c3-fe79a428b8be"],
 " is ",
 Cell[BoxData[
  RowBox[{
   RowBox[{"(", 
    RowBox[{
     TemplateBox[{"0"},
      "Ket"], "+", 
     RowBox[{
      StyleBox["i", "TI"], 
      TemplateBox[{"1"},
       "Ket"]}]}], ")"}], "/", 
   SqrtBox["2"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "6d305dd1-a92b-4861-af01-fbab0f3d7ec4"],
 ", and ",
 Cell[BoxData[
  RowBox[{"psi", "[", "\"\<Norm\>\"", "]"}]], "InlineFormula",ExpressionUUID->
  "b82eb9d1-885e-442a-af11-a36c3f141033"],
 " is ",
 Cell[BoxData[
 "1"], "InlineFormula",ExpressionUUID->"c18118e9-975f-47df-aebb-829bc6dd33ef"],
 "."
}], "Text",ExpressionUUID->"7fc1f3f2-e394-423a-853a-851c4d33312d"],

Cell[TextData[{
 "The ",
 StyleBox["bra",
  FontWeight->"Bold"],
 " ",
 Cell[BoxData[
  TemplateBox[{
    StyleBox["\[Psi]", "TI"]},
   "Bra"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "f9888b2a-170b-4e00-93da-9d28bfc8ea51"],
 " is the conjugate-transpose of the ket, obtained with the ",
 Cell[BoxData["\"\<Dagger\>\""], "InlineFormula",ExpressionUUID->
  "1253bb55-da99-4aa0-b655-7c3b703be4ca"],
 " property. The inner product ",
 Cell[BoxData[
  TemplateBox[{
    StyleBox["\[Phi]", "TI"], 
    StyleBox["\[Psi]", "TI"]},
   "BraKet"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "72f90d3e-fa08-40ea-a710-a48fcb240a8f"],
 " is then a bra applied to a ket, and its numerical value is the ",
 Cell[BoxData["\"\<Scalar\>\""], "InlineFormula",ExpressionUUID->
  "e09d4f21-de6e-4705-b7ed-69df62a506e6"],
 " of the resulting zero-qudit object. Compute ",
 Cell[BoxData[
  TemplateBox[{"0", "+"},
   "BraKet"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "1d6b03da-8a3c-419e-8f1c-b2d675291cd6"],
 ":"
}], "Text",ExpressionUUID->"99141376-ea9d-4669-ae45-f5a243e8cd82"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(", 
   RowBox[{
    RowBox[{"zero", "[", "\"\<Dagger\>\"", "]"}], " ", "@", " ", "plus"}], 
   ")"}], "[", "\"\<Scalar\>\"", "]"}]], "Input",
 CellLabel->"In[6]:= ",ExpressionUUID->"356ceede-a75e-4853-936e-c36ed72a017a"],

Cell[BoxData[
 FractionBox["1", 
  SqrtBox["2"]]], "Output",
 CellLabel->"Out[6]= ",ExpressionUUID->"2110383e-9084-4c9e-962b-6bfae6351328"]
}, Open  ]],

Cell[TextData[{
 "The answer is ",
 Cell[BoxData[
  RowBox[{"1", "/", 
   SqrtBox["2"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "e52be33d-fab7-49e7-bc3f-e9fda5051f1d"],
 ", the overlap of ",
 Cell[BoxData[
  TemplateBox[{"0"},
   "Ket"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "744f5a09-29ef-4fb2-8627-c8d22ed3c5d9"],
 " with ",
 Cell[BoxData[
  TemplateBox[{"+"},
   "Ket"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "accf8540-860b-4d6f-82e2-249d4c819b1c"],
 ". This single idiom, ",
 Cell[BoxData[
  RowBox[{
   RowBox[{"(", 
    RowBox[{
     RowBox[{"bra", "[", "\"\<Dagger\>\"", "]"}], " ", "@", " ", "ket"}], 
    ")"}], "[", "\"\<Scalar\>\"", "]"}]], "InlineFormula",ExpressionUUID->
  "6a6ea7bf-a3a7-4170-aaa7-598564713980"],
 ", is how we extract every amplitude, overlap, and expectation value below."
}], "Text",ExpressionUUID->"144570c9-50d5-418d-9a77-e66d30a3935d"],

Cell[TextData[{
 "An ",
 StyleBox["observable",
  FontWeight->"Bold"],
 " is a Hermitian operator. The Pauli operators ",
 Cell[BoxData[
  StyleBox["X", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "c9a63db6-b040-47db-bc71-ddee6c1b0e1a"],
 ", ",
 Cell[BoxData[
  StyleBox["Y", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "36ec9db7-8d9d-432d-a4f7-4d3b7aa03222"],
 ", ",
 Cell[BoxData[
  StyleBox["Z", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "eee255e3-1dc3-416e-a7ae-3e022d2264ea"],
 " are the basic qubit observables. Look at ",
 Cell[BoxData[
  StyleBox["Z", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "a6319a6d-260e-477e-a002-5696589b6ec0"],
 " and confirm it is Hermitian with real eigenvalues ",
 Cell[BoxData[
  RowBox[{"\[PlusMinus]", "1"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "af56f333-ac16-42b2-8d8d-8092a95399cb"],
 ":"
}], "Text",ExpressionUUID->"7705c1f2-11c9-45f6-9934-fb729413a9f4"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"Z", " ", "=", " ", 
   RowBox[{"QuantumOperator", "[", "\"\<Z\>\"", "]"}]}], ";"}], "\n", 
 RowBox[{"{", 
  RowBox[{
   RowBox[{"Z", "[", "\"\<HermitianQ\>\"", "]"}], ",", " ", 
   RowBox[{"Z", "[", "\"\<Eigenvalues\>\"", "]"}]}], "}"}]}], "Input",
 CellLabel->"In[7]:= ",ExpressionUUID->"c3d818c1-5fe3-461e-88b1-d96edbedb692"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"True", ",", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"-", "1"}], ",", "1"}], "}"}]}], "}"}]], "Output",
 CellLabel->"Out[7]= ",ExpressionUUID->"3105eb6d-18aa-40bc-9bcf-a238b717e697"]
}, Open  ]],

Cell[TextData[{
 "This returns ",
 Cell[BoxData[
  RowBox[{"{", 
   RowBox[{"True", ",", " ", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"-", "1"}], ",", " ", "1"}], "}"}]}], "}"}]], "InlineFormula",
  ExpressionUUID->"86d1948e-1c5d-4542-a807-259a4dee801e"],
 ": we ask the operator whether it is Hermitian rather than pulling out its \
matrix and testing by hand. The eigenvalues are the possible measurement \
outcomes; the eigenvectors ",
 Cell[BoxData[
  RowBox[{
   TemplateBox[{"0"},
    "Ket"], 
   RowBox[{",", "\[ThinSpace]"}], 
   TemplateBox[{"1"},
    "Ket"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "5ada0f06-1491-4388-8939-14ad8dbc10d9"],
 " are the states that yield those outcomes with certainty. Hermiticity is \
exactly the guarantee that the outcomes are real."
}], "Text",ExpressionUUID->"c7f5a246-1b68-4a00-9bc6-292f4a6a41fc"],

Cell[TextData[{
 "The ",
 StyleBox["expectation value",
  FontWeight->"Bold"],
 " ",
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     StyleBox["\[Psi]", "TI"]},
    "Bra"], 
   StyleBox["A", "TI"], 
   TemplateBox[{
     StyleBox["\[Psi]", "TI"]},
    "Ket"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "78457611-e730-4c44-8954-1b3d1f567d88"],
 " is the mean outcome of measuring ",
 Cell[BoxData[
  StyleBox["A", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "7801ffac-e74c-45b6-805a-45c002cfe5d0"],
 " in state ",
 Cell[BoxData[
  TemplateBox[{
    StyleBox["\[Psi]", "TI"]},
   "Ket"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "1b4ff921-c40a-4f70-95d9-f752626f4fac"],
 ". There are several equivalent ways to compute it, and seeing them agree \
builds confidence. Compute ",
 Cell[BoxData[
  RowBox[{
   StyleBox["\[LeftAngleBracket]",
    SpanMaxSize->1], 
   RowBox[{
    RowBox[{"+", "\[LeftBracketingBar]", 
     StyleBox["Z", "TI"], "\[VeryThinSpace]", "\[RightBracketingBar]"}], 
    "+"}], 
   StyleBox["\[RightAngleBracket]",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "c6eaaf98-4c7c-474e-b0f1-17eeb54dfd98"],
 " three ways, by a trace, by a bra-operator-ket sandwich, and by an explicit \
measurement:"
}], "Text",ExpressionUUID->"ba662464-9ca1-4d5c-a491-b4c38a692384"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"{", "\n", "  ", 
   RowBox[{
    RowBox[{"Tr", "[", 
     RowBox[{
      RowBox[{"Z", "[", "\"\<Matrix\>\"", "]"}], " ", ".", " ", 
      RowBox[{"plus", "[", "\"\<DensityMatrix\>\"", "]"}]}], "]"}], ",", "\n",
     "  ", 
    RowBox[{
     RowBox[{"(", 
      RowBox[{
       RowBox[{"plus", "[", "\"\<Dagger\>\"", "]"}], " ", "@", " ", 
       RowBox[{"Z", " ", "@", " ", "plus"}]}], ")"}], "[", "\"\<Scalar\>\"", 
     "]"}], ",", "\n", "  ", 
    RowBox[{
     RowBox[{
      RowBox[{"QuantumMeasurementOperator", "[", "Z", "]"}], "[", "plus", 
      "]"}], "[", "\"\<Mean\>\"", "]"}]}], "\n", "}"}], " ", "//", " ", 
  "Chop"}]], "Input",
 CellLabel->"In[8]:= ",ExpressionUUID->"ffeaa22d-9ac3-49d5-a355-0ecca3868f18"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"0", ",", "0", ",", "0"}], "}"}]], "Output",
 CellLabel->"Out[8]= ",ExpressionUUID->"186c0c37-4c7a-4ee8-8a52-93a1a338c203"]
}, Open  ]],

Cell[TextData[{
 "All three return ",
 Cell[BoxData[
 "0"], "InlineFormula",ExpressionUUID->"adc1855a-13d3-4d4f-8d03-541805770310"],
 ". In the state ",
 Cell[BoxData[
  TemplateBox[{"+"},
   "Ket"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "cbe5c059-e828-4fdf-b02d-b40dbd6a8c38"],
 ", ",
 Cell[BoxData[
  StyleBox["Z", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "1b7e0004-92e5-4a68-9adf-225b95e9bcca"],
 " is equally likely to give ",
 Cell[BoxData[
  RowBox[{"+", "1"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "304f4f45-7db1-4707-b0ac-efd4bf52a937"],
 " or ",
 Cell[BoxData[
  RowBox[{"-", "1"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "64171bc9-a9c1-4bb7-804c-ff9cdd19c453"],
 ", so its mean is zero."
}], "Text",ExpressionUUID->"a71c035e-f663-4ec2-9bae-dd9672079645"],

Cell[TextData[{
 "Measurement is more than its mean: it is a probability distribution over \
eigenvalues. Apply a ",
 Cell[BoxData[
  StyleBox["Z", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "2ab81aed-50bb-4baf-9421-3a9487cc7932"],
 " measurement to ",
 Cell[BoxData[
  TemplateBox[{"+"},
   "Ket"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "16d7a499-b1b0-4608-b10d-8f8291c9fedb"],
 " and read the outcome probabilities:"
}], "Text",ExpressionUUID->"49589af8-ad64-47cd-93be-9cc57faf6d8a"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"qm", " ", "=", " ", 
   RowBox[{
    RowBox[{"QuantumMeasurementOperator", "[", "\"\<Z\>\"", "]"}], "[", 
    "plus", "]"}]}], ";"}], "\n", 
 RowBox[{"Values", "[", 
  RowBox[{"qm", "[", "\"\<Probabilities\>\"", "]"}], "]"}]}], "Input",
 CellLabel->"In[9]:= ",ExpressionUUID->"7fb399b8-6b5c-43bc-8840-3ff0fb6a4f4e"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   FractionBox["1", "2"], ",", 
   FractionBox["1", "2"]}], "}"}]], "Output",
 CellLabel->"Out[9]= ",ExpressionUUID->"7dcfab25-b882-4400-989c-268db0bed358"]
}, Open  ]],

Cell[TextData[{
 "The result is ",
 Cell[BoxData[
  RowBox[{
   RowBox[{"{", "1", "/", "2"}], 
   RowBox[{",", "\[ThinSpace]"}], 
   RowBox[{"1", "/", "2", "}"}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "3cba7688-4365-457d-802f-c41722f99cfa"],
 ". This is the Born rule in action: the probability of an outcome is the \
squared overlap of the state with the corresponding eigenvector."
}], "Text",ExpressionUUID->"4369e3c8-19b7-496a-aeb7-ccd98764fc80"],

Cell[TextData[{
 "The ",
 StyleBox["uncertainty principle",
  FontWeight->"Bold"],
 " quantifies how unsharp two incompatible observables must be. The Robertson \
relation says ",
 Cell[BoxData[
  RowBox[{"\[CapitalDelta]", 
   StyleBox["A", "TI"], "\[CapitalDelta]", 
   StyleBox["B", "TI"], "\[GreaterEqual]", 
   FractionBox["1", "2"], "\[LeftBracketingBar]", 
   StyleBox["\[LeftAngleBracket]",
    SpanMaxSize->1], 
   StyleBox["[",
    SpanMaxSize->1], 
   StyleBox["A", "TI"], 
   RowBox[{",", "\[ThinSpace]"}], 
   StyleBox["B", "TI"], 
   StyleBox["]",
    SpanMaxSize->1], 
   StyleBox["\[RightAngleBracket]",
    SpanMaxSize->1], "\[RightBracketingBar]"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "ade6c3c3-de32-4ab1-b3e9-5e2455d3ed49"],
 ", where ",
 Cell[BoxData[
  RowBox[{"\[CapitalDelta]", 
   StyleBox["A", "TI"], "=", 
   SqrtBox[
    RowBox[{
     StyleBox["\[LeftAngleBracket]",
      SpanMaxSize->1], 
     SuperscriptBox[
      StyleBox["A", "TI"], "2"], 
     StyleBox["\[RightAngleBracket]",
      SpanMaxSize->1], "-", 
     SuperscriptBox[
      RowBox[{
       StyleBox["\[LeftAngleBracket]",
        SpanMaxSize->1], 
       StyleBox["A", "TI"], "\[VeryThinSpace]", 
       StyleBox["\[RightAngleBracket]",
        SpanMaxSize->1]}], "2"]}]]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "16b2670f-1306-4853-9902-281f2de5de22"],
 ". We do not hand-roll the variance: ",
 Cell[BoxData[
  RowBox[{"OperatorVariance", "[", 
   RowBox[{"state", ",", " ", "op"}], "]"}]], "InlineFormula",ExpressionUUID->
  "b16ea337-a46d-4c7f-8d4c-ff53fed5df78"],
 " is exactly ",
 Cell[BoxData[
  RowBox[{
   StyleBox["\[LeftAngleBracket]",
    SpanMaxSize->1], 
   SuperscriptBox[
    StyleBox["O", "TI"], "2"], 
   StyleBox["\[RightAngleBracket]",
    SpanMaxSize->1], "-", 
   SuperscriptBox[
    RowBox[{
     StyleBox["\[LeftAngleBracket]",
      SpanMaxSize->1], 
     StyleBox["O", "TI"], "\[VeryThinSpace]", 
     StyleBox["\[RightAngleBracket]",
      SpanMaxSize->1]}], "2"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "48877957-1ab3-4fb7-880f-9d6f17fc3be6"],
 ", and ",
 Cell[BoxData[
  RowBox[{"Commutator", "[", 
   RowBox[{"A", ",", " ", "B"}], "]"}]], "InlineFormula",ExpressionUUID->
  "50dba5dc-6941-4fee-8c1c-e36f22661d9a"],
 " is the built-in ",
 Cell[BoxData[
  RowBox[{
   StyleBox["A", "TI"], 
   StyleBox["B", "TI"], "-", 
   StyleBox["B", "TI"], 
   StyleBox["A", "TI"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "46f16ce9-2e44-4b2b-8b50-4020ce880a40"],
 ". Check the relation for ",
 Cell[BoxData[
  StyleBox["X", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "31aa7453-cfa9-4489-8b66-6d709c68cef2"],
 " and ",
 Cell[BoxData[
  StyleBox["Y", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "31fb8e15-c111-4940-aa83-bb29a312afed"],
 " on a generic complex state, one tilted off all three axes so the bound \
actually bites:"
}], "Text",ExpressionUUID->"ee731623-9859-4e64-9f90-e1052b482cfe"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"st", " ", "=", " ", 
   RowBox[{"QuantumState", "[", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"Cos", "[", 
       RowBox[{"Pi", "/", "8"}], "]"}], ",", " ", 
      RowBox[{
       RowBox[{"Exp", "[", 
        RowBox[{"I", " ", 
         RowBox[{"Pi", "/", "5"}]}], "]"}], " ", 
       RowBox[{"Sin", "[", 
        RowBox[{"Pi", "/", "8"}], "]"}]}]}], "}"}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"X", " ", "=", " ", 
   RowBox[{"QuantumOperator", "[", "\"\<X\>\"", "]"}]}], ";", " ", 
  RowBox[{"Y", " ", "=", " ", 
   RowBox[{"QuantumOperator", "[", "\"\<Y\>\"", "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{"Sqrt", "[", 
      RowBox[{
       RowBox[{"OperatorVariance", "[", 
        RowBox[{"st", ",", " ", "X"}], "]"}], " ", 
       RowBox[{"OperatorVariance", "[", 
        RowBox[{"st", ",", " ", "Y"}], "]"}]}], "]"}], ",", "\n", " ", 
     RowBox[{
      RowBox[{"Abs", "[", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{
          RowBox[{"st", "[", "\"\<Dagger\>\"", "]"}], " ", "@", " ", 
          RowBox[{
           RowBox[{"Commutator", "[", 
            RowBox[{"X", ",", " ", "Y"}], "]"}], " ", "@", " ", "st"}]}], 
         ")"}], "[", "\"\<Scalar\>\"", "]"}], "]"}], "/", "2"}]}], "}"}], " ",
    "//", " ", "N"}], " ", "//", " ", "Chop"}]}], "Input",
 CellLabel->
  "In[10]:= ",ExpressionUUID->"f2f24c1c-ad60-429f-a4c8-84c5e9711e0f"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"0.7460105770525087`", ",", "0.7071067811865475`"}], 
  "}"}]], "Output",
 CellLabel->
  "Out[10]= ",ExpressionUUID->"45da1c82-8818-4b30-b093-94caf6555be2"]
}, Open  ]],

Cell[TextData[{
 "This returns ",
 Cell[BoxData[
  RowBox[{"{", 
   RowBox[{"0.746", ",", " ", "0.707"}], "}"}]], "InlineFormula",
  ExpressionUUID->"62551416-5ca3-4b14-96e9-64239245dae5"],
 ": the product of spreads exceeds the bound ",
 Cell[BoxData[
  RowBox[{
   FractionBox["1", "2"], "\[LeftBracketingBar]", 
   StyleBox["\[LeftAngleBracket]",
    SpanMaxSize->1], 
   StyleBox["[",
    SpanMaxSize->1], 
   StyleBox["X", "TI"], 
   RowBox[{",", "\[ThinSpace]"}], 
   StyleBox["Y", "TI"], 
   StyleBox["]",
    SpanMaxSize->1], 
   StyleBox["\[RightAngleBracket]",
    SpanMaxSize->1], "\[RightBracketingBar]", "=", "\[LeftBracketingBar]", 
   StyleBox["\[LeftAngleBracket]",
    SpanMaxSize->1], 
   StyleBox["Z", "TI"], 
   StyleBox["\[RightAngleBracket]",
    SpanMaxSize->1], "\[RightBracketingBar]"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "8608c965-ef29-4765-963a-dfd99df1bf3b"],
 ", and the inequality is strict. For a pure qubit state the exact relation \
is ",
 Cell[BoxData[
  RowBox[{"\[CapitalDelta]", 
   SuperscriptBox[
    StyleBox["X", "TI"], "2"], " ", "\[CapitalDelta]", 
   SuperscriptBox[
    StyleBox["Y", "TI"], "2"], "=", 
   SuperscriptBox[
    RowBox[{
     StyleBox["\[LeftAngleBracket]",
      SpanMaxSize->1], 
     StyleBox["Z", "TI"], "\[VeryThinSpace]", 
     StyleBox["\[RightAngleBracket]",
      SpanMaxSize->1]}], "2"], "+", 
   SuperscriptBox[
    RowBox[{
     StyleBox["\[LeftAngleBracket]",
      SpanMaxSize->1], 
     StyleBox["X", "TI"], "\[VeryThinSpace]", 
     StyleBox["\[RightAngleBracket]",
      SpanMaxSize->1]}], "2"], 
   SuperscriptBox[
    RowBox[{
     StyleBox["\[LeftAngleBracket]",
      SpanMaxSize->1], 
     StyleBox["Y", "TI"], "\[VeryThinSpace]", 
     StyleBox["\[RightAngleBracket]",
      SpanMaxSize->1]}], "2"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "5cd747e0-ae43-4e89-ba4c-de6189933df3"],
 ", so the bound is reached only when one of ",
 Cell[BoxData[
  RowBox[{
   RowBox[{
    StyleBox["\[LeftAngleBracket]",
     SpanMaxSize->1], 
    StyleBox["X", "TI"], "\[VeryThinSpace]", 
    StyleBox["\[RightAngleBracket]",
     SpanMaxSize->1]}], 
   RowBox[{",", "\[ThinSpace]"}], 
   RowBox[{
    StyleBox["\[LeftAngleBracket]",
     SpanMaxSize->1], 
    StyleBox["Y", "TI"], "\[VeryThinSpace]", 
    StyleBox["\[RightAngleBracket]",
     SpanMaxSize->1]}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "3a83f84f-14f0-4b52-a6d4-997617123ecb"],
 " vanishes. Here neither does, so the state cannot even saturate the limit. \
The inequality is never violated, which is the whole content of the \
uncertainty principle: you cannot make both spreads small when the \
observables fail to commute. (Part 5 will show the oscillator's ground state \
hitting the bound exactly.)"
}], "Text",ExpressionUUID->"97a79a75-dfd3-4d47-9307-85421680b74d"],

Cell["Before moving on, the key results so far, all computed:", "Text",ExpressionUUID->"4be645da-5fb6-4dbc-8534-cc23d53361a7"],

Cell[TextData[{
 "A pure qubit state is a unit vector; the bra is its conjugate transpose, \
obtained with ",
 Cell[BoxData["\"\<Dagger\>\""], "InlineFormula",ExpressionUUID->
  "46cad535-b914-4357-982c-91e2e7525ebd"],
 "."
}], "Item",ExpressionUUID->"52951560-34e6-422d-8eab-1aa076f3d0ef"],

Cell[TextData[{
 "Inner products, amplitudes, and expectation values all reduce to ",
 Cell[BoxData[
  RowBox[{
   RowBox[{"(", 
    RowBox[{"bra", " ", "@", " ", "ket"}], ")"}], "[", "\"\<Scalar\>\"", 
   "]"}]], "InlineFormula",ExpressionUUID->
  "01b36222-35e5-403c-852f-d418647bffdb"],
 "."
}], "Item",ExpressionUUID->"c424c63c-178b-48cb-86eb-24a61ec2dcc8"],

Cell["\<\
Observables are Hermitian operators; their eigenvalues are the outcomes and \
are real.\
\>", "Item",ExpressionUUID->"6ddd394c-8df7-4034-9b8a-a735c038cf84"],

Cell["\<\
Measurement returns a Born-rule probability distribution, not just a number.\
\>", "Item",ExpressionUUID->"7dffd0dd-b703-4e00-9291-7fcde7a6e1d4"],

Cell["\<\
Non-commuting observables obey the Robertson uncertainty bound.\
\>", "Item",ExpressionUUID->"9adfb8d3-a193-4c73-9a59-7decdd2b8718"],

Cell["Part 3 \[LongDash] Dynamics and the three pictures", "Section",ExpressionUUID->"46d2c677-e010-462a-b692-10a3075ae2d2"],

Cell[TextData[{
 StyleBox["Course map:",
  FontWeight->"Bold"],
 " Week 3 (postulates; Schr\[ODoubleDot]dinger, Heisenberg, and interaction \
pictures)."
}], "Text",
 CellFrame->{{3, 0}, {0, 0}},
 CellMargins->{{40, 10}, {7, 7}},
 CellFrameMargins->10,
 CellFrameColor->GrayLevel[0.55],
 FontSlant->"Italic",
 FontColor->LightDarkSwitched[
   GrayLevel[0.45], 
   GrayLevel[0.65]],
 Background->LightDarkSwitched[
   GrayLevel[0.96], 
   GrayLevel[0.2]],ExpressionUUID->"6bbfdce3-8e5a-4e56-892c-80ab8581c959"],

Cell[TextData[{
 "A closed quantum system evolves by the Schr\[ODoubleDot]dinger equation ",
 Cell[BoxData[
  RowBox[{
   RowBox[{
    StyleBox["i", "TI"], 
    RowBox[{
     SubscriptBox["\[PartialD]", 
      StyleBox["t", "TI"]], 
     TemplateBox[{
       StyleBox["\[Psi]", "TI"]},
      "Ket"]}]}], "=", 
   RowBox[{
    StyleBox["H", "TI"], 
    TemplateBox[{
      StyleBox["\[Psi]", "TI"]},
     "Ket"]}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "ce6a9d62-a172-463d-845a-4235f32906db"],
 ", whose solution is ",
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     RowBox[{
       StyleBox["\[Psi]", "TI"], 
       StyleBox["(", SpanMaxSize -> 1], 
       StyleBox["t", "TI"], 
       StyleBox[")", SpanMaxSize -> 1]}]},
    "Ket"], "=", 
   RowBox[{
    SuperscriptBox[
     StyleBox["e", "TI"], 
     RowBox[{"-", 
      StyleBox["i", "TI"], 
      StyleBox["H", "TI"], 
      StyleBox["t", "TI"]}]], 
    TemplateBox[{
      RowBox[{
        StyleBox["\[Psi]", "TI"], 
        StyleBox["(", SpanMaxSize -> 1], "0", 
        StyleBox[")", SpanMaxSize -> 1]}]},
     "Ket"]}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "51157b34-c95f-49fd-8b35-ac972cc600bd"],
 ". ",
 Cell[BoxData[
 "QuantumEvolve"], "InlineFormula",ExpressionUUID->
  "efc50efe-125d-42e0-8b5f-814bf843f2ba"],
 " solves this for us. Called with no time range, it returns a ",
 StyleBox["closed-form symbolic",
  FontWeight->"Bold"],
 " state, which is the cleanest thing to learn from. Evolve ",
 Cell[BoxData[
  TemplateBox[{"+"},
   "Ket"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "8ddcbc56-b196-4856-8aeb-ba9bcaca566f"],
 " under ",
 Cell[BoxData[
  RowBox[{
   StyleBox["H", "TI"], "=", 
   StyleBox["Z", "TI"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "15eb6c95-939e-4bfe-a467-51a6a57cfdf3"],
 " (free precession of a spin in a field along ",
 Cell[BoxData[
  StyleBox["z", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "1c885b69-52d2-4577-a0c4-7731412083d1"],
 "):"
}], "Text",ExpressionUUID->"deb6c8ea-a783-41f5-8ee2-a76ea9bb4274"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"sol", " ", "=", " ", 
   RowBox[{"QuantumEvolve", "[", 
    RowBox[{
     RowBox[{"QuantumOperator", "[", "\"\<Z\>\"", "]"}], ",", " ", 
     RowBox[{"QuantumState", "[", "\"\<+\>\"", "]"}]}], "]"}]}], 
  ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"sol", "[", "\"\<StateVector\>\"", "]"}], " ", "//", " ", 
   "Normal"}], " ", "//", " ", "Simplify"}]}], "Input",
 CellLabel->
  "In[11]:= ",ExpressionUUID->"0abbcd61-59d7-4e73-a30e-b07a7a8c6d75"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   FractionBox[
    SuperscriptBox["\[ExponentialE]", 
     RowBox[{
      RowBox[{"-", "\[ImaginaryI]"}], " ", "\[FormalT]"}]], 
    SqrtBox["2"]], ",", 
   FractionBox[
    SuperscriptBox["\[ExponentialE]", 
     RowBox[{"\[ImaginaryI]", " ", "\[FormalT]"}]], 
    SqrtBox["2"]]}], "}"}]], "Output",
 CellLabel->
  "Out[11]= ",ExpressionUUID->"a4f7541e-e47d-417b-b83b-47f93cf1c642"]
}, Open  ]],

Cell[TextData[{
 "The result is ",
 Cell[BoxData[
  RowBox[{
   RowBox[{
    RowBox[{"{", 
     SuperscriptBox[
      StyleBox["e", "TI"], 
      RowBox[{"-", 
       StyleBox["i", "TI"], 
       StyleBox["t", "TI"]}]], "/", 
     SqrtBox["2"]}], 
    RowBox[{",", "\[ThinSpace]"}], "\[ThickSpace]", 
    RowBox[{
     SuperscriptBox[
      StyleBox["e", "TI"], 
      StyleBox[
       RowBox[{"i", "t"}], "TI"]], "/", 
     SqrtBox["2"]}]}], "}"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "bc9573ee-2211-42c2-ba48-31ec559175ff"],
 ", with the framework using a formal time symbol. The two amplitudes acquire \
opposite phases, so the state rotates around the ",
 Cell[BoxData[
  StyleBox["z", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "7d50ba26-1725-471c-9040-40708bbb541f"],
 "-axis of the Bloch sphere at angular frequency ",
 Cell[BoxData["2"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "75de65e1-fa71-4ca5-8892-4ee097309f60"],
 ". This is Larmor precession, derived with one line."
}], "Text",ExpressionUUID->"8de7101c-aa68-46b0-85b9-642ab3c719fd"],

Cell[TextData[{
 "When a closed form is unavailable or unwanted, give ",
 Cell[BoxData[
 "QuantumEvolve"], "InlineFormula",ExpressionUUID->
  "da13051a-bce0-4275-aa7d-27befce98458"],
 " a numeric time range and it integrates the equation, returning a state you \
sample at any time with ",
 Cell[BoxData[
  RowBox[{"sol", "[", 
   RowBox[{"<|", 
    RowBox[{"t", " ", "->", " ", "value"}], "|>"}], "]"}]], "InlineFormula",
  ExpressionUUID->"fedd2ab4-3364-4b47-acae-49434cc2dd13"],
 ". We use that form in the next two parts."
}], "Text",ExpressionUUID->"24d0e77f-f1b0-4754-99d9-28cbf63a3bd6"],

Cell[TextData[{
 "The ",
 StyleBox["three pictures",
  FontWeight->"Bold"],
 " are three bookkeeping conventions for the same physics. In the Schr\
\[ODoubleDot]dinger picture the state moves and operators are fixed. In the \
Heisenberg picture the state is fixed and operators move as ",
 Cell[BoxData[
  RowBox[{
   StyleBox["A", "TI"], 
   StyleBox["(",
    SpanMaxSize->1], 
   StyleBox["t", "TI"], 
   StyleBox[")",
    SpanMaxSize->1], "=", 
   SuperscriptBox[
    StyleBox["e", "TI"], 
    StyleBox[
     RowBox[{"i", "H", "t"}], "TI"]], 
   StyleBox["A", "TI"], " ", 
   SuperscriptBox[
    StyleBox["e", "TI"], 
    RowBox[{"-", 
     StyleBox["i", "TI"], 
     StyleBox["H", "TI"], 
     StyleBox["t", "TI"]}]]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "ea07199e-3603-435d-95d4-ee8b450efbf1"],
 ". Expectation values, the only measurable quantities, are identical in \
both. ",
 Cell[BoxData[
 "QuantumEvolve"], "InlineFormula",ExpressionUUID->
  "113a4883-4cc7-4914-9ef0-ef001a6d8c43"],
 " handles either: pass it a state and it moves the state; pass it an \
observable (with an empty Lindblad list ",
 Cell[BoxData[
  RowBox[{"{", "}"}]], "InlineFormula",ExpressionUUID->
  "4861e5ac-e127-4513-914e-eb3a4458f898"],
 ") and it returns the Heisenberg-evolved operator. Compute ",
 Cell[BoxData[
  RowBox[{
   StyleBox["\[LeftAngleBracket]",
    SpanMaxSize->1], 
   RowBox[{
    StyleBox["X", "TI"], 
    StyleBox["(",
     SpanMaxSize->1], 
    StyleBox["t", "TI"], 
    StyleBox[")",
     SpanMaxSize->1]}], 
   StyleBox["\[RightAngleBracket]",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "8c4fe7e4-6788-4df0-a895-3fd961f9bf02"],
 " under ",
 Cell[BoxData[
  RowBox[{
   StyleBox["H", "TI"], "=", 
   StyleBox["Z", "TI"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "2f294055-5318-4379-94eb-232395d96828"],
 " both ways:"
}], "Text",ExpressionUUID->"21fd55af-b46d-4483-ad29-3bf37ac1130b"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"H", " ", "=", " ", 
   RowBox[{"QuantumOperator", "[", "\"\<Z\>\"", "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"schrod", " ", "=", " ", 
   RowBox[{"QuantumEvolve", "[", 
    RowBox[{"H", ",", " ", 
     RowBox[{"QuantumState", "[", "\"\<+\>\"", "]"}]}], "]"}]}], 
  ";"}], "\n", 
 RowBox[{
  RowBox[{"xSchrodinger", " ", "=", " ", 
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{"(", 
       RowBox[{
        RowBox[{"schrod", "[", "\"\<Dagger\>\"", "]"}], " ", "@", " ", 
        RowBox[{
         RowBox[{"QuantumOperator", "[", "\"\<X\>\"", "]"}], " ", "@", " ", 
         "schrod"}]}], ")"}], "[", "\"\<Scalar\>\"", "]"}], " ", "//", " ", 
     "ComplexExpand"}], " ", "//", " ", "Simplify"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"Xt", " ", "=", " ", 
   RowBox[{"QuantumEvolve", "[", 
    RowBox[{"H", ",", " ", 
     RowBox[{"{", "}"}], ",", " ", 
     RowBox[{"QuantumOperator", "[", "\"\<X\>\"", "]"}]}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"xHeisenberg", " ", "=", " ", 
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{"(", 
       RowBox[{
        RowBox[{
         RowBox[{"QuantumState", "[", "\"\<+\>\"", "]"}], 
         "[", "\"\<Dagger\>\"", "]"}], " ", "@", " ", 
        RowBox[{"Xt", " ", "@", " ", 
         RowBox[{"QuantumState", "[", "\"\<+\>\"", "]"}]}]}], ")"}], 
      "[", "\"\<Scalar\>\"", "]"}], " ", "//", " ", "ComplexExpand"}], " ", "//",
     " ", "Simplify"}]}], ";"}], "\n", 
 RowBox[{"{", 
  RowBox[{"xSchrodinger", ",", " ", "xHeisenberg"}], "}"}]}], "Input",
 CellLabel->
  "In[12]:= ",ExpressionUUID->"8bcb1d48-a75c-437d-a973-bde712711ae0"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{"Cos", "[", 
    RowBox[{"2", " ", "\[FormalT]"}], "]"}], ",", 
   RowBox[{"Cos", "[", 
    RowBox[{"2", " ", "\[FormalT]"}], "]"}]}], "}"}]], "Output",
 CellLabel->
  "Out[12]= ",ExpressionUUID->"d2f16118-03a2-4e89-958c-612618f33cf2"]
}, Open  ]],

Cell[TextData[{
 "Both return ",
 Cell[BoxData[
  RowBox[{
   StyleBox["cos",
    FontSlant->"Plain"], "\[ThinSpace]", 
   StyleBox["(",
    SpanMaxSize->1], 
   RowBox[{"2", 
    StyleBox["t", "TI"]}], 
   StyleBox[")",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "fc9216eb-dd02-4570-aa6d-fe481acda4b6"],
 ": the expectation of ",
 Cell[BoxData[
  StyleBox["X", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "d8737168-7acb-4ebe-977e-70743c8172b5"],
 " oscillates as the state precesses, and the Schr\[ODoubleDot]dinger and \
Heisenberg computations agree identically. The interaction picture, \
introduced next for the driven qubit, is the same idea applied to the part of \
",
 Cell[BoxData[
  StyleBox["H", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "703abfdc-b5e1-4d19-b297-40337f9b3405"],
 " we already understand, leaving only the interesting interaction in the \
equations."
}], "Text",ExpressionUUID->"01aec77c-a525-4506-9827-9940bf17b527"],

Cell["Part 4 \[LongDash] The qubit and Rabi flopping (Lab 2)", "Section",ExpressionUUID->"bff78f23-21fe-4016-822e-7a8a5a5929ee"],

Cell[TextData[{
 StyleBox["Course map:",
  FontWeight->"Bold"],
 " Week 4 (two-level system driven by classical radiation, Pauli matrices, \
interaction picture, Rabi flopping, Bloch sphere). ",
 StyleBox["This is Lab 2.",
  FontWeight->"Bold"]
}], "Text",
 CellFrame->{{3, 0}, {0, 0}},
 CellMargins->{{40, 10}, {7, 7}},
 CellFrameMargins->10,
 CellFrameColor->GrayLevel[0.55],
 FontSlant->"Italic",
 FontColor->LightDarkSwitched[
   GrayLevel[0.45], 
   GrayLevel[0.65]],
 Background->LightDarkSwitched[
   GrayLevel[0.96], 
   GrayLevel[0.2]],ExpressionUUID->"82d653f6-79d7-49e5-a7b6-9bf382a69860"],

Cell[TextData[{
 "A two-level atom driven by a resonant classical field, viewed in the \
interaction picture, has the simple Hamiltonian ",
 Cell[BoxData[
  RowBox[{
   StyleBox["H", "TI"], "=", 
   StyleBox["(",
    SpanMaxSize->1], 
   RowBox[{"\[CapitalOmega]", "/", "2"}], 
   StyleBox[")",
    SpanMaxSize->1], " ", 
   StyleBox["X", "TI"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "f523663d-5cbc-49b5-8143-925c6db95c4c"],
 ", where ",
 Cell[BoxData["\[CapitalOmega]"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "ff527c3a-47fa-4062-b2a0-de253945a092"],
 " is the Rabi frequency set by the drive strength. Starting in the ground \
state ",
 Cell[BoxData[
  TemplateBox[{"0"},
   "Ket"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "6ff2a0ce-9ecc-43a1-a0ac-d943dba297d8"],
 ", the population sloshes coherently to the excited state and back. Evolve \
symbolically and read the amplitudes:"
}], "Text",ExpressionUUID->"d98715c3-abbb-445d-adc8-b179e859a4e4"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"\[CapitalOmega]", " ", "=", " ", "1"}], ";"}], "\n", 
 RowBox[{
  RowBox[{"Hdrive", " ", "=", " ", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{"\[CapitalOmega]", "/", "2"}], ")"}], " ", 
    RowBox[{"QuantumOperator", "[", "\"\<X\>\"", "]"}]}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"rabi", " ", "=", " ", 
   RowBox[{"QuantumEvolve", "[", 
    RowBox[{"Hdrive", ",", " ", 
     RowBox[{"QuantumState", "[", "\"\<0\>\"", "]"}]}], "]"}]}], 
  ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"rabi", "[", "\"\<StateVector\>\"", "]"}], " ", "//", " ", 
   "Normal"}], " ", "//", " ", "Simplify"}]}], "Input",
 CellLabel->
  "In[13]:= ",ExpressionUUID->"d8822f73-5eb9-4dcf-a3c2-dc699a8f9070"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{"Cos", "[", 
    FractionBox["\[FormalT]", "2"], "]"}], ",", 
   RowBox[{
    RowBox[{"-", "\[ImaginaryI]"}], " ", 
    RowBox[{"Sin", "[", 
     FractionBox["\[FormalT]", "2"], "]"}]}]}], "}"}]], "Output",
 CellLabel->
  "Out[13]= ",ExpressionUUID->"5bff6683-7c5c-42a1-a114-be6825f02467"]
}, Open  ]],

Cell[TextData[{
 "The state is ",
 Cell[BoxData[
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"{", 
      StyleBox["cos",
       FontSlant->"Plain"], "\[ThinSpace]", 
      StyleBox["(",
       SpanMaxSize->1], 
      RowBox[{
       StyleBox["t", "TI"], "/", "2"}], 
      StyleBox[")",
       SpanMaxSize->1]}], 
     RowBox[{",", "\[ThinSpace]"}]}], " ", "-", 
    RowBox[{
     StyleBox["i", "TI"], 
     StyleBox["sin",
      FontSlant->"Plain"], "\[ThinSpace]", 
     RowBox[{
      StyleBox["(",
       SpanMaxSize->1], 
      RowBox[{
       StyleBox["t", "TI"], "/", "2"}], 
      StyleBox[")",
       SpanMaxSize->1]}]}]}], "}"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "3a532acf-dbda-4fe2-9606-8d91f8b9b68c"],
 " (with ",
 Cell[BoxData[
  RowBox[{"\[CapitalOmega]", "=", "1"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "f0cecba2-cfb0-4b8e-acf5-4a6dacc72d6e"],
 "). The excited-state probability is therefore ",
 Cell[BoxData[
  RowBox[{
   SubscriptBox[
    StyleBox["P", "TI"], "1"], 
   StyleBox["(",
    SpanMaxSize->1], 
   StyleBox["t", "TI"], 
   StyleBox[")",
    SpanMaxSize->1], "=", 
   SuperscriptBox[
    StyleBox["sin",
     FontSlant->"Plain"], "2"], "\[ThinSpace]", 
   StyleBox["(",
    SpanMaxSize->1], 
   RowBox[{"\[CapitalOmega]", 
    StyleBox["t", "TI"], "/", "2"}], 
   StyleBox[")",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "1dd9c016-9b06-43d7-ae25-a760394738d7"],
 ": complete, periodic population transfer. A pulse of duration ",
 Cell[BoxData[
  RowBox[{
   StyleBox["t", "TI"], "=", "\[Pi]", "/", "\[CapitalOmega]"}]], 
  "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "867887c6-6b34-4c95-889d-adbc704df597"],
 " is a ",
 Cell[BoxData["\[Pi]"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "ca7e41f2-5bab-452c-b64a-60288ac51b61"],
 "-pulse, which flips ",
 Cell[BoxData[
  TemplateBox[{"0"},
   "Ket"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "19350145-2837-4201-b0b2-51936e20baa6"],
 " to ",
 Cell[BoxData[
  TemplateBox[{"1"},
   "Ket"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "a793c7db-ad8d-4615-800d-422739ced466"],
 "; a pulse of half that is a ",
 Cell[BoxData[
  RowBox[{"\[Pi]", "/", "2"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "4a3d2adb-c3db-4924-9279-1f92603c6eb0"],
 "-pulse, which builds an equal superposition. These are the elementary \
control operations of every qubit platform."
}], "Text",ExpressionUUID->"1793c289-d047-490f-af0d-422ce3d2788f"],

Cell[TextData[{
 "Real drives are never perfectly on resonance. With a detuning ",
 Cell[BoxData[
  StyleBox["\[Delta]", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "ba0045cf-f575-4f1c-86f2-209ef336853d"],
 " between the drive and the qubit, the interaction-picture Hamiltonian gains \
a ",
 Cell[BoxData[
  StyleBox["z", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "b6e1f2ff-2944-4a4a-a903-dc758002b840"],
 "-term: ",
 Cell[BoxData[
  RowBox[{
   StyleBox["H", "TI"], "=", 
   StyleBox["(",
    SpanMaxSize->1], 
   RowBox[{"\[CapitalOmega]", "/", "2"}], 
   StyleBox[")",
    SpanMaxSize->1], 
   StyleBox["X", "TI"], "+", 
   StyleBox["(",
    SpanMaxSize->1], 
   RowBox[{
    StyleBox["\[Delta]", "TI"], "/", "2"}], 
   StyleBox[")",
    SpanMaxSize->1], 
   StyleBox["Z", "TI"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "7ab93c95-5ae1-4d51-a407-26edc8d804ab"],
 ". Evolve and extract the excited-state probability as a function of time \
and detuning:"
}], "Text",ExpressionUUID->"3ddc19f5-eb10-4cba-ab8c-da51b8430085"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"Hdet", " ", "=", " ", 
   RowBox[{
    RowBox[{
     RowBox[{"(", 
      RowBox[{"1", "/", "2"}], ")"}], " ", 
     RowBox[{"QuantumOperator", "[", "\"\<X\>\"", "]"}]}], " ", "+", " ", 
    RowBox[{
     RowBox[{"(", 
      RowBox[{"\[Delta]", "/", "2"}], ")"}], " ", 
     RowBox[{"QuantumOperator", "[", "\"\<Z\>\"", "]"}]}]}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"rabiDet", " ", "=", " ", 
   RowBox[{"QuantumEvolve", "[", 
    RowBox[{"Hdet", ",", " ", 
     RowBox[{"QuantumState", "[", "\"\<0\>\"", "]"}]}], "]"}]}], 
  ";"}], "\n", 
 RowBox[{
  RowBox[{"sv", " ", "=", " ", 
   RowBox[{
    RowBox[{"rabiDet", "[", "\"\<StateVector\>\"", "]"}], " ", "//", " ", 
    "Normal"}]}], ";"}], "\n", 
 RowBox[{"FullSimplify", "[", 
  RowBox[{
   RowBox[{
    RowBox[{"Abs", "[", 
     RowBox[{"sv", "[", 
      RowBox[{"[", "2", "]"}], "]"}], "]"}], "^", "2"}], ",", " ", 
   RowBox[{"Assumptions", " ", "->", " ", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"\[Delta]", " ", "\[Element]", " ", "Reals"}], ",", " ", 
      RowBox[{"\[FormalT]", " ", "\[Element]", " ", "Reals"}]}], "}"}]}]}], 
  "]"}]}], "Input",
 CellLabel->
  "In[14]:= ",ExpressionUUID->"b9171522-548e-436d-a211-f5a1e8cadcfb"],

Cell[BoxData[
 FractionBox[
  SuperscriptBox[
   RowBox[{"Sin", "[", 
    RowBox[{
     FractionBox["1", "2"], " ", "\[FormalT]", " ", 
     SqrtBox[
      RowBox[{"1", "+", 
       SuperscriptBox["\[Delta]", "2"]}]]}], "]"}], "2"], 
  RowBox[{"1", "+", 
   SuperscriptBox["\[Delta]", "2"]}]]], "Output",
 CellLabel->
  "Out[14]= ",ExpressionUUID->"99fb9895-bcc1-4ab8-b82e-df5c1c2422d0"]
}, Open  ]],

Cell["The framework returns", "Text",ExpressionUUID->"31bcf11c-1d24-406f-998a-cb569d257a85"],

Cell[BoxData[
 PaneBox[
  RowBox[{
   RowBox[{
    SubscriptBox[
     StyleBox["P", "TI"], "1"], 
    StyleBox["(",
     SpanMaxSize->1], 
    StyleBox["t", "TI"], 
    StyleBox[")",
     SpanMaxSize->1], "=", 
    FractionBox[
     RowBox[{
      SuperscriptBox[
       StyleBox["sin",
        FontSlant->"Plain"], "2"], "\[ThinSpace]", "\[NegativeThinSpace]", 
      StyleBox["(",
       FontSize->1.2 Inherited], 
      FractionBox[
       StyleBox["t", "TI"], "2"], 
      SqrtBox[
       RowBox[{"1", "+", 
        SuperscriptBox[
         StyleBox["\[Delta]", "TI"], "2"]}]], 
      StyleBox[")",
       FontSize->1.2 Inherited]}], 
     RowBox[{"1", "+", 
      SuperscriptBox[
       StyleBox["\[Delta]", "TI"], "2"]}]]}], 
   RowBox[{",", "\[ThinSpace]"}]}],
  Alignment->Center,
  ImageSize->Full]], "DisplayFormula",ExpressionUUID->"262814ca-ed1f-46e3-\
b584-724bb2cb8ede"],

Cell[TextData[{
 "which (with ",
 Cell[BoxData[
  RowBox[{"\[CapitalOmega]", "=", "1"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "e680bb87-021a-46ca-8d0f-29cd64bd2ca8"],
 ", so ",
 Cell[BoxData[
  StyleBox["\[Delta]", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "f47eae3c-7f1e-4822-bca3-07c2ca08d40f"],
 " is measured in units of ",
 Cell[BoxData["\[CapitalOmega]"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "3ffdb851-4599-4a59-8f37-3572c4cfabe7"],
 ") is exactly the textbook detuned Rabi formula ",
 Cell[BoxData[
  RowBox[{
   SubscriptBox[
    StyleBox["P", "TI"], "1"], "=", 
   FractionBox[
    SuperscriptBox["\[CapitalOmega]", "2"], 
    SubsuperscriptBox["\[CapitalOmega]", 
     StyleBox["R", "TI"], "2"]], 
   SuperscriptBox[
    StyleBox["sin",
     FontSlant->"Plain"], "2"], "\[ThinSpace]", 
   StyleBox["(",
    SpanMaxSize->1], 
   RowBox[{
    SubscriptBox["\[CapitalOmega]", 
     StyleBox["R", "TI"]], 
    StyleBox["t", "TI"], "/", "2"}], 
   StyleBox[")",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "6d7e1f52-fc87-4134-b123-960c79292420"],
 " with generalized Rabi frequency ",
 Cell[BoxData[
  RowBox[{
   SubscriptBox["\[CapitalOmega]", 
    StyleBox["R", "TI"]], "=", 
   SqrtBox[
    RowBox[{
     SuperscriptBox["\[CapitalOmega]", "2"], "+", 
     SuperscriptBox[
      StyleBox["\[Delta]", "TI"], "2"]}]]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "07eca33a-1ceb-4de8-a362-4c4ded9fdccb"],
 ". Two things are visible at a glance: detuning ",
 StyleBox["speeds up",
  FontWeight->"Bold"],
 " the oscillation (",
 Cell[BoxData[
  RowBox[{
   SubscriptBox["\[CapitalOmega]", 
    StyleBox["R", "TI"]], ">", "\[CapitalOmega]"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "de347ae2-2994-40d9-9161-235a478d0bda"],
 ") and ",
 StyleBox["caps its amplitude",
  FontWeight->"Bold"],
 " below ",
 Cell[BoxData["1"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "e8817bd4-d055-4dbc-959c-8414c2973fd6"],
 " (",
 Cell[BoxData[
  RowBox[{
   SubsuperscriptBox[
    StyleBox["P", "TI"], "1", 
    StyleBox["max",
     FontSlant->"Plain"]], "=", "1", "/", 
   StyleBox["(",
    SpanMaxSize->1], 
   RowBox[{"1", "+", 
    SuperscriptBox[
     StyleBox["\[Delta]", "TI"], "2"]}], 
   StyleBox[")",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "abf4aa97-15ca-4ca3-9fd8-68dac4b5d6e1"],
 "). You can no longer fully invert the qubit once you are off resonance."
}], "Text",ExpressionUUID->"492fb1a5-44b0-40cc-ade1-61dcd662088a"],

Cell[TextData[{
 "The natural picture for a qubit is the ",
 StyleBox["Bloch sphere",
  FontWeight->"Bold"],
 ", where a pure state is a point on a unit sphere and a mixed state lies \
inside it. The Bloch vector is ",
 Cell[BoxData[
  RowBox[{
   RowBox[{
    StyleBox["\[LeftAngleBracket]",
     SpanMaxSize->1], 
    StyleBox["X", "TI"], "\[VeryThinSpace]", 
    StyleBox["\[RightAngleBracket]",
     SpanMaxSize->1]}], 
   RowBox[{",", "\[ThinSpace]"}], 
   RowBox[{
    StyleBox["\[LeftAngleBracket]",
     SpanMaxSize->1], 
    StyleBox["Y", "TI"], "\[VeryThinSpace]", 
    StyleBox["\[RightAngleBracket]",
     SpanMaxSize->1]}], 
   RowBox[{",", "\[ThinSpace]"}], 
   RowBox[{
    StyleBox["\[LeftAngleBracket]",
     SpanMaxSize->1], 
    StyleBox["Z", "TI"], "\[VeryThinSpace]", 
    StyleBox["\[RightAngleBracket]",
     SpanMaxSize->1]}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "afe4c939-1e6d-45f5-a6a5-cf8965560795"],
 ". Read it for a state at polar angle ",
 Cell[BoxData[
  RowBox[{"\[Pi]", "/", "3"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "6c9e5249-4dcf-4e1c-a386-082267b36989"],
 ":"
}], "Text",ExpressionUUID->"d363922c-f72e-4de5-b05d-5f3829a54ae2"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"QuantumState", "[", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"Cos", "[", 
      RowBox[{"Pi", "/", "6"}], "]"}], ",", " ", 
     RowBox[{"Sin", "[", 
      RowBox[{"Pi", "/", "6"}], "]"}]}], "}"}], "]"}], 
  "[", "\"\<BlochVector\>\"", "]"}]], "Input",
 CellLabel->
  "In[15]:= ",ExpressionUUID->"13ca6351-a9e9-48a7-a734-389a1d6c2129"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   FractionBox[
    SqrtBox["3"], "2"], ",", "0", ",", 
   FractionBox["1", "2"]}], "}"}]], "Output",
 CellLabel->
  "Out[15]= ",ExpressionUUID->"a7a9f38f-3194-4c2b-9103-a84dac863064"]
}, Open  ]],

Cell[TextData[{
 "The result is ",
 Cell[BoxData[
  RowBox[{
   RowBox[{
    RowBox[{"{", 
     SqrtBox["3"], "/", "2"}], 
    RowBox[{",", "\[ThinSpace]"}], " ", "0", 
    RowBox[{",", "\[ThinSpace]"}], " ", 
    RowBox[{"1", "/", "2"}]}], "}"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "c8c8cb1f-f063-4609-819d-0e8c2a14f2da"],
 ", a unit vector tilted ",
 Cell[BoxData[
  SuperscriptBox["60", "\[SmallCircle]"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "ed408bbc-3ca6-4bd1-9a14-c2bb4aef6bd2"],
 " from the north pole. The framework will also draw it for you with ",
 Cell[BoxData[
  RowBox[{
   RowBox[{"QuantumState", "[", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"Cos", "[", 
       RowBox[{"Pi", "/", "6"}], "]"}], ",", " ", 
      RowBox[{"Sin", "[", 
       RowBox[{"Pi", "/", "6"}], "]"}]}], "}"}], "]"}], 
   "[", "\"\<BlochPlot\>\"", "]"}]], "InlineFormula",ExpressionUUID->
  "74f6d630-5d65-4cf2-8be0-e2ef3a98c6e4"],
 ". Under the resonant drive of this section, this arrow simply rotates about \
the ",
 Cell[BoxData[
  StyleBox["X", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "472f9cab-eece-45c6-837f-e49d2291303d"],
 "-axis; Rabi flopping ",
 StyleBox["is", "TI"],
 " that rotation, seen in the populations."
}], "Text",ExpressionUUID->"7886dba0-3a64-4700-9186-bc0cc890f04a"],

Cell["Part 5 \[LongDash] The quantum harmonic oscillator", "Section",ExpressionUUID->"ed609f17-b736-4edc-bcec-638846e791b1"],

Cell[TextData[{
 StyleBox["Course map:",
  FontWeight->"Bold"],
 " Week 5 (classical analogy, operator method, number states, quantised \
light, Jaynes-Cummings interaction). Uses the second-quantization sub-package \
loaded in Setup."
}], "Text",
 CellFrame->{{3, 0}, {0, 0}},
 CellMargins->{{40, 10}, {7, 7}},
 CellFrameMargins->10,
 CellFrameColor->GrayLevel[0.55],
 FontSlant->"Italic",
 FontColor->LightDarkSwitched[
   GrayLevel[0.45], 
   GrayLevel[0.65]],
 Background->LightDarkSwitched[
   GrayLevel[0.96], 
   GrayLevel[0.2]],ExpressionUUID->"fe3bebc6-cf2f-4dbc-9071-7f592cf55305"],

Cell[TextData[{
 "The harmonic oscillator is the other system every quantum engineer must \
own, because it models a mode of the electromagnetic field in a cavity and a \
mechanical resonator alike. Its algebra is built from the lowering operator \
",
 Cell[BoxData[
  StyleBox["a", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "c3c4221b-8bd8-4fe1-a8b4-224ce4295e6e"],
 " and raising operator ",
 Cell[BoxData[
  SuperscriptBox[
   StyleBox["a", "TI"], "\[Dagger]"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "4b2e8bd8-2145-4ff0-b0d0-4a4eb457a434"],
 ", with ",
 Cell[BoxData[
  RowBox[{
   StyleBox["[",
    SpanMaxSize->1], 
   RowBox[{
    StyleBox["a", "TI"], 
    RowBox[{",", "\[ThinSpace]"}], 
    SuperscriptBox[
     StyleBox["a", "TI"], "\[Dagger]"]}], 
   StyleBox["]",
    SpanMaxSize->1], "=", "1"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "de060fd2-6d76-4dfc-bd32-ca1b998611cf"],
 ". In a truncated Fock space of size ",
 Cell[BoxData[
  StyleBox["N", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "dec9cd1e-6a0d-4717-9b4c-158a6b0a8317"],
 ", ",
 Cell[BoxData[
  RowBox[{"AnnihilationOperator", "[", "N", "]"}]], "InlineFormula",
  ExpressionUUID->"a89164da-0d59-4573-b5ae-226167e9e5ef"],
 " is the matrix with ",
 Cell[BoxData[
  SqrtBox[
   StyleBox["k", "TI"]]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "c86c2343-0cce-4de4-b6ea-a3050e97fbc2"],
 " on the first super-diagonal:"
}], "Text",ExpressionUUID->"5b25c7db-62ea-4bf2-b29c-f50b61bf42eb"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"a", " ", "=", " ", 
   RowBox[{"AnnihilationOperator", "[", "5", "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"a", "[", "\"\<Matrix\>\"", "]"}], " ", "//", " ", 
  "Normal"}]}], "Input",
 CellLabel->
  "In[16]:= ",ExpressionUUID->"e244ea0f-d676-48f7-813e-1ab4d2db3732"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"0", ",", "1", ",", "0", ",", "0", ",", "0"}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{"0", ",", "0", ",", 
     SqrtBox["2"], ",", "0", ",", "0"}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{"0", ",", "0", ",", "0", ",", 
     SqrtBox["3"], ",", "0"}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{"0", ",", "0", ",", "0", ",", "0", ",", "2"}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{"0", ",", "0", ",", "0", ",", "0", ",", "0"}], "}"}]}], 
  "}"}]], "Output",
 CellLabel->
  "Out[16]= ",ExpressionUUID->"5561d24d-69d4-413e-9b8f-3939c4d37d15"]
}, Open  ]],

Cell[TextData[{
 "The number operator ",
 Cell[BoxData[
  RowBox[{
   OverscriptBox[
    StyleBox["n", "TI"], "^"], "=", 
   SuperscriptBox[
    StyleBox["a", "TI"], "\[Dagger]"], 
   StyleBox["a", "TI"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "d5be2e51-ba24-4f63-9e80-55afc82f35d9"],
 " counts excitations, and its diagonal is ",
 Cell[BoxData[
  RowBox[{
   RowBox[{"0", ",", "1", ",", "2"}], 
   RowBox[{",", "\[ThinSpace]"}], "\[Ellipsis]"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "2c36395c-4d05-462f-8c76-c6b3ab38eebf"],
 ":"
}], "Text",ExpressionUUID->"b4ff2d8d-3e6d-4e16-be1d-4fb1f42e7787"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Diagonal", "[", 
  RowBox[{"Normal", "[", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{
      RowBox[{"a", "[", "\"\<Dagger\>\"", "]"}], " ", "@", " ", "a"}], ")"}], 
    "[", "\"\<Matrix\>\"", "]"}], "]"}], "]"}]], "Input",
 CellLabel->
  "In[17]:= ",ExpressionUUID->"11a732c9-dda4-444d-b70d-958e1f379856"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"0", ",", "1", ",", "2", ",", "3", ",", "4"}], "}"}]], "Output",
 CellLabel->
  "Out[17]= ",ExpressionUUID->"b40840a8-53ef-43a2-b772-c10761c256e0"]
}, Open  ]],

Cell[TextData[{
 "This returns ",
 Cell[BoxData[
  RowBox[{"{", 
   RowBox[{"0", ",", " ", "1", ",", " ", "2", ",", " ", "3", ",", " ", "4"}], 
   "}"}]], "InlineFormula",ExpressionUUID->
  "e7f77014-58f0-4352-a864-1934e00420e6"],
 ". The eigenstates of ",
 Cell[BoxData[
  OverscriptBox[
   StyleBox["n", "TI"], "^"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "941f7297-bc81-40dd-9b3e-359597b0ace4"],
 " are the ",
 StyleBox["number (Fock) states",
  FontWeight->"Bold"],
 " ",
 Cell[BoxData[
  TemplateBox[{
    StyleBox["n", "TI"]},
   "Ket"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "37e8e0ac-5fe5-4d74-9378-07344a7b847d"],
 ", the energy eigenstates of the oscillator. ",
 Cell[BoxData[
  RowBox[{"FockState", "[", 
   RowBox[{"2", ",", " ", "5"}], "]"}]], "InlineFormula",ExpressionUUID->
  "30ba3acb-25e7-4205-a9d0-dba92286dec6"],
 " is ",
 Cell[BoxData[
  TemplateBox[{"2"},
   "Ket"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "e43044b2-e149-4e06-b591-cfd3fe2f4f8c"],
 " in a five-level truncation:"
}], "Text",ExpressionUUID->"441d5913-f019-4b7b-96ea-0576a7b611db"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"FockState", "[", 
    RowBox[{"2", ",", " ", "5"}], "]"}], "[", "\"\<StateVector\>\"", "]"}], 
  " ", "//", " ", "Normal"}]], "Input",
 CellLabel->
  "In[18]:= ",ExpressionUUID->"f8a163a0-4963-4a2b-8a31-6a52f2531058"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"0", ",", "0", ",", "1", ",", "0", ",", "0"}], "}"}]], "Output",
 CellLabel->
  "Out[18]= ",ExpressionUUID->"fb5547da-1860-4ad0-8dab-56e5849fb049"]
}, Open  ]],

Cell[TextData[{
 "which is ",
 Cell[BoxData[
  RowBox[{
   RowBox[{"{", "0"}], 
   RowBox[{",", "\[ThinSpace]"}], 
   RowBox[{"0", ",", "1", ",", "0"}], 
   RowBox[{",", "\[ThinSpace]"}], 
   RowBox[{"0", "}"}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "45aeb1a9-1681-4d0e-91a5-a19740980563"],
 ", a single excitation count with definite energy."
}], "Text",ExpressionUUID->"d5362c42-34dc-4fdd-9d35-0d2cc6c41fe6"],

Cell[TextData[{
 "A ",
 StyleBox["coherent state",
  FontWeight->"Bold"],
 " ",
 Cell[BoxData[
  TemplateBox[{
    StyleBox["\[Alpha]", "TI"]},
   "Ket"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "5d157627-ca61-43e6-b21b-30a3b88d48d9"],
 " is the closest a quantum oscillator comes to a classical sinusoid: a \
displaced ground state with a Poisson distribution of photon numbers and mean \
occupation ",
 Cell[BoxData[
  SuperscriptBox[
   RowBox[{"\[LeftBracketingBar]", 
    StyleBox["\[Alpha]", "TI"], "\[VeryThinSpace]", "\[RightBracketingBar]"}],
    "2"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "c48b44ef-e947-4bed-ad74-bc703fc0aabb"],
 ". In the framework it is built parametrically in a formal amplitude; \
substitute a value to make it concrete:"
}], "Text",ExpressionUUID->"512f33b7-bdd8-48d7-be32-36e708331b94"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"coh", " ", "=", " ", 
   RowBox[{
    RowBox[{"CoherentState", "[", "8", "]"}], "[", 
    RowBox[{"<|", 
     RowBox[{"\[FormalAlpha]", " ", "->", " ", "1.0"}], "|>"}], "]"}]}], 
  ";"}], "\n", 
 RowBox[{
  RowBox[{"a8", " ", "=", " ", 
   RowBox[{"AnnihilationOperator", "[", "8", "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"(", 
   RowBox[{
    RowBox[{"coh", "[", "\"\<Dagger\>\"", "]"}], " ", "@", " ", 
    RowBox[{
     RowBox[{"(", 
      RowBox[{
       RowBox[{"a8", "[", "\"\<Dagger\>\"", "]"}], " ", "@", " ", "a8"}], 
      ")"}], " ", "@", " ", "coh"}]}], ")"}], "[", "\"\<Scalar\>\"", 
  "]"}]}], "Input",
 CellLabel->
  "In[19]:= ",ExpressionUUID->"9985e5c8-857f-40d1-bb28-4e0eb761b358"],

Cell[BoxData["0.99992700729927`"], "Output",
 CellLabel->
  "Out[19]= ",ExpressionUUID->"74d26f18-f76c-4e96-8cb6-0bd27505c897"]
}, Open  ]],

Cell[TextData[{
 "The mean photon number comes out as ",
 Cell[BoxData[
 "1.0"], "InlineFormula",ExpressionUUID->
  "7d208dc0-afcf-409d-8aef-9e4bed5499d3"],
 ", that is ",
 Cell[BoxData[
  SuperscriptBox[
   RowBox[{"\[LeftBracketingBar]", 
    StyleBox["\[Alpha]", "TI"], "\[VeryThinSpace]", "\[RightBracketingBar]"}],
    "2"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "cd2a2311-24a8-4821-852d-e80d70f16396"],
 " with ",
 Cell[BoxData[
  RowBox[{
   StyleBox["\[Alpha]", "TI"], "=", "1"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "a4ef9968-4ef4-4450-9a8c-9710a0527410"],
 ", confirming the Poisson mean."
}], "Text",ExpressionUUID->"9075dcf8-1fab-4805-80aa-7d9a6197d975"],

Cell[TextData[{
 "Whether light is ",
 StyleBox["classical or nonclassical",
  FontWeight->"Bold"],
 " is decided by photon statistics, not by mean intensity. The second-order \
coherence ",
 Cell[BoxData[
  RowBox[{
   SuperscriptBox[
    StyleBox["g", "TI"], 
    RowBox[{
     StyleBox["(",
      SpanMaxSize->1], "2", 
     StyleBox[")",
      SpanMaxSize->1]}]], 
   StyleBox["(",
    SpanMaxSize->1], "0", 
   StyleBox[")",
    SpanMaxSize->1], "=", 
   StyleBox["\[LeftAngleBracket]",
    SpanMaxSize->1], 
   RowBox[{
    SuperscriptBox[
     StyleBox["a", "TI"], "\[Dagger]"], 
    SuperscriptBox[
     StyleBox["a", "TI"], "\[Dagger]"], 
    StyleBox["a", "TI"], 
    StyleBox["a", "TI"]}], "\[VeryThinSpace]", 
   StyleBox["\[RightAngleBracket]",
    SpanMaxSize->1], "/", 
   SuperscriptBox[
    RowBox[{
     StyleBox["\[LeftAngleBracket]",
      SpanMaxSize->1], 
     RowBox[{
      SuperscriptBox[
       StyleBox["a", "TI"], "\[Dagger]"], 
      StyleBox["a", "TI"]}], "\[VeryThinSpace]", 
     StyleBox["\[RightAngleBracket]",
      SpanMaxSize->1]}], "2"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "093bc742-2ceb-466b-929b-5448930a6db6"],
 " measures how photons bunch: a coherent (laser-like) field has ",
 Cell[BoxData[
  RowBox[{
   SuperscriptBox[
    StyleBox["g", "TI"], 
    RowBox[{
     StyleBox["(",
      SpanMaxSize->1], "2", 
     StyleBox[")",
      SpanMaxSize->1]}]], 
   StyleBox["(",
    SpanMaxSize->1], "0", 
   StyleBox[")",
    SpanMaxSize->1], "=", "1"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "d87ff2e4-368e-41d1-98b5-d2650df1dc32"],
 ", while a single-photon state has ",
 Cell[BoxData[
  RowBox[{
   SuperscriptBox[
    StyleBox["g", "TI"], 
    RowBox[{
     StyleBox["(",
      SpanMaxSize->1], "2", 
     StyleBox[")",
      SpanMaxSize->1]}]], 
   StyleBox["(",
    SpanMaxSize->1], "0", 
   StyleBox[")",
    SpanMaxSize->1], "=", "0"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "24b09e18-ec88-43f4-926a-35d005646585"],
 ", since one photon cannot be detected twice at once. ",
 Cell[BoxData[
 "G2Coherence"], "InlineFormula",ExpressionUUID->
  "bc16bb79-6611-4b28-a588-36941b821b65"],
 " computes it from the state:"
}], "Text",ExpressionUUID->"59bc8f80-57d9-4f8c-be07-446dc69f7087"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{"G2Coherence", "[", 
    RowBox[{
     RowBox[{"CoherentState", "[", "10", "]"}], "[", 
     RowBox[{"<|", 
      RowBox[{"\[FormalAlpha]", " ", "->", " ", "1.0"}], "|>"}], "]"}], "]"}],
    ",", " ", 
   RowBox[{"G2Coherence", "[", 
    RowBox[{"FockState", "[", 
     RowBox[{"1", ",", " ", "10"}], "]"}], "]"}]}], "}"}]], "Input",
 CellLabel->
  "In[20]:= ",ExpressionUUID->"635bdfd5-39e6-4ae2-81f3-cfed026f8165"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"0.9999918897646678`", ",", "0"}], "}"}]], "Output",
 CellLabel->
  "Out[20]= ",ExpressionUUID->"0e4f3964-41cf-4041-948a-58d8e451bbbe"]
}, Open  ]],

Cell[TextData[{
 "The result is ",
 Cell[BoxData[
  RowBox[{"{", 
   RowBox[{"1.0", ",", " ", "0"}], "}"}]], "InlineFormula",ExpressionUUID->
  "7c0dffdd-0889-4a85-ab78-2f316ccca662"],
 ": the coherent state sits exactly at the classical boundary, and the single \
photon is perfectly ",
 StyleBox["antibunched",
  FontWeight->"Bold"],
 ". Any ",
 Cell[BoxData[
  RowBox[{
   SuperscriptBox[
    StyleBox["g", "TI"], 
    RowBox[{
     StyleBox["(",
      SpanMaxSize->1], "2", 
     StyleBox[")",
      SpanMaxSize->1]}]], 
   StyleBox["(",
    SpanMaxSize->1], "0", 
   StyleBox[")",
    SpanMaxSize->1], "<", "1"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "9cc9d6a8-66ba-4b4a-987e-6b3eb28aa927"],
 " is impossible for classical light and is the experimental signature of a \
true quantum emitter."
}], "Text",ExpressionUUID->"f65216e2-3b14-46df-af2f-02cca964737a"],

Cell[TextData[{
 "The oscillator is also where the ",
 StyleBox["position-momentum uncertainty",
  FontWeight->"Bold"],
 " lives. The quadratures ",
 Cell[BoxData[
  RowBox[{
   StyleBox["X", "TI"], "=", 
   StyleBox["(",
    SpanMaxSize->1], 
   RowBox[{
    StyleBox["a", "TI"], "+", 
    SuperscriptBox[
     StyleBox["a", "TI"], "\[Dagger]"]}], 
   StyleBox[")",
    SpanMaxSize->1], "/", "2"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "d8f37cc3-9b8c-493a-8a73-b02d88b931a9"],
 " and ",
 Cell[BoxData[
  RowBox[{
   StyleBox["P", "TI"], "=", "-", 
   StyleBox["i", "TI"], 
   StyleBox["(",
    SpanMaxSize->1], 
   RowBox[{
    StyleBox["a", "TI"], "-", 
    SuperscriptBox[
     StyleBox["a", "TI"], "\[Dagger]"]}], 
   StyleBox[")",
    SpanMaxSize->1], "/", "2"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "e533d10e-6aa3-480e-98e2-2c5dcc7021d2"],
 " are the oscillator's \"position\" and \"momentum\"; in this normalization ",
 Cell[BoxData[
  RowBox[{
   StyleBox["[",
    SpanMaxSize->1], 
   RowBox[{
    StyleBox["X", "TI"], 
    RowBox[{",", "\[ThinSpace]"}], 
    StyleBox["P", "TI"]}], 
   StyleBox["]",
    SpanMaxSize->1], "=", 
   StyleBox["i", "TI"], "/", "2"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "6fdf844c-585f-46ee-8756-df636e1791e3"],
 ". The ground state is a minimum-uncertainty state. Using the same ",
 Cell[BoxData[
 "OperatorVariance"], "InlineFormula",ExpressionUUID->
  "437a2e02-418e-4986-8ad8-9b957ba89989"],
 " as in Part 2, verify that it saturates the bound:"
}], "Text",ExpressionUUID->"44085f38-410a-4b07-bfad-144a65c1b821"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"{", 
    RowBox[{"Xq", ",", " ", "Pq"}], "}"}], " ", "=", " ", 
   RowBox[{"QuadratureOperators", "[", "6", "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"gs", " ", "=", " ", 
   RowBox[{"FockState", "[", 
    RowBox[{"0", ",", " ", "6"}], "]"}]}], ";"}], "\n", 
 RowBox[{"{", 
  RowBox[{
   RowBox[{"OperatorVariance", "[", 
    RowBox[{"gs", ",", " ", "Xq"}], "]"}], ",", " ", 
   RowBox[{"OperatorVariance", "[", 
    RowBox[{"gs", ",", " ", "Pq"}], "]"}], ",", "\n", " ", 
   RowBox[{
    RowBox[{"OperatorVariance", "[", 
     RowBox[{"gs", ",", " ", "Xq"}], "]"}], " ", 
    RowBox[{"OperatorVariance", "[", 
     RowBox[{"gs", ",", " ", "Pq"}], "]"}]}]}], "}"}]}], "Input",
 CellLabel->
  "In[21]:= ",ExpressionUUID->"eb64e8a2-2268-43a0-806d-c18883afd150"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   FractionBox["1", "4"], ",", 
   FractionBox["1", "4"], ",", 
   FractionBox["1", "16"]}], "}"}]], "Output",
 CellLabel->
  "Out[21]= ",ExpressionUUID->"d4ff1f08-5d2e-48a2-b361-c26f864f4d46"]
}, Open  ]],

Cell[TextData[{
 "This gives ",
 Cell[BoxData[
  RowBox[{"\[CapitalDelta]", 
   SuperscriptBox[
    StyleBox["X", "TI"], "2"], "=", "\[CapitalDelta]", 
   SuperscriptBox[
    StyleBox["P", "TI"], "2"], "=", "1", "/", "4"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "8e48b292-ec05-4235-8395-7633aa507995"],
 " and a product ",
 Cell[BoxData[
  RowBox[{"1", "/", "16"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "e46462dd-9e1c-480e-8c19-bca81abe5290"],
 ", so ",
 Cell[BoxData[
  RowBox[{"\[CapitalDelta]", 
   StyleBox["X", "TI"], "\[CapitalDelta]", 
   StyleBox["P", "TI"], "=", "1", "/", "4", "=", 
   FractionBox["1", "2"], "\[LeftBracketingBar]", 
   StyleBox["\[LeftAngleBracket]",
    SpanMaxSize->1], 
   StyleBox["[",
    SpanMaxSize->1], 
   StyleBox["X", "TI"], 
   RowBox[{",", "\[ThinSpace]"}], 
   StyleBox["P", "TI"], 
   StyleBox["]",
    SpanMaxSize->1], 
   StyleBox["\[RightAngleBracket]",
    SpanMaxSize->1], "\[RightBracketingBar]"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "23d374e1-63c7-4f44-931a-1a14ac04575b"],
 ". The vacuum is as sharp as quantum mechanics allows in both quadratures at \
once, the saturated case the strict qubit inequality of Part 2 anticipated."
}], "Text",ExpressionUUID->"227a12a3-9325-4ad8-b933-788b22b04825"],

Cell[TextData[{
 "Finally, the ",
 StyleBox["Jaynes-Cummings model",
  FontWeight->"Bold"],
 " couples one qubit to one field mode, the elementary model of light-matter \
interaction in a cavity (the extended topic of Week 5). On resonance and in \
the interaction picture, the coupling is ",
 Cell[BoxData[
  RowBox[{
   StyleBox["H", "TI"], "=", 
   StyleBox["g", "TI"], 
   StyleBox["(",
    SpanMaxSize->1], 
   RowBox[{
    SuperscriptBox[
     StyleBox["\[Sigma]", "TI"], "+"], 
    StyleBox["a", "TI"], "+", 
    SuperscriptBox[
     StyleBox["\[Sigma]", "TI"], "-"], 
    SuperscriptBox[
     StyleBox["a", "TI"], "\[Dagger]"]}], 
   StyleBox[")",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "f32abb98-ce79-48ec-ad1d-7c27c434d406"],
 ", where ",
 Cell[BoxData[
  SuperscriptBox[
   StyleBox["\[Sigma]", "TI"], "\[PlusMinus]"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "4bd0065f-a5c9-45a5-844e-66768a3b61c2"],
 " raise and lower the qubit and ",
 Cell[BoxData[
  RowBox[{
   StyleBox["a", "TI"], 
   RowBox[{",", "\[ThinSpace]"}], 
   SuperscriptBox[
    StyleBox["a", "TI"], "\[Dagger]"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "9bbd433b-1aae-41d3-9b32-6a95ef292526"],
 " destroy and create photons. Build it on a qubit-times-field space and \
watch a single excitation oscillate between atom and cavity:"
}], "Text",ExpressionUUID->"131b858e-9adc-4856-a126-bc252dcc5251"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"nF", " ", "=", " ", "4"}], ";", " ", 
  RowBox[{"g", " ", "=", " ", "1"}], ";"}], "\n", 
 RowBox[{
  RowBox[{"\[Sigma]p", " ", "=", " ", 
   RowBox[{
    RowBox[{"AnnihilationOperator", "[", "2", "]"}], "[", "\"\<Dagger\>\"", 
    "]"}]}], ";", " ", 
  RowBox[{"\[Sigma]m", " ", "=", " ", 
   RowBox[{"AnnihilationOperator", "[", "2", "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"af", " ", "=", " ", 
   RowBox[{"AnnihilationOperator", "[", "nF", "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"Hjc", " ", "=", " ", 
   RowBox[{"g", " ", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"QuantumTensorProduct", "[", 
       RowBox[{"\[Sigma]p", ",", " ", "af"}], "]"}], " ", "+", " ", 
      RowBox[{"QuantumTensorProduct", "[", 
       RowBox[{"\[Sigma]m", ",", " ", 
        RowBox[{"af", "[", "\"\<Dagger\>\"", "]"}]}], "]"}]}], ")"}]}]}], 
  ";"}], "\n", 
 RowBox[{
  RowBox[{"psi0", " ", "=", " ", 
   RowBox[{"QuantumTensorProduct", "[", 
    RowBox[{
     RowBox[{"QuantumState", "[", "\"\<1\>\"", "]"}], ",", " ", 
     RowBox[{"FockState", "[", 
      RowBox[{"0", ",", " ", "nF"}], "]"}]}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"jc", " ", "=", " ", 
   RowBox[{"QuantumEvolve", "[", 
    RowBox[{"Hjc", ",", " ", "psi0", ",", " ", 
     RowBox[{"{", 
      RowBox[{"t", ",", " ", "0", ",", " ", "Pi"}], "}"}]}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"pe", "[", "tt_", "]"}], " ", ":=", " ", 
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{"QuantumPartialTrace", "[", 
       RowBox[{
        RowBox[{"jc", "[", 
         RowBox[{"<|", 
          RowBox[{"t", " ", "->", " ", "tt"}], "|>"}], "]"}], ",", " ", 
        RowBox[{"{", "2", "}"}]}], "]"}], "[", "\"\<ProbabilitiesList\>\"", 
      "]"}], "[", 
     RowBox[{"[", "2", "]"}], "]"}], " ", "//", " ", "Chop"}]}], 
  ";"}], "\n", 
 RowBox[{"{", 
  RowBox[{
   RowBox[{"pe", "[", "0", "]"}], ",", " ", 
   RowBox[{"pe", "[", 
    RowBox[{"Pi", "/", "4."}], "]"}], ",", " ", 
   RowBox[{"pe", "[", 
    RowBox[{"Pi", "/", "2."}], "]"}]}], "}"}]}], "Input",
 CellLabel->
  "In[22]:= ",ExpressionUUID->"2152e1ca-13c3-41bf-aad7-fe8f43c1d402"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"1.`", ",", "0.5000000030916697`", ",", "0"}], "}"}]], "Output",
 CellLabel->
  "Out[22]= ",ExpressionUUID->"966fe303-34e9-4e7b-8640-7821a7cd2247"]
}, Open  ]],

Cell[TextData[{
 "The excited-state population is ",
 Cell[BoxData[
  RowBox[{"{", 
   RowBox[{"1.", ",", " ", "0.5", ",", " ", "0."}], "}"}]], "InlineFormula",
  ExpressionUUID->"51e898b1-bb7c-48ae-881b-3ba3d3035f65"],
 ", matching ",
 Cell[BoxData[
  RowBox[{
   SubscriptBox[
    StyleBox["P", "TI"], 
    StyleBox["e", "TI"]], 
   StyleBox["(",
    SpanMaxSize->1], 
   StyleBox["t", "TI"], 
   StyleBox[")",
    SpanMaxSize->1], "=", 
   SuperscriptBox[
    StyleBox["cos",
     FontSlant->"Plain"], "2"], "\[ThinSpace]", 
   StyleBox["(",
    SpanMaxSize->1], 
   StyleBox[
    RowBox[{"g", "t"}], "TI"], 
   StyleBox[")",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "b7cac555-e554-46f0-ba85-d37dfe73f83a"],
 ": the atom starts excited with the cavity empty (",
 Cell[BoxData[
  TemplateBox[{
    RowBox[{
      StyleBox["e", "TI"], ",\[ThinSpace]", "0"}]},
   "Ket"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "e6fcee8e-ff1c-4929-abc5-38643c6c809a"],
 "), and the energy quantum coherently shuttles to the field (",
 Cell[BoxData[
  TemplateBox[{
    RowBox[{
      StyleBox["g", "TI"], ",\[ThinSpace]", "1"}]},
   "Ket"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "07032267-7bb1-4df5-accd-92024c8d3c09"],
 ") and back. This ",
 StyleBox["vacuum Rabi oscillation",
  FontWeight->"Bold"],
 " has no classical analog. The coupling term ",
 Cell[BoxData[
  RowBox[{
   SuperscriptBox[
    StyleBox["\[Sigma]", "TI"], "+"], 
   StyleBox["a", "TI"], "+", 
   SuperscriptBox[
    StyleBox["\[Sigma]", "TI"], "-"], 
   SuperscriptBox[
    StyleBox["a", "TI"], "\[Dagger]"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "5c96d0b5-c24e-43f7-a776-5b03b7a436df"],
 " links ",
 Cell[BoxData[
  TemplateBox[{
    RowBox[{
      StyleBox["e", "TI"], ",\[ThinSpace]", "0"}]},
   "Ket"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "0dddee24-3009-433a-a5c3-105f3a897b75"],
 " directly to ",
 Cell[BoxData[
  TemplateBox[{
    RowBox[{
      StyleBox["g", "TI"], ",\[ThinSpace]", "1"}]},
   "Ket"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "9603bcda-7453-4d0c-8d8a-b568f700e2a7"],
 ", so even with zero photons in the cavity the initial state is not an \
eigenstate of ",
 Cell[BoxData[
  StyleBox["H", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "23235beb-e96b-4967-8193-3b5c61f7a94a"],
 " and is forced to evolve. A classical field of zero amplitude would leave \
the atom alone; the quantized field does not."
}], "Text",ExpressionUUID->"1fddfed6-cd7b-442c-aa73-3e9eba724a21"],

Cell["Part 6 \[LongDash] Many qubits: tensor products, gates, circuits", \
"Section",ExpressionUUID->"e91c58b4-8cf0-497a-9fe8-b2cffe7ab2b7"],

Cell[TextData[{
 StyleBox["Course map:",
  FontWeight->"Bold"],
 " Week 6 (tensor product, multiple qubits, quantum gates, quantum \
circuits)."
}], "Text",
 CellFrame->{{3, 0}, {0, 0}},
 CellMargins->{{40, 10}, {7, 7}},
 CellFrameMargins->10,
 CellFrameColor->GrayLevel[0.55],
 FontSlant->"Italic",
 FontColor->LightDarkSwitched[
   GrayLevel[0.45], 
   GrayLevel[0.65]],
 Background->LightDarkSwitched[
   GrayLevel[0.96], 
   GrayLevel[0.2]],ExpressionUUID->"a3655f38-bf07-49bc-bcd1-ba386438445a"],

Cell[TextData[{
 "Two qubits live in the ",
 StyleBox["tensor product",
  FontWeight->"Bold"],
 " of their spaces, a four-dimensional Hilbert space. ",
 Cell[BoxData[
 "QuantumTensorProduct"], "InlineFormula",ExpressionUUID->
  "a73f1e2c-fa8a-4bfe-9078-47d8f0b3cee2"],
 " builds composite states and operators:"
}], "Text",ExpressionUUID->"31a5ae07-a228-4fbb-8860-3ecc683db23b"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"q00", " ", "=", " ", 
   RowBox[{"QuantumTensorProduct", "[", 
    RowBox[{
     RowBox[{"QuantumState", "[", "\"\<0\>\"", "]"}], ",", " ", 
     RowBox[{"QuantumState", "[", "\"\<0\>\"", "]"}]}], "]"}]}], 
  ";"}], "\n", 
 RowBox[{"{", 
  RowBox[{
   RowBox[{"q00", "[", "\"\<Qudits\>\"", "]"}], ",", " ", 
   RowBox[{
    RowBox[{"q00", "[", "\"\<StateVector\>\"", "]"}], " ", "//", " ", 
    "Normal"}]}], "}"}]}], "Input",
 CellLabel->
  "In[23]:= ",ExpressionUUID->"a972509f-4ef7-43cb-8142-198c8fd774e8"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"2", ",", 
   RowBox[{"{", 
    RowBox[{"1", ",", "0", ",", "0", ",", "0"}], "}"}]}], "}"}]], "Output",
 CellLabel->
  "Out[23]= ",ExpressionUUID->"3c2d0ba5-002a-42b1-9df7-2b2008c3c15b"]
}, Open  ]],

Cell[TextData[{
 "This reports ",
 Cell[BoxData[
 "2"], "InlineFormula",ExpressionUUID->"83ad2c73-12b8-4e68-976e-f7d1d91209ab"],
 " qudits and the vector ",
 Cell[BoxData[
  RowBox[{
   RowBox[{"{", "1"}], 
   RowBox[{",", "\[ThinSpace]"}], 
   RowBox[{"0", ",", "0"}], 
   RowBox[{",", "\[ThinSpace]"}], 
   RowBox[{"0", "}"}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "347ee577-1b75-446b-8fb6-2023b96cb46d"],
 ", that is ",
 Cell[BoxData[
  TemplateBox[{"00"},
   "Ket"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "57e59f7f-4510-4c1b-bafb-f6d5804d448f"],
 ". The dimension doubles with every qubit added, which is precisely the \
resource that makes quantum computers powerful and classical simulation \
hard."
}], "Text",ExpressionUUID->"7590978e-81c2-4b05-a5cd-752929727bee"],

Cell[TextData[{
 "A ",
 StyleBox["quantum circuit",
  FontWeight->"Bold"],
 " is an ordered list of gates acting on named wires. A gate is a unitary ",
 Cell[BoxData[
 "QuantumOperator"], "InlineFormula",ExpressionUUID->
  "fd6b930f-a3ed-454b-9727-7d1f339d1aa8"],
 "; the basic library includes the Hadamard ",
 Cell[BoxData["\"\<H\>\""], "InlineFormula",ExpressionUUID->
  "07e403c7-0528-4e97-b407-53a21ff06bc9"],
 ", the Paulis, phase gates, and the controlled-NOT ",
 Cell[BoxData["\"\<CNOT\>\""], "InlineFormula",ExpressionUUID->
  "120925d8-5370-4cc8-91f9-2239de4ed624"],
 ". Unitarity is what makes gates reversible, and we check it the \
object-model way:"
}], "Text",ExpressionUUID->"005a54f4-33d2-4d11-ad8f-cd96109db515"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{
    RowBox[{"QuantumOperator", "[", "\"\<H\>\"", "]"}], 
    "[", "\"\<UnitaryQ\>\"", "]"}], ",", " ", 
   RowBox[{
    RowBox[{"QuantumOperator", "[", "\"\<CNOT\>\"", "]"}], 
    "[", "\"\<UnitaryQ\>\"", "]"}]}], "}"}]], "Input",
 CellLabel->
  "In[24]:= ",ExpressionUUID->"0f450f0f-7c45-4375-b4c6-37a733a42086"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"True", ",", "True"}], "}"}]], "Output",
 CellLabel->
  "Out[24]= ",ExpressionUUID->"7817420e-c212-46d7-9493-cafb324225ea"]
}, Open  ]],

Cell[TextData[{
 "Both are ",
 Cell[BoxData[
 "True"], "InlineFormula",ExpressionUUID->
  "51c544bf-2791-42a4-b534-8ec8aed1d31e"],
 ". The canonical two-qubit circuit prepares a Bell pair: a Hadamard on the \
first wire followed by a CNOT controlled on it:"
}], "Text",ExpressionUUID->"f519e9d7-996b-4c26-933d-ec872c897bd4"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"bell", " ", "=", " ", 
   RowBox[{"QuantumCircuitOperator", "[", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"\"\<H\>\"", " ", "->", " ", "1"}], ",", " ", 
      RowBox[{"\"\<CNOT\>\"", " ", "->", " ", 
       RowBox[{"{", 
        RowBox[{"1", ",", " ", "2"}], "}"}]}]}], "}"}], "]"}]}], 
  ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"bell", "[", 
    RowBox[{"QuantumState", "[", "\"\<00\>\"", "]"}], "]"}], 
   "[", "\"\<StateVector\>\"", "]"}], " ", "//", " ", "Normal"}]}], "Input",
 CellLabel->
  "In[25]:= ",ExpressionUUID->"39f3d0c6-cb96-4c3b-9be4-9aba3d23b06e"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   FractionBox["1", 
    SqrtBox["2"]], ",", "0", ",", "0", ",", 
   FractionBox["1", 
    SqrtBox["2"]]}], "}"}]], "Output",
 CellLabel->
  "Out[25]= ",ExpressionUUID->"04bec22c-487e-4da2-a96f-0bc231f8cf19"]
}, Open  ]],

Cell[TextData[{
 "The output is ",
 Cell[BoxData[
  RowBox[{
   RowBox[{"{", "1", "/", 
    SqrtBox["2"]}], 
   RowBox[{",", "\[ThinSpace]"}], 
   RowBox[{"0", ",", "0"}], 
   RowBox[{",", "\[ThinSpace]"}], 
   RowBox[{"1", "/", 
    SqrtBox["2"], "}"}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "7ab465c6-73d0-475a-bf0f-33a5b4edb9b5"],
 ", the entangled state ",
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     SuperscriptBox["\[CapitalPhi]", "+"]},
    "Ket"], "=", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{
      TemplateBox[{"00"},
       "Ket"], "+", 
      TemplateBox[{"11"},
       "Ket"]}], ")"}], "/", 
    SqrtBox["2"]}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "67b3bd40-6b31-47fa-b45e-938f21f5d011"],
 ". The notation ",
 Cell[BoxData[
  RowBox[{"\"\<gate\>\"", " ", "->", " ", "wires"}]], "InlineFormula",
  ExpressionUUID->"05460005-1bdc-46e5-a932-783e08c0bbf0"],
 " reads like a wiring diagram, and ",
 Cell[BoxData[
  RowBox[{"bell", "[", "\"\<Diagram\>\"", "]"}]], "InlineFormula",
  ExpressionUUID->"54672cc0-0962-476f-9606-37a972789749"],
 " draws the actual circuit."
}], "Text",ExpressionUUID->"14211dc5-dece-4eb7-aee4-2d66a909a567"],

Cell["\<\
Circuits compose and scale. The three-qubit GHZ state, a maximally entangled \
\"cat\" state, is one more CNOT:\
\>", "Text",ExpressionUUID->"284b9066-15d8-461f-9d33-c9888508d258"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"QuantumState", "[", 
    RowBox[{"\"\<GHZ\>\"", "[", "3", "]"}], "]"}], "[", "\"\<StateVector\>\"",
    "]"}], " ", "//", " ", "Normal"}]], "Input",
 CellLabel->
  "In[26]:= ",ExpressionUUID->"6cf4e021-eb02-4bee-b5af-7272198e9687"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   FractionBox["1", 
    SqrtBox["2"]], ",", "0", ",", "0", ",", "0", ",", "0", ",", "0", ",", "0",
    ",", 
   FractionBox["1", 
    SqrtBox["2"]]}], "}"}]], "Output",
 CellLabel->
  "Out[26]= ",ExpressionUUID->"349325f9-b1db-4390-8a15-f872400e66d5"]
}, Open  ]],

Cell[TextData[{
 "which is ",
 Cell[BoxData[
  RowBox[{
   RowBox[{"{", "1", "/", 
    SqrtBox["2"]}], 
   RowBox[{",", "\[ThinSpace]"}], 
   RowBox[{"0", ",", "0", ",", "0", ",", "0", ",", "0", ",", "0"}], 
   RowBox[{",", "\[ThinSpace]"}], 
   RowBox[{"1", "/", 
    SqrtBox["2"], "}"}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "a0aac6c0-ee31-4048-89ff-268315dae325"],
 ", the state ",
 Cell[BoxData[
  RowBox[{
   RowBox[{"(", 
    RowBox[{
     TemplateBox[{"000"},
      "Ket"], "+", 
     TemplateBox[{"111"},
      "Ket"]}], ")"}], "/", 
   SqrtBox["2"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "057615a3-b5f0-49c7-b4b8-a7fc384acdfa"],
 ". Gates and circuits are the hardware-independent logical layer of quantum \
computing: the same ",
 Cell[BoxData[
 "bell"], "InlineFormula",ExpressionUUID->
  "1a85d5a0-37a0-4301-92fd-1450561cc835"],
 " circuit runs on any platform, exactly as the course frames it."
}], "Text",ExpressionUUID->"44b0602b-2234-4a05-826f-0c1981a813f0"],

Cell["\<\
Part 7 \[LongDash] Communication: entanglement, no-cloning, teleportation \
(Lab 3)\
\>", "Section",ExpressionUUID->"ee72f297-a73a-450b-a243-9ed532bf55e7"],

Cell[TextData[{
 StyleBox["Course map:",
  FontWeight->"Bold"],
 " Week 8 (entanglement, Bell states, no-cloning, teleportation). ",
 StyleBox["This is Lab 3.",
  FontWeight->"Bold"]
}], "Text",
 CellFrame->{{3, 0}, {0, 0}},
 CellMargins->{{40, 10}, {7, 7}},
 CellFrameMargins->10,
 CellFrameColor->GrayLevel[0.55],
 FontSlant->"Italic",
 FontColor->LightDarkSwitched[
   GrayLevel[0.45], 
   GrayLevel[0.65]],
 Background->LightDarkSwitched[
   GrayLevel[0.96], 
   GrayLevel[0.2]],ExpressionUUID->"082c53b6-f175-4298-a30c-c52145191cad"],

Cell[TextData[{
 "Quantum communication rests on ",
 StyleBox["entanglement",
  FontWeight->"Bold"],
 ", correlation stronger than anything classical. The Bell state ",
 Cell[BoxData[
  TemplateBox[{
    SuperscriptBox["\[CapitalPhi]", "+"]},
   "Ket"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "a6f1d729-9130-4af0-9fde-fca3d4150927"],
 " is entangled, and the framework can certify it:"
}], "Text",ExpressionUUID->"0e1bcea7-fb0a-4f8d-be2b-a1b7a308b12c"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"bell", " ", "=", " ", 
   RowBox[{"QuantumState", "[", "\"\<PhiPlus\>\"", "]"}]}], ";"}], "\n", 
 RowBox[{"{", 
  RowBox[{
   RowBox[{"QuantumEntangledQ", "[", "bell", "]"}], ",", " ", 
   RowBox[{"QuantumEntanglementMonotone", "[", 
    RowBox[{"bell", ",", " ", "\"\<Concurrence\>\""}], "]"}]}], 
  "}"}]}], "Input",
 CellLabel->
  "In[27]:= ",ExpressionUUID->"cdedf4f2-6586-487d-8ba4-e5e042ce9a19"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"True", ",", "1"}], "}"}]], "Output",
 CellLabel->
  "Out[27]= ",ExpressionUUID->"7d85b358-351e-4c3c-8c55-6a735914c9c9"]
}, Open  ]],

Cell[TextData[{
 "returns ",
 Cell[BoxData[
  RowBox[{"{", 
   RowBox[{"True", ",", " ", "1"}], "}"}]], "InlineFormula",ExpressionUUID->
  "15a7782e-6374-42ea-afd5-2c67dab71094"],
 ": not only is the state entangled, its concurrence is the maximum value ",
 Cell[BoxData["1"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "157e20d4-2f46-4143-b010-7266a19039d0"],
 ". The signature of entanglement is that the ",
 StyleBox["parts",
  FontWeight->"Bold"],
 " are less defined than the whole. Trace out the second qubit and inspect \
what is left of the first:"
}], "Text",ExpressionUUID->"666dea01-3133-4030-88cc-a6a4af2171cb"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"QuantumPartialTrace", "[", 
   RowBox[{"bell", ",", " ", 
    RowBox[{"{", "2", "}"}]}], "]"}], "[", "\"\<Purity\>\"", "]"}]], "Input",
 CellLabel->
  "In[28]:= ",ExpressionUUID->"2d9bc53a-e5d7-407a-8da4-2ce44ab79469"],

Cell[BoxData[
 FractionBox["1", "2"]], "Output",
 CellLabel->
  "Out[28]= ",ExpressionUUID->"434f2ad6-b809-405d-b98f-57ccb91142c2"]
}, Open  ]],

Cell[TextData[{
 "The reduced state has purity ",
 Cell[BoxData[
  RowBox[{"1", "/", "2"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "9ea87e2d-a551-4eac-915d-7aeb9081b193"],
 ", the minimum possible for a qubit: it is ",
 StyleBox["maximally mixed",
  FontWeight->"Bold"],
 ". The whole is a perfectly definite pure state, yet each half, looked at \
alone, is maximally random. That trade-off is the engine of both \
teleportation and quantum cryptography."
}], "Text",ExpressionUUID->"fd47c929-4976-406f-bed5-d95ff909542e"],

Cell[TextData[{
 "A second pillar is the ",
 StyleBox["no-cloning theorem",
  FontWeight->"Bold"],
 ": no operation can copy an unknown quantum state. We can see why with the \
CNOT gate, which ",
 StyleBox["does", "TI"],
 " copy the basis states (",
 Cell[BoxData[
  RowBox[{
   RowBox[{
    TemplateBox[{"0"},
     "Ket"], 
    TemplateBox[{"0"},
     "Ket"]}], "\[Rule]", 
   RowBox[{
    TemplateBox[{"0"},
     "Ket"], 
    TemplateBox[{"0"},
     "Ket"]}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "a251e433-f9ec-4a2b-beb6-548835db99a2"],
 ", ",
 Cell[BoxData[
  RowBox[{
   RowBox[{
    TemplateBox[{"1"},
     "Ket"], 
    TemplateBox[{"0"},
     "Ket"]}], "\[Rule]", 
   RowBox[{
    TemplateBox[{"1"},
     "Ket"], 
    TemplateBox[{"1"},
     "Ket"]}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "62f49d95-efa8-4ae0-9f3a-11be16863726"],
 "). Try to use it to copy a superposition:"
}], "Text",ExpressionUUID->"a82f87a8-9837-4eec-a0ac-e81a439a5f32"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"cnot", " ", "=", " ", 
   RowBox[{"QuantumCircuitOperator", "[", 
    RowBox[{"{", 
     RowBox[{"\"\<CNOT\>\"", " ", "->", " ", 
      RowBox[{"{", 
       RowBox[{"1", ",", " ", "2"}], "}"}]}], "}"}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"copied", " ", "=", " ", 
   RowBox[{"cnot", "[", 
    RowBox[{"QuantumState", "[", "\"\<+0\>\"", "]"}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"target", " ", "=", " ", 
   RowBox[{"QuantumTensorProduct", "[", 
    RowBox[{
     RowBox[{"QuantumState", "[", "\"\<+\>\"", "]"}], ",", " ", 
     RowBox[{"QuantumState", "[", "\"\<+\>\"", "]"}]}], "]"}]}], 
  ";"}], "\n", 
 RowBox[{
  RowBox[{"Abs", "[", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{
      RowBox[{"copied", "[", "\"\<Dagger\>\"", "]"}], " ", "@", " ", 
      "target"}], ")"}], "[", "\"\<Scalar\>\"", "]"}], "]"}], "^", 
  "2"}]}], "Input",
 CellLabel->
  "In[29]:= ",ExpressionUUID->"25597c01-4775-4d5d-ab11-e608a3b81470"],

Cell[BoxData[
 FractionBox["1", "2"]], "Output",
 CellLabel->
  "Out[29]= ",ExpressionUUID->"244055c8-1527-4340-9fb0-2a9b66eb81dd"]
}, Open  ]],

Cell[TextData[{
 "The fidelity between what CNOT produces and a genuine copy ",
 Cell[BoxData[
  RowBox[{
   TemplateBox[{"+"},
    "Ket"], 
   TemplateBox[{"+"},
    "Ket"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "21e5bfae-f9cc-4634-a3cd-c2a13b478bae"],
 " is only ",
 Cell[BoxData[
  RowBox[{"1", "/", "2"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "0a59cbd9-4b3a-4edf-b875-663a0142e719"],
 ". Instead of two copies of ",
 Cell[BoxData[
  TemplateBox[{"+"},
   "Ket"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "81f45cad-8b6b-417f-ba02-3137da97d488"],
 ", CNOT produces the entangled Bell state ",
 Cell[BoxData[
  RowBox[{
   RowBox[{"(", 
    RowBox[{
     TemplateBox[{"00"},
      "Ket"], "+", 
     TemplateBox[{"11"},
      "Ket"]}], ")"}], "/", 
   SqrtBox["2"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "05406f99-5f12-49d9-ac3f-8fbb23912083"],
 ". A machine that copies a basis cannot copy its superpositions; that is \
no-cloning, made concrete."
}], "Text",ExpressionUUID->"79bca928-db70-458a-a369-b51379022c3d"],

Cell[TextData[{
 "No-cloning forbids copying, but ",
 StyleBox["teleportation",
  FontWeight->"Bold"],
 " still lets Alice send an unknown qubit to Bob using a shared Bell pair and \
two classical bits, destroying her original in the process. The protocol: \
entangle a helper pair (wires 2 and 3), have Alice interact her unknown qubit \
(wire 1) with her half, measure wires 1 and 2, and have Bob apply a \
correction to wire 3 conditioned on the two outcomes. Build it and run an \
unknown state through:"
}], "Text",ExpressionUUID->"7de53b4b-1d0c-4a96-9762-da2f1253233f"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"psiIn", " ", "=", " ", 
   RowBox[{"QuantumState", "[", 
    RowBox[{"N", " ", "@", " ", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"Cos", "[", 
        RowBox[{"Pi", "/", "5"}], "]"}], ",", " ", 
       RowBox[{
        RowBox[{"Exp", "[", 
         RowBox[{"I", " ", 
          RowBox[{"Pi", "/", "3"}]}], "]"}], " ", 
        RowBox[{"Sin", "[", 
         RowBox[{"Pi", "/", "5"}], "]"}]}]}], "}"}]}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"tele", " ", "=", " ", 
   RowBox[{"QuantumCircuitOperator", "[", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"\"\<H\>\"", " ", "->", " ", "2"}], ",", " ", 
      RowBox[{"\"\<CNOT\>\"", " ", "->", " ", 
       RowBox[{"{", 
        RowBox[{"2", ",", " ", "3"}], "}"}]}], ",", " ", 
      RowBox[{"\"\<CNOT\>\"", " ", "->", " ", 
       RowBox[{"{", 
        RowBox[{"1", ",", " ", "2"}], "}"}]}], ",", " ", 
      RowBox[{"\"\<H\>\"", " ", "->", " ", "1"}], ",", " ", 
      RowBox[{"{", 
       RowBox[{"1", ",", " ", "2"}], "}"}]}], "}"}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"meas", " ", "=", " ", 
   RowBox[{"tele", "[", 
    RowBox[{"QuantumTensorProduct", "[", 
     RowBox[{"psiIn", ",", " ", 
      RowBox[{"QuantumState", "[", "\"\<00\>\"", "]"}]}], "]"}], "]"}]}], 
  ";"}], "\n", 
 RowBox[{
  RowBox[{"Values", "[", 
   RowBox[{"meas", "[", "\"\<Probabilities\>\"", "]"}], "]"}], " ", "//", " ",
   "N"}]}], "Input",
 CellLabel->
  "In[30]:= ",ExpressionUUID->"9bb2ad21-5ded-4d6b-a9ff-0dba49e5d942"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"0.25`", ",", "0.25`", ",", "0.25`", ",", "0.25`"}], 
  "}"}]], "Output",
 CellLabel->
  "Out[30]= ",ExpressionUUID->"5d953419-4a01-461c-8a4a-5c9032078f50"]
}, Open  ]],

Cell[TextData[{
 "The four measurement outcomes are equally likely, ",
 Cell[BoxData[
  RowBox[{
   RowBox[{"{", "0.25"}], 
   RowBox[{",", "\[ThinSpace]"}], "0.25", 
   RowBox[{",", "\[ThinSpace]"}], "0.25", 
   RowBox[{",", "\[ThinSpace]"}], 
   RowBox[{"0.25", "}"}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "4e70b53f-7747-4b73-ad24-7c651fabf6d3"],
 ", so the measurement leaks ",
 StyleBox["nothing",
  FontWeight->"Bold"],
 " about the state. The post-measurement states on Bob's wire are the \
conditional outputs ",
 Cell[BoxData[
  RowBox[{"meas", "[", "\"\<States\>\"", "]"}]], "InlineFormula",
  ExpressionUUID->"5d76d5bd-b7fd-4cf8-af60-16330984f5f0"],
 ". For each outcome ",
 Cell[BoxData[
  RowBox[{
   StyleBox["(",
    SpanMaxSize->1], 
   RowBox[{
    SubscriptBox[
     StyleBox["m", "TI"], "1"], 
    RowBox[{",", "\[ThinSpace]"}], 
    SubscriptBox[
     StyleBox["m", "TI"], "2"]}], 
   StyleBox[")",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "acc86e92-a2a1-447e-b837-b78c2e7858e4"],
 ", Bob's correction is ",
 Cell[BoxData[
  RowBox[{
   SuperscriptBox[
    StyleBox["Z", "TI"], 
    SubscriptBox[
     StyleBox["m", "TI"], "1"]], 
   SuperscriptBox[
    StyleBox["X", "TI"], 
    SubscriptBox[
     StyleBox["m", "TI"], "2"]]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "188aa680-f51d-404d-ab2d-3ddd04cf34f8"],
 ". Apply it and verify perfect recovery:"
}], "Text",ExpressionUUID->"d937d887-7fc0-4984-b90b-87aa1050bcf8"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"corr", " ", "=", " ", 
   RowBox[{"<|", 
    RowBox[{
     RowBox[{
      RowBox[{"{", 
       RowBox[{"0", ",", " ", "0"}], "}"}], " ", "->", " ", "\"\<I\>\""}], ",",
      " ", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"0", ",", " ", "1"}], "}"}], " ", "->", " ", "\"\<X\>\""}], ",",
      " ", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"1", ",", " ", "0"}], "}"}], " ", "->", " ", "\"\<Z\>\""}], ",",
      " ", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"1", ",", " ", "1"}], "}"}], " ", "->", " ", "\"\<Y\>\""}]}], 
    "|>"}]}], ";"}], "\n", 
 RowBox[{"KeyValueMap", "[", "\n", "  ", 
  RowBox[{
   RowBox[{"Function", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"k", ",", " ", "st"}], "}"}], ",", "\n", "    ", 
     RowBox[{"Module", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{"outcome", " ", "=", " ", 
          RowBox[{"First", "[", "k", "]"}]}], ",", " ", "q3"}], "}"}], ",", 
       "\n", "      ", 
       RowBox[{
        RowBox[{"q3", " ", "=", " ", 
         RowBox[{
          RowBox[{"QuantumPartialTrace", "[", 
           RowBox[{"st", ",", " ", 
            RowBox[{"{", 
             RowBox[{"1", ",", " ", "2"}], "}"}]}], "]"}], 
          "[", "\"\<Normalize\>\"", "]"}]}], ";", "\n", "      ", 
        RowBox[{"{", 
         RowBox[{"outcome", ",", " ", 
          RowBox[{"Round", "[", 
           RowBox[{
            RowBox[{
             RowBox[{"Abs", "[", 
              RowBox[{
               RowBox[{"(", 
                RowBox[{
                 RowBox[{
                  RowBox[{"(", 
                   RowBox[{
                    RowBox[{
                    RowBox[{"QuantumOperator", "[", 
                    RowBox[{"corr", "[", "outcome", "]"}], "]"}], "[", "q3", 
                    "]"}], "[", "\"\<Normalize\>\"", "]"}], ")"}], 
                  "[", "\"\<Dagger\>\"", "]"}], " ", "@", " ", "psiIn"}], 
                ")"}], "[", "\"\<Scalar\>\"", "]"}], "]"}], "^", "2"}], ",", 
            " ", "0.001"}], "]"}]}], "}"}]}]}], "]"}]}], "]"}], ",", "\n", 
   "  ", 
   RowBox[{"meas", "[", "\"\<StateAssociation\>\"", "]"}]}], "]"}]}], "Input",\

 CellLabel->
  "In[31]:= ",ExpressionUUID->"a6d35f01-b1b4-4df9-89a7-2946b847b5cb"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"0", ",", "0"}], "}"}], ",", "1.`"}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"0", ",", "1"}], "}"}], ",", "1.`"}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"1", ",", "0"}], "}"}], ",", "1.`"}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"1", ",", "1"}], "}"}], ",", "1.`"}], "}"}]}], "}"}]], "Output",\

 CellLabel->
  "Out[31]= ",ExpressionUUID->"3346f1c2-d741-46db-a09c-f20aba65f71e"]
}, Open  ]],

Cell[TextData[{
 "Every branch returns fidelity ",
 Cell[BoxData[
 "1."], "InlineFormula",ExpressionUUID->
  "ff8b41f0-e9f6-4187-9922-b85c0725494e"],
 ": regardless of which of the four random outcomes occurred, Bob's corrected \
qubit is ",
 StyleBox["exactly",
  FontWeight->"Bold"],
 " the state Alice sent. The state crossed the channel carried by one Bell \
pair and two classical bits, with no copy left behind and no information in \
the transmitted bits alone."
}], "Text",ExpressionUUID->"7d349f8f-b93c-472e-9eb6-0dc31acd908a"],

Cell["\<\
Part 8 \[LongDash] Open systems: mixed states, channels, and decoherence (Lab \
3 context)\
\>", "Section",ExpressionUUID->"c8af2cfa-de3a-47d6-9078-c659db2cdf47"],

Cell[TextData[{
 StyleBox["Course map:",
  FontWeight->"Bold"],
 " Weeks 9 and 10 (pure vs mixed states, density operators, Lindblad master \
equation, noise types, Bloch sphere for mixed states, impact of noise)."
}], "Text",
 CellFrame->{{3, 0}, {0, 0}},
 CellMargins->{{40, 10}, {7, 7}},
 CellFrameMargins->10,
 CellFrameColor->GrayLevel[0.55],
 FontSlant->"Italic",
 FontColor->LightDarkSwitched[
   GrayLevel[0.45], 
   GrayLevel[0.65]],
 Background->LightDarkSwitched[
   GrayLevel[0.96], 
   GrayLevel[0.2]],ExpressionUUID->"db86caa5-d89d-467c-b707-d1e05326c545"],

Cell[TextData[{
 "Every real device is open to its environment, and an open system is \
generally not in a pure state. The complete description is the ",
 StyleBox["density operator",
  FontWeight->"Bold"],
 " ",
 Cell[BoxData[
  StyleBox["\[Rho]", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "2f5f6c96-851c-4e0b-b9bb-d86e14d02752"],
 ", a positive operator of unit trace. A classical mixture of ",
 Cell[BoxData[
  TemplateBox[{"0"},
   "Ket"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "1efaf1e3-156f-4cc7-bcec-3113beca5294"],
 " and ",
 Cell[BoxData[
  TemplateBox[{"1"},
   "Ket"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "b7e33cb5-f3d2-4aca-b1f4-4afcb93caef7"],
 " is diagonal:"
}], "Text",ExpressionUUID->"dc3c8a77-2a8b-4252-8d24-b567f728fab7"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"rho", " ", "=", " ", 
   RowBox[{"QuantumState", "[", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"0.75", ",", " ", "0"}], "}"}], ",", " ", 
      RowBox[{"{", 
       RowBox[{"0", ",", " ", "0.25"}], "}"}]}], "}"}], "]"}]}], 
  ";"}], "\n", 
 RowBox[{"{", 
  RowBox[{
   RowBox[{"rho", "[", "\"\<PureStateQ\>\"", "]"}], ",", " ", 
   RowBox[{"rho", "[", "\"\<Purity\>\"", "]"}], ",", " ", 
   RowBox[{"rho", "[", "\"\<VonNeumannEntropy\>\"", "]"}], ",", " ", 
   RowBox[{"rho", "[", "\"\<BlochVector\>\"", "]"}]}], "}"}]}], "Input",
 CellLabel->
  "In[32]:= ",ExpressionUUID->"f3bb315a-8322-433a-995e-cee4cf729f2f"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"False", ",", "0.625`", ",", 
   TemplateBox[{"0.8112781244591328`", "\"b\"", "bits", "\"Bits\""},
    "Quantity"], ",", 
   RowBox[{"{", 
    RowBox[{"0", ",", "0", ",", "0.5`"}], "}"}]}], "}"}]], "Output",
 CellLabel->
  "Out[32]= ",ExpressionUUID->"8a92a1ba-f4f0-4e90-8305-7f772f5c0619"]
}, Open  ]],

Cell[TextData[{
 "This reports ",
 Cell[BoxData[
 "False"], "InlineFormula",ExpressionUUID->
  "64f67249-eab1-4bd8-b36e-55307278730e"],
 " (not pure), purity ",
 Cell[BoxData["0.625"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "e5629528-ad71-4e82-804c-2a58153398ab"],
 ", von Neumann entropy ",
 Cell[BoxData["0.811"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "8307be22-e2e9-40a7-a65d-fc440048d319"],
 " bits, and Bloch vector ",
 Cell[BoxData[
  RowBox[{
   RowBox[{"{", "0"}], 
   RowBox[{",", "\[ThinSpace]"}], "0", 
   RowBox[{",", "\[ThinSpace]"}], 
   RowBox[{"0.5", "}"}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "53d0d515-b1e2-4c8c-836b-19b44056de8d"],
 ". Purity ",
 Cell[BoxData[
  RowBox[{
   StyleBox["Tr",
    FontSlant->"Plain"], " ", 
   SuperscriptBox[
    StyleBox["\[Rho]", "TI"], "2"], "<", "1"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "68fc1262-53bb-4384-adf8-f14a368cdc74"],
 " and nonzero entropy are the marks of a mixed state, and its Bloch vector \
lies strictly ",
 StyleBox["inside",
  FontWeight->"Bold"],
 " the sphere. The maximally mixed state ",
 Cell[BoxData[
  RowBox[{
   StyleBox["I", "TI"], "/", "2"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "e13726f5-f5c6-45d6-82e5-654088126c08"],
 " sits at the origin with purity ",
 Cell[BoxData[
  RowBox[{"1", "/", "2"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "8b9db2c9-be48-449e-9d45-24a2b49502c9"],
 " and one full bit of entropy."
}], "Text",ExpressionUUID->"6610ccbc-9272-4033-9711-579002713574"],

Cell[TextData[{
 "Decoherence is mixing caused by entanglement with an environment. We \
already saw it in Part 7: the reduced state of a Bell pair is maximally \
mixed. The general lesson is that ",
 StyleBox["tracing out",
  FontWeight->"Bold"],
 " an inaccessible partner turns pure into mixed. That is decoherence in one \
move."
}], "Text",ExpressionUUID->"7d3a9082-ff85-4430-be2c-8caa60c79c77"],

Cell[TextData[{
 "For Markovian environments, the dynamics of ",
 Cell[BoxData[
  StyleBox["\[Rho]", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "ab62273e-0c7e-4c24-a50c-fe9044eae672"],
 " obey the ",
 StyleBox["Lindblad master equation",
  FontWeight->"Bold"],
 ", and ",
 Cell[BoxData[
 "QuantumEvolve"], "InlineFormula",ExpressionUUID->
  "74d9fad9-b225-485f-b967-2a542652cf6a"],
 " integrates it when you supply collapse (jump) operators as a rule ",
 Cell[BoxData[
  RowBox[{
   RowBox[{"{", "L", "}"}], " ", "->", " ", 
   RowBox[{"{", "rate", "}"}]}]], "InlineFormula",ExpressionUUID->
  "2704cf5b-d416-499b-84cd-885dd3e57bbf"],
 " together with an initial density matrix. The two canonical processes are \
energy decay (",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["T", "TI"], "1"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "89db3f69-0240-427f-b5b1-78d0f07d65d1"],
 ") and dephasing (",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["T", "TI"], "2"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "5411f7b7-3e85-4866-b0cf-331aba66113b"],
 ")."
}], "Text",ExpressionUUID->"0c92abf8-eebb-4c00-9c87-a4bdbe5ef02c"],

Cell[TextData[{
 "Energy relaxation: the excited state decays to the ground state. The jump \
operator is the qubit lowering operator ",
 Cell[BoxData[
  RowBox[{
   SuperscriptBox[
    StyleBox["\[Sigma]", "TI"], "-"], "=", 
   RowBox[{
    TemplateBox[{"0"},
     "Ket"], 
    TemplateBox[{"1"},
     "Bra"]}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "000d8b9e-9b04-41ee-a53b-8ea0973cdb8a"],
 ", which is ",
 Cell[BoxData[
  RowBox[{"AnnihilationOperator", "[", "2", "]"}]], "InlineFormula",
  ExpressionUUID->"84538a4f-2a2e-4684-8383-d154336aa21c"],
 ". With no coherent drive the Hamiltonian is zero, written natively as ",
 Cell[BoxData[
  RowBox[{"0", " ", 
   RowBox[{"QuantumOperator", "[", "\"\<I\>\"", "]"}]}]], "InlineFormula",
  ExpressionUUID->"9040cf19-6687-4476-bcec-b156f29f1d3f"],
 ". Evolve ",
 Cell[BoxData[
  TemplateBox[{"1"},
   "Ket"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "03018b2e-54ea-4a5f-87a7-8f76f392f785"],
 " at rate ",
 Cell[BoxData[
  RowBox[{
   StyleBox["\[Gamma]", "TI"], "=", "1"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "d73ad771-7e5d-4e4c-a6fe-095362c60da8"],
 " and read the excited population:"
}], "Text",ExpressionUUID->"a5652da7-c7d9-493b-b72c-96c0891fc3ee"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"Hzero", " ", "=", " ", 
   RowBox[{"0", " ", 
    RowBox[{"QuantumOperator", "[", "\"\<I\>\"", "]"}]}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"sm", " ", "=", " ", 
   RowBox[{"AnnihilationOperator", "[", "2", "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"t1", " ", "=", " ", 
   RowBox[{"QuantumEvolve", "[", 
    RowBox[{"Hzero", ",", " ", 
     RowBox[{
      RowBox[{"{", "sm", "}"}], " ", "->", " ", 
      RowBox[{"{", "1", "}"}]}], ",", " ", 
     RowBox[{"QuantumState", "[", "\"\<1\>\"", "]"}], ",", " ", 
     RowBox[{"{", 
      RowBox[{"t", ",", " ", "0", ",", " ", "3"}], "}"}]}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"p1", "[", "tt_", "]"}], " ", ":=", " ", 
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{"t1", "[", 
       RowBox[{"<|", 
        RowBox[{"t", " ", "->", " ", "tt"}], "|>"}], "]"}], 
      "[", "\"\<ProbabilitiesList\>\"", "]"}], "[", 
     RowBox[{"[", "2", "]"}], "]"}], " ", "//", " ", "Chop"}]}], 
  ";"}], "\n", 
 RowBox[{"{", 
  RowBox[{
   RowBox[{"p1", "[", "0", "]"}], ",", " ", 
   RowBox[{"p1", "[", "1.", "]"}], ",", " ", 
   RowBox[{"p1", "[", "2.", "]"}]}], "}"}]}], "Input",
 CellLabel->
  "In[33]:= ",ExpressionUUID->"f258be88-64e9-49d8-b82a-79f46df1fd9e"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"1.`", ",", "0.3678766862006472`", ",", "0.13533458165972925`"}], 
  "}"}]], "Output",
 CellLabel->
  "Out[33]= ",ExpressionUUID->"689a83f9-cd28-4498-808c-8f2b08ce455b"]
}, Open  ]],

Cell[TextData[{
 "The populations ",
 Cell[BoxData[
  RowBox[{"{", 
   RowBox[{"1.", ",", " ", "0.368", ",", " ", "0.135"}], "}"}]], 
  "InlineFormula",ExpressionUUID->"353cc13f-04f7-4a6b-81f8-cbb1bb225e00"],
 " trace out ",
 Cell[BoxData[
  RowBox[{
   SubscriptBox[
    StyleBox["P", "TI"], "1"], 
   StyleBox["(",
    SpanMaxSize->1], 
   StyleBox["t", "TI"], 
   StyleBox[")",
    SpanMaxSize->1], "=", 
   SuperscriptBox[
    StyleBox["e", "TI"], 
    RowBox[{"-", 
     StyleBox["\[Gamma]", "TI"], 
     StyleBox["t", "TI"]}]]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "30cc56ca-4063-4211-8289-e3b87f8bbefe"],
 " exactly: exponential decay with lifetime ",
 Cell[BoxData[
  RowBox[{
   SubscriptBox[
    StyleBox["T", "TI"], "1"], "=", "1", "/", 
   StyleBox["\[Gamma]", "TI"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "125c61fd-6f2a-45aa-b950-9bfe8d358bc9"],
 "."
}], "Text",ExpressionUUID->"eeb805d7-8d2c-477f-b9ec-4dc7e864b09e"],

Cell[TextData[{
 "Dephasing: the populations survive but the ",
 StyleBox["coherence",
  FontWeight->"Bold"],
 " between ",
 Cell[BoxData[
  TemplateBox[{"0"},
   "Ket"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "11499370-76a6-45ab-8246-e25680a21913"],
 " and ",
 Cell[BoxData[
  TemplateBox[{"1"},
   "Ket"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "2f8947ee-798d-4173-b0cf-197f3b4cc0ff"],
 " decays, randomizing the phase. The jump operator is ",
 Cell[BoxData[
  StyleBox["Z", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "40b09474-0972-4339-a2e5-43a76f059865"],
 ". Evolve ",
 Cell[BoxData[
  TemplateBox[{"+"},
   "Ket"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "58495799-4c70-4519-b380-f7a32a19937e"],
 " and watch the Bloch vector's transverse component collapse:"
}], "Text",ExpressionUUID->"6b338872-6dc3-4c1c-8d71-d07c6f2a925d"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"t2", " ", "=", " ", 
   RowBox[{"QuantumEvolve", "[", 
    RowBox[{"Hzero", ",", " ", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"QuantumOperator", "[", "\"\<Z\>\"", "]"}], "}"}], " ", "->", 
      " ", 
      RowBox[{"{", "1", "}"}]}], ",", " ", 
     RowBox[{"QuantumState", "[", "\"\<+\>\"", "]"}], ",", " ", 
     RowBox[{"{", 
      RowBox[{"t", ",", " ", "0", ",", " ", "2"}], "}"}]}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"bx", "[", "tt_", "]"}], " ", ":=", " ", 
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{"t2", "[", 
       RowBox[{"<|", 
        RowBox[{"t", " ", "->", " ", "tt"}], "|>"}], "]"}], 
      "[", "\"\<BlochVector\>\"", "]"}], "[", 
     RowBox[{"[", "1", "]"}], "]"}], " ", "//", " ", "Chop"}]}], 
  ";"}], "\n", 
 RowBox[{"{", 
  RowBox[{
   RowBox[{"bx", "[", "0", "]"}], ",", " ", 
   RowBox[{"bx", "[", "0.5", "]"}], ",", " ", 
   RowBox[{"bx", "[", "1.", "]"}]}], "}"}]}], "Input",
 CellLabel->
  "In[34]:= ",ExpressionUUID->"b60c889d-eb74-4dc0-bae0-5b612926740a"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"1.`", ",", "0.36787858729627604`", ",", "0.13533435961982623`"}], 
  "}"}]], "Output",
 CellLabel->
  "Out[34]= ",ExpressionUUID->"8d4469cf-625b-469f-bff0-db990505246f"]
}, Open  ]],

Cell[TextData[{
 "The transverse Bloch component ",
 Cell[BoxData[
  RowBox[{"{", 
   RowBox[{"1.", ",", " ", "0.368", ",", " ", "0.135"}], "}"}]], 
  "InlineFormula",ExpressionUUID->"b07624c8-c0cc-49bd-92dd-2d2d44861863"],
 " decays as ",
 Cell[BoxData[
  SuperscriptBox[
   StyleBox["e", "TI"], 
   RowBox[{"-", "2", 
    StyleBox["\[Gamma]", "TI"], 
    StyleBox["t", "TI"]}]]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "13db2c53-2c29-42d9-8035-6d40c8a4b865"],
 " while the populations (the ",
 Cell[BoxData[
  StyleBox["z", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "1b133352-2e04-4572-9c90-1e1c0876a062"],
 "-component) stay put. On the Bloch sphere the arrow spirals inward toward \
the ",
 Cell[BoxData[
  StyleBox["z", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "38832fe9-42d0-4e0a-8a88-3e7907e60e65"],
 "-axis: the state is losing the phase coherence that lets it interfere, \
while its energy populations survive intact. This is the visual the course \
uses to make decoherence physical, and it is exactly the process the sensor \
of Part 9 must outrun."
}], "Text",ExpressionUUID->"af8287ef-93de-4cc4-a926-1e5af06885c4"],

Cell[TextData[{
 "It is often cleaner to think of a noise process as a ",
 StyleBox["channel",
  FontWeight->"Bold"],
 ", a map that sends states to states in one shot, summarizing the \
environment without time-resolving it. The framework's ",
 Cell[BoxData[
 "QuantumChannel"], "InlineFormula",ExpressionUUID->
  "a512978c-a891-4331-9ce1-1e530032b53d"],
 " carries the standard qubit noise models. Each one moves the Bloch vector \
in a characteristic way:"
}], "Text",ExpressionUUID->"a23fb949-a776-492d-bfe6-9928d43b9fa2"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"{", "\n", "  ", 
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{"QuantumChannel", "[", 
       RowBox[{"\"\<BitFlip\>\"", "[", "0.1", "]"}], "]"}], "[", 
      RowBox[{"QuantumState", "[", "\"\<0\>\"", "]"}], "]"}], 
     "[", "\"\<ProbabilitiesList\>\"", "]"}], ",", "\n", "  ", 
    RowBox[{
     RowBox[{
      RowBox[{"QuantumChannel", "[", 
       RowBox[{"\"\<AmplitudeDamping\>\"", "[", "0.3", "]"}], "]"}], "[", 
      RowBox[{"QuantumState", "[", "\"\<1\>\"", "]"}], "]"}], 
     "[", "\"\<ProbabilitiesList\>\"", "]"}], ",", "\n", "  ", 
    RowBox[{
     RowBox[{
      RowBox[{"QuantumChannel", "[", 
       RowBox[{"\"\<Depolarizing\>\"", "[", "0.4", "]"}], "]"}], "[", 
      RowBox[{"QuantumState", "[", "\"\<+\>\"", "]"}], "]"}], 
     "[", "\"\<BlochVector\>\"", "]"}], ",", "\n", "  ", 
    RowBox[{
     RowBox[{
      RowBox[{"QuantumChannel", "[", 
       RowBox[{"\"\<PhaseDamping\>\"", "[", "0.5", "]"}], "]"}], "[", 
      RowBox[{"QuantumState", "[", "\"\<+\>\"", "]"}], "]"}], 
     "[", "\"\<BlochVector\>\"", "]"}]}], "\n", "}"}], " ", "//", " ", 
  "Chop"}]], "Input",
 CellLabel->
  "In[35]:= ",ExpressionUUID->"1819890e-92c8-4410-b479-ec6d3154935d"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"0.9`", ",", "0.10000000000000002`"}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{"0.29999999999999993`", ",", "0.7000000000000001`"}], "}"}], ",", 
   
   RowBox[{"{", 
    RowBox[{"0.6`", ",", "0", ",", "0"}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{"0.7071067811865475`", ",", "0", ",", "0"}], "}"}]}], 
  "}"}]], "Output",
 CellLabel->
  "Out[35]= ",ExpressionUUID->"9915a84f-0ed0-4b50-9254-7e64511454b7"]
}, Open  ]],

Cell[TextData[{
 "Reading the four results: a bit-flip with probability ",
 Cell[BoxData["0.1"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "76bea936-a2e2-41f5-90c1-3ee093a9397d"],
 " leaves ",
 Cell[BoxData[
  TemplateBox[{"0"},
   "Ket"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "9bc0e8d8-0e8a-4a09-a2af-29d799ba4390"],
 " as the mixture ",
 Cell[BoxData[
  RowBox[{
   RowBox[{"{", "0.9"}], 
   RowBox[{",", "\[ThinSpace]"}], 
   RowBox[{"0.1", "}"}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "3f47cab6-794f-44c4-923c-597ff0beba99"],
 "; amplitude damping with strength ",
 Cell[BoxData["0.3"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "49c72fbf-acf2-4e86-8881-a187a233c8c3"],
 " partially relaxes ",
 Cell[BoxData[
  TemplateBox[{"1"},
   "Ket"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "730415b7-e1fc-4f8d-9b26-d9f1063b6e50"],
 " toward the ground state, giving populations ",
 Cell[BoxData[
  RowBox[{
   RowBox[{"{", "0.3"}], 
   RowBox[{",", "\[ThinSpace]"}], 
   RowBox[{"0.7", "}"}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "f9c54264-8b4f-4254-b303-3ea364a80d63"],
 "; depolarizing shrinks the Bloch vector of ",
 Cell[BoxData[
  TemplateBox[{"+"},
   "Ket"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "efecc5ff-2dce-4570-8184-80f8c0bff052"],
 " by the factor ",
 Cell[BoxData[
  RowBox[{"1", "-", 
   StyleBox["p", "TI"], "=", "0.6"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "d12d497a-6436-43ca-8f12-793e56d3cfbe"],
 ", toward the maximally mixed center; and phase damping multiplies the \
transverse coherence by ",
 Cell[BoxData[
  RowBox[{
   SqrtBox[
    RowBox[{"1", "-", 
     StyleBox["\[Lambda]", "TI"]}]], "=", 
   SqrtBox["0.5"], "\[TildeTilde]", "0.707"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "472e4467-fbde-40c0-9a31-972c329e542c"],
 " while leaving populations untouched. The channel picture and the Lindblad \
picture are two views of the same decoherence; the channel is what you apply \
once per gate, the master equation is what you integrate over continuous time."
}], "Text",ExpressionUUID->"f2a1d63d-026e-4f83-b82a-58d32b3d3527"],

Cell["Part 9 \[LongDash] Quantum sensing (Lab 4)", "Section",ExpressionUUID->"c43b5b45-af74-4f15-a1e4-71039387a7a5"],

Cell[TextData[{
 StyleBox["Course map:",
  FontWeight->"Bold"],
 " Week 11 (multi-level open systems as sensors, NV magnetometry, Rydberg \
electrometry) and ",
 StyleBox["Lab 4 (magnetometry / impact of noise)",
  FontWeight->"Bold"],
 "."
}], "Text",
 CellFrame->{{3, 0}, {0, 0}},
 CellMargins->{{40, 10}, {7, 7}},
 CellFrameMargins->10,
 CellFrameColor->GrayLevel[0.55],
 FontSlant->"Italic",
 FontColor->LightDarkSwitched[
   GrayLevel[0.45], 
   GrayLevel[0.65]],
 Background->LightDarkSwitched[
   GrayLevel[0.96], 
   GrayLevel[0.2]],ExpressionUUID->"928401cf-2e5e-42a3-806b-781492883d4f"],

Cell[TextData[{
 "Quantum sensing turns the fragility of Part 8 into an asset. A qubit whose \
energy splitting depends on an external field is a field meter: let it \
accumulate phase, and read the field off the phase. The standard protocol is ",
 StyleBox["Ramsey interferometry",
  FontWeight->"Bold"],
 ". A ",
 Cell[BoxData[
  RowBox[{"\[Pi]", "/", "2"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "a079fc65-53e2-455e-a3dc-198d97a3f405"],
 "-pulse puts the qubit on the equator, the qubit then precesses for a time \
",
 Cell[BoxData[
  StyleBox["\[Tau]", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "0af5dc18-0e79-43bd-95f1-cbf9f713a5e5"],
 " and accumulates a phase ",
 Cell[BoxData[
  StyleBox["\[Phi]", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "ace04cc4-4bce-463d-a746-6f21ea9903b7"],
 " proportional to the field, and a second ",
 Cell[BoxData[
  RowBox[{"\[Pi]", "/", "2"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "906009cc-46f2-4d28-8413-abc8435a8e6c"],
 "-pulse converts that phase into a population we can measure."
}], "Text",ExpressionUUID->"c508c888-a54b-4409-9738-559a847846f1"],

Cell[TextData[{
 "Model the sequence with two Hadamards bracketing a phase gate ",
 Cell[BoxData[
  RowBox[{
   StyleBox["P", "TI"], 
   StyleBox["(",
    SpanMaxSize->1], 
   StyleBox["\[Phi]", "TI"], 
   StyleBox[")",
    SpanMaxSize->1], "=", 
   StyleBox["diag",
    FontSlant->"Plain"], 
   StyleBox["(",
    SpanMaxSize->1], 
   RowBox[{"1", 
    RowBox[{",", "\[ThinSpace]"}], 
    SuperscriptBox[
     StyleBox["e", "TI"], 
     StyleBox[
      RowBox[{"i", "\[Phi]"}], "TI"]]}], 
   StyleBox[")",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "337f05b0-c25c-4ace-91e5-e0bed5106f26"],
 ", and read the ground-state probability:"
}], "Text",ExpressionUUID->"9424be69-a05c-41d1-abc8-0c7c0d52530e"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"ramsey", " ", "=", " ", 
   RowBox[{"QuantumCircuitOperator", "[", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"\"\<H\>\"", " ", "->", " ", "1"}], ",", " ", 
      RowBox[{
       RowBox[{"\"\<P\>\"", "[", "\[Phi]", "]"}], " ", "->", " ", "1"}], ",", 
      " ", 
      RowBox[{"\"\<H\>\"", " ", "->", " ", "1"}]}], "}"}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"out", " ", "=", " ", 
   RowBox[{"ramsey", "[", 
    RowBox[{"QuantumState", "[", "\"\<0\>\"", "]"}], "]"}]}], ";"}], "\n", 
 RowBox[{"P0", " ", "=", " ", 
  RowBox[{"FullSimplify", "[", 
   RowBox[{
    RowBox[{
     RowBox[{"out", "[", "\"\<ProbabilitiesList\>\"", "]"}], "[", 
     RowBox[{"[", "1", "]"}], "]"}], ",", " ", 
    RowBox[{"Assumptions", " ", "->", " ", 
     RowBox[{"\[Phi]", " ", "\[Element]", " ", "Reals"}]}]}], 
   "]"}]}]}], "Input",
 CellLabel->
  "In[36]:= ",ExpressionUUID->"bb8668cd-8329-43a1-9163-93ee96af4fe9"],

Cell[BoxData[
 SuperscriptBox[
  RowBox[{"Cos", "[", 
   FractionBox["\[Phi]", "2"], "]"}], "2"]], "Output",
 CellLabel->
  "Out[36]= ",ExpressionUUID->"9434453c-de91-4a84-86d0-8bc686fbd68b"]
}, Open  ]],

Cell[TextData[{
 "The framework returns ",
 Cell[BoxData[
  RowBox[{
   SubscriptBox[
    StyleBox["P", "TI"], "0"], 
   StyleBox["(",
    SpanMaxSize->1], 
   StyleBox["\[Phi]", "TI"], 
   StyleBox[")",
    SpanMaxSize->1], "=", 
   SuperscriptBox[
    StyleBox["cos",
     FontSlant->"Plain"], "2"], "\[ThinSpace]", 
   StyleBox["(",
    SpanMaxSize->1], 
   RowBox[{
    StyleBox["\[Phi]", "TI"], "/", "2"}], 
   StyleBox[")",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "4bd4af6c-b75f-4a59-999f-2b90cb404cb0"],
 ": a textbook ",
 StyleBox["Ramsey fringe",
  FontWeight->"Bold"],
 ". Since the accumulated phase is ",
 Cell[BoxData[
  RowBox[{
   StyleBox["\[Phi]", "TI"], "=", 
   SubscriptBox[
    StyleBox["\[Gamma]", "TI"], 
    StyleBox["q", "TI"]], 
   StyleBox["B", "TI"], " ", 
   StyleBox["\[Tau]", "TI"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "d2b9612e-9c43-4d72-9663-bec095d9aa88"],
 " for a magnetic field ",
 Cell[BoxData[
  StyleBox["B", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "9a369eb4-c7ae-4536-be4c-fd4f42a9645c"],
 " (with ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["\[Gamma]", "TI"], 
   StyleBox["q", "TI"]]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "ba747c2b-9e9e-4688-94eb-348d97f28c5e"],
 " the qubit's gyromagnetic ratio), the measured probability oscillates with \
the field. Counting fringes measures ",
 Cell[BoxData[
  StyleBox["B", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "9e1feb53-cd97-4682-9046-c562c66a42f6"],
 "."
}], "Text",ExpressionUUID->"6a8d987d-0407-4600-b5b0-afd5d08bac4e"],

Cell[TextData[{
 "The precision is set by how steeply the signal responds to the phase. \
Compute the sensitivity ",
 Cell[BoxData[
  RowBox[{"\[PartialD]", 
   SubscriptBox[
    StyleBox["P", "TI"], "0"], "/", "\[PartialD]", 
   StyleBox["\[Phi]", "TI"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "615e2df1-2244-412a-a25d-8ab91894c6fc"],
 ":"
}], "Text",ExpressionUUID->"2355f8e4-6675-48e0-ba06-90a7d2b29c7d"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"D", "[", 
   RowBox[{"P0", ",", " ", "\[Phi]"}], "]"}], " ", "//", " ", 
  "FullSimplify"}]], "Input",
 CellLabel->
  "In[37]:= ",ExpressionUUID->"7d3cd091-543f-4adb-a17f-9c75f961bd54"],

Cell[BoxData[
 RowBox[{"-", 
  FractionBox[
   RowBox[{"Sin", "[", "\[Phi]", "]"}], "2"]}]], "Output",
 CellLabel->
  "Out[37]= ",ExpressionUUID->"2b3c3e21-990a-43e2-b362-d8c6c02e762b"]
}, Open  ]],

Cell[TextData[{
 "This is ",
 Cell[BoxData[
  RowBox[{"-", 
   FractionBox["1", "2"], 
   StyleBox["sin",
    FontSlant->"Plain"], "\[ThinSpace]", 
   StyleBox["\[Phi]", "TI"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "ccc6eab6-2a8f-47fd-9eab-efa3842eafc2"],
 ", which is largest in magnitude at ",
 Cell[BoxData[
  RowBox[{
   StyleBox["\[Phi]", "TI"], "=", "\[Pi]", "/", "2"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "779aef71-e690-4df3-a22a-25dc1c89bfa6"],
 ". A well-designed magnetometer biases the interferometer to that steepest \
point, where a tiny change in field produces the largest change in signal."
}], "Text",ExpressionUUID->"22c3fc1e-903a-4bcd-b0f6-e33ac8a91893"],

Cell[TextData[{
 "Decoherence is what ultimately limits the sensitivity, which is exactly why \
Lab 4 pairs magnetometry with noise. During the free-evolution time ",
 Cell[BoxData[
  StyleBox["\[Tau]", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "8755ce8c-83a5-461b-9dfb-b980469321a2"],
 ", dephasing erodes the fringe ",
 StyleBox["contrast",
  FontWeight->"Bold"],
 ". Add a dephasing jump operator during the precession and track the \
transverse Bloch length, which is the contrast:"
}], "Text",ExpressionUUID->"6b47095b-1d3c-46a4-bf4d-820dbe53fab2"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"free", " ", "=", " ", 
   RowBox[{"QuantumEvolve", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"(", 
       RowBox[{"1", "/", "2"}], ")"}], " ", 
      RowBox[{"QuantumOperator", "[", "\"\<Z\>\"", "]"}]}], ",", " ", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"QuantumOperator", "[", "\"\<Z\>\"", "]"}], "}"}], " ", "->", 
      " ", 
      RowBox[{"{", "0.3", "}"}]}], ",", "\n", "   ", 
     RowBox[{"QuantumState", "[", "\"\<+\>\"", "]"}], ",", " ", 
     RowBox[{"{", 
      RowBox[{"t", ",", " ", "0", ",", " ", "6"}], "}"}]}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"Table", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"tt", ",", " ", 
      RowBox[{"Norm", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"free", "[", 
          RowBox[{"<|", 
           RowBox[{"t", " ", "->", " ", "tt"}], "|>"}], "]"}], 
         "[", "\"\<BlochVector\>\"", "]"}], "[", 
        RowBox[{"[", 
         RowBox[{"1", " ", ";;", " ", "2"}], "]"}], "]"}], "]"}]}], "}"}], ",",
     " ", 
    RowBox[{"{", 
     RowBox[{"tt", ",", " ", "0", ",", " ", "6", ",", " ", "1.5"}], "}"}]}], 
   "]"}], " ", "//", " ", "Chop"}]}], "Input",
 CellLabel->
  "In[38]:= ",ExpressionUUID->"9ddd9e0d-dc07-48fd-b09a-a42c6fdb17a7"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"0", ",", "1.`"}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{"1.5`", ",", "0.40656992040570766`"}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{"3.`", ",", "0.1653002161976581`"}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{"4.5`", ",", "0.0672068827664922`"}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{"6.`", ",", "0.027323708691246146`"}], "}"}]}], "}"}]], "Output",
 CellLabel->
  "Out[38]= ",ExpressionUUID->"e52a08de-4626-45c3-9704-54bc8b009ce0"]
}, Open  ]],

Cell[TextData[{
 "The contrast falls off as ",
 Cell[BoxData[
  SuperscriptBox[
   StyleBox["e", "TI"], 
   RowBox[{"-", "2", 
    StyleBox["\[Gamma]", "TI"], 
    StyleBox["\[Tau]", "TI"]}]]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "d8c9d2d3-d441-44bb-a47c-c42a747f0156"],
 ", from ",
 Cell[BoxData["1"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "13eabd8f-72d9-413d-9a7a-90a24978bbd7"],
 " at ",
 Cell[BoxData[
  RowBox[{
   StyleBox["\[Tau]", "TI"], "=", "0"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "162887bb-716a-45f7-b515-6d593f05ce18"],
 " to about ",
 Cell[BoxData["0.027"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "e544051f-cffc-415c-b909-fd7962d8ed26"],
 " by ",
 Cell[BoxData[
  RowBox[{
   StyleBox["\[Tau]", "TI"], "=", "6"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "17db449e-b918-4751-9ccb-bf1d28a47b2d"],
 ". There is a sweet spot: you want the longest interrogation time ",
 Cell[BoxData[
  StyleBox["\[Tau]", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "048db568-f50d-4d3d-8263-fb19e1993239"],
 " to accumulate the most phase, but only up to the coherence time ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["T", "TI"], "2"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "a3f3caa6-ae92-46bd-a1ff-e6f0d897f715"],
 ", beyond which the fringe washes out and information stops accumulating. \
The optimal ",
 Cell[BoxData[
  RowBox[{
   StyleBox["\[Tau]", "TI"], "\[Tilde]", 
   SubscriptBox[
    StyleBox["T", "TI"], "2"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "4656959c-35b0-4bb4-817b-2296a7a21ad0"],
 " is the central design trade-off in quantum sensing, and it is the same ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["T", "TI"], "2"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "6ebe7005-0402-4409-b3f3-9a3a0156dd10"],
 " we computed in Part 8. A nitrogen-vacancy center in diamond is one \
physical realization of exactly this qubit-magnetometer, with ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["T", "TI"], "2"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "350263a0-1b89-4fb9-93bb-ef297148c4e0"],
 " set by the surrounding nuclear spin bath."
}], "Text",ExpressionUUID->"281af69d-798c-42d7-ab16-53c25c309a3e"],

Cell["Where this leaves us", "Section",ExpressionUUID->"2d39a986-59a3-401c-89e6-0aab277d07b3"],

Cell["\<\
We have rebuilt the spine of the unit as a sequence of computations. Along \
the way we constructed a reusable toolkit, all of it in one framework:\
\>", "Text",ExpressionUUID->"80332fc4-e2a3-48ab-b571-b6c1579c3024"],

Cell[TextData[{
 StyleBox["The object model.",
  FontWeight->"Bold"],
 " Every quantity came from asking an object a question: ",
 Cell[BoxData[
  RowBox[{"[", "\"\<HermitianQ\>\"", "]"}]], "InlineFormula",ExpressionUUID->
  "bea43215-ca3a-4d21-9af4-3c25fd39f31b"],
 ", ",
 Cell[BoxData[
  RowBox[{"[", "\"\<UnitaryQ\>\"", "]"}]], "InlineFormula",ExpressionUUID->
  "71208971-5b1f-4e14-9e19-018482dea11f"],
 ", ",
 Cell[BoxData[
  RowBox[{"[", "\"\<BlochVector\>\"", "]"}]], "InlineFormula",ExpressionUUID->
  "139bf9a2-706c-45f9-a727-0f93992e5bf4"],
 ", ",
 Cell[BoxData[
  RowBox[{"[", "\"\<Purity\>\"", "]"}]], "InlineFormula",ExpressionUUID->
  "b9d833a2-bd3c-4d27-8224-a82176dfbe1d"],
 ", ",
 Cell[BoxData[
  RowBox[{"[", "\"\<PureStateQ\>\"", "]"}]], "InlineFormula",ExpressionUUID->
  "cfe46d19-707e-4e4a-9241-e14effc4effa"],
 ", ",
 Cell[BoxData[
  RowBox[{"[", "\"\<ProbabilitiesList\>\"", "]"}]], "InlineFormula",
  ExpressionUUID->"0f0c09bd-cb87-4f91-9487-39196248b0e8"],
 ", plus ",
 Cell[BoxData[
 "OperatorVariance"], "InlineFormula",ExpressionUUID->
  "46a7140c-7776-4758-a51d-fba4195e7276"],
 ", ",
 Cell[BoxData[
 "Commutator"], "InlineFormula",ExpressionUUID->
  "0451f8da-3c77-4faf-ad8a-fc422d234d1d"],
 ", ",
 Cell[BoxData[
 "G2Coherence"], "InlineFormula",ExpressionUUID->
  "8ff07160-1fac-440e-a2e7-152322a05bec"],
 ", and ",
 Cell[BoxData[
 "QuantumEntanglementMonotone"], "InlineFormula",ExpressionUUID->
  "13a6927c-1bb8-4ebe-8495-779495f1e005"],
 ". We built matrices only to ",
 StyleBox["create", "TI"],
 " operators, never to interrogate them."
}], "Item",ExpressionUUID->"0b114595-c47c-4717-9110-88c4894cb8ac"],

Cell[TextData[{
 StyleBox["States and observables.",
  FontWeight->"Bold"],
 " ",
 Cell[BoxData[
 "QuantumState"], "InlineFormula",ExpressionUUID->
  "5dfbb810-9b33-4c78-b722-79c5a9778feb"],
 " for kets and density matrices; ",
 Cell[BoxData[
 "QuantumOperator"], "InlineFormula",ExpressionUUID->
  "4f05c4ed-5265-4166-afc3-a6e20918e554"],
 " for observables, Hamiltonians, and gates; expectation values and overlaps \
from ",
 Cell[BoxData[
  RowBox[{
   RowBox[{"(", 
    RowBox[{
     RowBox[{"bra", "[", "\"\<Dagger\>\"", "]"}], " ", "@", " ", "ket"}], 
    ")"}], "[", "\"\<Scalar\>\"", "]"}]], "InlineFormula",ExpressionUUID->
  "461c8663-5f8e-4a65-a43e-fcc6a24a50d3"],
 "."
}], "Item",ExpressionUUID->"897a13ab-a179-4e37-8e63-331840f55704"],

Cell[TextData[{
 StyleBox["Dynamics.",
  FontWeight->"Bold"],
 " ",
 Cell[BoxData[
 "QuantumEvolve"], "InlineFormula",ExpressionUUID->
  "6f306336-43bb-44b5-9968-0e2bc4c3f5d1"],
 " for closed-form unitary evolution (no time range), numerically integrated \
trajectories (with a range), the Heisenberg picture (pass an observable), and \
Lindblad master equations (pass jump operators), in any picture."
}], "Item",ExpressionUUID->"e87f5bc0-a294-4ad9-8c9f-42ac72cdec8c"],

Cell[TextData[{
 StyleBox["The two model systems.",
  FontWeight->"Bold"],
 " The driven qubit with its resonant and detuned Rabi flopping, on the Bloch \
sphere; the harmonic oscillator with ladder operators, Fock and coherent \
states, the ",
 Cell[BoxData[
  RowBox[{
   SuperscriptBox[
    StyleBox["g", "TI"], 
    RowBox[{
     StyleBox["(",
      SpanMaxSize->1], "2", 
     StyleBox[")",
      SpanMaxSize->1]}]], 
   StyleBox["(",
    SpanMaxSize->1], "0", 
   StyleBox[")",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "691a2499-fb09-46ba-b8d3-2acca1205774"],
 " test for nonclassical light, quadrature uncertainty, and Jaynes-Cummings \
light-matter coupling."
}], "Item",ExpressionUUID->"23885c63-de18-4279-b8ca-eb3667a957d5"],

Cell[TextData[{
 StyleBox["Computing and communication.",
  FontWeight->"Bold"],
 " Tensor products, gate circuits, Bell and GHZ entanglement, the no-cloning \
obstruction, and teleportation verified at unit fidelity."
}], "Item",ExpressionUUID->"bcc3a1ef-eaee-401b-866f-beb0db10923b"],

Cell[TextData[{
 StyleBox["Open systems and sensing.",
  FontWeight->"Bold"],
 " Mixed states and entropy; the Lindblad master equation for ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["T", "TI"], "1"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "fff05d60-ef84-43bd-a124-01b94b5f3979"],
 " and ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["T", "TI"], "2"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "5c775f33-6f5d-4b1f-984d-8c783e37ab7f"],
 "; the standard noise channels; and Ramsey magnetometry whose precision is \
bounded by the very decoherence we modeled."
}], "Item",ExpressionUUID->"803b0c6f-2944-4aef-bbdc-118a0e8fa12a"],

Cell["\<\
The hardware-independent intuition is the takeaway the unit promises: nothing \
above committed to a platform, yet everything is a faithful, runnable model \
of what superconducting qubits, trapped ions, photonic modes, and NV centers \
actually do. To go further, swap in real device parameters, push the circuits \
to more qubits, replace the idealized channels with measured noise spectra, \
or send a circuit to real hardware. The framework that drew the Bloch sphere \
will also talk to a quantum processor.\
\>", "Text",ExpressionUUID->"a0decdc3-9811-44bc-ad0b-0161bb1fa718"],

Cell["The four labs, worked end to end", "Section",ExpressionUUID->"efa3be54-415a-42ca-89ea-841416c229d2"],

Cell["\<\
The unit's assessment includes four Python labs. Here is each one, built as a \
self-contained QuantumFramework computation you can run and extend. They draw \
on the parts above but stand on their own.\
\>", "Text",ExpressionUUID->"a83b7f7f-5724-4cd2-8e3e-7d0f44078331"],

Cell[BoxData[GridBox[{
   {Cell["      ", "ModInfo",ExpressionUUID->
     "906899f5-b8c1-4bf7-8d0a-4c50dc095c1f"], Cell["Lab", "TableText",
     FontWeight->Bold,ExpressionUUID->"e1647b3c-4e62-4873-a945-5765a9d1cbdb"],
     Cell["Course topic", "TableText",
     FontWeight->Bold,ExpressionUUID->"c4729414-d205-4e16-a581-24bb69077d97"],
     Cell["Section above", "TableText",
     FontWeight->Bold,ExpressionUUID->"f149a02a-144e-4093-abff-7d8434179dc2"]},
   {Cell["      ", "ModInfo",ExpressionUUID->
     "416c317d-6f6f-4ac3-829d-94b5efd2339d"], Cell[TextData[StyleBox["Lab 1",
     FontWeight->"Bold"]], "TableText",ExpressionUUID->
     "0f259e8c-80cc-404c-a8d7-94b66821467e"], Cell[
    "1-D particle in a box (finite/infinite well)", "TableText",
     ExpressionUUID->"bd6d3fa3-b2c4-43f7-9d39-d3a0c133e442"], Cell[
    "Part 1 (infinite well) + below (finite well)", "TableText",
     ExpressionUUID->"4926258f-9d71-4718-b165-1286bfadb994"]},
   {Cell["      ", "ModInfo",ExpressionUUID->
     "360e691a-3d29-4132-9ac0-c2773c2b71ed"], Cell[TextData[StyleBox["Lab 2",
     FontWeight->"Bold"]], "TableText",ExpressionUUID->
     "4ebc798c-55d9-40ba-bf89-2288d728496b"], Cell[
    "Rabi flopping of an ideal qubit (resonant/non-resonant)", "TableText",
     ExpressionUUID->"44328913-4be9-4cf7-be16-7cd9d8166d16"], Cell[
    "Part 4", "TableText",ExpressionUUID->
     "81bc9aba-604e-48fb-86c8-c818423005f3"]},
   {Cell["      ", "ModInfo",ExpressionUUID->
     "ee8ca0a2-40e1-47f0-9372-0bca930df296"], Cell[TextData[StyleBox["Lab 3",
     FontWeight->"Bold"]], "TableText",ExpressionUUID->
     "fef09d1f-0c2a-4e9c-ac31-65852143ffb2"], Cell[
    "Quantum teleportation / a simple circuit", "TableText",ExpressionUUID->
     "aa084e24-875a-48df-8c55-d7654914625b"], Cell[
    "Parts 6-7 (teleportation) + below (half-adder)", "TableText",
     ExpressionUUID->"ff7fa15b-8899-40ac-9a6d-d8380294edbe"]},
   {Cell["      ", "ModInfo",ExpressionUUID->
     "441c32be-0791-4046-acc9-5acc84580bf1"], Cell[TextData[StyleBox["Lab 4",
     FontWeight->"Bold"]], "TableText",ExpressionUUID->
     "8dc7df5b-f467-4d44-a54b-db89c094f189"], Cell[
    "Quantum magnetometry / impact of noise", "TableText",ExpressionUUID->
     "deed67b4-80c6-4a9d-ba52-6d3646c86d73"], Cell[
    "Part 9", "TableText",ExpressionUUID->
     "8d5a0928-1e4e-4b7c-b44e-b0a2f7a2b01f"]}
  }]], "3ColumnTableMod",ExpressionUUID->"f7fe1d02-0d72-4fea-b53d-\
9b9ec38004d0"],

Cell["Lab 1 \[LongDash] Finite vs infinite square well", "Subsection",ExpressionUUID->"ba67c672-0748-4961-ad26-339da0bdbf1e"],

Cell[TextData[{
 "Part 1 used infinite walls. A real quantum dot has ",
 StyleBox["finite",
  FontWeight->"Bold"],
 " walls of height ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["V", "TI"], "0"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "d1d6a304-0b74-43bb-b54e-4c025dbad2ba"],
 ", so the wavefunction leaks into the barrier and the particle is less \
tightly confined. We expect every bound level to drop below its infinite-well \
value, and, unlike the infinite well, only finitely many bound states to \
survive. Build the finite well as a piecewise potential and solve it \
natively, then compare the lowest four levels to the infinite well:"
}], "Text",ExpressionUUID->"0c89c988-a2c4-433d-aba2-8a7c9d0d9fe8"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"V0", " ", "=", " ", "200."}], ";", " ", 
  RowBox[{"d", " ", "=", " ", "1."}], ";"}], "\n", 
 RowBox[{
  RowBox[{"Hfinite", " ", "=", " ", 
   RowBox[{"SchrodingerPDEComponent", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"\[Psi]", "[", "x", "]"}], ",", " ", 
       RowBox[{"{", "x", "}"}]}], "}"}], ",", "\n", "   ", 
     RowBox[{"<|", 
      RowBox[{
       RowBox[{"\"\<Mass\>\"", " ", "->", " ", "1"}], ",", " ", 
       RowBox[{"\"\<ReducedPlanckConstant\>\"", " ", "->", " ", "1"}], ",", 
       "\n", "     ", 
       RowBox[{"\"\<SchrodingerPotential\>\"", " ", "->", " ", 
        RowBox[{"Piecewise", "[", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{"{", 
            RowBox[{"V0", ",", " ", 
             RowBox[{
              RowBox[{"Abs", "[", "x", "]"}], " ", ">=", " ", 
              RowBox[{"d", "/", "2"}]}]}], "}"}], "}"}], ",", " ", "0"}], 
         "]"}]}]}], "|>"}]}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"{", 
    RowBox[{"enFinite", ",", " ", "funsFinite"}], "}"}], " ", "=", " ", 
   RowBox[{"NDEigensystem", "[", "\n", "   ", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"Hfinite", ",", " ", 
       RowBox[{"DirichletCondition", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"\[Psi]", "[", "x", "]"}], " ", "==", " ", "0"}], ",", " ", 
         "True"}], "]"}]}], "}"}], ",", " ", 
     RowBox[{"\[Psi]", "[", "x", "]"}], ",", " ", 
     RowBox[{"{", 
      RowBox[{"x", ",", " ", 
       RowBox[{
        RowBox[{"-", "2"}], " ", "d"}], ",", " ", 
       RowBox[{"2", " ", "d"}]}], "}"}], ",", " ", "4", ",", "\n", "   ", 
     RowBox[{"Method", " ", "->", " ", 
      RowBox[{"{", 
       RowBox[{"\"\<PDEDiscretization\>\"", " ", "->", " ", 
        RowBox[{"{", 
         RowBox[{"\"\<FiniteElement\>\"", ",", " ", 
          RowBox[{"{", 
           RowBox[{"\"\<MeshOptions\>\"", " ", "->", " ", 
            RowBox[{"{", 
             RowBox[{"\"\<MaxCellMeasure\>\"", " ", "->", " ", "0.001"}], 
             "}"}]}], "}"}]}], "}"}]}], "}"}]}]}], "]"}]}], ";"}], "\n", 
 RowBox[{"{", 
  RowBox[{"enFinite", ",", " ", 
   RowBox[{"Table", "[", 
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{"(", 
         RowBox[{"k", " ", "Pi"}], ")"}], "^", "2"}], "/", "2"}], " ", "//", 
      " ", "N"}], ",", " ", 
     RowBox[{"{", 
      RowBox[{"k", ",", " ", "4"}], "}"}]}], "]"}]}], "}"}]}], "Input",
 CellLabel->
  "In[39]:= ",ExpressionUUID->"f30f0baf-3156-47a9-9554-d3f6b9bb9b01"],

