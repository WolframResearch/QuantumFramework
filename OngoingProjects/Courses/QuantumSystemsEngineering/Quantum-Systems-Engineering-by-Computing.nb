Cell["Lab 2 \[LongDash] Rabi flopping, resonant and detuned", "Subsection",ExpressionUUID->"a915f1ef-10ad-4c30-9d2d-9c48f7f93b3c"],

Cell[TextData[{
 "The lab drives a qubit and watches the excited-state population oscillate. \
Resonant driving fully inverts the qubit; detuning ",
 Cell[BoxData[
  StyleBox["\[Delta]", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "41aeec5a-ebf0-4222-8a21-1f4f31b44274"],
 " speeds the oscillation but caps its amplitude at ",
 Cell[BoxData[
  RowBox[{"1", "/", 
   StyleBox["(",
    SpanMaxSize->1], 
   RowBox[{"1", "+", 
    SuperscriptBox[
     StyleBox["\[Delta]", "TI"], "2"]}], 
   StyleBox[")",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "efb72bd5-a0b4-42ff-ad99-31a83f313f45"],
 ". Read the population directly off the evolved state's amplitude (no \
formula assumed):"
}], "Text",ExpressionUUID->"18dcad26-0ceb-44c3-926e-622ba08615b2"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"rabiP", "[", "\[Delta]_", "]"}], " ", ":=", " ", 
   RowBox[{
    RowBox[{"Abs", "[", 
     RowBox[{
      RowBox[{"Normal", "[", 
       RowBox[{
        RowBox[{"QuantumEvolve", "[", "\n", "      ", 
         RowBox[{
          RowBox[{
           RowBox[{
            RowBox[{"(", 
             RowBox[{"1", "/", "2"}], ")"}], " ", 
            RowBox[{"QuantumOperator", "[", "\"\<X\>\"", "]"}]}], " ", "+", 
           " ", 
           RowBox[{
            RowBox[{"(", 
             RowBox[{"\[Delta]", "/", "2"}], ")"}], " ", 
            RowBox[{"QuantumOperator", "[", "\"\<Z\>\"", "]"}]}]}], ",", "\n",
           "      ", 
          RowBox[{"QuantumState", "[", "\"\<0\>\"", "]"}]}], "]"}], 
        "[", "\"\<StateVector\>\"", "]"}], "]"}], "[", 
      RowBox[{"[", "2", "]"}], "]"}], "]"}], "^", "2"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"{", 
   RowBox[{
    RowBox[{"rabiP", "[", "0", "]"}], ",", " ", 
    RowBox[{"rabiP", "[", "1", "]"}]}], "}"}], " ", "//", " ", 
  "FullSimplify"}]}], "Input",
 CellLabel->
  "In[41]:= ",ExpressionUUID->"e1ca6ff2-d232-4800-9f79-0d9362a64f01"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   SuperscriptBox[
    RowBox[{"Abs", "[", 
     RowBox[{"Sin", "[", 
      FractionBox["\[FormalT]", "2"], "]"}], "]"}], "2"], ",", 
   RowBox[{
    FractionBox["1", "2"], " ", 
    SuperscriptBox[
     RowBox[{"Abs", "[", 
      RowBox[{"Sin", "[", 
       FractionBox["\[FormalT]", 
        SqrtBox["2"]], "]"}], "]"}], "2"]}]}], "}"}]], "Output",
 CellLabel->
  "Out[41]= ",ExpressionUUID->"7d764503-ce5e-4a49-99f7-519ee6dea1f7"]
}, Open  ]],

Cell[TextData[{
 "This returns ",
 Cell[BoxData[
  RowBox[{
   RowBox[{
    RowBox[{"{", 
     SuperscriptBox[
      StyleBox["sin",
       FontSlant->"Plain"], "2"], "\[ThinSpace]", 
     StyleBox["(",
      SpanMaxSize->1], 
     RowBox[{
      StyleBox["t", "TI"], "/", "2"}], 
     StyleBox[")",
      SpanMaxSize->1]}], 
    RowBox[{",", "\[ThinSpace]"}], "\[ThickSpace]", 
    FractionBox["1", "2"], 
    SuperscriptBox[
     StyleBox["sin",
      FontSlant->"Plain"], "2"], "\[ThinSpace]", 
    RowBox[{
     StyleBox["(",
      SpanMaxSize->1], 
     RowBox[{
      StyleBox["t", "TI"], "/", 
      SqrtBox["2"]}], 
     StyleBox[")",
      SpanMaxSize->1]}]}], "}"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "792a58a2-4384-4101-ba72-795e4adee0cb"],
 ": resonant flopping reaches ",
 Cell[BoxData["1"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "a91b7f65-4f26-4b07-add7-f14ee051b04e"],
 ", the detuned curve only ",
 Cell[BoxData[
  RowBox[{"1", "/", "2"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "94c2e4e4-c05b-4eb4-b598-5baaf1e413ef"],
 ". Plot the populations for three detunings:"
}], "Text",ExpressionUUID->"2f1706ed-a744-46f5-8b1a-e0c1d57ad646"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Plot", "[", 
  RowBox[{
   RowBox[{"Evaluate", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"rabiP", "[", "0", "]"}], ",", " ", 
       RowBox[{"rabiP", "[", "1", "]"}], ",", " ", 
       RowBox[{"rabiP", "[", "2", "]"}]}], "}"}], " ", "/.", " ", 
     RowBox[{"\[FormalT]", " ", "->", " ", "\[Tau]"}]}], "]"}], ",", " ", 
   RowBox[{"{", 
    RowBox[{"\[Tau]", ",", " ", "0", ",", " ", 
     RowBox[{"2", " ", "Pi"}]}], "}"}], ",", "\n", "   ", 
   RowBox[{"AxesLabel", " ", "->", " ", 
    RowBox[{"{", 
     RowBox[{"\"\<t\>\"", ",", " ", "\"\<P\:2081\>\""}], "}"}]}], ",", " ", 
   RowBox[{"PlotLegends", " ", "->", " ", 
    RowBox[{"{", 
     RowBox[{"\"\<\[Delta]=0\>\"", ",", " ", "\"\<\[Delta]=1\>\"", ",", 
      " ", "\"\<\[Delta]=2\>\""}], "}"}]}]}], "]"}]], "Input",
 CellLabel->
  "In[42]:= ",ExpressionUUID->"7f9720a2-7404-4aa5-858b-53e82ae93bda"],

