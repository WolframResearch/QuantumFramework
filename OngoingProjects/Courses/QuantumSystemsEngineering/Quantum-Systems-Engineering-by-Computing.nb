Cell[TextData[{
 "The finite-well energies ",
 Cell[BoxData[
  RowBox[{"{", 
   RowBox[{"4.08", ",", " ", "16.27", ",", " ", "36.48", ",", " ", "64.51"}], 
   "}"}]], "InlineFormula",ExpressionUUID->
  "5587df90-eb40-4321-9a82-acfc2eecc0c3"],
 " sit below the infinite-well ",
 Cell[BoxData[
  RowBox[{"{", 
   RowBox[{"4.93", ",", " ", "19.74", ",", " ", "44.41", ",", " ", "78.96"}], 
   "}"}]], "InlineFormula",ExpressionUUID->
  "b020bbae-1656-44c6-b2b2-7f20356366e8"],
 ": softer confinement, lower energy, exactly as expected. Plot the bound \
states to see them spill past the wall at ",
 Cell[BoxData[
  RowBox[{"\[LeftBracketingBar]", 
   StyleBox["x", "TI"], "\[VeryThinSpace]", "\[RightBracketingBar]", "=", "1",
    "/", "2"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "d7a66b8f-7b5c-41a6-a04e-a1f242c387d6"],
 ":"
}], "Text",ExpressionUUID->"d24991f9-f8e6-4bce-92e4-5c18000b7467"],

