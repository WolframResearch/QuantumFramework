     "912ac8a5-fd96-41b5-8ea7-890cf67c093f"], Cell[
    "Part 1", "TableText",ExpressionUUID->
     "e29ca1e4-7545-4b66-9a14-d52b8f769770"]},
   {Cell["      ", "ModInfo",ExpressionUUID->
