  }]], "2ColumnTableMod",ExpressionUUID->"7f8b26a4-db54-4f6e-a3e5-\
8b3bab685b0a"],

Cell["Finite vs infinite square well", "Subsection",ExpressionUUID->"f4bd1958-574f-43af-a2cb-85d98a9d2fa9"],

Cell[TextData[{
 "Part 1 used infinite walls. A real quantum dot has ",
 StyleBox["finite",
  FontWeight->"Bold"],
 " walls of height ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["V", "TI"], "0"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "6772f4b2-d56e-4785-91ed-1d27ec92b49d"],
 ", so the wavefunction leaks into the barrier and the particle is less \
tightly confined. We expect every bound level to drop below its infinite-well \
value, and, unlike the infinite well, only finitely many bound states to \
survive. Build the finite well as a piecewise potential and solve it \
natively, then compare the lowest four levels to the infinite well:"
}], "Text",ExpressionUUID->"2b857dc9-c92e-4148-8910-6b2ea06b4dc4"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"V0", " ", "=", " ", "200."}], ";", " ", 
  RowBox[{"d", " ", "=", " ", "1."}], ";"}], "\n", 
 RowBox[{
  RowBox[{"Hfinite", " ", "=", " ", 
   RowBox[{"SchrodingerPDEComponent", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"\[Psi]", "[", "x", "]"}], ",", " ", 
       RowBox[{"{", "x", "}"}]}], "}"}], ",", "\n", "   ", 
     RowBox[{"<|", 
      RowBox[{
       RowBox[{"\"\<Mass\>\"", " ", "->", " ", "1"}], ",", " ", 
       RowBox[{"\"\<ReducedPlanckConstant\>\"", " ", "->", " ", "1"}], ",", 
       "\n", "     ", 
       RowBox[{"\"\<SchrodingerPotential\>\"", " ", "->", " ", 
        RowBox[{"Piecewise", "[", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{"{", 
            RowBox[{"V0", ",", " ", 
             RowBox[{
              RowBox[{"Abs", "[", "x", "]"}], " ", ">=", " ", 
              RowBox[{"d", "/", "2"}]}]}], "}"}], "}"}], ",", " ", "0"}], 
         "]"}]}]}], "|>"}]}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"{", 
    RowBox[{"enFinite", ",", " ", "funsFinite"}], "}"}], " ", "=", " ", 
   RowBox[{"NDEigensystem", "[", "\n", "   ", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"Hfinite", ",", " ", 
       RowBox[{"DirichletCondition", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"\[Psi]", "[", "x", "]"}], " ", "==", " ", "0"}], ",", " ", 
         "True"}], "]"}]}], "}"}], ",", " ", 
     RowBox[{"\[Psi]", "[", "x", "]"}], ",", " ", 
     RowBox[{"{", 
      RowBox[{"x", ",", " ", 
       RowBox[{
        RowBox[{"-", "2"}], " ", "d"}], ",", " ", 
       RowBox[{"2", " ", "d"}]}], "}"}], ",", " ", "4", ",", "\n", "   ", 
     RowBox[{"Method", " ", "->", " ", 
      RowBox[{"{", 
       RowBox[{"\"\<PDEDiscretization\>\"", " ", "->", " ", 
        RowBox[{"{", 
         RowBox[{"\"\<FiniteElement\>\"", ",", " ", 
          RowBox[{"{", 
           RowBox[{"\"\<MeshOptions\>\"", " ", "->", " ", 
            RowBox[{"{", 
             RowBox[{"\"\<MaxCellMeasure\>\"", " ", "->", " ", "0.001"}], 
             "}"}]}], "}"}]}], "}"}]}], "}"}]}]}], "]"}]}], ";"}], "\n", 
 RowBox[{"{", 
  RowBox[{"enFinite", ",", " ", 
   RowBox[{"Table", "[", 
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{"(", 
         RowBox[{"k", " ", "Pi"}], ")"}], "^", "2"}], "/", "2"}], " ", "//", 
      " ", "N"}], ",", " ", 
     RowBox[{"{", 
      RowBox[{"k", ",", " ", "4"}], "}"}]}], "]"}]}], "}"}]}], "Input",
 CellLabel->
  "In[39]:= ",ExpressionUUID->"19ccff7d-5f75-4271-846f-94467aff0fa3"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
    "4.075808162059591`", ",", "16.2717085658352`", ",", "36.48451076684946`",
      ",", "64.50680238902252`"}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{
    "4.934802200544679`", ",", "19.739208802178716`", ",", 
     "44.41321980490211`", ",", "78.95683520871486`"}], "}"}]}], 
  "}"}]], "Output",
 CellLabel->
  "Out[39]= ",ExpressionUUID->"42d080e6-5f4c-4bb3-83f1-5ac3b3c5f70f"]
}, Open  ]],

Cell[TextData[{
 "The finite-well energies ",
 Cell[BoxData[
  RowBox[{"{", 
   RowBox[{"4.08", ",", " ", "16.27", ",", " ", "36.48", ",", " ", "64.51"}], 
   "}"}]], "InlineFormula",ExpressionUUID->
  "d72cc551-3ea5-402b-9a81-8b0b82c4ccee"],
 " sit below the infinite-well ",
 Cell[BoxData[
  RowBox[{"{", 
   RowBox[{"4.93", ",", " ", "19.74", ",", " ", "44.41", ",", " ", "78.96"}], 
   "}"}]], "InlineFormula",ExpressionUUID->
  "7dc98acc-e020-4a80-9860-5f518ceb6ba9"],
 ": softer confinement, lower energy, exactly as expected. Plot the bound \
states to see them spill past the wall at ",
 Cell[BoxData[
  RowBox[{"\[LeftBracketingBar]", 
   StyleBox["x", "TI"], "\[VeryThinSpace]", "\[RightBracketingBar]", "=", "1",
    "/", "2"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "142de34f-e633-478d-85f8-50360582b02f"],
 ":"
}], "Text",ExpressionUUID->"23e588b3-27ed-48ae-ad64-17af8009c6ef"],

