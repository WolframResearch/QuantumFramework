Cell["Rabi flopping, resonant and detuned", "Subsection",ExpressionUUID->"b3178047-14b3-4bb6-b18b-2f199b42ab09"],

Cell[TextData[{
 "This example drives a qubit and watches the excited-state population \
oscillate. Resonant driving fully inverts the qubit; detuning ",
 Cell[BoxData[
  StyleBox["\[Delta]", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "5ebcb53c-a3aa-4fa4-99b1-8a2b38bd415f"],
 " speeds the oscillation but caps its amplitude at ",
 Cell[BoxData[
  RowBox[{"1", "/", 
   StyleBox["(",
    SpanMaxSize->1], 
   RowBox[{"1", "+", 
    SuperscriptBox[
     StyleBox["\[Delta]", "TI"], "2"]}], 
   StyleBox[")",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "5d3440e5-1ca0-4221-9ab5-a211b08f808e"],
 ". Read the population directly off the evolved state's amplitude (no \
formula assumed):"
}], "Text",ExpressionUUID->"65ab9de0-7134-4aec-bbd8-836c816c531f"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"rabiP", "[", "\[Delta]_", "]"}], " ", ":=", " ", 
   RowBox[{
    RowBox[{"Abs", "[", 
     RowBox[{
      RowBox[{"Normal", "[", 
       RowBox[{
        RowBox[{"QuantumEvolve", "[", "\n", "      ", 
         RowBox[{
          RowBox[{
           RowBox[{
            RowBox[{"(", 
             RowBox[{"1", "/", "2"}], ")"}], " ", 
            RowBox[{"QuantumOperator", "[", "\"\<X\>\"", "]"}]}], " ", "+", 
           " ", 
           RowBox[{
            RowBox[{"(", 
             RowBox[{"\[Delta]", "/", "2"}], ")"}], " ", 
            RowBox[{"QuantumOperator", "[", "\"\<Z\>\"", "]"}]}]}], ",", "\n",
           "      ", 
          RowBox[{"QuantumState", "[", "\"\<0\>\"", "]"}]}], "]"}], 
        "[", "\"\<StateVector\>\"", "]"}], "]"}], "[", 
      RowBox[{"[", "2", "]"}], "]"}], "]"}], "^", "2"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"{", 
   RowBox[{
    RowBox[{"rabiP", "[", "0", "]"}], ",", " ", 
    RowBox[{"rabiP", "[", "1", "]"}]}], "}"}], " ", "//", " ", 
  "FullSimplify"}]}], "Input",
 CellLabel->
  "In[41]:= ",ExpressionUUID->"d4c3230a-dbf6-4a0a-814a-e26661405b9e"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   SuperscriptBox[
    RowBox[{"Abs", "[", 
     RowBox[{"Sin", "[", 
      FractionBox["\[FormalT]", "2"], "]"}], "]"}], "2"], ",", 
   RowBox[{
    FractionBox["1", "2"], " ", 
    SuperscriptBox[
     RowBox[{"Abs", "[", 
      RowBox[{"Sin", "[", 
       FractionBox["\[FormalT]", 
        SqrtBox["2"]], "]"}], "]"}], "2"]}]}], "}"}]], "Output",
 CellLabel->
  "Out[41]= ",ExpressionUUID->"c50a4d44-91c2-4091-896b-391c92c56b1c"]
}, Open  ]],

Cell[TextData[{
 "This returns ",
 Cell[BoxData[
  RowBox[{
   RowBox[{
    RowBox[{"{", 
     SuperscriptBox[
      StyleBox["sin",
       FontSlant->"Plain"], "2"], "\[ThinSpace]", 
     StyleBox["(",
      SpanMaxSize->1], 
     RowBox[{
      StyleBox["t", "TI"], "/", "2"}], 
     StyleBox[")",
      SpanMaxSize->1]}], 
    RowBox[{",", "\[ThinSpace]"}], "\[ThickSpace]", 
    FractionBox["1", "2"], 
    SuperscriptBox[
     StyleBox["sin",
      FontSlant->"Plain"], "2"], "\[ThinSpace]", 
    RowBox[{
     StyleBox["(",
      SpanMaxSize->1], 
     RowBox[{
      StyleBox["t", "TI"], "/", 
      SqrtBox["2"]}], 
     StyleBox[")",
      SpanMaxSize->1]}]}], "}"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "51717338-fb61-43b6-8bdf-9d3d0adbf4b4"],
 ": resonant flopping reaches ",
 Cell[BoxData["1"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "64388a5d-088b-48a1-a202-a7dad4226c81"],
 ", the detuned curve only ",
 Cell[BoxData[
  RowBox[{"1", "/", "2"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "8ef59260-cf8b-4647-ac4c-d1a82d9415ab"],
 ". Plot the populations for three detunings:"
}], "Text",ExpressionUUID->"8da14a93-864a-4da4-91fa-27e521d0bb8f"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Plot", "[", 
  RowBox[{
   RowBox[{"Evaluate", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"rabiP", "[", "0", "]"}], ",", " ", 
       RowBox[{"rabiP", "[", "1", "]"}], ",", " ", 
       RowBox[{"rabiP", "[", "2", "]"}]}], "}"}], " ", "/.", " ", 
     RowBox[{"\[FormalT]", " ", "->", " ", "\[Tau]"}]}], "]"}], ",", " ", 
   RowBox[{"{", 
    RowBox[{"\[Tau]", ",", " ", "0", ",", " ", 
     RowBox[{"2", " ", "Pi"}]}], "}"}], ",", "\n", "   ", 
   RowBox[{"AxesLabel", " ", "->", " ", 
    RowBox[{"{", 
     RowBox[{"\"\<t\>\"", ",", " ", "\"\<P\:2081\>\""}], "}"}]}], ",", " ", 
   RowBox[{"PlotLegends", " ", "->", " ", 
    RowBox[{"{", 
     RowBox[{"\"\<\[Delta]=0\>\"", ",", " ", "\"\<\[Delta]=1\>\"", ",", 
      " ", "\"\<\[Delta]=2\>\""}], "}"}]}]}], "]"}]], "Input",
 CellLabel->
  "In[42]:= ",ExpressionUUID->"37b0549b-fb8b-4ae0-9467-4787d4fe12f8"],

