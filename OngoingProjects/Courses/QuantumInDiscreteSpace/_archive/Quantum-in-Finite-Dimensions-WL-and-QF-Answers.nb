Cell[TextData[{
 "Both give outcomes ",
 Cell[BoxData[
  RowBox[{"\[PlusMinus]", "1"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "3087965e-7737-41d9-8c3d-416cc4c56823"],
 " with Born probabilities ",
 Cell[BoxData[
  FractionBox[
   RowBox[{"1", "+", 
    SubscriptBox[
     StyleBox["r", "TI"], 
     StyleBox["z", "TI"]]}], "2"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "5bad27e9-e1a0-42d2-8b5f-5e31c8f4c157"],
 " (for ",
 Cell[BoxData[
  RowBox[{"+", "1"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "97170c3b-e4ee-4888-b725-21e33a47c003"],
 ") and ",
 Cell[BoxData[
  FractionBox[
   RowBox[{"1", "-", 
    SubscriptBox[
     StyleBox["r", "TI"], 
     StyleBox["z", "TI"]]}], "2"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "f5c8e44c-6470-4df6-b8e0-87dbb0f2b964"],
 " (for ",
 Cell[BoxData[
  RowBox[{"-", "1"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "2ec54014-5eb7-4e27-8a18-6e8010fb77de"],
 ") and mean ",
 Cell[BoxData[
  RowBox[{
   StyleBox["\[LeftAngleBracket]",
    SpanMaxSize->1], 
   StyleBox["Z", "TI"], "\[VeryThinSpace]", 
   StyleBox["\[RightAngleBracket]",
    SpanMaxSize->1], "=", 
   SubscriptBox[
    StyleBox["r", "TI"], 
    StyleBox["z", "TI"]]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "10eb48b0-ae42-4b46-add7-fee6c2af7b24"],
 ": a ",
 Cell[BoxData[
  StyleBox["Z", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "a13d1968-f71f-4a50-9488-c9f73aa4e7ca"],
 " measurement reads only the populations (the ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["r", "TI"], 
   StyleBox["z", "TI"]]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "06416131-047d-4bb1-bf83-a8152a3f3110"],
 " component), so the coherences ",
 Cell[BoxData[
  RowBox[{
   SubscriptBox[
    StyleBox["r", "TI"], 
    StyleBox["x", "TI"]], ",", 
   SubscriptBox[
    StyleBox["r", "TI"], 
    StyleBox["y", "TI"]]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "f8b9a8f3-3faf-44de-bf54-dae6beea5787"],
 " drop out, and the mean is the difference of the two outcome probabilities. \
For a pure state (",
 Cell[BoxData[
  RowBox[{GridBox[{
     {
      OverscriptBox[
       StyleBox["r", "TI"], "\[RightVector]"]}
    },
    GridBoxDividers->{"Columns" -> {True, True}, "Rows" -> {}},
    GridBoxSpacings->{"Columns" -> {{0.15}}}], "=", "1"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "ca26c928-1c27-4bb6-91cc-c44680c87225"],
 ") these are the familiar ",
 Cell[BoxData[
  RowBox[{
   RowBox[{
    SuperscriptBox[
     StyleBox["cos",
      FontSlant->"Plain"], "2"], "\[ThinSpace]", 
    FractionBox[
     StyleBox["\[Theta]", "TI"], "2"]}], ",", 
   RowBox[{
    SuperscriptBox[
     StyleBox["sin",
      FontSlant->"Plain"], "2"], "\[ThinSpace]", 
    FractionBox[
     StyleBox["\[Theta]", "TI"], "2"]}], ",", 
   RowBox[{
    StyleBox["cos",
     FontSlant->"Plain"], "\[ThinSpace]", 
    StyleBox["\[Theta]", "TI"]}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "5415b531-f1b1-4a96-ae29-c030f0481761"],
 "."
}], "Text",ExpressionUUID->"d3d26f10-b9e6-41c8-b25d-9b409b91f882"],

Cell["\<\
5.2 [BSc] How do I measure in a non-computational basis and get the \
post-measurement (collapsed) states?\
\>", "Subsection",ExpressionUUID->"8d645658-19c6-438f-823b-d810570e1133"],

Cell[TextData[{
 "Measuring an observable whose eigenbasis is not the computational one, here \
",
 Cell[BoxData[
  StyleBox["X", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "7689790b-d69e-4806-b668-711d846be5b8"],
 " with eigenstates ",
 Cell[BoxData[
  RowBox[{
   TemplateBox[{"\[PlusMinus]"},
    "Ket"], "=", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{
      TemplateBox[{"0"},
       "Ket"], "\[PlusMinus]", 
      TemplateBox[{"1"},
       "Ket"]}], ")"}], "/", 
    SqrtBox["2"]}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "afd8ab83-6da7-4949-a9f3-78b4fc81de18"],
 ", collapses a general pure qubit ",
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     StyleBox["\[Psi]", "TI"]},
    "Ket"], "=", "{", 
   StyleBox["cos",
    FontSlant->"Plain"], 
   FractionBox[
    StyleBox["\[Theta]", "TI"], "2"], ",", 
   SuperscriptBox[
    StyleBox["e", "TI"], 
    RowBox[{
     StyleBox["i", "TI"], "\[CurlyPhi]"}]], 
   StyleBox["sin",
    FontSlant->"Plain"], 
   FractionBox[
    StyleBox["\[Theta]", "TI"], "2"], "}"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "e4380eaa-da18-4faf-9bf3-023802b9e7b5"],
 " onto one of those eigenstates with probability ",
 Cell[BoxData[
  SuperscriptBox[GridBox[{
     {
      TemplateBox[{"\[PlusMinus]", 
        StyleBox["\[Psi]", "TI"]},
       "BraKet"]}
    },
    GridBoxDividers->{"Columns" -> {True, True}, "Rows" -> {}},
    GridBoxSpacings->{"Columns" -> {{0.15}}}], "2"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "54c1ca3e-ef3d-4316-85dc-67c8ad88a469"],
 "."
}], "Text",ExpressionUUID->"dbef3d31-f298-4188-a839-3f2e398b9acf"],

Cell[TextData[{
 StyleBox["WL",
  FontWeight->"Bold"],
 " : the collapse targets are the normalized eigenvectors of ",
 Cell[BoxData[
  StyleBox["X", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "c703e824-48d9-43e9-a619-eefd6a748157"],
 "."
}], "Text",ExpressionUUID->"8fb676bb-2a78-4779-8aaa-84681f93aa44"],

Cell[BoxData[
 RowBox[{"Normalize", " ", "/@", " ", 
  RowBox[{"Eigenvectors", "[", 
   RowBox[{"PauliMatrix", "[", "1", "]"}], "]"}]}]], "Input",
 CellLabel->
  "In[155]:= ",ExpressionUUID->"f3a3e732-5a60-4d2e-9d75-38d14ce07bf2"],

Cell["Their probabilities are the squared overlaps with the state.", "Text",ExpressionUUID->"33971a7e-97f8-409b-9f39-b18f63ef500c"],

Cell[BoxData[
 RowBox[{"FullSimplify", "[", 
  RowBox[{
   RowBox[{"ComplexExpand", "[", 
    RowBox[{"With", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"psi", " ", "=", " ", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"Cos", "[", 
           RowBox[{"\[Theta]", "/", "2"}], "]"}], ",", " ", 
          RowBox[{
           RowBox[{"Exp", "[", 
            RowBox[{"I", " ", "\[Phi]"}], "]"}], " ", 
           RowBox[{"Sin", "[", 
            RowBox[{"\[Theta]", "/", "2"}], "]"}]}]}], "}"}]}], "}"}], ",", 
      " ", 
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{"Abs", "[", 
          RowBox[{
           RowBox[{"Conjugate", "[", "#", "]"}], " ", ".", " ", "psi"}], 
          "]"}], "^", "2"}], " ", "&"}], " ", "/@", " ", 
       RowBox[{"(", 
        RowBox[{"Normalize", " ", "/@", " ", 
         RowBox[{"Eigenvectors", "[", 
          RowBox[{"PauliMatrix", "[", "1", "]"}], "]"}]}], ")"}]}]}], "]"}], 
    "]"}], ",", " ", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"\[Theta]", ",", " ", "\[Phi]"}], "}"}], " ", "\[Element]", " ", 
    "Reals"}]}], "]"}]], "Input",
 CellLabel->
  "In[156]:= ",ExpressionUUID->"8cf7cc6a-26ff-4244-9222-223d3e5f8781"],

Cell[TextData[{
 StyleBox["QF",
  FontWeight->"Bold"],
 " : the ",
 Cell[BoxData[
  StyleBox["X", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "fa7c13c9-d734-4659-bf08-1022e31377a0"],
 "-basis measurement object."
}], "Text",ExpressionUUID->"ec7ef663-b73b-407d-9b9d-00de02b5e5ff"],

Cell[BoxData[
 RowBox[{
  RowBox[{"QuantumMeasurementOperator", "[", 
   RowBox[{"QuantumOperator", "[", "\"\<X\>\"", "]"}], "]"}], "[", 
  RowBox[{"QuantumState", "[", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"Cos", "[", 
      RowBox[{"\[Theta]", "/", "2"}], "]"}], ",", " ", 
     RowBox[{
      RowBox[{"Exp", "[", 
       RowBox[{"I", " ", "\[Phi]"}], "]"}], " ", 
      RowBox[{"Sin", "[", 
       RowBox[{"\[Theta]", "/", "2"}], "]"}]}]}], "}"}], "]"}], 
  "]"}]], "Input",
 CellLabel->
  "In[157]:= ",ExpressionUUID->"240249a9-1af3-4044-b26e-aec8e401bba5"],

Cell[TextData[{
 "Its ",
 Cell[BoxData["\"\<States\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "009d50a0-4cb3-43d6-ae58-2ab91b7de28a"],
 " are the post-measurement states, each collapsed onto an ",
 Cell[BoxData[
  StyleBox["X", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "34aa825b-86ec-4f37-963e-bda181c2981a"],
 " eigenstate and weighted by its measurement amplitude."
}], "Text",ExpressionUUID->"6837850e-bdfc-4d33-a4d7-eec16f1c0fdd"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"QuantumMeasurementOperator", "[", 
    RowBox[{"QuantumOperator", "[", "\"\<X\>\"", "]"}], "]"}], "[", 
   RowBox[{"QuantumState", "[", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"Cos", "[", 
       RowBox[{"\[Theta]", "/", "2"}], "]"}], ",", " ", 
      RowBox[{
       RowBox[{"Exp", "[", 
        RowBox[{"I", " ", "\[Phi]"}], "]"}], " ", 
       RowBox[{"Sin", "[", 
        RowBox[{"\[Theta]", "/", "2"}], "]"}]}]}], "}"}], "]"}], "]"}], 
  "[", "\"\<States\>\"", "]"}]], "Input",
 CellLabel->
  "In[158]:= ",ExpressionUUID->"df6af042-5f51-4032-af88-e3f82539e030"],

Cell[TextData[{
 "Both give the collapse basis ",
 Cell[BoxData[
  TemplateBox[{"\[PlusMinus]"},
   "Ket"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "fc3b200d-a53c-46a9-bc82-8448d9845867"],
 " with probabilities ",
 Cell[BoxData[
  RowBox[{
   FractionBox["1", "2"], 
   StyleBox["(",
    SpanMaxSize->1], 
   RowBox[{"1", "\[PlusMinus]", 
    StyleBox["sin",
     FontSlant->"Plain"], "\[ThinSpace]", 
    StyleBox["\[Theta]", "TI"], 
    StyleBox["cos",
     FontSlant->"Plain"], "\[ThinSpace]", "\[CurlyPhi]"}], 
   StyleBox[")",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "5243595b-88cd-4deb-b0a5-f9e32a42c627"],
 ": unlike a ",
 Cell[BoxData[
  StyleBox["Z", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "ef11e5f1-cc9a-4e1e-b6bf-43151bde87db"],
 " measurement, the ",
 Cell[BoxData[
  StyleBox["X", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "587f7b27-1a44-4e1d-826f-1bd25766f0cd"],
 " outcome depends on the relative phase ",
 Cell[BoxData["\[CurlyPhi]"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "038b38c5-1aaa-4a50-a3f9-641af52c4515"],
 ", so a real state would hide it. A measurement in the ",
 Cell[BoxData[
  StyleBox["X", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "7a337b74-be8d-40b6-b195-f9db8eb82be1"],
 " basis leaves the qubit in an ",
 Cell[BoxData[
  StyleBox["X", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "2f7c5160-8dab-4904-af91-4cca02ad5ce9"],
 " eigenstate. The post-measurement objects are those eigenstates, each \
scaled by its outcome amplitude (its squared norm is the probability)."
}], "Text",ExpressionUUID->"ee85a007-a18e-416e-8f43-426bda3bc596"],

Cell["\<\
5.3 [BSc] How do I simulate finite-shot statistics and watch the empirical \
frequencies approach the Born rule?\
\>", "Subsection",ExpressionUUID->"4a0ccb88-ac14-4a94-b273-944bc7080218"],

Cell[TextData[{
 "Real measurements return a finite sample of outcomes whose frequencies \
converge to the Born probabilities as the shot count grows. This is the one \
place the two answers do not agree cell-for-cell: each draws its own random \
sample, and what they share is the limit. Measure ",
 Cell[BoxData[
  StyleBox["Z", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "190c2544-1cae-442c-838f-04447c2cae9c"],
 " on the state ",
 Cell[BoxData[
  RowBox[{
   RowBox[{"{", 
    FractionBox[
     SqrtBox["3"], "2"]}], ",", 
   RowBox[{
    FractionBox["1", "2"], "}"}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "ea949c7e-7cec-41cc-a1c1-d5ac8c375e18"],
 ", whose Born probabilities are the unequal ",
 Cell[BoxData[
  RowBox[{
   FractionBox["3", "4"], ",", 
   FractionBox["1", "4"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "6eb5d454-8978-4441-82ef-4e8b0b9f6b91"],
 "."
}], "Text",ExpressionUUID->"a63a5b0e-7e53-4613-b744-c9d11b491355"],

Cell[TextData[{
 StyleBox["WL",
  FontWeight->"Bold"],
 " : draw ",
 Cell[BoxData["2000"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "174f81c8-f192-47b1-b760-5560e48fae3d"],
 " outcomes with the Born weights and tabulate their frequencies."
}], "Text",ExpressionUUID->"4bce192a-ac28-4ead-9598-d23c4b9711a8"],

Cell[BoxData[
 RowBox[{
  RowBox[{"SeedRandom", "[", "1", "]"}], ";", " ", 
  RowBox[{"N", "[", 
   RowBox[{
    RowBox[{"Counts", "[", 
     RowBox[{"RandomChoice", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"{", 
         RowBox[{
          RowBox[{"3", "/", "4"}], ",", " ", 
          RowBox[{"1", "/", "4"}]}], "}"}], " ", "->", " ", 
        RowBox[{"{", 
         RowBox[{"1", ",", " ", 
          RowBox[{"-", "1"}]}], "}"}]}], ",", " ", "2000"}], "]"}], "]"}], "/",
     "2000"}], "]"}]}]], "Input",
 CellLabel->
  "In[159]:= ",ExpressionUUID->"417cd1f0-45ab-41eb-bab3-f3a025294c15"],

Cell[TextData[{
 StyleBox["QF",
  FontWeight->"Bold"],
 " : ",
 Cell[BoxData["\"\<SimulatedCounts\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "aca94721-fcfb-40fe-b16b-0906d27aa1a8"],
 " draws the same-size sample from the measurement and returns the raw counts."
}], "Text",ExpressionUUID->"6d1095da-c89e-4764-ba8c-15512c5b366f"],

Cell[BoxData[
 RowBox[{
  RowBox[{"SeedRandom", "[", "1", "]"}], ";", " ", 
  RowBox[{
   RowBox[{
    RowBox[{"QuantumMeasurementOperator", "[", 
     RowBox[{"QuantumOperator", "[", "\"\<Z\>\"", "]"}], "]"}], "[", 
    RowBox[{"QuantumState", "[", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{
        RowBox[{"Sqrt", "[", "3", "]"}], "/", "2"}], ",", " ", 
       RowBox[{"1", "/", "2"}]}], "}"}], "]"}], "]"}], "[", 
   RowBox[{"\"\<SimulatedCounts\>\"", ",", " ", "2000"}], "]"}]}]], "Input",
 CellLabel->
  "In[160]:= ",ExpressionUUID->"5cf918ab-809e-4108-92f3-dde4a17baace"],

Cell[TextData[{
 "Both cluster near the Born prediction ",
 Cell[BoxData[
  RowBox[{
   RowBox[{"{", "1500"}], ",", 
   RowBox[{"500", "}"}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "aabca975-233f-42c3-9cf4-883e8096e3c5"],
 " (frequencies ",
 Cell[BoxData[
  RowBox[{
   RowBox[{"\[TildeTilde]", "{", "0.75"}], ",", 
   RowBox[{"0.25", "}"}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "bcbf0a96-8c27-4b6e-a456-788d4639f3bb"],
 "): the two samples differ in their individual draws but each approaches ",
 Cell[BoxData[
  RowBox[{
   FractionBox["3", "4"], ",", 
   FractionBox["1", "4"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "4d881392-23ac-4e33-b6b7-bdb521d3f955"],
 ", and the gap shrinks like ",
 Cell[BoxData[
  RowBox[{"1", "/", 
   SqrtBox[
    StyleBox["N", "TI"]]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "889cdb7b-d035-404b-bedd-3a0fb02214c3"],
 ". The unequal weights make the convergence discriminating, the frequencies \
track two distinct probabilities rather than a symmetric coin flip. The Born \
rule is the large-sample limit of the measured frequencies."
}], "Text",ExpressionUUID->"b015c0a2-5a93-4fa8-aa63-499c516f902d"],

Cell["\<\
5.4 [BSc] How do I apply a non-selective projective measurement (the L\
\[UDoubleDot]ders channel)?\
\>", "Subsection",ExpressionUUID->"949d87df-9622-4e0f-80db-92eace7434ab"],

Cell[TextData[{
 "A non-selective measurement records that a measurement happened but not \
which outcome, replacing ",
 Cell[BoxData[
  StyleBox["\[Rho]", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "d9700ad4-ca9d-494a-89c6-d4845abffa4d"],
 " by ",
 Cell[BoxData[
  RowBox[{
   UnderscriptBox["\[Sum]", 
    StyleBox["k", "TI"],
    LimitsPositioning->False], 
   SubscriptBox[
    StyleBox["P", "TI"], 
    StyleBox["k", "TI"]], " ", 
   StyleBox["\[Rho]", "TI"], " ", 
   SubscriptBox[
    StyleBox["P", "TI"], 
    StyleBox["k", "TI"]]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "d3bb8b13-e56c-4696-a034-6fe410945f9f"],
 " (the L\[UDoubleDot]ders channel). For a ",
 Cell[BoxData[
  StyleBox["Z", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "19b0a432-fd77-49d2-b59b-3f7fb8224468"],
 " measurement this erases the off-diagonal coherences and leaves the \
diagonal: pure dephasing. Apply it to a general qubit state in Bloch form ",
 Cell[BoxData[
  RowBox[{
   StyleBox["\[Rho]", "TI"], "=", 
   FractionBox["1", "2"], 
   StyleBox["(",
    SpanMaxSize->1], 
   RowBox[{
    StyleBox["I", "TI"], "+", 
    OverscriptBox[
     StyleBox["r", "TI"], "\[RightVector]"], "\[CenterDot]", 
    OverscriptBox[
     StyleBox["\[Sigma]", "TI"], "\[RightVector]"]}], 
   StyleBox[")",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "b5d22b35-88da-4e09-9cb0-8ea87659d1a5"],
 " (pure or mixed; ",
 Cell[BoxData[
  RowBox[{
   OverscriptBox[
    StyleBox["\[Sigma]", "TI"], "\[RightVector]"], "="}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "73ae9cfd-ac00-4a19-b021-0c3db48d81d8"],
 " ",
 Cell[BoxData[
  RowBox[{"PauliMatrix", "[", 
   RowBox[{"{", 
    RowBox[{"1", ",", " ", "2", ",", " ", "3"}], "}"}], "]"}]], 
  "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "d5f0f96c-bd16-4b6d-99fd-507164136962"],
 ")."
}], "Text",ExpressionUUID->"1f26be08-5dca-4fe6-ab76-fd70246deb5c"],

Cell[TextData[{
 StyleBox["WL",
  FontWeight->"Bold"],
 " : sandwich ",
 Cell[BoxData[
  StyleBox["\[Rho]", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "c9f141e6-8b2e-4c59-a860-ca7d79477dd0"],
 " between the two ",
 Cell[BoxData[
  StyleBox["Z", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "8a303661-a309-485f-abcc-0daa143140c9"],
 " projectors and sum."
}], "Text",ExpressionUUID->"60dac778-89d5-4892-9ec3-efa1a9c52012"],

Cell[BoxData[
 RowBox[{"With", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"rho", " ", "=", " ", 
     RowBox[{
      RowBox[{"1", "/", "2"}], " ", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{"IdentityMatrix", "[", "2", "]"}], " ", "+", " ", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"rx", ",", " ", "ry", ",", " ", "rz"}], "}"}], " ", ".", 
         " ", 
         RowBox[{"PauliMatrix", "[", 
          RowBox[{"{", 
           RowBox[{"1", ",", " ", "2", ",", " ", "3"}], "}"}], "]"}]}]}], 
       ")"}]}]}], "}"}], ",", "\n", " ", 
   RowBox[{"Sum", "[", 
    RowBox[{
     RowBox[{"p", " ", ".", " ", "rho", " ", ".", " ", "p"}], ",", " ", 
     RowBox[{"{", 
      RowBox[{"p", ",", " ", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{"1", ",", " ", "0"}], "}"}], ",", " ", 
           RowBox[{"{", 
            RowBox[{"0", ",", " ", "0"}], "}"}]}], "}"}], ",", " ", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{"0", ",", " ", "0"}], "}"}], ",", " ", 
           RowBox[{"{", 
            RowBox[{"0", ",", " ", "1"}], "}"}]}], "}"}]}], "}"}]}], "}"}]}], 
    "]"}]}], "]"}]], "Input",
 CellLabel->
  "In[161]:= ",ExpressionUUID->"2104396a-57b3-4610-af18-4bcc0b96730a"],

Cell[TextData[{
 StyleBox["QF",
  FontWeight->"Bold"],
 " : the measurement's ",
 Cell[BoxData["\"\<PostMeasurementState\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "0752a84a-e6c9-46be-90c0-796d8660e80f"],
 " is that non-selective mixture, as a state object."
}], "Text",ExpressionUUID->"9665e2fc-5ea8-4402-95ff-158228ce7531"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"QuantumMeasurementOperator", "[", 
    RowBox[{"QuantumOperator", "[", "\"\<Z\>\"", "]"}], "]"}], "[", 
   RowBox[{"QuantumState", "[", 
    RowBox[{
     RowBox[{"1", "/", "2"}], " ", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{"IdentityMatrix", "[", "2", "]"}], " ", "+", " ", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"rx", ",", " ", "ry", ",", " ", "rz"}], "}"}], " ", ".", " ", 
        RowBox[{"PauliMatrix", "[", 
         RowBox[{"{", 
          RowBox[{"1", ",", " ", "2", ",", " ", "3"}], "}"}], "]"}]}]}], 
      ")"}]}], "]"}], "]"}], "[", "\"\<PostMeasurementState\>\"", 
  "]"}]], "Input",
 CellLabel->
  "In[162]:= ",ExpressionUUID->"9fc1c559-a1b8-4b8c-af3c-2400cb91e5d3"],

Cell[TextData[{
 "Both give ",
 Cell[BoxData[
  RowBox[{
   RowBox[{
    StyleBox["diag",
     FontSlant->"Plain"], 
    StyleBox["(",
     FontSize->1.2 Inherited], 
    FractionBox[
     RowBox[{"1", "+", 
      SubscriptBox[
       StyleBox["r", "TI"], 
       StyleBox["z", "TI"]]}], "2"]}], ",", 
   RowBox[{
    FractionBox[
     RowBox[{"1", "-", 
      SubscriptBox[
       StyleBox["r", "TI"], 
       StyleBox["z", "TI"]]}], "2"], 
    StyleBox[")",
     FontSize->1.2 Inherited]}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "16fa3d86-a17a-4525-a771-b80f148ef1bb"],
 ": the coherences ",
 Cell[BoxData[
  RowBox[{
   SubscriptBox[
    StyleBox["r", "TI"], 
    StyleBox["x", "TI"]], ",", 
   SubscriptBox[
    StyleBox["r", "TI"], 
    StyleBox["y", "TI"]]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "1a093e4e-53d3-485f-8260-0983bbea9eca"],
 " are erased while the populations ",
 Cell[BoxData[
  FractionBox[
   RowBox[{"1", "\[PlusMinus]", 
    SubscriptBox[
     StyleBox["r", "TI"], 
     StyleBox["z", "TI"]]}], "2"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "6ee1c8bb-58f4-4981-98b9-03817ef5cf58"],
 " are untouched, for any state, pure or mixed. This is decoherence in the \
measured basis, the same map a dephasing environment applies, and it is what \
separates a measurement that is ",
 StyleBox["read", "TI"],
 " from one that is merely coupled."
}], "Text",ExpressionUUID->"bd677de9-b991-49d9-afc4-329e88109ac2"],

Cell["Part 6. Uncertainty and incompatibility", "Section",ExpressionUUID->"e37d55fc-c5ae-4710-8b20-89a8d553c0fd"],

Cell["\<\
6.1 [MSc] How do I verify the Robertson-Schrodinger uncertainty relation for \
a given state?\
\>", "Subsection",ExpressionUUID->"c8e835d6-0615-4e71-b14b-2204486ea6ff"],

Cell[TextData[{
 "For observables ",
 Cell[BoxData[
  RowBox[{
   StyleBox["A", "TI"], ",", 
   StyleBox["B", "TI"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "5b220f0c-36a5-4921-ad19-b28242096999"],
 " on ",
 StyleBox["any", "TI"],
 " state ",
 Cell[BoxData[
  StyleBox["\[Rho]", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "39cab586-47cc-400a-ba72-578edb191bee"],
 " (pure or mixed), with standard deviations ",
 Cell[BoxData[
  RowBox[{
   SubscriptBox[
    StyleBox["\[Sigma]", "TI"], 
    StyleBox["A", "TI"]], "=", 
   SqrtBox[
    RowBox[{
     StyleBox["\[LeftAngleBracket]",
      SpanMaxSize->1], 
     SuperscriptBox[
      StyleBox["A", "TI"], "2"], 
     StyleBox["\[RightAngleBracket]",
      SpanMaxSize->1], "-", 
     SuperscriptBox[
      RowBox[{
       StyleBox["\[LeftAngleBracket]",
        SpanMaxSize->1], 
       StyleBox["A", "TI"], "\[VeryThinSpace]", 
       StyleBox["\[RightAngleBracket]",
        SpanMaxSize->1]}], "2"]}]]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "3ca3d735-f453-4d2a-99da-ee9e7b1c6456"],
 " and ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["\[Sigma]", "TI"], 
   StyleBox["B", "TI"]]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "b82134a4-72ec-4b9f-8169-30a17a4e7780"],
 " likewise, the Robertson-Schrodinger relation bounds the product of \
variances,"
}], "Text",ExpressionUUID->"4eb0bb27-057e-4e26-9a82-5ae3b9a290e9"],

Cell[BoxData[
 PaneBox[
  RowBox[{
   RowBox[{
    SubsuperscriptBox[
     StyleBox["\[Sigma]", "TI"], 
     StyleBox["A", "TI"], "2"], " ", 
    SubsuperscriptBox[
     StyleBox["\[Sigma]", "TI"], 
     StyleBox["B", "TI"], "2"], "\[ThickSpace]", "\[GreaterEqual]", 
    "\[ThickSpace]", 
    StyleBox["(",
     FontSize->1.8 Inherited], 
    FractionBox["1", "2"], 
    StyleBox["\[LeftAngleBracket]",
     SpanMaxSize->1], 
    RowBox[{
     RowBox[{"{", 
      StyleBox["A", "TI"]}], ",", 
     RowBox[{
      StyleBox["B", "TI"], "}"}]}], 
    StyleBox["\[RightAngleBracket]",
     SpanMaxSize->1], "-", 
    StyleBox["\[LeftAngleBracket]",
     SpanMaxSize->1], 
    StyleBox["A", "TI"], "\[VeryThinSpace]", 
    StyleBox["\[RightAngleBracket]",
     SpanMaxSize->1], 
    StyleBox["\[LeftAngleBracket]",
     SpanMaxSize->1], 
    StyleBox["B", "TI"], "\[VeryThinSpace]", 
    StyleBox["\[RightAngleBracket]",
     SpanMaxSize->1], 
    SuperscriptBox[
     StyleBox[")",
      FontSize->1.8 Inherited], "2"], "+", 
    StyleBox["(",
     FontSize->1.8 Inherited], 
    FractionBox["1", 
     RowBox[{"2", 
      StyleBox["i", "TI"]}]], 
    StyleBox["\[LeftAngleBracket]",
     SpanMaxSize->1], 
    RowBox[{
     StyleBox["[",
      SpanMaxSize->1], 
     RowBox[{
      StyleBox["A", "TI"], ",", 
      StyleBox["B", "TI"]}], 
     StyleBox["]",
      SpanMaxSize->1]}], 
    StyleBox["\[RightAngleBracket]",
     SpanMaxSize->1], 
    SuperscriptBox[
     StyleBox[")",
      FontSize->1.8 Inherited], "2"]}], ","}],
  Alignment->Center,
  ImageSize->Full]], "DisplayFormula",ExpressionUUID->"8a0f150f-f078-4236-\
8e10-07e5a983beb8"],

Cell[TextData[{
 "the first term a covariance, the second the Robertson (commutator) piece, \
with ",
 Cell[BoxData[
  RowBox[{
   StyleBox["\[LeftAngleBracket]",
    SpanMaxSize->1], "\[CenterDot]", "\[VeryThinSpace]", 
   StyleBox["\[RightAngleBracket]",
    SpanMaxSize->1], "=", 
   StyleBox["Tr",
    FontSlant->"Plain"], 
   StyleBox["[",
    SpanMaxSize->1], 
   RowBox[{"\[CenterDot]", " ", 
    StyleBox["\[Rho]", "TI"]}], 
   StyleBox["]",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "698a8743-5937-400b-a05c-26906bcff146"],
 ". Take ",
 Cell[BoxData[
  RowBox[{
   RowBox[{
    StyleBox["A", "TI"], "=", 
    StyleBox["X", "TI"]}], ",", 
   RowBox[{
    StyleBox["B", "TI"], "=", 
    StyleBox["Z", "TI"]}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "4608415d-4f5e-4103-9009-688986951c8d"],
 " on a general qubit ",
 Cell[BoxData[
  RowBox[{
   StyleBox["\[Rho]", "TI"], "=", 
   FractionBox["1", "2"], 
   StyleBox["(",
    SpanMaxSize->1], 
   RowBox[{
    StyleBox["I", "TI"], "+", 
    OverscriptBox[
     StyleBox["r", "TI"], "\[RightVector]"], "\[CenterDot]", 
    OverscriptBox[
     StyleBox["\[Sigma]", "TI"], "\[RightVector]"]}], 
   StyleBox[")",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "c6045191-5c1a-47a0-a12b-465ed7a21e92"],
 ", ",
 Cell[BoxData[
  RowBox[{GridBox[{
     {
      OverscriptBox[
       StyleBox["r", "TI"], "\[RightVector]"]}
    },
    GridBoxDividers->{"Columns" -> {True, True}, "Rows" -> {}},
    GridBoxSpacings->{"Columns" -> {{0.15}}}], "\[LessEqual]", "1"}]], 
  "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "ebe47cea-976f-42e9-9b6c-8188b5ad9fbb"],
 "; the telling quantity is the slack, how far the state sits above the bound."
}], "Text",ExpressionUUID->"84160168-297c-43a9-b33a-aecd90938135"],

Cell[TextData[{
 StyleBox["WL",
  FontWeight->"Bold"],
 " : with ",
 Cell[BoxData[
  RowBox[{
   StyleBox["\[LeftAngleBracket]",
    SpanMaxSize->1], "\[CenterDot]", "\[VeryThinSpace]", 
   StyleBox["\[RightAngleBracket]",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "c02d4287-a104-4fd5-96e9-34d623bae5da"],
 " the trace against ",
 Cell[BoxData[
  StyleBox["\[Rho]", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "5f3265cf-8e31-4f98-8e21-6d0b64ab8a85"],
 ", compute the left side minus the right side."
}], "Text",ExpressionUUID->"a359fe6a-ebe7-4f4b-a588-7e512387cfde"],

Cell[BoxData[
 RowBox[{"With", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{"rho", " ", "=", " ", 
      RowBox[{
       RowBox[{"1", "/", "2"}], " ", 
       RowBox[{"(", 
        RowBox[{
         RowBox[{"IdentityMatrix", "[", "2", "]"}], " ", "+", " ", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{"rx", ",", " ", "ry", ",", " ", "rz"}], "}"}], " ", ".", 
          " ", 
          RowBox[{"PauliMatrix", "[", 
           RowBox[{"{", 
            RowBox[{"1", ",", " ", "2", ",", " ", "3"}], "}"}], "]"}]}]}], 
        ")"}]}]}], ",", " ", 
     RowBox[{"x", " ", "=", " ", 
      RowBox[{"PauliMatrix", "[", "1", "]"}]}], ",", " ", 
     RowBox[{"z", " ", "=", " ", 
      RowBox[{"PauliMatrix", "[", "3", "]"}]}]}], "}"}], ",", "\n", " ", 
   RowBox[{"With", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"ev", " ", "=", " ", 
       RowBox[{
        RowBox[{"Tr", "[", 
         RowBox[{"#", " ", ".", " ", "rho"}], "]"}], " ", "&"}]}], "}"}], ",",
      "\n", "  ", 
     RowBox[{"FullSimplify", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"(", 
         RowBox[{
          RowBox[{"ev", "[", 
           RowBox[{"x", " ", ".", " ", "x"}], "]"}], " ", "-", " ", 
          RowBox[{
           RowBox[{"ev", "[", "x", "]"}], "^", "2"}]}], ")"}], " ", 
        RowBox[{"(", 
         RowBox[{
          RowBox[{"ev", "[", 
           RowBox[{"z", " ", ".", " ", "z"}], "]"}], " ", "-", " ", 
          RowBox[{
           RowBox[{"ev", "[", "z", "]"}], "^", "2"}]}], ")"}]}], " ", "-", 
       "\n", "    ", 
       RowBox[{"(", 
        RowBox[{
         RowBox[{
          RowBox[{"(", 
           RowBox[{
            RowBox[{"ev", "[", 
             RowBox[{
              RowBox[{"(", 
               RowBox[{
                RowBox[{"x", " ", ".", " ", "z"}], " ", "+", " ", 
                RowBox[{"z", " ", ".", " ", "x"}]}], ")"}], "/", "2"}], "]"}],
             " ", "-", " ", 
            RowBox[{
             RowBox[{"ev", "[", "x", "]"}], " ", 
             RowBox[{"ev", "[", "z", "]"}]}]}], ")"}], "^", "2"}], " ", "+", 
         " ", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{
            RowBox[{"ev", "[", 
             RowBox[{
              RowBox[{"x", " ", ".", " ", "z"}], " ", "-", " ", 
              RowBox[{"z", " ", ".", " ", "x"}]}], "]"}], "/", 
            RowBox[{"(", 
             RowBox[{"2", " ", "I"}], ")"}]}], ")"}], "^", "2"}]}], ")"}]}], 
      "]"}]}], "]"}]}], "]"}]], "Input",
 CellLabel->
  "In[163]:= ",ExpressionUUID->"fc38ce45-0c01-4e7b-9a11-50b2d64468b2"],

Cell[TextData[{
 StyleBox["QF",
  FontWeight->"Bold"],
 " : the same, the general state as a ",
 Cell[BoxData["QuantumState"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "496a768d-77e1-486f-ad9c-3bf06e2151fe"],
 " and its density matrix, the operators as ",
 Cell[BoxData["QuantumOperator"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "b33d5cda-6637-4f14-bcfd-41b9d2d5171b"],
 "s and the commutator via ",
 Cell[BoxData["Commutator"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "ab959317-8e02-4c18-8a84-c573a7efd7b7"],
 "."
}], "Text",ExpressionUUID->"4abb4c24-f868-4b33-b115-6ea1506dfb96"],

Cell[BoxData[
 RowBox[{"With", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{"qs", " ", "=", " ", 
      RowBox[{"QuantumState", "[", 
       RowBox[{
        RowBox[{"1", "/", "2"}], " ", 
        RowBox[{"(", 
         RowBox[{
          RowBox[{"IdentityMatrix", "[", "2", "]"}], " ", "+", " ", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{"rx", ",", " ", "ry", ",", " ", "rz"}], "}"}], " ", ".", 
           " ", 
           RowBox[{"PauliMatrix", "[", 
            RowBox[{"{", 
             RowBox[{"1", ",", " ", "2", ",", " ", "3"}], "}"}], "]"}]}]}], 
         ")"}]}], "]"}]}], ",", " ", 
     RowBox[{"x", " ", "=", " ", 
      RowBox[{"QuantumOperator", "[", "\"\<X\>\"", "]"}]}], ",", " ", 
     RowBox[{"z", " ", "=", " ", 
      RowBox[{"QuantumOperator", "[", "\"\<Z\>\"", "]"}]}]}], "}"}], ",", 
   "\n", " ", 
   RowBox[{"With", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"ev", " ", "=", " ", 
       RowBox[{
        RowBox[{"Tr", "[", 
         RowBox[{
          RowBox[{"Normal", "[", 
           RowBox[{"#", "[", "\"\<Matrix\>\"", "]"}], "]"}], " ", ".", " ", 
          RowBox[{"Normal", "[", 
           RowBox[{"qs", "[", "\"\<DensityMatrix\>\"", "]"}], "]"}]}], "]"}], 
        " ", "&"}]}], "}"}], ",", "\n", "  ", 
     RowBox[{"FullSimplify", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"(", 
         RowBox[{
          RowBox[{"ev", "[", 
           RowBox[{"x", " ", "@", " ", "x"}], "]"}], " ", "-", " ", 
          RowBox[{
           RowBox[{"ev", "[", "x", "]"}], "^", "2"}]}], ")"}], " ", 
        RowBox[{"(", 
         RowBox[{
          RowBox[{"ev", "[", 
           RowBox[{"z", " ", "@", " ", "z"}], "]"}], " ", "-", " ", 
          RowBox[{
           RowBox[{"ev", "[", "z", "]"}], "^", "2"}]}], ")"}]}], " ", "-", 
       "\n", "    ", 
       RowBox[{"(", 
        RowBox[{
         RowBox[{
          RowBox[{"(", 
           RowBox[{
            RowBox[{"ev", "[", 
             RowBox[{
              RowBox[{"(", 
               RowBox[{
                RowBox[{"x", " ", "@", " ", "z"}], " ", "+", " ", 
                RowBox[{"z", " ", "@", " ", "x"}]}], ")"}], "/", "2"}], "]"}],
             " ", "-", " ", 
            RowBox[{
             RowBox[{"ev", "[", "x", "]"}], " ", 
             RowBox[{"ev", "[", "z", "]"}]}]}], ")"}], "^", "2"}], " ", "+", 
         " ", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{
            RowBox[{"ev", "[", 
             RowBox[{"Commutator", "[", 
              RowBox[{"x", ",", " ", "z"}], "]"}], "]"}], "/", 
            RowBox[{"(", 
             RowBox[{"2", " ", "I"}], ")"}]}], ")"}], "^", "2"}]}], ")"}]}], 
      "]"}]}], "]"}]}], "]"}]], "Input",
 CellLabel->
  "In[164]:= ",ExpressionUUID->"43d04d52-9a77-405d-aedf-378255a8d40c"],

Cell[TextData[{
 "Both return ",
 Cell[BoxData[
  RowBox[{"1", "-", 
   SuperscriptBox[GridBox[{
      {
       OverscriptBox[
        StyleBox["r", "TI"], "\[RightVector]"]}
     },
     GridBoxDividers->{"Columns" -> {True, True}, "Rows" -> {}},
     GridBoxSpacings->{"Columns" -> {{0.15}}}], "2"], "\[GreaterEqual]", 
   "0"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "52c9b111-15d9-4cd2-b05c-3a27811e3037"],
 ": the relation holds for every state, and the slack is exactly the \
mixedness, ",
 Cell[BoxData[
  RowBox[{"1", "-", 
   SuperscriptBox[GridBox[{
      {
       OverscriptBox[
        StyleBox["r", "TI"], "\[RightVector]"]}
     },
     GridBoxDividers->{"Columns" -> {True, True}, "Rows" -> {}},
     GridBoxSpacings->{"Columns" -> {{0.15}}}], "2"], "=", "2", 
   StyleBox["(",
    SpanMaxSize->1], 
   RowBox[{"1", "-", 
    StyleBox["Tr",
     FontSlant->"Plain"], 
    StyleBox["[",
     SpanMaxSize->1], 
    SuperscriptBox[
     StyleBox["\[Rho]", "TI"], "2"], 
    StyleBox["]",
     SpanMaxSize->1]}], 
   StyleBox[")",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "0bd1246a-b317-46ff-91aa-592b25e1c487"],
 ". It vanishes only on the pure states (",
 Cell[BoxData[
  RowBox[{GridBox[{
     {
      OverscriptBox[
       StyleBox["r", "TI"], "\[RightVector]"]}
    },
    GridBoxDividers->{"Columns" -> {True, True}, "Rows" -> {}},
    GridBoxSpacings->{"Columns" -> {{0.15}}}], "=", "1"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "277c1c6e-cb13-479b-acc9-f4328595c9b5"],
 "), which therefore saturate Robertson-Schrodinger; a mixed state's extra \
uncertainty lifts it strictly above the bound. The commutator term alone is \
the weaker Robertson relation ",
 Cell[BoxData[
  RowBox[{
   SubscriptBox[
    StyleBox["\[Sigma]", "TI"], 
    StyleBox["A", "TI"]], 
   SubscriptBox[
    StyleBox["\[Sigma]", "TI"], 
    StyleBox["B", "TI"]], "\[GreaterEqual]", 
   FractionBox["1", "2"], GridBox[{
     {
      RowBox[{
       StyleBox["\[LeftAngleBracket]",
        SpanMaxSize->1], 
       StyleBox["[",
        SpanMaxSize->1], 
       StyleBox["A", "TI"], ",", 
       StyleBox["B", "TI"], 
       StyleBox["]",
        SpanMaxSize->1], 
       StyleBox["\[RightAngleBracket]",
        SpanMaxSize->1]}]}
    },
    GridBoxDividers->{"Columns" -> {True, True}, "Rows" -> {}},
    GridBoxSpacings->{"Columns" -> {{0.15}}}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "5fd7c314-881e-4d68-ba13-b271bfb0f705"],
 "; Schrodinger's covariance term is what tightens it."
}], "Text",ExpressionUUID->"93a43a85-66d6-4a2c-9519-5d7db569bc0f"],

Cell["\<\
6.2 [MSc] How do I find a minimum-uncertainty state that saturates the \
Robertson bound?\
\>", "Subsection",ExpressionUUID->"dda9b67d-0842-4731-bb4f-d7f1a4879a0b"],

Cell[TextData[{
 "The Robertson bound ",
 Cell[BoxData[
  RowBox[{
   SubscriptBox[
    StyleBox["\[Sigma]", "TI"], 
    StyleBox["A", "TI"]], 
   SubscriptBox[
    StyleBox["\[Sigma]", "TI"], 
    StyleBox["B", "TI"]], "\[GreaterEqual]", 
   FractionBox["1", "2"], GridBox[{
     {
      RowBox[{
       StyleBox["\[LeftAngleBracket]",
        SpanMaxSize->1], 
       StyleBox["[",
        SpanMaxSize->1], 
       StyleBox["A", "TI"], ",", 
       StyleBox["B", "TI"], 
       StyleBox["]",
        SpanMaxSize->1], 
       StyleBox["\[RightAngleBracket]",
        SpanMaxSize->1]}]}
    },
    GridBoxDividers->{"Columns" -> {True, True}, "Rows" -> {}},
    GridBoxSpacings->{"Columns" -> {{0.15}}}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "db931504-58d1-4a26-9c92-0dc51b41523c"],
 " is saturated exactly where the ",
 StyleBox["Robertson gap", "TI"],
 " ",
 Cell[BoxData[
  RowBox[{
   StyleBox["g", "TI"], "=", 
   SubsuperscriptBox[
    StyleBox["\[Sigma]", "TI"], 
    StyleBox["A", "TI"], "2"], 
   SubsuperscriptBox[
    StyleBox["\[Sigma]", "TI"], 
    StyleBox["B", "TI"], "2"], "-", 
   StyleBox["(",
    FontSize->1.2 Inherited], 
   FractionBox["1", 
    RowBox[{"2", 
     StyleBox["i", "TI"]}]], 
   StyleBox["\[LeftAngleBracket]",
    SpanMaxSize->1], 
   RowBox[{
    StyleBox["[",
     SpanMaxSize->1], 
    RowBox[{
     StyleBox["A", "TI"], ",", 
     StyleBox["B", "TI"]}], 
    StyleBox["]",
     SpanMaxSize->1]}], 
   StyleBox["\[RightAngleBracket]",
    SpanMaxSize->1], 
   SuperscriptBox[
    StyleBox[")",
     FontSize->1.2 Inherited], "2"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "8f360cdb-496b-4a8b-9106-363eefa8dc8e"],
 " vanishes. So do not guess a state: compute ",
 Cell[BoxData[
  StyleBox["g", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "a76f5591-2d80-416d-bbbf-c15bfa4f8f71"],
 " over the whole pure-qubit family and solve ",
 Cell[BoxData[
  RowBox[{
   StyleBox["g", "TI"], "=", "0"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "6a96de9e-0e6c-4546-8b47-2f86c0946f38"],
 ". Take ",
 Cell[BoxData[
  RowBox[{
   RowBox[{
    StyleBox["A", "TI"], "=", 
    StyleBox["X", "TI"]}], ",", 
   RowBox[{
    StyleBox["B", "TI"], "=", 
    StyleBox["Z", "TI"]}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "daaa4dae-9b2f-4db4-9c4e-5fdd545c8389"],
 "."
}], "Text",ExpressionUUID->"d65747fb-6c63-474d-8c1e-80e59b1dec62"],

Cell[TextData[{
 StyleBox["WL",
  FontWeight->"Bold"],
 " : the gap as a function of the Bloch angles."
}], "Text",ExpressionUUID->"74a5f648-d371-4661-a6f4-2425f30b37f1"],

Cell[BoxData[
 RowBox[{"gap", " ", "=", " ", 
  RowBox[{"With", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{"psi", " ", "=", " ", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"Cos", "[", 
          RowBox[{"\[Theta]", "/", "2"}], "]"}], ",", " ", 
         RowBox[{
          RowBox[{"Exp", "[", 
           RowBox[{"I", " ", "\[Phi]"}], "]"}], " ", 
          RowBox[{"Sin", "[", 
           RowBox[{"\[Theta]", "/", "2"}], "]"}]}]}], "}"}]}], ",", " ", 
      RowBox[{"x", " ", "=", " ", 
       RowBox[{"PauliMatrix", "[", "1", "]"}]}], ",", " ", 
      RowBox[{"z", " ", "=", " ", 
       RowBox[{"PauliMatrix", "[", "3", "]"}]}]}], "}"}], ",", "\n", "  ", 
    RowBox[{"With", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"ev", " ", "=", " ", 
        RowBox[{
         RowBox[{
          RowBox[{"Conjugate", "[", "psi", "]"}], " ", ".", " ", "#", " ", ".",
           " ", "psi"}], " ", "&"}]}], "}"}], ",", "\n", "   ", 
      RowBox[{"FullSimplify", "[", 
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{"(", 
           RowBox[{
            RowBox[{"ev", "[", 
             RowBox[{"x", " ", ".", " ", "x"}], "]"}], " ", "-", " ", 
            RowBox[{
             RowBox[{"ev", "[", "x", "]"}], "^", "2"}]}], ")"}], " ", 
          RowBox[{"(", 
           RowBox[{
            RowBox[{"ev", "[", 
             RowBox[{"z", " ", ".", " ", "z"}], "]"}], " ", "-", " ", 
            RowBox[{
             RowBox[{"ev", "[", "z", "]"}], "^", "2"}]}], ")"}]}], " ", "-", 
         " ", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{
            RowBox[{"ev", "[", 
             RowBox[{
              RowBox[{"x", " ", ".", " ", "z"}], " ", "-", " ", 
              RowBox[{"z", " ", ".", " ", "x"}]}], "]"}], "/", 
            RowBox[{"(", 
             RowBox[{"2", " ", "I"}], ")"}]}], ")"}], "^", "2"}]}], ",", " ", 
        
        RowBox[{
         RowBox[{"{", 
          RowBox[{"\[Theta]", ",", " ", "\[Phi]"}], "}"}], " ", "\[Element]", 
         " ", "Reals"}]}], "]"}]}], "]"}]}], "]"}]}]], "Input",
 CellLabel->
  "In[165]:= ",ExpressionUUID->"61785bc7-8326-4154-a064-796adfa5c75d"],

Cell[TextData[{
 "Solving ",
 Cell[BoxData[
  RowBox[{
   StyleBox["g", "TI"], "=", "0"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "61e0535b-8016-4960-960e-e3507b1da57e"],
 " finds the minimum-uncertainty states."
}], "Text",ExpressionUUID->"18dac8a5-0f26-4ca9-ad14-f91036d58aa0"],

Cell[BoxData[
 RowBox[{"Reduce", "[", 
  RowBox[{
   RowBox[{
    RowBox[{"gap", " ", "==", " ", "0"}], " ", "&&", " ", 
    RowBox[{"0", " ", "<", " ", "\[Theta]", " ", "<", " ", "Pi"}], " ", "&&", 
    " ", 
    RowBox[{
     RowBox[{"-", "Pi"}], " ", "<", " ", "\[Phi]", " ", "<=", " ", "Pi"}]}], ",",
    " ", 
   RowBox[{"{", 
    RowBox[{"\[Theta]", ",", " ", "\[Phi]"}], "}"}]}], "]"}]], "Input",
 CellLabel->
  "In[166]:= ",ExpressionUUID->"1519af74-6d96-4087-b87a-0ac9a78f2c2a"],

Cell[TextData[{
 "One such state sits where the two branches cross, ",
 Cell[BoxData[
  RowBox[{
   StyleBox["\[Theta]", "TI"], "=", 
   StyleBox["\[Phi]", "TI"], "=", 
   FractionBox["\[Pi]", "2"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "d4aa91f8-75a7-4702-b59f-f5bd8c8bbdf3"],
 "."
}], "Text",ExpressionUUID->"54fec23e-7e76-4c83-93df-6a36c53505d4"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{"Cos", "[", 
      RowBox[{"\[Theta]", "/", "2"}], "]"}], ",", " ", 
     RowBox[{
      RowBox[{"Exp", "[", 
       RowBox[{"I", " ", "\[Phi]"}], "]"}], " ", 
      RowBox[{"Sin", "[", 
       RowBox[{"\[Theta]", "/", "2"}], "]"}]}]}], "}"}], " ", "/.", " ", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"\[Theta]", " ", "->", " ", 
      RowBox[{"Pi", "/", "2"}]}], ",", " ", 
     RowBox[{"\[Phi]", " ", "->", " ", 
      RowBox[{"Pi", "/", "2"}]}]}], "}"}]}], " ", "//", " ", 
  "FullSimplify"}]], "Input",
 CellLabel->
  "In[167]:= ",ExpressionUUID->"9e5dff89-eb0f-496b-b95a-44357d6ac5a5"],

Cell[TextData[{
 StyleBox["QF",
  FontWeight->"Bold"],
 " : the same gap from the ",
 Cell[BoxData["QuantumState"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "49debdb6-32d8-47c9-8669-81062ab72ce2"],
 " and ",
 Cell[BoxData["QuantumOperator"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "b9715f4d-4b9e-44f1-a5a2-67cfa9459b37"],
 "s (the solve is identical)."
}], "Text",ExpressionUUID->"fad40416-3967-4ba8-9d66-2f6a5dd665d4"],

Cell[BoxData[
 RowBox[{"With", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{"psi", " ", "=", " ", 
      RowBox[{"QuantumState", "[", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"Cos", "[", 
          RowBox[{"\[Theta]", "/", "2"}], "]"}], ",", " ", 
         RowBox[{
          RowBox[{"Exp", "[", 
           RowBox[{"I", " ", "\[Phi]"}], "]"}], " ", 
          RowBox[{"Sin", "[", 
           RowBox[{"\[Theta]", "/", "2"}], "]"}]}]}], "}"}], "]"}]}], ",", 
     " ", 
     RowBox[{"x", " ", "=", " ", 
      RowBox[{"QuantumOperator", "[", "\"\<X\>\"", "]"}]}], ",", " ", 
     RowBox[{"z", " ", "=", " ", 
      RowBox[{"QuantumOperator", "[", "\"\<Z\>\"", "]"}]}]}], "}"}], ",", 
   "\n", " ", 
   RowBox[{"With", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"ev", " ", "=", " ", 
       RowBox[{
        RowBox[{
         RowBox[{"(", 
          RowBox[{
           RowBox[{"psi", "[", "\"\<Dagger\>\"", "]"}], " ", "@", " ", 
           RowBox[{"#", " ", "@", " ", "psi"}]}], ")"}], "[", "\"\<Scalar\>\"",
          "]"}], " ", "&"}]}], "}"}], ",", "\n", "  ", 
     RowBox[{"FullSimplify", "[", 
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{"(", 
          RowBox[{
           RowBox[{"ev", "[", 
            RowBox[{"x", " ", "@", " ", "x"}], "]"}], " ", "-", " ", 
           RowBox[{
            RowBox[{"ev", "[", "x", "]"}], "^", "2"}]}], ")"}], " ", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{"ev", "[", 
            RowBox[{"z", " ", "@", " ", "z"}], "]"}], " ", "-", " ", 
           RowBox[{
            RowBox[{"ev", "[", "z", "]"}], "^", "2"}]}], ")"}]}], " ", "-", 
        " ", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{
           RowBox[{"ev", "[", 
            RowBox[{"Commutator", "[", 
             RowBox[{"x", ",", " ", "z"}], "]"}], "]"}], "/", 
           RowBox[{"(", 
            RowBox[{"2", " ", "I"}], ")"}]}], ")"}], "^", "2"}]}], ",", " ", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"\[Theta]", ",", " ", "\[Phi]"}], "}"}], " ", "\[Element]", 
        " ", "Reals"}]}], "]"}]}], "]"}]}], "]"}]], "Input",
 CellLabel->
  "In[168]:= ",ExpressionUUID->"e4b49358-ada9-463c-a19c-a97d72c4b0ac"],

Cell[TextData[{
 "The gap is ",
 Cell[BoxData[
  RowBox[{
   StyleBox["g", "TI"], "=", 
   SuperscriptBox[
    RowBox[{
     StyleBox["\[LeftAngleBracket]",
      SpanMaxSize->1], 
     StyleBox["X", "TI"], "\[VeryThinSpace]", 
     StyleBox["\[RightAngleBracket]",
      SpanMaxSize->1]}], "2"], 
   SuperscriptBox[
    RowBox[{
     StyleBox["\[LeftAngleBracket]",
      SpanMaxSize->1], 
     StyleBox["Z", "TI"], "\[VeryThinSpace]", 
     StyleBox["\[RightAngleBracket]",
      SpanMaxSize->1]}], "2"], "=", 
   SuperscriptBox[
    StyleBox["cos",
     FontSlant->"Plain"], "2"], "\[ThinSpace]", 
   StyleBox["\[Theta]", "TI"], " ", 
   SuperscriptBox[
    StyleBox["cos",
     FontSlant->"Plain"], "2"], "\[ThinSpace]", 
   StyleBox["\[Phi]", "TI"], " ", 
   SuperscriptBox[
    StyleBox["sin",
     FontSlant->"Plain"], "2"], "\[ThinSpace]", 
   StyleBox["\[Theta]", "TI"], "\[GreaterEqual]", "0"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "e885090d-f92a-4cee-901b-6ad019fc2f91"],
 ", so it vanishes exactly where ",
 Cell[BoxData[
  RowBox[{
   StyleBox["\[LeftAngleBracket]",
    SpanMaxSize->1], 
   StyleBox["X", "TI"], "\[VeryThinSpace]", 
   StyleBox["\[RightAngleBracket]",
    SpanMaxSize->1], "=", "0"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "b10d3540-1756-4864-a947-7e73b243cdf0"],
 " or ",
 Cell[BoxData[
  RowBox[{
   StyleBox["\[LeftAngleBracket]",
    SpanMaxSize->1], 
   StyleBox["Z", "TI"], "\[VeryThinSpace]", 
   StyleBox["\[RightAngleBracket]",
    SpanMaxSize->1], "=", "0"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "db53069d-47b6-4bfc-8bfd-ca00fb932762"],
 ": the equator ",
 Cell[BoxData[
  RowBox[{
   StyleBox["\[Theta]", "TI"], "=", 
   FractionBox["\[Pi]", "2"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "47cf92ac-a9cd-4eb5-8958-62b0ac63bae9"],
 " (",
 Cell[BoxData[
  RowBox[{
   StyleBox["\[LeftAngleBracket]",
    SpanMaxSize->1], 
   StyleBox["Z", "TI"], "\[VeryThinSpace]", 
   StyleBox["\[RightAngleBracket]",
    SpanMaxSize->1], "=", "0"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "a2831246-1ac6-43b1-a02d-8230be849e3b"],
 ") and the meridians ",
 Cell[BoxData[
  RowBox[{
   StyleBox["\[Phi]", "TI"], "=", "\[PlusMinus]", 
   FractionBox["\[Pi]", "2"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "7f783a28-6afc-41a8-80dc-4dc39d54bab7"],
 " (",
 Cell[BoxData[
  RowBox[{
   StyleBox["\[LeftAngleBracket]",
    SpanMaxSize->1], 
   StyleBox["X", "TI"], "\[VeryThinSpace]", 
   StyleBox["\[RightAngleBracket]",
    SpanMaxSize->1], "=", "0"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "150a90d6-078b-4eed-aaa5-c8a1f18c1d37"],
 "). At their crossing both vanish, giving the ",
 Cell[BoxData[
  StyleBox["Y", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "0e6fb95b-4225-4260-927d-83c51276eb87"],
 " eigenstate ",
 Cell[BoxData[
  RowBox[{
   RowBox[{"{", "1"}], ",", 
   RowBox[{
    StyleBox["i", "TI"], "}", "/", 
    SqrtBox["2"]}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "ec5e6451-eab3-4339-ab9a-3ede2bd0bfd7"],
 ", the most symmetric minimum-uncertainty state, which fell out of the solve \
rather than being assumed. There the covariance ",
 Cell[BoxData[
  RowBox[{
   StyleBox["\[LeftAngleBracket]",
    SpanMaxSize->1], 
   StyleBox["X", "TI"], "\[VeryThinSpace]", 
   StyleBox["\[RightAngleBracket]",
    SpanMaxSize->1], 
   StyleBox["\[LeftAngleBracket]",
    SpanMaxSize->1], 
   StyleBox["Z", "TI"], "\[VeryThinSpace]", 
   StyleBox["\[RightAngleBracket]",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "2aa0ed64-8379-483e-97af-40dd657043ba"],
 " is zero, which is what lets the plain Robertson bound be reached."
}], "Text",ExpressionUUID->"fe7868bd-01c4-40d2-a7f0-b74fbcdb7eec"],

Cell[TextData[{
 "6.3 [BSc] How do I compute the classical Shannon entropy ",
 Cell[BoxData[
  RowBox[{
   StyleBox["H", "TI"], 
   StyleBox["(",
    SpanMaxSize->1], 
   StyleBox["p", "TI"], 
   StyleBox[")",
    SpanMaxSize->1], "=", "-", 
   UnderscriptBox["\[Sum]", 
    StyleBox["i", "TI"],
    LimitsPositioning->False], 
   SubscriptBox[
    StyleBox["p", "TI"], 
    StyleBox["i", "TI"]], 
   SubscriptBox[
    StyleBox["log",
     FontSlant->"Plain"], "2"], "\[ThinSpace]", 
   SubscriptBox[
    StyleBox["p", "TI"], 
    StyleBox["i", "TI"]]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "23369235-fbdb-4bb4-9f21-a64fd2eb9f05"],
 " of a measurement distribution?"
}], "Subsection",ExpressionUUID->"889b93c1-3f84-46d3-9098-f8fce437217f"],

Cell[TextData[{
 "A measurement yields a probability distribution; its Shannon entropy ",
 Cell[BoxData[
  RowBox[{
   StyleBox["H", "TI"], 
   StyleBox["(",
    SpanMaxSize->1], 
   StyleBox["p", "TI"], 
   StyleBox[")",
    SpanMaxSize->1], "=", "-", 
   UnderscriptBox["\[Sum]", 
    StyleBox["i", "TI"],
    LimitsPositioning->False], 
   SubscriptBox[
    StyleBox["p", "TI"], 
    StyleBox["i", "TI"]], 
   SubscriptBox[
    StyleBox["log",
     FontSlant->"Plain"], "2"], "\[ThinSpace]", 
   SubscriptBox[
    StyleBox["p", "TI"], 
    StyleBox["i", "TI"]]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "1a54e42b-c327-4456-89ca-8d409355c29d"],
 " (in bits) measures the outcome uncertainty. Take the ",
 Cell[BoxData[
  StyleBox["Z", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "6f8973b1-0f29-480f-a3f4-63a0007364e2"],
 " distribution of a state with populations ",
 Cell[BoxData[
  RowBox[{
   RowBox[{"{", 
    FractionBox["3", "4"]}], ",", 
   RowBox[{
    FractionBox["1", "4"], "}"}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "ddc27e33-d519-4c97-bd60-8c628a113aba"],
 "."
}], "Text",ExpressionUUID->"62925ed6-08b8-46fd-abaf-8b4953507c6b"],

Cell[TextData[{
 StyleBox["WL",
  FontWeight->"Bold"],
 " : the entropy is the negative weighted sum of ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["log",
    FontSlant->"Plain"], "2"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "612a10c7-39d5-4312-a689-472d9b455060"],
 " probabilities."
}], "Text",ExpressionUUID->"51bf0367-c192-4c8d-a2fe-41df1963b121"],

Cell[BoxData[
 RowBox[{"-", 
  RowBox[{"Total", "[", 
   RowBox[{
    RowBox[{
     RowBox[{"#", " ", 
      RowBox[{"Log2", "[", "#", "]"}]}], " ", "&"}], " ", "/@", " ", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"3", "/", "4"}], ",", " ", 
      RowBox[{"1", "/", "4"}]}], "}"}]}], "]"}]}]], "Input",
 CellLabel->
  "In[169]:= ",ExpressionUUID->"2d4adfc7-fed4-4cc1-9aa3-0b4be5849f20"],

Cell[TextData[{
 StyleBox["QF",
  FontWeight->"Bold"],
 " : a ",
 Cell[BoxData["QuantumMeasurement"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "e9d0cf4d-de7a-4194-9bcd-180b2c49c6ac"],
 " reports its ",
 Cell[BoxData["\"\<Entropy\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "1d02675b-41d5-4130-bc12-957b9130a773"],
 " directly, as a ",
 Cell[BoxData["Quantity"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "985587bd-2a86-445d-8d09-c925a0053904"],
 " in bits."
}], "Text",ExpressionUUID->"beb59027-9905-46cb-9e24-51772b23b75a"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"QuantumMeasurementOperator", "[", 
    RowBox[{"QuantumOperator", "[", "\"\<Z\>\"", "]"}], "]"}], "[", 
   RowBox[{"QuantumState", "[", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{
       RowBox[{"Sqrt", "[", "3", "]"}], "/", "2"}], ",", " ", 
      RowBox[{"1", "/", "2"}]}], "}"}], "]"}], "]"}], "[", "\"\<Entropy\>\"", 
  "]"}]], "Input",
 CellLabel->
  "In[170]:= ",ExpressionUUID->"a9c8dd2d-8284-4d32-95f4-dfedd5c1da3c"],

Cell[TextData[{
 "Both give ",
 Cell[BoxData[
  RowBox[{"-", 
   FractionBox["3", "4"], 
   SubscriptBox[
    StyleBox["log",
     FontSlant->"Plain"], "2"], "\[ThinSpace]", 
   FractionBox["3", "4"], "-", 
   FractionBox["1", "4"], 
   SubscriptBox[
    StyleBox["log",
     FontSlant->"Plain"], "2"], "\[ThinSpace]", 
   FractionBox["1", "4"], "\[TildeTilde]", "0.811"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "bec1fff1-1f83-4fdf-8d3a-a7aaa87753c3"],
 " bits: a biased two-outcome distribution carries less than one bit, \
reaching exactly one bit only for the uniform ",
 Cell[BoxData[
  RowBox[{
   RowBox[{"{", 
    FractionBox["1", "2"]}], ",", 
   RowBox[{
    FractionBox["1", "2"], "}"}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "c0abe899-b2bc-466c-912b-559e84b6df5a"],
 "."
}], "Text",ExpressionUUID->"3687043c-5d89-48d5-87f4-bd6c6bc246a3"],

Cell["\<\
6.4 [MSc] How do I construct a maximal set of mutually unbiased bases for a \
qubit?\
\>", "Subsection",ExpressionUUID->"8f3c2f88-43b9-4a81-a34e-3a179e583df9"],

Cell[TextData[{
 "Two bases are mutually unbiased when every cross-overlap is flat, ",
 Cell[BoxData[
  RowBox[{
   SuperscriptBox[GridBox[{
      {
       TemplateBox[{
         StyleBox["e", "TI"], 
         StyleBox["f", "TI"]},
        "BraKet"]}
     },
     GridBoxDividers->{"Columns" -> {True, True}, "Rows" -> {}},
     GridBoxSpacings->{"Columns" -> {{0.15}}}], "2"], "=", "1", "/", 
   StyleBox["d", "TI"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "4b5da871-72fb-4813-8e04-cf6431fe9656"],
 ": a definite state in one is maximally uncertain in the other. Rather than \
name the bases, construct them: start from the computational basis, \
parametrize a basis unbiased to it, then solve for the phase that makes two \
such families mutually unbiased. A qubit (",
 Cell[BoxData[
  RowBox[{
   StyleBox["d", "TI"], "=", "2"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "9c09dce0-a055-4118-9cd4-263c15ac2142"],
 ") admits ",
 Cell[BoxData[
  RowBox[{
   StyleBox["d", "TI"], "+", "1", "=", "3"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "5a08fccd-8a26-42a4-a171-e869a7bb572a"],
 " mutually unbiased bases (MUBs)."
}], "Text",ExpressionUUID->"65297cf2-ee80-4f85-a1df-b4a14a7d19ca"],

Cell[TextData[{
 StyleBox["WL",
  FontWeight->"Bold"],
 " : a basis unbiased to the computational one has equal-modulus amplitudes, ",
 Cell[BoxData[
  RowBox[{
   RowBox[{"{", "1"}], ",", 
   RowBox[{
    SuperscriptBox[
     StyleBox["e", "TI"], 
     StyleBox[
      RowBox[{"i", "\[Alpha]"}], "TI"]], "}", "/", 
    SqrtBox["2"]}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "ca677198-7c9f-4aea-9398-1175b1b124ac"],
 " (with its orthogonal partner); its overlaps with ",
 Cell[BoxData[
  RowBox[{
   TemplateBox[{"0"},
    "Ket"], ",", 
   TemplateBox[{"1"},
    "Ket"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "1aaa864b-1a42-4053-adec-5f6fbdc15acc"],
 " are both ",
 Cell[BoxData[
  RowBox[{"1", "/", "2"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "e8b3ab5b-e693-4b04-abe5-a375b5b789f0"],
 " for any phase."
}], "Text",ExpressionUUID->"07145dba-0686-4f01-b091-1bc27f40ff81"],

Cell[BoxData[
 RowBox[{"With", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"u", " ", "=", " ", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"1", ",", " ", 
        RowBox[{"Exp", "[", 
         RowBox[{"I", " ", "\[Alpha]"}], "]"}]}], "}"}], "/", 
      RowBox[{"Sqrt", "[", "2", "]"}]}]}], "}"}], ",", " ", 
   RowBox[{"FullSimplify", "[", 
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{"Abs", "[", 
         RowBox[{
          RowBox[{"Conjugate", "[", "#", "]"}], " ", ".", " ", "u"}], "]"}], "^",
         "2"}], " ", "&"}], " ", "/@", " ", 
      RowBox[{"IdentityMatrix", "[", "2", "]"}]}], ",", " ", 
     RowBox[{"\[Alpha]", " ", "\[Element]", " ", "Reals"}]}], "]"}]}], 
  "]"}]], "Input",
 CellLabel->
  "In[171]:= ",ExpressionUUID->"b3fe8d76-1594-4129-aedb-cd81622d1992"],

Cell[TextData[{
 "Two such families are mutually unbiased only at a special phase separation; \
solve for it, fixing the first at ",
 Cell[BoxData[
  RowBox[{
   StyleBox["\[Alpha]", "TI"], "=", "0"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "fdaba046-6ec4-4934-bcbe-3bca91efc299"],
 "."
}], "Text",ExpressionUUID->"352afff0-b986-4459-a3e2-3efbba3a5229"],

Cell[BoxData[
 RowBox[{"With", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"ov", " ", "=", " ", 
     RowBox[{"FullSimplify", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"Abs", "[", 
         RowBox[{
          RowBox[{"Conjugate", "[", 
           RowBox[{
            RowBox[{"{", 
             RowBox[{"1", ",", " ", "1"}], "}"}], "/", 
            RowBox[{"Sqrt", "[", "2", "]"}]}], "]"}], " ", ".", " ", 
          RowBox[{"(", 
           RowBox[{
            RowBox[{"{", 
             RowBox[{"1", ",", " ", 
              RowBox[{"Exp", "[", 
               RowBox[{"I", " ", "\[Beta]"}], "]"}]}], "}"}], "/", 
            RowBox[{"Sqrt", "[", "2", "]"}]}], ")"}]}], "]"}], "^", "2"}], ",",
        " ", 
       RowBox[{"\[Beta]", " ", "\[Element]", " ", "Reals"}]}], "]"}]}], "}"}],
    ",", "\n", " ", 
   RowBox[{"Reduce", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"ov", " ", "==", " ", 
       RowBox[{"1", "/", "2"}]}], " ", "&&", " ", 
      RowBox[{"0", " ", "<=", " ", "\[Beta]", " ", "<", " ", 
       RowBox[{"2", " ", "Pi"}]}]}], ",", " ", "\[Beta]"}], "]"}]}], 
  "]"}]], "Input",
 CellLabel->
  "In[172]:= ",ExpressionUUID->"321ad54b-173d-4134-bc03-eb3661e02cd4"],

Cell[TextData[{
 "The phase must be ",
 Cell[BoxData[
  RowBox[{
   StyleBox["\[Beta]", "TI"], "=", 
   FractionBox["\[Pi]", "2"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "286f1b1e-15c8-486f-abbe-842744dc05be"],
 ", so the maximal set is the computational basis together with the ",
 Cell[BoxData[
  RowBox[{
   StyleBox["\[Alpha]", "TI"], "=", "0"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "8b22e7ce-649a-47d9-90e8-a3d75ca22fcd"],
 " and ",
 Cell[BoxData[
  RowBox[{
   StyleBox["\[Alpha]", "TI"], "=", 
   FractionBox["\[Pi]", "2"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "c7f13ca2-f267-42f4-8c7b-3e42344a12cf"],
 " families."
}], "Text",ExpressionUUID->"b50b8e8f-7f8a-4e93-b2ff-20aae4df75b0"],

Cell[BoxData[
 RowBox[{"With", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"mub", " ", "=", " ", 
     RowBox[{"Function", "[", 
      RowBox[{"a", ",", " ", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{"1", ",", " ", 
            RowBox[{"Exp", "[", 
             RowBox[{"I", " ", "a"}], "]"}]}], "}"}], ",", " ", 
          RowBox[{"{", 
           RowBox[{"1", ",", " ", 
            RowBox[{"-", 
             RowBox[{"Exp", "[", 
              RowBox[{"I", " ", "a"}], "]"}]}]}], "}"}]}], "}"}], "/", 
        RowBox[{"Sqrt", "[", "2", "]"}]}]}], "]"}]}], "}"}], ",", "\n", " ", 
   RowBox[{"Prepend", "[", 
    RowBox[{
     RowBox[{"mub", " ", "/@", " ", 
      RowBox[{"{", 
       RowBox[{"0", ",", " ", 
        RowBox[{"Pi", "/", "2"}]}], "}"}]}], ",", " ", 
     RowBox[{"IdentityMatrix", "[", "2", "]"}]}], "]"}]}], "]"}]], "Input",
 CellLabel->
  "In[173]:= ",ExpressionUUID->"235c7dbf-c889-49a7-af5b-8a5a2c15ec27"],

Cell[TextData[{
 StyleBox["QF",
  FontWeight->"Bold"],
 " : those three constructed bases are (up to phase) the eigenbases of ",
 Cell[BoxData[
  RowBox[{
   StyleBox["Z", "TI"], ",", 
   StyleBox["X", "TI"], ",", 
   StyleBox["Y", "TI"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "f6423d51-a039-45a4-a31d-5a149232fa81"],
 "; read them off the operators."
}], "Text",ExpressionUUID->"5016108a-db72-4ec1-8372-c05115311545"],

Cell[BoxData[
 RowBox[{
  RowBox[{"Function", "[", 
   RowBox[{"A", ",", " ", 
    RowBox[{"Normal", " ", "/@", " ", 
     RowBox[{
      RowBox[{"QuantumOperator", "[", "A", "]"}], "[", "\"\<Eigenvectors\>\"",
       "]"}]}]}], "]"}], " ", "/@", " ", 
  RowBox[{"{", 
   RowBox[{"\"\<Z\>\"", ",", " ", "\"\<X\>\"", ",", " ", "\"\<Y\>\""}], 
   "}"}]}]], "Input",
 CellLabel->
  "In[174]:= ",ExpressionUUID->"b691552f-cff8-4603-9adc-264607c36442"],

Cell[TextData[{
 "Solving the unbiasedness conditions delivers three bases and no more: the \
computational (",
 Cell[BoxData[
  StyleBox["Z", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "3a38e890-a9ee-47ea-aa4d-c1e55bc81326"],
 ") basis and the phase families at ",
 Cell[BoxData[
  RowBox[{
   StyleBox["\[Alpha]", "TI"], "=", "0"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "c8900090-dd69-4e44-8f61-c52a62450cb4"],
 " and ",
 Cell[BoxData[
  FractionBox["\[Pi]", "2"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "511ff020-ba71-4ad3-b56e-658a4c1c3513"],
 ", which are the ",
 Cell[BoxData[
  StyleBox["X", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "0e9481a0-d141-4f98-834b-9550e8f299d6"],
 " and ",
 Cell[BoxData[
  StyleBox["Y", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "7e6949b4-6f36-4135-acff-fe05e87d92b7"],
 " eigenbases. Both the count ",
 Cell[BoxData[
  RowBox[{
   StyleBox["d", "TI"], "+", "1", "=", "3"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "f90877a9-c1e2-4e8b-bea7-118ddfb12b99"],
 " and the identity of the bases (the Pauli eigenbases) emerge from the \
construction rather than being assumed."
}], "Text",ExpressionUUID->"ddcd428a-8e93-4b7c-be84-380af9f8468a"],

Cell["\<\
6.4b [BSc] How do I verify that a set of bases is mutually unbiased?\
\>", "Subsection",ExpressionUUID->"e8bf669b-aa6e-47b1-bbe8-db2c7e850469"],

Cell[TextData[{
 "Given candidate bases, the test is direct: every cross-overlap between ",
 StyleBox["different", "TI"],
 " bases must equal ",
 Cell[BoxData[
  RowBox[{
   SuperscriptBox[GridBox[{
      {
       TemplateBox[{
         StyleBox["e", "TI"], 
         StyleBox["f", "TI"]},
        "BraKet"]}
     },
     GridBoxDividers->{"Columns" -> {True, True}, "Rows" -> {}},
     GridBoxSpacings->{"Columns" -> {{0.15}}}], "2"], "=", "1", "/", 
   StyleBox["d", "TI"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "f4c6cc27-3e30-410b-bc13-fc17d7c2b7ff"],
 ". Check it on the three qubit MUBs, the eigenbases of ",
 Cell[BoxData[
  RowBox[{
   StyleBox["X", "TI"], ",", 
   StyleBox["Y", "TI"], ",", 
   StyleBox["Z", "TI"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "0190f15f-d44d-453d-b050-2bd103f31d13"],
 "."
}], "Text",ExpressionUUID->"b0373a2f-e52f-4e68-8b05-ecf5142ddd72"],

Cell[TextData[{
 StyleBox["WL",
  FontWeight->"Bold"],
 " : form the three eigenbases and compute all three pairwise overlap \
matrices."
}], "Text",ExpressionUUID->"b89f1d15-b48a-40ed-b0d3-3961556d9379"],

Cell[BoxData[
 RowBox[{"With", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{"bx", " ", "=", " ", 
      RowBox[{"Normalize", " ", "/@", " ", 
       RowBox[{"Eigenvectors", "[", 
        RowBox[{"PauliMatrix", "[", "1", "]"}], "]"}]}]}], ",", " ", 
     RowBox[{"by", " ", "=", " ", 
      RowBox[{"Normalize", " ", "/@", " ", 
       RowBox[{"Eigenvectors", "[", 
        RowBox[{"PauliMatrix", "[", "2", "]"}], "]"}]}]}], ",", " ", 
     RowBox[{"bz", " ", "=", " ", 
      RowBox[{"Normalize", " ", "/@", " ", 
       RowBox[{"Eigenvectors", "[", 
        RowBox[{"PauliMatrix", "[", "3", "]"}], "]"}]}]}]}], "}"}], ",", "\n",
    " ", 
   RowBox[{
    RowBox[{
     RowBox[{"Outer", "[", 
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{"Abs", "[", 
          RowBox[{
           RowBox[{"Conjugate", "[", "#1", "]"}], " ", ".", " ", "#2"}], 
          "]"}], "^", "2"}], " ", "&"}], ",", " ", 
       RowBox[{"#", "[", 
        RowBox[{"[", "1", "]"}], "]"}], ",", " ", 
       RowBox[{"#", "[", 
        RowBox[{"[", "2", "]"}], "]"}], ",", " ", "1"}], "]"}], " ", "&"}], 
    " ", "/@", " ", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"bx", ",", " ", "by"}], "}"}], ",", " ", 
      RowBox[{"{", 
       RowBox[{"bx", ",", " ", "bz"}], "}"}], ",", " ", 
      RowBox[{"{", 
       RowBox[{"by", ",", " ", "bz"}], "}"}]}], "}"}]}]}], "]"}]], "Input",
 CellLabel->
  "In[175]:= ",ExpressionUUID->"c5313cc6-9099-40f6-a938-9faa95a2e02f"],

Cell[TextData[{
 StyleBox["QF",
  FontWeight->"Bold"],
 " : the same from the operators' ",
 Cell[BoxData["\"\<Eigenvectors\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "03852e08-cab4-46a2-aa36-8321051e7aa6"],
 ", over all pairs."
}], "Text",ExpressionUUID->"b1825ae4-5828-42b6-a704-6a75e4cd6cd8"],

Cell[BoxData[
 RowBox[{"With", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"b", " ", "=", " ", 
     RowBox[{
      RowBox[{"Function", "[", 
       RowBox[{"A", ",", " ", 
        RowBox[{"Normal", " ", "/@", " ", 
         RowBox[{
          RowBox[{"QuantumOperator", "[", "A", "]"}], 
          "[", "\"\<Eigenvectors\>\"", "]"}]}]}], "]"}], " ", "/@", " ", 
      RowBox[{"{", 
       RowBox[{"\"\<X\>\"", ",", " ", "\"\<Y\>\"", ",", " ", "\"\<Z\>\""}], 
       "}"}]}]}], "}"}], ",", "\n", " ", 
   RowBox[{
    RowBox[{
     RowBox[{"Outer", "[", 
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{"Abs", "[", 
          RowBox[{
           RowBox[{"Conjugate", "[", "#1", "]"}], " ", ".", " ", "#2"}], 
          "]"}], "^", "2"}], " ", "&"}], ",", " ", 
       RowBox[{"#", "[", 
        RowBox[{"[", "1", "]"}], "]"}], ",", " ", 
       RowBox[{"#", "[", 
        RowBox[{"[", "2", "]"}], "]"}], ",", " ", "1"}], "]"}], " ", "&"}], 
    " ", "/@", " ", 
    RowBox[{"Subsets", "[", 
     RowBox[{"b", ",", " ", 
      RowBox[{"{", "2", "}"}]}], "]"}]}]}], "]"}]], "Input",
 CellLabel->
  "In[176]:= ",ExpressionUUID->"f4400611-65be-45de-9fa1-5c3e215038c4"],

Cell[TextData[{
 "Every entry of all three pairwise matrices is ",
 Cell[BoxData[
  RowBox[{
   FractionBox["1", "2"], "=", "1", "/", 
   StyleBox["d", "TI"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "26b3183e-409a-421e-9e47-12653c63ea83"],
 ": the ",
 Cell[BoxData[
  RowBox[{
   StyleBox["X", "TI"], ",", 
   StyleBox["Y", "TI"], ",", 
   StyleBox["Z", "TI"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "066ce8e6-489d-498b-8066-ad7930f0f0c8"],
 " eigenbases are pairwise mutually unbiased, confirming they are the three \
MUBs of a qubit. A single entry different from ",
 Cell[BoxData[
  FractionBox["1", "2"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "431e995a-9f34-4ef6-835e-e4d31d8dc81b"],
 " would disqualify the set, which is what makes this a genuine test rather \
than a restatement."
}], "Text",ExpressionUUID->"8975e14c-b279-4f47-8946-047a1f27f0f7"],

Cell[TextData[{
 "6.5 [MSc] How do I verify the Maassen-Uffink entropic uncertainty relation ",
 Cell[BoxData[
  RowBox[{
   StyleBox["H", "TI"], 
   StyleBox["(",
    SpanMaxSize->1], 
   StyleBox["A", "TI"], 
   StyleBox[")",
    SpanMaxSize->1], "+", 
   StyleBox["H", "TI"], 
   StyleBox["(",
    SpanMaxSize->1], 
   StyleBox["B", "TI"], 
   StyleBox[")",
    SpanMaxSize->1], "\[GreaterEqual]", "-", 
   SubscriptBox[
    StyleBox["log",
     FontSlant->"Plain"], "2"], "\[ThinSpace]", 
   SuperscriptBox[
    StyleBox["c", "TI"], "2"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "60911cb3-fb03-45bf-b227-e694c9a3044a"],
 " for two observables?"
}], "Subsection",ExpressionUUID->"3bd84160-c939-41c0-9d0f-81addfcbf507"],

Cell[TextData[{
 "Let ",
 Cell[BoxData[
  RowBox[{
   StyleBox["H", "TI"], 
   StyleBox["(",
    SpanMaxSize->1], 
   StyleBox["A", "TI"], 
   StyleBox[")",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "6aa6004d-e6cf-479e-947e-756d78e93207"],
 " denote the Shannon entropy (6.3) of the outcome distribution of measuring ",
 Cell[BoxData[
  StyleBox["A", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "8e1139a8-da30-465e-bcb4-51574b33b4f4"],
 ". The Maassen-Uffink relation bounds the ",
 StyleBox["summed", "TI"],
 " entropies of two measurements, ",
 Cell[BoxData[
  RowBox[{
   StyleBox["H", "TI"], 
   StyleBox["(",
    SpanMaxSize->1], 
   StyleBox["A", "TI"], 
   StyleBox[")",
    SpanMaxSize->1], "+", 
   StyleBox["H", "TI"], 
   StyleBox["(",
    SpanMaxSize->1], 
   StyleBox["B", "TI"], 
   StyleBox[")",
    SpanMaxSize->1], "\[GreaterEqual]", "-", 
   SubscriptBox[
    StyleBox["log",
     FontSlant->"Plain"], "2"], "\[ThinSpace]", 
   SuperscriptBox[
    StyleBox["c", "TI"], "2"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "c6396f29-d6bb-4a2f-b690-8a5c3135ac3d"],
 ", where ",
 Cell[BoxData[
  RowBox[{
   StyleBox["c", "TI"], "=", 
   UnderscriptBox[
    StyleBox["max",
     FontSlant->"Plain"], 
    RowBox[{
     StyleBox["a", "TI"], ",", 
     StyleBox["b", "TI"]}],
    LimitsPositioning->False], GridBox[{
     {
      TemplateBox[{
        StyleBox["a", "TI"], 
        StyleBox["b", "TI"]},
       "BraKet"]}
    },
    GridBoxDividers->{"Columns" -> {True, True}, "Rows" -> {}},
    GridBoxSpacings->{"Columns" -> {{0.15}}}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "7e257496-8260-41db-9ad7-3e910434d5e8"],
 " is the largest overlap between an ",
 Cell[BoxData[
  StyleBox["A", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "7d4faa8d-777e-499b-9dc9-40d760cc48bd"],
 " eigenstate and a ",
 Cell[BoxData[
  StyleBox["B", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "d8c742ae-efbd-4125-ae4d-e0b8dd642b09"],
 " eigenstate. Take ",
 Cell[BoxData[
  RowBox[{
   RowBox[{
    StyleBox["A", "TI"], "=", 
    StyleBox["X", "TI"]}], ",", 
   RowBox[{
    StyleBox["B", "TI"], "=", 
    StyleBox["Z", "TI"]}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "566f0d52-7505-411e-b3d9-1573aea787a8"],
 " and a complex off-axis state ",
 Cell[BoxData[
  RowBox[{
   RowBox[{"{", 
    StyleBox["cos",
     FontSlant->"Plain"], "\[ThinSpace]", 
    FractionBox["\[Pi]", "6"]}], ",", 
   RowBox[{
    SuperscriptBox[
     StyleBox["e", "TI"], 
     RowBox[{"2", "\[Pi]", 
      StyleBox["i", "TI"], "/", "5"}]], 
    StyleBox["sin",
     FontSlant->"Plain"], "\[ThinSpace]", 
    FractionBox["\[Pi]", "6"], "}"}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "038f41b0-37cb-4b88-b1cf-b9f9e9bc4901"],
 ", whose relative phase keeps both measurements genuinely uncertain; the \
overlap constant ",
 Cell[BoxData[
  StyleBox["c", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "7edd0dc6-9c09-487d-85c2-8431b7a21434"],
 ", and hence the bound, is computed below rather than assumed."
}], "Text",ExpressionUUID->"5f26fa4c-b8aa-4fc1-b0a2-fb1fb5897e09"],

Cell[TextData[{
 StyleBox["WL",
  FontWeight->"Bold"],
 " : first compute the overlap constant ",
 Cell[BoxData[
  RowBox[{
   StyleBox["c", "TI"], "=", 
   UnderscriptBox[
    StyleBox["max",
     FontSlant->"Plain"], 
    RowBox[{
     StyleBox["a", "TI"], ",", 
     StyleBox["b", "TI"]}],
    LimitsPositioning->False], GridBox[{
     {
      TemplateBox[{
        StyleBox["a", "TI"], 
        StyleBox["b", "TI"]},
       "BraKet"]}
    },
    GridBoxDividers->{"Columns" -> {True, True}, "Rows" -> {}},
    GridBoxSpacings->{"Columns" -> {{0.15}}}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "c4d91f20-3730-4165-8507-ab6306a6c816"],
 " from the two eigenbases, which sets the bound ",
 Cell[BoxData[
  RowBox[{"-", 
   SubscriptBox[
    StyleBox["log",
     FontSlant->"Plain"], "2"], "\[ThinSpace]", 
   SuperscriptBox[
    StyleBox["c", "TI"], "2"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "ea5304c5-a97a-4bb7-8abe-3983ba3a63ea"],
 "."
}], "Text",ExpressionUUID->"b4fa4ded-26e9-48b2-afb2-f2d669cb6091"],

Cell[BoxData[
 RowBox[{"With", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{"eX", " ", "=", " ", 
      RowBox[{"Normalize", " ", "/@", " ", 
       RowBox[{"Eigenvectors", "[", 
        RowBox[{"PauliMatrix", "[", "1", "]"}], "]"}]}]}], ",", " ", 
     RowBox[{"eZ", " ", "=", " ", 
      RowBox[{"Normalize", " ", "/@", " ", 
       RowBox[{"Eigenvectors", "[", 
        RowBox[{"PauliMatrix", "[", "3", "]"}], "]"}]}]}]}], "}"}], ",", "\n",
    " ", 
   RowBox[{"With", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"c", " ", "=", " ", 
       RowBox[{"Max", "[", 
        RowBox[{"Flatten", "[", 
         RowBox[{"Outer", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"Abs", "[", 
             RowBox[{
              RowBox[{"Conjugate", "[", "#1", "]"}], " ", ".", " ", "#2"}], 
             "]"}], " ", "&"}], ",", " ", "eX", ",", " ", "eZ", ",", " ", 
           "1"}], "]"}], "]"}], "]"}]}], "}"}], ",", " ", 
     RowBox[{"{", 
      RowBox[{"c", ",", " ", 
       RowBox[{"-", 
        RowBox[{"Log2", "[", 
         RowBox[{"c", "^", "2"}], "]"}]}]}], "}"}]}], "]"}]}], "]"}]], "Input",\

 CellLabel->
  "In[177]:= ",ExpressionUUID->"e458b7bf-2d38-4da8-8b8b-2ba3a3c53476"],

Cell[TextData[{
 "This returns ",
 Cell[BoxData[
  RowBox[{
   RowBox[{"{", "1", "/", 
    SqrtBox["2"]}], ",", 
   RowBox[{"1", "}"}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "f8e4413c-70db-4688-83a2-8e333f8cd4dd"],
 ": for the mutually unbiased ",
 Cell[BoxData[
  RowBox[{
   StyleBox["X", "TI"], ",", 
   StyleBox["Z", "TI"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "2735be7d-c396-4549-8e2d-c60c8413c5d5"],
 " every cross-overlap is ",
 Cell[BoxData[
  RowBox[{"1", "/", 
   SqrtBox["2"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "ea589ec7-9ccd-416c-9383-af4469d4f975"],
 ", so the bound ",
 Cell[BoxData[
  RowBox[{"-", 
   SubscriptBox[
    StyleBox["log",
     FontSlant->"Plain"], "2"], "\[ThinSpace]", 
   SuperscriptBox[
    StyleBox["c", "TI"], "2"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "4119c13a-9707-4127-80f1-da827baead4d"],
 " is exactly ",
 Cell[BoxData["1"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "ee278183-2af9-4dc1-883c-4e9ea8faedaa"],
 " bit. Then sum the Shannon entropies of the ",
 Cell[BoxData[
  StyleBox["X", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "364343a7-dd2d-4152-9d88-514a5f93d940"],
 " and ",
 Cell[BoxData[
  StyleBox["Z", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "d1284222-356b-443a-a41d-f48f689e81d6"],
 " measurement distributions and compare to that bound."
}], "Text",ExpressionUUID->"6eb8b8a7-f328-4f80-ab6d-f09319f328b2"],

Cell[BoxData[
 RowBox[{"With", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{"psi", " ", "=", " ", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"Cos", "[", 
         RowBox[{"Pi", "/", "6"}], "]"}], ",", " ", 
        RowBox[{
         RowBox[{"Exp", "[", 
          RowBox[{"I", " ", "2", " ", 
           RowBox[{"Pi", "/", "5"}]}], "]"}], " ", 
         RowBox[{"Sin", "[", 
          RowBox[{"Pi", "/", "6"}], "]"}]}]}], "}"}]}], ",", " ", 
     RowBox[{"h", " ", "=", " ", 
      RowBox[{
       RowBox[{"-", 
        RowBox[{"Total", "[", 
         RowBox[{
          RowBox[{
           RowBox[{
            RowBox[{
             RowBox[{"If", "[", 
              RowBox[{
               RowBox[{"#", " ", "==", " ", "0"}], ",", " ", "0", ",", " ", 
               RowBox[{"#", " ", 
                RowBox[{"Log2", "[", "#", "]"}]}]}], "]"}], " ", "&"}], "[", 
            "#", "]"}], " ", "&"}], " ", "/@", " ", "#"}], "]"}]}], " ", 
       "&"}]}]}], "}"}], ",", "\n", " ", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{
       RowBox[{"h", "[", 
        RowBox[{
         RowBox[{
          RowBox[{
           RowBox[{"Abs", "[", 
            RowBox[{
             RowBox[{"Conjugate", "[", "#", "]"}], " ", ".", " ", "psi"}], 
            "]"}], "^", "2"}], " ", "&"}], " ", "/@", " ", 
         RowBox[{"(", 
          RowBox[{"Normalize", " ", "/@", " ", 
           RowBox[{"Eigenvectors", "[", 
            RowBox[{"PauliMatrix", "[", "1", "]"}], "]"}]}], ")"}]}], "]"}], 
       " ", "+", "\n", "    ", 
       RowBox[{"h", "[", 
        RowBox[{
         RowBox[{
          RowBox[{
           RowBox[{"Abs", "[", 
            RowBox[{
             RowBox[{"Conjugate", "[", "#", "]"}], " ", ".", " ", "psi"}], 
            "]"}], "^", "2"}], " ", "&"}], " ", "/@", " ", 
         RowBox[{"(", 
          RowBox[{"Normalize", " ", "/@", " ", 
           RowBox[{"Eigenvectors", "[", 
            RowBox[{"PauliMatrix", "[", "3", "]"}], "]"}]}], ")"}]}], "]"}]}],
       ",", " ", "1"}], "}"}], " ", "//", " ", "N"}]}], "]"}]], "Input",
 CellLabel->
  "In[178]:= ",ExpressionUUID->"02042b89-dd71-4b5e-9446-8b7cddba76b8"],

Cell[TextData[{
 StyleBox["QF",
  FontWeight->"Bold"],
 " : sum the two measurements' ",
 Cell[BoxData["\"\<Entropy\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "5da3120b-138a-4f44-8dfa-2673dfcf48fe"],
 " (stripping the bit unit) and compare to ",
 Cell[BoxData["1"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "8f20f74a-d4e7-4da5-9469-c563e5e40394"],
 "."
}], "Text",ExpressionUUID->"ef273529-8d3f-4c51-91ff-3eb6ea5c8be0"],

Cell[BoxData[
 RowBox[{"With", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"psi", " ", "=", " ", 
     RowBox[{"QuantumState", "[", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"Cos", "[", 
         RowBox[{"Pi", "/", "6"}], "]"}], ",", " ", 
        RowBox[{
         RowBox[{"Exp", "[", 
          RowBox[{"I", " ", "2", " ", 
           RowBox[{"Pi", "/", "5"}]}], "]"}], " ", 
         RowBox[{"Sin", "[", 
          RowBox[{"Pi", "/", "6"}], "]"}]}]}], "}"}], "]"}]}], "}"}], ",", 
   "\n", " ", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{
       RowBox[{"QuantityMagnitude", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"QuantumMeasurementOperator", "[", 
           RowBox[{"QuantumOperator", "[", "\"\<X\>\"", "]"}], "]"}], "[", 
          "psi", "]"}], "[", "\"\<Entropy\>\"", "]"}], "]"}], " ", "+", "\n", 
       "    ", 
       RowBox[{"QuantityMagnitude", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"QuantumMeasurementOperator", "[", 
           RowBox[{"QuantumOperator", "[", "\"\<Z\>\"", "]"}], "]"}], "[", 
          "psi", "]"}], "[", "\"\<Entropy\>\"", "]"}], "]"}]}], ",", " ", 
      "1"}], "}"}], " ", "//", " ", "N"}]}], "]"}]], "Input",
 CellLabel->
  "In[179]:= ",ExpressionUUID->"0ca22976-5b0f-462f-86c5-a153590d04e1"],

Cell[TextData[{
 "Both give ",
 Cell[BoxData[
  RowBox[{
   StyleBox["H", "TI"], 
   StyleBox["(",
    SpanMaxSize->1], 
   StyleBox["X", "TI"], 
   StyleBox[")",
    SpanMaxSize->1], "+", 
   StyleBox["H", "TI"], 
   StyleBox["(",
    SpanMaxSize->1], 
   StyleBox["Z", "TI"], 
   StyleBox[")",
    SpanMaxSize->1], "\[TildeTilde]", "1.76", "\[GreaterEqual]", "1"}]], 
  "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "93910142-b8ec-45f7-9a8f-c0016fa302e2"],
 ": the summed uncertainty of two complementary measurements cannot fall \
below the computed bound, so a state cannot be sharp in both ",
 Cell[BoxData[
  StyleBox["X", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "ac709698-0c3f-4581-bad1-082a17ce65d0"],
 " and ",
 Cell[BoxData[
  StyleBox["Z", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "6945479d-33f3-4017-a6ab-f661fad8dd1c"],
 " at once."
}], "Text",ExpressionUUID->"e2f27e67-f074-440f-aaa6-b4044b6d9b9b"],

Cell["\<\
6.6 [MSc] How do I find a state that saturates the Maassen-Uffink entropic \
bound (maximal complementarity)?\
\>", "Subsection",ExpressionUUID->"8957a8ed-ca7d-46c2-b19e-c177bc3176b1"],

Cell[TextData[{
 "The Maassen-Uffink bound of 6.5, ",
 Cell[BoxData[
  RowBox[{
   StyleBox["H", "TI"], 
   StyleBox["(",
    SpanMaxSize->1], 
   StyleBox["X", "TI"], 
   StyleBox[")",
    SpanMaxSize->1], "+", 
   StyleBox["H", "TI"], 
   StyleBox["(",
    SpanMaxSize->1], 
   StyleBox["Z", "TI"], 
   StyleBox[")",
    SpanMaxSize->1], "\[GreaterEqual]", "1"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "f45fd5c6-0e0a-4fbd-9f92-8223bff08b5b"],
 " bit for the complementary ",
 Cell[BoxData[
  RowBox[{
   StyleBox["X", "TI"], ",", 
   StyleBox["Z", "TI"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "1664c10d-e07f-4075-ba07-36a5b1df1b30"],
 " (with ",
 Cell[BoxData[
  RowBox[{
   StyleBox["H", "TI"], 
   StyleBox["(",
    SpanMaxSize->1], 
   StyleBox["A", "TI"], 
   StyleBox[")",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "cd7a0e19-1ee9-4a8e-af75-7e4caf953ac3"],
 " the Shannon entropy of measuring ",
 Cell[BoxData[
  StyleBox["A", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "57b98292-bf8d-4202-9e5b-ada078e7a178"],
 ", from 6.3 and 6.5), is achievable with equality: a ",
 Cell[BoxData[
  StyleBox["Z", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "b39bfab8-a65f-48e9-ba9b-4dd911954a32"],
 " eigenstate ",
 Cell[BoxData[
  TemplateBox[{"0"},
   "Ket"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "bf9fa1fd-d46d-49c0-9d50-6a96e67d9ed8"],
 " has ",
 Cell[BoxData[
  RowBox[{
   StyleBox["H", "TI"], 
   StyleBox["(",
    SpanMaxSize->1], 
   StyleBox["Z", "TI"], 
   StyleBox[")",
    SpanMaxSize->1], "=", "0"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "2e1faed9-2d1d-419c-a75d-05227b4df316"],
 " (certain) and ",
 Cell[BoxData[
  RowBox[{
   StyleBox["H", "TI"], 
   StyleBox["(",
    SpanMaxSize->1], 
   StyleBox["X", "TI"], 
   StyleBox[")",
    SpanMaxSize->1], "=", "1"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "63ee988a-29db-4567-ac6d-58d64969ed89"],
 " (maximally uncertain), so the sum equals the bound exactly."
}], "Text",ExpressionUUID->"887b949e-5cbd-45b5-96d6-75aa241424fb"],

Cell[TextData[{
 StyleBox["WL",
  FontWeight->"Bold"],
 " : the summed entropy for ",
 Cell[BoxData[
  TemplateBox[{"0"},
   "Ket"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "c90fa454-5f87-45da-9ce7-2c2d347d0700"],
 "."
}], "Text",ExpressionUUID->"9b77f600-972c-4f12-89f2-9d1eae7336bf"],

Cell[BoxData[
 RowBox[{"With", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{"psi", " ", "=", " ", 
      RowBox[{"{", 
       RowBox[{"1", ",", " ", "0"}], "}"}]}], ",", " ", 
     RowBox[{"h", " ", "=", " ", 
      RowBox[{
       RowBox[{"-", 
        RowBox[{"Total", "[", 
         RowBox[{
          RowBox[{
           RowBox[{
            RowBox[{
             RowBox[{"If", "[", 
              RowBox[{
               RowBox[{"#", " ", "==", " ", "0"}], ",", " ", "0", ",", " ", 
               RowBox[{"#", " ", 
                RowBox[{"Log2", "[", "#", "]"}]}]}], "]"}], " ", "&"}], "[", 
            "#", "]"}], " ", "&"}], " ", "/@", " ", "#"}], "]"}]}], " ", 
       "&"}]}]}], "}"}], ",", "\n", " ", 
   RowBox[{
    RowBox[{"h", "[", 
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{"Abs", "[", 
         RowBox[{
          RowBox[{"Conjugate", "[", "#", "]"}], " ", ".", " ", "psi"}], "]"}],
         "^", "2"}], " ", "&"}], " ", "/@", " ", 
      RowBox[{"(", 
       RowBox[{"Normalize", " ", "/@", " ", 
        RowBox[{"Eigenvectors", "[", 
         RowBox[{"PauliMatrix", "[", "1", "]"}], "]"}]}], ")"}]}], "]"}], " ",
     "+", "\n", "  ", 
    RowBox[{"h", "[", 
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{"Abs", "[", 
         RowBox[{
          RowBox[{"Conjugate", "[", "#", "]"}], " ", ".", " ", "psi"}], "]"}],
         "^", "2"}], " ", "&"}], " ", "/@", " ", 
      RowBox[{"(", 
       RowBox[{"Normalize", " ", "/@", " ", 
        RowBox[{"Eigenvectors", "[", 
         RowBox[{"PauliMatrix", "[", "3", "]"}], "]"}]}], ")"}]}], "]"}]}]}], 
  "]"}]], "Input",
 CellLabel->
  "In[180]:= ",ExpressionUUID->"e0eac4a3-cf89-4088-8bec-990f32f02362"],

Cell[TextData[{
 StyleBox["QF",
  FontWeight->"Bold"],
 " : the same from the two measurements' ",
 Cell[BoxData["\"\<Entropy\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "3f9afd1d-13a0-489c-911d-78cddde5e730"],
 "."
}], "Text",ExpressionUUID->"5603b101-74f5-4404-8be4-ae6ee7d06aa8"],

Cell[BoxData[
 RowBox[{"With", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"psi", " ", "=", " ", 
     RowBox[{"QuantumState", "[", "\"\<0\>\"", "]"}]}], "}"}], ",", "\n", " ", 
   RowBox[{
    RowBox[{"QuantityMagnitude", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"QuantumMeasurementOperator", "[", 
        RowBox[{"QuantumOperator", "[", "\"\<X\>\"", "]"}], "]"}], "[", "psi",
        "]"}], "[", "\"\<Entropy\>\"", "]"}], "]"}], " ", "+", "\n", "  ", 
    RowBox[{"QuantityMagnitude", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"QuantumMeasurementOperator", "[", 
        RowBox[{"QuantumOperator", "[", "\"\<Z\>\"", "]"}], "]"}], "[", "psi",
        "]"}], "[", "\"\<Entropy\>\"", "]"}], "]"}]}]}], "]"}]], "Input",
 CellLabel->
  "In[181]:= ",ExpressionUUID->"d6ca877f-927f-4697-a46e-cac1bde27f6b"],

Cell[TextData[{
 "Both give exactly ",
 Cell[BoxData["1"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "01e117ac-6a2a-4a39-a4a7-0425ce4381c3"],
 ": knowing the qubit is ",
 Cell[BoxData[
  TemplateBox[{"0"},
   "Ket"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "465d521a-227a-4e44-81b7-b562ed5e1296"],
 " pins ",
 Cell[BoxData[
  StyleBox["Z", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "8d70bd28-8156-4ed2-82a3-3487b1a288d5"],
 " completely (",
 Cell[BoxData[
  RowBox[{
   StyleBox["H", "TI"], 
   StyleBox["(",
    SpanMaxSize->1], 
   StyleBox["Z", "TI"], 
   StyleBox[")",
    SpanMaxSize->1], "=", "0"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "5ae7c9bd-51c7-4e78-aa00-94bae0f8b853"],
 ") at the cost of total ignorance of ",
 Cell[BoxData[
  StyleBox["X", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "bf4409ff-0f40-4a90-9ecb-b8bfd9258773"],
 " (",
 Cell[BoxData[
  RowBox[{
   StyleBox["H", "TI"], 
   StyleBox["(",
    SpanMaxSize->1], 
   StyleBox["X", "TI"], 
   StyleBox[")",
    SpanMaxSize->1], "=", "1"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "ac870a1a-53aa-4134-8743-9248e9c053db"],
 "). Mutually unbiased bases realize maximal complementarity, the entropic \
bound is met with equality."
}], "Text",ExpressionUUID->"ce8d4c13-b46b-4cf1-9a03-ead43d418942"]
},
