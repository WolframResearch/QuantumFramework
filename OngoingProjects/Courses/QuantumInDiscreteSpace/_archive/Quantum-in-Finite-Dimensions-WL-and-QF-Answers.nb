(* Beginning of Notebook Content *)
Notebook[{
Cell["\<\
Quantum in Finite Dimensions: Answers in WL and in QuantumFramework\
\>", "Title",ExpressionUUID->"b3a7e12d-3f11-4806-8768-c9d3d299c5ef"],

Cell[TextData[{
 "A companion answer key to ",
 Cell["Question-List.md", "InlineCode",ExpressionUUID->
  "d6618279-706c-4dea-8c0e-fe4458e8ab07"],
 ". For each question it gives ",
 StyleBox["two",
  FontWeight->"Bold"],
 " worked answers:"
}], "Text",ExpressionUUID->"b0291d1c-e066-4e27-be68-27cf87187ec4"],

Cell[TextData[{
 StyleBox["WL",
  FontWeight->"Bold"],
 " : native Wolfram Language only (plain vectors and matrices, ",
 Cell[BoxData["PauliMatrix"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "3c58d9d7-3b2b-4509-b9ac-b3370fbf8ada"],
 ", ",
 Cell[BoxData["Conjugate"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "69a1de64-0171-4117-af9e-f6fe4829832c"],
 ", ",
 Cell[BoxData["Normalize"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "2c053fbf-289e-4b64-8c21-be7cbc609a18"],
 ", ",
 Cell[BoxData["Eigenvectors"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "31484cad-b117-4e8d-85ec-31632bad8a2a"],
 ", ",
 Cell[BoxData["MatrixExp"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "e92f958f-c3f0-4552-a722-3a1116fa8614"],
 ", and friends). Nothing beyond the built-in language."
}], "ItemNumbered",ExpressionUUID->"150c4e4a-7069-43c1-9d42-18c0cc78e457"],

Cell[TextData[{
 StyleBox["QF",
  FontWeight->"Bold"],
 " : the same task done through the ",
 StyleBox["QuantumFramework",
  FontWeight->"Bold"],
 " paclet, leaning on its objects and property downvalues (",
 Cell[BoxData[
  RowBox[{
   RowBox[{"QuantumState", "[", "...", "]"}], "[", "\"\<...\>\"", "]"}]], 
  "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "0d46b7b0-cf34-40ef-aa90-b058b234bd73"],
 ") rather than rebuilding matrices by hand. A QF result is a rich object, a \
state or an operator, not a bare array: it can act on a target, compose with \
others, report its spectrum, change basis, and more. The answers keep results \
as objects and treat a matrix or amplitude vector as just one of the object's \
many representations, not the thing itself."
}], "ItemNumbered",ExpressionUUID->"61aebfe5-cc74-4725-af80-f2aa19303276"],

Cell[TextData[{
 "Three habits run through the answers. They stay ",
 StyleBox["symbolic",
  FontWeight->"Bold"],
 " wherever possible (general amplitudes ",
 Cell[BoxData[
  RowBox[{
   StyleBox["\[Alpha]", "TI"], ",", 
   StyleBox["\[Beta]", "TI"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "d11a1353-8a5d-418d-b1ea-4db0e0f53cf3"],
 ", general angles ",
 Cell[BoxData[
  RowBox[{
   StyleBox["\[Theta]", "TI"], ",", 
   StyleBox["\[Phi]", "TI"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "a2dfa05c-06e5-48fc-9ce8-5b3f758c3d2b"],
 "), so each operation is exercised in full generality rather than on a lucky \
special case. They write the computation ",
 StyleBox["explicitly",
  FontWeight->"Bold"],
 " rather than hiding it in a helper function, because the code is itself \
part of the explanation. And they prefer ",
 StyleBox["built-in features",
  FontWeight->"Bold"],
 " (a ",
 Cell[BoxData["Normalize"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "a1908b14-875a-43c3-b466-2d16301baba6"],
 ", a named state) over hand-rolled constructions, so nothing is hardcoded: \
every cell computes its result. Each cell does ",
 StyleBox["one",
  FontWeight->"Bold"],
 " thing and is preceded by a sentence saying what, so the notebook reads as \
a sequence of single, captioned computations. Run the WL answers in a bare \
kernel; the QF answers need the paclet loaded once."
}], "Text",ExpressionUUID->"8647979b-2bbe-4354-b472-eceaf69d2560"],

Cell["Setup", "Section",ExpressionUUID->"8e9d99d0-34b6-4f37-ab23-dae111080403"],

Cell["The QF answers load the paclet once:", "Text",ExpressionUUID->"ef95032d-e204-46e4-b9f2-1d22b3e4b29d"],

Cell[BoxData[
 RowBox[{"Needs", "[", "\"\<Wolfram`QuantumFramework`\>\"", "]"}]], "Input",
 CellLabel->"In[1]:= ",ExpressionUUID->"4bbe42da-f7f0-4443-9d11-98bd8ac672ae"],

Cell["Part 1. Pure states and the Born rule", "Section",ExpressionUUID->"7ea0c937-e4cf-4114-9f79-099f93423120"],

Cell[TextData[{
 "1.1 [BSc] How do I represent a qubit as a state vector ",
 Cell[BoxData[
  RowBox[{
   RowBox[{"{", 
    StyleBox["\[Alpha]", "TI"]}], ",", 
   RowBox[{
    StyleBox["\[Beta]", "TI"], "}"}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "25118d15-fc26-4e8c-bdb3-64ac60b75c39"],
 " in ",
 Cell[BoxData[
  SuperscriptBox["\:2102", "2"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "4754947c-94d4-4547-a95d-f17d90187711"],
 "?"
}], "Subsection",ExpressionUUID->"65385c97-3b59-4341-b7be-dacff66b52e9"],

Cell[TextData[{
 "A pure qubit is a two-component complex vector ",
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     StyleBox["\[Psi]", "TI"]},
    "Ket"], "=", 
   RowBox[{
    RowBox[{
     StyleBox["\[Alpha]", "TI"], 
     TemplateBox[{"0"},
      "Ket"]}], "+", 
    RowBox[{
     StyleBox["\[Beta]", "TI"], 
     TemplateBox[{"1"},
      "Ket"]}]}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "645da93e-2831-473b-91b0-33b17a54a097"],
 "."
}], "Text",ExpressionUUID->"4a612ba2-15a4-4cf9-9ab6-01043545ea8b"],

Cell[TextData[{
 StyleBox["WL",
  FontWeight->"Bold"],
 " : a qubit is literally a length-2 complex list, kept fully general."
}], "Text",ExpressionUUID->"ce7cb4a2-1c35-45cd-8915-39348deb222a"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"\[Alpha]", ",", " ", "\[Beta]"}], "}"}]], "Input",
 CellLabel->"In[2]:= ",ExpressionUUID->"a37d7e1c-7aea-4394-953b-68d11265ca7b"],

Cell[TextData[{
 StyleBox["QF",
  FontWeight->"Bold"],
 " : wrap the amplitudes in ",
 Cell[BoxData["QuantumState"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "d6d9ac9e-b067-4c13-90c4-dee1fb845d38"],
 ". Evaluated without a trailing semicolon, the construction displays as its ",
 StyleBox["summary box",
  FontWeight->"Bold"],
 ": a compact panel that ",
 StyleBox["is", "TI"],
 " the live object, showing its type, dimension, and basis, not a printout of \
a matrix. Properties are read off that object on demand."
}], "Text",ExpressionUUID->"c1e1c972-2c25-4184-af67-de06bcd5c9ca"],

Cell[BoxData[
 RowBox[{"qs", " ", "=", " ", 
  RowBox[{"QuantumState", "[", 
   RowBox[{"{", 
    RowBox[{"\[Alpha]", ",", " ", "\[Beta]"}], "}"}], "]"}]}]], "Input",
 CellLabel->"In[3]:= ",ExpressionUUID->"4b1465f0-9c4b-49db-ab99-7527985692ef"],

Cell[TextData[{
 "Then ",
 Cell[BoxData["\"\<StateVector\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "1e7c3c0b-145c-47e3-ad17-54e540ffa4a0"],
 " reads one representation, the amplitudes, back out:"
}], "Text",ExpressionUUID->"b3e463f6-bfbe-4896-b1df-3ecb1f558dbd"],

Cell[BoxData[
 RowBox[{
  RowBox[{"qs", "[", "\"\<StateVector\>\"", "]"}], " ", "//", " ", 
  "Normal"}]], "Input",
 CellLabel->"In[4]:= ",ExpressionUUID->"f320f0e1-aeb3-4b00-b8dd-df1023798b60"],

Cell[TextData[{
 "Both hold the amplitudes ",
 Cell[BoxData[
  RowBox[{
   RowBox[{"{", 
    StyleBox["\[Alpha]", "TI"]}], ",", 
   RowBox[{
    StyleBox["\[Beta]", "TI"], "}"}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "75807512-1496-4fb8-a92d-5db89759c02b"],
 "; the QF object additionally knows it is a single qubit in the \
computational basis, and the summary box is that object itself, with the \
amplitude vector just one field read from it."
}], "Text",ExpressionUUID->"583802f4-0029-491b-91dc-b8ec874e3551"],

Cell["\<\
1.2 [BSc] How do I read the Born-rule probabilities of a state?\
\>", "Subsection",ExpressionUUID->"aa79a8b3-fc3c-4bb7-a5cb-4c9674afee6c"],

Cell[TextData[{
 "The probability of outcome ",
 Cell[BoxData[
  StyleBox["i", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "113ea36d-73a0-4e80-b6c7-12d974e5b4b3"],
 " is ",
 Cell[BoxData[
  SuperscriptBox[GridBox[{
     {
      TemplateBox[{
        StyleBox["i", "TI"], 
        StyleBox["\[Psi]", "TI"]},
       "BraKet"]}
    },
    GridBoxDividers->{"Columns" -> {True, True}, "Rows" -> {}},
    GridBoxSpacings->{"Columns" -> {{0.15}}}], "2"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "d9c2b4f8-3775-4629-a750-0d01845b58ce"],
 ", i.e. the squared modulus of the amplitude (divided by the norm if the \
state is not yet normalized)."
}], "Text",ExpressionUUID->"d63f5e37-e3d0-4fca-a6cd-676ed384cc2f"],

Cell[TextData[{
 StyleBox["WL",
  FontWeight->"Bold"],
 " : square the moduli of the normalized amplitudes; ",
 Cell[BoxData["FullSimplify"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "2087765f-4502-4cf0-b63a-25273e0ad882"],
 " reduces the nested modulus to a single ratio (the numerator ",
 Cell[BoxData[
  RowBox[{
   StyleBox["\[Alpha]", "TI"], " ", 
   SuperscriptBox[
    StyleBox["\[Alpha]", "TI"], "*"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "7443193b-4a85-4293-a1cd-8f67b61362b0"],
 " is ",
 Cell[BoxData[
  SuperscriptBox[GridBox[{
     {
      StyleBox["\[Alpha]", "TI"]}
    },
    GridBoxDividers->{"Columns" -> {True, True}, "Rows" -> {}},
    GridBoxSpacings->{"Columns" -> {{0.15}}}], "2"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "b7a1d790-5430-4a17-9c18-274db0bc2552"],
 ")."
}], "Text",ExpressionUUID->"f15a93fc-739a-4631-b2dd-235e37d3178f"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"Abs", "[", 
    RowBox[{"Normalize", "[", 
     RowBox[{"{", 
      RowBox[{"\[Alpha]", ",", " ", "\[Beta]"}], "}"}], "]"}], "]"}], "^", 
   "2"}], " ", "//", " ", "FullSimplify"}]], "Input",
 CellLabel->"In[5]:= ",ExpressionUUID->"72ee263c-4c8b-4dc5-996f-1b8acddd137f"],

Cell[TextData[{
 StyleBox["QF",
  FontWeight->"Bold"],
 " : ask the state for its probabilities; ",
 Cell[BoxData["\"\<ProbabilitiesList\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "793ffd91-decb-4ec7-a372-dcce616c3d78"],
 " normalizes internally and returns them in basis order."
}], "Text",ExpressionUUID->"636dbe3e-adb8-4c5f-b928-2b93ada66d33"],

Cell[BoxData[
 RowBox[{
  RowBox[{"QuantumState", "[", 
   RowBox[{"{", 
    RowBox[{"\[Alpha]", ",", " ", "\[Beta]"}], "}"}], "]"}], 
  "[", "\"\<ProbabilitiesList\>\"", "]"}]], "Input",
 CellLabel->"In[6]:= ",ExpressionUUID->"2218ffbe-069d-466a-ab1a-d29e77efb942"],

Cell[TextData[{
 "Both give ",
 Cell[BoxData[
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{
      StyleBox["{",
       FontSize->1.2 Inherited], 
      SuperscriptBox[GridBox[{
         {
          StyleBox["\[Alpha]", "TI"]}
        },
        GridBoxDividers->{"Columns" -> {True, True}, "Rows" -> {}},
        GridBoxSpacings->{"Columns" -> {{0.15}}}], "2"]}], ",", " ", 
     SuperscriptBox[GridBox[{
        {
         StyleBox["\[Beta]", "TI"]}
       },
       GridBoxDividers->{"Columns" -> {True, True}, "Rows" -> {}},
       GridBoxSpacings->{"Columns" -> {{0.15}}}], "2"]}], 
    StyleBox["}",
     FontSize->1.2 Inherited]}], "/", 
   RowBox[{
    StyleBox["(",
     SpanMaxSize->1], 
    RowBox[{
     SuperscriptBox[GridBox[{
        {
         StyleBox["\[Alpha]", "TI"]}
       },
       GridBoxDividers->{"Columns" -> {True, True}, "Rows" -> {}},
       GridBoxSpacings->{"Columns" -> {{0.15}}}], "2"], "+", 
     SuperscriptBox[GridBox[{
        {
         StyleBox["\[Beta]", "TI"]}
       },
       GridBoxDividers->{"Columns" -> {True, True}, "Rows" -> {}},
       GridBoxSpacings->{"Columns" -> {{0.15}}}], "2"]}], 
    StyleBox[")",
     SpanMaxSize->1]}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "c7548597-c934-4e31-9305-0eddde9417d2"],
 ": the Born rule weights the outcomes by the squared amplitudes, unequally \
in general, and the weights sum to one."
}], "Text",ExpressionUUID->"a12af66e-23f2-4713-8061-535dc8588761"],

Cell["\<\
1.3 [BSc] How do I check that a state is normalized, and normalize one that \
is not?\
\>", "Subsection",ExpressionUUID->"db0a1c2a-55f0-45ab-b754-2abec9970399"],

Cell[TextData[{
 "A physical state vector must have unit norm, ",
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     StyleBox["\[Psi]", "TI"], 
     StyleBox["\[Psi]", "TI"]},
    "BraKet"], "=", "1"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "180f5b81-2ffe-4786-ba7f-2709367e6503"],
 "."
}], "Text",ExpressionUUID->"42ebbc93-ee00-48cc-b2b0-68837a315224"],

Cell[TextData[{
 StyleBox["WL",
  FontWeight->"Bold"],
 " : ",
 Cell[BoxData["Norm"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "e2c20c9b-cf35-411b-b7fe-1ea9843089e0"],
 " measures the length of the raw amplitude vector."
}], "Text",ExpressionUUID->"6cb0514b-ca46-4a07-8974-261f87d8149f"],

Cell[BoxData[
 RowBox[{"Norm", "[", 
  RowBox[{"{", 
   RowBox[{"\[Alpha]", ",", " ", "\[Beta]"}], "}"}], "]"}]], "Input",
 CellLabel->"In[7]:= ",ExpressionUUID->"4ce38a38-9ca8-483c-9e02-92f2c408ed05"],

Cell[TextData[{
 Cell[BoxData["Normalize"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "0dc121ff-cf52-4d3d-8620-f0c67dd170be"],
 " rescales it to unit length, so the norm of the normalized vector is ",
 Cell[BoxData["1"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "c00cc895-6e18-4953-ba34-0b3a0529726b"],
 "."
}], "Text",ExpressionUUID->"fd84684f-d94b-4c11-abe7-2dfabbaa4fac"],

Cell[BoxData[
 RowBox[{"Simplify", "[", 
  RowBox[{"Norm", " ", "@", " ", 
   RowBox[{"Normalize", "[", 
    RowBox[{"{", 
     RowBox[{"\[Alpha]", ",", " ", "\[Beta]"}], "}"}], "]"}]}], 
  "]"}]], "Input",
 CellLabel->"In[8]:= ",ExpressionUUID->"2edec307-3d1c-4f7c-9305-3516a9baf8ac"],

Cell[TextData[{
 StyleBox["QF",
  FontWeight->"Bold"],
 " : the ",
 Cell[BoxData["\"\<Norm\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "39652656-9d54-41e1-9ffc-049e279d11df"],
 " property reports the same raw length."
}], "Text",ExpressionUUID->"cdb8c7f3-76ee-4dbf-87f4-8e0897aa6128"],

Cell[BoxData[
 RowBox[{
  RowBox[{"QuantumState", "[", 
   RowBox[{"{", 
    RowBox[{"\[Alpha]", ",", " ", "\[Beta]"}], "}"}], "]"}], 
  "[", "\"\<Norm\>\"", "]"}]], "Input",
 CellLabel->"In[9]:= ",ExpressionUUID->"d42d7169-3ac1-4b5e-9b12-b0f9282e7222"],

Cell[TextData[{
 Cell[BoxData["\"\<Normalize\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "d82af705-a006-4b2e-8648-040c56036903"],
 " returns a new, unit-norm state object, whose ",
 Cell[BoxData["\"\<Norm\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "4cca3a4a-2f0a-4e5a-9416-82bde41ade2b"],
 " is then ",
 Cell[BoxData["1"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "5d361158-6d85-45df-9733-ebe06d6c6c9b"],
 "."
}], "Text",ExpressionUUID->"ca68fe0e-7c0b-4d88-8f1b-6609ff4664bb"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"QuantumState", "[", 
    RowBox[{"{", 
     RowBox[{"\[Alpha]", ",", " ", "\[Beta]"}], "}"}], "]"}], 
   "[", "\"\<Normalize\>\"", "]"}], "[", "\"\<Norm\>\"", "]"}]], "Input",
 CellLabel->
  "In[10]:= ",ExpressionUUID->"acef20a4-018d-450b-9231-f9fedbd8fc59"],

Cell[TextData[{
 "Both report the raw norm ",
 Cell[BoxData[
  SqrtBox[
   RowBox[{
    SuperscriptBox[GridBox[{
       {
        StyleBox["\[Alpha]", "TI"]}
      },
      GridBoxDividers->{"Columns" -> {True, True}, "Rows" -> {}},
      GridBoxSpacings->{"Columns" -> {{0.15}}}], "2"], "+", 
    SuperscriptBox[GridBox[{
       {
        StyleBox["\[Beta]", "TI"]}
      },
      GridBoxDividers->{"Columns" -> {True, True}, "Rows" -> {}},
      GridBoxSpacings->{"Columns" -> {{0.15}}}], "2"]}]]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "9a9b5937-0a22-40fe-9908-bcf4db8483d1"],
 " and confirm the normalized state has norm ",
 Cell[BoxData["1"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "2997b432-eb89-4e82-98a8-652f7fb74eb2"],
 "."
}], "Text",ExpressionUUID->"c7101c70-d2ca-451b-a889-0fbaf3ffff7a"],

Cell["\<\
1.4 [BSc] How do I show that a global phase is physically unobservable?\
\>", "Subsection",ExpressionUUID->"77e958be-3a50-4f73-9770-60a295e84916"],

Cell[TextData[{
 "Multiplying ",
 Cell[BoxData[
  TemplateBox[{
    StyleBox["\[Psi]", "TI"]},
   "Ket"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "a4e3170f-4af9-412a-9d17-0e7edcb9dbbe"],
 " by ",
 Cell[BoxData[
  SuperscriptBox[
   StyleBox["e", "TI"], 
   RowBox[{
    StyleBox["i", "TI"], "\[CurlyPhi]"}]]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "acc96c08-bb2b-4168-aefe-1429b976aceb"],
 " changes no measurable prediction, because every probability depends only \
on ",
 Cell[BoxData[
  SuperscriptBox[GridBox[{
     {
      SubscriptBox[
       StyleBox["c", "TI"], 
       StyleBox["i", "TI"]]}
    },
    GridBoxDividers->{"Columns" -> {True, True}, "Rows" -> {}},
    GridBoxSpacings->{"Columns" -> {{0.15}}}], "2"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "2c8243e6-48a9-45d7-9b1f-0aed73dba3f8"],
 "."
}], "Text",ExpressionUUID->"3e5c4b28-d9df-4db4-b3c3-344d434f5be4"],

Cell[TextData[{
 StyleBox["WL",
  FontWeight->"Bold"],
 " : compare the two probability vectors symbolically for all real phases."
}], "Text",ExpressionUUID->"ae5ef3f9-c5b0-4934-a6ab-f3d0bafbc867"],

Cell[BoxData[
 RowBox[{"FullSimplify", "[", "\n", " ", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"Abs", "[", 
      RowBox[{"{", 
       RowBox[{"\[Alpha]", ",", " ", "\[Beta]"}], "}"}], "]"}], "^", "2"}], 
    " ", "==", " ", 
    RowBox[{
     RowBox[{"Abs", "[", 
      RowBox[{
       RowBox[{"Exp", "[", 
        RowBox[{"I", " ", "\[CurlyPhi]"}], "]"}], " ", 
       RowBox[{"{", 
        RowBox[{"\[Alpha]", ",", " ", "\[Beta]"}], "}"}]}], "]"}], "^", 
     "2"}]}], ",", "\n", " ", 
   RowBox[{"\[CurlyPhi]", " ", "\[Element]", " ", "Reals"}]}], "]"}]], "Input",\

 CellLabel->
  "In[11]:= ",ExpressionUUID->"872196d5-d2a4-4084-b273-3739fd9fc653"],

Cell[TextData[{
 StyleBox["QF",
  FontWeight->"Bold"],
 " : compare the two state objects directly. QuantumFramework's ",
 Cell[BoxData["=="], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "ba8bcee3-44e6-483a-90fb-2f97adc7708c"],
 " is a ",
 StyleBox["physical", "TI"],
 " comparison: it equates states that differ only by a global phase (it uses \
an inner-product oracle, not the raw amplitudes, so ",
 Cell[BoxData["==="], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "cae33ca1-08ff-48ae-ae55-e84447b70cc5"],
 " would still see them as distinct)."
}], "Text",ExpressionUUID->"2b94d971-bc4b-4149-98d1-c978b49006e2"],

Cell[BoxData[
 RowBox[{
  RowBox[{"QuantumState", "[", 
   RowBox[{"{", 
    RowBox[{"\[Alpha]", ",", " ", "\[Beta]"}], "}"}], "]"}], " ", "==", " ", 
  RowBox[{"QuantumState", "[", 
   RowBox[{
    RowBox[{"Exp", "[", 
     RowBox[{"I", " ", "\[CurlyPhi]"}], "]"}], " ", 
    RowBox[{"{", 
     RowBox[{"\[Alpha]", ",", " ", "\[Beta]"}], "}"}]}], "]"}]}]], "Input",
 CellLabel->
  "In[12]:= ",ExpressionUUID->"c325d8f9-2c91-41f5-b28a-9b939fff0c3e"],

Cell[TextData[{
 "Both return ",
 Cell[BoxData["True"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "4a8dacaa-7229-4988-ba79-be90aed30084"],
 ", symbolically, for every phase ",
 Cell[BoxData["\[CurlyPhi]"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "8090ebf1-1391-4a92-a71c-74f8aee327d4"],
 ": the WL test shows the Born probabilities are phase-independent, and \
QuantumFramework declares the two state objects ",
 StyleBox["equal", "TI"],
 ". The phase labels no physical degree of freedom."
}], "Text",ExpressionUUID->"2cc77dc7-e5dc-4df4-bd1e-dedc1c27608d"],

Cell[TextData[{
 "1.5 [BSc] How do I count the real parameters of a pure qubit and a pure \
qudit in ",
 Cell[BoxData[
  SuperscriptBox["\:2102", 
   StyleBox["d", "TI"]]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "b8daadb8-491e-48f0-9845-e3536b814541"],
 "?"
}], "Subsection",ExpressionUUID->"a9a4271c-c2de-4991-bf2f-9e516f290c8a"],

Cell[TextData[{
 "A pure state in ",
 Cell[BoxData[
  SuperscriptBox["\:2102", 
   StyleBox["d", "TI"]]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "4f65282f-3ab2-4e32-9cb1-ce925ff6b851"],
 " has ",
 Cell[BoxData[
  RowBox[{"2", 
   StyleBox["d", "TI"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "bebd578e-fe84-4def-b768-d2852d198dc4"],
 " real amplitude components; normalization removes one and the global phase \
another, so the naive count is ",
 Cell[BoxData[
  RowBox[{"2", 
   StyleBox["d", "TI"], "-", "2"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "5b5a1962-964e-4cb3-b9ca-42789bc6300e"],
 ". But that bookkeeping ",
 StyleBox["assumes", "TI"],
 " each constraint removes exactly one independent direction. To ",
 StyleBox["measure",
  FontWeight->"Bold"],
 " the count instead of assuming it, note what \"degrees of freedom\" means \
geometrically: the states sweep out a surface, and the number of free real \
parameters is the ",
 StyleBox["dimension", "TI"],
 " of that surface. The dimension of a parametrized surface is the generic ",
 StyleBox["rank of its Jacobian",
  FontWeight->"Bold"],
 ", the matrix of derivatives ",
 Cell[BoxData[
  RowBox[{
   RowBox[{"\[PartialD]", 
    TemplateBox[{
      StyleBox["\[Psi]", "TI"]},
     "Ket"]}], "/", 
   RowBox[{"\[PartialD]", 
    RowBox[{
     StyleBox["(",
      SpanMaxSize->1], 
     StyleBox["parameter",
      FontSlant->"Plain"], 
     StyleBox[")",
      SpanMaxSize->1]}]}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "ecaf9095-061b-4145-bc0d-bb792b718ebe"],
 ": the rank is how many linearly independent directions the state actually \
moves in as the parameters vary, and a redundant parameter (whose motion \
duplicates another's) does not raise it. That is why the Jacobian rank is the \
rigorous count, and why it exposes the global phase as a genuine redundancy."
}], "Text",ExpressionUUID->"c1e8d90e-4872-46e8-ad9e-ef1de0428b46"],

Cell[TextData[{
 StyleBox["WL",
  FontWeight->"Bold"],
 " : embed the qubit family (the two Bloch angles plus the global phase ",
 Cell[BoxData[
  StyleBox["g", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "ccd4ec7a-8f84-4cd5-87df-8525d680b6a8"],
 ") into ",
 Cell[BoxData[
  SuperscriptBox["\:211d", "4"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "b32d3fd0-8c60-4332-b1c8-96fa378d0cc3"],
 " as real and imaginary parts, and count its independent tangent directions. \
With the phase kept, the rank is ",
 Cell[BoxData["3"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "f59692ee-f72b-4b29-ac1e-39dfc7098467"],
 ": the normalized states fill a 3-sphere."
}], "Text",ExpressionUUID->"0dd0b819-6e31-4131-b3e3-607ad662e71d"],

Cell[BoxData[
 RowBox[{"With", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"psi", " ", "=", " ", 
     RowBox[{
      RowBox[{"Exp", "[", 
       RowBox[{"I", " ", "g"}], "]"}], " ", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"Cos", "[", 
         RowBox[{"\[Theta]", "/", "2"}], "]"}], ",", " ", 
        RowBox[{
         RowBox[{"Exp", "[", 
          RowBox[{"I", " ", "\[Phi]"}], "]"}], " ", 
         RowBox[{"Sin", "[", 
          RowBox[{"\[Theta]", "/", "2"}], "]"}]}]}], "}"}]}]}], "}"}], ",", 
   "\n", " ", 
   RowBox[{"MatrixRank", "[", 
    RowBox[{"D", "[", 
     RowBox[{
      RowBox[{"Flatten", "[", 
       RowBox[{"ReIm", "[", 
        RowBox[{"ComplexExpand", "[", "psi", "]"}], "]"}], "]"}], ",", " ", 
      RowBox[{"{", 
       RowBox[{"{", 
        RowBox[{"\[Theta]", ",", " ", "\[Phi]", ",", " ", "g"}], "}"}], 
       "}"}]}], "]"}], "]"}]}], "]"}]], "Input",
 CellLabel->
  "In[13]:= ",ExpressionUUID->"e695d025-9ac1-4644-b84f-0b84681ae9e2"],

Cell[TextData[{
 "Drop the phase ",
 Cell[BoxData[
  StyleBox["g", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "d7bf538f-5189-42ca-8986-4eed7b6ac5eb"],
 " and the rank falls to ",
 Cell[BoxData["2"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "2a961ba5-0dd3-49bd-95cc-ad2983b798ad"],
 ", the physical state space. The drop of exactly one direction is the global \
phase, a single redundancy."
}], "Text",ExpressionUUID->"e7f64fbb-7bda-4508-9192-5196e35f6da3"],

Cell[BoxData[
 RowBox[{"With", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"psi", " ", "=", " ", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"Cos", "[", 
        RowBox[{"\[Theta]", "/", "2"}], "]"}], ",", " ", 
       RowBox[{
        RowBox[{"Exp", "[", 
         RowBox[{"I", " ", "\[Phi]"}], "]"}], " ", 
        RowBox[{"Sin", "[", 
         RowBox[{"\[Theta]", "/", "2"}], "]"}]}]}], "}"}]}], "}"}], ",", "\n",
    " ", 
   RowBox[{"MatrixRank", "[", 
    RowBox[{"D", "[", 
     RowBox[{
      RowBox[{"Flatten", "[", 
       RowBox[{"ReIm", "[", 
        RowBox[{"ComplexExpand", "[", "psi", "]"}], "]"}], "]"}], ",", " ", 
      RowBox[{"{", 
       RowBox[{"{", 
        RowBox[{"\[Theta]", ",", " ", "\[Phi]"}], "}"}], "}"}]}], "]"}], 
    "]"}]}], "]"}]], "Input",
 CellLabel->
  "In[14]:= ",ExpressionUUID->"7f8723fb-e934-44c2-a131-5466b12776f3"],

Cell[TextData[{
 "For a general qudit, drop the hand-built chart and differentiate the one \
object that ",
 StyleBox["already", "TI"],
 " has both redundancies removed: the density matrix ",
 Cell[BoxData[
  RowBox[{
   StyleBox["\[Rho]", "TI"], "=", 
   RowBox[{
    TemplateBox[{
      StyleBox["\[Psi]", "TI"]},
     "Ket"], 
    RowBox[{
     TemplateBox[{
       StyleBox["\[Psi]", "TI"]},
      "Bra"], "/", 
     TemplateBox[{
       StyleBox["\[Psi]", "TI"], 
       StyleBox["\[Psi]", "TI"]},
      "BraKet"]}]}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "47365583-848a-4e1d-a0b1-f1fcaad03626"],
 ". Build it from a raw, unnormalized vector ",
 Cell[BoxData[
  RowBox[{
   StyleBox["z", "TI"], "\[Element]", 
   SuperscriptBox["\:2102", 
    StyleBox["d", "TI"]]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "e4f4fff2-d83e-4c6e-b232-5f832c43cdb6"],
 " and take the ",
 Cell[BoxData[
  RowBox[{"2", 
   StyleBox["d", "TI"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "67045dbd-216f-40c1-98f5-d7a91b1e3269"],
 " real and imaginary components of ",
 Cell[BoxData[
  StyleBox["z", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "0c29dea2-0781-48c2-bcff-f50ed76b8124"],
 " as the parameters. Because ",
 Cell[BoxData[
  StyleBox["\[Rho]", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "3737bf38-7d57-4df1-9212-bb88214ea192"],
 " is unchanged by ",
 Cell[BoxData[
  RowBox[{
   StyleBox["z", "TI"], "\[Rule]", 
   StyleBox["\[Lambda]", "TI"], 
   StyleBox["z", "TI"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "44493aac-342b-48b9-b6ab-0d8ab6fcbcf1"],
 " for any complex ",
 Cell[BoxData[
  StyleBox["\[Lambda]", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "b970b18c-5a88-4865-9b57-53209db9b98e"],
 ", it discards the normalization ",
 StyleBox["and", "TI"],
 " the global phase at a single stroke, so its Jacobian rank is the physical \
parameter count for any ",
 Cell[BoxData[
  StyleBox["d", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "ff7c28e1-8a6d-43ce-a2cf-0fcf37a9db28"],
 ", measured rather than assumed."
}], "Text",ExpressionUUID->"5f2b5f53-62fe-43ec-9d38-c129c893e345"],

Cell[TextData[{
 StyleBox["WL",
  FontWeight->"Bold"],
 " : form the projector ",
 Cell[BoxData[
  RowBox[{
   StyleBox["z", "TI"], 
   SuperscriptBox[
    StyleBox["z", "TI"], "\[Dagger]"], "/", 
   StyleBox["(",
    SpanMaxSize->1], 
   RowBox[{
    SuperscriptBox[
     StyleBox["z", "TI"], "\[Dagger]"], 
    StyleBox["z", "TI"]}], 
   StyleBox[")",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "0a8885c4-a3e0-4bf7-babe-679491444f9b"],
 " by hand and rank its Jacobian for ",
 Cell[BoxData[
  RowBox[{
   RowBox[{
    StyleBox["d", "TI"], "=", "2"}], ",", 
   RowBox[{"3", ",", "4"}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "84ff5464-e62e-4797-a4b0-5735ef6ff149"],
 "."
}], "Text",ExpressionUUID->"6ed6e522-2c34-4989-af58-2dc0a3fdb143"],

Cell[BoxData[
 RowBox[{"Table", "[", "\n", " ", 
  RowBox[{
   RowBox[{"With", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"z", " ", "=", " ", 
       RowBox[{
        RowBox[{"Array", "[", 
         RowBox[{"a", ",", " ", "d"}], "]"}], " ", "+", " ", 
        RowBox[{"I", " ", 
         RowBox[{"Array", "[", 
          RowBox[{"b", ",", " ", "d"}], "]"}]}]}]}], "}"}], ",", "\n", "  ", 
     RowBox[{"MatrixRank", "[", 
      RowBox[{"D", "[", "\n", "    ", 
       RowBox[{
        RowBox[{"Flatten", "[", 
         RowBox[{"ReIm", "[", 
          RowBox[{"ComplexExpand", "[", "\n", "      ", 
           RowBox[{"Flatten", "[", 
            RowBox[{
             RowBox[{"Outer", "[", 
              RowBox[{"Times", ",", " ", "z", ",", " ", 
               RowBox[{"Conjugate", "[", "z", "]"}]}], "]"}], "/", 
             RowBox[{"(", 
              RowBox[{
               RowBox[{"Conjugate", "[", "z", "]"}], " ", ".", " ", "z"}], 
              ")"}]}], "]"}], "]"}], "]"}], "]"}], ",", "\n", "    ", 
        RowBox[{"{", 
         RowBox[{"Join", "[", 
          RowBox[{
           RowBox[{"Array", "[", 
            RowBox[{"a", ",", " ", "d"}], "]"}], ",", " ", 
           RowBox[{"Array", "[", 
            RowBox[{"b", ",", " ", "d"}], "]"}]}], "]"}], "}"}]}], "]"}], 
      "]"}]}], "]"}], ",", "\n", " ", 
   RowBox[{"{", 
    RowBox[{"d", ",", " ", "2", ",", " ", "4"}], "}"}]}], "]"}]], "Input",
 CellLabel->
  "In[15]:= ",ExpressionUUID->"94282969-5838-4769-97a0-410d5b757b92"],

Cell[TextData[{
 "The ranks ",
 Cell[BoxData[
  RowBox[{
   RowBox[{"{", "2"}], ",", "4", ",", 
   RowBox[{"6", "}"}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "f214ccd8-bbc8-449c-9284-5769b8699ebc"],
 " are exactly ",
 Cell[BoxData[
  RowBox[{"2", 
   StyleBox["d", "TI"], "-", "2"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "1aa6bcf9-d523-4f50-bdf5-9271db4adafb"],
 ": each added Hilbert-space dimension contributes two new real parameters."
}], "Text",ExpressionUUID->"ef7805f5-dcdc-41f5-a353-21f3d2399535"],

Cell[TextData[{
 StyleBox["QF",
  FontWeight->"Bold"],
 " : a ",
 Cell[BoxData["QuantumState"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "1976badd-2ccc-4e24-bcbc-7a8a2cb0138a"],
 " carries the same density matrix, so take it from the object instead of \
building it. QF leaves a ",
 StyleBox["symbolic", "TI"],
 " input unnormalized (its ",
 Cell[BoxData["\"\<DensityMatrix\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "e64d6aa1-2509-47e6-aeff-e4fdce7e4942"],
 " is the bare ",
 Cell[BoxData[
  RowBox[{
   StyleBox["z", "TI"], 
   SuperscriptBox[
    StyleBox["z", "TI"], "\[Dagger]"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "a6a68b40-1125-4795-96d8-a90b6c661622"],
 ", of trace ",
 Cell[BoxData[
  TemplateBox[{
    StyleBox["\[Psi]", "TI"], 
    StyleBox["\[Psi]", "TI"]},
   "BraKet"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "0b9e326b-f061-4f65-963b-ca521a9f7e33"],
 "), so divide by the trace and rank the identical map."
}], "Text",ExpressionUUID->"61cba21f-f91a-4e8e-a4a7-e1e892d1dd17"],

Cell[BoxData[
 RowBox[{"Table", "[", "\n", " ", 
  RowBox[{
   RowBox[{"With", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"dm", " ", "=", " ", 
       RowBox[{
        RowBox[{"QuantumState", "[", 
         RowBox[{
          RowBox[{"Array", "[", 
           RowBox[{"a", ",", " ", "d"}], "]"}], " ", "+", " ", 
          RowBox[{"I", " ", 
           RowBox[{"Array", "[", 
            RowBox[{"b", ",", " ", "d"}], "]"}]}]}], "]"}], 
        "[", "\"\<DensityMatrix\>\"", "]"}]}], "}"}], ",", "\n", "  ", 
     RowBox[{"MatrixRank", "[", 
      RowBox[{"D", "[", "\n", "    ", 
       RowBox[{
        RowBox[{"Flatten", "[", 
         RowBox[{"ReIm", "[", 
          RowBox[{"ComplexExpand", "[", 
           RowBox[{"Flatten", "[", 
            RowBox[{"dm", "/", 
             RowBox[{"Tr", "[", "dm", "]"}]}], "]"}], "]"}], "]"}], "]"}], ",",
         "\n", "    ", 
        RowBox[{"{", 
         RowBox[{"Join", "[", 
          RowBox[{
           RowBox[{"Array", "[", 
            RowBox[{"a", ",", " ", "d"}], "]"}], ",", " ", 
           RowBox[{"Array", "[", 
            RowBox[{"b", ",", " ", "d"}], "]"}]}], "]"}], "}"}]}], "]"}], 
      "]"}]}], "]"}], ",", "\n", " ", 
   RowBox[{"{", 
    RowBox[{"d", ",", " ", "2", ",", " ", "4"}], "}"}]}], "]"}]], "Input",
 CellLabel->
  "In[16]:= ",ExpressionUUID->"43987855-eb98-4607-a23b-b4ce242c7deb"],

Cell[TextData[{
 "So a qubit has exactly two real parameters, the two Bloch angles: the rank \
falls from ",
 Cell[BoxData["3"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "a4077cdb-1bc5-4aca-aab8-5a9313a51fdd"],
 " (the normalized vectors, a 3-sphere in ",
 Cell[BoxData[
  SuperscriptBox["\:211d", "4"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "b5090d6c-7767-4ee6-8304-6e9e922ca800"],
 ") to ",
 Cell[BoxData["2"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "6acc9a58-c7a4-4266-b5ba-6c7a8cdbecfa"],
 " (the physical states) precisely when the global phase is removed. For any \
qudit the gauge freedom ",
 Cell[BoxData[
  RowBox[{
   StyleBox["z", "TI"], "\[Rule]", 
   StyleBox["\[Lambda]", "TI"], 
   StyleBox["z", "TI"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "5237c2b7-a1aa-4412-aec9-7b3ca193695f"],
 " is always two real dimensions, one scale and one phase, so the \
density-matrix rank is ",
 Cell[BoxData[
  RowBox[{"2", 
   StyleBox["d", "TI"], "-", "2"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "9130b4d4-d471-421a-8afc-fafe32f1cb88"],
 " for every ",
 Cell[BoxData[
  StyleBox["d", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "c1ee7546-a2fe-4de2-afe2-223dd82c9b1c"],
 ". The measured ",
 Cell[BoxData[
  RowBox[{
   RowBox[{"{", "2"}], ",", "4", ",", 
   RowBox[{"6", "}"}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "66fe8b24-38f8-43f5-8745-ee6630c27e86"],
 " confirm it, extending to ",
 Cell[BoxData[
  RowBox[{
   RowBox[{"{", "2"}], ",", 
   RowBox[{"4", ",", "6", ",", "8", ",", "10"}], ",", 
   RowBox[{"\[Ellipsis]", "}"}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "3dcf9341-6f0d-4bb2-aca6-2031acadd4cd"],
 " for ",
 Cell[BoxData[
  RowBox[{
   RowBox[{
    StyleBox["d", "TI"], "=", "2"}], ",", 
   RowBox[{"3", ",", "4", ",", "5", ",", "6"}], ",", "\[Ellipsis]"}]], 
  "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "514d1c19-b12c-4c9d-8901-192abcd1b22a"],
 ". The count is now measured at each step, not asserted."
}], "Text",ExpressionUUID->"bdc132c7-dd13-4bac-9a19-baf790357bf0"],

Cell[TextData[{
 "1.6 [BSc] How do I compute an inner product ",
 Cell[BoxData[
  TemplateBox[{
    StyleBox["\[Phi]", "TI"], 
    StyleBox["\[Psi]", "TI"]},
   "BraKet"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "9b0222ad-9da9-4383-8770-186d474c8c28"],
 ", its modulus, and the transition probability ",
 Cell[BoxData[
  SuperscriptBox[GridBox[{
     {
      TemplateBox[{
        StyleBox["\[Phi]", "TI"], 
        StyleBox["\[Psi]", "TI"]},
       "BraKet"]}
    },
    GridBoxDividers->{"Columns" -> {True, True}, "Rows" -> {}},
    GridBoxSpacings->{"Columns" -> {{0.15}}}], "2"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "95ceab51-e166-47a7-a07a-b5e8b50e2748"],
 "?"
}], "Subsection",ExpressionUUID->"e870bcff-e5a1-49db-a1fc-9898bfc003ad"],

Cell["\<\
The overlap of two states, its absolute value, and its absolute square give \
the amplitude and the probability to find one state in the other.\
\>", "Text",ExpressionUUID->"2572c256-9dfc-44db-9850-5f745d6d541e"],

Cell[TextData[{
 StyleBox["WL",
  FontWeight->"Bold"],
 " : the inner product is the ",
 StyleBox["conjugated", "TI"],
 " dot product; the conjugation acts on the bra ",
 Cell[BoxData[
  TemplateBox[{
    StyleBox["\[Phi]", "TI"]},
   "Bra"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "9646d680-35a6-4a75-91c6-fc6bdf00b8ed"],
 ", which is why ",
 Cell[BoxData[
  RowBox[{
   SubscriptBox[
    StyleBox["\[Alpha]", "TI"], "1"], ",", 
   SubscriptBox[
    StyleBox["\[Beta]", "TI"], "1"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "dc015a81-70a1-4be3-b762-1cf22cf199f1"],
 " appear conjugated. The cell returns the overlap, its modulus, and its \
transition probability as a labeled Association, one inner product read three \
ways."
}], "Text",ExpressionUUID->"dc1cb6be-a42b-41e5-9d5c-5a5ed7def6ca"],

Cell[BoxData[
 RowBox[{"With", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{"phi", " ", "=", " ", 
      RowBox[{"{", 
       RowBox[{"\[Alpha]1", ",", " ", "\[Beta]1"}], "}"}]}], ",", " ", 
     RowBox[{"psi", " ", "=", " ", 
      RowBox[{"{", 
       RowBox[{"\[Alpha]2", ",", " ", "\[Beta]2"}], "}"}]}]}], "}"}], ",", 
   "\n", " ", 
   RowBox[{"With", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"ip", " ", "=", " ", 
       RowBox[{
        RowBox[{"Conjugate", "[", "phi", "]"}], " ", ".", " ", "psi"}]}], 
      "}"}], ",", "\n", "  ", 
     RowBox[{"AssociationThread", "[", "\n", "   ", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"\"\<\[LeftAngleBracket]\[Phi]|\[Psi]\[RightAngleBracket]\>\"",
          ",", "\n", 
         "    ", "\"\<|\[LeftAngleBracket]\[Phi]|\[Psi]\[RightAngleBracket]|\>\
\"", ",", "\n", 
         "    ", "\"\<|\[LeftAngleBracket]\[Phi]|\[Psi]\[RightAngleBracket]\!\
\(\*SuperscriptBox[\(|\), \(2\)]\)\>\""}], "}"}], ",", "\n", "   ", 
       RowBox[{"{", 
        RowBox[{"ip", ",", " ", 
         RowBox[{"Abs", "[", "ip", "]"}], ",", " ", 
         RowBox[{
          RowBox[{"Abs", "[", "ip", "]"}], "^", "2"}]}], "}"}]}], "]"}]}], 
    "]"}]}], "]"}]], "Input",
 CellLabel->
  "In[17]:= ",ExpressionUUID->"7d21e5b2-8efe-4071-962b-3b419e08efa5"],

Cell[TextData[{
 StyleBox["QF",
  FontWeight->"Bold"],
 " : build the bra with ",
 Cell[BoxData["\"\<Dagger\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "7eaf7741-9cdc-49c4-b477-9ba3e089f616"],
 ", compose with the ket, and read the same three quantities off the scalar, \
under the same labels."
}], "Text",ExpressionUUID->"ea2369b1-1ac5-4bff-91aa-ba485f820ed3"],

Cell[BoxData[
 RowBox[{"With", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{"bra", " ", "=", " ", 
      RowBox[{
       RowBox[{"QuantumState", "[", 
        RowBox[{"{", 
         RowBox[{"\[Alpha]1", ",", " ", "\[Beta]1"}], "}"}], "]"}], 
       "[", "\"\<Dagger\>\"", "]"}]}], ",", " ", 
     RowBox[{"ket", " ", "=", " ", 
      RowBox[{"QuantumState", "[", 
       RowBox[{"{", 
        RowBox[{"\[Alpha]2", ",", " ", "\[Beta]2"}], "}"}], "]"}]}]}], "}"}], 
   ",", "\n", " ", 
   RowBox[{"With", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"ip", " ", "=", " ", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{"bra", " ", "@", " ", "ket"}], ")"}], "[", "\"\<Scalar\>\"", 
        "]"}]}], "}"}], ",", "\n", "  ", 
     RowBox[{"AssociationThread", "[", "\n", "   ", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"\"\<\[LeftAngleBracket]\[Phi]|\[Psi]\[RightAngleBracket]\>\"",
          ",", "\n", 
         "    ", "\"\<|\[LeftAngleBracket]\[Phi]|\[Psi]\[RightAngleBracket]|\>\
\"", ",", "\n", 
         "    ", "\"\<|\[LeftAngleBracket]\[Phi]|\[Psi]\[RightAngleBracket]\!\
\(\*SuperscriptBox[\(|\), \(2\)]\)\>\""}], "}"}], ",", "\n", "   ", 
       RowBox[{"{", 
        RowBox[{"ip", ",", " ", 
         RowBox[{"Abs", "[", "ip", "]"}], ",", " ", 
         RowBox[{
          RowBox[{"Abs", "[", "ip", "]"}], "^", "2"}]}], "}"}]}], "]"}]}], 
    "]"}]}], "]"}]], "Input",
 CellLabel->
  "In[18]:= ",ExpressionUUID->"7360808c-d445-4319-a9de-c461bcbc2ef9"],

Cell[TextData[{
 "Both give ",
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     StyleBox["\[Phi]", "TI"], 
     StyleBox["\[Psi]", "TI"]},
    "BraKet"], "=", 
   SubscriptBox[
    StyleBox["\[Alpha]", "TI"], "2"], 
   SubsuperscriptBox[
    StyleBox["\[Alpha]", "TI"], "1", "*"], "+", 
   SubscriptBox[
    StyleBox["\[Beta]", "TI"], "2"], 
   SubsuperscriptBox[
    StyleBox["\[Beta]", "TI"], "1", "*"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "8be5015c-877e-4f8f-9975-41503ff8b270"],
 ", with its modulus and its square. The conjugation on the bra is what makes \
this a sesquilinear inner product rather than a plain bilinear dot product."
}], "Text",ExpressionUUID->"0a05b0e4-3115-46ae-aded-c7edb6217f0f"],

Cell[TextData[{
 "1.7 [BSc] How do I write a state both as a column vector of amplitudes and \
as a Dirac superposition ",
 Cell[BoxData[
  RowBox[{
   UnderscriptBox["\[Sum]", 
    StyleBox["i", "TI"],
    LimitsPositioning->False], 
   RowBox[{
    SubscriptBox[
     StyleBox["c", "TI"], 
     StyleBox["i", "TI"]], 
    TemplateBox[{
      StyleBox["i", "TI"]},
     "Ket"]}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "be97da58-cf6c-4d08-b9fb-4d71d5fee182"],
 "?"
}], "Subsection",ExpressionUUID->"47d8c9db-a396-43dc-b16e-244985a2a5b3"],

Cell["\<\
The amplitude list and the ket-superposition are two views of one object.\
\>", "Text",ExpressionUUID->"a69523b2-89de-4511-9c43-0f0ec7a93a89"],

Cell[TextData[{
 StyleBox["WL",
  FontWeight->"Bold"],
 " : the amplitude vector is the list itself."
}], "Text",ExpressionUUID->"a87ae916-3416-49f3-80af-f2d9fc9e5fd3"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"\[Alpha]", ",", " ", "\[Beta]"}], "}"}]], "Input",
 CellLabel->
  "In[19]:= ",ExpressionUUID->"0d7a2e1e-6dcd-4242-8181-e5dc63ddb169"],

Cell["\<\
The Dirac form is the same numbers against the computational basis; the \
identity confirms the expansion.\
\>", "Text",ExpressionUUID->"309c1246-5a8d-4b45-adac-3cc14db678ed"],

Cell[BoxData[
 RowBox[{
  RowBox[{"{", 
   RowBox[{"\[Alpha]", ",", " ", "\[Beta]"}], "}"}], " ", "==", " ", 
  RowBox[{
   RowBox[{"\[Alpha]", " ", 
    RowBox[{"{", 
     RowBox[{"1", ",", " ", "0"}], "}"}]}], " ", "+", " ", 
   RowBox[{"\[Beta]", " ", 
    RowBox[{"{", 
     RowBox[{"0", ",", " ", "1"}], "}"}]}]}]}]], "Input",
 CellLabel->
  "In[20]:= ",ExpressionUUID->"affb7c7d-3c26-4862-84c8-facfae425f8d"],

Cell[TextData[{
 StyleBox["QF",
  FontWeight->"Bold"],
 " : the state object, shown first as its summary box."
}], "Text",ExpressionUUID->"6ab7c6c5-762f-42ef-81da-45c2d4e607cc"],

Cell[BoxData[
 RowBox[{"qs", " ", "=", " ", 
  RowBox[{"QuantumState", "[", 
   RowBox[{"{", 
    RowBox[{"\[Alpha]", ",", " ", "\[Beta]"}], "}"}], "]"}]}]], "Input",
 CellLabel->
  "In[21]:= ",ExpressionUUID->"511ba6e9-4bed-4dfb-be9c-7bf2866e4ef9"],

Cell[TextData[{
 Cell[BoxData["\"\<StateVector\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "0d7b6711-d448-405f-bed7-16d3a78af798"],
 " reads the amplitudes:"
}], "Text",ExpressionUUID->"ace70f29-b3b3-43fa-b70c-1879dc91554e"],

Cell[BoxData[
 RowBox[{
  RowBox[{"qs", "[", "\"\<StateVector\>\"", "]"}], " ", "//", " ", 
  "Normal"}]], "Input",
 CellLabel->
  "In[22]:= ",ExpressionUUID->"18b2922d-6acb-4e05-867d-60494318f65a"],

Cell[TextData[{
 Cell[BoxData["\"\<Formula\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "247938b3-ad9e-4866-bf00-6770f2847d3e"],
 " typesets the same object as the Dirac superposition ",
 Cell[BoxData[
  RowBox[{
   UnderscriptBox["\[Sum]", 
    StyleBox["i", "TI"],
    LimitsPositioning->False], 
   RowBox[{
    SubscriptBox[
     StyleBox["c", "TI"], 
     StyleBox["i", "TI"]], 
    TemplateBox[{
      StyleBox["i", "TI"]},
     "Ket"]}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "ec7ea585-44b4-476a-a816-4e0a3731a0b5"],
 ":"
}], "Text",ExpressionUUID->"a85e7a72-bce0-4dc0-96a8-3ad85a86e267"],

Cell[BoxData[
 RowBox[{"qs", "[", "\"\<Formula\>\"", "]"}]], "Input",
 CellLabel->
  "In[23]:= ",ExpressionUUID->"bf874634-d2d6-47e7-8933-608d31a54859"],

Cell[TextData[{
 "The amplitude vector and the superposition ",
 Cell[BoxData[
  RowBox[{
   RowBox[{
    StyleBox["\[Alpha]", "TI"], 
    TemplateBox[{"0"},
     "Ket"]}], "+", 
   RowBox[{
    StyleBox["\[Beta]", "TI"], 
    TemplateBox[{"1"},
     "Ket"]}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "18f87b9e-f375-4e8b-8a29-1a14a3bcead0"],
 " carry identical information; both are representations read from the one \
object whose summary box is shown above."
}], "Text",ExpressionUUID->"4a7f0704-cdd4-440e-8885-0d86297d0642"],

Cell["\<\
1.8 [BSc] How do I get the Bloch vector of a qubit, and the Bloch-sphere \
angles?\
\>", "Subsection",ExpressionUUID->"854a8059-2c1c-4ecc-8af8-04b4fe0d2453"],

Cell[TextData[{
 "The Bloch vector ",
 Cell[BoxData[
  RowBox[{
   OverscriptBox[
    StyleBox["r", "TI"], "\[RightVector]"], "=", 
   StyleBox["(",
    SpanMaxSize->1], 
   RowBox[{
    RowBox[{
     StyleBox["\[LeftAngleBracket]",
      SpanMaxSize->1], 
     SubscriptBox[
      StyleBox["\[Sigma]", "TI"], 
      StyleBox["x", "TI"]], 
     StyleBox["\[RightAngleBracket]",
      SpanMaxSize->1]}], ",", 
    RowBox[{
     StyleBox["\[LeftAngleBracket]",
      SpanMaxSize->1], 
     SubscriptBox[
      StyleBox["\[Sigma]", "TI"], 
      StyleBox["y", "TI"]], 
     StyleBox["\[RightAngleBracket]",
      SpanMaxSize->1]}], ",", 
    RowBox[{
     StyleBox["\[LeftAngleBracket]",
      SpanMaxSize->1], 
     SubscriptBox[
      StyleBox["\[Sigma]", "TI"], 
      StyleBox["z", "TI"]], 
     StyleBox["\[RightAngleBracket]",
      SpanMaxSize->1]}]}], 
   StyleBox[")",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "d9c95b90-3861-441c-b470-6cab7e3c4a84"],
 " places a pure qubit on the unit sphere, with ",
 Cell[BoxData[
  RowBox[{
   StyleBox["(",
    SpanMaxSize->1], 
   RowBox[{
    StyleBox["\[Theta]", "TI"], ",", 
    StyleBox["\[Phi]", "TI"]}], 
   StyleBox[")",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "54627c68-aed8-4143-a793-1f9e0aa6c916"],
 " its spherical angles."
}], "Text",ExpressionUUID->"cd4e07df-d3ec-4192-ae72-da1995a90c91"],

Cell[TextData[{
 StyleBox["WL",
  FontWeight->"Bold"],
 " : the Bloch vector is, ",
 StyleBox["by definition", "TI"],
 ", the triple of Pauli expectation values ",
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     StyleBox["\[Psi]", "TI"]},
    "Bra"], 
   SubscriptBox[
    StyleBox["\[Sigma]", "TI"], 
    StyleBox["j", "TI"]], 
   TemplateBox[{
     StyleBox["\[Psi]", "TI"]},
    "Ket"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "986b0000-460c-4320-bfa2-52b0b7a6a65d"],
 ". Evaluate that definition for a general ",
 Cell[BoxData[
  RowBox[{
   RowBox[{"{", 
    StyleBox["\[Alpha]", "TI"]}], ",", 
   RowBox[{
    StyleBox["\[Beta]", "TI"], "}"}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "24ea839b-21cd-4e3f-92a8-ee2001070d69"],
 " to get the familiar component formula."
}], "Text",ExpressionUUID->"3d391b05-0b87-4ade-9dd5-d58724a9ffb3"],

Cell[BoxData[
 RowBox[{"FullSimplify", " ", "@", " ", 
  RowBox[{"Table", "[", 
   RowBox[{
    RowBox[{
     RowBox[{"Conjugate", "[", 
      RowBox[{"{", 
       RowBox[{"\[Alpha]", ",", " ", "\[Beta]"}], "}"}], "]"}], " ", ".", " ", 
     RowBox[{"PauliMatrix", "[", "j", "]"}], " ", ".", " ", 
     RowBox[{"{", 
      RowBox[{"\[Alpha]", ",", " ", "\[Beta]"}], "}"}]}], ",", " ", 
    RowBox[{"{", 
     RowBox[{"j", ",", " ", "3"}], "}"}]}], "]"}]}]], "Input",
 CellLabel->
  "In[24]:= ",ExpressionUUID->"2803aa67-0222-48eb-a4e2-e19d4b227b5c"],

Cell["\<\
For the angle-parametrized state the same definition gives the geometric \
vector on the sphere.\
\>", "Text",ExpressionUUID->"8161c330-ace9-446e-9195-cc0d068bc6b8"],

Cell[BoxData[
 RowBox[{"rvec", " ", "=", " ", 
  RowBox[{"With", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"\[Psi]", " ", "=", " ", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"Cos", "[", 
         RowBox[{"\[Theta]", "/", "2"}], "]"}], ",", " ", 
        RowBox[{
         RowBox[{"Exp", "[", 
          RowBox[{"I", " ", "\[Phi]"}], "]"}], " ", 
         RowBox[{"Sin", "[", 
          RowBox[{"\[Theta]", "/", "2"}], "]"}]}]}], "}"}]}], "}"}], ",", 
    "\n", "  ", 
    RowBox[{"FullSimplify", "[", 
     RowBox[{
      RowBox[{"Table", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"Conjugate", "[", "\[Psi]", "]"}], " ", ".", " ", 
         RowBox[{"PauliMatrix", "[", "j", "]"}], " ", ".", " ", "\[Psi]"}], ",",
         " ", 
        RowBox[{"{", 
         RowBox[{"j", ",", " ", "3"}], "}"}]}], "]"}], ",", " ", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"\[Theta]", ",", " ", "\[Phi]"}], "}"}], " ", "\[Element]", 
       " ", "Reals"}]}], "]"}]}], "]"}]}]], "Input",
 CellLabel->
  "In[25]:= ",ExpressionUUID->"8c60b72e-bbcf-4532-b103-42b1dfc1c43c"],

Cell["\<\
A built-in coordinate transform turns that Cartesian vector into spherical \
angles.\
\>", "Text",ExpressionUUID->"5f0d8147-bf35-4768-9127-4fdd8e9b1d85"],

Cell[BoxData[
 RowBox[{"FullSimplify", "[", 
  RowBox[{
   RowBox[{"ToSphericalCoordinates", "[", "rvec", "]"}], ",", " ", 
   RowBox[{
    RowBox[{"0", " ", "<", " ", "\[Theta]", " ", "<", " ", "Pi"}], " ", "&&", 
    " ", 
    RowBox[{
     RowBox[{"-", "Pi"}], " ", "<", " ", "\[Phi]", " ", "<", " ", "Pi"}]}]}], 
  "]"}]], "Input",
 CellLabel->
  "In[26]:= ",ExpressionUUID->"661b18ab-538e-4918-97e7-d548059f02a2"],

Cell[TextData[{
 StyleBox["QF",
  FontWeight->"Bold"],
 " : the state object, shown as its summary box."
}], "Text",ExpressionUUID->"0477629e-8fa1-45bf-a600-99b5757b5783"],

Cell[BoxData[
 RowBox[{"qs", " ", "=", " ", 
  RowBox[{"QuantumState", "[", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"Cos", "[", 
      RowBox[{"\[Theta]", "/", "2"}], "]"}], ",", " ", 
     RowBox[{
      RowBox[{"Exp", "[", 
       RowBox[{"I", " ", "\[Phi]"}], "]"}], " ", 
      RowBox[{"Sin", "[", 
       RowBox[{"\[Theta]", "/", "2"}], "]"}]}]}], "}"}], "]"}]}]], "Input",
 CellLabel->
  "In[27]:= ",ExpressionUUID->"87994898-7931-45bc-826e-cca62aac1653"],

Cell[TextData[{
 Cell[BoxData["\"\<BlochVector\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "692b7248-df1b-470b-95fd-dc9efd22d206"],
 " computes the same Pauli expectation values internally (as ",
 Cell[BoxData[
  RowBox[{
   StyleBox["Tr",
    FontSlant->"Plain"], 
   StyleBox["[",
    SpanMaxSize->1], 
   RowBox[{
    StyleBox["\[Rho]", "TI"], " ", 
    SubscriptBox[
     StyleBox["\[Sigma]", "TI"], 
     StyleBox["j", "TI"]]}], 
   StyleBox["]",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "0227118f-1c36-49d0-83c1-98bdfc8b4172"],
 ")."
}], "Text",ExpressionUUID->"a77b903c-6778-46b9-8e49-d0337be52f54"],

Cell[BoxData[
 RowBox[{"FullSimplify", "[", 
  RowBox[{
   RowBox[{"qs", "[", "\"\<BlochVector\>\"", "]"}], ",", " ", 
   RowBox[{
    RowBox[{"0", " ", "<", " ", "\[Theta]", " ", "<", " ", "Pi"}], " ", "&&", 
    " ", 
    RowBox[{
     RowBox[{"-", "Pi"}], " ", "<", " ", "\[Phi]", " ", "<", " ", "Pi"}]}]}], 
  "]"}]], "Input",
 CellLabel->
  "In[28]:= ",ExpressionUUID->"e0674b22-d76f-47fc-a27e-810cda311e7a"],

Cell[TextData[{
 Cell[BoxData["\"\<BlochSphericalCoordinates\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "b0e3b712-c057-41a5-a03a-c705750b975c"],
 " gives the polar and azimuthal angles."
}], "Text",ExpressionUUID->"55f36655-04b0-437f-9391-294bef5e3a57"],

Cell[BoxData[
 RowBox[{"FullSimplify", "[", 
  RowBox[{
   RowBox[{"qs", "[", "\"\<BlochSphericalCoordinates\>\"", "]"}], ",", " ", 
   RowBox[{
    RowBox[{"0", " ", "<", " ", "\[Theta]", " ", "<", " ", "Pi"}], " ", "&&", 
    " ", 
    RowBox[{
     RowBox[{"-", "Pi"}], " ", "<", " ", "\[Phi]", " ", "<", " ", "Pi"}]}]}], 
  "]"}]], "Input",
 CellLabel->
  "In[29]:= ",ExpressionUUID->"165d3157-995a-4ae6-a6a1-ad8140c0700a"],

Cell[TextData[{
 "Evaluating the definition returns ",
 Cell[BoxData[
  RowBox[{
   RowBox[{
    RowBox[{"{", "2", " ", 
     StyleBox["Re",
      FontSlant->"Plain"], " ", 
     SuperscriptBox[
      StyleBox["\[Alpha]", "TI"], "*"], 
     StyleBox["\[Beta]", "TI"]}], ",", " ", 
    RowBox[{"2", " ", 
     StyleBox["Im",
      FontSlant->"Plain"], " ", 
     SuperscriptBox[
      StyleBox["\[Alpha]", "TI"], "*"], 
     StyleBox["\[Beta]", "TI"]}], ",", " ", 
    RowBox[{
     SuperscriptBox[GridBox[{
        {
         StyleBox["\[Alpha]", "TI"]}
       },
       GridBoxDividers->{"Columns" -> {True, True}, "Rows" -> {}},
       GridBoxSpacings->{"Columns" -> {{0.15}}}], "2"], "-", 
     SuperscriptBox[GridBox[{
        {
         StyleBox["\[Beta]", "TI"]}
       },
       GridBoxDividers->{"Columns" -> {True, True}, "Rows" -> {}},
       GridBoxSpacings->{"Columns" -> {{0.15}}}], "2"]}]}], "}"}]], 
  "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "e00cbe39-cce7-4ddf-acc9-3b6888d890dc"],
 " for a general state and ",
 Cell[BoxData[
  RowBox[{
   StyleBox["(",
    SpanMaxSize->1], 
   RowBox[{
    RowBox[{
     StyleBox["sin",
      FontSlant->"Plain"], "\[ThinSpace]", 
     StyleBox["\[Theta]", "TI"], 
     StyleBox["cos",
      FontSlant->"Plain"], "\[ThinSpace]", 
     StyleBox["\[Phi]", "TI"]}], ",", " ", 
    RowBox[{
     StyleBox["sin",
      FontSlant->"Plain"], "\[ThinSpace]", 
     StyleBox["\[Theta]", "TI"], 
     StyleBox["sin",
      FontSlant->"Plain"], "\[ThinSpace]", 
     StyleBox["\[Phi]", "TI"]}], ",", " ", 
    RowBox[{
     StyleBox["cos",
      FontSlant->"Plain"], "\[ThinSpace]", 
     StyleBox["\[Theta]", "TI"]}]}], 
   StyleBox[")",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "608812ca-cf3e-42c8-bfee-338b59ddb55b"],
 " for the parametrized one, with spherical coordinates ",
 Cell[BoxData[
  RowBox[{
   StyleBox["(",
    SpanMaxSize->1], 
   RowBox[{"1", ",", 
    StyleBox["\[Theta]", "TI"], ",", 
    StyleBox["\[Phi]", "TI"]}], 
   StyleBox[")",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "ba9ae103-cc10-4795-acc4-066a3ae34705"],
 ". So the component formula is a ",
 StyleBox["result", "TI"],
 " of evaluating the Pauli expectation values, not the definition itself, and \
the parametrization angles are exactly the polar and azimuthal angles on the \
Bloch sphere."
}], "Text",ExpressionUUID->"456a036b-e2fc-4e09-a6c7-f3a520644d38"],

Cell[TextData[{
 "1.9a [BSc] How do I prepare a qudit in the computational basis state ",
 Cell[BoxData[
  TemplateBox[{"0"},
   "Ket"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "5f51c443-34ef-4098-acdb-d1ab164f4359"],
 "?"
}], "Subsection",ExpressionUUID->"c92e4cdd-ba7f-400a-9f4c-72696c081637"],

Cell[TextData[{
 "A qudit lives in ",
 Cell[BoxData[
  SuperscriptBox["\:2102", 
   StyleBox["d", "TI"]]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "692d63af-f03b-4604-bd95-2bfef37e4133"],
 "; its simplest preparation is the computational basis state ",
 Cell[BoxData[
  TemplateBox[{"0"},
   "Ket"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "b0b5b99b-1c22-473b-ba41-c28b76055ec9"],
 ", the unit vector along the first axis."
}], "Text",ExpressionUUID->"6bd33e34-fa70-478b-9679-ede5a2db7d51"],

Cell[TextData[{
 StyleBox["WL",
  FontWeight->"Bold"],
 " : ",
 Cell[BoxData[
  TemplateBox[{"0"},
   "Ket"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "73434fad-bc05-414c-ab33-8430b1284660"],
 " is a unit vector in ",
 Cell[BoxData[
  SuperscriptBox["\:2102", 
   StyleBox["d", "TI"]]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "4f26eac2-4974-4e32-9a39-a6658b8f9e2c"],
 "."
}], "Text",ExpressionUUID->"7d1fb9b1-9c42-4ea0-b525-477452ad26b3"],

Cell[BoxData[
 RowBox[{"With", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"d", " ", "=", " ", "3"}], "}"}], ",", " ", 
   RowBox[{"UnitVector", "[", 
    RowBox[{"d", ",", " ", "1"}], "]"}]}], "]"}]], "Input",
 CellLabel->
  "In[30]:= ",ExpressionUUID->"593b64d6-e7ef-441e-829d-2ea084ca3183"],

Cell[TextData[{
 StyleBox["QF",
  FontWeight->"Bold"],
 " : name the basis state with its dimension."
}], "Text",ExpressionUUID->"c84bf536-75ae-4e4c-aee5-1d007477ec54"],

Cell[BoxData[
 RowBox[{"With", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"d", " ", "=", " ", "3"}], "}"}], ",", " ", 
   RowBox[{
    RowBox[{
     RowBox[{"QuantumState", "[", 
      RowBox[{"\"\<0\>\"", ",", " ", "d"}], "]"}], "[", "\"\<StateVector\>\"",
      "]"}], " ", "//", " ", "Normal"}]}], "]"}]], "Input",
 CellLabel->
  "In[31]:= ",ExpressionUUID->"c57af33f-bcca-4083-a9cc-d7e441eaa7bb"],

Cell[TextData[{
 "Both give ",
 Cell[BoxData[
  RowBox[{
   TemplateBox[{"0"},
    "Ket"], "=", 
   StyleBox["(",
    SpanMaxSize->1], 
   RowBox[{"1", ",", "0", ",", "0"}], 
   StyleBox[")",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "6cebd778-f464-415a-bbae-37c806b41f3c"],
 " in ",
 Cell[BoxData[
  RowBox[{
   StyleBox["d", "TI"], "=", "3"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "465e5f48-638c-4014-be40-e372530f6e4b"],
 "; written in ",
 Cell[BoxData[
  StyleBox["d", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "23796fed-5ecd-4e32-bfd5-312cf6f06382"],
 ", the preparation works for any dimension."
}], "Text",ExpressionUUID->"5a85ea49-41f7-4da2-8187-a4b4a01cac28"],

Cell[TextData[{
 "1.9b [BSc] How do I prepare a uniform superposition ",
 Cell[BoxData[
  RowBox[{
   FractionBox["1", 
    SqrtBox[
     StyleBox["d", "TI"]]], 
   RowBox[{
    UnderscriptBox["\[Sum]", 
     StyleBox["k", "TI"],
     LimitsPositioning->False], 
    TemplateBox[{
      StyleBox["k", "TI"]},
     "Ket"]}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "1d613fde-ddb3-4d2f-b5d3-0cdce7f31b51"],
 " in ",
 Cell[BoxData[
  SuperscriptBox["\:2102", 
   StyleBox["d", "TI"]]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "a17c788c-a91d-4837-8302-fe532074b938"],
 "?"
}], "Subsection",ExpressionUUID->"0ad2ffb7-fe62-4ad2-bd14-b1f50b3f8c88"],

Cell[TextData[{
 "The equal-weight superposition ",
 Cell[BoxData[
  RowBox[{
   FractionBox["1", 
    SqrtBox[
     StyleBox["d", "TI"]]], 
   RowBox[{
    UnderscriptBox["\[Sum]", 
     StyleBox["k", "TI"],
     LimitsPositioning->False], 
    TemplateBox[{
      StyleBox["k", "TI"]},
     "Ket"]}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "034986de-4aa1-41cc-8be7-66da2f335b0d"],
 " puts the same amplitude on every basis state; it is the flat starting \
state of many algorithms."
}], "Text",ExpressionUUID->"657d3495-50fa-474c-a939-10d7d0dbde45"],

Cell[TextData[{
 StyleBox["WL",
  FontWeight->"Bold"],
 " : a constant vector handed to ",
 Cell[BoxData["Normalize"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "cdfea44e-77cb-4762-aa4a-bad5a0d1f6b6"],
 " (no hardcoded ",
 Cell[BoxData[
  RowBox[{"1", "/", 
   SqrtBox[
    StyleBox["d", "TI"]]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "2e870b16-393d-46b1-8f57-d45df4d16e0f"],
 ")."
}], "Text",ExpressionUUID->"dfab07e5-0e01-4f49-88c9-eb28c2437cb6"],

Cell[BoxData[
 RowBox[{"With", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"d", " ", "=", " ", "3"}], "}"}], ",", " ", 
   RowBox[{"Normalize", " ", "@", " ", 
    RowBox[{"ConstantArray", "[", 
     RowBox[{"1", ",", " ", "d"}], "]"}]}]}], "]"}]], "Input",
 CellLabel->
  "In[32]:= ",ExpressionUUID->"d8b3ef56-bbfe-41b1-9c99-52f951a66e64"],

Cell[TextData[{
 StyleBox["QF",
  FontWeight->"Bold"],
 " : use the built-in ",
 Cell[BoxData["\"\<UniformSuperposition\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "86ffd49f-e802-4eb6-a997-882c0f92c191"],
 " state rather than building it by hand."
}], "Text",ExpressionUUID->"163736c2-29b8-4789-a395-f54b5e36bd90"],

Cell[BoxData[
 RowBox[{"With", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"d", " ", "=", " ", "3"}], "}"}], ",", " ", 
   RowBox[{
    RowBox[{
     RowBox[{"QuantumState", "[", 
      RowBox[{"\"\<UniformSuperposition\>\"", ",", " ", "d"}], "]"}], 
     "[", "\"\<StateVector\>\"", "]"}], " ", "//", " ", "Normal"}]}], 
  "]"}]], "Input",
 CellLabel->
  "In[33]:= ",ExpressionUUID->"8ed97f90-af46-4e63-b9bf-bc0fc2972bf9"],

Cell[TextData[{
 "Both give the uniform qutrit ",
 Cell[BoxData[
  RowBox[{
   FractionBox["1", 
    SqrtBox["3"]], 
   StyleBox["(",
    SpanMaxSize->1], 
   RowBox[{"1", ",", "1", ",", "1"}], 
   StyleBox[")",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "abf3c3c3-1da7-4a9f-868a-621797bda420"],
 "; written in ",
 Cell[BoxData[
  StyleBox["d", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "581768a3-38da-4e6d-9de6-5203aef0a695"],
 ", it works for any dimension."
}], "Text",ExpressionUUID->"09369764-f98a-4bfd-9f52-9973527b0f61"],

Cell["Part 2. Observables, spectra, and approximation", "Section",ExpressionUUID->"5111c788-eec1-4419-8bc3-7a20e445d988"],

Cell["\<\
2.1 [BSc] How do I compute a commutator and an anticommutator of two \
operators?\
\>", "Subsection",ExpressionUUID->"65a87546-5060-473b-9931-781010486d72"],

Cell[TextData[{
 "The commutator ",
 Cell[BoxData[
  RowBox[{
   StyleBox["[",
    SpanMaxSize->1], 
   RowBox[{
    StyleBox["A", "TI"], ",", 
    StyleBox["B", "TI"]}], 
   StyleBox["]",
    SpanMaxSize->1], "=", 
   StyleBox["A", "TI"], 
   StyleBox["B", "TI"], "-", 
   StyleBox["B", "TI"], 
   StyleBox["A", "TI"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "4190914c-4f11-47e1-ab02-dd7e5e0245ee"],
 " measures the failure to commute; the anticommutator ",
 Cell[BoxData[
  RowBox[{
   RowBox[{"{", 
    StyleBox["A", "TI"]}], ",", 
   RowBox[{
    StyleBox["B", "TI"], "}", "=", 
    StyleBox["A", "TI"], 
    StyleBox["B", "TI"], "+", 
    StyleBox["B", "TI"], 
    StyleBox["A", "TI"]}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "dd97110d-cc7b-4695-8f85-6a2bfd978043"],
 ". Together they split the product, ",
 Cell[BoxData[
  RowBox[{
   StyleBox["A", "TI"], 
   StyleBox["B", "TI"], "=", 
   FractionBox["1", "2"], 
   StyleBox["(",
    SpanMaxSize->1], 
   RowBox[{
    RowBox[{"{", 
     StyleBox["A", "TI"]}], ",", 
    RowBox[{
     StyleBox["B", "TI"], "}", "+", 
     StyleBox["[",
      SpanMaxSize->1], 
     RowBox[{
      StyleBox["A", "TI"], ",", 
      StyleBox["B", "TI"]}], 
     StyleBox["]",
      SpanMaxSize->1]}]}], 
   StyleBox[")",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "7f2dfe8b-e25d-445f-a66f-97e486b32cb6"],
 "."
}], "Text",ExpressionUUID->"7759a0a4-84ac-4bcd-ad3c-1ddd92e9350f"],

Cell[TextData[{
 StyleBox["WL",
  FontWeight->"Bold"],
 " : the commutator is ",
 Cell[BoxData[
  RowBox[{
   StyleBox["A", "TI"], 
   StyleBox["B", "TI"], "-", 
   StyleBox["B", "TI"], 
   StyleBox["A", "TI"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "4e188aa0-42ef-4a58-95b3-6a44897ccd74"],
 " on two general operators."
}], "Text",ExpressionUUID->"eee433b6-ba5c-425a-a4fd-17b68c2d5a7b"],

Cell[BoxData[
 RowBox[{"With", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{"a", " ", "=", " ", 
      RowBox[{"Array", "[", 
       RowBox[{"\[FormalA]", ",", " ", 
        RowBox[{"{", 
         RowBox[{"2", ",", " ", "2"}], "}"}]}], "]"}]}], ",", " ", 
     RowBox[{"b", " ", "=", " ", 
      RowBox[{"Array", "[", 
       RowBox[{"\[FormalB]", ",", " ", 
        RowBox[{"{", 
         RowBox[{"2", ",", " ", "2"}], "}"}]}], "]"}]}]}], "}"}], ",", " ", 
   RowBox[{
    RowBox[{"a", " ", ".", " ", "b"}], " ", "-", " ", 
    RowBox[{"b", " ", ".", " ", "a"}]}]}], "]"}]], "Input",
 CellLabel->
  "In[34]:= ",ExpressionUUID->"dd89e1b3-9380-4b60-979c-4dd971c4a0c0"],

Cell[TextData[{
 "The anticommutator is ",
 Cell[BoxData[
  RowBox[{
   StyleBox["A", "TI"], 
   StyleBox["B", "TI"], "+", 
   StyleBox["B", "TI"], 
   StyleBox["A", "TI"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "795be681-4f92-49ba-a7d1-e386cb499dc4"],
 "."
}], "Text",ExpressionUUID->"03c1a205-81a8-4679-8c3d-8336eb6a4c68"],

Cell[BoxData[
 RowBox[{"With", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{"a", " ", "=", " ", 
      RowBox[{"Array", "[", 
       RowBox[{"\[FormalA]", ",", " ", 
        RowBox[{"{", 
         RowBox[{"2", ",", " ", "2"}], "}"}]}], "]"}]}], ",", " ", 
     RowBox[{"b", " ", "=", " ", 
      RowBox[{"Array", "[", 
       RowBox[{"\[FormalB]", ",", " ", 
        RowBox[{"{", 
         RowBox[{"2", ",", " ", "2"}], "}"}]}], "]"}]}]}], "}"}], ",", " ", 
   RowBox[{
    RowBox[{"a", " ", ".", " ", "b"}], " ", "+", " ", 
    RowBox[{"b", " ", ".", " ", "a"}]}]}], "]"}]], "Input",
 CellLabel->
  "In[35]:= ",ExpressionUUID->"a84605b4-6a1e-4345-a282-8c9a1e90743d"],

Cell[TextData[{
 "The Wolfram Language also provides them as built-ins (passing ",
 Cell[BoxData["Dot"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "ab1c870f-b9ae-49ba-b68c-f307bfc9729e"],
 " as the product). The commutator:"
}], "Text",ExpressionUUID->"d25a10bc-6330-404d-a3b3-2d63af5f8c7a"],

Cell[BoxData[
 RowBox[{"With", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{"a", " ", "=", " ", 
      RowBox[{"Array", "[", 
       RowBox[{"\[FormalA]", ",", " ", 
        RowBox[{"{", 
         RowBox[{"2", ",", " ", "2"}], "}"}]}], "]"}]}], ",", " ", 
     RowBox[{"b", " ", "=", " ", 
      RowBox[{"Array", "[", 
       RowBox[{"\[FormalB]", ",", " ", 
        RowBox[{"{", 
         RowBox[{"2", ",", " ", "2"}], "}"}]}], "]"}]}]}], "}"}], ",", " ", 
   RowBox[{"Commutator", "[", 
    RowBox[{"a", ",", " ", "b", ",", " ", "Dot"}], "]"}]}], "]"}]], "Input",
 CellLabel->
  "In[36]:= ",ExpressionUUID->"4d53df69-a857-4f22-b5b9-d411e9399e63"],

Cell["and the anticommutator:", "Text",ExpressionUUID->"5a67884e-8955-4c5b-a4b3-b4043248b162"],

Cell[BoxData[
 RowBox[{"With", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{"a", " ", "=", " ", 
      RowBox[{"Array", "[", 
       RowBox[{"\[FormalA]", ",", " ", 
        RowBox[{"{", 
         RowBox[{"2", ",", " ", "2"}], "}"}]}], "]"}]}], ",", " ", 
     RowBox[{"b", " ", "=", " ", 
      RowBox[{"Array", "[", 
       RowBox[{"\[FormalB]", ",", " ", 
        RowBox[{"{", 
         RowBox[{"2", ",", " ", "2"}], "}"}]}], "]"}]}]}], "}"}], ",", " ", 
   RowBox[{"Anticommutator", "[", 
    RowBox[{"a", ",", " ", "b", ",", " ", "Dot"}], "]"}]}], "]"}]], "Input",
 CellLabel->
  "In[37]:= ",ExpressionUUID->"8cfbff44-b403-4b45-abe5-70f294dde5c3"],

Cell[TextData[{
 StyleBox["QF",
  FontWeight->"Bold"],
 " : here the operands are ",
 StyleBox["operators", "TI"],
 ", so the results are again operators, not arrays. The built-in ",
 Cell[BoxData["Commutator"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "92bbacdd-a144-4950-ba1f-e3f6f7aab23c"],
 " reduces directly on QuantumOperators (QF teaches it the operator product), \
and returns a ",
 Cell[BoxData["QuantumOperator"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "d1d107ef-62ab-4e3b-8086-a8b2eebd8a3a"],
 "."
}], "Text",ExpressionUUID->"d8f6df60-d612-4618-ae51-cdb00c5bf3e1"],

Cell[BoxData[
 RowBox[{"With", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{"a", " ", "=", " ", 
      RowBox[{"QuantumOperator", "[", 
       RowBox[{"Array", "[", 
        RowBox[{"\[FormalA]", ",", " ", 
         RowBox[{"{", 
          RowBox[{"2", ",", " ", "2"}], "}"}]}], "]"}], "]"}]}], ",", " ", 
     RowBox[{"b", " ", "=", " ", 
      RowBox[{"QuantumOperator", "[", 
       RowBox[{"Array", "[", 
        RowBox[{"\[FormalB]", ",", " ", 
         RowBox[{"{", 
          RowBox[{"2", ",", " ", "2"}], "}"}]}], "]"}], "]"}]}]}], "}"}], ",",
    "\n", " ", 
   RowBox[{"Commutator", "[", 
    RowBox[{"a", ",", " ", "b"}], "]"}]}], "]"}]], "Input",
 CellLabel->
  "In[38]:= ",ExpressionUUID->"b6609d77-fc80-49ab-9dad-873c686e5930"],

Cell[TextData[{
 "The built-in ",
 Cell[BoxData["Anticommutator"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "6b5748a5-fb38-42e6-ac54-10554c24fac1"],
 " does ",
 StyleBox["not", "TI"],
 " reduce on operators, so write it as ",
 Cell[BoxData[
  RowBox[{
   RowBox[{"a", " ", "@", " ", "b"}], " ", "+", " ", 
   RowBox[{"b", " ", "@", " ", "a"}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "3055c00d-49b3-4bb8-986f-038dcfbb3dee"],
 ", with ",
 Cell[BoxData["@"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "48dc41fe-3ffa-4f70-a722-bb62282caf1e"],
 " the operator product."
}], "Text",ExpressionUUID->"31cb5d26-c51f-462a-adcd-005f2d32b045"],

Cell[BoxData[
 RowBox[{"With", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{"a", " ", "=", " ", 
      RowBox[{"QuantumOperator", "[", 
       RowBox[{"Array", "[", 
        RowBox[{"\[FormalA]", ",", " ", 
         RowBox[{"{", 
          RowBox[{"2", ",", " ", "2"}], "}"}]}], "]"}], "]"}]}], ",", " ", 
     RowBox[{"b", " ", "=", " ", 
      RowBox[{"QuantumOperator", "[", 
       RowBox[{"Array", "[", 
        RowBox[{"\[FormalB]", ",", " ", 
         RowBox[{"{", 
          RowBox[{"2", ",", " ", "2"}], "}"}]}], "]"}], "]"}]}]}], "}"}], ",",
    "\n", " ", 
   RowBox[{
    RowBox[{"a", " ", "@", " ", "b"}], " ", "+", " ", 
    RowBox[{"b", " ", "@", " ", "a"}]}]}], "]"}]], "Input",
 CellLabel->
  "In[39]:= ",ExpressionUUID->"c4cf03f9-2238-49bb-ae41-820197d5c26e"],

Cell[TextData[{
 "An operator does far more than carry a matrix. Take the concrete Pauli case \
",
 Cell[BoxData[
  RowBox[{
   StyleBox["[",
    SpanMaxSize->1], 
   RowBox[{
    StyleBox["X", "TI"], ",", 
    StyleBox["Y", "TI"]}], 
   StyleBox["]",
    SpanMaxSize->1], "=", "2", 
   StyleBox["i", "TI"], 
   StyleBox["Z", "TI"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "07bd99af-396d-47e5-b96b-b5ffefe60f74"],
 ": the commutator is itself an operator object, shown here as its summary \
box."
}], "Text",ExpressionUUID->"933abaa3-a452-4a4b-b145-cd6f9ee9e61e"],

Cell[BoxData[
 RowBox[{"c", " ", "=", " ", 
  RowBox[{"Commutator", "[", 
   RowBox[{
    RowBox[{"QuantumOperator", "[", "\"\<X\>\"", "]"}], ",", " ", 
    RowBox[{"QuantumOperator", "[", "\"\<Y\>\"", "]"}]}], "]"}]}]], "Input",
 CellLabel->
  "In[40]:= ",ExpressionUUID->"6510e760-c7e4-4cc0-9085-a32d28ce74ea"],

Cell[TextData[{
 "It acts on a state, sending ",
 Cell[BoxData[
  TemplateBox[{"0"},
   "Ket"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "2903ba2c-7373-475a-9abc-c6e4c6b18803"],
 " to ",
 Cell[BoxData[
  RowBox[{"2", 
   StyleBox["i", "TI"], 
   TemplateBox[{"0"},
    "Ket"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "6c2f942f-ee63-4ae7-9d48-5712322b36c0"],
 "."
}], "Text",ExpressionUUID->"a0425319-ba71-46a2-ba52-48913714607d"],

Cell[BoxData[
 RowBox[{"c", "[", 
  RowBox[{"QuantumState", "[", "\"\<0\>\"", "]"}], "]"}]], "Input",
 CellLabel->
  "In[41]:= ",ExpressionUUID->"c7f36fae-ddd4-40c9-9703-11a3ec5010be"],

Cell[TextData[{
 "It answers whether it is Hermitian (a commutator of Hermitian operators is \
anti-Hermitian, so ",
 Cell[BoxData["False"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "67ca0e8e-c7fe-4338-88da-3176d04d7bab"],
 ")."
}], "Text",ExpressionUUID->"3e966167-3e0e-4857-bdce-2a2a7d5b5046"],

Cell[BoxData[
 RowBox[{"c", "[", "\"\<HermitianQ\>\"", "]"}]], "Input",
 CellLabel->
  "In[42]:= ",ExpressionUUID->"f373961d-ccf9-4ef1-91d5-a3d78cfe9693"],

Cell[TextData[{
 "Its eigenvalues are imaginary, ",
 Cell[BoxData[
  RowBox[{"\[PlusMinus]", "2", 
   StyleBox["i", "TI"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "cc656e03-93d5-4091-b924-db2df774c17f"],
 "."
}], "Text",ExpressionUUID->"eb1f61c8-5d1a-4455-8fe3-dcbde3b54b09"],

Cell[BoxData[
 RowBox[{"c", "[", "\"\<Eigenvalues\>\"", "]"}]], "Input",
 CellLabel->
  "In[43]:= ",ExpressionUUID->"4f6176f4-ed48-4302-bf86-fb212cb99a23"],

Cell[TextData[{
 "And only last of all does it hand back its matrix, ",
 Cell[BoxData[
  RowBox[{"2", 
   StyleBox["i", "TI"], 
   SubscriptBox[
    StyleBox["\[Sigma]", "TI"], 
    StyleBox["z", "TI"]]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "3fe9cab7-7621-4fa2-ac4a-6646de2c8990"],
 "."
}], "Text",ExpressionUUID->"91171fb4-3931-4b32-913a-e60b98d0f7a0"],

Cell[BoxData[
 RowBox[{
  RowBox[{"c", "[", "\"\<Matrix\>\"", "]"}], " ", "//", " ", 
  "Normal"}]], "Input",
 CellLabel->
  "In[44]:= ",ExpressionUUID->"32876492-cadc-4562-aa8d-53623f52a254"],

Cell["\<\
The matrix is one view of a much richer object; that is the difference \
between QuantumFramework and bare linear algebra.\
\>", "Text",ExpressionUUID->"c6866708-be7d-4e7f-b3c6-8ee856898967"],

Cell["\<\
2.2 [BSc] How do I build the Pauli operators and verify their algebra \
(Levi-Civita product rule)?\
\>", "Subsection",ExpressionUUID->"68ddfef2-52ac-46c7-a792-7f6425a9aa12"],

Cell[TextData[{
 "The Pauli operators close under commutation, ",
 Cell[BoxData[
  RowBox[{
   StyleBox["[",
    SpanMaxSize->1], 
   RowBox[{
    SubscriptBox[
     StyleBox["\[Sigma]", "TI"], 
     StyleBox["i", "TI"]], ",", 
    SubscriptBox[
     StyleBox["\[Sigma]", "TI"], 
     StyleBox["j", "TI"]]}], 
   StyleBox["]",
    SpanMaxSize->1], "=", "2", 
   StyleBox["i", "TI"], " ", 
   SubscriptBox[
    StyleBox["\[CurlyEpsilon]", "TI"], 
    StyleBox[
     RowBox[{"i", "j", "k"}], "TI"]], " ", 
   SubscriptBox[
    StyleBox["\[Sigma]", "TI"], 
    StyleBox["k", "TI"]]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "6b816aa4-f67e-4808-8f04-4ff259e9f7db"],
 "."
}], "Text",ExpressionUUID->"21ab0c20-2127-41b1-af3e-c57358cf8276"],

Cell[TextData[{
 StyleBox["WL",
  FontWeight->"Bold"],
 " : assemble the Pauli vector and check all nine commutators at once against \
the Levi-Civita tensor."
}], "Text",ExpressionUUID->"8a9e811f-2928-4a1c-9c2f-c844e3cb6c4f"],

Cell[BoxData[
 RowBox[{"With", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"\[Sigma]", " ", "=", " ", 
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{"PauliMatrix", "[", "j", "]"}], ",", " ", 
       RowBox[{"{", 
        RowBox[{"j", ",", " ", "3"}], "}"}]}], "]"}]}], "}"}], ",", "\n", " ", 
   RowBox[{
    RowBox[{"Outer", "[", 
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{"#1", " ", ".", " ", "#2"}], " ", "-", " ", 
        RowBox[{"#2", " ", ".", " ", "#1"}]}], " ", "&"}], ",", " ", 
      "\[Sigma]", ",", " ", "\[Sigma]", ",", " ", "1"}], "]"}], " ", "==", 
    "\n", "  ", 
    RowBox[{"2", " ", "I", " ", 
     RowBox[{"TensorContract", "[", 
      RowBox[{
       RowBox[{"TensorProduct", "[", 
        RowBox[{
         RowBox[{"LeviCivitaTensor", "[", "3", "]"}], ",", " ", "\[Sigma]"}], 
        "]"}], ",", " ", 
       RowBox[{"{", 
        RowBox[{"3", ",", " ", "4"}], "}"}]}], "]"}]}]}]}], "]"}]], "Input",
 CellLabel->
  "In[45]:= ",ExpressionUUID->"23300141-eb46-450e-9fe9-47ef3a66ebbe"],

Cell[TextData[{
 StyleBox["QF",
  FontWeight->"Bold"],
 " : the same check staying at the ",
 StyleBox["operator", "TI"],
 " level. Each ",
 Cell[BoxData[
  RowBox[{"Commutator", "[", 
   RowBox[{"#1", ",", " ", "#2"}], "]"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "bf5dca8a-edee-4777-9691-b27fd0888d03"],
 " is an operator, and every entry is compared directly to the operator ",
 Cell[BoxData[
  RowBox[{"2", 
   StyleBox["i", "TI"], " ", 
   SubscriptBox[
    StyleBox["\[CurlyEpsilon]", "TI"], 
    StyleBox[
     RowBox[{"i", "j", "k"}], "TI"]], 
   SubscriptBox[
    StyleBox["\[Sigma]", "TI"], 
    StyleBox["k", "TI"]]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "088e6955-e034-4c46-8a66-9ca86cb90d60"],
 ", with no matrices extracted."
}], "Text",ExpressionUUID->"8d2ae256-c428-4b9c-ab19-b8678c29c673"],

Cell[BoxData[
 RowBox[{"With", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"\[Sigma]", " ", "=", " ", 
     RowBox[{"QuantumOperator", " ", "/@", " ", 
      RowBox[{"{", 
       RowBox[{"\"\<X\>\"", ",", " ", "\"\<Y\>\"", ",", " ", "\"\<Z\>\""}], 
       "}"}]}]}], "}"}], ",", " ", 
   RowBox[{"{", 
    RowBox[{"com", " ", "=", "\n", "   ", 
     RowBox[{"Outer", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"Commutator", "[", 
         RowBox[{"#1", ",", " ", "#2"}], "]"}], " ", "&"}], ",", " ", 
       "\[Sigma]", ",", " ", "\[Sigma]", ",", " ", "1"}], "]"}]}], "}"}], ",",
    "\n", " ", 
   RowBox[{"Table", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"com", "[", 
       RowBox[{"[", 
        RowBox[{"i", ",", " ", "j"}], "]"}], "]"}], " ", "==", " ", 
      RowBox[{"2", " ", "I", " ", 
       RowBox[{"Sum", "[", 
        RowBox[{
         RowBox[{
          RowBox[{
           RowBox[{"LeviCivitaTensor", "[", "3", "]"}], "[", 
           RowBox[{"[", 
            RowBox[{"i", ",", " ", "j", ",", " ", "k"}], "]"}], "]"}], " ", 
          RowBox[{"\[Sigma]", "[", 
           RowBox[{"[", "k", "]"}], "]"}]}], ",", " ", 
         RowBox[{"{", 
          RowBox[{"k", ",", " ", "3"}], "}"}]}], "]"}]}]}], ",", " ", 
     RowBox[{"{", 
      RowBox[{"i", ",", " ", "3"}], "}"}], ",", " ", 
     RowBox[{"{", 
      RowBox[{"j", ",", " ", "3"}], "}"}]}], "]"}]}], "]"}]], "Input",
 CellLabel->
  "In[46]:= ",ExpressionUUID->"5e7ba3d5-4945-49aa-abd5-b2a1ef5be4fa"],

Cell[TextData[{
 "The WL line returns ",
 Cell[BoxData["True"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "20af1a9f-2daf-4b56-98f3-59796a86a91f"],
 " and the QF line returns a ",
 Cell[BoxData[
  RowBox[{"3", "\[Times]", "3"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "4d0ab565-31a1-47be-aa7e-0d1ae9279db1"],
 " table of ",
 Cell[BoxData["True"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "532b3a67-f373-4733-ae7d-65e239d15a43"],
 ": every commutator operator ",
 Cell[BoxData[
  RowBox[{
   StyleBox["[",
    SpanMaxSize->1], 
   RowBox[{
    SubscriptBox[
     StyleBox["\[Sigma]", "TI"], 
     StyleBox["i", "TI"]], ",", 
    SubscriptBox[
     StyleBox["\[Sigma]", "TI"], 
     StyleBox["j", "TI"]]}], 
   StyleBox["]",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "4eaf8394-3085-4333-90ae-dd9275e71f9b"],
 " equals the operator ",
 Cell[BoxData[
  RowBox[{"2", 
   StyleBox["i", "TI"], " ", 
   SubscriptBox[
    StyleBox["\[CurlyEpsilon]", "TI"], 
    StyleBox[
     RowBox[{"i", "j", "k"}], "TI"]], 
   SubscriptBox[
    StyleBox["\[Sigma]", "TI"], 
    StyleBox["k", "TI"]]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "46e6168c-aaf2-45ec-9013-4573e9ececf1"],
 " (the diagonal ",
 Cell[BoxData[
  RowBox[{
   StyleBox["[",
    SpanMaxSize->1], 
   RowBox[{
    SubscriptBox[
     StyleBox["\[Sigma]", "TI"], 
     StyleBox["i", "TI"]], ",", 
    SubscriptBox[
     StyleBox["\[Sigma]", "TI"], 
     StyleBox["i", "TI"]]}], 
   StyleBox["]",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "57c3904b-0f22-4ff6-b64d-1c1ac8cfcaa1"],
 " vanishing), so the whole ",
 Cell[BoxData[
  RowBox[{"\|01d530", "\|01d532", 
   StyleBox["(",
    SpanMaxSize->1], "2", 
   StyleBox[")",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "534a5cc5-d0ba-46f3-b5bf-3eb6afa5facf"],
 " algebra is verified through operator equality, never touching a matrix."
}], "Text",ExpressionUUID->"acf5522b-79a6-4e13-a592-1faee3160c89"],

Cell["2.3a [BSc] How do I test that an operator is Hermitian?", "Subsection",ExpressionUUID->"6daf165c-63d6-4c0a-ac6d-20be8237dbf0"],

Cell[TextData[{
 "An operator is Hermitian when it equals its own conjugate transpose, ",
 Cell[BoxData[
  RowBox[{
   StyleBox["A", "TI"], "=", 
   SuperscriptBox[
    StyleBox["A", "TI"], "\[Dagger]"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "ac6e1c48-3bd0-4323-bf5d-467f78071fc4"],
 "."
}], "Text",ExpressionUUID->"6eb1f280-2f81-42ee-b9cd-67d829ae2daa"],

Cell[TextData[{
 StyleBox["WL",
  FontWeight->"Bold"],
 " : test Hermiticity directly."
}], "Text",ExpressionUUID->"212650c2-c8d2-487c-86b5-46f1c32cca4d"],

Cell[BoxData[
 RowBox[{"HermitianMatrixQ", "[", 
  RowBox[{"PauliMatrix", "[", "1", "]"}], "]"}]], "Input",
 CellLabel->
  "In[47]:= ",ExpressionUUID->"42d71683-0b51-4cca-a5af-ce5fdaa7ef09"],

Cell[TextData[{
 StyleBox["QF",
  FontWeight->"Bold"],
 " : the operator answers ",
 Cell[BoxData["\"\<HermitianQ\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "821aa118-aea9-490e-94c9-f0fe152215d0"],
 "."
}], "Text",ExpressionUUID->"11a86f5e-bd5a-41ee-8a31-8f3c2bbb06e6"],

Cell[BoxData[
 RowBox[{
  RowBox[{"QuantumOperator", "[", "\"\<X\>\"", "]"}], 
  "[", "\"\<HermitianQ\>\"", "]"}]], "Input",
 CellLabel->
  "In[48]:= ",ExpressionUUID->"6572ae5a-dc22-4e0d-aa27-0d8670ea40d1"],

Cell[TextData[{
 "Both return ",
 Cell[BoxData["True"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "bf6ec6e5-7818-48bf-bb0e-9fc476f2c9c8"],
 ": ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["\[Sigma]", "TI"], 
   StyleBox["x", "TI"]]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "6aeddd93-df10-49d0-8854-4512be6dffa2"],
 " is Hermitian."
}], "Text",ExpressionUUID->"5669b0ac-41a6-47d2-aeac-2c1433b635d9"],

Cell["2.3b [BSc] Why must an observable be Hermitian?", "Subsection",ExpressionUUID->"63ffce9b-4f47-4803-b67c-0ebc3253e4f8"],

Cell["\<\
Measurement outcomes are real numbers, and the possible outcomes of an \
observable are its eigenvalues. Hermiticity is exactly the condition that \
forces those eigenvalues to be real, which is why every observable is \
represented by a Hermitian operator.\
\>", "Text",ExpressionUUID->"501d9ba5-ee29-408a-90dd-b9a7785f0426"],

Cell[TextData[{
 StyleBox["WL",
  FontWeight->"Bold"],
 " : a generic Hermitian matrix has real eigenvalues."
}], "Text",ExpressionUUID->"c676911b-40a6-4974-94db-2ad0dee6cd6e"],

Cell[BoxData[
 RowBox[{"FullSimplify", "[", 
  RowBox[{
   RowBox[{
    RowBox[{"Eigenvalues", "[", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"a1", ",", " ", 
         RowBox[{"a2", " ", "+", " ", 
          RowBox[{"I", " ", "a3"}]}]}], "}"}], ",", " ", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"a2", " ", "-", " ", 
          RowBox[{"I", " ", "a3"}]}], ",", " ", "a4"}], "}"}]}], "}"}], "]"}],
     " ", "\[Element]", " ", "Reals"}], ",", "\n", " ", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{
     "a1", " ", "|", " ", "a2", " ", "|", " ", "a3", " ", "|", " ", "a4"}], 
     ")"}], " ", "\[Element]", " ", "Reals"}]}], "]"}]], "Input",
 CellLabel->
  "In[49]:= ",ExpressionUUID->"df5802e8-6ec8-42b4-9a92-b71c97732d0b"],

Cell[TextData[{
 StyleBox["QF",
  FontWeight->"Bold"],
 " : the same, read off the operator's ",
 Cell[BoxData["\"\<Eigenvalues\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "b5f69e4f-89d9-4aa0-bc5b-99bc763a1468"],
 "."
}], "Text",ExpressionUUID->"bfb5a3f1-3688-4369-a3ea-5d333b88b222"],

Cell[BoxData[
 RowBox[{"FullSimplify", "[", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"QuantumOperator", "[", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"a1", ",", " ", 
          RowBox[{"a2", " ", "+", " ", 
           RowBox[{"I", " ", "a3"}]}]}], "}"}], ",", " ", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"a2", " ", "-", " ", 
           RowBox[{"I", " ", "a3"}]}], ",", " ", "a4"}], "}"}]}], "}"}], 
      "]"}], "[", "\"\<Eigenvalues\>\"", "]"}], " ", "\[Element]", " ", 
    "Reals"}], ",", "\n", " ", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{
     "a1", " ", "|", " ", "a2", " ", "|", " ", "a3", " ", "|", " ", "a4"}], 
     ")"}], " ", "\[Element]", " ", "Reals"}]}], "]"}]], "Input",
 CellLabel->
  "In[50]:= ",ExpressionUUID->"9fb6c1ae-2610-4d6a-953d-fabeff7f0a3a"],

Cell[TextData[{
 "Both return ",
 Cell[BoxData["True"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "4e4b118a-bebd-4285-b6ff-d8db5e22dd5b"],
 ": every Hermitian operator has a real spectrum, so its measurement outcomes \
are real. That real-spectrum guarantee is the physical reason observables \
must be Hermitian."
}], "Text",ExpressionUUID->"08be2bad-0860-437f-98af-3c9e9bbba7a1"],

Cell["\<\
2.4 [BSc] How do I compute eigenvalues and eigenvectors and form the spectral \
decomposition?\
\>", "Subsection",ExpressionUUID->"e5fe5933-09fc-48a0-b185-f0a69e42edf6"],

Cell[TextData[{
 "Every observable is its own spectral sum, ",
 Cell[BoxData[
  RowBox[{
   StyleBox["A", "TI"], "=", 
   RowBox[{
    UnderscriptBox["\[Sum]", 
     StyleBox["a", "TI"],
     LimitsPositioning->False], 
    RowBox[{
     StyleBox["a", "TI"], 
     TemplateBox[{
       StyleBox["a", "TI"]},
      "Ket"], 
     TemplateBox[{
       StyleBox["a", "TI"]},
      "Bra"]}]}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "d8523d0f-3458-4872-a8f2-60516a896871"],
 ". The built-in ",
 Cell[BoxData["EigenvalueDecomposition"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "e8a17f79-1701-4e2b-bce1-49cff73ff832"],
 " packages exactly this: it returns ",
 Cell[BoxData[
  RowBox[{
   RowBox[{"{", 
    StyleBox["S", "TI"]}], ",", 
   RowBox[{
    StyleBox["D", "TI"], "}"}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "60778c44-5979-405b-85ac-1d441dd7d925"],
 " with the eigenvectors as the columns of ",
 Cell[BoxData[
  StyleBox["S", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "6cf43d7e-d35b-43f2-97af-9e6134b485bd"],
 ", the eigenvalues on the diagonal of ",
 Cell[BoxData[
  StyleBox["D", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "0b3c1b67-e0a8-40e1-83f8-5afca57d8123"],
 ", and ",
 Cell[BoxData[
  RowBox[{
   StyleBox["A", "TI"], "=", 
   StyleBox["S", "TI"], " ", 
   StyleBox["D", "TI"], " ", 
   SuperscriptBox[
    StyleBox["S", "TI"], 
    RowBox[{"-", "1"}]]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "529aaf9a-9b72-45a0-9829-3d66d8db1b7d"],
 "."
}], "Text",ExpressionUUID->"8e56118d-962c-4a44-a989-67638dc4d875"],

Cell[TextData[{
 StyleBox["WL",
  FontWeight->"Bold"],
 " : compute the decomposition once and bind it."
}], "Text",ExpressionUUID->"f5b8a530-1c34-429e-a036-c0f387c2c90b"],

Cell[BoxData[
 RowBox[{
  RowBox[{"evd", " ", "=", " ", 
   RowBox[{"EigenvalueDecomposition", "[", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"a1", ",", " ", 
        RowBox[{"a2", " ", "+", " ", 
         RowBox[{"I", " ", "a3"}]}]}], "}"}], ",", " ", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"a2", " ", "-", " ", 
         RowBox[{"I", " ", "a3"}]}], ",", " ", "a4"}], "}"}]}], "}"}], 
    "]"}]}], ";"}]], "Input",
 CellLabel->
  "In[51]:= ",ExpressionUUID->"e906a4fc-4ffc-43fe-8698-bb28d4bee22e"],

Cell[TextData[{
 "The eigenvalues are the diagonal of ",
 Cell[BoxData[
  StyleBox["D", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "be471110-4fa3-47c1-8c1e-b0b649848ab1"],
 "."
}], "Text",ExpressionUUID->"782b88b9-ac08-496b-a195-08ac7445b93e"],

Cell[BoxData[
 RowBox[{"Diagonal", "[", 
  RowBox[{"evd", "[", 
   RowBox[{"[", "2", "]"}], "]"}], "]"}]], "Input",
 CellLabel->
  "In[52]:= ",ExpressionUUID->"1c357e68-9308-457a-a053-49ab5d7a6cbf"],

Cell[TextData[{
 "The eigenvectors are the columns of ",
 Cell[BoxData[
  StyleBox["S", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "0e62e081-67c7-45ea-a7ff-79b8e654ad0b"],
 " (rows of its transpose)."
}], "Text",ExpressionUUID->"aaff5a1f-100a-4511-9b35-a6169fcb9cac"],

Cell[BoxData[
 RowBox[{"Transpose", "[", 
  RowBox[{"evd", "[", 
   RowBox[{"[", "1", "]"}], "]"}], "]"}]], "Input",
 CellLabel->
  "In[53]:= ",ExpressionUUID->"bfb10cc8-4354-43d9-b4a0-a8634a0a36d4"],

Cell[TextData[{
 "And the reconstruction ",
 Cell[BoxData[
  RowBox[{
   StyleBox["A", "TI"], "=", 
   StyleBox["S", "TI"], " ", 
   StyleBox["D", "TI"], " ", 
   SuperscriptBox[
    StyleBox["S", "TI"], 
    RowBox[{"-", "1"}]]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "6b0e09d9-add4-41ae-8d1d-52a95576f84e"],
 " holds."
}], "Text",ExpressionUUID->"64516cd7-b5d1-4161-9bd6-d1812251734f"],

Cell[BoxData[
 RowBox[{"FullSimplify", "[", 
  RowBox[{
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"a1", ",", " ", 
        RowBox[{"a2", " ", "+", " ", 
         RowBox[{"I", " ", "a3"}]}]}], "}"}], ",", " ", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"a2", " ", "-", " ", 
         RowBox[{"I", " ", "a3"}]}], ",", " ", "a4"}], "}"}]}], "}"}], " ", "==",
     " ", 
    RowBox[{
     RowBox[{"evd", "[", 
      RowBox[{"[", "1", "]"}], "]"}], " ", ".", " ", 
     RowBox[{"evd", "[", 
      RowBox[{"[", "2", "]"}], "]"}], " ", ".", " ", 
     RowBox[{"Inverse", "[", 
      RowBox[{"evd", "[", 
       RowBox[{"[", "1", "]"}], "]"}], "]"}]}]}], ",", "\n", " ", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{
     "a1", " ", "|", " ", "a2", " ", "|", " ", "a3", " ", "|", " ", "a4"}], 
     ")"}], " ", "\[Element]", " ", "Reals"}]}], "]"}]], "Input",
 CellLabel->
  "In[54]:= ",ExpressionUUID->"92dc5865-b132-4091-afd9-9d5fdd7ef62c"],

Cell[TextData[{
 StyleBox["QF",
  FontWeight->"Bold"],
 " : keep it in the object model. The operator, shown as its summary box."
}], "Text",ExpressionUUID->"29de3e15-88d5-4410-8120-eb088d53b29c"],

Cell[BoxData[
 RowBox[{"qo", " ", "=", " ", 
  RowBox[{"QuantumOperator", "[", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"a1", ",", " ", 
       RowBox[{"a2", " ", "+", " ", 
        RowBox[{"I", " ", "a3"}]}]}], "}"}], ",", " ", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"a2", " ", "-", " ", 
        RowBox[{"I", " ", "a3"}]}], ",", " ", "a4"}], "}"}]}], "}"}], 
   "]"}]}]], "Input",
 CellLabel->
  "In[55]:= ",ExpressionUUID->"ac1e8f67-39e6-40e5-b71a-73a977410e31"],

Cell["It hands back its eigenvalues,", "Text",ExpressionUUID->"32086f81-a08c-4cf7-a7d4-226f61ea3b7f"],

Cell[BoxData[
 RowBox[{"qo", "[", "\"\<Eigenvalues\>\"", "]"}]], "Input",
 CellLabel->
  "In[56]:= ",ExpressionUUID->"efa65e47-a7b7-4f72-b73d-55fadbf904be"],

Cell["its eigenvectors,", "Text",ExpressionUUID->"256b5572-c323-4de5-bb78-8e0f8cf22e25"],

Cell[BoxData[
 RowBox[{"qo", "[", "\"\<Eigenvectors\>\"", "]"}]], "Input",
 CellLabel->
  "In[57]:= ",ExpressionUUID->"e19f87c5-ae7b-4e47-afe6-b01e6d229b41"],

Cell[TextData[{
 "and ",
 Cell[BoxData["\"\<Diagonalize\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "cfffc80b-fada-4499-bbbd-5fed1edbfb77"],
 " returns the ",
 StyleBox["operator", "TI"],
 " expressed in its own eigenbasis, a ",
 Cell[BoxData["QuantumOperator"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "27caa69d-84df-4171-b145-5ebfa5efa146"],
 " whose matrix is diagonal with the eigenvalues on it."
}], "Text",ExpressionUUID->"cf021c21-bfd3-4c17-bb73-282375bf3d76"],

Cell[BoxData[
 RowBox[{"qo", "[", "\"\<Diagonalize\>\"", "]"}]], "Input",
 CellLabel->
  "In[58]:= ",ExpressionUUID->"b7c5cf86-6ee1-461f-a13d-28b34f55cb4f"],

Cell[TextData[{
 "Both report the same two real eigenvalues ",
 Cell[BoxData[
  RowBox[{
   FractionBox["1", "2"], 
   StyleBox["(",
    FontSize->1.2 Inherited], 
   SubscriptBox[
    StyleBox["a", "TI"], "1"], "+", 
   SubscriptBox[
    StyleBox["a", "TI"], "4"], "\[PlusMinus]", 
   SqrtBox[
    RowBox[{
     SuperscriptBox[
      RowBox[{
       StyleBox["(",
        SpanMaxSize->1], 
       RowBox[{
        SubscriptBox[
         StyleBox["a", "TI"], "1"], "-", 
        SubscriptBox[
         StyleBox["a", "TI"], "4"]}], 
       StyleBox[")",
        SpanMaxSize->1]}], "2"], "+", "4", 
     StyleBox["(",
      SpanMaxSize->1], 
     RowBox[{
      SubsuperscriptBox[
       StyleBox["a", "TI"], "2", "2"], "+", 
      SubsuperscriptBox[
       StyleBox["a", "TI"], "3", "2"]}], 
     StyleBox[")",
      SpanMaxSize->1]}]], 
   StyleBox[")",
    FontSize->1.2 Inherited]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "f80e85e7-f0f8-41b0-a294-b845730e8957"],
 ". On the WL side ",
 Cell[BoxData["EigenvalueDecomposition"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "e23f888a-e466-4e18-9712-cb5ae29c460a"],
 " reconstructs ",
 Cell[BoxData[
  RowBox[{
   StyleBox["A", "TI"], "=", 
   StyleBox["S", "TI"], 
   StyleBox["D", "TI"], 
   SuperscriptBox[
    StyleBox["S", "TI"], 
    RowBox[{"-", "1"}]]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "45086873-6209-4ecd-a3e4-49108538fbfa"],
 " (for a Hermitian operator the eigenvectors are orthogonal, so normalizing ",
 Cell[BoxData[
  StyleBox["S", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "4d17ad80-42ff-4d57-ae9a-fae724cc363a"],
 " to a unitary ",
 Cell[BoxData[
  StyleBox["U", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "2b936e96-2287-4a2b-830c-369d031167b5"],
 " turns this into the spectral form ",
 Cell[BoxData[
  RowBox[{
   StyleBox["A", "TI"], "=", 
   RowBox[{
    RowBox[{
     StyleBox["U", "TI"], 
     StyleBox["D", "TI"], 
     SuperscriptBox[
      StyleBox["U", "TI"], "\[Dagger]"]}], "=", 
    RowBox[{
     UnderscriptBox["\[Sum]", 
      StyleBox["a", "TI"],
      LimitsPositioning->False], 
     RowBox[{
      StyleBox["a", "TI"], 
      TemplateBox[{
        StyleBox["a", "TI"]},
       "Ket"], 
      TemplateBox[{
        StyleBox["a", "TI"]},
       "Bra"]}]}]}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "58d11961-294b-4e9d-b92d-dfb0c158d9a4"],
 "). On the QF side ",
 Cell[BoxData["\"\<Diagonalize\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "022f3e3e-a494-4f60-a139-2d43e200ca25"],
 " ",
 StyleBox["is", "TI"],
 " that spectral form, the operator already diagonal in its eigenbasis, still \
an object rather than a bare array."
}], "Text",ExpressionUUID->"7049cd5e-83ae-4237-9cc1-d9ed44014553"],

Cell[TextData[{
 "2.5 [BSc] How do I evaluate a function of an operator ",
 Cell[BoxData[
  RowBox[{
   StyleBox["f", "TI"], 
   StyleBox["(",
    SpanMaxSize->1], 
   OverscriptBox[
    StyleBox["A", "TI"], "^"], 
   StyleBox[")",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "e3726533-58cf-4809-a227-be95e32db43f"],
 " by functional calculus?"
}], "Subsection",ExpressionUUID->"c52ab7d8-e21f-43ac-abed-1c362429a859"],

Cell[TextData[{
 "Functional calculus defines ",
 Cell[BoxData[
  RowBox[{
   StyleBox["f", "TI"], 
   StyleBox["(",
    SpanMaxSize->1], 
   OverscriptBox[
    StyleBox["A", "TI"], "^"], 
   StyleBox[")",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "c7e377a1-fd4f-4b97-b670-997fc5204ba7"],
 " by letting ",
 Cell[BoxData[
  StyleBox["f", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "e69906cb-93ce-446f-8b64-22b1d899fd05"],
 " act on the eigenvalues in the eigenbasis, ",
 Cell[BoxData[
  RowBox[{
   RowBox[{
    StyleBox["f", "TI"], 
    RowBox[{
     StyleBox["(",
      SpanMaxSize->1], 
     OverscriptBox[
      StyleBox["A", "TI"], "^"], 
     StyleBox[")",
      SpanMaxSize->1]}]}], "=", 
   RowBox[{
    UnderscriptBox["\[Sum]", 
     StyleBox["a", "TI"],
     LimitsPositioning->False], 
    RowBox[{
     StyleBox["f", "TI"], 
     RowBox[{
      StyleBox["(",
       SpanMaxSize->1], 
      StyleBox["a", "TI"], 
      StyleBox[")",
       SpanMaxSize->1]}], 
     TemplateBox[{
       StyleBox["a", "TI"]},
      "Ket"], 
     TemplateBox[{
       StyleBox["a", "TI"]},
      "Bra"]}]}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "565f40a7-527d-43d8-9c7c-953bb73408e2"],
 ". In WL the one-call tool that does exactly this is ",
 Cell[BoxData["MatrixFunction"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "3024d9bf-40c8-47f3-bf7e-b5f610084d45"],
 "."
}], "Text",ExpressionUUID->"e961c61a-6d15-439b-9eeb-705671e8b213"],

Cell[TextData[{
 StyleBox["WL",
  FontWeight->"Bold"],
 " : apply a symbolic ",
 Cell[BoxData[
  StyleBox["f", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "44ce6d72-5e24-4697-88ad-d9752890687a"],
 " to ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["\[Sigma]", "TI"], 
   StyleBox["x", "TI"]]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "54f447bb-6bc4-4171-87b3-6849bf975a84"],
 " directly."
}], "Text",ExpressionUUID->"841ce48a-f3b4-47f8-a0ea-8a914247358a"],

Cell[BoxData[
 RowBox[{"MatrixFunction", "[", 
  RowBox[{"f", ",", " ", 
   RowBox[{"PauliMatrix", "[", "1", "]"}]}], "]"}]], "Input",
 CellLabel->
  "In[59]:= ",ExpressionUUID->"300abd78-fc0b-4ff6-a56d-6c83d8858167"],

Cell[TextData[{
 "The result ",
 Cell[BoxData[
  RowBox[{
   StyleBox["f", "TI"], 
   StyleBox["(",
    SpanMaxSize->1], 
   SubscriptBox[
    StyleBox["\[Sigma]", "TI"], 
    StyleBox["x", "TI"]], 
   StyleBox[")",
    SpanMaxSize->1], "=", 
   FractionBox["1", "2"], "(", GridBox[{
     {
      RowBox[{
       StyleBox["f", "TI"], 
       StyleBox["(",
        SpanMaxSize->1], "1", 
       StyleBox[")",
        SpanMaxSize->1], "+", 
       StyleBox["f", "TI"], 
       StyleBox["(",
        SpanMaxSize->1], 
       RowBox[{"-", "1"}], 
       StyleBox[")",
        SpanMaxSize->1]}], 
      RowBox[{
       StyleBox["f", "TI"], 
       StyleBox["(",
        SpanMaxSize->1], "1", 
       StyleBox[")",
        SpanMaxSize->1], "-", 
       StyleBox["f", "TI"], 
       StyleBox["(",
        SpanMaxSize->1], 
       RowBox[{"-", "1"}], 
       StyleBox[")",
        SpanMaxSize->1]}]},
     {
      RowBox[{
       StyleBox["f", "TI"], 
       StyleBox["(",
        SpanMaxSize->1], "1", 
       StyleBox[")",
        SpanMaxSize->1], "-", 
       StyleBox["f", "TI"], 
       StyleBox["(",
        SpanMaxSize->1], 
       RowBox[{"-", "1"}], 
       StyleBox[")",
        SpanMaxSize->1]}], 
      RowBox[{
       StyleBox["f", "TI"], 
       StyleBox["(",
        SpanMaxSize->1], "1", 
       StyleBox[")",
        SpanMaxSize->1], "+", 
       StyleBox["f", "TI"], 
       StyleBox["(",
        SpanMaxSize->1], 
       RowBox[{"-", "1"}], 
       StyleBox[")",
        SpanMaxSize->1]}]}
    }], ")"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "acfa7376-b1ba-4832-a064-fd90c1468ad8"],
 " is ",
 StyleBox["not", "TI"],
 " ",
 Cell[BoxData[
  StyleBox["f", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "0bab360b-0c53-44d2-8024-53ab627bb659"],
 " taken entry by entry: the naive entrywise map would send the diagonal ",
 Cell[BoxData["0"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "51ebf25f-41f0-4868-ab44-9045439b5391"],
 "s of ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["\[Sigma]", "TI"], 
   StyleBox["x", "TI"]]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "2a147be5-1587-4aff-a62b-435aae70818c"],
 " to ",
 Cell[BoxData[
  RowBox[{
   StyleBox["f", "TI"], 
   StyleBox["(",
    SpanMaxSize->1], "0", 
   StyleBox[")",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "42775605-c2fa-41dc-b66d-9896f937d603"],
 ", whereas functional calculus gives ",
 Cell[BoxData[
  RowBox[{
   FractionBox["1", "2"], 
   StyleBox["(",
    FontSize->1.2 Inherited], 
   StyleBox["f", "TI"], 
   StyleBox["(",
    SpanMaxSize->1], "1", 
   StyleBox[")",
    SpanMaxSize->1], "+", 
   StyleBox["f", "TI"], 
   StyleBox["(",
    SpanMaxSize->1], 
   RowBox[{"-", "1"}], 
   StyleBox[")",
    SpanMaxSize->1], 
   StyleBox[")",
    FontSize->1.2 Inherited]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "6181cf6c-ab3b-4b60-961e-98ef465f35e4"],
 " there. The reason is the spectral definition, ",
 Cell[BoxData[
  StyleBox["f", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "9ee8cdfc-4158-4597-8667-4f1ad76f5c1d"],
 " acts on the eigenvalues ",
 Cell[BoxData[
  RowBox[{"\[PlusMinus]", "1"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "8aa3d2f6-1965-4858-9596-28e705d21a70"],
 " and the eigenprojectors of ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["\[Sigma]", "TI"], 
   StyleBox["x", "TI"]]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "4556fbbd-710d-4a74-940a-6d51c1407f10"],
 " spread that action across the whole matrix."
}], "Text",ExpressionUUID->"dffb1e3c-bcf8-4b57-9175-2de8ebf0a2af"],

Cell[TextData[{
 "To make that explicit, build the spectral sum ",
 Cell[BoxData[
  RowBox[{
   UnderscriptBox["\[Sum]", 
    StyleBox["a", "TI"],
    LimitsPositioning->False], 
   RowBox[{
    StyleBox["f", "TI"], 
    RowBox[{
     StyleBox["(",
      SpanMaxSize->1], 
     StyleBox["a", "TI"], 
     StyleBox[")",
      SpanMaxSize->1]}], 
    TemplateBox[{
      StyleBox["a", "TI"]},
     "Ket"], 
    TemplateBox[{
      StyleBox["a", "TI"]},
     "Bra"]}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "f1bb1105-fea1-46aa-ac16-30333fb85b5d"],
 " from the eigensystem."
}], "Text",ExpressionUUID->"6e3041d1-4974-4114-a813-b8be65c678ab"],

Cell[BoxData[
 RowBox[{"spec", " ", "=", " ", 
  RowBox[{"With", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"sys", " ", "=", " ", 
      RowBox[{"Eigensystem", "[", 
       RowBox[{"PauliMatrix", "[", "1", "]"}], "]"}]}], "}"}], ",", "\n", 
    "  ", 
    RowBox[{"Total", "[", 
     RowBox[{"MapThread", "[", 
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{"f", "[", "#1", "]"}], " ", 
         RowBox[{"KroneckerProduct", "[", 
          RowBox[{"#2", ",", " ", 
           RowBox[{"Conjugate", "[", "#2", "]"}]}], "]"}]}], " ", "&"}], ",", 
       " ", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"sys", "[", 
          RowBox[{"[", "1", "]"}], "]"}], ",", " ", 
         RowBox[{"Normalize", " ", "/@", " ", 
          RowBox[{"sys", "[", 
           RowBox[{"[", "2", "]"}], "]"}]}]}], "}"}]}], "]"}], "]"}]}], 
   "]"}]}]], "Input",
 CellLabel->
  "In[60]:= ",ExpressionUUID->"81616ccf-01f2-4c42-b84f-9f0e0fe586b8"],

Cell["It reproduces the built-in to the last entry.", "Text",ExpressionUUID->"baa3ab5a-16ca-410b-87b9-996ed0085c3b"],

Cell[BoxData[
 RowBox[{"spec", " ", "==", " ", 
  RowBox[{"MatrixFunction", "[", 
   RowBox[{"f", ",", " ", 
    RowBox[{"PauliMatrix", "[", "1", "]"}]}], "]"}]}]], "Input",
 CellLabel->
  "In[61]:= ",ExpressionUUID->"1b730d18-18d8-44dd-afb0-e43c3f5d40a8"],

Cell[TextData[{
 StyleBox["QF",
  FontWeight->"Bold"],
 " : the same spectral definition driven by the operator's own ",
 Cell[BoxData["\"\<Eigensystem\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "93a7715b-f8e1-4cb5-b20b-7360b265bf18"],
 "."
}], "Text",ExpressionUUID->"b8400ba4-3fb6-4c59-b8a7-adcc78ca18e0"],

Cell[BoxData[
 RowBox[{"With", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"sys", " ", "=", " ", 
     RowBox[{
      RowBox[{"QuantumOperator", "[", "\"\<X\>\"", "]"}], 
      "[", "\"\<Eigensystem\>\"", "]"}]}], "}"}], ",", "\n", " ", 
   RowBox[{"Total", "[", 
    RowBox[{"MapThread", "[", 
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{"f", "[", "#1", "]"}], " ", 
        RowBox[{"KroneckerProduct", "[", 
         RowBox[{"#2", ",", " ", 
          RowBox[{"Conjugate", "[", "#2", "]"}]}], "]"}]}], " ", "&"}], ",", 
      " ", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"sys", "[", 
         RowBox[{"[", "1", "]"}], "]"}], ",", " ", 
        RowBox[{"Normalize", " ", "/@", " ", 
         RowBox[{"sys", "[", 
          RowBox[{"[", "2", "]"}], "]"}]}]}], "}"}]}], "]"}], "]"}]}], 
  "]"}]], "Input",
 CellLabel->
  "In[62]:= ",ExpressionUUID->"c2726a7c-7923-43d6-bbda-6d04424fb95d"],

Cell[TextData[{
 "So ",
 Cell[BoxData["MatrixFunction"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "f4c91887-1aca-40be-a572-d86d252ba49b"],
 " is the direct answer and the spectral sum is what it evaluates: ",
 Cell[BoxData[
  StyleBox["f", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "8eb7d329-7d0d-4a09-a635-7106808d20e1"],
 " acts through the eigenbasis, and the two agree exactly."
}], "Text",ExpressionUUID->"59166744-d30b-4549-8ae6-afe4fe199f65"],

Cell[TextData[{
 "2.6 [BSc] How do I compute an expectation value and a variance on a pure \
state as ",
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     StyleBox["\[Psi]", "TI"]},
    "Bra"], 
   OverscriptBox[
    StyleBox["A", "TI"], "^"], 
   TemplateBox[{
     StyleBox["\[Psi]", "TI"]},
    "Ket"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "ea8d6c54-3550-454b-bcca-71084a860827"],
 "?"
}], "Subsection",ExpressionUUID->"6a03232a-0ab9-4985-a107-0a2890b2f67e"],

Cell[TextData[{
 "The mean is ",
 Cell[BoxData[
  RowBox[{
   RowBox[{
    StyleBox["\[LeftAngleBracket]",
     SpanMaxSize->1], 
    StyleBox["A", "TI"], 
    StyleBox["\[RightAngleBracket]",
     SpanMaxSize->1]}], "=", 
   RowBox[{
    TemplateBox[{
      StyleBox["\[Psi]", "TI"]},
     "Bra"], 
    StyleBox["A", "TI"], 
    TemplateBox[{
      StyleBox["\[Psi]", "TI"]},
     "Ket"]}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "595a5c2e-f30f-4ee3-9969-a5a256f30cb7"],
 " and the variance is ",
 Cell[BoxData[
  RowBox[{
   StyleBox["\[LeftAngleBracket]",
    SpanMaxSize->1], 
   SuperscriptBox[
    StyleBox["A", "TI"], "2"], 
   StyleBox["\[RightAngleBracket]",
    SpanMaxSize->1], "-", 
   SuperscriptBox[
    RowBox[{
     StyleBox["\[LeftAngleBracket]",
      SpanMaxSize->1], 
     StyleBox["A", "TI"], "\[VeryThinSpace]", 
     StyleBox["\[RightAngleBracket]",
      SpanMaxSize->1]}], "2"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "73d694da-a471-4c04-9d86-fbd6397ff786"],
 "."
}], "Text",ExpressionUUID->"f7103bf9-7dcc-451f-bfa9-9ca761b0ea4c"],

Cell[TextData[{
 StyleBox["WL",
  FontWeight->"Bold"],
 " : contract the bra, operator, and ket for the mean."
}], "Text",ExpressionUUID->"87d6e5f1-67e0-49f1-8d2f-ec1fd0f7b9d8"],

Cell[BoxData[
 RowBox[{"With", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{"a", " ", "=", " ", 
      RowBox[{"PauliMatrix", "[", "3", "]"}]}], ",", " ", 
     RowBox[{"psi", " ", "=", " ", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"Cos", "[", 
         RowBox[{"\[Theta]", "/", "2"}], "]"}], ",", " ", 
        RowBox[{
         RowBox[{"Exp", "[", 
          RowBox[{"I", " ", "\[Phi]"}], "]"}], " ", 
         RowBox[{"Sin", "[", 
          RowBox[{"\[Theta]", "/", "2"}], "]"}]}]}], "}"}]}]}], "}"}], ",", 
   "\n", " ", 
   RowBox[{"FullSimplify", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"Conjugate", "[", "psi", "]"}], " ", ".", " ", "a", " ", ".", 
      " ", "psi"}], ",", " ", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"\[Theta]", ",", " ", "\[Phi]"}], "}"}], " ", "\[Element]", 
      " ", "Reals"}]}], "]"}]}], "]"}]], "Input",
 CellLabel->
  "In[63]:= ",ExpressionUUID->"0e68fa12-e185-492f-a6fd-e4d98181dfd3"],

Cell[TextData[{
 "The variance reuses ",
 Cell[BoxData[
  SuperscriptBox[
   StyleBox["A", "TI"], "2"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "61bec139-4ad5-4a89-96f9-70bf921ba0e3"],
 "."
}], "Text",ExpressionUUID->"c00c5d0a-f3c9-4073-9d4d-29f8bbcc3ba9"],

Cell[BoxData[
 RowBox[{"With", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{"a", " ", "=", " ", 
      RowBox[{"PauliMatrix", "[", "3", "]"}]}], ",", " ", 
     RowBox[{"psi", " ", "=", " ", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"Cos", "[", 
         RowBox[{"\[Theta]", "/", "2"}], "]"}], ",", " ", 
        RowBox[{
         RowBox[{"Exp", "[", 
          RowBox[{"I", " ", "\[Phi]"}], "]"}], " ", 
         RowBox[{"Sin", "[", 
          RowBox[{"\[Theta]", "/", "2"}], "]"}]}]}], "}"}]}]}], "}"}], ",", 
   "\n", " ", 
   RowBox[{"FullSimplify", "[", 
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{"Conjugate", "[", "psi", "]"}], " ", ".", " ", "a", " ", ".", 
       " ", "a", " ", ".", " ", "psi"}], " ", "-", " ", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{
         RowBox[{"Conjugate", "[", "psi", "]"}], " ", ".", " ", "a", " ", ".",
          " ", "psi"}], ")"}], "^", "2"}]}], ",", " ", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"\[Theta]", ",", " ", "\[Phi]"}], "}"}], " ", "\[Element]", 
      " ", "Reals"}]}], "]"}]}], "]"}]], "Input",
 CellLabel->
  "In[64]:= ",ExpressionUUID->"192f38f0-c68a-4ef3-83bc-e9ab8f5c4059"],

Cell[TextData[{
 StyleBox["QF",
  FontWeight->"Bold"],
 " : the mean as a bra-operator-ket scalar."
}], "Text",ExpressionUUID->"17bf8a76-a9c3-4a1c-af5a-8aeadb117fa4"],

Cell[BoxData[
 RowBox[{"With", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{"a", " ", "=", " ", 
      RowBox[{"QuantumOperator", "[", "\"\<Z\>\"", "]"}]}], ",", " ", 
     RowBox[{"ps", " ", "=", " ", 
      RowBox[{"QuantumState", "[", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"Cos", "[", 
          RowBox[{"\[Theta]", "/", "2"}], "]"}], ",", " ", 
         RowBox[{
          RowBox[{"Exp", "[", 
           RowBox[{"I", " ", "\[Phi]"}], "]"}], " ", 
          RowBox[{"Sin", "[", 
           RowBox[{"\[Theta]", "/", "2"}], "]"}]}]}], "}"}], "]"}]}]}], "}"}],
    ",", "\n", " ", 
   RowBox[{"FullSimplify", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"(", 
       RowBox[{
        RowBox[{"ps", "[", "\"\<Dagger\>\"", "]"}], " ", "@", " ", 
        RowBox[{"a", " ", "@", " ", "ps"}]}], ")"}], "[", "\"\<Scalar\>\"", 
      "]"}], ",", " ", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"\[Theta]", ",", " ", "\[Phi]"}], "}"}], " ", "\[Element]", 
      " ", "Reals"}]}], "]"}]}], "]"}]], "Input",
 CellLabel->
  "In[65]:= ",ExpressionUUID->"e5ce2442-22db-425b-8cd3-b7c6155937b4"],

Cell["The variance, again as scalars.", "Text",ExpressionUUID->"31bd0953-af68-4615-9a8d-0a4ae0867740"],

Cell[BoxData[
 RowBox[{"With", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{"a", " ", "=", " ", 
      RowBox[{"QuantumOperator", "[", "\"\<Z\>\"", "]"}]}], ",", " ", 
     RowBox[{"ps", " ", "=", " ", 
      RowBox[{"QuantumState", "[", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"Cos", "[", 
          RowBox[{"\[Theta]", "/", "2"}], "]"}], ",", " ", 
         RowBox[{
          RowBox[{"Exp", "[", 
           RowBox[{"I", " ", "\[Phi]"}], "]"}], " ", 
          RowBox[{"Sin", "[", 
           RowBox[{"\[Theta]", "/", "2"}], "]"}]}]}], "}"}], "]"}]}]}], "}"}],
    ",", "\n", " ", 
   RowBox[{"FullSimplify", "[", 
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{"(", 
        RowBox[{
         RowBox[{"ps", "[", "\"\<Dagger\>\"", "]"}], " ", "@", " ", 
         RowBox[{"a", " ", "@", " ", 
          RowBox[{"a", " ", "@", " ", "ps"}]}]}], ")"}], "[", "\"\<Scalar\>\"",
        "]"}], " ", "-", " ", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{
           RowBox[{"ps", "[", "\"\<Dagger\>\"", "]"}], " ", "@", " ", 
           RowBox[{"a", " ", "@", " ", "ps"}]}], ")"}], "[", "\"\<Scalar\>\"",
          "]"}], ")"}], "^", "2"}]}], ",", "\n", "  ", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"\[Theta]", ",", " ", "\[Phi]"}], "}"}], " ", "\[Element]", 
      " ", "Reals"}]}], "]"}]}], "]"}]], "Input",
 CellLabel->
  "In[66]:= ",ExpressionUUID->"b1de84c6-cb40-4e50-ac70-bf0dd7588c4f"],

Cell[TextData[{
 "Both give ",
 Cell[BoxData[
  RowBox[{
   StyleBox["\[LeftAngleBracket]",
    SpanMaxSize->1], 
   SubscriptBox[
    StyleBox["\[Sigma]", "TI"], 
    StyleBox["z", "TI"]], 
   StyleBox["\[RightAngleBracket]",
    SpanMaxSize->1], "=", 
   StyleBox["cos",
    FontSlant->"Plain"], "\[ThinSpace]", 
   StyleBox["\[Theta]", "TI"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "b67005cc-813b-45c5-ab8d-7caadeb82338"],
 " and ",
 Cell[BoxData[
  RowBox[{
   StyleBox["Var",
    FontSlant->"Plain"], "=", 
   SuperscriptBox[
    StyleBox["sin",
     FontSlant->"Plain"], "2"], "\[ThinSpace]", 
   StyleBox["\[Theta]", "TI"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "6ad4b39f-e89d-4b82-a68d-1bafbb6a1e32"],
 ": the spin points along ",
 Cell[BoxData[
  StyleBox["z", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "91dd21f1-09c2-4ede-9166-f8be915b6fd6"],
 " with certainty at the poles and is maximally uncertain on the equator. The \
mixed-state generalization, ",
 Cell[BoxData[
  RowBox[{
   StyleBox["\[LeftAngleBracket]",
    SpanMaxSize->1], 
   StyleBox["A", "TI"], "\[VeryThinSpace]", 
   StyleBox["\[RightAngleBracket]",
    SpanMaxSize->1], "=", 
   StyleBox["Tr",
    FontSlant->"Plain"], 
   StyleBox["[",
    SpanMaxSize->1], 
   StyleBox[
    RowBox[{"A", "\[Rho]"}], "TI"], 
   StyleBox["]",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "f32073bf-81c8-4494-b4b0-2fa199c7ed6a"],
 " on any ",
 Cell[BoxData[
  RowBox[{
   StyleBox["\[Rho]", "TI"], "=", 
   FractionBox["1", "2"], 
   StyleBox["(",
    SpanMaxSize->1], 
   RowBox[{
    StyleBox["I", "TI"], "+", 
    OverscriptBox[
     StyleBox["r", "TI"], "\[RightVector]"], "\[CenterDot]", 
    OverscriptBox[
     StyleBox["\[Sigma]", "TI"], "\[RightVector]"]}], 
   StyleBox[")",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "af96b192-7c82-4c4c-beda-3907b2a19660"],
 " (giving ",
 Cell[BoxData[
  RowBox[{
   StyleBox["\[LeftAngleBracket]",
    SpanMaxSize->1], 
   SubscriptBox[
    StyleBox["\[Sigma]", "TI"], 
    StyleBox["z", "TI"]], 
   StyleBox["\[RightAngleBracket]",
    SpanMaxSize->1], "=", 
   SubscriptBox[
    StyleBox["r", "TI"], 
    StyleBox["z", "TI"]]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "227c0e7e-ba79-4903-be9b-1830c2e76628"],
 ", ",
 Cell[BoxData[
  RowBox[{
   StyleBox["Var",
    FontSlant->"Plain"], "=", "1", "-", 
   SubsuperscriptBox[
    StyleBox["r", "TI"], 
    StyleBox["z", "TI"], "2"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "d57ed6b4-0b7a-453d-9731-bd1c04b9848a"],
 "), is 3.4."
}], "Text",ExpressionUUID->"7d945277-0251-4979-af47-385a27c21534"],

Cell["\<\
2.7 [BSc] How do I write the resolution of the identity in an orthonormal \
basis?\
\>", "Subsection",ExpressionUUID->"cb415bd4-bf45-4dc0-b691-e77bbda422ba"],

Cell[TextData[{
 "Any orthonormal basis is complete, ",
 Cell[BoxData[
  RowBox[{
   RowBox[{
    UnderscriptBox["\[Sum]", 
     StyleBox["i", "TI"],
     LimitsPositioning->False], 
    RowBox[{
     TemplateBox[{
       StyleBox["i", "TI"]},
      "Ket"], 
     TemplateBox[{
       StyleBox["i", "TI"]},
      "Bra"]}]}], "=", 
   StyleBox["I", "TI"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "0814b501-e38e-4b20-a006-eaca8b853d6a"],
 "."
}], "Text",ExpressionUUID->"4f6070e2-5ed0-4c6d-a7fb-5124e07f2eaf"],

Cell[TextData[{
 StyleBox["WL",
  FontWeight->"Bold"],
 " : sum the eigenprojectors of a generic Hermitian operator."
}], "Text",ExpressionUUID->"3f07564c-5850-42a0-a17d-aaeec167afba"],

Cell[BoxData[
 RowBox[{"With", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"vecs", " ", "=", " ", 
     RowBox[{"Normalize", " ", "/@", " ", 
      RowBox[{"Eigenvectors", "[", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"a1", ",", " ", 
           RowBox[{"a2", " ", "+", " ", 
            RowBox[{"I", " ", "a3"}]}]}], "}"}], ",", " ", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{"a2", " ", "-", " ", 
            RowBox[{"I", " ", "a3"}]}], ",", " ", "a4"}], "}"}]}], "}"}], 
       "]"}]}]}], "}"}], ",", "\n", " ", 
   RowBox[{"FullSimplify", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"Total", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"KroneckerProduct", "[", 
          RowBox[{"#", ",", " ", 
           RowBox[{"Conjugate", "[", "#", "]"}]}], "]"}], " ", "&"}], " ", "/@",
         " ", "vecs"}], "]"}], " ", "==", " ", 
      RowBox[{"IdentityMatrix", "[", "2", "]"}]}], ",", "\n", "  ", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{
       "a1", " ", "|", " ", "a2", " ", "|", " ", "a3", " ", "|", " ", "a4"}], 
       ")"}], " ", "\[Element]", " ", "Reals"}]}], "]"}]}], "]"}]], "Input",
 CellLabel->
  "In[67]:= ",ExpressionUUID->"45652ce8-633c-4cab-8765-770461ec566d"],

Cell[TextData[{
 StyleBox["QF",
  FontWeight->"Bold"],
 " : the same with the operator's ",
 Cell[BoxData["\"\<Eigenvectors\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "dd4205ca-4fb4-4481-9547-eeab6c99252e"],
 "."
}], "Text",ExpressionUUID->"e50b6c79-1734-4492-b934-651816d15a5e"],

Cell[BoxData[
 RowBox[{"With", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"vecs", " ", "=", " ", 
     RowBox[{"Normalize", " ", "/@", " ", 
      RowBox[{
       RowBox[{"QuantumOperator", "[", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{"a1", ",", " ", 
            RowBox[{"a2", " ", "+", " ", 
             RowBox[{"I", " ", "a3"}]}]}], "}"}], ",", " ", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"a2", " ", "-", " ", 
             RowBox[{"I", " ", "a3"}]}], ",", " ", "a4"}], "}"}]}], "}"}], 
        "]"}], "[", "\"\<Eigenvectors\>\"", "]"}]}]}], "}"}], ",", "\n", " ", 
   
   RowBox[{"FullSimplify", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"Total", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"KroneckerProduct", "[", 
          RowBox[{"#", ",", " ", 
           RowBox[{"Conjugate", "[", "#", "]"}]}], "]"}], " ", "&"}], " ", "/@",
         " ", "vecs"}], "]"}], " ", "==", " ", 
      RowBox[{"IdentityMatrix", "[", "2", "]"}]}], ",", "\n", "  ", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{
       "a1", " ", "|", " ", "a2", " ", "|", " ", "a3", " ", "|", " ", "a4"}], 
       ")"}], " ", "\[Element]", " ", "Reals"}]}], "]"}]}], "]"}]], "Input",
 CellLabel->
  "In[68]:= ",ExpressionUUID->"3420f8c8-c7ab-4f87-8517-5f093c341d61"],

Cell[TextData[{
 "Both return ",
 Cell[BoxData["True"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "b018c203-8d30-4970-879c-758d13e7dea5"],
 ": the eigenprojectors of any observable sum to the identity."
}], "Text",ExpressionUUID->"8156a3e5-1b10-474f-b68b-b61b3a81d45c"],

Cell["\<\
2.8 [BSc] How do I decide whether two observables are compatible (commute) \
and find a simultaneous eigenbasis?\
\>", "Subsection",ExpressionUUID->"c64fa71b-ff22-4f84-96ca-88fa0edf1491"],

Cell[TextData[{
 "Two observables are ",
 StyleBox["compatible", "TI"],
 ", meaning they can hold definite values at the same time, exactly when they \
commute, ",
 Cell[BoxData[
  RowBox[{
   StyleBox["[",
    SpanMaxSize->1], 
   RowBox[{
    StyleBox["A", "TI"], ",", 
    StyleBox["B", "TI"]}], 
   StyleBox["]",
    SpanMaxSize->1], "=", "0"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "c5d86cd7-34c9-42ee-aadd-a6a29ea5fa36"],
 ". The reason commuting gives a shared eigenbasis is one line: if ",
 Cell[BoxData[
  RowBox[{
   RowBox[{
    StyleBox["A", "TI"], 
    TemplateBox[{
      StyleBox["a", "TI"]},
     "Ket"]}], "=", 
   RowBox[{
    StyleBox["a", "TI"], 
    TemplateBox[{
      StyleBox["a", "TI"]},
     "Ket"]}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "7482f841-516d-406e-9b2d-f1d2ec2b7452"],
 " and ",
 Cell[BoxData[
  RowBox[{
   StyleBox["A", "TI"], 
   StyleBox["B", "TI"], "=", 
   StyleBox["B", "TI"], 
   StyleBox["A", "TI"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "eeac3e3b-4100-45ec-afa8-2ddc589d861d"],
 ", then ",
 Cell[BoxData[
  RowBox[{
   RowBox[{
    StyleBox["A", "TI"], 
    RowBox[{"(", 
     RowBox[{
      StyleBox["B", "TI"], 
      TemplateBox[{
        StyleBox["a", "TI"]},
       "Ket"]}], ")"}]}], "=", 
   RowBox[{
    RowBox[{
     StyleBox["B", "TI"], 
     RowBox[{"(", 
      RowBox[{
       StyleBox["A", "TI"], 
       TemplateBox[{
         StyleBox["a", "TI"]},
        "Ket"]}], ")"}]}], "=", 
    RowBox[{
     StyleBox["a", "TI"], 
     RowBox[{"(", 
      RowBox[{
       StyleBox["B", "TI"], 
       TemplateBox[{
         StyleBox["a", "TI"]},
        "Ket"]}], ")"}]}]}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "7a9c4cd0-1d35-4a53-b07b-8847ebfe0aa3"],
 ", so ",
 Cell[BoxData[
  StyleBox["B", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "d1d8c5fb-7455-4be1-a6de-e88fc952897b"],
 " keeps each eigenspace of ",
 Cell[BoxData[
  StyleBox["A", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "56d9d169-5c76-4e39-bd70-60d550fc3829"],
 " inside itself. When the eigenvalue ",
 Cell[BoxData[
  StyleBox["a", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "570e5bec-44db-4697-9650-cd96b4d43325"],
 " is ",
 StyleBox["non-degenerate",
  FontWeight->"Bold"],
 " (a one-dimensional eigenspace), ",
 Cell[BoxData[
  RowBox[{
   StyleBox["B", "TI"], 
   TemplateBox[{
     StyleBox["a", "TI"]},
    "Ket"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "57fb95b3-25a3-4b48-a343-2ca7fe85de75"],
 " can only be a multiple of ",
 Cell[BoxData[
  TemplateBox[{
    StyleBox["a", "TI"]},
   "Ket"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "90799375-e3f1-4c81-a815-963d3feb9f04"],
 ", so ",
 Cell[BoxData[
  TemplateBox[{
    StyleBox["a", "TI"]},
   "Ket"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "5a5a828d-2484-479c-9b95-7314ca653be8"],
 " is automatically an eigenvector of ",
 Cell[BoxData[
  StyleBox["B", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "54556ac4-8302-4276-b22c-a9c627e42272"],
 " too. That is the whole job in the ordinary case: diagonalize one \
non-degenerate observable, and its eigenvectors are already the simultaneous \
eigenbasis."
}], "Text",ExpressionUUID->"400c9fd6-3279-4fe8-9717-c5d69c528c44"],

Cell[TextData[{
 StyleBox["Normal case.",
  FontWeight->"Bold"],
 " Take a non-degenerate ",
 Cell[BoxData[
  RowBox[{
   StyleBox["A", "TI"], "=", 
   StyleBox["X", "TI"], "\[CircleTimes]", 
   StyleBox["I", "TI"], "+", "2", " ", 
   StyleBox["I", "TI"], "\[CircleTimes]", 
   StyleBox["Z", "TI"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "c1881243-b7dd-4c32-ba10-d510b6b1a805"],
 " and a compatible partner ",
 Cell[BoxData[
  RowBox[{
   StyleBox["B", "TI"], "=", 
   StyleBox["X", "TI"], "\[CircleTimes]", 
   StyleBox["Z", "TI"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "56023fc0-1314-42f2-b588-ea18ecaa7711"],
 "."
}], "Text",ExpressionUUID->"7449274d-9d3f-40ba-8677-ca087aa088fd"],

Cell[TextData[{
 StyleBox["WL",
  FontWeight->"Bold"],
 " : compatibility is the vanishing commutator."
}], "Text",ExpressionUUID->"cfa37e4b-4974-4455-aedd-759641ea1147"],

Cell[BoxData[
 RowBox[{"With", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{"a", " ", "=", " ", 
      RowBox[{
       RowBox[{"KroneckerProduct", "[", 
        RowBox[{
         RowBox[{"PauliMatrix", "[", "1", "]"}], ",", " ", 
         RowBox[{"IdentityMatrix", "[", "2", "]"}]}], "]"}], " ", "+", " ", 
       RowBox[{"2", " ", 
        RowBox[{"KroneckerProduct", "[", 
         RowBox[{
          RowBox[{"IdentityMatrix", "[", "2", "]"}], ",", " ", 
          RowBox[{"PauliMatrix", "[", "3", "]"}]}], "]"}]}]}]}], ",", "\n", 
     "   ", 
     RowBox[{"b", " ", "=", " ", 
      RowBox[{"KroneckerProduct", "[", 
       RowBox[{
        RowBox[{"PauliMatrix", "[", "1", "]"}], ",", " ", 
        RowBox[{"PauliMatrix", "[", "3", "]"}]}], "]"}]}]}], "}"}], ",", "\n",
    " ", 
   RowBox[{
    RowBox[{"a", " ", ".", " ", "b"}], " ", "==", " ", 
    RowBox[{"b", " ", ".", " ", "a"}]}]}], "]"}]], "Input",
 CellLabel->
  "In[69]:= ",ExpressionUUID->"3b8e7c35-84c3-4b45-b0b4-320cdbdc88c6"],

Cell[TextData[{
 "What makes this the easy case is that ",
 Cell[BoxData[
  StyleBox["A", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "5d9c64e2-cb2c-4e32-9812-f138cc757bb5"],
 " is non-degenerate: its four eigenvalues are distinct, so every eigenspace \
is one-dimensional and the eigenbasis is unique."
}], "Text",ExpressionUUID->"1353b206-5c2c-43a9-9f27-85ab7aa917dc"],

Cell[BoxData[
 RowBox[{"Eigenvalues", "[", "\n", " ", 
  RowBox[{
   RowBox[{"KroneckerProduct", "[", 
    RowBox[{
     RowBox[{"PauliMatrix", "[", "1", "]"}], ",", " ", 
     RowBox[{"IdentityMatrix", "[", "2", "]"}]}], "]"}], " ", "+", " ", 
   RowBox[{"2", " ", 
    RowBox[{"KroneckerProduct", "[", 
     RowBox[{
      RowBox[{"IdentityMatrix", "[", "2", "]"}], ",", " ", 
      RowBox[{"PauliMatrix", "[", "3", "]"}]}], "]"}]}]}], "]"}]], "Input",
 CellLabel->
  "In[70]:= ",ExpressionUUID->"0be9bfec-14d7-4521-aa5b-c3c0866a7615"],

Cell[TextData[{
 "Diagonalize ",
 Cell[BoxData[
  StyleBox["A", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "9d367ab6-ff6e-4182-906b-48aa6bf8c9c3"],
 " once: its eigenvectors also diagonalize ",
 Cell[BoxData[
  StyleBox["B", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "f1817e30-7233-4b73-b890-175b46ca256d"],
 ", so they ",
 StyleBox["are", "TI"],
 " the simultaneous eigenbasis. The check conjugates each operator into the \
candidate basis (",
 Cell[BoxData[
  StyleBox["u", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "cb584d9d-7272-4e02-84a6-b5d022549ec7"],
 " holding the eigenvectors as rows) and tests that the result is diagonal; \
the pair ",
 Cell[BoxData[
  RowBox[{"{", 
   RowBox[{"True", ",", " ", "True"}], "}"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "5de729f2-9965-4626-b6ab-e1bc7729ec10"],
 " says both are."
}], "Text",ExpressionUUID->"c6c03fb1-35c1-49ae-b4bc-a5beef63be57"],

Cell[BoxData[
 RowBox[{"With", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{"a", " ", "=", " ", 
      RowBox[{
       RowBox[{"KroneckerProduct", "[", 
        RowBox[{
         RowBox[{"PauliMatrix", "[", "1", "]"}], ",", " ", 
         RowBox[{"IdentityMatrix", "[", "2", "]"}]}], "]"}], " ", "+", " ", 
       RowBox[{"2", " ", 
        RowBox[{"KroneckerProduct", "[", 
         RowBox[{
          RowBox[{"IdentityMatrix", "[", "2", "]"}], ",", " ", 
          RowBox[{"PauliMatrix", "[", "3", "]"}]}], "]"}]}]}]}], ",", "\n", 
     "   ", 
     RowBox[{"b", " ", "=", " ", 
      RowBox[{"KroneckerProduct", "[", 
       RowBox[{
        RowBox[{"PauliMatrix", "[", "1", "]"}], ",", " ", 
        RowBox[{"PauliMatrix", "[", "3", "]"}]}], "]"}]}]}], "}"}], ",", "\n",
    " ", 
   RowBox[{"With", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"u", " ", "=", " ", 
       RowBox[{"Normalize", " ", "/@", " ", 
        RowBox[{"Eigenvectors", "[", "a", "]"}]}]}], "}"}], ",", "\n", "  ", 
     RowBox[{"DiagonalMatrixQ", " ", "/@", " ", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{
         RowBox[{"Chop", "[", 
          RowBox[{
           RowBox[{"Conjugate", "[", "u", "]"}], " ", ".", " ", "#", " ", ".",
            " ", 
           RowBox[{"Transpose", "[", "u", "]"}]}], "]"}], " ", "&"}], " ", "/@",
         " ", 
        RowBox[{"{", 
         RowBox[{"a", ",", " ", "b"}], "}"}]}], ")"}]}]}], "]"}]}], 
  "]"}]], "Input",
 CellLabel->
  "In[71]:= ",ExpressionUUID->"bbb0e154-69cf-483a-8675-c5d7d1828b1a"],

Cell[TextData[{
 StyleBox["Special case: when neither observable is enough by itself.",
  FontWeight->"Bold"],
 " The shortcut breaks when the observables are degenerate, because then \
\"diagonalize ",
 Cell[BoxData[
  StyleBox["A", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "9cc2e4c3-56af-45f9-9892-12286e504c33"],
 "\" no longer names a unique basis. Take ",
 Cell[BoxData[
  RowBox[{
   StyleBox["A", "TI"], "=", 
   StyleBox["X", "TI"], "\[CircleTimes]", 
   StyleBox["X", "TI"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "8d349030-64b2-43b8-81d2-9107896a8e35"],
 " and ",
 Cell[BoxData[
  RowBox[{
   StyleBox["B", "TI"], "=", 
   StyleBox["Z", "TI"], "\[CircleTimes]", 
   StyleBox["Z", "TI"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "4a66f62e-319e-4649-a3ae-f59567e03366"],
 ": they commute, but each has ",
 Cell[BoxData[
  RowBox[{"+", "1"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "bebc8b68-31cb-4c10-ac54-f47d1b5a3e05"],
 " and ",
 Cell[BoxData[
  RowBox[{"-", "1"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "98ec5c35-0c34-47d8-b4bd-24c669b2ac04"],
 " ",
 StyleBox["doubled", "TI"],
 "."
}], "Text",ExpressionUUID->"af0d41d6-ceac-472e-aeba-e7fab0900c7f"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{"Eigenvalues", "[", 
    RowBox[{"KroneckerProduct", "[", 
     RowBox[{
      RowBox[{"PauliMatrix", "[", "1", "]"}], ",", " ", 
      RowBox[{"PauliMatrix", "[", "1", "]"}]}], "]"}], "]"}], ",", "\n", " ", 
   
   RowBox[{"Eigenvalues", "[", 
    RowBox[{"KroneckerProduct", "[", 
     RowBox[{
      RowBox[{"PauliMatrix", "[", "3", "]"}], ",", " ", 
      RowBox[{"PauliMatrix", "[", "3", "]"}]}], "]"}], "]"}]}], 
  "}"}]], "Input",
 CellLabel->
  "In[72]:= ",ExpressionUUID->"95c1bf5c-eb90-4c20-85e8-702f9da5d87f"],

Cell[TextData[{
 "A doubled eigenvalue is a two-dimensional eigenspace, and ",
 StyleBox["any", "TI"],
 " orthonormal pair inside it is an equally valid eigenbasis, so a choice \
that diagonalizes one operator need not diagonalize the other. Concretely, \
the obvious eigenbasis of ",
 Cell[BoxData[
  RowBox[{
   StyleBox["X", "TI"], "\[CircleTimes]", 
   StyleBox["X", "TI"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "5d15c404-d7a6-4e77-b335-5d1c970dd75c"],
 ", each qubit in an ",
 Cell[BoxData[
  StyleBox["X", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "c043685b-9ec9-49b8-9920-56ae9b63b7a8"],
 "-eigenstate ",
 Cell[BoxData[
  TemplateBox[{"\[PlusMinus]"},
   "Ket"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "e64fef2c-d8c1-4d5c-ba2f-7e0c275a5037"],
 " (the rows of ",
 Cell[BoxData[
  RowBox[{
   StyleBox["H", "TI"], "\[CircleTimes]", 
   StyleBox["H", "TI"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "11c7e86f-56e1-40d1-a6fa-2660d6eba8d1"],
 "), diagonalizes ",
 Cell[BoxData[
  RowBox[{
   StyleBox["X", "TI"], "\[CircleTimes]", 
   StyleBox["X", "TI"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "d1f25b7b-48d0-4854-8f0d-cea93cdedff0"],
 " but not ",
 Cell[BoxData[
  RowBox[{
   StyleBox["Z", "TI"], "\[CircleTimes]", 
   StyleBox["Z", "TI"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "da9f4ec4-833c-4463-8492-32a736d8071f"],
 ": the pair comes back ",
 Cell[BoxData[
  RowBox[{"{", 
   RowBox[{"True", ",", " ", "False"}], "}"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "23eac70d-5630-485f-9ff1-8f56ff085f4b"],
 "."
}], "Text",ExpressionUUID->"3541ec77-4a36-4bcd-b1e3-0e40e3d6966e"],

Cell[BoxData[
 RowBox[{"With", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"u", " ", "=", " ", 
     RowBox[{"KroneckerProduct", "[", 
      RowBox[{
       RowBox[{"HadamardMatrix", "[", "2", "]"}], ",", " ", 
       RowBox[{"HadamardMatrix", "[", "2", "]"}]}], "]"}]}], "}"}], ",", "\n",
    " ", 
   RowBox[{"DiagonalMatrixQ", " ", "/@", " ", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{
       RowBox[{"Chop", "[", 
        RowBox[{
         RowBox[{"Conjugate", "[", "u", "]"}], " ", ".", " ", "#", " ", ".", 
         " ", 
         RowBox[{"Transpose", "[", "u", "]"}]}], "]"}], " ", "&"}], " ", "/@",
       "\n", "   ", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"KroneckerProduct", "[", 
         RowBox[{
          RowBox[{"PauliMatrix", "[", "1", "]"}], ",", " ", 
          RowBox[{"PauliMatrix", "[", "1", "]"}]}], "]"}], ",", " ", 
        RowBox[{"KroneckerProduct", "[", 
         RowBox[{
          RowBox[{"PauliMatrix", "[", "3", "]"}], ",", " ", 
          RowBox[{"PauliMatrix", "[", "3", "]"}]}], "]"}]}], "}"}]}], 
     ")"}]}]}], "]"}]], "Input",
 CellLabel->
  "In[73]:= ",ExpressionUUID->"ec0b71f9-ab76-438f-923d-7e618832ac62"],

Cell[TextData[{
 "The fix is to diagonalize a single ",
 StyleBox["non-degenerate", "TI"],
 " combination ",
 Cell[BoxData[
  RowBox[{
   StyleBox["A", "TI"], "+", 
   StyleBox["c", "TI"], 
   StyleBox["B", "TI"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "27159f6d-0636-47e5-8587-72578c9f3389"],
 " for a generic constant ",
 Cell[BoxData[
  StyleBox["c", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "3c67dcee-3071-4564-9725-bf76991c7440"],
 ". Its eigenvalues are ",
 Cell[BoxData[
  RowBox[{
   StyleBox["a", "TI"], "+", 
   StyleBox["c", "TI"], " ", 
   StyleBox["b", "TI"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "4eee1d2c-92c0-4adc-a238-0f182b6308d0"],
 " over the joint values ",
 Cell[BoxData[
  RowBox[{
   StyleBox["(",
    SpanMaxSize->1], 
   RowBox[{
    StyleBox["a", "TI"], ",", 
    StyleBox["b", "TI"]}], 
   StyleBox[")",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "1692480c-d2b5-487e-a5c0-0912c5a08acb"],
 ", which a generic ",
 Cell[BoxData[
  StyleBox["c", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "c8ce75a0-3514-41ca-b6dd-36bbfdd16300"],
 " keeps distinct, so its eigenbasis is unique; and because ",
 Cell[BoxData[
  RowBox[{
   StyleBox["A", "TI"], "+", 
   StyleBox["c", "TI"], 
   StyleBox["B", "TI"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "67d5f550-40fa-4fe5-aa38-90800e24c113"],
 " commutes with both ",
 Cell[BoxData[
  StyleBox["A", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "029fd914-3c5b-41d3-9db9-c01f2a4bcc2b"],
 " and ",
 Cell[BoxData[
  StyleBox["B", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "fc893e29-bd2f-44e2-afdd-f2bc0fa5cec6"],
 ", that one basis diagonalizes both. Take ",
 Cell[BoxData[
  RowBox[{
   StyleBox["c", "TI"], "=", "\[Pi]"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "9e8e0329-b7e1-4305-9e1f-0947fd526433"],
 ", and the pair is ",
 Cell[BoxData[
  RowBox[{"{", 
   RowBox[{"True", ",", " ", "True"}], "}"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "58aef50d-03c7-489e-8327-f7437b592024"],
 "."
}], "Text",ExpressionUUID->"e39b7c57-c336-46d4-8f23-611664b04e68"],

Cell[BoxData[
 RowBox[{"With", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{"a", " ", "=", " ", 
      RowBox[{"KroneckerProduct", "[", 
       RowBox[{
        RowBox[{"PauliMatrix", "[", "1", "]"}], ",", " ", 
        RowBox[{"PauliMatrix", "[", "1", "]"}]}], "]"}]}], ",", " ", 
     RowBox[{"b", " ", "=", " ", 
      RowBox[{"KroneckerProduct", "[", 
       RowBox[{
        RowBox[{"PauliMatrix", "[", "3", "]"}], ",", " ", 
        RowBox[{"PauliMatrix", "[", "3", "]"}]}], "]"}]}]}], "}"}], ",", "\n",
    " ", 
   RowBox[{"With", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"u", " ", "=", " ", 
       RowBox[{"Normalize", " ", "/@", " ", 
        RowBox[{"Eigenvectors", "[", 
         RowBox[{"a", " ", "+", " ", 
          RowBox[{"\[Pi]", " ", "b"}]}], "]"}]}]}], "}"}], ",", "\n", "  ", 
     RowBox[{"DiagonalMatrixQ", " ", "/@", " ", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{
         RowBox[{"Chop", "[", 
          RowBox[{
           RowBox[{"Conjugate", "[", "u", "]"}], " ", ".", " ", "#", " ", ".",
            " ", 
           RowBox[{"Transpose", "[", "u", "]"}]}], "]"}], " ", "&"}], " ", "/@",
         " ", 
        RowBox[{"{", 
         RowBox[{"a", ",", " ", "b"}], "}"}]}], ")"}]}]}], "]"}]}], 
  "]"}]], "Input",
 CellLabel->
  "In[74]:= ",ExpressionUUID->"5a2a3c54-ba0f-4079-9412-59f97de97b63"],

Cell[TextData[{
 StyleBox["QF",
  FontWeight->"Bold"],
 " : compatibility is the ",
 StyleBox["operator", "TI"],
 " equality ",
 Cell[BoxData[
  RowBox[{
   StyleBox["A", "TI"], 
   StyleBox["B", "TI"], "=", 
   StyleBox["B", "TI"], 
   StyleBox["A", "TI"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "1c263598-5ba7-41fa-af55-82654eb1d8e2"],
 ", written ",
 Cell[BoxData[
  RowBox[{
   RowBox[{"a", " ", "@", " ", "b"}], " ", "==", " ", 
   RowBox[{"b", " ", "@", " ", "a"}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "91bedfff-b424-4a7d-95c7-09ae49410935"],
 "."
}], "Text",ExpressionUUID->"4b6a6c8e-5a3d-4e9a-af5f-bf3d7ea09b36"],

Cell[BoxData[
 RowBox[{"With", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{"a", " ", "=", " ", 
      RowBox[{"QuantumOperator", "[", "\"\<XX\>\"", "]"}]}], ",", " ", 
     RowBox[{"b", " ", "=", " ", 
      RowBox[{"QuantumOperator", "[", "\"\<ZZ\>\"", "]"}]}]}], "}"}], ",", 
   "\n", " ", 
   RowBox[{
    RowBox[{"a", " ", "@", " ", "b"}], " ", "==", " ", 
    RowBox[{"b", " ", "@", " ", "a"}]}]}], "]"}]], "Input",
 CellLabel->
  "In[75]:= ",ExpressionUUID->"2fc825c3-aa51-4bda-b6cb-2158330e6099"],

Cell[TextData[{
 "The simultaneous eigenbasis is the eigenstates of ",
 Cell[BoxData[
  RowBox[{"a", " ", "+", " ", 
   RowBox[{"Pi", " ", "b"}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "dae6860a-f057-47df-9715-2448bc1b7b8e"],
 ". Each one holds a definite value of both ",
 Cell[BoxData[
  StyleBox["A", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "a5ef84ea-94e2-41c7-9196-f37fab7094b3"],
 " and ",
 Cell[BoxData[
  StyleBox["B", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "bb8dbada-f136-44c8-9aa1-2827c1d3ee48"],
 ", so each operator returns it to itself up to a phase, leaving its density \
matrix unchanged."
}], "Text",ExpressionUUID->"441b6d8f-4443-460b-bdf6-3909a933a76b"],

Cell[BoxData[
 RowBox[{"With", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{"a", " ", "=", " ", 
      RowBox[{"QuantumOperator", "[", "\"\<XX\>\"", "]"}]}], ",", " ", 
     RowBox[{"b", " ", "=", " ", 
      RowBox[{"QuantumOperator", "[", "\"\<ZZ\>\"", "]"}]}]}], "}"}], ",", 
   "\n", " ", 
   RowBox[{"With", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"basis", " ", "=", " ", 
       RowBox[{"QuantumState", " ", "/@", " ", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{"a", " ", "+", " ", 
           RowBox[{"\[Pi]", " ", "b"}]}], ")"}], "[", "\"\<Eigenvectors\>\"", 
         "]"}]}]}], "}"}], ",", "\n", "  ", 
     RowBox[{"AllTrue", "[", 
      RowBox[{"basis", ",", " ", 
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{
           RowBox[{"(", 
            RowBox[{"a", "[", "#", "]"}], ")"}], "[", "\"\<DensityMatrix\>\"",
            "]"}], " ", "==", " ", 
          RowBox[{"#", "[", "\"\<DensityMatrix\>\"", "]"}]}], " ", "&&", " ", 
         
         RowBox[{
          RowBox[{
           RowBox[{"(", 
            RowBox[{"b", "[", "#", "]"}], ")"}], "[", "\"\<DensityMatrix\>\"",
            "]"}], " ", "==", " ", 
          RowBox[{"#", "[", "\"\<DensityMatrix\>\"", "]"}]}]}], " ", "&"}]}], 
      "]"}]}], "]"}]}], "]"}]], "Input",
 CellLabel->
  "In[76]:= ",ExpressionUUID->"02078e53-3ff8-4058-8d0d-cb71707737c3"],

Cell[TextData[{
 "So: compatible means commuting; in the ordinary case one non-degenerate \
observable already fixes the shared eigenbasis, and when both observables are \
degenerate you restore uniqueness by diagonalizing a generic combination ",
 Cell[BoxData[
  RowBox[{
   StyleBox["A", "TI"], "+", 
   StyleBox["c", "TI"], 
   StyleBox["B", "TI"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "35bd2005-f8fc-4f7e-be6c-7af12d929274"],
 " just once. The basis that ",
 Cell[BoxData[
  RowBox[{
   StyleBox["A", "TI"], "+", "\[Pi]", 
   StyleBox["B", "TI"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "e6ed5a2e-8736-4095-9e9c-07366079ef77"],
 " returns is the Bell basis, ",
 StyleBox["derived", "TI"],
 " rather than assumed; ",
 Cell[BoxData["\[Pi]"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "20bcf475-8117-47a2-bc3c-ec885fc3cd6f"],
 " only serves to break the degeneracy, and any value that does so yields the \
same simultaneous eigenbasis."
}], "Text",ExpressionUUID->"d90e5b25-273c-4981-8bbb-6d2a9445254d"],

Cell["\<\
2.9a [MSc] How do I construct a complete set of commuting observables (CSCO)?\
\
\>", "Subsection",ExpressionUUID->"391e1b73-fa5c-47f8-98b4-bcb5564f3015"],

Cell[TextData[{
 "A complete set of commuting observables (CSCO) is a set of mutually \
commuting Hermitian operators whose simultaneous eigenvalues label every \
basis state ",
 StyleBox["uniquely", "TI"],
 ". Commuting is the easy half (handled in 2.8); ",
 StyleBox["complete", "TI"],
 " is the real content. A single observable is a CSCO only when it is \
non-degenerate: a degenerate eigenvalue is a multi-dimensional eigenspace in \
which no basis is singled out, so the observable cannot distinguish the \
states it contains. The construction is to adjoin further commuting \
observables, each lifting some remaining degeneracy, until every simultaneous \
eigenspace is one-dimensional. Completeness is then a computable test: once \
the observables commute, the number of ",
 StyleBox["distinct", "TI"],
 " joint-eigenvalue tuples must equal the Hilbert-space dimension, since only \
then does the label pin down a unique state."
}], "Text",ExpressionUUID->"5db8dc97-6156-43ea-9b74-42f41c34d11d"],

Cell[TextData[{
 StyleBox["WL",
  FontWeight->"Bold"],
 " : one observable is not enough. ",
 Cell[BoxData[
  RowBox[{
   StyleBox["Z", "TI"], "\[CircleTimes]", 
   StyleBox["I", "TI"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "58f85827-4796-4f14-9f12-82e9d0980b35"],
 " reads only the first qubit, so it is blind to the second; its spectrum is \
doubly degenerate (two distinct eigenvalues for a four-dimensional space), \
and its eigenbasis is not unique."
}], "Text",ExpressionUUID->"a46f6690-f56b-4031-8feb-d41341f267f3"],

Cell[BoxData[
 RowBox[{"With", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"a", " ", "=", " ", 
     RowBox[{"KroneckerProduct", "[", 
      RowBox[{
       RowBox[{"PauliMatrix", "[", "3", "]"}], ",", " ", 
       RowBox[{"IdentityMatrix", "[", "2", "]"}]}], "]"}]}], "}"}], ",", "\n",
    " ", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"Eigenvalues", "[", "a", "]"}], ",", " ", 
     RowBox[{
      RowBox[{"Length", "@", 
       RowBox[{"DeleteDuplicates", "@", 
        RowBox[{"Eigenvalues", "[", "a", "]"}]}]}], " ", "<", " ", 
      RowBox[{"Length", "[", "a", "]"}]}]}], "}"}]}], "]"}]], "Input",
 CellLabel->
  "In[77]:= ",ExpressionUUID->"739bfb50-716e-48ca-a666-b1bb15331465"],

Cell[TextData[{
 "Adjoin the commuting observable ",
 Cell[BoxData[
  RowBox[{
   StyleBox["I", "TI"], "\[CircleTimes]", 
   StyleBox["Z", "TI"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "f9c25bb5-fe1d-401a-90df-fb376defcc44"],
 ", which reads the second qubit. The joint-eigenvalue tuples are now all \
distinct (four of them, equal to the dimension), so every state is uniquely \
labeled and the pair is a CSCO."
}], "Text",ExpressionUUID->"1568cc8b-22cb-466b-88eb-b8e9e64c2b4a"],

Cell[BoxData[
 RowBox[{"With", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{"a", " ", "=", " ", 
      RowBox[{"KroneckerProduct", "[", 
       RowBox[{
        RowBox[{"PauliMatrix", "[", "3", "]"}], ",", " ", 
        RowBox[{"IdentityMatrix", "[", "2", "]"}]}], "]"}]}], ",", " ", 
     RowBox[{"b", " ", "=", " ", 
      RowBox[{"KroneckerProduct", "[", 
       RowBox[{
        RowBox[{"IdentityMatrix", "[", "2", "]"}], ",", " ", 
        RowBox[{"PauliMatrix", "[", "3", "]"}]}], "]"}]}]}], "}"}], ",", "\n",
    " ", 
   RowBox[{"With", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"joint", " ", "=", " ", 
       RowBox[{"Transpose", "[", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"Diagonal", "[", "a", "]"}], ",", " ", 
          RowBox[{"Diagonal", "[", "b", "]"}]}], "}"}], "]"}]}], "}"}], ",", 
     "\n", "  ", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{
        RowBox[{"a", " ", ".", " ", "b"}], " ", "==", " ", 
        RowBox[{"b", " ", ".", " ", "a"}]}], ",", " ", 
       RowBox[{
        RowBox[{"Length", "@", 
         RowBox[{"DeleteDuplicates", "@", "joint"}]}], " ", "==", " ", 
        RowBox[{"Length", "@", "joint"}]}]}], "}"}]}], "]"}]}], 
  "]"}]], "Input",
 CellLabel->
  "In[78]:= ",ExpressionUUID->"29e1fa09-cd04-4536-9ab4-1ea580519500"],

Cell[TextData[{
 StyleBox["QF",
  FontWeight->"Bold"],
 " : the same construction, with the operators named as strings. ",
 Cell[BoxData[
  RowBox[{
   StyleBox["Z", "TI"], "\[CircleTimes]", 
   StyleBox["I", "TI"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "68adc2f4-c3a0-4249-94b2-1521177578e3"],
 " alone is degenerate,"
}], "Text",ExpressionUUID->"cc52bd83-2f27-48f8-be4f-7846aeb4737f"],

Cell[BoxData[
 RowBox[{"With", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"a", " ", "=", " ", 
     RowBox[{"QuantumOperator", "[", "\"\<ZI\>\"", "]"}]}], "}"}], ",", "\n", 
   " ", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"a", "[", "\"\<Eigenvalues\>\"", "]"}], ",", " ", 
     RowBox[{
      RowBox[{"Length", "@", 
       RowBox[{"DeleteDuplicates", "@", 
        RowBox[{"a", "[", "\"\<Eigenvalues\>\"", "]"}]}]}], " ", "<", " ", 
      RowBox[{"Length", "@", 
       RowBox[{"a", "[", "\"\<Eigenvalues\>\"", "]"}]}]}]}], "}"}]}], 
  "]"}]], "Input",
 CellLabel->
  "In[79]:= ",ExpressionUUID->"8a3efdfb-162d-4378-b901-bf37383f55df"],

Cell[TextData[{
 "and adjoining ",
 Cell[BoxData[
  RowBox[{
   StyleBox["I", "TI"], "\[CircleTimes]", 
   StyleBox["Z", "TI"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "90cf9773-e200-452a-a7b1-cc6cd802340f"],
 " completes the set."
}], "Text",ExpressionUUID->"45308117-328b-4641-b96b-481b465e42ee"],

Cell[BoxData[
 RowBox[{"With", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{"a", " ", "=", " ", 
      RowBox[{"QuantumOperator", "[", "\"\<ZI\>\"", "]"}]}], ",", " ", 
     RowBox[{"b", " ", "=", " ", 
      RowBox[{"QuantumOperator", "[", "\"\<IZ\>\"", "]"}]}]}], "}"}], ",", 
   "\n", " ", 
   RowBox[{"With", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"joint", " ", "=", " ", 
       RowBox[{"Transpose", "[", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"Diagonal", "[", 
           RowBox[{"Normal", "[", 
            RowBox[{"a", "[", "\"\<Matrix\>\"", "]"}], "]"}], "]"}], ",", " ", 
          RowBox[{"Diagonal", "[", 
           RowBox[{"Normal", "[", 
            RowBox[{"b", "[", "\"\<Matrix\>\"", "]"}], "]"}], "]"}]}], "}"}], 
        "]"}]}], "}"}], ",", "\n", "  ", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{
        RowBox[{"a", " ", "@", " ", "b"}], " ", "==", " ", 
        RowBox[{"b", " ", "@", " ", "a"}]}], ",", " ", 
       RowBox[{
        RowBox[{"Length", "@", 
         RowBox[{"DeleteDuplicates", "@", "joint"}]}], " ", "==", " ", 
        RowBox[{"Length", "@", "joint"}]}]}], "}"}]}], "]"}]}], 
  "]"}]], "Input",
 CellLabel->
  "In[80]:= ",ExpressionUUID->"241fd8be-ceaa-4798-a0a6-041380aa1bea"],

Cell[TextData[{
 "The single observable returns two distinct eigenvalues for a \
four-dimensional space (",
 Cell[BoxData["True"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "f34e0f25-e5db-4d3a-9398-602a01ccbb4f"],
 ": degenerate, hence incomplete); the pair returns ",
 Cell[BoxData[
  RowBox[{"{", 
   RowBox[{"True", ",", " ", "True"}], "}"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "8961d3be-5792-496d-b636-4654b8027b10"],
 " (commuting, and its four joint tuples are distinct, so complete). Here the \
joint eigenvalues are read straight off the diagonals because ",
 Cell[BoxData[
  RowBox[{
   StyleBox["Z", "TI"], "\[CircleTimes]", 
   StyleBox["I", "TI"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "e45e1fb2-561e-4a20-87b7-15630a0eaa8d"],
 " and ",
 Cell[BoxData[
  RowBox[{
   StyleBox["I", "TI"], "\[CircleTimes]", 
   StyleBox["Z", "TI"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "d2acbbc5-3b23-45b6-93bc-ac654e008fd9"],
 " are already simultaneously diagonal; in general one first diagonalizes a \
non-degenerate combination ",
 Cell[BoxData[
  RowBox[{
   StyleBox["A", "TI"], "+", 
   StyleBox["c", "TI"], 
   StyleBox["B", "TI"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "e53d88e0-6d1b-421c-83ed-ed9a444188e3"],
 " (as in 2.8) and reads the tuples in that common eigenbasis. The unique \
labels this CSCO assigns are the subject of 2.9b."
}], "Text",ExpressionUUID->"19690e0f-3239-4c8d-8e75-3ef7943ee0e9"],

Cell["\<\
2.9b [MSc] How do I label basis states by the joint spectrum of a CSCO?\
\>", "Subsection",ExpressionUUID->"6a43924b-ea54-4b19-9a80-ce94b5c06f94"],

Cell[TextData[{
 "With ",
 Cell[BoxData[
  RowBox[{
   RowBox[{"{", 
    StyleBox["Z", "TI"], "\[CircleTimes]", 
    StyleBox["I", "TI"]}], ",", 
   RowBox[{
    StyleBox["I", "TI"], "\[CircleTimes]", 
    StyleBox["Z", "TI"], "}"}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "4ba3f19f-0251-4850-8915-ef23e6e724a4"],
 " established as a CSCO (2.9a), its joint eigenvalues are the ",
 StyleBox["quantum numbers", "TI"],
 " that name the basis: each state carries a tuple ",
 Cell[BoxData[
  RowBox[{
   StyleBox["(",
    SpanMaxSize->1], 
   RowBox[{
    SubscriptBox[
     StyleBox["z", "TI"], "1"], ",", 
    SubscriptBox[
     StyleBox["z", "TI"], "2"]}], 
   StyleBox[")",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "ae989b53-eb29-4880-ab58-e2ce95464f43"],
 ", and because the set is complete those tuples are all distinct. Reading \
them off (the operators are simultaneously diagonal) pairs every \
computational basis state with its label."
}], "Text",ExpressionUUID->"43ed1428-2cf8-4492-82dd-c4ad48ad6f6e"],

Cell[TextData[{
 StyleBox["WL",
  FontWeight->"Bold"],
 " : pair each basis state ",
 Cell[BoxData[
  TemplateBox[{
    RowBox[{
      SubscriptBox[
       StyleBox["z", "TI"], "1"], 
      SubscriptBox[
       StyleBox["z", "TI"], "2"]}]},
   "Ket"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "dd5b6829-fd10-4fbf-897e-e06e4a4490e7"],
 " with its joint eigenvalues."
}], "Text",ExpressionUUID->"6fd7cb07-269d-448a-a913-98cd16067e1a"],

Cell[BoxData[
 RowBox[{"With", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{"a", " ", "=", " ", 
      RowBox[{"KroneckerProduct", "[", 
       RowBox[{
        RowBox[{"PauliMatrix", "[", "3", "]"}], ",", " ", 
        RowBox[{"IdentityMatrix", "[", "2", "]"}]}], "]"}]}], ",", " ", 
     RowBox[{"b", " ", "=", " ", 
      RowBox[{"KroneckerProduct", "[", 
       RowBox[{
        RowBox[{"IdentityMatrix", "[", "2", "]"}], ",", " ", 
        RowBox[{"PauliMatrix", "[", "3", "]"}]}], "]"}]}]}], "}"}], ",", "\n",
    " ", 
   RowBox[{"AssociationThread", "[", 
    RowBox[{
     RowBox[{"Tuples", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"0", ",", " ", "1"}], "}"}], ",", " ", "2"}], "]"}], ",", " ", 
     RowBox[{"Transpose", "[", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"Diagonal", "[", "a", "]"}], ",", " ", 
        RowBox[{"Diagonal", "[", "b", "]"}]}], "}"}], "]"}]}], "]"}]}], 
  "]"}]], "Input",
 CellLabel->
  "In[81]:= ",ExpressionUUID->"5a92b3bf-7784-42a8-878f-6c6f684af93b"],

Cell[TextData[{
 StyleBox["QF",
  FontWeight->"Bold"],
 " : the same labels, with the operators named as strings."
}], "Text",ExpressionUUID->"8678874b-15c5-42f8-9e28-52a413652f93"],

Cell[BoxData[
 RowBox[{"With", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{"a", " ", "=", " ", 
      RowBox[{"QuantumOperator", "[", "\"\<ZI\>\"", "]"}]}], ",", " ", 
     RowBox[{"b", " ", "=", " ", 
      RowBox[{"QuantumOperator", "[", "\"\<IZ\>\"", "]"}]}]}], "}"}], ",", 
   "\n", " ", 
   RowBox[{"AssociationThread", "[", 
    RowBox[{
     RowBox[{"Tuples", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"0", ",", " ", "1"}], "}"}], ",", " ", "2"}], "]"}], ",", " ", 
     RowBox[{"Transpose", "[", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"Diagonal", "[", 
         RowBox[{"Normal", "[", 
          RowBox[{"a", "[", "\"\<Matrix\>\"", "]"}], "]"}], "]"}], ",", " ", 
        RowBox[{"Diagonal", "[", 
         RowBox[{"Normal", "[", 
          RowBox[{"b", "[", "\"\<Matrix\>\"", "]"}], "]"}], "]"}]}], "}"}], 
      "]"}]}], "]"}]}], "]"}]], "Input",
 CellLabel->
  "In[82]:= ",ExpressionUUID->"d4cb14b3-50a2-48d9-bd78-5af54e65d0c2"],

Cell[TextData[{
 "Both pair ",
 Cell[BoxData[
  RowBox[{
   TemplateBox[{"00"},
    "Ket"], "\[Rule]", 
   StyleBox["(",
    SpanMaxSize->1], "+", ",", "+", 
   StyleBox[")",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "55b0a910-6a43-4473-b123-06b361a282cd"],
 ", ",
 Cell[BoxData[
  RowBox[{
   TemplateBox[{"01"},
    "Ket"], "\[Rule]", 
   StyleBox["(",
    SpanMaxSize->1], "+", ",", "-", 
   StyleBox[")",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "3def7bfe-1e31-43e9-8efe-fd5518fd1e46"],
 ", ",
 Cell[BoxData[
  RowBox[{
   TemplateBox[{"10"},
    "Ket"], "\[Rule]", 
   StyleBox["(",
    SpanMaxSize->1], "-", ",", "+", 
   StyleBox[")",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "5313ed4d-fdd8-415c-9d98-b5e80ba3ae00"],
 ", ",
 Cell[BoxData[
  RowBox[{
   TemplateBox[{"11"},
    "Ket"], "\[Rule]", 
   StyleBox["(",
    SpanMaxSize->1], "-", ",", "-", 
   StyleBox[")",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "04b4fba7-7b69-44bf-9cbf-b1bb233b523d"],
 ": the four eigenvalue tuples are distinct, so the joint spectrum is a \
complete, unambiguous label for the basis. These tuples are the \
finite-dimensional analogue of the good quantum numbers (like ",
 Cell[BoxData[
  RowBox[{
   StyleBox["n", "TI"], ",", "\[ScriptL]", ",", 
   StyleBox["m", "TI"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "05d5e924-4b85-4ad2-b920-ae6750067689"],
 ") that index states in continuous problems."
}], "Text",ExpressionUUID->"96392f70-54b3-4a9f-988c-061a0f11fd9e"],

Cell[TextData[{
 "2.10a [MSc] How do I define the Hilbert-Schmidt operator inner product ",
 Cell[BoxData[
  RowBox[{
   StyleBox["\[LeftAngleBracket]",
    SpanMaxSize->1], 
   RowBox[{
    StyleBox["A", "TI"], ",", 
    StyleBox["B", "TI"]}], "\[VeryThinSpace]", 
   StyleBox["\[RightAngleBracket]",
    SpanMaxSize->1], "=", 
   StyleBox["Tr",
    FontSlant->"Plain"], 
   StyleBox["[",
    SpanMaxSize->1], 
   RowBox[{
    SuperscriptBox[
     StyleBox["A", "TI"], "\[Dagger]"], 
    StyleBox["B", "TI"]}], 
   StyleBox["]",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "ef68ac49-6153-41a2-a08a-a5abf5bf4040"],
 " and show the Pauli operators are orthogonal?"
}], "Subsection",ExpressionUUID->"f24b0119-ed6d-41ea-aef4-1c377d7e2d94"],

Cell[TextData[{
 "Operators form a Hilbert space under their own inner product, the \
Hilbert-Schmidt product ",
 Cell[BoxData[
  RowBox[{
   StyleBox["\[LeftAngleBracket]",
    SpanMaxSize->1], 
   RowBox[{
    StyleBox["A", "TI"], ",", 
    StyleBox["B", "TI"]}], "\[VeryThinSpace]", 
   StyleBox["\[RightAngleBracket]",
    SpanMaxSize->1], "=", 
   StyleBox["Tr",
    FontSlant->"Plain"], 
   StyleBox["[",
    SpanMaxSize->1], 
   RowBox[{
    SuperscriptBox[
     StyleBox["A", "TI"], "\[Dagger]"], 
    StyleBox["B", "TI"]}], 
   StyleBox["]",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "56da46de-f22c-4ac3-9e03-7720de108665"],
 ". Under it the four operators ",
 Cell[BoxData[
  RowBox[{
   RowBox[{"{", 
    StyleBox["I", "TI"]}], ",", 
   StyleBox["X", "TI"], ",", 
   StyleBox["Y", "TI"], ",", 
   RowBox[{
    StyleBox["Z", "TI"], "}"}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "66ba07cf-34b9-48b2-a63c-476ca2c1a7d2"],
 " are mutually orthogonal, each of squared norm ",
 Cell[BoxData[
  RowBox[{
   StyleBox["\[LeftAngleBracket]",
    SpanMaxSize->1], 
   RowBox[{
    SubscriptBox[
     StyleBox["\[Sigma]", "TI"], 
     StyleBox["j", "TI"]], ",", 
    SubscriptBox[
     StyleBox["\[Sigma]", "TI"], 
     StyleBox["j", "TI"]]}], 
   StyleBox["\[RightAngleBracket]",
    SpanMaxSize->1], "=", "2"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "72a5f744-70a2-45b2-a9e2-24dfcf53da86"],
 "."
}], "Text",ExpressionUUID->"c3556de8-b0b0-4cd1-9071-3d2062858b1d"],

Cell[TextData[{
 StyleBox["WL",
  FontWeight->"Bold"],
 " : the Gram matrix ",
 Cell[BoxData[
  RowBox[{
   StyleBox["\[LeftAngleBracket]",
    SpanMaxSize->1], 
   RowBox[{
    SubscriptBox[
     StyleBox["\[Sigma]", "TI"], 
     StyleBox["i", "TI"]], ",", 
    SubscriptBox[
     StyleBox["\[Sigma]", "TI"], 
     StyleBox["j", "TI"]]}], 
   StyleBox["\[RightAngleBracket]",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "27b78174-81bf-497f-b6c6-9e6acbcb56ac"],
 " over ",
 Cell[BoxData[
  RowBox[{
   RowBox[{"{", 
    StyleBox["I", "TI"]}], ",", 
   StyleBox["X", "TI"], ",", 
   StyleBox["Y", "TI"], ",", 
   RowBox[{
    StyleBox["Z", "TI"], "}"}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "8103ff58-10db-45fa-9c80-5e29c4d18a10"],
 "."
}], "Text",ExpressionUUID->"3c72bf3a-1aa9-452c-95ea-0ba009004166"],

Cell[BoxData[
 RowBox[{"Table", "[", 
  RowBox[{
   RowBox[{"Tr", "[", 
    RowBox[{
     RowBox[{"ConjugateTranspose", "[", 
      RowBox[{"PauliMatrix", "[", "i", "]"}], "]"}], " ", ".", " ", 
     RowBox[{"PauliMatrix", "[", "j", "]"}]}], "]"}], ",", " ", 
   RowBox[{"{", 
    RowBox[{"i", ",", " ", "0", ",", " ", "3"}], "}"}], ",", " ", 
   RowBox[{"{", 
    RowBox[{"j", ",", " ", "0", ",", " ", "3"}], "}"}]}], "]"}]], "Input",
 CellLabel->
  "In[83]:= ",ExpressionUUID->"28bbe98b-9cbc-4807-b309-fd8779db5f19"],

Cell[TextData[{
 StyleBox["QF",
  FontWeight->"Bold"],
 " : the same inner product on ",
 Cell[BoxData["QuantumOperator"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "eba59230-a8e5-4ea5-9dbf-688506257861"],
 "s, ",
 Cell[BoxData[
  RowBox[{
   StyleBox["Tr",
    FontSlant->"Plain"], 
   StyleBox["[",
    SpanMaxSize->1], 
   RowBox[{
    SuperscriptBox[
     StyleBox["A", "TI"], "\[Dagger]"], 
    StyleBox["B", "TI"]}], 
   StyleBox["]",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "1a98c7e2-ae90-449d-b9f1-a0899b958ba6"],
 " being the trace of the composed operator ",
 Cell[BoxData[
  RowBox[{
   SuperscriptBox[
    StyleBox["A", "TI"], "\[Dagger]"], 
   StyleBox["B", "TI"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "651891d3-3ec3-4ea3-800d-88f08b6d5831"],
 "."
}], "Text",ExpressionUUID->"03a488fe-ab16-48a2-a79f-64467130b6db"],

Cell[BoxData[
 RowBox[{"With", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"paulis", " ", "=", " ", 
     RowBox[{"QuantumOperator", " ", "/@", " ", 
      RowBox[{"{", 
       RowBox[{"\"\<I\>\"", ",", " ", "\"\<X\>\"", ",", " ", "\"\<Y\>\"", ",",
         " ", "\"\<Z\>\""}], "}"}]}]}], "}"}], ",", "\n", " ", 
   RowBox[{"Outer", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"Tr", "[", 
       RowBox[{"Normal", "[", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{
           RowBox[{"#1", "[", "\"\<Dagger\>\"", "]"}], " ", "@", " ", "#2"}], 
          ")"}], "[", "\"\<Matrix\>\"", "]"}], "]"}], "]"}], " ", "&"}], ",", 
     " ", "paulis", ",", " ", "paulis", ",", " ", "1"}], "]"}]}], 
  "]"}]], "Input",
 CellLabel->
  "In[84]:= ",ExpressionUUID->"4476c1ad-d96d-42c5-844c-c917b2c8ed4f"],

Cell[TextData[{
 "Both return ",
 Cell[BoxData[
  RowBox[{"2", " ", 
   SubscriptBox["\|01d7d9", "4"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "3e6e2c42-ca7b-4d0e-9c0f-1461e01dc01b"],
 ": the operators are mutually orthogonal (",
 Cell[BoxData[
  RowBox[{
   StyleBox["\[LeftAngleBracket]",
    SpanMaxSize->1], 
   RowBox[{
    SubscriptBox[
     StyleBox["\[Sigma]", "TI"], 
     StyleBox["i", "TI"]], ",", 
    SubscriptBox[
     StyleBox["\[Sigma]", "TI"], 
     StyleBox["j", "TI"]]}], 
   StyleBox["\[RightAngleBracket]",
    SpanMaxSize->1], "=", "0"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "c913e80e-91a1-40b7-979e-f349768cac8a"],
 " for ",
 Cell[BoxData[
  RowBox[{
   StyleBox["i", "TI"], "\[NotEqual]", 
   StyleBox["j", "TI"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "1c0f32ef-69a3-4129-9464-3a46b3480012"],
 ") and each has squared norm ",
 Cell[BoxData["2"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "efdb3512-0caa-47a2-883c-0a1338429560"],
 ", so ",
 Cell[BoxData[
  RowBox[{
   RowBox[{"{", 
    StyleBox["I", "TI"]}], ",", 
   StyleBox["X", "TI"], ",", 
   StyleBox["Y", "TI"], ",", 
   RowBox[{
    StyleBox["Z", "TI"], "}", "/", 
    SqrtBox["2"]}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "ba77204a-8d86-4d3e-bdf1-4618696e9b31"],
 " is an orthonormal basis of the ",
 Cell[BoxData[
  RowBox[{"2", "\[Times]", "2"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "e38052e1-4280-4c55-a34f-52246e8fc2e3"],
 " operator space."
}], "Text",ExpressionUUID->"5b63b380-5663-4862-9d26-22cd16ece641"],

Cell["2.10b [MSc] How do I expand an operator in the Pauli basis?", \
"Subsection",ExpressionUUID->"9a5a1303-2663-4ae0-b935-852cd9aa4db6"],

Cell[TextData[{
 "Because ",
 Cell[BoxData[
  RowBox[{
   RowBox[{"{", 
    StyleBox["I", "TI"]}], ",", 
   StyleBox["X", "TI"], ",", 
   StyleBox["Y", "TI"], ",", 
   RowBox[{
    StyleBox["Z", "TI"], "}"}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "caefa14a-f0a5-43db-806c-0ef49b60e9db"],
 " is orthogonal under the Hilbert-Schmidt product, any ",
 Cell[BoxData[
  RowBox[{"2", "\[Times]", "2"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "0788acf3-0b14-447c-86f3-cf2838a23f1d"],
 " operator ",
 Cell[BoxData[
  StyleBox["A", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "2f6038a6-8b0b-4fbb-a31a-2896d08068ed"],
 " has a unique Pauli expansion ",
 Cell[BoxData[
  RowBox[{
   StyleBox["A", "TI"], "=", 
   UnderscriptBox["\[Sum]", 
    StyleBox["j", "TI"],
    LimitsPositioning->False], 
   SubscriptBox[
    StyleBox["c", "TI"], 
    StyleBox["j", "TI"]], " ", 
   SubscriptBox[
    StyleBox["\[Sigma]", "TI"], 
    StyleBox["j", "TI"]]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "f8b4e6ba-848c-4ea2-8fe4-8cfb40f610c7"],
 " with coefficients ",
 Cell[BoxData[
  RowBox[{
   SubscriptBox[
    StyleBox["c", "TI"], 
    StyleBox["j", "TI"]], "=", 
   FractionBox["1", "2"], 
   StyleBox["Tr",
    FontSlant->"Plain"], 
   StyleBox["[",
    SpanMaxSize->1], 
   RowBox[{
    SubscriptBox[
     StyleBox["\[Sigma]", "TI"], 
     StyleBox["j", "TI"]], 
    StyleBox["A", "TI"]}], 
   StyleBox["]",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "a3764f6b-5bb5-4fa4-bbbd-1fbfa4bd213f"],
 " (the ",
 Cell[BoxData[
  FractionBox["1", "2"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "8297a132-31e7-4ac3-8fc5-4aa72ffbd732"],
 " is ",
 Cell[BoxData[
  RowBox[{"1", "/", 
   StyleBox["\[LeftAngleBracket]",
    SpanMaxSize->1], 
   RowBox[{
    SubscriptBox[
     StyleBox["\[Sigma]", "TI"], 
     StyleBox["j", "TI"]], ",", 
    SubscriptBox[
     StyleBox["\[Sigma]", "TI"], 
     StyleBox["j", "TI"]]}], 
   StyleBox["\[RightAngleBracket]",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "3ec220a6-062b-4ee0-911f-f55473da8b2a"],
 ")."
}], "Text",ExpressionUUID->"052fbc5d-fdae-40e5-a7be-cb5e07ec9267"],

Cell[TextData[{
 StyleBox["WL",
  FontWeight->"Bold"],
 " : compute the four coefficients directly from the definition."
}], "Text",ExpressionUUID->"1428d6a8-dd82-403d-87fc-ed591ddd508d"],

Cell[BoxData[
 RowBox[{"With", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"aa", " ", "=", " ", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"a1", ",", " ", 
         RowBox[{"a2", " ", "+", " ", 
          RowBox[{"I", " ", "a3"}]}]}], "}"}], ",", " ", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"a2", " ", "-", " ", 
          RowBox[{"I", " ", "a3"}]}], ",", " ", "a4"}], "}"}]}], "}"}]}], 
    "}"}], ",", "\n", " ", 
   RowBox[{"AssociationThread", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"\"\<I\>\"", ",", " ", "\"\<X\>\"", ",", " ", "\"\<Y\>\"", ",", 
       " ", "\"\<Z\>\""}], "}"}], ",", " ", 
     RowBox[{"FullSimplify", " ", "@", " ", 
      RowBox[{"Table", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"Tr", "[", 
          RowBox[{
           RowBox[{"ConjugateTranspose", "[", 
            RowBox[{"PauliMatrix", "[", "j", "]"}], "]"}], " ", ".", " ", 
           "aa"}], "]"}], "/", "2"}], ",", " ", 
        RowBox[{"{", 
         RowBox[{"j", ",", " ", "0", ",", " ", "3"}], "}"}]}], "]"}]}]}], 
    "]"}]}], "]"}]], "Input",
 CellLabel->
  "In[85]:= ",ExpressionUUID->"cdf943e8-7095-4120-8a62-20d76f77a8db"],

Cell[TextData[{
 StyleBox["QF",
  FontWeight->"Bold"],
 " : the operator decomposes itself."
}], "Text",ExpressionUUID->"4f941a57-beca-4980-88bf-669163f3e595"],

Cell[BoxData[
 RowBox[{"FullSimplify", " ", "/@", " ", 
  RowBox[{
   RowBox[{"QuantumOperator", "[", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"a1", ",", " ", 
        RowBox[{"a2", " ", "+", " ", 
         RowBox[{"I", " ", "a3"}]}]}], "}"}], ",", " ", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"a2", " ", "-", " ", 
         RowBox[{"I", " ", "a3"}]}], ",", " ", "a4"}], "}"}]}], "}"}], "]"}], 
   "[", "\"\<PauliDecompose\>\"", "]"}]}]], "Input",
 CellLabel->
  "In[86]:= ",ExpressionUUID->"acf539ea-dd25-4ca2-9109-ccdf8fc3f7c5"],

Cell[TextData[{
 "Both return the coefficients ",
 Cell[BoxData[
  RowBox[{
   RowBox[{
    RowBox[{"{", 
     StyleBox["I", "TI"]}], ":", 
    FractionBox[
     RowBox[{
      SubscriptBox[
       StyleBox["a", "TI"], "1"], "+", 
      SubscriptBox[
       StyleBox["a", "TI"], "4"]}], "2"]}], ",", " ", 
   RowBox[{
    StyleBox["X", "TI"], ":", 
    SubscriptBox[
     StyleBox["a", "TI"], "2"]}], ",", " ", 
   RowBox[{
    StyleBox["Y", "TI"], ":", 
    RowBox[{"-", 
     SubscriptBox[
      StyleBox["a", "TI"], "3"]}]}], ",", " ", 
   RowBox[{
    StyleBox["Z", "TI"], ":", 
    RowBox[{
     FractionBox[
      RowBox[{
       SubscriptBox[
        StyleBox["a", "TI"], "1"], "-", 
       SubscriptBox[
        StyleBox["a", "TI"], "4"]}], "2"], "}"}]}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "d5d5eea4-37cf-4cb1-93e9-86766873968c"],
 ": the generic Hermitian operator is exactly ",
 Cell[BoxData[
  RowBox[{
   FractionBox[
    RowBox[{
     SubscriptBox[
      StyleBox["a", "TI"], "1"], "+", 
     SubscriptBox[
      StyleBox["a", "TI"], "4"]}], "2"], 
   StyleBox["I", "TI"], "+", 
   SubscriptBox[
    StyleBox["a", "TI"], "2"], 
   SubscriptBox[
    StyleBox["\[Sigma]", "TI"], 
    StyleBox["x", "TI"]], "-", 
   SubscriptBox[
    StyleBox["a", "TI"], "3"], 
   SubscriptBox[
    StyleBox["\[Sigma]", "TI"], 
    StyleBox["y", "TI"]], "+", 
   FractionBox[
    RowBox[{
     SubscriptBox[
      StyleBox["a", "TI"], "1"], "-", 
     SubscriptBox[
      StyleBox["a", "TI"], "4"]}], "2"], 
   SubscriptBox[
    StyleBox["\[Sigma]", "TI"], 
    StyleBox["z", "TI"]]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "4c403bdc-c0ee-43cf-ba88-448c86cbbaf7"],
 "."
}], "Text",ExpressionUUID->"b5d7a3d0-c26d-409a-85f2-6fee2146b345"],

Cell["\<\
2.11 [BSc] How do I bound the ground-state energy from above using a trial \
state (the Rayleigh-Ritz variational method)?\
\>", "Subsection",ExpressionUUID->"a7546392-516b-466d-b058-38cba669b661"],

Cell[TextData[{
 "The variational method estimates the ground-state energy ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["E", "TI"], "0"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "6a015dae-b84d-437f-92c7-26436ca99659"],
 " from above using a guessed ",
 StyleBox["trial state", "TI"],
 " ",
 Cell[BoxData[
  TemplateBox[{
    StyleBox["\[Psi]", "TI"]},
   "Ket"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "cf60e354-f86a-443f-af09-8bf9440f0eb9"],
 ", without solving the eigenproblem. The key fact is that the ",
 StyleBox["Rayleigh quotient",
  FontWeight->"Bold"],
 " is an upper bound on ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["E", "TI"], "0"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "b4eb82dd-864d-4940-9bb1-7cfc283cdd65"],
 ","
}], "Text",ExpressionUUID->"8785189a-088c-48e5-a162-091816bdc66a"],

Cell[BoxData[
 PaneBox[
  RowBox[{
   RowBox[{
    RowBox[{
     StyleBox["E", "TI"], 
     StyleBox["[",
      SpanMaxSize->1], 
     StyleBox["\[Psi]", "TI"], 
     StyleBox["]",
      SpanMaxSize->1]}], "\[ThickSpace]", "=", "\[ThickSpace]", 
    RowBox[{
     FractionBox[
      RowBox[{
       TemplateBox[{
         StyleBox["\[Psi]", "TI"]},
        "Bra"], 
       StyleBox["H", "TI"], 
       TemplateBox[{
         StyleBox["\[Psi]", "TI"]},
        "Ket"]}], 
      TemplateBox[{
        StyleBox["\[Psi]", "TI"], 
        StyleBox["\[Psi]", "TI"]},
       "BraKet"]], "\[ThickSpace]", "\[GreaterEqual]", "\[ThickSpace]", 
     SubscriptBox[
      StyleBox["E", "TI"], "0"]}]}], ","}],
  Alignment->Center,
  ImageSize->Full]], "DisplayFormula",ExpressionUUID->"fe04af6e-d9ea-4b3c-\
997b-2e3eda535175"],

Cell[TextData[{
 "with equality only when ",
 Cell[BoxData[
  TemplateBox[{
    StyleBox["\[Psi]", "TI"]},
   "Ket"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "6fbcd223-f951-4ab6-847a-40b8e026d3bb"],
 " is the ground state. (Expanding ",
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     StyleBox["\[Psi]", "TI"]},
    "Ket"], "=", 
   RowBox[{
    UnderscriptBox["\[Sum]", 
     StyleBox["n", "TI"],
     LimitsPositioning->False], 
    RowBox[{
     SubscriptBox[
      StyleBox["c", "TI"], 
      StyleBox["n", "TI"]], 
     TemplateBox[{
       StyleBox["n", "TI"]},
      "Ket"]}]}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "a65f87a4-d9e1-47fe-88e5-e292a9af9726"],
 " in the energy eigenbasis, ",
 Cell[BoxData[
  RowBox[{
   RowBox[{
    StyleBox["H", "TI"], 
    TemplateBox[{
      StyleBox["n", "TI"]},
     "Ket"]}], "=", 
   RowBox[{
    SubscriptBox[
     StyleBox["E", "TI"], 
     StyleBox["n", "TI"]], 
    TemplateBox[{
      StyleBox["n", "TI"]},
     "Ket"]}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "bcfcc58b-604b-4e39-9570-952456841bc8"],
 " with ",
 Cell[BoxData[
  RowBox[{
   SubscriptBox[
    StyleBox["E", "TI"], "0"], "\[LessEqual]", 
   SubscriptBox[
    StyleBox["E", "TI"], "1"], "\[LessEqual]", "\[CenterDot]", 
   StyleBox["s", "TI"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "f560b7c7-52b1-49ca-82ae-4c48b9d4640f"],
 ", makes ",
 Cell[BoxData[
  RowBox[{
   StyleBox["E", "TI"], 
   StyleBox["[",
    SpanMaxSize->1], 
   StyleBox["\[Psi]", "TI"], 
   StyleBox["]",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "f105e40f-f66b-4209-b2c8-59c47f6cf596"],
 " a weighted average of the ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["E", "TI"], 
   StyleBox["n", "TI"]]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "572e2f20-fe77-49b8-8ba2-0b0b0e41ea95"],
 ", which cannot fall below the smallest.) ",
 StyleBox["Rayleigh-Ritz", "TI"],
 " is the recipe that turns the bound into an estimate: take a parametrized \
family of trial states and ",
 StyleBox["minimize",
  FontWeight->"Bold"],
 " ",
 Cell[BoxData[
  RowBox[{
   StyleBox["E", "TI"], 
   StyleBox["[",
    SpanMaxSize->1], 
   StyleBox["\[Psi]", "TI"], 
   StyleBox["]",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "43bb609a-0645-4ee0-a0ae-6942642128e9"],
 " over the parameters; the minimum is the lowest, hence best, upper bound \
that family can give. Below the trial state is normalized, so ",
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     StyleBox["\[Psi]", "TI"], 
     StyleBox["\[Psi]", "TI"]},
    "BraKet"], "=", "1"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "3d88821d-71c7-43be-a6b2-3c4510fc8ca0"],
 " and ",
 Cell[BoxData[
  RowBox[{
   RowBox[{
    StyleBox["E", "TI"], 
    StyleBox["[",
     SpanMaxSize->1], 
    StyleBox["\[Psi]", "TI"], 
    StyleBox["]",
     SpanMaxSize->1]}], "=", 
   RowBox[{
    TemplateBox[{
      StyleBox["\[Psi]", "TI"]},
     "Bra"], 
    StyleBox["H", "TI"], 
    TemplateBox[{
      StyleBox["\[Psi]", "TI"]},
     "Ket"]}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "259954b1-95a8-40fd-a0a9-4f6a50855b10"],
 "."
}], "Text",ExpressionUUID->"3bd4e9df-275a-4531-833e-7213b1929544"],

Cell[TextData[{
 StyleBox["WL",
  FontWeight->"Bold"],
 " : the trial energy over a one-parameter family."
}], "Text",ExpressionUUID->"c19ac721-dc8d-4863-b172-cee7f27908b2"],

Cell[BoxData[
 RowBox[{"exp", " ", "=", " ", 
  RowBox[{"With", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{"h", " ", "=", " ", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"1", ",", " ", "1"}], "}"}], ",", " ", 
         RowBox[{"{", 
          RowBox[{"1", ",", " ", 
           RowBox[{"-", "1"}]}], "}"}]}], "}"}]}], ",", " ", 
      RowBox[{"psi", " ", "=", " ", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"Cos", "[", "t", "]"}], ",", " ", 
         RowBox[{"Sin", "[", "t", "]"}]}], "}"}]}]}], "}"}], ",", "\n", "  ", 
    
    RowBox[{"FullSimplify", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"Conjugate", "[", "psi", "]"}], " ", ".", " ", "h", " ", ".", 
       " ", "psi"}], ",", " ", 
      RowBox[{"t", " ", "\[Element]", " ", "Reals"}]}], "]"}]}], 
   "]"}]}]], "Input",
 CellLabel->
  "In[87]:= ",ExpressionUUID->"d7768715-729e-4dcf-8b78-dfa8165d08d7"],

Cell["The true ground energy is the lowest eigenvalue.", "Text",ExpressionUUID->"56c1e74d-f175-4b36-a29e-4c97753a905e"],

Cell[BoxData[
 RowBox[{"e0", " ", "=", " ", 
  RowBox[{"Min", "[", 
   RowBox[{"Eigenvalues", "[", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"1", ",", " ", "1"}], "}"}], ",", " ", 
      RowBox[{"{", 
       RowBox[{"1", ",", " ", 
        RowBox[{"-", "1"}]}], "}"}]}], "}"}], "]"}], "]"}]}]], "Input",
 CellLabel->
  "In[88]:= ",ExpressionUUID->"9383a77a-c3c7-4f69-8c5a-f75957e29b5f"],

Cell["Minimizing the trial energy reaches that bound.", "Text",ExpressionUUID->"9587ca8e-cf3d-49aa-a1cf-4fd67bd325f7"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"Minimize", "[", 
    RowBox[{"exp", ",", " ", "t"}], "]"}], "[", 
   RowBox[{"[", "1", "]"}], "]"}], " ", "==", " ", "e0"}]], "Input",
 CellLabel->
  "In[89]:= ",ExpressionUUID->"370fe5ec-d223-4fbd-a0ec-d4fd78fee7e5"],

Cell[TextData[{
 StyleBox["QF",
  FontWeight->"Bold"],
 " : the Hamiltonian as a ",
 Cell[BoxData["QuantumOperator"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "d65a4ba3-532b-47e4-8359-2544cdb3584d"],
 ", the trial energy as a bra-operator-ket scalar."
}], "Text",ExpressionUUID->"9328f540-0e3d-4311-8adf-522b3db828d8"],

Cell[BoxData[
 RowBox[{"expQF", " ", "=", " ", 
  RowBox[{"With", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{"h", " ", "=", " ", 
       RowBox[{"QuantumOperator", "[", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{"1", ",", " ", "1"}], "}"}], ",", " ", 
          RowBox[{"{", 
           RowBox[{"1", ",", " ", 
            RowBox[{"-", "1"}]}], "}"}]}], "}"}], "]"}]}], ",", " ", 
      RowBox[{"ps", " ", "=", " ", 
       RowBox[{"QuantumState", "[", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"Cos", "[", "t", "]"}], ",", " ", 
          RowBox[{"Sin", "[", "t", "]"}]}], "}"}], "]"}]}]}], "}"}], ",", 
    "\n", "  ", 
    RowBox[{"FullSimplify", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"(", 
        RowBox[{
         RowBox[{"ps", "[", "\"\<Dagger\>\"", "]"}], " ", "@", " ", 
         RowBox[{"h", " ", "@", " ", "ps"}]}], ")"}], "[", "\"\<Scalar\>\"", 
       "]"}], ",", " ", 
      RowBox[{"t", " ", "\[Element]", " ", "Reals"}]}], "]"}]}], 
   "]"}]}]], "Input",
 CellLabel->
  "In[90]:= ",ExpressionUUID->"e0d493e4-2a5c-485a-890f-9110b3776be1"],

Cell["The ground energy from the operator's eigenvalues.", "Text",ExpressionUUID->"53d74674-51eb-47f1-a51b-a4ef9ac9be22"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"QuantumOperator", "[", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"1", ",", " ", "1"}], "}"}], ",", " ", 
      RowBox[{"{", 
       RowBox[{"1", ",", " ", 
        RowBox[{"-", "1"}]}], "}"}]}], "}"}], "]"}], 
   "[", "\"\<Eigenvalues\>\"", "]"}], " ", "//", " ", "Min"}]], "Input",
 CellLabel->
  "In[91]:= ",ExpressionUUID->"b910c0c7-dfcf-4584-a566-31e8348535c5"],

Cell["And the variational minimum reaches it.", "Text",ExpressionUUID->"d72c5dd4-9ca7-4982-8e59-1dbfa2300202"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"Minimize", "[", 
    RowBox[{"expQF", ",", " ", "t"}], "]"}], "[", 
   RowBox[{"[", "1", "]"}], "]"}], " ", "==", " ", 
  RowBox[{"Min", "[", 
   RowBox[{
    RowBox[{"QuantumOperator", "[", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"1", ",", " ", "1"}], "}"}], ",", " ", 
       RowBox[{"{", 
        RowBox[{"1", ",", " ", 
         RowBox[{"-", "1"}]}], "}"}]}], "}"}], "]"}], 
    "[", "\"\<Eigenvalues\>\"", "]"}], "]"}]}]], "Input",
 CellLabel->
  "In[92]:= ",ExpressionUUID->"1b281f0a-5e48-4518-87f2-2edf7f4e481f"],

Cell[TextData[{
 "Both give the trial energy ",
 Cell[BoxData[
  RowBox[{
   StyleBox["cos",
    FontSlant->"Plain"], "\[ThinSpace]", "2", 
   StyleBox["t", "TI"], "+", 
   StyleBox["sin",
    FontSlant->"Plain"], "\[ThinSpace]", "2", 
   StyleBox["t", "TI"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "5a7bfa19-ec0b-43ce-9561-e8038149ea06"],
 ", the true ground energy ",
 Cell[BoxData[
  RowBox[{"-", 
   SqrtBox["2"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "90e75ce7-091e-43b3-b1fa-253402769018"],
 ", and ",
 Cell[BoxData["True"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "5c1d9ac0-ee3f-4bc9-83a1-7a4e58ea2ee5"],
 ": the minimum over the trial family reaches ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["E", "TI"], "0"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "2f8d0c54-aebb-40ef-9b13-36970a063d11"],
 ", so the variational estimate is an upper bound that is tight here."
}], "Text",ExpressionUUID->"5cbc319e-da0d-47e6-9537-4958a02d792a"],

Cell["\<\
2.12 [MSc] How do I compute first- and second-order energy shifts by \
non-degenerate time-independent perturbation theory?\
\>", "Subsection",ExpressionUUID->"ab932822-ce41-4a6d-b9a6-9f025607b814"],

Cell[TextData[{
 "Perturbation theory finds the spectrum of a Hamiltonian ",
 Cell[BoxData[
  RowBox[{
   StyleBox["H", "TI"], "=", 
   SubscriptBox[
    StyleBox["H", "TI"], "0"], "+", 
   StyleBox["\[Lambda]", "TI"], 
   StyleBox["V", "TI"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "9b31152f-5043-4f1c-8051-43bfb63dd9d9"],
 " that sits a small perturbation ",
 Cell[BoxData[
  StyleBox[
   RowBox[{"\[Lambda]", "V"}], "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "5a037cb0-5116-4f6a-8721-7b79d9dd5ae9"],
 " away from a solvable one ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["H", "TI"], "0"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "1a416f85-d4eb-4b53-8b5b-4d9cd3aaca12"],
 ", whose eigenstates ",
 Cell[BoxData[
  TemplateBox[{
    StyleBox["n", "TI"]},
   "Ket"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "d2cb319f-58db-4350-9542-bbd5e7c8c048"],
 " and energies ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["E", "TI"], 
   StyleBox["n", "TI"]]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "4101aa56-b949-4116-8b7a-b21b3a81d825"],
 " are already known. Turning on ",
 Cell[BoxData[
  StyleBox["\[Lambda]", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "51ce937a-9ce9-4da3-9003-6a4146f89103"],
 " shifts each energy, and the shift is expanded in powers of ",
 Cell[BoxData[
  StyleBox["\[Lambda]", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "71ec37be-60f9-40c8-82f4-9009ab1bf75a"],
 ","
}], "Text",ExpressionUUID->"3c0f7fb8-f53b-4215-a1c6-14b0035679da"],

Cell[BoxData[
 PaneBox[
  RowBox[{
   RowBox[{
    SubscriptBox[
     StyleBox["E", "TI"], 
     StyleBox["n", "TI"]], 
    StyleBox["(",
     SpanMaxSize->1], 
    StyleBox["\[Lambda]", "TI"], 
    StyleBox[")",
     SpanMaxSize->1], "\[ThickSpace]", "=", "\[ThickSpace]", 
    SubscriptBox[
     StyleBox["E", "TI"], 
     StyleBox["n", "TI"]], "+", 
    StyleBox["\[Lambda]", "TI"], " ", 
    SubsuperscriptBox[
     StyleBox["E", "TI"], 
     StyleBox["n", "TI"], 
     RowBox[{
      StyleBox["(",
       SpanMaxSize->1], "1", 
      StyleBox[")",
       SpanMaxSize->1]}]], "+", 
    SuperscriptBox[
     StyleBox["\[Lambda]", "TI"], "2"], 
    SubsuperscriptBox[
     StyleBox["E", "TI"], 
     StyleBox["n", "TI"], 
     RowBox[{
      StyleBox["(",
       SpanMaxSize->1], "2", 
      StyleBox[")",
       SpanMaxSize->1]}]], "+", "\[CenterEllipsis]"}], ","}],
  Alignment->Center,
  ImageSize->Full]], "DisplayFormula",ExpressionUUID->"334dc6b9-a6a3-4a92-\
a4dc-7fd0f2705c43"],

Cell["\<\
with the first- and second-order coefficients (the Rayleigh-Schrodinger \
shifts)\
\>", "Text",ExpressionUUID->"05f0a668-34f3-4689-a2e7-14256f2686de"],

Cell[BoxData[
 PaneBox[
  RowBox[{
   RowBox[{
    SubsuperscriptBox[
     StyleBox["E", "TI"], 
     StyleBox["n", "TI"], 
     RowBox[{
      StyleBox["(",
       SpanMaxSize->1], "1", 
      StyleBox[")",
       SpanMaxSize->1]}]], "=", 
    RowBox[{
     TemplateBox[{
       StyleBox["n", "TI"]},
      "Bra"], 
     StyleBox["V", "TI"], 
     TemplateBox[{
       StyleBox["n", "TI"]},
      "Ket"]}]}], ",", 
   "\[NonBreakingSpace]\[NonBreakingSpace]\[NonBreakingSpace]\
\[NonBreakingSpace]", 
   RowBox[{
    SubsuperscriptBox[
     StyleBox["E", "TI"], 
     StyleBox["n", "TI"], 
     RowBox[{
      StyleBox["(",
       SpanMaxSize->1], "2", 
      StyleBox[")",
       SpanMaxSize->1]}]], "=", 
    RowBox[{
     UnderscriptBox["\[Sum]", 
      RowBox[{
       StyleBox["m", "TI"], "\[NotEqual]", 
       StyleBox["n", "TI"]}],
      LimitsPositioning->False], 
     RowBox[{
      FractionBox[
       SuperscriptBox[GridBox[{
          {
           RowBox[{
            TemplateBox[{
              StyleBox["m", "TI"]},
             "Bra"], 
            StyleBox["V", "TI"], 
            TemplateBox[{
              StyleBox["n", "TI"]},
             "Ket"]}]}
         },
         GridBoxDividers->{"Columns" -> {True, True}, "Rows" -> {}},
         GridBoxSpacings->{"Columns" -> {{0.15}}}], "2"], 
       RowBox[{
        SubscriptBox[
         StyleBox["E", "TI"], 
         StyleBox["n", "TI"]], "-", 
        SubscriptBox[
         StyleBox["E", "TI"], 
         StyleBox["m", "TI"]]}]], "."}]}]}]}],
  Alignment->Center,
  ImageSize->Full]], "DisplayFormula",ExpressionUUID->"c7a56038-ac7d-4250-\
a811-3711d0aade3e"],

Cell[TextData[{
 "The first order is just the diagonal matrix element of ",
 Cell[BoxData[
  StyleBox["V", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "9d35c2c8-f67d-49bf-b1f7-acc30ab419fa"],
 " in the unperturbed state ",
 Cell[BoxData[
  TemplateBox[{
    StyleBox["n", "TI"]},
   "Ket"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "7343013c-3842-4a6e-b75b-a72b16b1d607"],
 "; the second order sums the squared off-diagonal couplings ",
 Cell[BoxData[
  SuperscriptBox[GridBox[{
     {
      RowBox[{
       TemplateBox[{
         StyleBox["m", "TI"]},
        "Bra"], 
       StyleBox["V", "TI"], 
       TemplateBox[{
         StyleBox["n", "TI"]},
        "Ket"]}]}
    },
    GridBoxDividers->{"Columns" -> {True, True}, "Rows" -> {}},
    GridBoxSpacings->{"Columns" -> {{0.15}}}], "2"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "92897bc4-595d-4e62-bfd8-575398804ae4"],
 " over the other states, each divided by the energy gap ",
 Cell[BoxData[
  RowBox[{
   SubscriptBox[
    StyleBox["E", "TI"], 
    StyleBox["n", "TI"]], "-", 
   SubscriptBox[
    StyleBox["E", "TI"], 
    StyleBox["m", "TI"]]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "d7547b9c-c446-4645-8f51-e58567403a20"],
 ". ",
 StyleBox["Non-degenerate", "TI"],
 " means the unperturbed energies ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["E", "TI"], 
   StyleBox["n", "TI"]]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "30fcd08b-6fbf-4bfd-af70-43ad10d60ba6"],
 " are distinct, so those gaps never vanish; degenerate levels require the \
separate treatment of 2.13."
}], "Text",ExpressionUUID->"ff6b619c-74c6-4493-be9c-b07adb7cb863"],

Cell[TextData[{
 StyleBox["WL",
  FontWeight->"Bold"],
 " : the first-order shifts are the diagonal matrix elements."
}], "Text",ExpressionUUID->"8aee8d0f-2fda-4463-a174-3d0a484fca2e"],

Cell[BoxData[
 RowBox[{"With", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{"V", " ", "=", " ", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"w", ",", " ", "v"}], "}"}], ",", " ", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"Conjugate", "[", "v", "]"}], ",", " ", 
          RowBox[{"-", "w"}]}], "}"}]}], "}"}]}], ",", " ", 
     RowBox[{"basis", " ", "=", " ", 
      RowBox[{"IdentityMatrix", "[", "2", "]"}]}]}], "}"}], ",", "\n", " ", 
   RowBox[{"Table", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"Conjugate", "[", 
       RowBox[{"basis", "[", 
        RowBox[{"[", "n", "]"}], "]"}], "]"}], " ", ".", " ", "V", " ", ".", 
      " ", 
      RowBox[{"basis", "[", 
       RowBox[{"[", "n", "]"}], "]"}]}], ",", " ", 
     RowBox[{"{", 
      RowBox[{"n", ",", " ", "2"}], "}"}]}], "]"}]}], "]"}]], "Input",
 CellLabel->
  "In[93]:= ",ExpressionUUID->"6be584d7-6c96-48a3-a2aa-6fc6097a9d47"],

Cell["\<\
The second-order shifts sum the off-diagonal couplings over the spectrum.\
\>", "Text",ExpressionUUID->"c059fad5-9d30-42e9-835b-421f9689c3f1"],

Cell[BoxData[
 RowBox[{"With", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{"en", " ", "=", " ", 
      RowBox[{"{", 
       RowBox[{"e1", ",", " ", "e2"}], "}"}]}], ",", " ", 
     RowBox[{"V", " ", "=", " ", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"w", ",", " ", "v"}], "}"}], ",", " ", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"Conjugate", "[", "v", "]"}], ",", " ", 
          RowBox[{"-", "w"}]}], "}"}]}], "}"}]}], ",", " ", 
     RowBox[{"basis", " ", "=", " ", 
      RowBox[{"IdentityMatrix", "[", "2", "]"}]}]}], "}"}], ",", "\n", " ", 
   RowBox[{"Table", "[", 
    RowBox[{
     RowBox[{"Sum", "[", 
      RowBox[{
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{"m", " ", "==", " ", "n"}], ",", " ", "0", ",", " ", 
         RowBox[{
          RowBox[{
           RowBox[{"Abs", "[", 
            RowBox[{
             RowBox[{"Conjugate", "[", 
              RowBox[{"basis", "[", 
               RowBox[{"[", "m", "]"}], "]"}], "]"}], " ", ".", " ", "V", " ",
              ".", " ", 
             RowBox[{"basis", "[", 
              RowBox[{"[", "n", "]"}], "]"}]}], "]"}], "^", "2"}], "/", 
          RowBox[{"(", 
           RowBox[{
            RowBox[{"en", "[", 
             RowBox[{"[", "n", "]"}], "]"}], " ", "-", " ", 
            RowBox[{"en", "[", 
             RowBox[{"[", "m", "]"}], "]"}]}], ")"}]}]}], "]"}], ",", " ", 
       RowBox[{"{", 
        RowBox[{"m", ",", " ", "2"}], "}"}]}], "]"}], ",", " ", 
     RowBox[{"{", 
      RowBox[{"n", ",", " ", "2"}], "}"}]}], "]"}]}], "]"}]], "Input",
 CellLabel->
  "In[94]:= ",ExpressionUUID->"f0ae3455-23ff-4c33-8e6b-2dc88dccfa12"],

Cell[TextData[{
 StyleBox["QF",
  FontWeight->"Bold"],
 " : the first-order shifts as bra-operator-ket scalars on the basis states."
}], "Text",ExpressionUUID->"d0ed112d-46cf-4115-b964-ba81956c51e6"],

Cell[BoxData[
 RowBox[{"With", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{"V", " ", "=", " ", 
      RowBox[{"QuantumOperator", "[", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"w", ",", " ", "v"}], "}"}], ",", " ", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{"Conjugate", "[", "v", "]"}], ",", " ", 
           RowBox[{"-", "w"}]}], "}"}]}], "}"}], "]"}]}], ",", " ", 
     RowBox[{"basis", " ", "=", " ", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"QuantumState", "[", "\"\<0\>\"", "]"}], ",", " ", 
        RowBox[{"QuantumState", "[", "\"\<1\>\"", "]"}]}], "}"}]}]}], "}"}], ",",
    "\n", " ", 
   RowBox[{"Table", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"(", 
       RowBox[{
        RowBox[{
         RowBox[{"basis", "[", 
          RowBox[{"[", "n", "]"}], "]"}], "[", "\"\<Dagger\>\"", "]"}], " ", "@",
         " ", 
        RowBox[{"V", " ", "@", " ", 
         RowBox[{"basis", "[", 
          RowBox[{"[", "n", "]"}], "]"}]}]}], ")"}], "[", "\"\<Scalar\>\"", 
      "]"}], ",", " ", 
     RowBox[{"{", 
      RowBox[{"n", ",", " ", "2"}], "}"}]}], "]"}]}], "]"}]], "Input",
 CellLabel->
  "In[95]:= ",ExpressionUUID->"2280d6ed-50f2-4288-bdd4-a023d10922d4"],

Cell["The second-order shifts, same matrix elements summed.", "Text",ExpressionUUID->"c8dd609a-9462-4323-ba6d-524a73ee1210"],

Cell[BoxData[
 RowBox[{"With", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{"en", " ", "=", " ", 
      RowBox[{"{", 
       RowBox[{"e1", ",", " ", "e2"}], "}"}]}], ",", " ", 
     RowBox[{"V", " ", "=", " ", 
      RowBox[{"QuantumOperator", "[", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"w", ",", " ", "v"}], "}"}], ",", " ", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{"Conjugate", "[", "v", "]"}], ",", " ", 
           RowBox[{"-", "w"}]}], "}"}]}], "}"}], "]"}]}], ",", " ", 
     RowBox[{"basis", " ", "=", " ", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"QuantumState", "[", "\"\<0\>\"", "]"}], ",", " ", 
        RowBox[{"QuantumState", "[", "\"\<1\>\"", "]"}]}], "}"}]}]}], "}"}], ",",
    "\n", " ", 
   RowBox[{"Table", "[", 
    RowBox[{
     RowBox[{"Sum", "[", 
      RowBox[{
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{"m", " ", "==", " ", "n"}], ",", " ", "0", ",", " ", 
         RowBox[{
          RowBox[{
           RowBox[{"Abs", "[", 
            RowBox[{
             RowBox[{"(", 
              RowBox[{
               RowBox[{
                RowBox[{"basis", "[", 
                 RowBox[{"[", "m", "]"}], "]"}], "[", "\"\<Dagger\>\"", "]"}],
                " ", "@", " ", 
               RowBox[{"V", " ", "@", " ", 
                RowBox[{"basis", "[", 
                 RowBox[{"[", "n", "]"}], "]"}]}]}], ")"}], 
             "[", "\"\<Scalar\>\"", "]"}], "]"}], "^", "2"}], "/", 
          RowBox[{"(", 
           RowBox[{
            RowBox[{"en", "[", 
             RowBox[{"[", "n", "]"}], "]"}], " ", "-", " ", 
            RowBox[{"en", "[", 
             RowBox[{"[", "m", "]"}], "]"}]}], ")"}]}]}], "]"}], ",", " ", 
       RowBox[{"{", 
        RowBox[{"m", ",", " ", "2"}], "}"}]}], "]"}], ",", " ", 
     RowBox[{"{", 
      RowBox[{"n", ",", " ", "2"}], "}"}]}], "]"}]}], "]"}]], "Input",
 CellLabel->
  "In[96]:= ",ExpressionUUID->"09fa7685-47e7-4251-a231-63b7c96e370b"],

Cell[TextData[{
 "Both give first-order shifts ",
 Cell[BoxData[
  RowBox[{
   RowBox[{"{", 
    StyleBox["w", "TI"]}], ",", 
   RowBox[{"-", 
    StyleBox["w", "TI"], "}"}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "fe671642-599e-413d-941f-59f6f7ada5a2"],
 " (the diagonal of ",
 Cell[BoxData[
  StyleBox["V", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "0c8b11ef-a742-44db-a62d-428fe45fe438"],
 ") and second-order shifts ",
 Cell[BoxData[
  RowBox[{"{", 
   RowBox[{
    FractionBox[
     SuperscriptBox[GridBox[{
        {
         StyleBox["v", "TI"]}
       },
       GridBoxDividers->{"Columns" -> {True, True}, "Rows" -> {}},
       GridBoxSpacings->{"Columns" -> {{0.15}}}], "2"], 
     RowBox[{
      SubscriptBox[
       StyleBox["e", "TI"], "1"], "-", 
      SubscriptBox[
       StyleBox["e", "TI"], "2"]}]], ",", " ", 
    FractionBox[
     SuperscriptBox[GridBox[{
        {
         StyleBox["v", "TI"]}
       },
       GridBoxDividers->{"Columns" -> {True, True}, "Rows" -> {}},
       GridBoxSpacings->{"Columns" -> {{0.15}}}], "2"], 
     RowBox[{
      SubscriptBox[
       StyleBox["e", "TI"], "2"], "-", 
      SubscriptBox[
       StyleBox["e", "TI"], "1"]}]]}], "}"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "9e75052e-27db-4977-9688-a17ffdb2b06e"],
 ": the off-diagonal coupling pushes the levels apart, the lower one down and \
the upper one up."
}], "Text",ExpressionUUID->"8a09682f-f6ea-4a0c-8753-9de9246ba970"],

Cell["\<\
2.13 [MSc] How do I resolve an avoided crossing by degenerate perturbation \
theory (level repulsion)?\
\>", "Subsection",ExpressionUUID->"0a717a58-e46c-43aa-becb-e38c68a846d0"],

Cell[TextData[{
 "Where two diagonal levels would cross, an off-diagonal coupling ",
 Cell[BoxData["\[CapitalDelta]"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "e71624b0-5e64-4bd4-9156-6e9e9384a3c0"],
 " opens a gap: the eigenvalues of ",
 Cell[BoxData[
  RowBox[{"(", GridBox[{
     {
      StyleBox["\[Lambda]", "TI"], "\[CapitalDelta]"},
     {"\[CapitalDelta]", 
      RowBox[{"-", 
       StyleBox["\[Lambda]", "TI"]}]}
    }], ")"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "2b48904b-e589-4a4c-a6c7-affd6f1a04d9"],
 " are ",
 Cell[BoxData[
  RowBox[{"\[PlusMinus]", 
   SqrtBox[
    RowBox[{
     SuperscriptBox["\[CapitalDelta]", "2"], "+", 
     SuperscriptBox[
      StyleBox["\[Lambda]", "TI"], "2"]}]]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "51aa6b2e-d160-439d-96d8-c48a311bcfca"],
 ". At the would-be crossing ",
 Cell[BoxData[
  RowBox[{
   StyleBox["\[Lambda]", "TI"], "=", "0"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "0f2fe29d-b99d-430a-bbdd-732acedbf3c3"],
 " the two levels are degenerate, and diagonalizing the coupling ",
 Cell[BoxData["\[CapitalDelta]"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "15a6b593-3b10-4d37-b687-2e7f1ec8f195"],
 " within that degenerate subspace is exactly first-order degenerate \
perturbation theory; in this ",
 Cell[BoxData[
  RowBox[{"2", "\[Times]", "2"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "7a98840e-7bf1-4b2d-80b4-74d9da73d7ee"],
 " case the degenerate-subspace diagonalization and the exact diagonalization \
coincide, giving the split ",
 Cell[BoxData[
  RowBox[{"\[PlusMinus]", "\[CapitalDelta]"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "4a6cc452-894f-468f-8369-8c554205fd23"],
 " at the crossing."
}], "Text",ExpressionUUID->"da7df0ad-2d54-4b39-8fd4-a93211f5b475"],

Cell[TextData[{
 StyleBox["WL",
  FontWeight->"Bold"],
 " : the two eigenvalues of the two-level Hamiltonian."
}], "Text",ExpressionUUID->"466b64a9-3558-496a-b2a7-df75f1572fa2"],

Cell[BoxData[
 RowBox[{"With", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"h", " ", "=", " ", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"\[Lambda]", ",", " ", "\[CapitalDelta]"}], "}"}], ",", " ", 
       RowBox[{"{", 
        RowBox[{"\[CapitalDelta]", ",", " ", 
         RowBox[{"-", "\[Lambda]"}]}], "}"}]}], "}"}]}], "}"}], ",", "\n", 
   " ", 
   RowBox[{"FullSimplify", "[", 
    RowBox[{
     RowBox[{"Eigenvalues", "[", "h", "]"}], ",", " ", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{"\[Lambda]", " ", "|", " ", "\[CapitalDelta]"}], ")"}], " ", "\[Element]",
       " ", "Reals"}]}], "]"}]}], "]"}]], "Input",
 CellLabel->
  "In[97]:= ",ExpressionUUID->"7365f2b7-d08b-4265-a9e7-13cd622badd4"],

Cell["Their difference is the gap.", "Text",ExpressionUUID->"1b514e8a-0fb5-4d3b-90df-0a63185cff54"],

Cell[BoxData[
 RowBox[{"With", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"h", " ", "=", " ", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"\[Lambda]", ",", " ", "\[CapitalDelta]"}], "}"}], ",", " ", 
       RowBox[{"{", 
        RowBox[{"\[CapitalDelta]", ",", " ", 
         RowBox[{"-", "\[Lambda]"}]}], "}"}]}], "}"}]}], "}"}], ",", "\n", 
   " ", 
   RowBox[{"FullSimplify", "[", 
    RowBox[{
     RowBox[{"Abs", "[", 
      RowBox[{"Subtract", " ", "@@", " ", 
       RowBox[{"Eigenvalues", "[", "h", "]"}]}], "]"}], ",", " ", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{"\[Lambda]", " ", "|", " ", "\[CapitalDelta]"}], ")"}], " ", "\[Element]",
       " ", "Reals"}]}], "]"}]}], "]"}]], "Input",
 CellLabel->
  "In[98]:= ",ExpressionUUID->"6a9230db-e6bc-4b1c-b2ab-b5552d6159b3"],

Cell[TextData[{
 StyleBox["QF",
  FontWeight->"Bold"],
 " : the eigenvalues through the operator."
}], "Text",ExpressionUUID->"e4d3d3f4-7bae-4c92-a320-4a5babebebe9"],

Cell[BoxData[
 RowBox[{"With", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"h", " ", "=", " ", 
     RowBox[{"QuantumOperator", "[", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"\[Lambda]", ",", " ", "\[CapitalDelta]"}], "}"}], ",", " ", 
        
        RowBox[{"{", 
         RowBox[{"\[CapitalDelta]", ",", " ", 
          RowBox[{"-", "\[Lambda]"}]}], "}"}]}], "}"}], "]"}]}], "}"}], ",", 
   "\n", " ", 
   RowBox[{"FullSimplify", "[", 
    RowBox[{
     RowBox[{"h", "[", "\"\<Eigenvalues\>\"", "]"}], ",", " ", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{"\[Lambda]", " ", "|", " ", "\[CapitalDelta]"}], ")"}], " ", "\[Element]",
       " ", "Reals"}]}], "]"}]}], "]"}]], "Input",
 CellLabel->
  "In[99]:= ",ExpressionUUID->"8364af41-3c6c-4a2e-bcfd-9f7152c7ce83"],

Cell["And the gap.", "Text",ExpressionUUID->"1e023391-05b9-4159-9245-7e711398326a"],

Cell[BoxData[
 RowBox[{"With", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"h", " ", "=", " ", 
     RowBox[{"QuantumOperator", "[", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"\[Lambda]", ",", " ", "\[CapitalDelta]"}], "}"}], ",", " ", 
        
        RowBox[{"{", 
         RowBox[{"\[CapitalDelta]", ",", " ", 
          RowBox[{"-", "\[Lambda]"}]}], "}"}]}], "}"}], "]"}]}], "}"}], ",", 
   "\n", " ", 
   RowBox[{"FullSimplify", "[", 
    RowBox[{
     RowBox[{"Abs", "[", 
      RowBox[{"Subtract", " ", "@@", " ", 
       RowBox[{"h", "[", "\"\<Eigenvalues\>\"", "]"}]}], "]"}], ",", " ", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{"\[Lambda]", " ", "|", " ", "\[CapitalDelta]"}], ")"}], " ", "\[Element]",
       " ", "Reals"}]}], "]"}]}], "]"}]], "Input",
 CellLabel->
  "In[100]:= ",ExpressionUUID->"682d9d2c-0447-449f-a33c-29b1aad62f95"],

Cell[TextData[{
 "Both give eigenvalues ",
 Cell[BoxData[
  RowBox[{"\[PlusMinus]", 
   SqrtBox[
    RowBox[{
     SuperscriptBox["\[CapitalDelta]", "2"], "+", 
     SuperscriptBox[
      StyleBox["\[Lambda]", "TI"], "2"]}]]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "2453772d-2aa0-43bf-884c-47d10ba085d8"],
 " and a gap ",
 Cell[BoxData[
  RowBox[{"2", 
   SqrtBox[
    RowBox[{
     SuperscriptBox["\[CapitalDelta]", "2"], "+", 
     SuperscriptBox[
      StyleBox["\[Lambda]", "TI"], "2"]}]]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "8c166c03-b543-4394-9961-fab95afcb9f9"],
 ". As ",
 Cell[BoxData[
  StyleBox["\[Lambda]", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "6a758bbc-9734-4390-874d-122edef30929"],
 " sweeps through the would-be crossing at ",
 Cell[BoxData[
  RowBox[{
   StyleBox["\[Lambda]", "TI"], "=", "0"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "fdfe0baf-883e-4041-acfb-03ce24e79f74"],
 ", the gap shrinks only to ",
 Cell[BoxData[
  RowBox[{"2", "\[CapitalDelta]"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "56ead9e5-844a-4154-b1bf-4eca6bd267f2"],
 ", never to zero: the coupling turns the crossing into an avoided crossing."
}], "Text",ExpressionUUID->"27f52fea-b0c2-43b4-a383-f92ea2a70702"],

Cell["Part 3. States as density operators", "Section",ExpressionUUID->"43d694a2-618f-4929-baf4-290aefc55040"],

Cell["\<\
3.1a [BSc] How do I build a density matrix from a classical ensemble?\
\>", "Subsection",ExpressionUUID->"625e4fa6-7ca5-486c-8410-e2f0a152b410"],

Cell[TextData[{
 "A classical mixture of pure states, each ",
 Cell[BoxData[
  TemplateBox[{
    SubscriptBox[
     StyleBox["\[Psi]", "TI"], 
     StyleBox["i", "TI"]]},
   "Ket"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "e1aaddc4-6650-4995-9e17-12f875c0fd85"],
 " prepared with probability ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["p", "TI"], 
   StyleBox["i", "TI"]]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "b719412c-fba7-456f-af7f-70370b837b6b"],
 ", is the density matrix ",
 Cell[BoxData[
  RowBox[{
   StyleBox["\[Rho]", "TI"], "=", 
   RowBox[{
    UnderscriptBox["\[Sum]", 
     StyleBox["i", "TI"],
     LimitsPositioning->False], 
    RowBox[{
     SubscriptBox[
      StyleBox["p", "TI"], 
      StyleBox["i", "TI"]], 
     TemplateBox[{
       SubscriptBox[
        StyleBox["\[Psi]", "TI"], 
        StyleBox["i", "TI"]]},
      "Ket"], 
     TemplateBox[{
       SubscriptBox[
        StyleBox["\[Psi]", "TI"], 
        StyleBox["i", "TI"]]},
      "Bra"]}]}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "566d731d-9ea4-438c-8185-b7aa2374369b"],
 "."
}], "Text",ExpressionUUID->"985b46ac-bf83-496c-b8d8-914cd3003a54"],

Cell[TextData[{
 StyleBox["WL",
  FontWeight->"Bold"],
 " : sum the weighted projectors, each ",
 Cell[BoxData[
  RowBox[{
   RowBox[{
    TemplateBox[{
      SubscriptBox[
       StyleBox["\[Psi]", "TI"], 
       StyleBox["i", "TI"]]},
     "Ket"], 
    TemplateBox[{
      SubscriptBox[
       StyleBox["\[Psi]", "TI"], 
       StyleBox["i", "TI"]]},
     "Bra"]}], "="}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "4a15280c-dc29-4f3b-9021-29fcb28c0070"],
 " ",
 Cell[BoxData[
  RowBox[{"KroneckerProduct", "[", 
   RowBox[{"psi", ",", " ", 
    RowBox[{"Conjugate", "[", "psi", "]"}]}], "]"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "f5e6f965-4974-487d-9ae4-13670e6d7e8b"],
 "."
}], "Text",ExpressionUUID->"a10be683-0f23-48a0-bd97-2aa5d01872b5"],

Cell[BoxData[
 RowBox[{"rho", " ", "=", " ", 
  RowBox[{
   RowBox[{
    RowBox[{"3", "/", "4"}], " ", 
    RowBox[{"KroneckerProduct", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"1", ",", " ", "0"}], "}"}], ",", " ", 
      RowBox[{"Conjugate", "[", 
       RowBox[{"{", 
        RowBox[{"1", ",", " ", "0"}], "}"}], "]"}]}], "]"}]}], " ", "+", "\n",
    "   ", 
   RowBox[{
    RowBox[{"1", "/", "4"}], " ", 
    RowBox[{"KroneckerProduct", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"{", 
        RowBox[{"1", ",", " ", "1"}], "}"}], "/", 
       RowBox[{"Sqrt", "[", "2", "]"}]}], ",", " ", 
      RowBox[{"Conjugate", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"1", ",", " ", "1"}], "}"}], "/", 
        RowBox[{"Sqrt", "[", "2", "]"}]}], "]"}]}], "]"}]}]}]}]], "Input",
 CellLabel->
  "In[101]:= ",ExpressionUUID->"9ab33318-e646-4aed-90f7-45e6b1a8df42"],

Cell[TextData[{
 StyleBox["QF",
  FontWeight->"Bold"],
 " : a classical mixture is the sum of the component density matrices (NOT a \
sum of the state vectors, which would build a coherent superposition); wrap \
that matrix as a state object."
}], "Text",ExpressionUUID->"7955bedb-4555-44e9-a05a-ec6175f6cece"],

Cell[BoxData[
 RowBox[{"rhoQF", " ", "=", " ", 
  RowBox[{"QuantumState", "[", 
   RowBox[{
    RowBox[{
     RowBox[{"3", "/", "4"}], " ", 
     RowBox[{
      RowBox[{"QuantumState", "[", 
       RowBox[{"{", 
        RowBox[{"1", ",", " ", "0"}], "}"}], "]"}], 
      "[", "\"\<DensityMatrix\>\"", "]"}]}], " ", "+", "\n", "    ", 
    RowBox[{
     RowBox[{"1", "/", "4"}], " ", 
     RowBox[{
      RowBox[{"QuantumState", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"1", ",", " ", "1"}], "}"}], "/", 
        RowBox[{"Sqrt", "[", "2", "]"}]}], "]"}], "[", "\"\<DensityMatrix\>\"",
       "]"}]}]}], "]"}]}]], "Input",
 CellLabel->
  "In[102]:= ",ExpressionUUID->"03728449-6cfd-4db4-b1ec-d6645386fdfe"],

Cell[TextData[{
 "Both build the same ",
 Cell[BoxData[
  StyleBox["\[Rho]", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "e90dceb7-8b81-43f6-83ff-d7b11f03adcf"],
 ". Summing the ",
 StyleBox["state vectors", "TI"],
 " instead would have built a coherent superposition, a pure state, a \
physically different object from this classical mixture."
}], "Text",ExpressionUUID->"26522e7a-8918-495f-b9ef-bc09dd3420a4"],

Cell[TextData[{
 "3.1b [BSc] How do I compute the purity ",
 Cell[BoxData[
  RowBox[{
   StyleBox["Tr",
    FontSlant->"Plain"], 
   StyleBox["[",
    SpanMaxSize->1], 
   SuperscriptBox[
    StyleBox["\[Rho]", "TI"], "2"], 
   StyleBox["]",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "b0cf6909-a7f4-4613-aa9b-2c084af4e46d"],
 " of a density matrix?"
}], "Subsection",ExpressionUUID->"0ab5bcf4-6c12-4736-8b81-201205634302"],

Cell[TextData[{
 "The purity ",
 Cell[BoxData[
  RowBox[{
   StyleBox["Tr",
    FontSlant->"Plain"], 
   StyleBox["[",
    SpanMaxSize->1], 
   SuperscriptBox[
    StyleBox["\[Rho]", "TI"], "2"], 
   StyleBox["]",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "480364cc-90c6-4483-afc9-2071603a002c"],
 " measures how mixed a state is: it runs from ",
 Cell[BoxData[
  RowBox[{"1", "/", 
   StyleBox["d", "TI"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "f627c135-a35a-4a42-9094-e35cf87b9e1c"],
 " (maximally mixed) up to ",
 Cell[BoxData["1"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "2fa54cb0-f806-42ee-b3cb-c62ca6f1c7f7"],
 " (pure), the value ",
 Cell[BoxData["1"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "088a7641-547f-4938-9947-8da663f38133"],
 " reached only when ",
 Cell[BoxData[
  StyleBox["\[Rho]", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "f7cb0204-6a78-4a2d-817b-d4d495759628"],
 " is a single projector."
}], "Text",ExpressionUUID->"13f96281-0835-45e1-a545-c54b5fcacd56"],

Cell[TextData[{
 StyleBox["WL",
  FontWeight->"Bold"],
 " : form the ensemble density matrix ",
 Cell[BoxData[
  RowBox[{
   RowBox[{
    FractionBox["3", "4"], 
    TemplateBox[{"0"},
     "Ket"], 
    TemplateBox[{"0"},
     "Bra"]}], "+", 
   RowBox[{
    FractionBox["1", "4"], 
    TemplateBox[{"+"},
     "Ket"], 
    TemplateBox[{"+"},
     "Bra"]}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "64a298f4-d484-4b36-aad2-17b1cddbcb60"],
 " and read its purity ",
 Cell[BoxData[
  RowBox[{
   StyleBox["Tr",
    FontSlant->"Plain"], 
   StyleBox["[",
    SpanMaxSize->1], 
   SuperscriptBox[
    StyleBox["\[Rho]", "TI"], "2"], 
   StyleBox["]",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "7b1f4f03-956c-4434-abfd-8efebb088081"],
 "."
}], "Text",ExpressionUUID->"d709e1c2-36f5-4b9e-a19d-b5f80cde53c9"],

Cell[BoxData[
 RowBox[{"With", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"rho", " ", "=", " ", 
     RowBox[{
      RowBox[{
       RowBox[{"3", "/", "4"}], " ", 
       RowBox[{"KroneckerProduct", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"1", ",", " ", "0"}], "}"}], ",", " ", 
         RowBox[{"Conjugate", "[", 
          RowBox[{"{", 
           RowBox[{"1", ",", " ", "0"}], "}"}], "]"}]}], "]"}]}], " ", "+", 
      " ", 
      RowBox[{
       RowBox[{"1", "/", "4"}], " ", 
       RowBox[{"KroneckerProduct", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"{", 
           RowBox[{"1", ",", " ", "1"}], "}"}], "/", 
          RowBox[{"Sqrt", "[", "2", "]"}]}], ",", " ", 
         RowBox[{"Conjugate", "[", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{"1", ",", " ", "1"}], "}"}], "/", 
           RowBox[{"Sqrt", "[", "2", "]"}]}], "]"}]}], "]"}]}]}]}], "}"}], ",",
    "\n", " ", 
   RowBox[{"Tr", "[", 
    RowBox[{"rho", " ", ".", " ", "rho"}], "]"}]}], "]"}]], "Input",
 CellLabel->
  "In[103]:= ",ExpressionUUID->"f404d4e5-b3e2-406a-9d10-86aca6b06c8e"],

Cell[TextData[{
 StyleBox["QF",
  FontWeight->"Bold"],
 " : ",
 Cell[BoxData["\"\<Purity\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "3d506b54-6320-400d-96b0-e882b7617495"],
 " reads ",
 Cell[BoxData[
  RowBox[{
   StyleBox["Tr",
    FontSlant->"Plain"], 
   StyleBox["[",
    SpanMaxSize->1], 
   SuperscriptBox[
    StyleBox["\[Rho]", "TI"], "2"], 
   StyleBox["]",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "0b9f7470-9519-40d8-9167-3392e440f3d0"],
 " off the state object."
}], "Text",ExpressionUUID->"1c1141c4-8b65-43c0-974b-71876b88a611"],

Cell[BoxData[
 RowBox[{
  RowBox[{"QuantumState", "[", 
   RowBox[{
    RowBox[{
     RowBox[{"3", "/", "4"}], " ", 
     RowBox[{
      RowBox[{"QuantumState", "[", 
       RowBox[{"{", 
        RowBox[{"1", ",", " ", "0"}], "}"}], "]"}], 
      "[", "\"\<DensityMatrix\>\"", "]"}]}], " ", "+", " ", 
    RowBox[{
     RowBox[{"1", "/", "4"}], " ", 
     RowBox[{
      RowBox[{"QuantumState", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"1", ",", " ", "1"}], "}"}], "/", 
        RowBox[{"Sqrt", "[", "2", "]"}]}], "]"}], "[", "\"\<DensityMatrix\>\"",
       "]"}]}]}], "]"}], "[", "\"\<Purity\>\"", "]"}]], "Input",
 CellLabel->
  "In[104]:= ",ExpressionUUID->"2cb6e9fc-bf50-4a07-b612-5b23b6916c90"],

Cell[TextData[{
 "Both give ",
 Cell[BoxData[
  RowBox[{
   StyleBox["Tr",
    FontSlant->"Plain"], 
   StyleBox["[",
    SpanMaxSize->1], 
   SuperscriptBox[
    StyleBox["\[Rho]", "TI"], "2"], 
   StyleBox["]",
    SpanMaxSize->1], "=", "13", "/", "16", "<", "1"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "1d6f5cae-8263-4e36-a81c-4cdbef4fef3c"],
 ": the ensemble state is mixed, below the pure-state value ",
 Cell[BoxData["1"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "402d6a55-0f01-49af-bff8-b059cd7ae347"],
 " and above the qubit floor ",
 Cell[BoxData[
  RowBox[{"1", "/", "2"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "498cf440-fb57-462f-b464-d41bef58f116"],
 "."
}], "Text",ExpressionUUID->"129d80de-473b-49f8-9416-52d4c26d134e"],

Cell["3.2 [BSc] How do I test whether a state is pure or mixed?", "Subsection",ExpressionUUID->"ccefbe66-19d8-4609-a2ad-3b936ce73b0a"],

Cell[TextData[{
 "A state is pure iff any one of three equivalent conditions holds: ",
 Cell[BoxData[
  RowBox[{
   StyleBox["Tr",
    FontSlant->"Plain"], 
   StyleBox["[",
    SpanMaxSize->1], 
   SuperscriptBox[
    StyleBox["\[Rho]", "TI"], "2"], 
   StyleBox["]",
    SpanMaxSize->1], "=", "1"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "a5f8e407-4bd2-46ac-806a-fc4138711024"],
 ", ",
 Cell[BoxData[
  StyleBox["\[Rho]", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "68526039-7c1e-4b28-9ad8-0c990d82886d"],
 " has rank one, or ",
 Cell[BoxData[
  StyleBox["\[Rho]", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "7e8f2150-0995-4a0d-8ab7-6e796c6b188d"],
 " is idempotent (",
 Cell[BoxData[
  RowBox[{
   SuperscriptBox[
    StyleBox["\[Rho]", "TI"], "2"], "=", 
   StyleBox["\[Rho]", "TI"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "dcc40dd4-03f9-4941-88b5-af2f514ecc90"],
 ", a projector)."
}], "Text",ExpressionUUID->"e929d396-81a6-4c5e-8233-e8a9098c38ab"],

Cell[TextData[{
 StyleBox["WL",
  FontWeight->"Bold"],
 " : build a mixed state to test, the classical ensemble ",
 Cell[BoxData[
  RowBox[{
   RowBox[{
    FractionBox["3", "4"], 
    TemplateBox[{"0"},
     "Ket"], 
    TemplateBox[{"0"},
     "Bra"]}], "+", 
   RowBox[{
    FractionBox["1", "4"], 
    TemplateBox[{"+"},
     "Ket"], 
    TemplateBox[{"+"},
     "Bra"]}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "93519693-3a53-4259-8809-4c944bdd73df"],
 "."
}], "Text",ExpressionUUID->"feef7d3b-5399-4d60-8d65-846d3e5a2443"],

Cell[BoxData[
 RowBox[{
  RowBox[{"rho", " ", "=", " ", 
   RowBox[{
    RowBox[{
     RowBox[{"3", "/", "4"}], " ", 
     RowBox[{"KroneckerProduct", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"1", ",", " ", "0"}], "}"}], ",", " ", 
       RowBox[{"Conjugate", "[", 
        RowBox[{"{", 
         RowBox[{"1", ",", " ", "0"}], "}"}], "]"}]}], "]"}]}], " ", "+", " ", 
    RowBox[{
     RowBox[{"1", "/", "4"}], " ", 
     RowBox[{"KroneckerProduct", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"{", 
         RowBox[{"1", ",", " ", "1"}], "}"}], "/", 
        RowBox[{"Sqrt", "[", "2", "]"}]}], ",", " ", 
       RowBox[{"Conjugate", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"1", ",", " ", "1"}], "}"}], "/", 
         RowBox[{"Sqrt", "[", "2", "]"}]}], "]"}]}], "]"}]}]}]}], 
  ";"}]], "Input",
 CellLabel->
  "In[105]:= ",ExpressionUUID->"3ac40235-762f-4d48-815e-24f7a78e3461"],

Cell["Purity equals one only for a pure state.", "Text",ExpressionUUID->"9924118d-0e68-4a53-84ab-e35e487c43b0"],

Cell[BoxData[
 RowBox[{
  RowBox[{"Tr", "[", 
   RowBox[{"rho", " ", ".", " ", "rho"}], "]"}], " ", "==", " ", 
  "1"}]], "Input",
 CellLabel->
  "In[106]:= ",ExpressionUUID->"ea0596dd-81c2-4ac7-9564-285d359ea3b0"],

Cell["A pure state's density matrix has rank one.", "Text",ExpressionUUID->"15b8b6a0-7f25-42de-87fc-ce5632ac0f33"],

Cell[BoxData[
 RowBox[{
  RowBox[{"MatrixRank", "[", "rho", "]"}], " ", "==", " ", "1"}]], "Input",
 CellLabel->
  "In[107]:= ",ExpressionUUID->"319df08e-c2d7-4db2-a288-7f9f014d3df0"],

Cell[TextData[{
 "A pure state is idempotent, a projector ",
 Cell[BoxData[
  RowBox[{
   SuperscriptBox[
    StyleBox["\[Rho]", "TI"], "2"], "=", 
   StyleBox["\[Rho]", "TI"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "48fe8874-8a55-4184-ab2f-581597964c89"],
 "."
}], "Text",ExpressionUUID->"5fa2b111-bf1c-494a-a15c-981207097642"],

Cell[BoxData[
 RowBox[{
  RowBox[{"rho", " ", ".", " ", "rho"}], " ", "==", " ", "rho"}]], "Input",
 CellLabel->
  "In[108]:= ",ExpressionUUID->"929b8562-a71f-42e2-9210-ef146a3f6861"],

Cell[TextData[{
 StyleBox["QF",
  FontWeight->"Bold"],
 " : build the same mixture as a state object; it answers directly with ",
 Cell[BoxData["\"\<PureStateQ\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "5620006c-dda2-43ac-be42-9eab214b729f"],
 "."
}], "Text",ExpressionUUID->"9743754e-fc73-4192-9514-4868df2e9969"],

Cell[BoxData[
 RowBox[{
  RowBox[{"rhoQF", " ", "=", " ", 
   RowBox[{"QuantumState", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"3", "/", "4"}], " ", 
      RowBox[{
       RowBox[{"QuantumState", "[", 
        RowBox[{"{", 
         RowBox[{"1", ",", " ", "0"}], "}"}], "]"}], 
       "[", "\"\<DensityMatrix\>\"", "]"}]}], " ", "+", " ", 
     RowBox[{
      RowBox[{"1", "/", "4"}], " ", 
      RowBox[{
       RowBox[{"QuantumState", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"1", ",", " ", "1"}], "}"}], "/", 
         RowBox[{"Sqrt", "[", "2", "]"}]}], "]"}], 
       "[", "\"\<DensityMatrix\>\"", "]"}]}]}], "]"}]}], ";"}]], "Input",
 CellLabel->
  "In[109]:= ",ExpressionUUID->"fbffb06e-c91e-4788-a61a-2d3f9a19c2a1"],

Cell["The mixed state is not pure.", "Text",ExpressionUUID->"beed70bb-6747-4fc1-842d-acc057fb5d03"],

Cell[BoxData[
 RowBox[{"rhoQF", "[", "\"\<PureStateQ\>\"", "]"}]], "Input",
 CellLabel->
  "In[110]:= ",ExpressionUUID->"6c00ec83-283b-4846-9d2a-ad336a094451"],

Cell[TextData[{
 "Contrast a genuine pure state, which returns ",
 Cell[BoxData["True"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "063655c7-0ade-4409-8af5-4bea1ff97b35"],
 "."
}], "Text",ExpressionUUID->"f7461d14-5798-483f-870c-928f026dfaaf"],

Cell[BoxData[
 RowBox[{
  RowBox[{"QuantumState", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"1", ",", " ", "I"}], "}"}], "/", 
    RowBox[{"Sqrt", "[", "2", "]"}]}], "]"}], "[", "\"\<PureStateQ\>\"", 
  "]"}]], "Input",
 CellLabel->
  "In[111]:= ",ExpressionUUID->"aa4f8bcb-73d5-48e2-abbc-63449fa02810"],

Cell[TextData[{
 "The mixed state fails all three criteria (each cell returns ",
 Cell[BoxData["False"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "ab9f94a0-4d00-4aef-961c-93a7df33a3f6"],
 ", the rank is ",
 Cell[BoxData["2"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "9567132c-2cdb-444b-b939-e0cd13e9f979"],
 "); the pure state passes. The three tests are equivalent characterizations \
of the same rank-one property."
}], "Text",ExpressionUUID->"77957f8d-d54d-43aa-9cd0-efc5f55bb987"],

Cell[TextData[{
 "3.3 [BSc] How do I build the maximally mixed state ",
 Cell[BoxData[
  RowBox[{
   StyleBox["I", "TI"], "/", 
   StyleBox["d", "TI"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "279d6799-5c91-42ee-af8c-4309edf4074a"],
 " and read its purity?"
}], "Subsection",ExpressionUUID->"39e74eb2-2b96-4178-8ce0-c5ceec0aded7"],

Cell[TextData[{
 "The maximally mixed state ",
 Cell[BoxData[
  RowBox[{
   StyleBox["I", "TI"], "/", 
   StyleBox["d", "TI"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "6996fe99-e10f-4d14-8cba-170e056c7690"],
 " is the unique state of maximal entropy; its purity is the floor ",
 Cell[BoxData[
  RowBox[{"1", "/", 
   StyleBox["d", "TI"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "2c1e7d49-e537-4e7d-91ac-128ed6b390be"],
 "."
}], "Text",ExpressionUUID->"d4607c0c-a154-47bc-bc6c-d663d6b7ffe6"],

Cell[TextData[{
 StyleBox["WL",
  FontWeight->"Bold"],
 " : the normalized identity, and its purity."
}], "Text",ExpressionUUID->"0a26ac85-b12d-4cda-8255-160e87184432"],

Cell[BoxData[
 RowBox[{"With", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"d", " ", "=", " ", "3"}], "}"}], ",", " ", 
   RowBox[{"Tr", "[", 
    RowBox[{
     RowBox[{"(", 
      RowBox[{
       RowBox[{"IdentityMatrix", "[", "d", "]"}], "/", "d"}], ")"}], " ", ".",
      " ", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{"IdentityMatrix", "[", "d", "]"}], "/", "d"}], ")"}]}], 
    "]"}]}], "]"}]], "Input",
 CellLabel->
  "In[112]:= ",ExpressionUUID->"130844ef-c9e5-42b1-b50a-2e948ada076f"],

Cell[TextData[{
 StyleBox["QF",
  FontWeight->"Bold"],
 " : the same state as an object, shown as its summary box."
}], "Text",ExpressionUUID->"2a377718-61ea-4112-8c3e-ae965d9bc588"],

Cell[BoxData[
 RowBox[{"QuantumState", "[", 
  RowBox[{
   RowBox[{"IdentityMatrix", "[", "3", "]"}], "/", "3"}], "]"}]], "Input",
 CellLabel->
  "In[113]:= ",ExpressionUUID->"dfd5b8d1-7bf2-433e-96a9-600bb8c0b3e4"],

Cell[TextData[{
 "Its ",
 Cell[BoxData["\"\<Purity\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "bd85d8b8-b429-4b5a-94a9-fdc974c2125d"],
 " is the floor ",
 Cell[BoxData[
  RowBox[{"1", "/", 
   StyleBox["d", "TI"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "0c6fea24-cadf-4ddf-8e81-430726087dd7"],
 "."
}], "Text",ExpressionUUID->"cd61827f-0cb6-4d65-a54d-4ec4412d1ae6"],

Cell[BoxData[
 RowBox[{
  RowBox[{"QuantumState", "[", 
   RowBox[{
    RowBox[{"IdentityMatrix", "[", "3", "]"}], "/", "3"}], "]"}], 
  "[", "\"\<Purity\>\"", "]"}]], "Input",
 CellLabel->
  "In[114]:= ",ExpressionUUID->"e9ddcabd-964b-4b71-bdc0-04fc6e08ace9"],

Cell[TextData[{
 "Both give ",
 Cell[BoxData[
  RowBox[{"1", "/", "3", "=", "1", "/", 
   StyleBox["d", "TI"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "d754ca0a-01a7-4338-bb18-c73b8bc265b7"],
 ", the minimum purity in dimension ",
 Cell[BoxData[
  RowBox[{
   StyleBox["d", "TI"], "=", "3"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "86b117e8-5f15-4249-8335-79ab8c28616f"],
 ": no state is less pure than ",
 Cell[BoxData[
  RowBox[{
   StyleBox["I", "TI"], "/", 
   StyleBox["d", "TI"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "5281cebc-3894-47dd-92d3-55f5aa0da2cb"],
 "."
}], "Text",ExpressionUUID->"8c451a9b-2835-4fb9-b702-8c5b65dc1b66"],

Cell[TextData[{
 "3.4 [BSc] How do I compute an expectation value and a variance of an \
observable on a general (mixed) state as ",
 Cell[BoxData[
  RowBox[{
   StyleBox["Tr",
    FontSlant->"Plain"], 
   StyleBox["[",
    SpanMaxSize->1], 
   RowBox[{
    OverscriptBox[
     StyleBox["A", "TI"], "^"], 
    StyleBox["\[Rho]", "TI"]}], 
   StyleBox["]",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "1f26668b-962a-4be6-9972-bbfaf4446e58"],
 "?"
}], "Subsection",ExpressionUUID->"52280f06-800c-4b7a-9d60-b50a253ea76b"],

Cell[TextData[{
 "For any state, ",
 Cell[BoxData[
  RowBox[{
   StyleBox["\[LeftAngleBracket]",
    SpanMaxSize->1], 
   StyleBox["A", "TI"], "\[VeryThinSpace]", 
   StyleBox["\[RightAngleBracket]",
    SpanMaxSize->1], "=", 
   StyleBox["Tr",
    FontSlant->"Plain"], 
   StyleBox["[",
    SpanMaxSize->1], 
   StyleBox[
    RowBox[{"A", "\[Rho]"}], "TI"], 
   StyleBox["]",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "803fbdbe-c697-4bac-ac2e-cc7eea1ceaf5"],
 " and ",
 Cell[BoxData[
  RowBox[{
   StyleBox["Var",
    FontSlant->"Plain"], "=", 
   StyleBox["Tr",
    FontSlant->"Plain"], 
   StyleBox["[",
    SpanMaxSize->1], 
   RowBox[{
    SuperscriptBox[
     StyleBox["A", "TI"], "2"], 
    StyleBox["\[Rho]", "TI"]}], 
   StyleBox["]",
    SpanMaxSize->1], "-", 
   StyleBox["Tr",
    FontSlant->"Plain"], 
   SuperscriptBox[
    RowBox[{
     StyleBox["[",
      SpanMaxSize->1], 
     StyleBox[
      RowBox[{"A", "\[Rho]"}], "TI"], 
     StyleBox["]",
      SpanMaxSize->1]}], "2"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "ef6189f6-108d-4307-8391-0b2622437811"],
 ". Writing a general qubit state in Bloch form ",
 Cell[BoxData[
  RowBox[{
   StyleBox["\[Rho]", "TI"], "=", 
   FractionBox["1", "2"], 
   StyleBox["(",
    SpanMaxSize->1], 
   RowBox[{
    StyleBox["I", "TI"], "+", 
    OverscriptBox[
     StyleBox["r", "TI"], "\[RightVector]"], "\[CenterDot]", 
    OverscriptBox[
     StyleBox["\[Sigma]", "TI"], "\[RightVector]"]}], 
   StyleBox[")",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "25a68025-0947-472f-b6ad-979eb929c743"],
 " makes the result transparent."
}], "Text",ExpressionUUID->"a2d82b35-2b53-43d3-b49f-784f4d1fa084"],

Cell[TextData[{
 StyleBox["WL",
  FontWeight->"Bold"],
 " : build the general Bloch state and bind it (",
 Cell[BoxData[
  RowBox[{
   OverscriptBox[
    StyleBox["\[Sigma]", "TI"], "\[RightVector]"], "="}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "407eb486-a0d8-4031-abb7-52d886cfe747"],
 " ",
 Cell[BoxData[
  RowBox[{"PauliMatrix", "[", 
   RowBox[{"{", 
    RowBox[{"1", ",", " ", "2", ",", " ", "3"}], "}"}], "]"}]], 
  "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "bcaffff0-6c1c-4b1d-8260-8db4f2e8ec76"],
 ")."
}], "Text",ExpressionUUID->"0885624b-0027-42c2-9c01-c90df05f2b34"],

Cell[BoxData[
 RowBox[{
  RowBox[{"rhoB", " ", "=", " ", 
   RowBox[{
    RowBox[{"1", "/", "2"}], " ", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"IdentityMatrix", "[", "2", "]"}], " ", "+", " ", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"rx", ",", " ", "ry", ",", " ", "rz"}], "}"}], " ", ".", " ", 
       
       RowBox[{"PauliMatrix", "[", 
        RowBox[{"{", 
         RowBox[{"1", ",", " ", "2", ",", " ", "3"}], "}"}], "]"}]}]}], 
     ")"}]}]}], ";"}]], "Input",
 CellLabel->
  "In[115]:= ",ExpressionUUID->"01457e68-a634-4400-8d1d-ff6041a6db82"],

Cell[TextData[{
 "The mean of ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["\[Sigma]", "TI"], 
   StyleBox["z", "TI"]]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "e31682ac-f14e-4a8e-98c3-44b5632e3301"],
 " is ",
 Cell[BoxData[
  RowBox[{
   StyleBox["Tr",
    FontSlant->"Plain"], 
   StyleBox["[",
    SpanMaxSize->1], 
   RowBox[{
    SubscriptBox[
     StyleBox["\[Sigma]", "TI"], 
     StyleBox["z", "TI"]], 
    StyleBox["\[Rho]", "TI"]}], 
   StyleBox["]",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "93538ea9-0f47-4c0c-8b28-85c307107931"],
 "."
}], "Text",ExpressionUUID->"677cc7dd-949f-4a0a-9f31-4775db2dc4e6"],

Cell[BoxData[
 RowBox[{"Tr", "[", 
  RowBox[{
   RowBox[{"PauliMatrix", "[", "3", "]"}], " ", ".", " ", "rhoB"}], 
  "]"}]], "Input",
 CellLabel->
  "In[116]:= ",ExpressionUUID->"375faa88-413e-4e96-8e17-638784b2fa68"],

Cell[TextData[{
 "The variance reuses ",
 Cell[BoxData[
  RowBox[{
   SubsuperscriptBox[
    StyleBox["\[Sigma]", "TI"], 
    StyleBox["z", "TI"], "2"], "=", 
   StyleBox["I", "TI"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "78b987d3-ffab-4212-aaa6-209cf940547c"],
 "."
}], "Text",ExpressionUUID->"8b278608-a16a-4eea-be29-ce4b52233d18"],

Cell[BoxData[
 RowBox[{
  RowBox[{"Tr", "[", 
   RowBox[{
    RowBox[{"PauliMatrix", "[", "3", "]"}], " ", ".", " ", 
    RowBox[{"PauliMatrix", "[", "3", "]"}], " ", ".", " ", "rhoB"}], "]"}], 
  " ", "-", " ", 
  RowBox[{
   RowBox[{"Tr", "[", 
    RowBox[{
     RowBox[{"PauliMatrix", "[", "3", "]"}], " ", ".", " ", "rhoB"}], "]"}], "^",
    "2"}]}]], "Input",
 CellLabel->
  "In[117]:= ",ExpressionUUID->"08105545-a331-40df-944c-e2b825440c4a"],

Cell[TextData[{
 StyleBox["QF",
  FontWeight->"Bold"],
 " : the same general state as an object, shown as its summary box."
}], "Text",ExpressionUUID->"12186056-da41-4c39-bacd-bf377ce76b6d"],

Cell[BoxData[
 RowBox[{"rhoBQF", " ", "=", " ", 
  RowBox[{"QuantumState", "[", 
   RowBox[{
    RowBox[{"1", "/", "2"}], " ", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"IdentityMatrix", "[", "2", "]"}], " ", "+", " ", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"rx", ",", " ", "ry", ",", " ", "rz"}], "}"}], " ", ".", " ", 
       
       RowBox[{"PauliMatrix", "[", 
        RowBox[{"{", 
         RowBox[{"1", ",", " ", "2", ",", " ", "3"}], "}"}], "]"}]}]}], 
     ")"}]}], "]"}]}]], "Input",
 CellLabel->
  "In[118]:= ",ExpressionUUID->"0239fdec-126a-4da5-88e3-b2ae5d5bea1c"],

Cell[TextData[{
 "The mean, as a measurement-operator expectation on the state. The ",
 Cell[BoxData["\"\<Mean\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "0f36b6ab-ffd9-4e60-8e5a-bf973004530f"],
 " runs through Born probabilities ",
 Cell[BoxData[
  RowBox[{
   StyleBox["(",
    SpanMaxSize->1], 
   RowBox[{"1", "\[PlusMinus]", 
    SubscriptBox[
     StyleBox["r", "TI"], 
     StyleBox["z", "TI"]]}], 
   StyleBox[")",
    SpanMaxSize->1], "/", "2"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "a2b584dd-ec5e-43f5-9b71-c91d7bfb4213"],
 ", so it is simplified under the physicality assumption ",
 Cell[BoxData[
  RowBox[{GridBox[{
     {
      SubscriptBox[
       StyleBox["r", "TI"], 
       StyleBox["z", "TI"]]}
    },
    GridBoxDividers->{"Columns" -> {True, True}, "Rows" -> {}},
    GridBoxSpacings->{"Columns" -> {{0.15}}}], "\[LessEqual]", "1"}]], 
  "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "746c67cf-7aed-4d07-ac18-51544c78365c"],
 "."
}], "Text",ExpressionUUID->"16d73790-9891-4afd-9002-956167033555"],

Cell[BoxData[
 RowBox[{"Simplify", "[", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"QuantumMeasurementOperator", "[", 
      RowBox[{"QuantumOperator", "[", "\"\<Z\>\"", "]"}], "]"}], "[", 
     "rhoBQF", "]"}], "[", "\"\<Mean\>\"", "]"}], ",", " ", 
   RowBox[{
    RowBox[{"-", "1"}], " ", "<=", " ", "rz", " ", "<=", " ", "1"}]}], 
  "]"}]], "Input",
 CellLabel->
  "In[119]:= ",ExpressionUUID->"996fbe91-5b1d-414b-8f7a-5f5d218db6ca"],

Cell[TextData[{
 "The variance, from ",
 Cell[BoxData[
  RowBox[{
   StyleBox["\[LeftAngleBracket]",
    SpanMaxSize->1], 
   SubsuperscriptBox[
    StyleBox["\[Sigma]", "TI"], 
    StyleBox["z", "TI"], "2"], 
   StyleBox["\[RightAngleBracket]",
    SpanMaxSize->1], "-", 
   SuperscriptBox[
    RowBox[{
     StyleBox["\[LeftAngleBracket]",
      SpanMaxSize->1], 
     SubscriptBox[
      StyleBox["\[Sigma]", "TI"], 
      StyleBox["z", "TI"]], 
     StyleBox["\[RightAngleBracket]",
      SpanMaxSize->1]}], "2"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "9b13b3a2-df86-4812-918f-1ef9b0e8e753"],
 ", under the same assumption."
}], "Text",ExpressionUUID->"1dc19298-6d53-4a8e-8bc2-3d43bc9986b8"],

Cell[BoxData[
 RowBox[{"Simplify", "[", "\n", " ", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{"QuantumMeasurementOperator", "[", 
       RowBox[{
        RowBox[{"QuantumOperator", "[", "\"\<Z\>\"", "]"}], " ", "@", " ", 
        RowBox[{"QuantumOperator", "[", "\"\<Z\>\"", "]"}]}], "]"}], "[", 
      "rhoBQF", "]"}], "[", "\"\<Mean\>\"", "]"}], " ", "-", "\n", "  ", 
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{"QuantumMeasurementOperator", "[", 
        RowBox[{"QuantumOperator", "[", "\"\<Z\>\"", "]"}], "]"}], "[", 
       "rhoBQF", "]"}], "[", "\"\<Mean\>\"", "]"}], "^", "2"}]}], ",", " ", 
   RowBox[{
    RowBox[{"-", "1"}], " ", "<=", " ", "rz", " ", "<=", " ", "1"}]}], 
  "]"}]], "Input",
 CellLabel->
  "In[120]:= ",ExpressionUUID->"9132a0a6-10ad-4414-ad98-f0d04d2fafae"],

Cell[TextData[{
 "Both give ",
 Cell[BoxData[
  RowBox[{
   StyleBox["\[LeftAngleBracket]",
    SpanMaxSize->1], 
   SubscriptBox[
    StyleBox["\[Sigma]", "TI"], 
    StyleBox["z", "TI"]], 
   StyleBox["\[RightAngleBracket]",
    SpanMaxSize->1], "=", 
   SubscriptBox[
    StyleBox["r", "TI"], 
    StyleBox["z", "TI"]]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "ef04be2e-6a12-43a6-ae7d-a1e9dafe2515"],
 " (the expectation of a Pauli is its Bloch component) and ",
 Cell[BoxData[
  RowBox[{
   StyleBox["Var",
    FontSlant->"Plain"], "=", "1", "-", 
   SubsuperscriptBox[
    StyleBox["r", "TI"], 
    StyleBox["z", "TI"], "2"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "60800a19-0cb1-4026-947d-d1c5a3a6436e"],
 ": the spin is sharp (",
 Cell[BoxData[
  RowBox[{
   StyleBox["Var",
    FontSlant->"Plain"], "=", "0"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "2d048eb0-825e-49a9-b15e-1513c163c46c"],
 ") only at the poles ",
 Cell[BoxData[
  RowBox[{
   SubscriptBox[
    StyleBox["r", "TI"], 
    StyleBox["z", "TI"]], "=", "\[PlusMinus]", "1"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "70c6bc10-a677-40b3-a656-1c8db968536f"],
 ". (The WL trace ",
 Cell[BoxData[
  RowBox[{
   StyleBox["Tr",
    FontSlant->"Plain"], 
   StyleBox["[",
    SpanMaxSize->1], 
   RowBox[{
    SubscriptBox[
     StyleBox["\[Sigma]", "TI"], 
     StyleBox["z", "TI"]], 
    StyleBox["\[Rho]", "TI"]}], 
   StyleBox["]",
    SpanMaxSize->1], "=", 
   SubscriptBox[
    StyleBox["r", "TI"], 
    StyleBox["z", "TI"]]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "d22f413a-dd10-4562-bb78-a9a7a2510781"],
 " holds for any ",
 Cell[BoxData[
  StyleBox["\[Rho]", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "49cb90cc-4d38-4ba2-a972-ecf411237c22"],
 "; the QF measurement form needs ",
 Cell[BoxData[
  StyleBox["\[Rho]", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "66ae1f66-8892-48a6-966d-559e48d84b4c"],
 " to be a physical state, which is the ",
 Cell[BoxData[
  RowBox[{GridBox[{
     {
      SubscriptBox[
       StyleBox["r", "TI"], 
       StyleBox["z", "TI"]]}
    },
    GridBoxDividers->{"Columns" -> {True, True}, "Rows" -> {}},
    GridBoxSpacings->{"Columns" -> {{0.15}}}], "\[LessEqual]", "1"}]], 
  "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "b2bbcb37-a6f3-4cf4-b18a-c1efe37fc443"],
 " assumption.)"
}], "Text",ExpressionUUID->"a8764f1e-2394-4f86-b502-cbe5ce692353"],

Cell[TextData[{
 "3.5 [BSc] How do I count the real parameters of a ",
 Cell[BoxData[
  StyleBox["d", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "7b54fe09-4092-4d47-9ddd-159e3f990751"],
 "-dimensional mixed state (density matrix)?"
}], "Subsection",ExpressionUUID->"9e6ed75c-d231-4059-9489-9cf0c594ecd9"],

Cell[TextData[{
 "A ",
 Cell[BoxData[
  RowBox[{
   StyleBox["d", "TI"], "\[Times]", 
   StyleBox["d", "TI"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "13d4a4bd-3e2a-4926-99ca-137079a88fa2"],
 " density matrix is Hermitian (",
 Cell[BoxData[
  SuperscriptBox[
   StyleBox["d", "TI"], "2"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "128f0d40-02aa-45ea-aa76-89d0999b7a88"],
 " real parameters) with unit trace (one constraint), leaving ",
 Cell[BoxData[
  RowBox[{
   SuperscriptBox[
    StyleBox["d", "TI"], "2"], "-", "1"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "8f7da1e6-49dd-4080-bfa1-1f66fc8ad640"],
 ". As in 1.5, the rigorous count is a Jacobian rank."
}], "Text",ExpressionUUID->"1343e6f4-7f96-4a16-9b86-f28601efe593"],

Cell[TextData[{
 StyleBox["WL",
  FontWeight->"Bold"],
 " : the general Hermitian unit-trace qubit ",
 Cell[BoxData[
  RowBox[{
   RowBox[{"{", "{", 
    StyleBox["a", "TI"]}], ",", 
   RowBox[{
    StyleBox["b", "TI"], "+", 
    StyleBox["i", "TI"], 
    StyleBox["c", "TI"], "}"}], ",", 
   RowBox[{"{", 
    StyleBox["b", "TI"], "-", 
    StyleBox["i", "TI"], 
    StyleBox["c", "TI"]}], ",", 
   RowBox[{"1", "-", 
    StyleBox["a", "TI"], "}", "}"}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "4188b04d-8993-4eae-a104-0a37df6e01c6"],
 " has three real parameters; its real-coordinate embedding has Jacobian rank \
",
 Cell[BoxData[
  RowBox[{"3", "=", 
   SuperscriptBox["2", "2"], "-", "1"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "fed7d6aa-f0a0-46dd-83be-196c928671a6"],
 "."
}], "Text",ExpressionUUID->"bee2d137-929f-488c-bd2d-4265a314f303"],

Cell[BoxData[
 RowBox[{"With", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"rho", " ", "=", " ", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"a", ",", " ", 
         RowBox[{"b", " ", "+", " ", 
          RowBox[{"I", " ", "c"}]}]}], "}"}], ",", " ", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"b", " ", "-", " ", 
          RowBox[{"I", " ", "c"}]}], ",", " ", 
         RowBox[{"1", " ", "-", " ", "a"}]}], "}"}]}], "}"}]}], "}"}], ",", 
   "\n", " ", 
   RowBox[{"MatrixRank", "[", 
    RowBox[{"D", "[", 
     RowBox[{
      RowBox[{"Flatten", "[", 
       RowBox[{"ReIm", "[", 
        RowBox[{"Flatten", "[", "rho", "]"}], "]"}], "]"}], ",", " ", 
      RowBox[{"{", 
       RowBox[{"{", 
        RowBox[{"a", ",", " ", "b", ",", " ", "c"}], "}"}], "}"}]}], "]"}], 
    "]"}]}], "]"}]], "Input",
 CellLabel->
  "In[121]:= ",ExpressionUUID->"0376895d-0bf9-409b-a794-aaed044f7f40"],

Cell[TextData[{
 "The general count for dimension ",
 Cell[BoxData[
  StyleBox["d", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "7d946074-6c5f-4fad-9305-f1f18a243f36"],
 " is ",
 Cell[BoxData[
  RowBox[{
   SuperscriptBox[
    StyleBox["d", "TI"], "2"], "-", "1"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "8ce7a1b4-ccfd-4a82-ba62-2eca3d033cbc"],
 "."
}], "Text",ExpressionUUID->"1d41d0a2-2657-49a0-b496-c0f75f0a484f"],

Cell[BoxData[
 RowBox[{"Table", "[", 
  RowBox[{
   RowBox[{
    RowBox[{"d", "^", "2"}], " ", "-", " ", "1"}], ",", " ", 
   RowBox[{"{", 
    RowBox[{"d", ",", " ", "2", ",", " ", "4"}], "}"}]}], "]"}]], "Input",
 CellLabel->
  "In[122]:= ",ExpressionUUID->"5fc27c0c-e6e7-4b3c-b591-ebf5a8b91dea"],

Cell[TextData[{
 StyleBox["QF",
  FontWeight->"Bold"],
 " : drive the general count from the object's own dimension."
}], "Text",ExpressionUUID->"47393b09-805a-4fd8-b9a5-ae0a2c25abf1"],

Cell[BoxData[
 RowBox[{"Table", "[", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{"QuantumState", "[", 
       RowBox[{"\"\<0\>\"", ",", " ", "d"}], "]"}], "[", "\"\<Dimension\>\"", 
      "]"}], "^", "2"}], " ", "-", " ", "1"}], ",", " ", 
   RowBox[{"{", 
    RowBox[{"d", ",", " ", "2", ",", " ", "4"}], "}"}]}], "]"}]], "Input",
 CellLabel->
  "In[123]:= ",ExpressionUUID->"1ca862a7-9864-4d8e-8524-72429a8ae0f8"],

Cell[TextData[{
 "The qubit rank is ",
 Cell[BoxData[
  RowBox[{"3", "=", 
   SuperscriptBox["2", "2"], "-", "1"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "4ac4428a-c3e1-46d4-9b27-ecfcb3122055"],
 "; the general count is ",
 Cell[BoxData[
  RowBox[{
   RowBox[{"{", "3"}], ",", "8", ",", 
   RowBox[{"15", "}"}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "799632f4-bedb-47c0-a9ba-fecafbd89363"],
 " for ",
 Cell[BoxData[
  RowBox[{
   RowBox[{
    StyleBox["d", "TI"], "=", "2"}], ",", 
   RowBox[{"3", ",", "4"}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "5a301e03-e6bd-49a3-be7e-6206a3af9fe4"],
 ". (The pure-state count ",
 Cell[BoxData[
  RowBox[{"2", 
   StyleBox["d", "TI"], "-", "2"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "ac87bf92-2418-4047-a87f-1528eed2caff"],
 " of 1.5 is smaller: a pure state is a measure-zero boundary of the full \
state space.)"
}], "Text",ExpressionUUID->"5b902198-0645-4894-a477-c09f7fb0fab0"],

Cell["\<\
3.6 [BSc] How do I map a qubit density matrix to its Bloch vector and read \
positivity and the pure-state boundary?\
\>", "Subsection",ExpressionUUID->"699f38e6-67bb-4c90-97f0-2670653a3227"],

Cell[TextData[{
 "For a qubit, ",
 Cell[BoxData[
  RowBox[{
   StyleBox["\[Rho]", "TI"], "=", 
   FractionBox["1", "2"], 
   StyleBox["(",
    SpanMaxSize->1], 
   RowBox[{
    StyleBox["I", "TI"], "+", 
    OverscriptBox[
     StyleBox["r", "TI"], "\[RightVector]"], "\[CenterDot]", 
    OverscriptBox[
     StyleBox["\[Sigma]", "TI"], "\[RightVector]"]}], 
   StyleBox[")",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "ebcd8172-d9cb-43b2-8d90-2809b036fcf4"],
 " with ",
 Cell[BoxData[
  RowBox[{
   SubscriptBox[
    StyleBox["r", "TI"], 
    StyleBox["j", "TI"]], "=", 
   StyleBox["Tr",
    FontSlant->"Plain"], 
   StyleBox["[",
    SpanMaxSize->1], 
   RowBox[{
    SubscriptBox[
     StyleBox["\[Sigma]", "TI"], 
     StyleBox["j", "TI"]], 
    StyleBox["\[Rho]", "TI"]}], 
   StyleBox["]",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "8aef7d4d-3c56-47ee-85a4-61603e19d596"],
 "; positivity forces ",
 Cell[BoxData[
  RowBox[{GridBox[{
     {
      OverscriptBox[
       StyleBox["r", "TI"], "\[RightVector]"]}
    },
    GridBoxDividers->{"Columns" -> {True, True}, "Rows" -> {}},
    GridBoxSpacings->{"Columns" -> {{0.15}}}], "\[LessEqual]", "1"}]], 
  "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "2cf6e189-0c5a-48ce-a1e0-657f00917385"],
 ", and ",
 Cell[BoxData[
  RowBox[{GridBox[{
     {
      OverscriptBox[
       StyleBox["r", "TI"], "\[RightVector]"]}
    },
    GridBoxDividers->{"Columns" -> {True, True}, "Rows" -> {}},
    GridBoxSpacings->{"Columns" -> {{0.15}}}], "=", "1"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "790c2c62-cd5d-4417-89b6-fb09a0cc6597"],
 " exactly on the pure states."
}], "Text",ExpressionUUID->"8e257cd8-9c91-4364-8ce4-ce6198a4906f"],

Cell[TextData[{
 StyleBox["WL",
  FontWeight->"Bold"],
 " : build the general qubit state in Bloch form (",
 Cell[BoxData[
  RowBox[{
   OverscriptBox[
    StyleBox["\[Sigma]", "TI"], "\[RightVector]"], "="}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "aa76b13e-9f9d-454d-95aa-bc3ab48f9401"],
 " ",
 Cell[BoxData[
  RowBox[{"PauliMatrix", "[", 
   RowBox[{"{", 
    RowBox[{"1", ",", " ", "2", ",", " ", "3"}], "}"}], "]"}]], 
  "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "2f0bd58d-c379-4390-adb0-06a540366b3c"],
 ")."
}], "Text",ExpressionUUID->"1dd450eb-29e8-4eef-b609-985ff496cd1e"],

Cell[BoxData[
 RowBox[{
  RowBox[{"rhoB", " ", "=", " ", 
   RowBox[{
    RowBox[{"1", "/", "2"}], " ", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"IdentityMatrix", "[", "2", "]"}], " ", "+", " ", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"rx", ",", " ", "ry", ",", " ", "rz"}], "}"}], " ", ".", " ", 
       
       RowBox[{"PauliMatrix", "[", 
        RowBox[{"{", 
         RowBox[{"1", ",", " ", "2", ",", " ", "3"}], "}"}], "]"}]}]}], 
     ")"}]}]}], ";"}]], "Input",
 CellLabel->
  "In[124]:= ",ExpressionUUID->"bad61dfc-9a9b-471c-b963-fc631e0f5f74"],

Cell[TextData[{
 "Recover the Bloch vector as the Pauli expectations ",
 Cell[BoxData[
  RowBox[{
   SubscriptBox[
    StyleBox["r", "TI"], 
    StyleBox["j", "TI"]], "=", 
   StyleBox["Tr",
    FontSlant->"Plain"], 
   StyleBox["[",
    SpanMaxSize->1], 
   RowBox[{
    SubscriptBox[
     StyleBox["\[Sigma]", "TI"], 
     StyleBox["j", "TI"]], 
    StyleBox["\[Rho]", "TI"]}], 
   StyleBox["]",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "2cce2744-7906-4b86-8786-d5679ad54ca5"],
 "."
}], "Text",ExpressionUUID->"33794a57-0e9b-4387-8c7a-5c64a7ee87ea"],

Cell[BoxData[
 RowBox[{"Table", "[", 
  RowBox[{
   RowBox[{"Tr", "[", 
    RowBox[{
     RowBox[{"PauliMatrix", "[", "j", "]"}], " ", ".", " ", "rhoB"}], "]"}], ",",
    " ", 
   RowBox[{"{", 
    RowBox[{"j", ",", " ", "3"}], "}"}]}], "]"}]], "Input",
 CellLabel->
  "In[125]:= ",ExpressionUUID->"b1a6d56f-b30b-40db-81dd-ac6df290ebe3"],

Cell[TextData[{
 "Purity and radius are tied by ",
 Cell[BoxData[
  RowBox[{
   StyleBox["Tr",
    FontSlant->"Plain"], 
   StyleBox["[",
    SpanMaxSize->1], 
   SuperscriptBox[
    StyleBox["\[Rho]", "TI"], "2"], 
   StyleBox["]",
    SpanMaxSize->1], "=", 
   FractionBox["1", "2"], 
   StyleBox["(",
    SpanMaxSize->1], 
   RowBox[{"1", "+", 
    SuperscriptBox[GridBox[{
       {
        OverscriptBox[
         StyleBox["r", "TI"], "\[RightVector]"]}
      },
      GridBoxDividers->{"Columns" -> {True, True}, "Rows" -> {}},
      GridBoxSpacings->{"Columns" -> {{0.15}}}], "2"]}], 
   StyleBox[")",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "6fd4f8d3-f8b3-4f3e-abae-e01c2b06d7b7"],
 ", so ",
 Cell[BoxData[
  RowBox[{GridBox[{
     {
      OverscriptBox[
       StyleBox["r", "TI"], "\[RightVector]"]}
    },
    GridBoxDividers->{"Columns" -> {True, True}, "Rows" -> {}},
    GridBoxSpacings->{"Columns" -> {{0.15}}}], "=", "1"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "799647b8-b246-4a1e-b07e-b3c033083692"],
 " iff the state is pure."
}], "Text",ExpressionUUID->"b0a52b0e-be45-47c8-95f8-5af378b6a8bc"],

Cell[BoxData[
 RowBox[{"FullSimplify", "[", 
  RowBox[{"Tr", "[", 
   RowBox[{"rhoB", " ", ".", " ", "rhoB"}], "]"}], "]"}]], "Input",
 CellLabel->
  "In[126]:= ",ExpressionUUID->"d596233c-174e-4ba5-904d-c498308d3659"],

Cell[TextData[{
 StyleBox["QF",
  FontWeight->"Bold"],
 " : the object computes the Bloch vector directly from the same ",
 Cell[BoxData[
  StyleBox["\[Rho]", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "d663de6b-d7f8-437a-9228-9e609e2d7efe"],
 "."
}], "Text",ExpressionUUID->"1b911cd2-4e5b-46e8-a2ef-c980344a42a4"],

Cell[BoxData[
 RowBox[{
  RowBox[{"QuantumState", "[", "rhoB", "]"}], "[", "\"\<BlochVector\>\"", 
  "]"}]], "Input",
 CellLabel->
  "In[127]:= ",ExpressionUUID->"bd5aad59-65c3-4097-a0cc-a06025eff3dc"],

Cell[TextData[{
 "Both recover ",
 Cell[BoxData[
  RowBox[{
   OverscriptBox[
    StyleBox["r", "TI"], "\[RightVector]"], "=", 
   StyleBox["(",
    SpanMaxSize->1], 
   RowBox[{
    SubscriptBox[
     StyleBox["r", "TI"], 
     StyleBox["x", "TI"]], ",", 
    SubscriptBox[
     StyleBox["r", "TI"], 
     StyleBox["y", "TI"]], ",", 
    SubscriptBox[
     StyleBox["r", "TI"], 
     StyleBox["z", "TI"]]}], 
   StyleBox[")",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "c7cbe9ec-a9e3-477c-b786-fa618fefdd95"],
 ", and the purity is ",
 Cell[BoxData[
  RowBox[{
   FractionBox["1", "2"], 
   StyleBox["(",
    SpanMaxSize->1], 
   RowBox[{"1", "+", 
    SubsuperscriptBox[
     StyleBox["r", "TI"], 
     StyleBox["x", "TI"], "2"], "+", 
    SubsuperscriptBox[
     StyleBox["r", "TI"], 
     StyleBox["y", "TI"], "2"], "+", 
    SubsuperscriptBox[
     StyleBox["r", "TI"], 
     StyleBox["z", "TI"], "2"]}], 
   StyleBox[")",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "3908b8d2-511b-480b-aed7-bd338e712af1"],
 ": positivity (",
 Cell[BoxData[
  RowBox[{
   StyleBox["\[Rho]", "TI"], "\[SucceedsEqual]", "0"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "f646274b-c44b-4bee-9fb1-e7e50563b1f7"],
 ") is exactly ",
 Cell[BoxData[
  RowBox[{GridBox[{
     {
      OverscriptBox[
       StyleBox["r", "TI"], "\[RightVector]"]}
    },
    GridBoxDividers->{"Columns" -> {True, True}, "Rows" -> {}},
    GridBoxSpacings->{"Columns" -> {{0.15}}}], "\[LessEqual]", "1"}]], 
  "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "5f3ddc41-67c3-4e91-b45c-5d653b5266dc"],
 " (the Bloch ball), and the pure states are its surface ",
 Cell[BoxData[
  RowBox[{GridBox[{
     {
      OverscriptBox[
       StyleBox["r", "TI"], "\[RightVector]"]}
    },
    GridBoxDividers->{"Columns" -> {True, True}, "Rows" -> {}},
    GridBoxSpacings->{"Columns" -> {{0.15}}}], "=", "1"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "68a30d95-0b25-461d-972f-69e3587c69dd"],
 "."
}], "Text",ExpressionUUID->"d3514eee-4334-441e-a330-9666f3b8b2f3"],

Cell["\<\
3.7 [MSc] How do I show that the state space is convex, with pure states as \
its extreme points?\
\>", "Subsection",ExpressionUUID->"26472b69-641a-4ecf-8c08-30ab23723637"],

Cell[TextData[{
 "The density operators form a convex set: any mixture ",
 Cell[BoxData[
  RowBox[{
   StyleBox["p", "TI"], 
   SubscriptBox[
    StyleBox["\[Rho]", "TI"], "1"], "+", 
   StyleBox["(",
    SpanMaxSize->1], 
   RowBox[{"1", "-", 
    StyleBox["p", "TI"]}], 
   StyleBox[")",
    SpanMaxSize->1], 
   SubscriptBox[
    StyleBox["\[Rho]", "TI"], "2"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "081c524f-346d-4f7e-96c6-b82a0f603042"],
 " is again a state. The pure states are its extreme points, which for a \
qubit is the surface of the Bloch ball."
}], "Text",ExpressionUUID->"7c394bcd-635a-4a20-8e69-bce967c2b996"],

Cell[TextData[{
 StyleBox["WL",
  FontWeight->"Bold"],
 " : every pure qubit sits on the sphere (",
 Cell[BoxData[
  RowBox[{GridBox[{
     {
      OverscriptBox[
       StyleBox["r", "TI"], "\[RightVector]"]}
    },
    GridBoxDividers->{"Columns" -> {True, True}, "Rows" -> {}},
    GridBoxSpacings->{"Columns" -> {{0.15}}}], "=", "1"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "0f7bf8ef-03a5-4688-9e20-e609b7a35ec9"],
 "), so pure states are extreme."
}], "Text",ExpressionUUID->"eb1631a4-beba-44ea-8b6c-c6789dafdda9"],

Cell[BoxData[
 RowBox[{"FullSimplify", "[", "\n", " ", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"Norm", "[", 
      RowBox[{"Table", "[", 
       RowBox[{
        RowBox[{"Tr", "[", 
         RowBox[{
          RowBox[{"PauliMatrix", "[", "j", "]"}], " ", ".", " ", 
          RowBox[{"KroneckerProduct", "[", 
           RowBox[{"#", ",", " ", 
            RowBox[{"Conjugate", "[", "#", "]"}]}], "]"}]}], "]"}], ",", " ", 
        
        RowBox[{"{", 
         RowBox[{"j", ",", " ", "3"}], "}"}]}], "]"}], "]"}], " ", "&"}], " ",
     "@", " ", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"Cos", "[", 
       RowBox[{"\[Theta]", "/", "2"}], "]"}], ",", " ", 
      RowBox[{
       RowBox[{"Exp", "[", 
        RowBox[{"I", " ", "\[Phi]"}], "]"}], " ", 
       RowBox[{"Sin", "[", 
        RowBox[{"\[Theta]", "/", "2"}], "]"}]}]}], "}"}]}], ",", "\n", " ", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"\[Theta]", ",", " ", "\[Phi]"}], "}"}], " ", "\[Element]", " ", 
    "Reals"}]}], "]"}]], "Input",
 CellLabel->
  "In[128]:= ",ExpressionUUID->"9d13351b-ae09-4b15-99ed-6627b1178ab7"],

Cell[TextData[{
 "A nontrivial mixture of two distinct pure states (here ",
 Cell[BoxData[
  TemplateBox[{"0"},
   "Ket"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "0564ed12-2dcb-4635-864a-381c43d8de12"],
 " and ",
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     StyleBox["R", "TI"]},
    "Ket"], "=", "{", "1", ",", 
   StyleBox["i", "TI"], "}", "/", 
   SqrtBox["2"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "08dd94b8-97bf-4fd7-b480-134478115ee1"],
 ", the same pair used by the QF cells below) lands strictly inside (purity \
",
 Cell[BoxData[
  RowBox[{"<", "1"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "b808b482-d41d-421d-87c5-6a0126f12757"],
 ")."
}], "Text",ExpressionUUID->"0a505685-1fec-400c-9663-5a13716847e5"],

Cell[BoxData[
 RowBox[{"With", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"p", " ", "=", " ", 
     RowBox[{"1", "/", "3"}]}], "}"}], ",", "\n", " ", 
   RowBox[{
    RowBox[{
     RowBox[{"Tr", "[", 
      RowBox[{"#", ".", "#"}], "]"}], " ", "&"}], "[", 
    RowBox[{
     RowBox[{"p", " ", 
      RowBox[{"KroneckerProduct", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"1", ",", " ", "0"}], "}"}], ",", " ", 
        RowBox[{"Conjugate", "[", 
         RowBox[{"{", 
          RowBox[{"1", ",", " ", "0"}], "}"}], "]"}]}], "]"}]}], " ", "+", 
     " ", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{"1", " ", "-", " ", "p"}], ")"}], " ", 
      RowBox[{"KroneckerProduct", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"{", 
          RowBox[{"1", ",", " ", "I"}], "}"}], "/", 
         RowBox[{"Sqrt", "[", "2", "]"}]}], ",", " ", 
        RowBox[{"Conjugate", "[", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{"1", ",", " ", "I"}], "}"}], "/", 
          RowBox[{"Sqrt", "[", "2", "]"}]}], "]"}]}], "]"}]}]}], "]"}]}], 
  "]"}]], "Input",
 CellLabel->
  "In[129]:= ",ExpressionUUID->"0ca9ba46-eb9e-4024-a0ea-f2569e300bf2"],

Cell[TextData[{
 StyleBox["QF",
  FontWeight->"Bold"],
 " : build the same mixture as an object."
}], "Text",ExpressionUUID->"0fb19ed9-db67-4797-9c61-d37c3ff4c583"],

Cell[BoxData[
 RowBox[{"mix", " ", "=", " ", 
  RowBox[{"QuantumState", "[", 
   RowBox[{
    RowBox[{
     RowBox[{"1", "/", "3"}], " ", 
     RowBox[{
      RowBox[{"QuantumState", "[", 
       RowBox[{"{", 
        RowBox[{"1", ",", " ", "0"}], "}"}], "]"}], 
      "[", "\"\<DensityMatrix\>\"", "]"}]}], " ", "+", " ", 
    RowBox[{
     RowBox[{"2", "/", "3"}], " ", 
     RowBox[{
      RowBox[{"QuantumState", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"1", ",", " ", "I"}], "}"}], "/", 
        RowBox[{"Sqrt", "[", "2", "]"}]}], "]"}], "[", "\"\<DensityMatrix\>\"",
       "]"}]}]}], "]"}]}]], "Input",
 CellLabel->
  "In[130]:= ",ExpressionUUID->"3235099b-1b29-418e-8679-c90bae0bf0db"],

Cell["Its purity is below one.", "Text",ExpressionUUID->"5dafa15a-cdda-4ed7-a2ab-aca70b01731f"],

Cell[BoxData[
 RowBox[{"mix", "[", "\"\<Purity\>\"", "]"}]], "Input",
 CellLabel->
  "In[131]:= ",ExpressionUUID->"b7bd61d8-da79-4db4-b626-2ab01745c9df"],

Cell["\<\
Its Bloch radius is below one, so it lies in the interior of the ball.\
\>", "Text",ExpressionUUID->"d1d1f1d5-4079-4091-9e0f-687925cad730"],

Cell[BoxData[
 RowBox[{"Norm", "[", 
  RowBox[{"mix", "[", "\"\<BlochVector\>\"", "]"}], "]"}]], "Input",
 CellLabel->
  "In[132]:= ",ExpressionUUID->"84f95d2f-762c-4c2d-b919-d26aea480011"],

Cell["\<\
The Bloch map is affine: the mixture's Bloch vector is the convex combination \
of the components'.\
\>", "Text",ExpressionUUID->"1f62c879-548f-4331-91d2-169b141bfd8c"],

Cell[BoxData[
 RowBox[{
  RowBox[{"mix", "[", "\"\<BlochVector\>\"", "]"}], " ", "==", " ", 
  RowBox[{
   RowBox[{
    RowBox[{"1", "/", "3"}], " ", 
    RowBox[{
     RowBox[{"QuantumState", "[", 
      RowBox[{"{", 
       RowBox[{"1", ",", " ", "0"}], "}"}], "]"}], "[", "\"\<BlochVector\>\"",
      "]"}]}], " ", "+", " ", 
   RowBox[{
    RowBox[{"2", "/", "3"}], " ", 
    RowBox[{
     RowBox[{"QuantumState", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"1", ",", " ", "I"}], "}"}], "/", 
       RowBox[{"Sqrt", "[", "2", "]"}]}], "]"}], "[", "\"\<BlochVector\>\"", 
     "]"}]}]}]}]], "Input",
 CellLabel->
  "In[133]:= ",ExpressionUUID->"e6d5d927-cda9-4b01-a231-a910d0b24476"],

Cell[TextData[{
 "Pure states have radius ",
 Cell[BoxData["1"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "659f9b42-49f3-4e19-ba3f-b2979a23efa7"],
 " (extreme points, not expressible as a nontrivial mixture); every mixture \
has radius and purity below ",
 Cell[BoxData["1"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "674e6289-1c99-4294-9261-a21415cb92cf"],
 " and lies in the interior; and because the Bloch map is affine, mixing \
states maps to mixing their Bloch vectors. That is the convex geometry of the \
Bloch ball."
}], "Text",ExpressionUUID->"9d557c74-5e26-4ac7-8c5c-1cdaae850531"],

Cell["\<\
3.8 [BSc] How do I compute the von Neumann entropy of a density matrix?\
\>", "Subsection",ExpressionUUID->"ef6deb4c-0b25-4b26-99a8-a2419b98ed93"],

Cell[TextData[{
 "The von Neumann entropy ",
 Cell[BoxData[
  RowBox[{
   StyleBox["S", "TI"], 
   StyleBox["(",
    SpanMaxSize->1], 
   StyleBox["\[Rho]", "TI"], 
   StyleBox[")",
    SpanMaxSize->1], "=", "-", 
   StyleBox["Tr",
    FontSlant->"Plain"], 
   StyleBox["[",
    SpanMaxSize->1], 
   RowBox[{
    StyleBox["\[Rho]", "TI"], 
    StyleBox["log",
     FontSlant->"Plain"], "\[ThinSpace]", 
    StyleBox["\[Rho]", "TI"]}], 
   StyleBox["]",
    SpanMaxSize->1], "=", "-", 
   UnderscriptBox["\[Sum]", 
    StyleBox["k", "TI"],
    LimitsPositioning->False], 
   SubscriptBox[
    StyleBox["\[Lambda]", "TI"], 
    StyleBox["k", "TI"]], 
   StyleBox["log",
    FontSlant->"Plain"], "\[ThinSpace]", 
   SubscriptBox[
    StyleBox["\[Lambda]", "TI"], 
    StyleBox["k", "TI"]]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "cd3852ea-3e1d-4501-89ac-ade16d9af0a8"],
 " is the Shannon entropy of the eigenvalue spectrum: ",
 Cell[BoxData["0"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "82f0cdbb-b650-49b5-ac04-5b710d5dfda3"],
 " for a pure state, ",
 Cell[BoxData[
  RowBox[{
   SubscriptBox[
    StyleBox["log",
     FontSlant->"Plain"], "2"], "\[ThinSpace]", 
   StyleBox["d", "TI"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "ae85a042-8b90-411f-a58e-e0dbc1be5b97"],
 " for the maximally mixed."
}], "Text",ExpressionUUID->"80df8679-bcdf-4c10-a69b-b28f145a1a75"],

Cell[TextData[{
 StyleBox["WL",
  FontWeight->"Bold"],
 " : the Shannon entropy of the eigenvalues, in bits."
}], "Text",ExpressionUUID->"4e70f1f3-0ed2-425d-bc4d-055a774579c3"],

Cell[BoxData[
 RowBox[{"-", 
  RowBox[{"Total", "[", 
   RowBox[{
    RowBox[{
     RowBox[{"#", " ", 
      RowBox[{"Log2", "[", "#", "]"}]}], " ", "&"}], " ", "/@", " ", 
    RowBox[{"Eigenvalues", "[", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{"3", "/", "4"}], ",", " ", "0"}], "}"}], ",", " ", 
       RowBox[{"{", 
        RowBox[{"0", ",", " ", 
         RowBox[{"1", "/", "4"}]}], "}"}]}], "}"}], "]"}]}], "]"}]}]], "Input",\

 CellLabel->
  "In[134]:= ",ExpressionUUID->"62d488ee-8601-4a36-ab8b-460119f96620"],

Cell[TextData[{
 StyleBox["QF",
  FontWeight->"Bold"],
 " : the object reports it directly (as a ",
 Cell[BoxData["Quantity"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "43116c7f-162e-4910-b32b-7ef18fbc6ec3"],
 " in bits)."
}], "Text",ExpressionUUID->"b98eb477-e4b3-4aa1-a378-41a749c48589"],

Cell[BoxData[
 RowBox[{
  RowBox[{"QuantumState", "[", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"3", "/", "4"}], ",", " ", "0"}], "}"}], ",", " ", 
     RowBox[{"{", 
      RowBox[{"0", ",", " ", 
       RowBox[{"1", "/", "4"}]}], "}"}]}], "}"}], "]"}], 
  "[", "\"\<VonNeumannEntropy\>\"", "]"}]], "Input",
 CellLabel->
  "In[135]:= ",ExpressionUUID->"f90a69cd-dfbe-4c8d-90eb-9c665e8f5709"],

Cell[TextData[{
 "Both give ",
 Cell[BoxData[
  RowBox[{"-", 
   FractionBox["3", "4"], 
   SubscriptBox[
    StyleBox["log",
     FontSlant->"Plain"], "2"], "\[ThinSpace]", 
   FractionBox["3", "4"], "-", 
   FractionBox["1", "4"], 
   SubscriptBox[
    StyleBox["log",
     FontSlant->"Plain"], "2"], "\[ThinSpace]", 
   FractionBox["1", "4"], "\[TildeTilde]", "0.811"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "c307eaec-18a4-43f8-a302-5c74b438733b"],
 " bits: the entropy is the classical uncertainty of the eigenvalue \
distribution, vanishing on a pure state and reaching ",
 Cell[BoxData[
  RowBox[{
   SubscriptBox[
    StyleBox["log",
     FontSlant->"Plain"], "2"], "\[ThinSpace]", 
   StyleBox["d", "TI"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "7a973901-16a4-451c-a631-11c29bce0a34"],
 " on the maximally mixed state."
}], "Text",ExpressionUUID->"0fc39eeb-e8c2-4e47-948e-2efa19a225a3"],

Cell["\<\
3.9 [BSc] How do I test whether a matrix is a valid density operator?\
\>", "Subsection",ExpressionUUID->"9ca15ce8-edd2-418d-918c-351baedd15ae"],

Cell[TextData[{
 "A density operator must satisfy three conditions: Hermiticity (",
 Cell[BoxData[
  RowBox[{
   StyleBox["\[Rho]", "TI"], "=", 
   SuperscriptBox[
    StyleBox["\[Rho]", "TI"], "\[Dagger]"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "83024b96-63ff-475e-865a-913d9e3795ea"],
 "), unit trace (",
 Cell[BoxData[
  RowBox[{
   StyleBox["Tr",
    FontSlant->"Plain"], " ", 
   StyleBox["\[Rho]", "TI"], "=", "1"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "e5ed3e88-9dd6-402e-8546-e498bddef670"],
 "), and positive semidefiniteness (",
 Cell[BoxData[
  RowBox[{
   StyleBox["\[Rho]", "TI"], "\[SucceedsEqual]", "0"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "20c770a4-633f-4707-aee5-444fad33b530"],
 ", no negative eigenvalue). Together they are exactly what makes ",
 Cell[BoxData[
  StyleBox["\[Rho]", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "e1368251-2f02-4e71-896f-c4d859d344ec"],
 " a legitimate state."
}], "Text",ExpressionUUID->"e802ea88-41be-44ec-bdf6-74c9bd095ecd"],

Cell[TextData[{
 StyleBox["WL",
  FontWeight->"Bold"],
 " : check the three conditions on a candidate matrix."
}], "Text",ExpressionUUID->"483de471-d4e1-4caf-96fc-7558ef79d872"],

Cell[BoxData[
 RowBox[{"With", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"rho", " ", "=", " ", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{"3", "/", "4"}], ",", " ", "0"}], "}"}], ",", " ", 
       RowBox[{"{", 
        RowBox[{"0", ",", " ", 
         RowBox[{"1", "/", "4"}]}], "}"}]}], "}"}]}], "}"}], ",", "\n", " ", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"HermitianMatrixQ", "[", "rho", "]"}], ",", " ", 
     RowBox[{
      RowBox[{"Tr", "[", "rho", "]"}], " ", "==", " ", "1"}], ",", " ", 
     RowBox[{"PositiveSemidefiniteMatrixQ", "[", "rho", "]"}]}], "}"}]}], 
  "]"}]], "Input",
 CellLabel->
  "In[136]:= ",ExpressionUUID->"4a8c5681-a55d-4913-bdad-de2410563069"],

Cell["\<\
A Hermitian, unit-trace matrix that fails positivity is not a state.\
\>", "Text",ExpressionUUID->"f99840f0-e4a1-465b-a38f-cdc06d1b509a"],

Cell[BoxData[
 RowBox[{"With", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"rho", " ", "=", " ", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{"3", "/", "4"}], ",", " ", "1"}], "}"}], ",", " ", 
       RowBox[{"{", 
        RowBox[{"1", ",", " ", 
         RowBox[{"1", "/", "4"}]}], "}"}]}], "}"}]}], "}"}], ",", "\n", " ", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"HermitianMatrixQ", "[", "rho", "]"}], ",", " ", 
     RowBox[{
      RowBox[{"Tr", "[", "rho", "]"}], " ", "==", " ", "1"}], ",", " ", 
     RowBox[{"PositiveSemidefiniteMatrixQ", "[", "rho", "]"}]}], "}"}]}], 
  "]"}]], "Input",
 CellLabel->
  "In[137]:= ",ExpressionUUID->"d1c2048b-ce91-4572-b382-78003c91d853"],

Cell[TextData[{
 StyleBox["QF",
  FontWeight->"Bold"],
 " : the object folds all three conditions into the single property ",
 Cell[BoxData["\"\<PhysicalQ\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "575f1387-0fb3-4655-b3c5-b432064a2c87"],
 "."
}], "Text",ExpressionUUID->"872d643e-cc40-4903-b78b-3f12af5886f5"],

Cell[BoxData[
 RowBox[{
  RowBox[{"QuantumState", "[", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"3", "/", "4"}], ",", " ", "0"}], "}"}], ",", " ", 
     RowBox[{"{", 
      RowBox[{"0", ",", " ", 
       RowBox[{"1", "/", "4"}]}], "}"}]}], "}"}], "]"}], 
  "[", "\"\<PhysicalQ\>\"", "]"}]], "Input",
 CellLabel->
  "In[138]:= ",ExpressionUUID->"c17f7ef3-9f44-495a-a0d3-71905293c024"],

Cell["The invalid matrix fails it.", "Text",ExpressionUUID->"228dca0a-8c28-4b1a-9e80-f3fdd6cbf0cd"],

Cell[BoxData[
 RowBox[{
  RowBox[{"QuantumState", "[", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"3", "/", "4"}], ",", " ", "1"}], "}"}], ",", " ", 
     RowBox[{"{", 
      RowBox[{"1", ",", " ", 
       RowBox[{"1", "/", "4"}]}], "}"}]}], "}"}], "]"}], 
  "[", "\"\<PhysicalQ\>\"", "]"}]], "Input",
 CellLabel->
  "In[139]:= ",ExpressionUUID->"c2fdec21-a5f3-44f9-a1b7-d89f0cd54b3e"],

Cell[TextData[{
 "Both agree: the first matrix is a valid density operator (the three \
conditions all hold and ",
 Cell[BoxData["\"\<PhysicalQ\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "4a72c3b0-5de4-4ba8-9783-30f55f417882"],
 " is ",
 Cell[BoxData["True"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "cd68e355-d3a8-469d-b6a1-5b5fc820cdf9"],
 "); the second is Hermitian and unit-trace but not positive (one eigenvalue \
is negative), so it is not a physical state."
}], "Text",ExpressionUUID->"2cf61624-d0c1-44e6-a226-7d8b82961255"],

Cell["Part 4. Composite systems: tensor product and partial trace", "Section",ExpressionUUID->"3ef90c34-0f06-4ced-80df-9e6473ad6bb2"],

Cell["\<\
4.1 [BSc] How do I form the tensor product of states and of operators?\
\>", "Subsection",ExpressionUUID->"77e5fef2-881a-4487-b285-af35eacf5b91"],

Cell[TextData[{
 "Two subsystems combine by the tensor product: states as ",
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     StyleBox["\[Psi]", "TI"]},
    "Ket"], "\[CircleTimes]", 
   TemplateBox[{
     StyleBox["\[Phi]", "TI"]},
    "Ket"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "64d8e194-d447-4fc6-9795-1a6c6f999c83"],
 ", operators as ",
 Cell[BoxData[
  RowBox[{
   StyleBox["A", "TI"], "\[CircleTimes]", 
   StyleBox["B", "TI"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "9731c9cd-8cd8-40ca-9007-0cf1a03da67f"],
 ", and the two are compatible, ",
 Cell[BoxData[
  RowBox[{
   RowBox[{
    RowBox[{
     StyleBox["(",
      SpanMaxSize->1], 
     RowBox[{
      StyleBox["A", "TI"], "\[CircleTimes]", 
      StyleBox["B", "TI"]}], 
     StyleBox[")",
      SpanMaxSize->1]}], 
    RowBox[{"(", 
     RowBox[{
      TemplateBox[{
        StyleBox["\[Psi]", "TI"]},
       "Ket"], "\[CircleTimes]", 
      TemplateBox[{
        StyleBox["\[Phi]", "TI"]},
       "Ket"]}], ")"}]}], "=", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{
      StyleBox["A", "TI"], 
      TemplateBox[{
        StyleBox["\[Psi]", "TI"]},
       "Ket"]}], ")"}], "\[CircleTimes]", 
    RowBox[{"(", 
     RowBox[{
      StyleBox["B", "TI"], 
      TemplateBox[{
        StyleBox["\[Phi]", "TI"]},
       "Ket"]}], ")"}]}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "ea54edad-4222-4982-9b71-c2e386303335"],
 ". In the computational basis the tensor product is the Kronecker product, \
and the composite lives in the ",
 Cell[BoxData[
  RowBox[{
   SubscriptBox[
    StyleBox["d", "TI"], "1"], 
   SubscriptBox[
    StyleBox["d", "TI"], "2"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "1364a11f-545d-4758-9bcc-6902a26fa793"],
 "-dimensional product space."
}], "Text",ExpressionUUID->"8ca0b5fb-2c8e-4835-bb05-f79d92df96f2"],

Cell[TextData[{
 StyleBox["WL",
  FontWeight->"Bold"],
 " : the tensor product of two amplitude vectors is their (flattened) \
Kronecker product."
}], "Text",ExpressionUUID->"e45d9e12-d38e-4490-8c5e-11935e4b2ca0"],

Cell[BoxData[
 RowBox[{"Flatten", "[", 
  RowBox[{"KroneckerProduct", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"a", ",", " ", "b"}], "}"}], ",", " ", 
    RowBox[{"{", 
     RowBox[{"c", ",", " ", "d"}], "}"}]}], "]"}], "]"}]], "Input",
 CellLabel->
  "In[140]:= ",ExpressionUUID->"07801e86-3d4e-4575-a451-f26e9eb35a6f"],

Cell[TextData[{
 "The tensor product of two operators is the Kronecker product of their \
matrices, here ",
 Cell[BoxData[
  RowBox[{
   StyleBox["X", "TI"], "\[CircleTimes]", 
   StyleBox["Z", "TI"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "212337b7-c790-46d4-9d1d-de0eb27bea40"],
 "."
}], "Text",ExpressionUUID->"55ebd6a7-2202-4326-a93e-92cac594d0a7"],

Cell[BoxData[
 RowBox[{"KroneckerProduct", "[", 
  RowBox[{
   RowBox[{"PauliMatrix", "[", "1", "]"}], ",", " ", 
   RowBox[{"PauliMatrix", "[", "3", "]"}]}], "]"}]], "Input",
 CellLabel->
  "In[141]:= ",ExpressionUUID->"b33c4fbd-8d7d-4316-aab6-5b2d00b2a8c6"],

Cell[TextData[{
 StyleBox["QF",
  FontWeight->"Bold"],
 " : ",
 Cell[BoxData["QuantumTensorProduct"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "3ecef483-8a58-4cbe-9383-7ed9f3cabdfb"],
 " combines two states into one two-qubit state object."
}], "Text",ExpressionUUID->"83f0fbd3-26b1-4f0b-bcbc-d93ed24397b2"],

Cell[BoxData[
 RowBox[{"QuantumTensorProduct", "[", 
  RowBox[{
   RowBox[{"QuantumState", "[", 
    RowBox[{"{", 
     RowBox[{"a", ",", " ", "b"}], "}"}], "]"}], ",", " ", 
   RowBox[{"QuantumState", "[", 
    RowBox[{"{", 
     RowBox[{"c", ",", " ", "d"}], "}"}], "]"}]}], "]"}]], "Input",
 CellLabel->
  "In[142]:= ",ExpressionUUID->"b77f1bdb-7e3b-4246-8cd2-82509f834b1c"],

Cell[TextData[{
 "Its ",
 Cell[BoxData["\"\<StateVector\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "8049db46-bd0b-46b9-bcc3-5a62f4cbb8f2"],
 " is that same Kronecker product."
}], "Text",ExpressionUUID->"eb6f2c50-8658-4c04-b70a-3ac873df5880"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"QuantumTensorProduct", "[", 
    RowBox[{
     RowBox[{"QuantumState", "[", 
      RowBox[{"{", 
       RowBox[{"a", ",", " ", "b"}], "}"}], "]"}], ",", " ", 
     RowBox[{"QuantumState", "[", 
      RowBox[{"{", 
       RowBox[{"c", ",", " ", "d"}], "}"}], "]"}]}], "]"}], 
   "[", "\"\<StateVector\>\"", "]"}], " ", "//", " ", "Normal"}]], "Input",
 CellLabel->
  "In[143]:= ",ExpressionUUID->"e5bf3579-45c4-4af4-91be-46c4419ad7e5"],

Cell[TextData[{
 "It joins operators the same way; here ",
 Cell[BoxData[
  RowBox[{
   StyleBox["X", "TI"], "\[CircleTimes]", 
   StyleBox["Z", "TI"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "f429d032-3c65-451e-a9a0-dcf50bbdeac4"],
 " kept as a ",
 Cell[BoxData["QuantumOperator"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "9baaef99-6f35-4342-9fa2-c5b2d2cca611"],
 "."
}], "Text",ExpressionUUID->"e586b2fd-cfc4-43bf-93f2-c6f84ef83a2b"],

Cell[BoxData[
 RowBox[{"QuantumTensorProduct", "[", 
  RowBox[{
   RowBox[{"QuantumOperator", "[", "\"\<X\>\"", "]"}], ",", " ", 
   RowBox[{"QuantumOperator", "[", "\"\<Z\>\"", "]"}]}], "]"}]], "Input",
 CellLabel->
  "In[144]:= ",ExpressionUUID->"8e97ecbd-65ea-40e3-8e42-1aae43e7c512"],

Cell[TextData[{
 "Both give the amplitude vector ",
 Cell[BoxData[
  RowBox[{
   RowBox[{
    RowBox[{"{", 
     StyleBox["a", "TI"], 
     StyleBox["c", "TI"]}], ",", " ", 
    StyleBox[
     RowBox[{"a", "d"}], "TI"], ",", " ", 
    StyleBox[
     RowBox[{"b", "c"}], "TI"], ",", " ", 
    StyleBox[
     RowBox[{"b", "d"}], "TI"]}], "}"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "02b8cebb-8ef2-4323-93a2-3057f812b244"],
 " and the operator ",
 Cell[BoxData[
  RowBox[{
   StyleBox["X", "TI"], "\[CircleTimes]", 
   StyleBox["Z", "TI"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "50bdc815-11ff-4553-a36c-08cf33112c98"],
 ": the composite state factorizes into its parts, and the QF object \
additionally knows it is a two-qubit system (its factors, order, and basis), \
a matrix being just one representation read from it."
}], "Text",ExpressionUUID->"369fe915-b464-4ad9-a4ea-c1dafaf8493b"],

Cell["\<\
4.2 [BSc] How do I take a partial trace of a two-party state and obtain a \
reduced density matrix?\
\>", "Subsection",ExpressionUUID->"e4edf504-f975-4d4a-9067-197641ba960e"],

Cell[TextData[{
 "The state of subsystem ",
 Cell[BoxData[
  StyleBox["A", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "75088860-0724-4cf2-800b-4c91571ecb14"],
 " alone is the reduced density matrix ",
 Cell[BoxData[
  RowBox[{
   SubscriptBox[
    StyleBox["\[Rho]", "TI"], 
    StyleBox["A", "TI"]], "=", 
   SubscriptBox[
    StyleBox["Tr",
     FontSlant->"Plain"], 
    StyleBox["B", "TI"]], 
   StyleBox["[",
    SpanMaxSize->1], 
   SubscriptBox[
    StyleBox["\[Rho]", "TI"], 
    StyleBox[
     RowBox[{"A", "B"}], "TI"]], 
   StyleBox["]",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "a86fc52d-013a-4769-a27c-d906127acf6e"],
 ", formed by tracing out ",
 Cell[BoxData[
  StyleBox["B", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "794a8172-ac08-408b-8d11-59ff26cb16f4"],
 ". For a product state ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["\[Rho]", "TI"], 
   StyleBox["A", "TI"]]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "908e3f1c-26a0-4600-b820-66ba8aac2cbb"],
 " stays pure; for an ",
 StyleBox["entangled", "TI"],
 " state it comes out mixed, which is the operational signature of \
entanglement."
}], "Text",ExpressionUUID->"94d7e4ab-9736-4e12-98b5-5bcc8236aeb4"],

Cell[TextData[{
 StyleBox["WL",
  FontWeight->"Bold"],
 " : trace qubit ",
 Cell[BoxData[
  StyleBox["B", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "28e65c6e-6f95-4cc6-bcb3-a6981ef41998"],
 " out of the Bell state ",
 Cell[BoxData[
  RowBox[{
   StyleBox["\[Rho]", "TI"], "=", 
   RowBox[{
    TemplateBox[{
      SuperscriptBox["\[CapitalPhi]", "+"]},
     "Ket"], 
    TemplateBox[{
      SuperscriptBox["\[CapitalPhi]", "+"]},
     "Bra"]}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "46ad6832-d8f0-42ff-90b3-4f8a3895d591"],
 " by reshaping the ",
 Cell[BoxData[
  RowBox[{"4", "\[Times]", "4"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "0faca567-51de-4ffa-8354-5f38093f7e87"],
 " matrix to a ",
 Cell[BoxData[
  RowBox[{"2", "\[Times]", "2", "\[Times]", "2", "\[Times]", "2"}]], 
  "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "1bf1cd67-b0db-480f-81f9-406275f11472"],
 " tensor and contracting the two ",
 Cell[BoxData[
  StyleBox["B", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "803444e3-1a16-4b8b-9060-6751d7aab18b"],
 " indices."
}], "Text",ExpressionUUID->"74586dfe-8c35-47f1-839f-0a78ae3bb919"],

Cell[BoxData[
 RowBox[{"With", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"bell", " ", "=", " ", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"1", ",", " ", "0", ",", " ", "0", ",", " ", "1"}], "}"}], "/", 
      RowBox[{"Sqrt", "[", "2", "]"}]}]}], "}"}], ",", "\n", " ", 
   RowBox[{"TensorContract", "[", 
    RowBox[{
     RowBox[{"ArrayReshape", "[", 
      RowBox[{
       RowBox[{"KroneckerProduct", "[", 
        RowBox[{"bell", ",", " ", 
         RowBox[{"Conjugate", "[", "bell", "]"}]}], "]"}], ",", " ", 
       RowBox[{"{", 
        RowBox[{"2", ",", " ", "2", ",", " ", "2", ",", " ", "2"}], "}"}]}], 
      "]"}], ",", " ", 
     RowBox[{"{", 
      RowBox[{"{", 
       RowBox[{"2", ",", " ", "4"}], "}"}], "}"}]}], "]"}]}], "]"}]], "Input",\

 CellLabel->
  "In[145]:= ",ExpressionUUID->"6baac0be-c0cd-4591-9afb-3340b2260f8d"],

Cell[TextData[{
 StyleBox["QF",
  FontWeight->"Bold"],
 " : ",
 Cell[BoxData["QuantumPartialTrace"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "1514392a-2456-48fe-b96f-23571aa2a804"],
 " traces out the listed qubit and returns the reduced state as an object."
}], "Text",ExpressionUUID->"87dfb0ec-0e0c-4562-8a00-78df8c783661"],

Cell[BoxData[
 RowBox[{"QuantumPartialTrace", "[", 
  RowBox[{
   RowBox[{"QuantumState", "[", "\"\<PhiPlus\>\"", "]"}], ",", " ", 
   RowBox[{"{", "2", "}"}]}], "]"}]], "Input",
 CellLabel->
  "In[146]:= ",ExpressionUUID->"d4800ef7-31e5-4d66-938f-17ee8741a5f9"],

Cell[TextData[{
 "Its ",
 Cell[BoxData["\"\<Purity\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "ab851974-2a03-4c92-827e-693404c38af0"],
 " is below one, so the reduction of the entangled pair is mixed."
}], "Text",ExpressionUUID->"2363b53d-d47a-4673-b68f-ba65ef5e529c"],

Cell[BoxData[
 RowBox[{
  RowBox[{"QuantumPartialTrace", "[", 
   RowBox[{
    RowBox[{"QuantumState", "[", "\"\<PhiPlus\>\"", "]"}], ",", " ", 
    RowBox[{"{", "2", "}"}]}], "]"}], "[", "\"\<Purity\>\"", "]"}]], "Input",
 CellLabel->
  "In[147]:= ",ExpressionUUID->"429c4e07-a9c9-44e8-8e2b-f5cbae71c53a"],

Cell[TextData[{
 "A ",
 StyleBox["product", "TI"],
 " input, by contrast, reduces to a pure state (purity ",
 Cell[BoxData["1"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "db159061-e14f-4d75-9f49-2396a4c07a9f"],
 ")."
}], "Text",ExpressionUUID->"a40b8fba-4968-4525-8298-00f4b9509393"],

Cell[BoxData[
 RowBox[{
  RowBox[{"QuantumPartialTrace", "[", 
   RowBox[{
    RowBox[{"QuantumTensorProduct", "[", 
     RowBox[{
      RowBox[{"QuantumState", "[", "\"\<0\>\"", "]"}], ",", " ", 
      RowBox[{"QuantumState", "[", "\"\<1\>\"", "]"}]}], "]"}], ",", " ", 
    RowBox[{"{", "2", "}"}]}], "]"}], "[", "\"\<Purity\>\"", "]"}]], "Input",
 CellLabel->
  "In[148]:= ",ExpressionUUID->"cbbd94da-f25a-43ca-8efb-a27a9ce3464e"],

Cell[TextData[{
 "Both give ",
 Cell[BoxData[
  RowBox[{
   SubscriptBox[
    StyleBox["\[Rho]", "TI"], 
    StyleBox["A", "TI"]], "=", 
   StyleBox["I", "TI"], "/", "2"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "96d0dd0d-1d8d-4888-b873-c450b1fbf92a"],
 " with purity ",
 Cell[BoxData[
  FractionBox["1", "2"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "5cc74eb9-618e-4439-8737-6aa6b7e2a6de"],
 ": tracing a maximally entangled pair down to one qubit yields the maximally \
mixed state, whereas a product state stays pure. The mixedness of the reduced \
state is exactly the entanglement discarded along with ",
 Cell[BoxData[
  StyleBox["B", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "331bd659-fcf5-484d-8fd7-d992224c005c"],
 "."
}], "Text",ExpressionUUID->"9ec24dc1-4285-4deb-9592-7d0d374ef3ce"],

Cell["Part 5. Projective measurement", "Section",ExpressionUUID->"2385d6a1-ef79-45f9-be6f-7126ef1e947f"],

Cell["\<\
5.1 [BSc] How do I perform a projective measurement and read outcomes, \
probabilities, and the mean?\
\>", "Subsection",ExpressionUUID->"a9b3c7f7-d9cb-4432-8a17-f8f85b19e43d"],

Cell[TextData[{
 "A projective measurement of an observable ",
 Cell[BoxData[
  StyleBox["A", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "e1af247c-75b2-4a7d-9a61-01ae50b249dc"],
 " returns one of ",
 Cell[BoxData[
  StyleBox["A", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "28654ebc-d651-445b-bb81-7489b26839bc"],
 "'s eigenvalues ",
 Cell[BoxData[
  StyleBox["a", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "6ae54d49-9fb6-4b63-890d-20cad24cf183"],
 " (the outcome) with probability ",
 Cell[BoxData[
  RowBox[{
   RowBox[{
    StyleBox["Tr",
     FontSlant->"Plain"], 
    StyleBox["[",
     SpanMaxSize->1], 
    RowBox[{
     SubscriptBox[
      StyleBox["P", "TI"], 
      StyleBox["a", "TI"]], 
     StyleBox["\[Rho]", "TI"]}], 
    StyleBox["]",
     SpanMaxSize->1]}], "=", 
   RowBox[{
    TemplateBox[{
      StyleBox["a", "TI"]},
     "Bra"], 
    StyleBox["\[Rho]", "TI"], 
    TemplateBox[{
      StyleBox["a", "TI"]},
     "Ket"]}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "5f761f10-b8bd-4928-a174-7535034f796d"],
 " (the Born rule, ",
 Cell[BoxData[
  SuperscriptBox[GridBox[{
     {
      TemplateBox[{
        StyleBox["a", "TI"], 
        StyleBox["\[Psi]", "TI"]},
       "BraKet"]}
    },
    GridBoxDividers->{"Columns" -> {True, True}, "Rows" -> {}},
    GridBoxSpacings->{"Columns" -> {{0.15}}}], "2"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "a7ca5cb4-ef07-4cf2-8aca-b54206fa6886"],
 " for a pure state), and the mean is ",
 Cell[BoxData[
  RowBox[{
   StyleBox["\[LeftAngleBracket]",
    SpanMaxSize->1], 
   StyleBox["A", "TI"], "\[VeryThinSpace]", 
   StyleBox["\[RightAngleBracket]",
    SpanMaxSize->1], "=", 
   StyleBox["Tr",
    FontSlant->"Plain"], 
   StyleBox["[",
    SpanMaxSize->1], 
   StyleBox[
    RowBox[{"A", "\[Rho]"}], "TI"], 
   StyleBox["]",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "183b5ef0-c70d-4233-b179-5d07f8e9b540"],
 ". Take ",
 Cell[BoxData[
  RowBox[{
   StyleBox["A", "TI"], "=", 
   StyleBox["Z", "TI"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "e366cde7-7b8b-4592-85a2-10207eefd239"],
 " on a general qubit ",
 Cell[BoxData[
  RowBox[{
   StyleBox["\[Rho]", "TI"], "=", 
   FractionBox["1", "2"], 
   StyleBox["(",
    SpanMaxSize->1], 
   RowBox[{
    StyleBox["I", "TI"], "+", 
    OverscriptBox[
     StyleBox["r", "TI"], "\[RightVector]"], "\[CenterDot]", 
    OverscriptBox[
     StyleBox["\[Sigma]", "TI"], "\[RightVector]"]}], 
   StyleBox[")",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "e4a82654-56e3-435f-b0dd-7b3c4b5b74e5"],
 ", ",
 Cell[BoxData[
  RowBox[{GridBox[{
     {
      OverscriptBox[
       StyleBox["r", "TI"], "\[RightVector]"]}
    },
    GridBoxDividers->{"Columns" -> {True, True}, "Rows" -> {}},
    GridBoxSpacings->{"Columns" -> {{0.15}}}], "\[LessEqual]", "1"}]], 
  "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "5a95e13a-303f-4f67-a62e-c1f309c39489"],
 " (",
 Cell[BoxData[
  RowBox[{
   OverscriptBox[
    StyleBox["\[Sigma]", "TI"], "\[RightVector]"], "="}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "dfa43ccf-7877-475e-9b79-253ece4c20c5"],
 " ",
 Cell[BoxData[
  RowBox[{"PauliMatrix", "[", 
   RowBox[{"{", 
    RowBox[{"1", ",", " ", "2", ",", " ", "3"}], "}"}], "]"}]], 
  "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "f0c765ab-5d10-4a39-a50c-70930e16d72e"],
 ")."
}], "Text",ExpressionUUID->"262579b3-9c19-4216-8847-0b586e694d5e"],

Cell[TextData[{
 StyleBox["WL",
  FontWeight->"Bold"],
 " : the possible outcomes are the eigenvalues of the observable."
}], "Text",ExpressionUUID->"82fece48-e247-47e0-a25a-26a12d2ea986"],

