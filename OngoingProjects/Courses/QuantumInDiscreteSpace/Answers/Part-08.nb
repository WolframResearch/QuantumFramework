Cell[TextData[{
 "Both return ",
 Cell[BoxData["{"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "d4a8cd55-5968-4d10-b743-dc9f99a8d721"],
 "True, True",
 Cell[BoxData["}"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "bf723dc9-4acb-450b-b9c4-fdfd89ebfad3"],
 ": the spin-1 operators close under the ",
 Cell[BoxData[
  RowBox[{"\|01d530", "\|01d532", 
   StyleBox["(",
    SpanMaxSize->1], "2", 
   StyleBox[")",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "0c546c3e-1297-4c3b-a42e-162da0482ed2"],
 " commutator and their Casimir is the scalar ",
 Cell[BoxData[
  RowBox[{
   StyleBox["j", "TI"], 
   StyleBox["(",
    SpanMaxSize->1], 
   RowBox[{
    StyleBox["j", "TI"], "+", "1"}], 
   StyleBox[")",
    SpanMaxSize->1], "=", "2"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "793aefcb-bb64-4647-aeb2-f3f16ebe1608"],
 ", the defining features of an angular momentum. The same construction gives \
any spin ",
 Cell[BoxData[
  StyleBox["j", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "f0fef4f0-a86c-4d2a-8f5a-3beaf0e9a67a"],
 " by changing the one number."
}], "Text",ExpressionUUID->"b1ff612a-5810-44b3-aed5-5e12ed394e5b"],

Cell["\<\
8.3 [BSc] How do I rotate a spin state and read the rotation off the \
expectation values?\
\>", "Subsection",ExpressionUUID->"fc7d24a7-ff27-4096-bd11-52c12b462a44"],

Cell[TextData[{
 "A spatial rotation of a spin-",
 Cell[BoxData[
  StyleBox["j", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "e859d199-7171-4afa-9f63-06d3c9cc53ad"],
 " acts by ",
 Cell[BoxData[
  RowBox[{
   SubscriptBox[
    StyleBox["R", "TI"], 
    OverscriptBox[
     StyleBox["n", "TI"], "^"]], 
   StyleBox["(",
    SpanMaxSize->1], 
   StyleBox["\[Beta]", "TI"], 
   StyleBox[")",
    SpanMaxSize->1], "=", 
   SuperscriptBox[
    StyleBox["e", "TI"], 
    RowBox[{"-", 
     StyleBox["i", "TI"], 
     StyleBox["\[Beta]", "TI"], " ", 
     OverscriptBox[
      StyleBox["n", "TI"], "^"], "\[CenterDot]", 
     OverscriptBox[
      StyleBox["J", "TI"], "\[RightVector]"]}]]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "dc69361b-61cc-4808-b438-b472721c3579"],
 ". Rotating the highest-weight state ",
 Cell[BoxData[
  TemplateBox[{
    RowBox[{
      StyleBox["j", "TI"], ",", 
      StyleBox["j", "TI"]}]},
   "Ket"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "923396e3-d86c-4d07-8ed3-468fb4057d24"],
 " (which points along ",
 Cell[BoxData[
  RowBox[{"+", 
   StyleBox["z", "TI"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "d255fed0-b768-4e29-9c2f-9ec7508ff1c0"],
 ", with ",
 Cell[BoxData[
  RowBox[{
   StyleBox["\[LeftAngleBracket]",
    SpanMaxSize->1], 
   SubscriptBox[
    StyleBox["J", "TI"], 
    StyleBox["z", "TI"]], 
   StyleBox["\[RightAngleBracket]",
    SpanMaxSize->1], "=", 
   StyleBox["j", "TI"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "c16069a8-cec4-459d-aea4-04ab9dcf5939"],
 ") about the ",
 Cell[BoxData[
  StyleBox["y", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "85238252-c1eb-4fdd-852e-21a58e71e1c0"],
 " axis by ",
 Cell[BoxData[
  StyleBox["\[Beta]", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "ea3836b7-d0c3-4f36-978b-bf1269697b37"],
 " tilts the spin into the ",
 Cell[BoxData[
  StyleBox["x", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "d991d45b-b308-4dc2-801a-b0d88512f208"],
 "-",
 Cell[BoxData[
  StyleBox["z", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "927571f8-1274-4c2b-8cd0-2e293ac86109"],
 " plane: the expectation vector becomes ",
 Cell[BoxData[
  RowBox[{
   StyleBox["\[LeftAngleBracket]",
    SpanMaxSize->1], 
   OverscriptBox[
    StyleBox["J", "TI"], "\[RightVector]"], 
   StyleBox["\[RightAngleBracket]",
    SpanMaxSize->1], "=", 
   StyleBox["j", "TI"], " ", 
   StyleBox["(",
    SpanMaxSize->1], 
   RowBox[{
    RowBox[{
     StyleBox["sin",
      FontSlant->"Plain"], "\[ThinSpace]", 
     StyleBox["\[Beta]", "TI"]}], ",", "0", ",", 
    RowBox[{
     StyleBox["cos",
      FontSlant->"Plain"], "\[ThinSpace]", 
     StyleBox["\[Beta]", "TI"]}]}], 
   StyleBox[")",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "2c0448f8-0deb-4ca7-b4a2-cf7dca2fb2cb"],
 ". Show this for spin ",
 Cell[BoxData[
  RowBox[{
   StyleBox["j", "TI"], "=", "1"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "88fa73ae-aa61-4381-b81c-636b2d580bc0"],
 "."
}], "Text",ExpressionUUID->"766d2c3b-f413-4fb8-84da-c8cd5b91d728"],

Cell[TextData[{
 StyleBox["WL",
  FontWeight->"Bold"],
 " : rotate ",
