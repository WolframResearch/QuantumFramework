               RowBox[{
                RowBox[{
                 RowBox[{"-", "I"}], " ", "\[Beta]", " ", "jy"}], ",", " ", 
                RowBox[{"UnitVector", "[", 
                 RowBox[{"n", ",", " ", "1"}], "]"}]}], "]"}], "]"}]}], "}"}],
            ",", " ", 
           RowBox[{"Simplify", "[", 
            RowBox[{
             RowBox[{"ComplexExpand", "[", 
              RowBox[{"Table", "[", 
               RowBox[{
                RowBox[{
                 RowBox[{"(", 
                  RowBox[{
                   RowBox[{"\[Psi]", "[", "\"\<Dagger\>\"", "]"}], " ", "@", 
                   " ", 
                   RowBox[{
                    RowBox[{"QuantumOperator", "[", "op", "]"}], " ", "@", 
                    " ", "\[Psi]"}]}], ")"}], "[", "\"\<Scalar\>\"", "]"}], ",",
                 " ", 
                RowBox[{"{", 
                 RowBox[{"op", ",", " ", 
                  RowBox[{"{", 
                   RowBox[{"jx", ",", " ", "jy", ",", " ", "jz"}], "}"}]}], 
                 "}"}]}], "]"}], "]"}], ",", " ", 
             RowBox[{"\[Beta]", " ", "\[Element]", " ", "Reals"}]}], "]"}]}], 
          "]"}]}], "]"}]}], "]"}]}], "]"}]}], "]"}]], "Input",
 CellLabel->"In[7]:= ",ExpressionUUID->"2d371fa3-fdc6-42f6-9787-193287a30b8c"],

Cell[TextData[{
 "Both return ",
 Cell[BoxData[
  RowBox[{
   StyleBox["\[LeftAngleBracket]",
    SpanMaxSize->1], 
   OverscriptBox[
    StyleBox["J", "TI"], "\[RightVector]"], 
   StyleBox["\[RightAngleBracket]",
    SpanMaxSize->1], "=", 
   StyleBox["(",
    SpanMaxSize->1], 
   RowBox[{
    RowBox[{
     StyleBox["sin",
      FontSlant->"Plain"], "\[ThinSpace]", 
     StyleBox["\[Beta]", "TI"]}], ",", "0", ",", 
    RowBox[{
     StyleBox["cos",
      FontSlant->"Plain"], "\[ThinSpace]", 
     StyleBox["\[Beta]", "TI"]}]}], 
   StyleBox[")",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "96c42887-f5e9-435e-86b7-076594d0a375"],
 ": the quantum expectation vector rotates exactly as a classical arrow \
would, so a spin measurement tracks the geometric rotation, the content of \
the vector (adjoint) representation of ",
 Cell[BoxData[
  RowBox[{
   StyleBox["S", "TI"], 
   StyleBox["U", "TI"], 
   StyleBox["(",
    SpanMaxSize->1], "2", 
   StyleBox[")",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "f2bff9bf-e975-4574-9c7d-41372f9097dc"],
 " on angular momentum."
}], "Text",ExpressionUUID->"a18e349e-46ea-47c7-b94a-2b9a60694293"],

Cell[TextData[{
 "8.4 [MSc] How do I construct the Wigner ",
 Cell[BoxData[
  StyleBox["D", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "78370cd5-d445-4d5e-ab84-7b80aa251545"],
 "-matrix element ",
 Cell[BoxData[
  RowBox[{
   RowBox[{
    SubsuperscriptBox[
     StyleBox["D", "TI"], 
     RowBox[{
      SuperscriptBox[
       StyleBox["m", "TI"], "\[Prime]"], 
      StyleBox["m", "TI"]}], 
     StyleBox["j", "TI"]], 
    RowBox[{
     StyleBox["(",
      SpanMaxSize->1], 
     RowBox[{
      StyleBox["\[Alpha]", "TI"], ",", 
      StyleBox["\[Beta]", "TI"], ",", 
      StyleBox["\[Gamma]", "TI"]}], 
     StyleBox[")",
      SpanMaxSize->1]}]}], "=", 
   RowBox[{
    TemplateBox[{
      RowBox[{
        StyleBox["j", "TI"], 
        SuperscriptBox[
         StyleBox["m", "TI"], "\[Prime]"]}]},
     "Bra"], 
    SuperscriptBox[
     StyleBox["e", "TI"], 
     RowBox[{"-", 
      StyleBox["i", "TI"], 
      StyleBox["\[Alpha]", "TI"], 
      SubscriptBox[
       StyleBox["J", "TI"], 
       StyleBox["z", "TI"]]}]], 
    SuperscriptBox[
     StyleBox["e", "TI"], 
     RowBox[{"-", 
      StyleBox["i", "TI"], 
      StyleBox["\[Beta]", "TI"], 
      SubscriptBox[
       StyleBox["J", "TI"], 
       StyleBox["y", "TI"]]}]], 
    SuperscriptBox[
     StyleBox["e", "TI"], 
     RowBox[{"-", 
      StyleBox["i", "TI"], 
      StyleBox["\[Gamma]", "TI"], 
      SubscriptBox[
       StyleBox["J", "TI"], 
       StyleBox["z", "TI"]]}]], 
    TemplateBox[{
      RowBox[{
        StyleBox["j", "TI"], 
        StyleBox["m", "TI"]}]},
     "Ket"]}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "35ceaf67-504b-44a5-85ab-3e0ebd7828cd"],
 " for a spin-",
 Cell[BoxData[
  StyleBox["j", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "89b9df19-5146-4eb7-af2c-dc625da891c8"],
 " rotation?"
}], "Subsection",ExpressionUUID->"24a307e8-1656-42c4-86f3-ce742aea2a5c"],

Cell[TextData[{
 "The Wigner ",
 Cell[BoxData[
  StyleBox["D", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "0bf94d31-9f2a-4fff-b37c-99ba2fd42096"],
 "-matrix is the spin-",
 Cell[BoxData[
  StyleBox["j", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "8ddd97ef-8e3e-4669-9ecf-244b9c263432"],
 " representation of a rotation parametrized by Euler angles, ",
 Cell[BoxData[
  RowBox[{
   RowBox[{
    SubsuperscriptBox[
     StyleBox["D", "TI"], 
     RowBox[{
      SuperscriptBox[
       StyleBox["m", "TI"], "\[Prime]"], 
      StyleBox["m", "TI"]}], 
     StyleBox["j", "TI"]], 
    RowBox[{
     StyleBox["(",
      SpanMaxSize->1], 
     RowBox[{
      StyleBox["\[Alpha]", "TI"], ",", 
      StyleBox["\[Beta]", "TI"], ",", 
      StyleBox["\[Gamma]", "TI"]}], 
     StyleBox[")",
      SpanMaxSize->1]}]}], "=", 
   RowBox[{
    TemplateBox[{
      RowBox[{
        StyleBox["j", "TI"], 
        SuperscriptBox[
         StyleBox["m", "TI"], "\[Prime]"]}]},
     "Bra"], 
    SuperscriptBox[
     StyleBox["e", "TI"], 
     RowBox[{"-", 
      StyleBox["i", "TI"], 
      StyleBox["\[Alpha]", "TI"], 
      SubscriptBox[
       StyleBox["J", "TI"], 
       StyleBox["z", "TI"]]}]], 
    SuperscriptBox[
     StyleBox["e", "TI"], 
     RowBox[{"-", 
      StyleBox["i", "TI"], 
      StyleBox["\[Beta]", "TI"], 
      SubscriptBox[
       StyleBox["J", "TI"], 
       StyleBox["y", "TI"]]}]], 
    SuperscriptBox[
     StyleBox["e", "TI"], 
     RowBox[{"-", 
      StyleBox["i", "TI"], 
      StyleBox["\[Gamma]", "TI"], 
      SubscriptBox[
       StyleBox["J", "TI"], 
       StyleBox["z", "TI"]]}]], 
    TemplateBox[{
      RowBox[{
        StyleBox["j", "TI"], 
        StyleBox["m", "TI"]}]},
     "Ket"]}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "c2627d1a-3b90-471d-8330-bec1e7456827"],
 ". Build the full rotation for spin ",
 Cell[BoxData[
  RowBox[{
   StyleBox["j", "TI"], "=", "1"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "74dcb726-7b39-417e-b621-beac19ed73ef"],
 " from the ladder operators and read off its matrix; compare it to the \
built-in ",
 Cell[BoxData["WignerD"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "962461e5-7162-4d39-91f1-b91ae47a47b4"],
 "."
}], "Text",ExpressionUUID->"927465a3-ef21-4744-a8e2-f3727cedc199"],

Cell[TextData[{
 StyleBox["WL",
  FontWeight->"Bold"],
 " : assemble ",
 Cell[BoxData[
  RowBox[{
   SuperscriptBox[
    StyleBox["e", "TI"], 
    RowBox[{"-", 
     StyleBox["i", "TI"], 
     StyleBox["\[Alpha]", "TI"], 
     SubscriptBox[
      StyleBox["J", "TI"], 
      StyleBox["z", "TI"]]}]], 
   SuperscriptBox[
    StyleBox["e", "TI"], 
    RowBox[{"-", 
     StyleBox["i", "TI"], 
     StyleBox["\[Beta]", "TI"], 
     SubscriptBox[
      StyleBox["J", "TI"], 
      StyleBox["y", "TI"]]}]], 
   SuperscriptBox[
    StyleBox["e", "TI"], 
    RowBox[{"-", 
     StyleBox["i", "TI"], 
     StyleBox["\[Gamma]", "TI"], 
     SubscriptBox[
      StyleBox["J", "TI"], 
      StyleBox["z", "TI"]]}]]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "dd9990ec-5e54-4a12-b9f4-40d3f12ff47f"],
 " from the spin-1 operators, and check its entries against the built-in ",
 Cell[BoxData["WignerD"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "7cc35fa3-ca9c-4d1c-b014-9055c30726aa"],
 " (index order ",
 Cell[BoxData[
  RowBox[{
   RowBox[{"{", 
    StyleBox["j", "TI"]}], ",", 
   SuperscriptBox[
    StyleBox["m", "TI"], "\[Prime]"], ",", 
   RowBox[{
    StyleBox["m", "TI"], "}"}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "c3fbdaf5-0e17-48d6-b30b-64e29188a492"],
 "). The built-in uses the opposite (active, ",
 Cell[BoxData[
  SuperscriptBox[
   StyleBox["e", "TI"], 
   RowBox[{"+", 
    StyleBox["i", "TI"], 
    StyleBox["J", "TI"]}]]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "e4a6e2c3-497a-4302-9fd3-cbee58961f60"],
 ") sign convention, so its Euler angles are negated relative to the passive ",
 Cell[BoxData[
  SuperscriptBox[
   StyleBox["e", "TI"], 
   RowBox[{"-", 
    StyleBox["i", "TI"], 
    StyleBox["J", "TI"]}]]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "7a46d118-9159-47d4-9e07-f0300c6167b2"],
 " formula stated here."
}], "Text",ExpressionUUID->"938b7750-8a58-4c71-a6d3-0108585d1d43"],

Cell[BoxData[
 RowBox[{"With", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"j", " ", "=", " ", "1"}], "}"}], ",", " ", 
   RowBox[{"With", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"m", " ", "=", " ", 
        RowBox[{"Range", "[", 
         RowBox[{"j", ",", " ", 
          RowBox[{"-", "j"}], ",", " ", 
          RowBox[{"-", "1"}]}], "]"}]}], ",", " ", 
       RowBox[{"n", " ", "=", " ", 
        RowBox[{
         RowBox[{"2", " ", "j"}], " ", "+", " ", "1"}]}]}], "}"}], ",", " ", 
     RowBox[{"With", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{"jz", " ", "=", " ", 
          RowBox[{"DiagonalMatrix", "[", 
           RowBox[{"Range", "[", 
            RowBox[{"j", ",", " ", 
             RowBox[{"-", "j"}], ",", " ", 
             RowBox[{"-", "1"}]}], "]"}], "]"}]}], ",", " ", 
         RowBox[{"jp", " ", "=", " ", 
          RowBox[{"SparseArray", "[", 
           RowBox[{
            RowBox[{
             RowBox[{
              RowBox[{"{", 
               RowBox[{"r_", ",", " ", "c_"}], "}"}], " ", "/;", " ", 
              RowBox[{"r", " ", "==", " ", 
               RowBox[{"c", " ", "-", " ", "1"}]}]}], " ", ":>", " ", 
             RowBox[{"Sqrt", "[", 
              RowBox[{
               RowBox[{"j", " ", 
                RowBox[{"(", 
                 RowBox[{"j", " ", "+", " ", "1"}], ")"}]}], " ", "-", " ", 
               RowBox[{
                RowBox[{"m", "[", 
                 RowBox[{"[", "c", "]"}], "]"}], " ", 
                RowBox[{"(", 
                 RowBox[{
                  RowBox[{"m", "[", 
                   RowBox[{"[", "c", "]"}], "]"}], " ", "+", " ", "1"}], 
                 ")"}]}]}], "]"}]}], ",", " ", 
            RowBox[{"{", 
             RowBox[{"n", ",", " ", "n"}], "}"}]}], "]"}]}]}], "}"}], ",", 
       " ", 
       RowBox[{"With", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"jy", " ", "=", " ", 
           RowBox[{
            RowBox[{"(", 
             RowBox[{"jp", " ", "-", " ", 
              RowBox[{"Transpose", "[", "jp", "]"}]}], ")"}], "/", 
            RowBox[{"(", 
             RowBox[{"2", " ", "I"}], ")"}]}]}], "}"}], ",", " ", 
         RowBox[{"With", "[", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{"d", " ", "=", " ", 
             RowBox[{
              RowBox[{"MatrixExp", "[", 
               RowBox[{
                RowBox[{"-", "I"}], " ", "\[Alpha]", " ", "jz"}], "]"}], " ", 
              ".", " ", 
              RowBox[{"MatrixExp", "[", 
               RowBox[{
                RowBox[{"-", "I"}], " ", "\[Beta]", " ", "jy"}], "]"}], " ", ".",
               " ", 
              RowBox[{"MatrixExp", "[", 
               RowBox[{
                RowBox[{"-", "I"}], " ", "\[Gamma]", " ", "jz"}], "]"}]}]}], 
            "}"}], ",", " ", 
           RowBox[{"Simplify", "[", 
            RowBox[{
             RowBox[{"d", " ", "==", " ", 
              RowBox[{"Table", "[", 
               RowBox[{
                RowBox[{"WignerD", "[", 
                 RowBox[{
                  RowBox[{"{", 
                   RowBox[{"j", ",", " ", "mp", ",", " ", "mm"}], "}"}], ",", 
                  " ", 
                  RowBox[{"-", "\[Alpha]"}], ",", " ", 
                  RowBox[{"-", "\[Beta]"}], ",", " ", 
                  RowBox[{"-", "\[Gamma]"}]}], "]"}], ",", " ", 
                RowBox[{"{", 
                 RowBox[{"mp", ",", " ", "j", ",", " ", 
                  RowBox[{"-", "j"}], ",", " ", 
                  RowBox[{"-", "1"}]}], "}"}], ",", " ", 
                RowBox[{"{", 
                 RowBox[{"mm", ",", " ", "j", ",", " ", 
                  RowBox[{"-", "j"}], ",", " ", 
                  RowBox[{"-", "1"}]}], "}"}]}], "]"}]}], ",", " ", 
             RowBox[{
              RowBox[{"{", 
               RowBox[{
               "\[Alpha]", ",", " ", "\[Beta]", ",", " ", "\[Gamma]"}], "}"}],
               " ", "\[Element]", " ", "Reals"}]}], "]"}]}], "]"}]}], "]"}]}],
       "]"}]}], "]"}]}], "]"}]], "Input",
 CellLabel->"In[8]:= ",ExpressionUUID->"03fdc9bd-1f41-485a-a623-ce0349119978"],

Cell[TextData[{
 StyleBox["QF",
  FontWeight->"Bold"],
 " : the same rotation as a product of ",
 Cell[BoxData["QuantumOperator"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "620b6b7e-505e-459a-92b4-7ad50691e021"],
 " exponentials; its matrix is the ",
 Cell[BoxData[
  StyleBox["D", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "7e118cd0-1c78-4a66-9932-61e0b1adfa19"],
 "-matrix."
}], "Text",ExpressionUUID->"21417784-ce04-420a-b138-eb06f939a121"],

Cell[BoxData[
 RowBox[{"With", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"j", " ", "=", " ", "1"}], "}"}], ",", " ", 
   RowBox[{"With", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"m", " ", "=", " ", 
        RowBox[{"Range", "[", 
         RowBox[{"j", ",", " ", 
          RowBox[{"-", "j"}], ",", " ", 
          RowBox[{"-", "1"}]}], "]"}]}], ",", " ", 
       RowBox[{"n", " ", "=", " ", 
        RowBox[{
         RowBox[{"2", " ", "j"}], " ", "+", " ", "1"}]}]}], "}"}], ",", " ", 
     RowBox[{"With", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{"jz", " ", "=", " ", 
          RowBox[{"DiagonalMatrix", "[", 
           RowBox[{"Range", "[", 
            RowBox[{"j", ",", " ", 
             RowBox[{"-", "j"}], ",", " ", 
             RowBox[{"-", "1"}]}], "]"}], "]"}]}], ",", " ", 
         RowBox[{"jp", " ", "=", " ", 
          RowBox[{"SparseArray", "[", 
           RowBox[{
            RowBox[{
             RowBox[{
              RowBox[{"{", 
               RowBox[{"r_", ",", " ", "c_"}], "}"}], " ", "/;", " ", 
              RowBox[{"r", " ", "==", " ", 
               RowBox[{"c", " ", "-", " ", "1"}]}]}], " ", ":>", " ", 
             RowBox[{"Sqrt", "[", 
              RowBox[{
               RowBox[{"j", " ", 
                RowBox[{"(", 
                 RowBox[{"j", " ", "+", " ", "1"}], ")"}]}], " ", "-", " ", 
               RowBox[{
                RowBox[{"m", "[", 
                 RowBox[{"[", "c", "]"}], "]"}], " ", 
                RowBox[{"(", 
                 RowBox[{
                  RowBox[{"m", "[", 
                   RowBox[{"[", "c", "]"}], "]"}], " ", "+", " ", "1"}], 
                 ")"}]}]}], "]"}]}], ",", " ", 
            RowBox[{"{", 
             RowBox[{"n", ",", " ", "n"}], "}"}]}], "]"}]}]}], "}"}], ",", 
       " ", 
       RowBox[{"With", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"jy", " ", "=", " ", 
           RowBox[{
            RowBox[{"(", 
             RowBox[{"jp", " ", "-", " ", 
              RowBox[{"Transpose", "[", "jp", "]"}]}], ")"}], "/", 
            RowBox[{"(", 
             RowBox[{"2", " ", "I"}], ")"}]}]}], "}"}], ",", " ", 
         RowBox[{"With", "[", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{"d", " ", "=", " ", 
             RowBox[{
              RowBox[{"QuantumOperator", "[", 
               RowBox[{"MatrixExp", "[", 
                RowBox[{
                 RowBox[{"-", "I"}], " ", "\[Alpha]", " ", "jz"}], "]"}], 
               "]"}], " ", "@", " ", 
              RowBox[{
               RowBox[{"QuantumOperator", "[", 
                RowBox[{"MatrixExp", "[", 
                 RowBox[{
                  RowBox[{"-", "I"}], " ", "\[Beta]", " ", "jy"}], "]"}], 
                "]"}], " ", "@", " ", 
               RowBox[{"QuantumOperator", "[", 
                RowBox[{"MatrixExp", "[", 
                 RowBox[{
                  RowBox[{"-", "I"}], " ", "\[Gamma]", " ", "jz"}], "]"}], 
                "]"}]}]}]}], "}"}], ",", " ", 
           RowBox[{"Simplify", "[", 
            RowBox[{
             RowBox[{
              RowBox[{"Normal", "[", 
               RowBox[{"d", "[", "\"\<Matrix\>\"", "]"}], "]"}], " ", "==", 
              " ", 
              RowBox[{"Table", "[", 
               RowBox[{
                RowBox[{"WignerD", "[", 
                 RowBox[{
                  RowBox[{"{", 
                   RowBox[{"j", ",", " ", "mp", ",", " ", "mm"}], "}"}], ",", 
                  " ", 
                  RowBox[{"-", "\[Alpha]"}], ",", " ", 
                  RowBox[{"-", "\[Beta]"}], ",", " ", 
                  RowBox[{"-", "\[Gamma]"}]}], "]"}], ",", " ", 
                RowBox[{"{", 
                 RowBox[{"mp", ",", " ", "j", ",", " ", 
                  RowBox[{"-", "j"}], ",", " ", 
                  RowBox[{"-", "1"}]}], "}"}], ",", " ", 
                RowBox[{"{", 
                 RowBox[{"mm", ",", " ", "j", ",", " ", 
                  RowBox[{"-", "j"}], ",", " ", 
                  RowBox[{"-", "1"}]}], "}"}]}], "]"}]}], ",", " ", 
             RowBox[{
              RowBox[{"{", 
               RowBox[{
               "\[Alpha]", ",", " ", "\[Beta]", ",", " ", "\[Gamma]"}], "}"}],
               " ", "\[Element]", " ", "Reals"}]}], "]"}]}], "]"}]}], "]"}]}],
       "]"}]}], "]"}]}], "]"}]], "Input",
 CellLabel->"In[9]:= ",ExpressionUUID->"d579104d-e901-4e17-afd3-3d61cff926dd"],

Cell[TextData[{
 "Both confirm the constructed rotation equals the built-in ",
 Cell[BoxData["WignerD"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "93bc8eb0-5302-4646-b413-7d3369bd66fb"],
 " table entry by entry: the ",
 Cell[BoxData[
  StyleBox["D", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "2ad9dd27-bdfb-4a46-98f0-066e2d1d9db0"],
 "-matrix is nothing more than the explicit representation of the abstract \
rotation on the ",
 Cell[BoxData[
  RowBox[{
   StyleBox["(",
    SpanMaxSize->1], 
   RowBox[{"2", 
    StyleBox["j", "TI"], "+", "1"}], 
   StyleBox[")",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "2e116dd7-7fd0-4fba-8739-911269651d19"],
 "-dimensional spin space, and building it from the ladder operators \
reproduces the tabulated special functions exactly."
}], "Text",ExpressionUUID->"4d128422-7f4e-49e8-a860-20306082c278"],

Cell["\<\
8.5 [MSc] How do I add two angular momenta and compute the Clebsch-Gordan \
coefficients?\
\>", "Subsection",ExpressionUUID->"0eb3692e-4a78-4c35-a182-2616f5862514"],

Cell[TextData[{
 "Coupling two spins combines their spaces, ",
 Cell[BoxData[
  RowBox[{
   FractionBox["1", "2"], "\[CircleTimes]", 
   FractionBox["1", "2"], "=", "0", "\[CirclePlus]", "1"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "632773c8-73ab-4eb5-afce-74a49e603e6f"],
 ": the product basis ",
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     SubscriptBox[
      StyleBox["m", "TI"], "1"]},
    "Ket"], 
   TemplateBox[{
     SubscriptBox[
      StyleBox["m", "TI"], "2"]},
    "Ket"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "963ab5b9-b102-41ed-9f35-21e53dd19f8d"],
 " recombines into total-spin eigenstates ",
 Cell[BoxData[
  TemplateBox[{
    RowBox[{
      StyleBox["J", "TI"], ",", 
      StyleBox["M", "TI"]}]},
   "Ket"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "e4e64916-632e-44a5-a1c7-0a8497fc7826"],
 ", and the overlaps ",
 Cell[BoxData[
  TemplateBox[{
    RowBox[{
      SubscriptBox[
       StyleBox["m", "TI"], "1"], 
      SubscriptBox[
       StyleBox["m", "TI"], "2"]}], 
    RowBox[{
      StyleBox["J", "TI"], ",", 
      StyleBox["M", "TI"]}]},
   "BraKet"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "31f7fa10-640a-454b-af9e-3f8ada9fa3a7"],
 " are the Clebsch-Gordan coefficients. Build the coupled basis for two \
spin-1/2 and read the coefficients."
}], "Text",ExpressionUUID->"caf1f37b-d113-4b3c-af16-c72c9af9572d"],

Cell[TextData[{
 StyleBox["WL",
  FontWeight->"Bold"],
 " : the coupled states are assembled from the product basis with the \
built-in ",
 Cell[BoxData["ClebschGordan"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "b87d9861-8820-40af-bd15-d1af4d68c105"],
 " coefficients; here is ",
 Cell[BoxData[
  TemplateBox[{"1,0"},
   "Ket"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "36497308-5900-4fec-a4fa-c434270d113f"],
 ", the symmetric ",
 Cell[BoxData[
  RowBox[{
   StyleBox["M", "TI"], "=", "0"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "6778ea6e-38c1-47e4-b498-bb779f4f4a82"],
 " triplet state."
}], "Text",ExpressionUUID->"fe397b81-dcc1-405d-b604-95b3a3a58c0d"],

Cell[BoxData[
 RowBox[{"With", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"basis", " ", "=", " ", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{"1", "/", "2"}], ",", " ", 
         RowBox[{"1", "/", "2"}]}], "}"}], ",", " ", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"1", "/", "2"}], ",", " ", 
         RowBox[{
          RowBox[{"-", "1"}], "/", "2"}]}], "}"}], ",", " ", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{
          RowBox[{"-", "1"}], "/", "2"}], ",", " ", 
         RowBox[{"1", "/", "2"}]}], "}"}], ",", " ", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{
          RowBox[{"-", "1"}], "/", "2"}], ",", " ", 
         RowBox[{
          RowBox[{"-", "1"}], "/", "2"}]}], "}"}]}], "}"}]}], "}"}], ",", " ", 
   RowBox[{"Sum", "[", 
    RowBox[{
     RowBox[{"If", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"Total", "[", 
         RowBox[{"basis", "[", 
          RowBox[{"[", "k", "]"}], "]"}], "]"}], " ", "==", " ", "0"}], ",", 
       " ", 
       RowBox[{
        RowBox[{"ClebschGordan", "[", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{
            RowBox[{"1", "/", "2"}], ",", " ", 
            RowBox[{"basis", "[", 
             RowBox[{"[", 
              RowBox[{"k", ",", " ", "1"}], "]"}], "]"}]}], "}"}], ",", " ", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"1", "/", "2"}], ",", " ", 
            RowBox[{"basis", "[", 
             RowBox[{"[", 
              RowBox[{"k", ",", " ", "2"}], "]"}], "]"}]}], "}"}], ",", " ", 
          RowBox[{"{", 
           RowBox[{"1", ",", " ", "0"}], "}"}]}], "]"}], " ", 
        RowBox[{"UnitVector", "[", 
         RowBox[{"4", ",", " ", "k"}], "]"}]}], ",", " ", "0"}], "]"}], ",", 
     " ", 
     RowBox[{"{", 
      RowBox[{"k", ",", " ", "4"}], "}"}]}], "]"}]}], "]"}]], "Input",
 CellLabel->
  "In[10]:= ",ExpressionUUID->"6c794f6b-f5ea-4c8f-9c56-c4261d2b98cb"],

Cell[TextData[{
 StyleBox["QF",
  FontWeight->"Bold"],
 " : the coupled basis is the eigenbasis of the total spin ",
 Cell[BoxData[
  RowBox[{
   OverscriptBox[
    StyleBox["S", "TI"], "\[RightVector]"], "=", 
   SubscriptBox[
    OverscriptBox[
     StyleBox["S", "TI"], "\[RightVector]"], "1"], "+", 
   SubscriptBox[
    OverscriptBox[
     StyleBox["S", "TI"], "\[RightVector]"], "2"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "f4a26be7-3067-4216-b107-f057a0f9c77c"],
 "; diagonalize ",
 Cell[BoxData[
  SuperscriptBox[
   StyleBox["S", "TI"], "2"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "4cc9b1e2-7673-4b8d-bc0a-cfd6aa61c12a"],
 " and its overlaps with the product basis ",
 StyleBox["are", "TI"],
 " the Clebsch-Gordan coefficients. The ",
 Cell[BoxData[
  TemplateBox[{"1,0"},
   "Ket"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "f9d8dfbd-fd5e-4567-8c37-4baedbf707f2"],
 " state is the ",
 Cell[BoxData[
  RowBox[{
   StyleBox["M", "TI"], "=", "0"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "2be0be86-7b26-4108-8a92-dbc16c587cd4"],
 " (",
 Cell[BoxData[
  RowBox[{
   SubsuperscriptBox[
    StyleBox["S", "TI"], 
    StyleBox["z", "TI"], 
    StyleBox["tot",
     FontSlant->"Plain"]], "=", "0"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "aa48f8a9-3444-479d-89e1-9d90746eb43e"],
 ") eigenvector inside the ",
 Cell[BoxData[
  RowBox[{
   SuperscriptBox[
    StyleBox["S", "TI"], "2"], "=", "2"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "e7298e88-1666-4d25-9d4f-e9275964cbd2"],
 " (triplet) block."
}], "Text",ExpressionUUID->"56e1c676-2349-4add-8b7d-84e6f434d995"],

Cell[BoxData[
 RowBox[{"With", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"stot", " ", "=", " ", 
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"KroneckerProduct", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"PauliMatrix", "[", "k", "]"}], "/", "2"}], ",", " ", 
          RowBox[{"IdentityMatrix", "[", "2", "]"}]}], "]"}], " ", "+", " ", 
        RowBox[{"KroneckerProduct", "[", 
         RowBox[{
          RowBox[{"IdentityMatrix", "[", "2", "]"}], ",", " ", 
          RowBox[{
           RowBox[{"PauliMatrix", "[", "k", "]"}], "/", "2"}]}], "]"}]}], ",",
        " ", 
       RowBox[{"{", 
        RowBox[{"k", ",", " ", "3"}], "}"}]}], "]"}]}], "}"}], ",", " ", 
   RowBox[{"With", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"s2", " ", "=", " ", 
        RowBox[{"Sum", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"stot", "[", 
            RowBox[{"[", "k", "]"}], "]"}], " ", ".", " ", 
           RowBox[{"stot", "[", 
            RowBox[{"[", "k", "]"}], "]"}]}], ",", " ", 
          RowBox[{"{", 
           RowBox[{"k", ",", " ", "3"}], "}"}]}], "]"}]}], ",", " ", 
       RowBox[{"sz", " ", "=", " ", 
        RowBox[{"stot", "[", 
         RowBox[{"[", "3", "]"}], "]"}]}]}], "}"}], ",", " ", 
     RowBox[{"Select", "[", 
      RowBox[{
       RowBox[{"Normalize", " ", "/@", " ", 
        RowBox[{"(", 
         RowBox[{"Normal", " ", "/@", " ", 
          RowBox[{
           RowBox[{"QuantumOperator", "[", "s2", "]"}], 
           "[", "\"\<Eigenvectors\>\"", "]"}]}], ")"}]}], ",", " ", 
       RowBox[{
        RowBox[{"Simplify", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"#", " ", ".", " ", "s2", " ", ".", " ", "#"}], " ", "==", 
           " ", "2"}], " ", "&&", " ", 
          RowBox[{
           RowBox[{"#", " ", ".", " ", "sz", " ", ".", " ", "#"}], " ", "==", 
           " ", "0"}]}], "]"}], " ", "&"}]}], "]"}]}], "]"}]}], 
  "]"}]], "Input",
 CellLabel->
  "In[11]:= ",ExpressionUUID->"a9febdaa-b108-46c5-bc0d-5837b80dc3dc"],

Cell[TextData[{
 "Both single out ",
 Cell[BoxData[
  RowBox[{
   TemplateBox[{"1,0"},
    "Ket"], "=", 
   RowBox[{
    FractionBox["1", 
     SqrtBox["2"]], 
    RowBox[{"(", 
     RowBox[{
      TemplateBox[{
        RowBox[{"\[UpArrow]", "\[DownArrow]"}]},
       "Ket"], "+", 
      TemplateBox[{
        RowBox[{"\[DownArrow]", "\[UpArrow]"}]},
       "Ket"]}], ")"}]}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "10d95018-ac6d-4308-ad1f-6bad014af7d1"],
 ", its Clebsch-Gordan coefficients ",
 Cell[BoxData[
  RowBox[{
   RowBox[{"{", "0"}], ",", 
   FractionBox["1", 
    SqrtBox["2"]], ",", 
   FractionBox["1", 
    SqrtBox["2"]], ",", 
   RowBox[{"0", "}"}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "f08b7954-49a0-4009-8310-31bd5a14a862"],
 ": adding two spins is a change of basis from the product basis to the \
total-spin basis, and the change-of-basis matrix is the table of \
Clebsch-Gordan coefficients, recoverable either from the built-in or by \
diagonalizing ",
 Cell[BoxData[
  SuperscriptBox[
   StyleBox["S", "TI"], "2"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "8ba47267-5884-474e-99a4-a213d31be7b0"],
 "."
}], "Text",ExpressionUUID->"422d81b0-7ebe-4028-941f-7733e994d0a6"],

Cell["\<\
8.6 [MSc] How do I build the singlet and triplet states and identify them by \
total spin?\
\>", "Subsection",ExpressionUUID->"d0ecc8a6-611e-4b42-8db6-714d68f89dba"],

Cell[TextData[{
 "Two spin-1/2 combine into one singlet (",
 Cell[BoxData[
  RowBox[{
   StyleBox["S", "TI"], "=", "0"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "12e18d36-3405-47e4-8fb1-5146c0db15dc"],
 ", antisymmetric) and three triplet states (",
 Cell[BoxData[
  RowBox[{
   StyleBox["S", "TI"], "=", "1"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "0e5a5776-5a8a-4b7b-be13-f9554c944e01"],
 ", symmetric). They are told apart by the total-spin Casimir ",
 Cell[BoxData[
  RowBox[{
   SuperscriptBox[
    StyleBox["S", "TI"], "2"], "=", 
   SuperscriptBox[
    RowBox[{
     StyleBox["(",
      SpanMaxSize->1], 
     RowBox[{
      SubscriptBox[
       OverscriptBox[
        StyleBox["S", "TI"], "\[RightVector]"], "1"], "+", 
      SubscriptBox[
       OverscriptBox[
        StyleBox["S", "TI"], "\[RightVector]"], "2"]}], 
     StyleBox[")",
      SpanMaxSize->1]}], "2"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "70362c35-6d81-45b3-a7dd-9b6d17225c73"],
 ", whose eigenvalue is ",
 Cell[BoxData[
  RowBox[{
   StyleBox["S", "TI"], 
   StyleBox["(",
    SpanMaxSize->1], 
   RowBox[{
    StyleBox["S", "TI"], "+", "1"}], 
   StyleBox[")",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "164bcf34-f97e-40ef-a74b-e5fb1e466ab9"],
 ": ",
 Cell[BoxData["0"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "d9ba151b-de26-4598-b8f3-f6c022a6497d"],
 " for the singlet, ",
 Cell[BoxData["2"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "105b1f7f-3341-41ec-8771-44be06a9b6cb"],
 " for the triplet. Build the four states and read their ",
 Cell[BoxData[
  SuperscriptBox[
   StyleBox["S", "TI"], "2"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "41c143ba-487d-4ed8-ad0e-080b00096ca1"],
 "."
}], "Text",ExpressionUUID->"de3a5900-cbcf-4cc3-86c2-9801b8564e95"],

Cell[TextData[{
 StyleBox["WL",
  FontWeight->"Bold"],
 " : form ",
 Cell[BoxData[
  SuperscriptBox[
   StyleBox["S", "TI"], "2"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "9c493bd6-ea7e-4cd2-89d9-ba525aec6859"],
 " from the two spins, and evaluate it on the singlet and on a triplet \
representative."
}], "Text",ExpressionUUID->"5c931c3c-91d2-41db-a11e-4f1e6e46a744"],

Cell[BoxData[
 RowBox[{"With", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{"singlet", " ", "=", " ", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"0", ",", " ", "1", ",", " ", 
         RowBox[{"-", "1"}], ",", " ", "0"}], "}"}], "/", 
       RowBox[{"Sqrt", "[", "2", "]"}]}]}], ",", " ", 
     RowBox[{"triplet", " ", "=", " ", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"0", ",", " ", "1", ",", " ", "1", ",", " ", "0"}], "}"}], "/", 
       RowBox[{"Sqrt", "[", "2", "]"}]}]}]}], "}"}], ",", " ", 
   RowBox[{"With", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"stot", " ", "=", " ", 
       RowBox[{"Table", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"KroneckerProduct", "[", 
           RowBox[{
            RowBox[{
             RowBox[{"PauliMatrix", "[", "k", "]"}], "/", "2"}], ",", " ", 
            RowBox[{"IdentityMatrix", "[", "2", "]"}]}], "]"}], " ", "+", " ", 
          RowBox[{"KroneckerProduct", "[", 
           RowBox[{
            RowBox[{"IdentityMatrix", "[", "2", "]"}], ",", " ", 
            RowBox[{
             RowBox[{"PauliMatrix", "[", "k", "]"}], "/", "2"}]}], "]"}]}], ",",
          " ", 
         RowBox[{"{", 
          RowBox[{"k", ",", " ", "3"}], "}"}]}], "]"}]}], "}"}], ",", " ", 
     RowBox[{"With", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"s2", " ", "=", " ", 
         RowBox[{"Sum", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"stot", "[", 
             RowBox[{"[", "k", "]"}], "]"}], " ", ".", " ", 
            RowBox[{"stot", "[", 
             RowBox[{"[", "k", "]"}], "]"}]}], ",", " ", 
           RowBox[{"{", 
            RowBox[{"k", ",", " ", "3"}], "}"}]}], "]"}]}], "}"}], ",", " ", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{
          RowBox[{"Conjugate", "[", "singlet", "]"}], " ", ".", " ", "s2", 
          " ", ".", " ", "singlet"}], ",", " ", 
         RowBox[{
          RowBox[{"Conjugate", "[", "triplet", "]"}], " ", ".", " ", "s2", 
          " ", ".", " ", "triplet"}]}], "}"}]}], "]"}]}], "]"}]}], 
  "]"}]], "Input",
 CellLabel->
  "In[12]:= ",ExpressionUUID->"184ea659-7c6f-4cda-9f5a-423b4458a851"],

Cell[TextData[{
 StyleBox["QF",
  FontWeight->"Bold"],
 " : the same ",
 Cell[BoxData[
  SuperscriptBox[
   StyleBox["S", "TI"], "2"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "ab7754ea-38e0-4e0e-9417-652ae08d5da0"],
 " as a ",
 Cell[BoxData["QuantumOperator"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "8a3dc1a8-a946-4993-8d54-bc8983da9316"],
 "; its spectrum on the whole space shows the multiplicities directly, one ",
 Cell[BoxData[
  RowBox[{
   SuperscriptBox[
    StyleBox["S", "TI"], "2"], "=", "0"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "56bdd039-7fb6-4fc2-bb75-7b8e3fb2669f"],
 " level and three ",
 Cell[BoxData[
  RowBox[{
   SuperscriptBox[
    StyleBox["S", "TI"], "2"], "=", "2"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "c71f5d5e-1022-4012-8e83-7821f1828e2a"],
 " levels."
}], "Text",ExpressionUUID->"e282b755-7304-4065-8fb3-2ca4405f365f"],

Cell[BoxData[
 RowBox[{"With", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"stot", " ", "=", " ", 
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"QuantumTensorProduct", "[", 
         RowBox[{
          RowBox[{"QuantumOperator", "[", 
           RowBox[{
            RowBox[{"PauliMatrix", "[", "k", "]"}], "/", "2"}], "]"}], ",", 
          " ", 
          RowBox[{"QuantumOperator", "[", "\"\<I\>\"", "]"}]}], "]"}], " ", "+",
         " ", 
        RowBox[{"QuantumTensorProduct", "[", 
         RowBox[{
          RowBox[{"QuantumOperator", "[", "\"\<I\>\"", "]"}], ",", " ", 
          RowBox[{"QuantumOperator", "[", 
           RowBox[{
            RowBox[{"PauliMatrix", "[", "k", "]"}], "/", "2"}], "]"}]}], 
         "]"}]}], ",", " ", 
       RowBox[{"{", 
        RowBox[{"k", ",", " ", "3"}], "}"}]}], "]"}]}], "}"}], ",", " ", 
   RowBox[{"Sort", "[", 
    RowBox[{
     RowBox[{"Sum", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"stot", "[", 
         RowBox[{"[", "k", "]"}], "]"}], " ", "@", " ", 
        RowBox[{"stot", "[", 
         RowBox[{"[", "k", "]"}], "]"}]}], ",", " ", 
       RowBox[{"{", 
        RowBox[{"k", ",", " ", "3"}], "}"}]}], "]"}], 
     "[", "\"\<Eigenvalues\>\"", "]"}], "]"}]}], "]"}]], "Input",
 CellLabel->
  "In[13]:= ",ExpressionUUID->"42922973-b25f-40aa-a737-46db1a047cd6"],

Cell[TextData[{
 "The singlet returns ",
 Cell[BoxData[
  RowBox[{
   SuperscriptBox[
    StyleBox["S", "TI"], "2"], "=", "0"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "76d95bcb-6d18-4803-a6b0-a8a1cf20c604"],
 " and every triplet state returns ",
 Cell[BoxData[
  RowBox[{
   SuperscriptBox[
    StyleBox["S", "TI"], "2"], "=", "2", "=", "1", 
   StyleBox["(",
    SpanMaxSize->1], 
   RowBox[{"1", "+", "1"}], 
   StyleBox[")",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "d416450b-f4fb-4098-8cde-fb3556bfea5a"],
 "; the QF spectrum is ",
 Cell[BoxData[
  RowBox[{
   RowBox[{"{", "0"}], ",", 
   RowBox[{"2", ",", "2"}], ",", 
   RowBox[{"2", "}"}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "bc596bfa-ac1a-4990-90b7-f3c1bb73a80c"],
 ", exactly the ",
 Cell[BoxData[
  RowBox[{"1", "\[CirclePlus]", "3"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "a0858fa3-bc75-42a9-be2f-5e640004dc36"],
 " multiplicity of ",
 Cell[BoxData[
  RowBox[{
   FractionBox["1", "2"], "\[CircleTimes]", 
   FractionBox["1", "2"], "=", "0", "\[CirclePlus]", "1"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "d18e723a-6b39-4e0b-8b0a-678f48fe7a53"],
 ". Total spin is the conserved label that block-diagonalizes any \
rotationally invariant two-spin interaction (as in Part 7, 7.10)."
}], "Text",ExpressionUUID->"574505c0-6e57-42f8-ae91-c8cd176af7a3"],

Cell["\<\
8.7 [MSc] How do I construct a spin coherent state and place it on the \
generalized Bloch sphere?\
\>", "Subsection",ExpressionUUID->"60b57d0c-bd1d-40ad-8d22-5ee55efbd8e7"],

Cell[TextData[{
 "A spin coherent state is the most classical state of a spin-",
 Cell[BoxData[
  StyleBox["j", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "129bddea-014c-4486-8751-eb490a339d6b"],
 ": the highest-weight state ",
 Cell[BoxData[
  TemplateBox[{
    RowBox[{
      StyleBox["j", "TI"], ",", 
      StyleBox["j", "TI"]}]},
   "Ket"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "1baeb1a4-249a-4797-8851-2cfe0ecde4ee"],
 " rotated to point along a direction ",
 Cell[BoxData[
  RowBox[{
   OverscriptBox[
    StyleBox["n", "TI"], "^"], 
   StyleBox["(",
    SpanMaxSize->1], 
   RowBox[{
    StyleBox["\[Theta]", "TI"], ",", "\[CurlyPhi]"}], 
   StyleBox[")",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "ed69cc36-ce9e-447b-9de1-4e5e0c140b07"],
 ", ",
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     RowBox[{
       StyleBox["j", "TI"], ",", 
       OverscriptBox[
        StyleBox["n", "TI"], "^"]}]},
    "Ket"], "=", 
   RowBox[{
    SuperscriptBox[
     StyleBox["e", "TI"], 
     RowBox[{"-", 
      StyleBox["i", "TI"], "\[CurlyPhi]", 
      SubscriptBox[
       StyleBox["J", "TI"], 
       StyleBox["z", "TI"]]}]], 
    SuperscriptBox[
     StyleBox["e", "TI"], 
     RowBox[{"-", 
      StyleBox["i", "TI"], 
      StyleBox["\[Theta]", "TI"], 
      SubscriptBox[
       StyleBox["J", "TI"], 
       StyleBox["y", "TI"]]}]], 
    TemplateBox[{
      RowBox[{
        StyleBox["j", "TI"], ",", 
        StyleBox["j", "TI"]}]},
     "Ket"]}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "51f2cc13-9662-463d-8c50-7262a9ecb435"],
 ". Its expectation vector is fully polarized, ",
 Cell[BoxData[
  RowBox[{
   StyleBox["\[LeftAngleBracket]",
    SpanMaxSize->1], 
   OverscriptBox[
    StyleBox["J", "TI"], "\[RightVector]"], 
   StyleBox["\[RightAngleBracket]",
    SpanMaxSize->1], "=", 
   StyleBox["j", "TI"], " ", 
   OverscriptBox[
    StyleBox["n", "TI"], "^"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "d6bbac5a-ce0e-4939-8886-3e697b80efca"],
 ", so it sits on the sphere of radius ",
 Cell[BoxData[
  StyleBox["j", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "643bc45f-2a4a-4964-824c-b5f8a54559a7"],
 ", the generalized Bloch sphere. Build it for spin ",
 Cell[BoxData[
  RowBox[{
   StyleBox["j", "TI"], "=", "1"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "6b933b55-30a7-4400-8a54-90db034842bb"],
 "."
}], "Text",ExpressionUUID->"5970cfbb-6cf8-4188-a702-484b93cb1eda"],

Cell[TextData[{
 StyleBox["WL",
  FontWeight->"Bold"],
 " : rotate the highest-weight state and confirm ",
 Cell[BoxData[
  RowBox[{
   StyleBox["\[LeftAngleBracket]",
    SpanMaxSize->1], 
   OverscriptBox[
    StyleBox["J", "TI"], "\[RightVector]"], 
   StyleBox["\[RightAngleBracket]",
    SpanMaxSize->1], "=", 
   StyleBox["j", "TI"], " ", 
   OverscriptBox[
    StyleBox["n", "TI"], "^"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "e1e9d744-4c7c-4e54-889f-c8f0cb0c7e04"],
 "."
}], "Text",ExpressionUUID->"b7ee3c45-4c21-4624-9312-3a2cb03440af"],

Cell[BoxData[
 RowBox[{"With", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"j", " ", "=", " ", "1"}], "}"}], ",", " ", 
   RowBox[{"With", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"m", " ", "=", " ", 
        RowBox[{"Range", "[", 
         RowBox[{"j", ",", " ", 
          RowBox[{"-", "j"}], ",", " ", 
          RowBox[{"-", "1"}]}], "]"}]}], ",", " ", 
       RowBox[{"n", " ", "=", " ", 
        RowBox[{
         RowBox[{"2", " ", "j"}], " ", "+", " ", "1"}]}]}], "}"}], ",", " ", 
     RowBox[{"With", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{"jz", " ", "=", " ", 
          RowBox[{"DiagonalMatrix", "[", 
           RowBox[{"Range", "[", 
            RowBox[{"j", ",", " ", 
             RowBox[{"-", "j"}], ",", " ", 
             RowBox[{"-", "1"}]}], "]"}], "]"}]}], ",", " ", 
         RowBox[{"jp", " ", "=", " ", 
          RowBox[{"SparseArray", "[", 
           RowBox[{
            RowBox[{
             RowBox[{
              RowBox[{"{", 
               RowBox[{"r_", ",", " ", "c_"}], "}"}], " ", "/;", " ", 
              RowBox[{"r", " ", "==", " ", 
               RowBox[{"c", " ", "-", " ", "1"}]}]}], " ", ":>", " ", 
             RowBox[{"Sqrt", "[", 
              RowBox[{
               RowBox[{"j", " ", 
                RowBox[{"(", 
                 RowBox[{"j", " ", "+", " ", "1"}], ")"}]}], " ", "-", " ", 
               RowBox[{
                RowBox[{"m", "[", 
                 RowBox[{"[", "c", "]"}], "]"}], " ", 
                RowBox[{"(", 
                 RowBox[{
                  RowBox[{"m", "[", 
                   RowBox[{"[", "c", "]"}], "]"}], " ", "+", " ", "1"}], 
                 ")"}]}]}], "]"}]}], ",", " ", 
            RowBox[{"{", 
             RowBox[{"n", ",", " ", "n"}], "}"}]}], "]"}]}]}], "}"}], ",", 
       " ", 
       RowBox[{"With", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{
           RowBox[{"jx", " ", "=", " ", 
            RowBox[{
             RowBox[{"(", 
              RowBox[{"jp", " ", "+", " ", 
               RowBox[{"Transpose", "[", "jp", "]"}]}], ")"}], "/", "2"}]}], ",",
            " ", 
           RowBox[{"jy", " ", "=", " ", 
            RowBox[{
             RowBox[{"(", 
              RowBox[{"jp", " ", "-", " ", 
               RowBox[{"Transpose", "[", "jp", "]"}]}], ")"}], "/", 
             RowBox[{"(", 
              RowBox[{"2", " ", "I"}], ")"}]}]}]}], "}"}], ",", " ", 
         RowBox[{"With", "[", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{"coh", " ", "=", " ", 
             RowBox[{
              RowBox[{"MatrixExp", "[", 
               RowBox[{
                RowBox[{"-", "I"}], " ", "\[Phi]", " ", "jz"}], "]"}], " ", ".",
               " ", 
              RowBox[{"MatrixExp", "[", 
               RowBox[{
                RowBox[{"-", "I"}], " ", "\[Theta]", " ", "jy"}], "]"}], " ", 
              ".", " ", 
              RowBox[{"UnitVector", "[", 
               RowBox[{"n", ",", " ", "1"}], "]"}]}]}], "}"}], ",", " ", 
           RowBox[{"Simplify", "[", 
            RowBox[{
             RowBox[{"ComplexExpand", "[", 
              RowBox[{"{", 
               RowBox[{
                RowBox[{
                 RowBox[{"Conjugate", "[", "coh", "]"}], " ", ".", " ", "jx", 
                 " ", ".", " ", "coh"}], ",", " ", 
                RowBox[{
                 RowBox[{"Conjugate", "[", "coh", "]"}], " ", ".", " ", "jy", 
                 " ", ".", " ", "coh"}], ",", " ", 
                RowBox[{
                 RowBox[{"Conjugate", "[", "coh", "]"}], " ", ".", " ", "jz", 
                 " ", ".", " ", "coh"}]}], "}"}], "]"}], ",", " ", 
             RowBox[{
              RowBox[{"{", 
               RowBox[{"\[Theta]", ",", " ", "\[Phi]"}], "}"}], " ", "\[Element]",
               " ", "Reals"}]}], "]"}]}], "]"}]}], "]"}]}], "]"}]}], "]"}]}], 
  "]"}]], "Input",
 CellLabel->
  "In[14]:= ",ExpressionUUID->"f2412e99-c553-4e33-afcb-00525d55ecfb"],

Cell[TextData[{
 StyleBox["QF",
  FontWeight->"Bold"],
 " : the same coherent state as a ",
 Cell[BoxData["QuantumState"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "f571f1b5-2943-4134-bcf3-27862d7d58d9"],
 "; its polarization vector, the three spin expectations, points along ",
 Cell[BoxData[
  OverscriptBox[
   StyleBox["n", "TI"], "^"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "63ebdcc5-6b65-4f06-a95c-47b8594c46a3"],
 " with length ",
 Cell[BoxData[
  StyleBox["j", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "56861902-595a-4056-9273-f8ae02c177c3"],
 "."
}], "Text",ExpressionUUID->"a75e9c4a-85a8-431c-bdb4-e62fd224d941"],

Cell[BoxData[
 RowBox[{"With", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"j", " ", "=", " ", "1"}], "}"}], ",", " ", 
   RowBox[{"With", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"m", " ", "=", " ", 
        RowBox[{"Range", "[", 
         RowBox[{"j", ",", " ", 
          RowBox[{"-", "j"}], ",", " ", 
          RowBox[{"-", "1"}]}], "]"}]}], ",", " ", 
       RowBox[{"n", " ", "=", " ", 
        RowBox[{
         RowBox[{"2", " ", "j"}], " ", "+", " ", "1"}]}]}], "}"}], ",", " ", 
     RowBox[{"With", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{"jz", " ", "=", " ", 
          RowBox[{"DiagonalMatrix", "[", 
           RowBox[{"Range", "[", 
            RowBox[{"j", ",", " ", 
             RowBox[{"-", "j"}], ",", " ", 
             RowBox[{"-", "1"}]}], "]"}], "]"}]}], ",", " ", 
         RowBox[{"jp", " ", "=", " ", 
          RowBox[{"SparseArray", "[", 
           RowBox[{
            RowBox[{
             RowBox[{
              RowBox[{"{", 
               RowBox[{"r_", ",", " ", "c_"}], "}"}], " ", "/;", " ", 
              RowBox[{"r", " ", "==", " ", 
               RowBox[{"c", " ", "-", " ", "1"}]}]}], " ", ":>", " ", 
             RowBox[{"Sqrt", "[", 
              RowBox[{
               RowBox[{"j", " ", 
                RowBox[{"(", 
                 RowBox[{"j", " ", "+", " ", "1"}], ")"}]}], " ", "-", " ", 
               RowBox[{
                RowBox[{"m", "[", 
                 RowBox[{"[", "c", "]"}], "]"}], " ", 
                RowBox[{"(", 
                 RowBox[{
                  RowBox[{"m", "[", 
                   RowBox[{"[", "c", "]"}], "]"}], " ", "+", " ", "1"}], 
                 ")"}]}]}], "]"}]}], ",", " ", 
            RowBox[{"{", 
             RowBox[{"n", ",", " ", "n"}], "}"}]}], "]"}]}]}], "}"}], ",", 
       " ", 
       RowBox[{"With", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{
           RowBox[{"jx", " ", "=", " ", 
            RowBox[{
             RowBox[{"(", 
              RowBox[{"jp", " ", "+", " ", 
               RowBox[{"Transpose", "[", "jp", "]"}]}], ")"}], "/", "2"}]}], ",",
            " ", 
           RowBox[{"jy", " ", "=", " ", 
            RowBox[{
             RowBox[{"(", 
              RowBox[{"jp", " ", "-", " ", 
               RowBox[{"Transpose", "[", "jp", "]"}]}], ")"}], "/", 
             RowBox[{"(", 
              RowBox[{"2", " ", "I"}], ")"}]}]}]}], "}"}], ",", " ", 
         RowBox[{"With", "[", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{"coh", " ", "=", " ", 
             RowBox[{"QuantumState", "[", 
              RowBox[{
               RowBox[{"MatrixExp", "[", 
                RowBox[{
                 RowBox[{"-", "I"}], " ", "\[Phi]", " ", "jz"}], "]"}], " ", ".",
                " ", 
               RowBox[{"MatrixExp", "[", 
                RowBox[{
                 RowBox[{"-", "I"}], " ", "\[Theta]", " ", "jy"}], "]"}], " ",
                ".", " ", 
               RowBox[{"UnitVector", "[", 
                RowBox[{"n", ",", " ", "1"}], "]"}]}], "]"}]}], "}"}], ",", 
           " ", 
           RowBox[{"Simplify", "[", 
            RowBox[{
             RowBox[{"ComplexExpand", "[", 
              RowBox[{"Table", "[", 
               RowBox[{
                RowBox[{
                 RowBox[{"(", 
                  RowBox[{
                   RowBox[{"coh", "[", "\"\<Dagger\>\"", "]"}], " ", "@", " ", 
                   RowBox[{
                    RowBox[{"QuantumOperator", "[", "op", "]"}], " ", "@", 
                    " ", "coh"}]}], ")"}], "[", "\"\<Scalar\>\"", "]"}], ",", 
                " ", 
                RowBox[{"{", 
                 RowBox[{"op", ",", " ", 
                  RowBox[{"{", 
                   RowBox[{"jx", ",", " ", "jy", ",", " ", "jz"}], "}"}]}], 
                 "}"}]}], "]"}], "]"}], ",", " ", 
             RowBox[{
              RowBox[{"{", 
               RowBox[{"\[Theta]", ",", " ", "\[Phi]"}], "}"}], " ", "\[Element]",
               " ", "Reals"}]}], "]"}]}], "]"}]}], "]"}]}], "]"}]}], "]"}]}], 
  "]"}]], "Input",
 CellLabel->
  "In[15]:= ",ExpressionUUID->"c71d3663-c462-43f0-b885-b3f13395d721"],

Cell[TextData[{
 "Both give ",
 Cell[BoxData[
  RowBox[{
   StyleBox["\[LeftAngleBracket]",
    SpanMaxSize->1], 
   OverscriptBox[
    StyleBox["J", "TI"], "\[RightVector]"], 
   StyleBox["\[RightAngleBracket]",
    SpanMaxSize->1], "=", 
   StyleBox["(",
    SpanMaxSize->1], 
   RowBox[{
    RowBox[{
     StyleBox["sin",
      FontSlant->"Plain"], "\[ThinSpace]", 
     StyleBox["\[Theta]", "TI"], 
     StyleBox["cos",
      FontSlant->"Plain"], "\[ThinSpace]", "\[CurlyPhi]"}], ",", 
    RowBox[{
     StyleBox["sin",
      FontSlant->"Plain"], "\[ThinSpace]", 
     StyleBox["\[Theta]", "TI"], 
     StyleBox["sin",
      FontSlant->"Plain"], "\[ThinSpace]", "\[CurlyPhi]"}], ",", 
    RowBox[{
     StyleBox["cos",
      FontSlant->"Plain"], "\[ThinSpace]", 
     StyleBox["\[Theta]", "TI"]}]}], 
   StyleBox[")",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "e486a245-4a68-4b51-ae64-2edf5651c8e8"],
 ", exactly ",
 Cell[BoxData[
  RowBox[{
   StyleBox["j", "TI"], " ", 
   OverscriptBox[
    StyleBox["n", "TI"], "^"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "fe4d831b-762d-4b01-8349-434be536ad51"],
 " with ",
 Cell[BoxData[
  RowBox[{
   StyleBox["j", "TI"], "=", "1"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "31832d0b-cf99-40ff-99f9-64b5b53bf331"],
 ": the spin coherent state points as definitely as a spin can in the \
direction ",
 Cell[BoxData[
  OverscriptBox[
   StyleBox["n", "TI"], "^"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "e2c6456d-b251-4a65-a54e-dee926ef6c89"],
 ", saturating the angular-momentum uncertainty and serving as the \
finite-dimensional stand-in for the (infinite-dimensional) coherent state of \
light."
}], "Text",ExpressionUUID->"6056f957-e148-4733-9363-064b7acd9c88"]
