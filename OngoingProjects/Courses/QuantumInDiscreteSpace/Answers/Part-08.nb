         RowBox[{"j", ",", " ", 
          RowBox[{"-", "j"}], ",", " ", 
          RowBox[{"-", "1"}]}], "]"}]}], ",", " ", 
       RowBox[{"n", " ", "=", " ", 
        RowBox[{
         RowBox[{"2", " ", "j"}], " ", "+", " ", "1"}]}]}], "}"}], ",", " ", 
     RowBox[{"With", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{"jz", " ", "=", " ", 
          RowBox[{"DiagonalMatrix", "[", 
           RowBox[{"Range", "[", 
            RowBox[{"j", ",", " ", 
             RowBox[{"-", "j"}], ",", " ", 
             RowBox[{"-", "1"}]}], "]"}], "]"}]}], ",", " ", 
         RowBox[{"jp", " ", "=", " ", 
          RowBox[{"SparseArray", "[", 
           RowBox[{
            RowBox[{
             RowBox[{
              RowBox[{"{", 
               RowBox[{"r_", ",", " ", "c_"}], "}"}], " ", "/;", " ", 
              RowBox[{"r", " ", "==", " ", 
               RowBox[{"c", " ", "-", " ", "1"}]}]}], " ", ":>", " ", 
             RowBox[{"Sqrt", "[", 
              RowBox[{
               RowBox[{"j", " ", 
                RowBox[{"(", 
                 RowBox[{"j", " ", "+", " ", "1"}], ")"}]}], " ", "-", " ", 
