Cell[BoxData[
 RowBox[{"With", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"j", " ", "=", " ", "1"}], "}"}], ",", " ", 
   RowBox[{"With", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"m", " ", "=", " ", 
        RowBox[{"Range", "[", 
         RowBox[{"j", ",", " ", 
          RowBox[{"-", "j"}], ",", " ", 
          RowBox[{"-", "1"}]}], "]"}]}], ",", " ", 
       RowBox[{"n", " ", "=", " ", 
        RowBox[{
         RowBox[{"2", " ", "j"}], " ", "+", " ", "1"}]}]}], "}"}], ",", " ", 
     RowBox[{"With", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{"jz", " ", "=", " ", 
          RowBox[{"DiagonalMatrix", "[", 
           RowBox[{"Range", "[", 
            RowBox[{"j", ",", " ", 
             RowBox[{"-", "j"}], ",", " ", 
             RowBox[{"-", "1"}]}], "]"}], "]"}]}], ",", " ", 
         RowBox[{"jp", " ", "=", " ", 
          RowBox[{"SparseArray", "[", 
           RowBox[{
            RowBox[{
             RowBox[{
              RowBox[{"{", 
               RowBox[{"r_", ",", " ", "c_"}], "}"}], " ", "/;", " ", 
              RowBox[{"r", " ", "==", " ", 
               RowBox[{"c", " ", "-", " ", "1"}]}]}], " ", ":>", " ", 
             RowBox[{"Sqrt", "[", 
              RowBox[{
               RowBox[{"j", " ", 
                RowBox[{"(", 
                 RowBox[{"j", " ", "+", " ", "1"}], ")"}]}], " ", "-", " ", 
               RowBox[{
                RowBox[{"m", "[", 
                 RowBox[{"[", "c", "]"}], "]"}], " ", 
                RowBox[{"(", 
                 RowBox[{
                  RowBox[{"m", "[", 
                   RowBox[{"[", "c", "]"}], "]"}], " ", "+", " ", "1"}], 
                 ")"}]}]}], "]"}]}], ",", " ", 
            RowBox[{"{", 
             RowBox[{"n", ",", " ", "n"}], "}"}]}], "]"}]}]}], "}"}], ",", 
       " ", 
       RowBox[{"With", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{
           RowBox[{"jx", " ", "=", " ", 
            RowBox[{
             RowBox[{"(", 
              RowBox[{"jp", " ", "+", " ", 
               RowBox[{"Transpose", "[", "jp", "]"}]}], ")"}], "/", "2"}]}], ",",
            " ", 
           RowBox[{"jy", " ", "=", " ", 
            RowBox[{
             RowBox[{"(", 
              RowBox[{"jp", " ", "-", " ", 
               RowBox[{"Transpose", "[", "jp", "]"}]}], ")"}], "/", 
             RowBox[{"(", 
              RowBox[{"2", " ", "I"}], ")"}]}]}]}], "}"}], ",", " ", 
         RowBox[{"With", "[", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{"\[Psi]", " ", "=", " ", 
             RowBox[{
              RowBox[{"MatrixExp", "[", 
               RowBox[{
                RowBox[{"-", "I"}], " ", "\[Beta]", " ", "jy"}], "]"}], " ", ".",
               " ", 
              RowBox[{"UnitVector", "[", 
               RowBox[{"n", ",", " ", "1"}], "]"}]}]}], "}"}], ",", " ", 
           RowBox[{"Simplify", "[", 
            RowBox[{
             RowBox[{"ComplexExpand", "[", 
              RowBox[{"{", 
               RowBox[{
                RowBox[{
                 RowBox[{"Conjugate", "[", "\[Psi]", "]"}], " ", ".", " ", 
                 "jx", " ", ".", " ", "\[Psi]"}], ",", " ", 
                RowBox[{
                 RowBox[{"Conjugate", "[", "\[Psi]", "]"}], " ", ".", " ", 
                 "jy", " ", ".", " ", "\[Psi]"}], ",", " ", 
                RowBox[{
                 RowBox[{"Conjugate", "[", "\[Psi]", "]"}], " ", ".", " ", 
                 "jz", " ", ".", " ", "\[Psi]"}]}], "}"}], "]"}], ",", " ", 
             RowBox[{"\[Beta]", " ", "\[Element]", " ", "Reals"}]}], "]"}]}], 
          "]"}]}], "]"}]}], "]"}]}], "]"}]}], "]"}]], "Input",
 CellLabel->"In[6]:= ",ExpressionUUID->"50eb0986-74ff-4750-9cd8-77d767795268"],

