(* Beginning of Notebook Content *)
Notebook[{
Cell["\<\
Quantum in Finite Dimensions: Answers in WL and in QuantumFramework (Part 8)\
\>", "Title",ExpressionUUID->"0ebefc9f-ebb1-41bd-a1b5-b4552d7f749e"],

Cell[TextData[{
 "A companion answer key to ",
 Cell["Question-List.md", "InlineCode",ExpressionUUID->
  "d35aed6e-052c-4f9c-a4d5-cf2b722a539a"],
 ". For each question it gives ",
 StyleBox["two",
  FontWeight->"Bold"],
 " worked answers:"
}], "Text",ExpressionUUID->"8971f3c0-3d1b-44df-842d-8ad5c3937fa0"],

Cell[TextData[{
 StyleBox["WL",
  FontWeight->"Bold"],
 " : native Wolfram Language only (plain vectors and matrices, ",
 Cell[BoxData["PauliMatrix"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "1d339760-365a-4be7-b24c-9e369a7dd61e"],
 ", ",
 Cell[BoxData["MatrixExp"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "9b618dfa-4911-4a5d-9ad8-b5f42a622a2e"],
 ", ",
 Cell[BoxData["WignerD"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "f0c193f3-1e8e-4fad-b21f-ed296b0d7737"],
 ", ",
 Cell[BoxData["ClebschGordan"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "e66bb075-e997-4f94-b1f7-e738b55da3fa"],
 ", ",
 Cell[BoxData["Eigensystem"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "bab527c4-b07d-49ad-ba3b-e41174a897cc"],
 ", and friends). Nothing beyond the built-in language."
}], "ItemNumbered",ExpressionUUID->"bf311eb2-fb5b-45e7-8b15-a3c45e152e94"],

Cell[TextData[{
 StyleBox["QF",
  FontWeight->"Bold"],
 " : the same task done through the ",
 StyleBox["QuantumFramework",
  FontWeight->"Bold"],
 " paclet, leaning on its objects and property downvalues (",
 Cell[BoxData[
  RowBox[{
   RowBox[{"QuantumState", "[", "...", "]"}], "[", "\"\<...\>\"", "]"}]], 
  "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "10bb1758-4640-43e7-8752-51473094245b"],
 ") rather than rebuilding matrices by hand. A QF result is a rich object, a \
state or an operator, not a bare array: it can act on a target, compose with \
others, report its spectrum, change basis, and more. The answers keep results \
as objects and treat a matrix or amplitude vector as just one of the object's \
many representations, not the thing itself."
}], "ItemNumbered",ExpressionUUID->"f5df040c-4705-4f34-9358-11e7362a1ea2"],

Cell[TextData[{
 "Three habits run through the answers. They stay ",
 StyleBox["symbolic",
  FontWeight->"Bold"],
 " wherever possible (general angles ",
 Cell[BoxData[
  RowBox[{
   StyleBox["\[Theta]", "TI"], ",", 
   StyleBox["\[Phi]", "TI"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "b49c5d4e-b389-46f1-8ee6-7eb37661a90b"],
 "), so each operation is exercised in full generality rather than on a lucky \
special case. They write the computation ",
 StyleBox["explicitly",
  FontWeight->"Bold"],
 " rather than hiding it in a helper function, because the code is itself \
part of the explanation: the spin-",
 Cell[BoxData[
  StyleBox["j", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "c877c1d9-6b77-4d49-8252-b80ed304d726"],
 " operators are built in place from the ladder relation ",
 Cell[BoxData[
  RowBox[{
   RowBox[{
    SubscriptBox[
     StyleBox["J", "TI"], "\[PlusMinus]"], 
    TemplateBox[{
      RowBox[{
        StyleBox["j", "TI"], ",", 
        StyleBox["m", "TI"]}]},
     "Ket"]}], "=", 
   RowBox[{
    SqrtBox[
     RowBox[{
      StyleBox["j", "TI"], 
      StyleBox["(",
       SpanMaxSize->1], 
      RowBox[{
       StyleBox["j", "TI"], "+", "1"}], 
      StyleBox[")",
       SpanMaxSize->1], "-", 
      StyleBox["m", "TI"], 
      StyleBox["(",
       SpanMaxSize->1], 
      RowBox[{
       StyleBox["m", "TI"], "\[PlusMinus]", "1"}], 
      StyleBox[")",
       SpanMaxSize->1]}]], 
    TemplateBox[{
      RowBox[{
        StyleBox["j", "TI"], ",", 
        StyleBox["m", "TI"], "\[PlusMinus]", "1"}]},
     "Ket"]}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "ba8e3079-b583-4738-b175-a3575e4124c5"],
 ", never pasted in as fixed matrices. And they prefer ",
 StyleBox["built-in features",
  FontWeight->"Bold"],
 " (a ",
 Cell[BoxData["WignerD"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "287d0a70-b333-4a0b-a292-0c06af01649b"],
 ", a ",
 Cell[BoxData["ClebschGordan"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "8601e565-d232-40b4-9b71-cbc535399931"],
 ") over hand-rolled constructions. Each cell does ",
 StyleBox["one",
  FontWeight->"Bold"],
 " thing and is preceded by a sentence saying what. We use the physicist's \
convention ",
 Cell[BoxData[
  RowBox[{"\[HBar]", "=", "1"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "3a28cb60-b712-491a-bd85-2b1b93346484"],
 ", so a spin-",
 Cell[BoxData[
  StyleBox["j", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "c2792c44-197d-465d-af0a-9b1841d87b43"],
 " has ",
 Cell[BoxData[
  RowBox[{
   SuperscriptBox[
    StyleBox["J", "TI"], "2"], "=", 
   StyleBox["j", "TI"], 
   StyleBox["(",
    SpanMaxSize->1], 
   RowBox[{
    StyleBox["j", "TI"], "+", "1"}], 
   StyleBox[")",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "bf83d3d7-693e-4af1-a97d-69d84eaec92d"],
 " and ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["J", "TI"], 
   StyleBox["z", "TI"]]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "b7830dc3-106d-4d0c-b3c9-dc186895802f"],
 " eigenvalues ",
 Cell[BoxData[
  RowBox[{
   RowBox[{
    StyleBox["m", "TI"], "=", "-", 
    StyleBox["j", "TI"]}], ",", "\[Ellipsis]", ",", 
   StyleBox["j", "TI"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "a237cc91-77ef-4def-9379-55d71dfb4e87"],
 ". Run the WL answers in a bare kernel; the QF answers need the paclet \
loaded once."
}], "Text",ExpressionUUID->"fbafe58d-f88b-47f0-96fd-d7f64c53d288"],

Cell["Setup", "Section",ExpressionUUID->"4cf49eaf-fa7c-4b54-b120-15ab28665a36"],

Cell["The QF answers load the paclet once:", "Text",ExpressionUUID->"c96acf02-0bb9-47ec-8ae4-66bbe40aab94"],

Cell[BoxData[
 RowBox[{"Needs", "[", "\"\<Wolfram`QuantumFramework`\>\"", "]"}]], "Input",
 CellLabel->"In[1]:= ",ExpressionUUID->"42c83bb3-198f-407a-90c8-bde27b39ffbf"],

Cell["Part 8. Spin and angular momentum", "Section",ExpressionUUID->"28b518be-f4f6-4325-97a8-0f706e1aa411"],

Cell["\<\
8.1 [BSc] How do I model a spin-1/2 in a magnetic field and reproduce the \
Stern-Gerlach spin-projection outcomes?\
\>", "Subsection",ExpressionUUID->"5269ed4b-a19c-4fd1-9cc0-f34af8fe9894"],

Cell[TextData[{
 "A spin-1/2 in a field along ",
 Cell[BoxData[
  StyleBox["z", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "2de97915-6246-419a-9d5b-fee1b657b1f3"],
 " has ",
 Cell[BoxData[
  RowBox[{
   OverscriptBox[
    StyleBox["H", "TI"], "^"], "=", "-", 
   StyleBox["\[Gamma]", "TI"], 
   StyleBox["B", "TI"], " ", 
   SubscriptBox[
    StyleBox["S", "TI"], 
    StyleBox["z", "TI"]]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "52f0ed1d-3396-4541-ad11-a68b5a5efeca"],
 " with ",
 Cell[BoxData[
  RowBox[{
   SubscriptBox[
    StyleBox["S", "TI"], 
    StyleBox["z", "TI"]], "=", 
   FractionBox["1", "2"], 
   StyleBox["Z", "TI"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "56234be4-bfb5-4a10-b1ca-d27e898aac22"],
 ". A Stern-Gerlach apparatus measures ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["S", "TI"], 
   StyleBox["z", "TI"]]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "6f27b270-65d9-442c-8a45-654b7736f488"],
 ", which has just two eigenvalues ",
 Cell[BoxData[
  RowBox[{"\[PlusMinus]", 
   FractionBox["1", "2"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "a9b21bca-6710-423c-8dc3-40a171f68786"],
 ": the beam splits in two, never a continuum. Prepare a spin pointing along \
a general direction ",
 Cell[BoxData[
  RowBox[{
   OverscriptBox[
    StyleBox["n", "TI"], "^"], 
   StyleBox["(",
    SpanMaxSize->1], 
   RowBox[{
    StyleBox["\[Theta]", "TI"], ",", "\[CurlyPhi]"}], 
   StyleBox[")",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "9a89b1d3-eeea-4a1d-bf98-7a537c092c39"],
 ", the state ",
 Cell[BoxData[
  RowBox[{
   RowBox[{"{", 
    StyleBox["cos",
     FontSlant->"Plain"], "\[ThinSpace]", 
    FractionBox[
     StyleBox["\[Theta]", "TI"], "2"]}], ",", 
   RowBox[{
    SuperscriptBox[
     StyleBox["e", "TI"], 
     RowBox[{
      StyleBox["i", "TI"], "\[CurlyPhi]"}]], 
    StyleBox["sin",
     FontSlant->"Plain"], "\[ThinSpace]", 
    FractionBox[
     StyleBox["\[Theta]", "TI"], "2"], "}"}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "43fa7369-0aa7-4a3d-a8bf-10739cb74c61"],
 ", and find the two deflection outcomes and their Born weights."
}], "Text",ExpressionUUID->"2a353b92-0f58-42cf-b7ed-af669389af84"],

Cell[TextData[{
 StyleBox["WL",
  FontWeight->"Bold"],
 " : the outcomes are the eigenvalues of ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["S", "TI"], 
   StyleBox["z", "TI"]]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "d4b2c6f4-fcb7-4586-ad50-4e1a993c60ab"],
 ", and the weights are the squared amplitudes in the ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["S", "TI"], 
   StyleBox["z", "TI"]]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "0d2b4f70-28e7-4b7a-a3d8-44a083ef0418"],
 " eigenbasis."
}], "Text",ExpressionUUID->"365ee170-36af-4ff8-8f45-a9a89bb573fc"],

Cell[BoxData[
 RowBox[{"With", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{"sz", " ", "=", " ", 
      RowBox[{
       RowBox[{"PauliMatrix", "[", "3", "]"}], "/", "2"}]}], ",", " ", 
     RowBox[{"\[Psi]", " ", "=", " ", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"Cos", "[", 
         RowBox[{"\[Theta]", "/", "2"}], "]"}], ",", " ", 
        RowBox[{
         RowBox[{"Exp", "[", 
          RowBox[{"I", " ", "\[Phi]"}], "]"}], " ", 
         RowBox[{"Sin", "[", 
          RowBox[{"\[Theta]", "/", "2"}], "]"}]}]}], "}"}]}]}], "}"}], ",", 
   " ", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"Eigenvalues", "[", "sz", "]"}], ",", " ", 
     RowBox[{"ComplexExpand", "[", 
      RowBox[{
       RowBox[{"Abs", "[", "\[Psi]", "]"}], "^", "2"}], "]"}]}], "}"}]}], 
  "]"}]], "Input",
 CellLabel->"In[2]:= ",ExpressionUUID->"53c5b965-9d9f-4d35-8b2b-4442267bf3a1"],

Cell[TextData[{
 StyleBox["QF",
  FontWeight->"Bold"],
 " : a ",
 Cell[BoxData["QuantumMeasurementOperator"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "a513fdc2-c9a9-4f48-99f4-10cf3df7d7ed"],
 " for ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["S", "TI"], 
   StyleBox["z", "TI"]]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "4fc7bb0b-0279-4c86-b9f5-ebc3e9a99581"],
 " measures the state and reports its outcomes (the eigenvalues) with their \
probabilities."
}], "Text",ExpressionUUID->"b3130b0d-6416-489e-9a09-1610e787a4f6"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{
    RowBox[{"QuantumOperator", "[", 
     RowBox[{
      RowBox[{"PauliMatrix", "[", "3", "]"}], "/", "2"}], "]"}], 
    "[", "\"\<Eigenvalues\>\"", "]"}], ",", " ", 
   RowBox[{"ComplexExpand", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"QuantumMeasurementOperator", "[", 
       RowBox[{"QuantumOperator", "[", 
        RowBox[{
         RowBox[{"PauliMatrix", "[", "3", "]"}], "/", "2"}], "]"}], "]"}], "[", 
      RowBox[{"QuantumState", "[", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"Cos", "[", 
          RowBox[{"\[Theta]", "/", "2"}], "]"}], ",", " ", 
         RowBox[{
          RowBox[{"Exp", "[", 
           RowBox[{"I", " ", "\[Phi]"}], "]"}], " ", 
          RowBox[{"Sin", "[", 
           RowBox[{"\[Theta]", "/", "2"}], "]"}]}]}], "}"}], "]"}], "]"}], 
     "[", "\"\<ProbabilitiesList\>\"", "]"}], "]"}]}], "}"}]], "Input",
 CellLabel->"In[3]:= ",ExpressionUUID->"5abaaf28-ea18-470e-bd59-0efb766fa1c6"],

Cell[TextData[{
 "Both give the two spin projections ",
 Cell[BoxData[
  RowBox[{"\[PlusMinus]", 
   FractionBox["1", "2"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "6b43d145-7c87-4b6a-a7fc-de327a307940"],
 " with probabilities ",
 Cell[BoxData[
  RowBox[{
   RowBox[{"{", 
    SuperscriptBox[
     StyleBox["cos",
      FontSlant->"Plain"], "2"], "\[ThinSpace]", 
    FractionBox[
     StyleBox["\[Theta]", "TI"], "2"]}], ",", 
   RowBox[{
    SuperscriptBox[
     StyleBox["sin",
      FontSlant->"Plain"], "2"], "\[ThinSpace]", 
    FractionBox[
     StyleBox["\[Theta]", "TI"], "2"], "}"}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "fb842253-78a0-4c15-9748-11c61ae9e89b"],
 ": the apparatus reveals the discreteness of angular momentum (only two \
beams for a spin-1/2), and a spin tilted at angle ",
 Cell[BoxData[
  StyleBox["\[Theta]", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "e87480ef-9070-439d-92d3-8c91854ea58b"],
 " from the field lands in the upper beam with probability ",
 Cell[BoxData[
  RowBox[{
   SuperscriptBox[
    StyleBox["cos",
     FontSlant->"Plain"], "2"], "\[ThinSpace]", 
   FractionBox[
    StyleBox["\[Theta]", "TI"], "2"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "c2376a8b-3293-4cab-be64-24e861a9b0b5"],
 ", the quantitative Stern-Gerlach result."
}], "Text",ExpressionUUID->"e8ca1580-fc45-4949-9b3b-59e30b7a14b5"],

Cell[TextData[{
 "8.2 [BSc] How do I build the spin-",
 Cell[BoxData[
  StyleBox["j", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "e43bd997-a859-4b9a-bbe7-4ac1a3e950ca"],
 " angular-momentum operators and verify ",
 Cell[BoxData[
  RowBox[{
   StyleBox["[",
    SpanMaxSize->1], 
   RowBox[{
    SubscriptBox[
     StyleBox["J", "TI"], 
     StyleBox["x", "TI"]], ",", 
    SubscriptBox[
     StyleBox["J", "TI"], 
     StyleBox["y", "TI"]]}], 
   StyleBox["]",
    SpanMaxSize->1], "=", 
   StyleBox["i", "TI"], 
   SubscriptBox[
    StyleBox["J", "TI"], 
    StyleBox["z", "TI"]]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "07e08319-f5c9-44c8-a866-0e4a79e47883"],
 " and the Casimir?"
}], "Subsection",ExpressionUUID->"a1902227-b0b5-49cd-bf51-fb036f0a43e2"],

Cell[TextData[{
 "The angular-momentum operators are defined by their algebra: the raising \
and lowering operators ",
 Cell[BoxData[
  RowBox[{
   RowBox[{
    SubscriptBox[
     StyleBox["J", "TI"], "\[PlusMinus]"], 
    TemplateBox[{
      RowBox[{
        StyleBox["j", "TI"], ",", 
        StyleBox["m", "TI"]}]},
     "Ket"]}], "=", 
   RowBox[{
    SqrtBox[
     RowBox[{
      StyleBox["j", "TI"], 
      StyleBox["(",
       SpanMaxSize->1], 
      RowBox[{
       StyleBox["j", "TI"], "+", "1"}], 
      StyleBox[")",
       SpanMaxSize->1], "-", 
      StyleBox["m", "TI"], 
      StyleBox["(",
       SpanMaxSize->1], 
      RowBox[{
       StyleBox["m", "TI"], "\[PlusMinus]", "1"}], 
      StyleBox[")",
       SpanMaxSize->1]}]], 
    TemplateBox[{
      RowBox[{
        StyleBox["j", "TI"], ",", 
        StyleBox["m", "TI"], "\[PlusMinus]", "1"}]},
     "Ket"]}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "df164a83-89f7-4d12-9148-6f85c6ee5a70"],
 " build ",
 Cell[BoxData[
  RowBox[{
   SubscriptBox[
    StyleBox["J", "TI"], 
    StyleBox["x", "TI"]], "=", 
   FractionBox["1", "2"], 
   StyleBox["(",
    SpanMaxSize->1], 
   RowBox[{
    SubscriptBox[
     StyleBox["J", "TI"], "+"], "+", 
    SubscriptBox[
     StyleBox["J", "TI"], "-"]}], 
   StyleBox[")",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "5f44fc5a-c02f-4d5c-9154-aad37589c355"],
 " and ",
 Cell[BoxData[
  RowBox[{
   SubscriptBox[
    StyleBox["J", "TI"], 
    StyleBox["y", "TI"]], "=", 
   FractionBox["1", 
    RowBox[{"2", 
     StyleBox["i", "TI"]}]], 
   StyleBox["(",
    SpanMaxSize->1], 
   RowBox[{
    SubscriptBox[
     StyleBox["J", "TI"], "+"], "-", 
    SubscriptBox[
     StyleBox["J", "TI"], "-"]}], 
   StyleBox[")",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "4a3c1798-34a0-4701-9d2d-e0ff0ff86e67"],
 ", and ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["J", "TI"], 
   StyleBox["z", "TI"]]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "dbcb9c58-a80e-4de4-b2d6-01131f63adf0"],
 " is diagonal with entries ",
 Cell[BoxData[
  StyleBox["m", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "bb669fbe-6635-43b7-b0df-13dae9586e71"],
 ". They satisfy ",
 Cell[BoxData[
  RowBox[{
   StyleBox["[",
    SpanMaxSize->1], 
   RowBox[{
    SubscriptBox[
     StyleBox["J", "TI"], 
     StyleBox["x", "TI"]], ",", 
    SubscriptBox[
     StyleBox["J", "TI"], 
     StyleBox["y", "TI"]]}], 
   StyleBox["]",
    SpanMaxSize->1], "=", 
   StyleBox["i", "TI"], 
   SubscriptBox[
    StyleBox["J", "TI"], 
    StyleBox["z", "TI"]]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "df861baf-0548-4de7-82db-6af1ff70d84f"],
 " and the Casimir ",
 Cell[BoxData[
  RowBox[{
   SuperscriptBox[
    StyleBox["J", "TI"], "2"], "=", 
   SubsuperscriptBox[
    StyleBox["J", "TI"], 
    StyleBox["x", "TI"], "2"], "+", 
   SubsuperscriptBox[
    StyleBox["J", "TI"], 
    StyleBox["y", "TI"], "2"], "+", 
   SubsuperscriptBox[
    StyleBox["J", "TI"], 
    StyleBox["z", "TI"], "2"], "=", 
   StyleBox["j", "TI"], 
   StyleBox["(",
    SpanMaxSize->1], 
   RowBox[{
    StyleBox["j", "TI"], "+", "1"}], 
   StyleBox[")",
    SpanMaxSize->1], " ", 
   StyleBox["I", "TI"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "5db72067-1d87-40bd-8fe3-c84172a54f37"],
 ". Build them for spin ",
 Cell[BoxData[
  RowBox[{
   StyleBox["j", "TI"], "=", "1"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "ffaceb9a-c877-45da-a338-b030149a9e49"],
 " (a qutrit) from the ladder relation."
}], "Text",ExpressionUUID->"31e5fe1d-df8f-480e-b2ef-b1874b035060"],

Cell[TextData[{
 StyleBox["WL",
  FontWeight->"Bold"],
 " : construct ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["J", "TI"], 
   StyleBox["z", "TI"]]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "3a5ce425-b73b-4f7e-86eb-547d3d17d4a3"],
 " and ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["J", "TI"], "+"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "1a2c5d9a-984c-4ea2-b6e9-7a3c156fdbb4"],
 " from the definition, then ",
 Cell[BoxData[
  RowBox[{
   SubscriptBox[
    StyleBox["J", "TI"], 
    StyleBox["x", "TI"]], ",", 
