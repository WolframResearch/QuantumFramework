             RowBox[{
              RowBox[{"(", 
               RowBox[{"jp", " ", "+", " ", 
                RowBox[{"Transpose", "[", "jp", "]"}]}], ")"}], "/", "2"}], 
             "]"}]}], ",", " ", 
           RowBox[{"jy", " ", "=", " ", 
