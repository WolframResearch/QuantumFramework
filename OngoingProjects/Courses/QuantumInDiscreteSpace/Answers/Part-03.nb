Cell[15064, 470, 134, 0, 70, "Subsection",ExpressionUUID->"36862258-352f-4f7b-bbae-0b08f74474e0"],
Cell[15201, 472, 1058, 33, 70, "Text",ExpressionUUID->"649682d2-d4bf-488b-875c-71227995bb30"],
Cell[16262, 507, 554, 21, 70, "Text",ExpressionUUID->"08b84dc5-e850-4b30-b3a6-714e79d63d8d"],
Cell[16819, 530, 923, 27, 70, "Input",ExpressionUUID->"60a5646b-3e00-437c-a9bf-ad0a1582a98c"],
Cell[17745, 559, 111, 0, 70, "Text",ExpressionUUID->"b54df6f6-f899-4338-8317-421916a2937a"],
Cell[17859, 561, 209, 5, 70, "Input",ExpressionUUID->"95809d3b-9076-445a-9238-586fbc6ec515"],
Cell[18071, 568, 114, 0, 70, "Text",ExpressionUUID->"17a58489-f28d-4821-baaa-d89ed439902e"],
