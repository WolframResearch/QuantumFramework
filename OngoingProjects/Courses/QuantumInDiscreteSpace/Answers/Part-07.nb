(* Beginning of Notebook Content *)
Notebook[{
Cell["\<\
Quantum in Finite Dimensions: Answers in WL and in QuantumFramework (Part 7)\
\>", "Title",ExpressionUUID->"ebc42fbe-a354-49c5-bb3b-7e76668d123a"],

Cell[TextData[{
 "A companion answer key to ",
 Cell["Question-List.md", "InlineCode",ExpressionUUID->
  "38668942-3803-410d-be6c-9ffff490c129"],
 ". For each question it gives ",
 StyleBox["two",
  FontWeight->"Bold"],
 " worked answers:"
}], "Text",ExpressionUUID->"2aa24450-5f07-4d77-a908-13a04e6e5bdb"],

Cell[TextData[{
 StyleBox["WL",
  FontWeight->"Bold"],
 " : native Wolfram Language only (plain vectors and matrices, ",
 Cell[BoxData["PauliMatrix"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "3fbce228-d27c-417d-b527-de44dd1b9904"],
 ", ",
 Cell[BoxData["MatrixExp"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "fd49de23-ed0b-41fc-ae8a-0084240d1c2d"],
 ", ",
 Cell[BoxData["DSolveValue"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "75665a21-b7ba-4178-abe5-50cbc4c7cd97"],
 ", ",
 Cell[BoxData["Eigensystem"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "3ce883e6-f1dc-488f-baaf-ff55bba3effb"],
 ", and friends). Nothing beyond the built-in language."
}], "ItemNumbered",ExpressionUUID->"1ef40314-9221-4217-91aa-1c4ee83426c9"],

Cell[TextData[{
 StyleBox["QF",
  FontWeight->"Bold"],
 " : the same task done through the ",
 StyleBox["QuantumFramework",
  FontWeight->"Bold"],
 " paclet, leaning on its objects and property downvalues (",
 Cell[BoxData[
  RowBox[{
   RowBox[{"QuantumState", "[", "...", "]"}], "[", "\"\<...\>\"", "]"}]], 
  "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "3df0d477-7030-428a-af68-be2de766bd62"],
 ") rather than rebuilding matrices by hand. A QF result is a rich object, a \
state or an operator, not a bare array: it can act on a target, compose with \
others, report its spectrum, change basis, and more. The answers keep results \
as objects and treat a matrix or amplitude vector as just one of the object's \
many representations, not the thing itself."
}], "ItemNumbered",ExpressionUUID->"0aed5f11-5b16-455f-b42d-39db11c18188"],

Cell[TextData[{
 "Three habits run through the answers. They stay ",
 StyleBox["symbolic",
  FontWeight->"Bold"],
 " wherever possible (general amplitudes ",
 Cell[BoxData[
  RowBox[{
   StyleBox["\[Alpha]", "TI"], ",", 
   StyleBox["\[Beta]", "TI"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "c7807c16-02c3-4bf0-96f9-39c6c151beac"],
 ", general angles ",
 Cell[BoxData[
  RowBox[{
   StyleBox["\[Theta]", "TI"], ",", 
   StyleBox["\[Phi]", "TI"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "fc0cd9eb-b92a-43c2-8b98-f1bf8c26a8a9"],
 "), so each operation is exercised in full generality rather than on a lucky \
special case. They write the computation ",
 StyleBox["explicitly",
  FontWeight->"Bold"],
 " rather than hiding it in a helper function, because the code is itself \
part of the explanation. And they prefer ",
 StyleBox["built-in features",
  FontWeight->"Bold"],
 " (a ",
 Cell[BoxData["MatrixExp"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "5878950d-b085-432e-a626-269acbfee47d"],
 ", a named state, ",
 Cell[BoxData["QuantumEvolve"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "27d0dc2e-b660-4af7-a9e3-51683ade650f"],
 ") over hand-rolled constructions, so nothing is hardcoded: every cell \
computes its result. Each cell does ",
 StyleBox["one",
  FontWeight->"Bold"],
 " thing and is preceded by a sentence saying what, so the notebook reads as \
a sequence of single, captioned computations. A few graduate items (Fermi's \
golden rule in the dense-band limit, the adiabatic sweep, Berry's geometric \
phase) resist a closed symbolic form; there the answer drops to a concrete, \
discriminating instance and says so. Run the WL answers in a bare kernel; the \
QF answers need the paclet loaded once."
}], "Text",ExpressionUUID->"c33125a4-6a8f-4245-bb00-33f20397f468"],

Cell[TextData[{
 "Throughout Part 7 we work in units where ",
 Cell[BoxData[
  RowBox[{"\[HBar]", "=", "1"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "f9371c6c-c3c9-46c8-a34d-62c0561aed59"],
 ", so the time-evolution operator is ",
 Cell[BoxData[
  RowBox[{
   StyleBox["U", "TI"], 
   StyleBox["(",
    SpanMaxSize->1], 
   StyleBox["t", "TI"], 
   StyleBox[")",
    SpanMaxSize->1], "=", 
   SuperscriptBox[
    StyleBox["e", "TI"], 
    RowBox[{"-", 
     StyleBox["i", "TI"], 
     OverscriptBox[
      StyleBox["H", "TI"], "^"], 
     StyleBox["t", "TI"]}]]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "2310e645-e578-4325-bb33-0a40a21f8947"],
 " and the Schrodinger equation is ",
 Cell[BoxData[
  RowBox[{
   RowBox[{
    StyleBox["i", "TI"], 
    RowBox[{
     SubscriptBox["\[PartialD]", 
      StyleBox["t", "TI"]], 
     TemplateBox[{
       StyleBox["\[Psi]", "TI"]},
      "Ket"]}]}], "=", 
   RowBox[{
    OverscriptBox[
     StyleBox["H", "TI"], "^"], 
    TemplateBox[{
      StyleBox["\[Psi]", "TI"]},
     "Ket"]}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "fc88be53-5f11-467e-b1e5-fb27bea96aa9"],
 "."
}], "Text",ExpressionUUID->"29dc3e33-0d93-40ac-9d0e-43b9bd2af3a9"],

Cell["Setup", "Section",ExpressionUUID->"7e41eeaa-18df-4cf8-9960-71984172e1be"],

Cell["The QF answers load the paclet once:", "Text",ExpressionUUID->"30c9abc5-c681-4c79-b340-6cb1bedbe889"],

Cell[BoxData[
 RowBox[{"Needs", "[", "\"\<Wolfram`QuantumFramework`\>\"", "]"}]], "Input",
 CellLabel->"In[1]:= ",ExpressionUUID->"8db0d61b-38d4-42e7-ab5a-e64dd8b20ae3"],

Cell["Part 7. Unitary dynamics and pictures", "Section",ExpressionUUID->"d5559818-452a-4640-a9a9-3a5f825035c8"],

Cell[TextData[{
 "7.1a [BSc] How do I build the time-evolution operator ",
 Cell[BoxData[
  RowBox[{
   StyleBox["U", "TI"], 
   StyleBox["(",
    SpanMaxSize->1], 
   StyleBox["t", "TI"], 
   StyleBox[")",
    SpanMaxSize->1], "=", 
   SuperscriptBox[
    StyleBox["e", "TI"], 
    RowBox[{"-", 
     StyleBox["i", "TI"], 
     OverscriptBox[
      StyleBox["H", "TI"], "^"], 
     StyleBox["t", "TI"]}]]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "32753f80-af15-4744-8249-7dafd612539f"],
 " (working in units where ",
 Cell[BoxData[
  RowBox[{"\[HBar]", "=", "1"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "4d8c514e-8ba3-437f-bcfe-c924c8e9cdda"],
 ")?"
}], "Subsection",ExpressionUUID->"a88a5354-5316-4739-8739-24ddcb9d5bea"],

Cell[TextData[{
 "Dynamics is generated by a Hermitian Hamiltonian ",
 Cell[BoxData[
  OverscriptBox[
   StyleBox["H", "TI"], "^"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "d2187b73-476e-4394-a8c8-f8fed261f283"],
 ": the state at time ",
 Cell[BoxData[
  StyleBox["t", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "12cb7476-71f4-4d17-98e4-36ad5b714ab8"],
 " is ",
 Cell[BoxData[
  RowBox[{
   StyleBox["U", "TI"], 
   RowBox[{
    StyleBox["(",
     SpanMaxSize->1], 
    StyleBox["t", "TI"], 
    StyleBox[")",
     SpanMaxSize->1]}], 
   TemplateBox[{
     SubscriptBox[
      StyleBox["\[Psi]", "TI"], "0"]},
    "Ket"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "bb3c4f2a-7387-4348-ae6e-f913f4016ad7"],
 " with ",
 Cell[BoxData[
  RowBox[{
   StyleBox["U", "TI"], 
   StyleBox["(",
    SpanMaxSize->1], 
   StyleBox["t", "TI"], 
   StyleBox[")",
    SpanMaxSize->1], "=", 
   SuperscriptBox[
    StyleBox["e", "TI"], 
    RowBox[{"-", 
     StyleBox["i", "TI"], 
     OverscriptBox[
      StyleBox["H", "TI"], "^"], 
     StyleBox["t", "TI"]}]]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "b5d32c25-1337-402c-b95c-b376a74bdc37"],
 ", the matrix exponential of ",
 Cell[BoxData[
  RowBox[{"-", 
   StyleBox["i", "TI"], 
   OverscriptBox[
    StyleBox["H", "TI"], "^"], 
   StyleBox["t", "TI"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "c76f3b51-e1c8-4022-a6b0-0dec97035f24"],
 ". Because ",
 Cell[BoxData[
  OverscriptBox[
   StyleBox["H", "TI"], "^"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "8683fab9-fc72-4570-9dcf-f565b55eae19"],
 " is Hermitian, ",
 Cell[BoxData[
  RowBox[{
   StyleBox["U", "TI"], 
   StyleBox["(",
    SpanMaxSize->1], 
   StyleBox["t", "TI"], 
   StyleBox[")",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "a12e53b1-1473-4a1e-acc4-d365d443b855"],
 " is unitary at every time, ",
 Cell[BoxData[
  RowBox[{
   SuperscriptBox[
    StyleBox["U", "TI"], "\[Dagger]"], 
   StyleBox["U", "TI"], "=", 
   StyleBox["I", "TI"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "e3cffb92-afee-4ccc-a8b6-5f3973d065ed"],
 ", so probability is conserved. Take the generic single-qubit Hamiltonian, a \
spin in a magnetic field along an arbitrary Bloch axis ",
 Cell[BoxData[
  RowBox[{
   OverscriptBox[
    StyleBox["n", "TI"], "^"], "=", 
   RowBox[{
    StyleBox["(",
     SpanMaxSize->1], 
    RowBox[{
     RowBox[{
      StyleBox["sin",
       FontSlant->"Plain"], "\[ThinSpace]", 
      StyleBox["\[Theta]", "TI"], 
      StyleBox["cos",
       FontSlant->"Plain"], "\[ThinSpace]", 
      StyleBox["\[Phi]", "TI"]}], ",", " ", 
     RowBox[{
      StyleBox["sin",
       FontSlant->"Plain"], "\[ThinSpace]", 
      StyleBox["\[Theta]", "TI"], 
      StyleBox["sin",
       FontSlant->"Plain"], "\[ThinSpace]", 
      StyleBox["\[Phi]", "TI"]}], ",", " ", 
     RowBox[{
      StyleBox["cos",
       FontSlant->"Plain"], "\[ThinSpace]", 
      StyleBox["\[Theta]", "TI"]}]}], 
    StyleBox[")",
     SpanMaxSize->1]}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "748894f1-5bc7-4ff0-a7b5-f709c7c86549"],
 ": the energy splitting ",
 Cell[BoxData[
  RowBox[{
   OverscriptBox[
    StyleBox["H", "TI"], "^"], "=", 
   FractionBox[
    StyleBox["\[Omega]", "TI"], "2"], " ", 
   OverscriptBox[
    StyleBox["n", "TI"], "^"], "\[CenterDot]", 
   OverscriptBox[
    StyleBox["\[Sigma]", "TI"], "\[RightVector]"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "880cd5e2-5279-4efd-8b93-844aaeaf6444"],
 ", of which a field along ",
 Cell[BoxData[
  StyleBox["z", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "411c19c9-c481-4e90-affc-45e17d55d80d"],
 " (",
 Cell[BoxData[
  RowBox[{
   StyleBox["\[Theta]", "TI"], "=", "0"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "34305799-d681-4cc7-8b33-abf3e1bd88ee"],
 ") is the special case ",
 Cell[BoxData[
  RowBox[{
   FractionBox[
    StyleBox["\[Omega]", "TI"], "2"], 
   StyleBox["Z", "TI"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "1e0174ee-bd94-4cb0-a230-45851d8cbf33"],
 "."
}], "Text",ExpressionUUID->"2d458210-5435-4973-b8a6-7ad547fe6aea"],

Cell[TextData[{
 StyleBox["WL",
  FontWeight->"Bold"],
 " : the propagator is ",
 Cell[BoxData["MatrixExp"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "177b4ab4-77e0-4925-b37e-39eb46228709"],
 " of ",
 Cell[BoxData[
  RowBox[{"-", 
   StyleBox["i", "TI"], 
   OverscriptBox[
    StyleBox["H", "TI"], "^"], 
   StyleBox["t", "TI"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "93aac451-ad67-49e9-9be8-eb8e5380c72e"],
 "."
}], "Text",ExpressionUUID->"e53329f7-7f4d-4b70-9e85-f18c2b4f80fc"],

Cell[BoxData[
 RowBox[{
  RowBox[{"MatrixExp", "[", 
   RowBox[{
    RowBox[{"-", "I"}], " ", 
    RowBox[{"(", 
     RowBox[{"\[Omega]", "/", "2"}], ")"}], " ", 
    RowBox[{
     RowBox[{"FromSphericalCoordinates", "[", 
      RowBox[{"{", 
       RowBox[{"1", ",", " ", "\[Theta]", ",", " ", "\[Phi]"}], "}"}], "]"}], 
     " ", ".", " ", 
     RowBox[{"PauliMatrix", "[", 
      RowBox[{"{", 
       RowBox[{"1", ",", " ", "2", ",", " ", "3"}], "}"}], "]"}]}], " ", 
    "t"}], "]"}], " ", "//", " ", "FullSimplify"}]], "Input",
 CellLabel->"In[2]:= ",ExpressionUUID->"4e8de0b3-c276-4a97-ad73-5fab5ad4f6cd"],

Cell[TextData[{
 "Unitarity is the statement ",
 Cell[BoxData[
  RowBox[{
   StyleBox["U", "TI"], 
   SuperscriptBox[
    StyleBox["U", "TI"], "\[Dagger]"], "=", 
   StyleBox["I", "TI"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "95d10ca5-2803-444f-808e-881846f8c081"],
 "; check it (declare the parameters real)."
}], "Text",ExpressionUUID->"442668ae-27ac-438a-b086-e737e2de1b07"],

Cell[BoxData[
 RowBox[{"With", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"u", " ", "=", " ", 
     RowBox[{"MatrixExp", "[", 
      RowBox[{
       RowBox[{"-", "I"}], " ", 
       RowBox[{"(", 
        RowBox[{"\[Omega]", "/", "2"}], ")"}], " ", 
       RowBox[{
        RowBox[{"FromSphericalCoordinates", "[", 
         RowBox[{"{", 
          RowBox[{"1", ",", " ", "\[Theta]", ",", " ", "\[Phi]"}], "}"}], 
         "]"}], " ", ".", " ", 
        RowBox[{"PauliMatrix", "[", 
         RowBox[{"{", 
          RowBox[{"1", ",", " ", "2", ",", " ", "3"}], "}"}], "]"}]}], " ", 
       "t"}], "]"}]}], "}"}], ",", " ", 
   RowBox[{"FullSimplify", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"u", " ", ".", " ", 
       RowBox[{"ConjugateTranspose", "[", "u", "]"}]}], " ", "==", " ", 
      RowBox[{"IdentityMatrix", "[", "2", "]"}]}], ",", " ", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
       "\[Omega]", ",", " ", "t", ",", " ", "\[Theta]", ",", " ", "\[Phi]"}], 
       "}"}], " ", "\[Element]", " ", "Reals"}]}], "]"}]}], "]"}]], "Input",
 CellLabel->"In[3]:= ",ExpressionUUID->"99123ee4-c716-4e0a-ad95-07a87ece0509"],

Cell[TextData[{
 StyleBox["QF",
  FontWeight->"Bold"],
 " : the same propagator kept as a ",
 Cell[BoxData["QuantumOperator"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "829dfb6b-1732-4d26-88c3-4bdfd51179e1"],
 ", an object that acts on states and composes, not a bare matrix."
}], "Text",ExpressionUUID->"85f07e02-8311-4bbd-91f4-ea56c71d1e2c"],

Cell[BoxData[
 RowBox[{"QuantumOperator", "[", 
  RowBox[{"MatrixExp", "[", 
   RowBox[{
    RowBox[{"-", "I"}], " ", 
    RowBox[{"(", 
     RowBox[{"\[Omega]", "/", "2"}], ")"}], " ", 
    RowBox[{
     RowBox[{"FromSphericalCoordinates", "[", 
      RowBox[{"{", 
       RowBox[{"1", ",", " ", "\[Theta]", ",", " ", "\[Phi]"}], "}"}], "]"}], 
     " ", ".", " ", 
     RowBox[{"PauliMatrix", "[", 
      RowBox[{"{", 
       RowBox[{"1", ",", " ", "2", ",", " ", "3"}], "}"}], "]"}]}], " ", 
    "t"}], "]"}], "]"}]], "Input",
 CellLabel->"In[4]:= ",ExpressionUUID->"534d1c2f-242b-486a-8f6b-337529559c1c"],

Cell[TextData[{
 "Its unitarity reads back at the operator level: ",
 Cell[BoxData[
  RowBox[{
   SuperscriptBox[
    StyleBox["U", "TI"], "\[Dagger]"], 
   StyleBox["U", "TI"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "b4e94511-1722-4df7-b357-11cf27f737ee"],
 " reduces to the identity operator."
}], "Text",ExpressionUUID->"72949c4a-356d-4213-9c2e-4a1f24638533"],

Cell[BoxData[
 RowBox[{"With", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"u", " ", "=", " ", 
     RowBox[{"QuantumOperator", "[", 
      RowBox[{"MatrixExp", "[", 
       RowBox[{
        RowBox[{"-", "I"}], " ", 
        RowBox[{"(", 
         RowBox[{"\[Omega]", "/", "2"}], ")"}], " ", 
        RowBox[{
         RowBox[{"FromSphericalCoordinates", "[", 
          RowBox[{"{", 
           RowBox[{"1", ",", " ", "\[Theta]", ",", " ", "\[Phi]"}], "}"}], 
          "]"}], " ", ".", " ", 
         RowBox[{"PauliMatrix", "[", 
          RowBox[{"{", 
           RowBox[{"1", ",", " ", "2", ",", " ", "3"}], "}"}], "]"}]}], " ", 
        "t"}], "]"}], "]"}]}], "}"}], ",", " ", 
   RowBox[{"FullSimplify", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"Normal", "[", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{
          RowBox[{"u", "[", "\"\<Dagger\>\"", "]"}], " ", "@", " ", "u"}], 
         ")"}], "[", "\"\<Matrix\>\"", "]"}], "]"}], " ", "==", " ", 
      RowBox[{"IdentityMatrix", "[", "2", "]"}]}], ",", " ", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
       "\[Omega]", ",", " ", "t", ",", " ", "\[Theta]", ",", " ", "\[Phi]"}], 
       "}"}], " ", "\[Element]", " ", "Reals"}]}], "]"}]}], "]"}]], "Input",
 CellLabel->"In[5]:= ",ExpressionUUID->"cb5a8716-4e43-43d7-a59a-6fea38280cd7"],

Cell[TextData[{
 "Both build the same propagator ",
 Cell[BoxData[
  RowBox[{
   StyleBox["U", "TI"], 
   StyleBox["(",
    SpanMaxSize->1], 
   StyleBox["t", "TI"], 
   StyleBox[")",
    SpanMaxSize->1], "=", 
   StyleBox["cos",
    FontSlant->"Plain"], "\[ThinSpace]", 
   FractionBox[
    StyleBox[
     RowBox[{"\[Omega]", "t"}], "TI"], "2"], " ", 
   StyleBox["I", "TI"], "-", 
   StyleBox["i", "TI"], 
   StyleBox["sin",
    FontSlant->"Plain"], "\[ThinSpace]", 
   FractionBox[
    StyleBox[
     RowBox[{"\[Omega]", "t"}], "TI"], "2"], " ", 
   OverscriptBox[
    StyleBox["n", "TI"], "^"], "\[CenterDot]", 
   OverscriptBox[
    StyleBox["\[Sigma]", "TI"], "\[RightVector]"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "4093b8d3-c2ed-48ff-a1ef-ce5f2b57332a"],
 ", the rotation by angle ",
 Cell[BoxData[
  StyleBox[
   RowBox[{"\[Omega]", "t"}], "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "a50a693f-7259-41a9-944f-d793d101ccd0"],
 " about the axis ",
 Cell[BoxData[
  OverscriptBox[
   StyleBox["n", "TI"], "^"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "157b3b00-57b0-4465-b7ef-5b9dabd8746f"],
 ", and both confirm it is unitary: the two eigenstates of ",
 Cell[BoxData[
  RowBox[{
   OverscriptBox[
    StyleBox["n", "TI"], "^"], "\[CenterDot]", 
   OverscriptBox[
    StyleBox["\[Sigma]", "TI"], "\[RightVector]"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "a8210879-a4a6-42d1-82b9-8071586a5585"],
 " accumulate opposite phases ",
 Cell[BoxData[
  SuperscriptBox[
   StyleBox["e", "TI"], 
   RowBox[{"\[MinusPlus]", 
    StyleBox["i", "TI"], 
    StyleBox["\[Omega]", "TI"], 
    StyleBox["t", "TI"], "/", "2"}]]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "3a37c76b-b736-4836-81c5-9cd85586aa38"],
 " set by their energies ",
 Cell[BoxData[
  RowBox[{"\[MinusPlus]", 
   FractionBox[
    StyleBox["\[Omega]", "TI"], "2"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "7fdec4a0-787a-4e09-b25e-8a417aa5b625"],
 ", which along ",
 Cell[BoxData[
  StyleBox["z", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "39780724-7bb4-4b7c-8323-bfbfc6ef5615"],
 " (",
 Cell[BoxData[
  RowBox[{
   StyleBox["\[Theta]", "TI"], "=", "0"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "f74780bc-f83a-4c3a-9e99-2473bce92417"],
 ") collapses to the diagonal ",
 Cell[BoxData[
  RowBox[{
   StyleBox["diag",
    FontSlant->"Plain"], 
   StyleBox["(",
    SpanMaxSize->1], 
   RowBox[{
    SuperscriptBox[
     StyleBox["e", "TI"], 
     RowBox[{"-", 
      StyleBox["i", "TI"], 
      StyleBox["\[Omega]", "TI"], 
      StyleBox["t", "TI"], "/", "2"}]], ",", 
    SuperscriptBox[
     StyleBox["e", "TI"], 
     RowBox[{"+", 
      StyleBox["i", "TI"], 
      StyleBox["\[Omega]", "TI"], 
      StyleBox["t", "TI"], "/", "2"}]]}], 
   StyleBox[")",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "d82f97e2-ce0d-4fa1-a456-9e7a7b491583"],
 "."
}], "Text",ExpressionUUID->"dcd1f4c8-fe2d-4677-8862-8eecfe23ef59"],

Cell[TextData[{
 "7.1b [BSc] How do I solve the Schrodinger equation for a time-independent \
Hamiltonian, ",
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     RowBox[{
       StyleBox["\[Psi]", "TI"], 
       StyleBox["(", SpanMaxSize -> 1], 
       StyleBox["t", "TI"], 
       StyleBox[")", SpanMaxSize -> 1]}]},
    "Ket"], "=", 
   RowBox[{
    SuperscriptBox[
     StyleBox["e", "TI"], 
     RowBox[{"-", 
      StyleBox["i", "TI"], 
      OverscriptBox[
       StyleBox["H", "TI"], "^"], 
      StyleBox["t", "TI"]}]], 
    TemplateBox[{
      SubscriptBox[
       StyleBox["\[Psi]", "TI"], "0"]},
     "Ket"]}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "b00b3f6b-fe26-481a-ac25-ea082f281ac1"],
 "?"
}], "Subsection",ExpressionUUID->"3a50a33b-7703-444c-a9d7-447f465a3042"],

Cell[TextData[{
 "For a ",
 StyleBox["time-independent",
  FontWeight->"Bold"],
 " Hamiltonian ",
 Cell[BoxData[
  OverscriptBox[
   StyleBox["H", "TI"], "^"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "ee003fcf-05c7-4d8b-be7f-f6c0caeb05c6"],
 " (no explicit dependence on ",
 Cell[BoxData[
  StyleBox["t", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "07ce8c74-15c8-4aaf-8df9-dde35ef4f146"],
 "), the Schrodinger equation ",
 Cell[BoxData[
  RowBox[{
   RowBox[{
    StyleBox["i", "TI"], 
    RowBox[{
     SubscriptBox["\[PartialD]", 
      StyleBox["t", "TI"]], 
     TemplateBox[{
       RowBox[{
         StyleBox["\[Psi]", "TI"], 
         StyleBox["(", SpanMaxSize -> 1], 
         StyleBox["t", "TI"], 
         StyleBox[")", SpanMaxSize -> 1]}]},
      "Ket"]}]}], "=", 
   RowBox[{
    OverscriptBox[
     StyleBox["H", "TI"], "^"], 
    TemplateBox[{
      RowBox[{
        StyleBox["\[Psi]", "TI"], 
        StyleBox["(", SpanMaxSize -> 1], 
        StyleBox["t", "TI"], 
        StyleBox[")", SpanMaxSize -> 1]}]},
     "Ket"]}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "c3e4fead-452e-4f19-9d16-6b1beaf945c8"],
 " with ",
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     RowBox[{
       StyleBox["\[Psi]", "TI"], 
       StyleBox["(", SpanMaxSize -> 1], "0", 
       StyleBox[")", SpanMaxSize -> 1]}]},
    "Ket"], "=", 
   TemplateBox[{
     SubscriptBox[
      StyleBox["\[Psi]", "TI"], "0"]},
    "Ket"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "764b4a5e-398b-43de-a09d-975798b2192c"],
 " is solved by the constant-",
 Cell[BoxData[
  OverscriptBox[
   StyleBox["H", "TI"], "^"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "dd12e5b2-275b-4529-bcb6-316c9b9cdb38"],
 " propagator of 7.1a, ",
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     RowBox[{
       StyleBox["\[Psi]", "TI"], 
       StyleBox["(", SpanMaxSize -> 1], 
       StyleBox["t", "TI"], 
       StyleBox[")", SpanMaxSize -> 1]}]},
    "Ket"], "=", 
   RowBox[{
    SuperscriptBox[
     StyleBox["e", "TI"], 
     RowBox[{"-", 
      StyleBox["i", "TI"], 
      OverscriptBox[
       StyleBox["H", "TI"], "^"], 
      StyleBox["t", "TI"]}]], 
    TemplateBox[{
      SubscriptBox[
       StyleBox["\[Psi]", "TI"], "0"]},
     "Ket"]}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "ae2b0082-080a-4bc5-9e6c-b6eac8779a13"],
 "; a time-dependent ",
 Cell[BoxData[
  RowBox[{
   OverscriptBox[
    StyleBox["H", "TI"], "^"], 
   StyleBox["(",
    SpanMaxSize->1], 
   StyleBox["t", "TI"], 
   StyleBox[")",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "e8ece4e0-ad8f-4f9b-85d1-bfd72d147e72"],
 " would instead require the time-ordered exponential. Take the generic ",
 Cell[BoxData[
  RowBox[{
   OverscriptBox[
    StyleBox["H", "TI"], "^"], "=", 
   FractionBox[
    StyleBox["\[Omega]", "TI"], "2"], " ", 
   OverscriptBox[
    StyleBox["n", "TI"], "^"], "\[CenterDot]", 
   OverscriptBox[
    StyleBox["\[Sigma]", "TI"], "\[RightVector]"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "05a2f542-2acf-4eb0-a6d1-fc9310f595e1"],
 " along the fixed axis ",
 Cell[BoxData[
  RowBox[{
   OverscriptBox[
    StyleBox["n", "TI"], "^"], "=", 
   RowBox[{
    StyleBox["(",
     SpanMaxSize->1], 
    RowBox[{
     RowBox[{
      StyleBox["sin",
       FontSlant->"Plain"], "\[ThinSpace]", 
      SubscriptBox[
       StyleBox["\[Theta]", "TI"], 
       StyleBox["H", "TI"]], 
      StyleBox["cos",
       FontSlant->"Plain"], "\[ThinSpace]", 
      SubscriptBox[
       StyleBox["\[Phi]", "TI"], 
       StyleBox["H", "TI"]]}], ",", " ", 
     RowBox[{
      StyleBox["sin",
       FontSlant->"Plain"], "\[ThinSpace]", 
      SubscriptBox[
       StyleBox["\[Theta]", "TI"], 
       StyleBox["H", "TI"]], 
      StyleBox["sin",
       FontSlant->"Plain"], "\[ThinSpace]", 
      SubscriptBox[
       StyleBox["\[Phi]", "TI"], 
       StyleBox["H", "TI"]]}], ",", " ", 
     RowBox[{
      StyleBox["cos",
       FontSlant->"Plain"], "\[ThinSpace]", 
      SubscriptBox[
       StyleBox["\[Theta]", "TI"], 
       StyleBox["H", "TI"]]}]}], 
    StyleBox[")",
     SpanMaxSize->1]}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "ca18e17a-7563-4da8-a191-e15c8208cadf"],
 " and a general pure initial qubit ",
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     SubscriptBox[
      StyleBox["\[Psi]", "TI"], "0"]},
    "Ket"], "=", "{", 
   StyleBox["cos",
    FontSlant->"Plain"], 
   FractionBox[
    StyleBox["\[Theta]", "TI"], "2"], ",", 
   SuperscriptBox[
    StyleBox["e", "TI"], 
    RowBox[{
     StyleBox["i", "TI"], "\[CurlyPhi]"}]], 
   StyleBox["sin",
    FontSlant->"Plain"], 
   FractionBox[
    StyleBox["\[Theta]", "TI"], "2"], "}"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "a59993d9-2406-487f-9454-170d48af384b"],
 "."
}], "Text",ExpressionUUID->"8a07efe2-b540-4287-9d0e-65b60d3b72f8"],

Cell[TextData[{
 StyleBox["WL",
  FontWeight->"Bold"],
 " : the solution is the propagator of 7.1a acting on ",
 Cell[BoxData[
  TemplateBox[{
    SubscriptBox[
     StyleBox["\[Psi]", "TI"], "0"]},
   "Ket"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "67a393bd-9a44-4543-aca3-d99b48c7b256"],
 "; ",
 Cell[BoxData["MatrixExp"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "6d7627d8-fba3-461d-ad6e-836912d396e5"],
 " applies ",
 Cell[BoxData[
  SuperscriptBox[
   StyleBox["e", "TI"], 
   RowBox[{"-", 
    StyleBox["i", "TI"], 
    OverscriptBox[
     StyleBox["H", "TI"], "^"], 
    StyleBox["t", "TI"]}]]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "7b8e8baa-acb5-4849-a121-893a207d6803"],
 " straight to the initial vector through its two-argument form ",
 Cell[BoxData[
  RowBox[{
   StyleBox["MatrixExp",
    FontSlant->"Plain"], 
   StyleBox["[",
    SpanMaxSize->1], 
   RowBox[{
    StyleBox["m", "TI"], ",", 
    StyleBox["v", "TI"]}], 
   StyleBox["]",
    SpanMaxSize->1], "=", 
   SuperscriptBox[
    StyleBox["e", "TI"], 
    StyleBox["m", "TI"]], 
   StyleBox["v", "TI"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "8b79a421-572c-4d8a-be1b-b8bd14ec780f"],
 "."
}], "Text",ExpressionUUID->"6f750621-c662-4f3f-95fd-b7df0e52e75a"],

Cell[BoxData[
 RowBox[{"psit", " ", "=", " ", 
  RowBox[{
   RowBox[{"MatrixExp", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"-", "I"}], " ", 
      RowBox[{"(", 
       RowBox[{"\[Omega]", "/", "2"}], ")"}], " ", 
      RowBox[{
       RowBox[{"FromSphericalCoordinates", "[", 
        RowBox[{"{", 
         RowBox[{"1", ",", " ", "\[Theta]H", ",", " ", "\[Phi]H"}], "}"}], 
        "]"}], " ", ".", " ", 
       RowBox[{"PauliMatrix", "[", 
        RowBox[{"{", 
         RowBox[{"1", ",", " ", "2", ",", " ", "3"}], "}"}], "]"}]}], " ", 
      "t"}], ",", " ", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"Cos", "[", 
        RowBox[{"\[Theta]", "/", "2"}], "]"}], ",", " ", 
       RowBox[{
        RowBox[{"Exp", "[", 
         RowBox[{"I", " ", "\[Phi]"}], "]"}], " ", 
        RowBox[{"Sin", "[", 
         RowBox[{"\[Theta]", "/", "2"}], "]"}]}]}], "}"}]}], "]"}], " ", "//",
    " ", "FullSimplify"}]}]], "Input",
 CellLabel->"In[6]:= ",ExpressionUUID->"7912801c-0ee9-42fc-8195-38e179329498"],

Cell[TextData[{
 "The same state also follows from integrating the Schrodinger ODE from \
scratch with ",
 Cell[BoxData["DSolveValue"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "5930a50e-1f9f-4061-8fee-a6a12dc1a646"],
 ", taking the unknown as a 2-vector ",
 Cell[BoxData[
  RowBox[{"vec", "[", "t", "]"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "700e63b2-b84c-4a99-b08c-a07c9fc802ba"],
 "."
}], "Text",ExpressionUUID->"eca2a431-6216-4095-b4f1-2b690ee98e26"],

Cell[BoxData[
 RowBox[{"sch", " ", "=", " ", 
  RowBox[{
   RowBox[{"DSolveValue", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{
        RowBox[{"I", " ", 
         RowBox[{"D", "[", 
          RowBox[{
           RowBox[{"vec", "[", "t", "]"}], ",", " ", "t"}], "]"}]}], " ", "==",
         " ", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{"\[Omega]", "/", "2"}], ")"}], " ", 
         RowBox[{
          RowBox[{"FromSphericalCoordinates", "[", 
           RowBox[{"{", 
            RowBox[{"1", ",", " ", "\[Theta]H", ",", " ", "\[Phi]H"}], "}"}], 
           "]"}], " ", ".", " ", 
          RowBox[{"PauliMatrix", "[", 
           RowBox[{"{", 
            RowBox[{"1", ",", " ", "2", ",", " ", "3"}], "}"}], "]"}], " ", ".",
           " ", 
          RowBox[{"vec", "[", "t", "]"}]}]}]}], ",", " ", 
       RowBox[{
        RowBox[{"vec", "[", "0", "]"}], " ", "==", " ", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"Cos", "[", 
           RowBox[{"\[Theta]", "/", "2"}], "]"}], ",", " ", 
          RowBox[{
           RowBox[{"Exp", "[", 
            RowBox[{"I", " ", "\[Phi]"}], "]"}], " ", 
           RowBox[{"Sin", "[", 
            RowBox[{"\[Theta]", "/", "2"}], "]"}]}]}], "}"}]}]}], "}"}], ",", 
     " ", 
     RowBox[{
      RowBox[{"vec", "[", "t", "]"}], " ", "\[Element]", " ", 
      RowBox[{"Vectors", "[", "2", "]"}]}], ",", " ", "t"}], "]"}], " ", "//",
    " ", "FullSimplify"}]}]], "Input",
 CellLabel->"In[7]:= ",ExpressionUUID->"b12265f9-2c18-4ded-822c-2c6355be0246"],

Cell[TextData[{
 StyleBox["QF",
  FontWeight->"Bold"],
 " : ",
 Cell[BoxData["QuantumEvolve"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "c2eff31e-4a6b-471b-ad92-4e7be0721870"],
 " integrates the Schrodinger equation for the state object and returns the \
evolved ",
 Cell[BoxData["QuantumState"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "7a68f441-af91-4457-b44d-8ba2c7254290"],
 " as a function of ",
 Cell[BoxData[
  StyleBox["t", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "09539ccb-fadb-4b0a-982d-03699091541f"],
 "; read its amplitudes."
}], "Text",ExpressionUUID->"89a5a61d-8b62-4bba-bedb-e83c947b0997"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"QuantumEvolve", "[", 
    RowBox[{
     RowBox[{"QuantumOperator", "[", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{"\[Omega]", "/", "2"}], ")"}], " ", 
       RowBox[{
        RowBox[{"FromSphericalCoordinates", "[", 
         RowBox[{"{", 
          RowBox[{"1", ",", " ", "\[Theta]H", ",", " ", "\[Phi]H"}], "}"}], 
         "]"}], " ", ".", " ", 
        RowBox[{"PauliMatrix", "[", 
         RowBox[{"{", 
          RowBox[{"1", ",", " ", "2", ",", " ", "3"}], "}"}], "]"}]}]}], 
      "]"}], ",", " ", 
     RowBox[{"QuantumState", "[", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"Cos", "[", 
         RowBox[{"\[Theta]", "/", "2"}], "]"}], ",", " ", 
        RowBox[{
         RowBox[{"Exp", "[", 
          RowBox[{"I", " ", "\[Phi]"}], "]"}], " ", 
         RowBox[{"Sin", "[", 
          RowBox[{"\[Theta]", "/", "2"}], "]"}]}]}], "}"}], "]"}], ",", " ", 
     "t"}], "]"}], "[", "\"\<StateVector\>\"", "]"}], " ", "//", " ", 
  "Normal"}]], "Input",
 CellLabel->"In[8]:= ",ExpressionUUID->"21819de2-9dc1-47ed-97cc-11512fc793c7"],

Cell["\<\
The direct propagator, the ODE integration, and the QF evolution are the same \
state; confirm all three agree.\
\>", "Text",ExpressionUUID->"10629533-904a-4a8d-861f-0ad84bd49b58"],

Cell[BoxData[
 RowBox[{"FullSimplify", "[", 
  RowBox[{"psit", " ", "==", " ", "sch", " ", "==", " ", 
   RowBox[{"(", 
    RowBox[{
     RowBox[{
      RowBox[{"QuantumEvolve", "[", 
       RowBox[{
        RowBox[{"QuantumOperator", "[", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{"\[Omega]", "/", "2"}], ")"}], " ", 
          RowBox[{
           RowBox[{"FromSphericalCoordinates", "[", 
            RowBox[{"{", 
             RowBox[{"1", ",", " ", "\[Theta]H", ",", " ", "\[Phi]H"}], "}"}],
             "]"}], " ", ".", " ", 
           RowBox[{"PauliMatrix", "[", 
            RowBox[{"{", 
             RowBox[{"1", ",", " ", "2", ",", " ", "3"}], "}"}], "]"}]}]}], 
         "]"}], ",", " ", 
        RowBox[{"QuantumState", "[", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{"Cos", "[", 
            RowBox[{"\[Theta]", "/", "2"}], "]"}], ",", " ", 
           RowBox[{
            RowBox[{"Exp", "[", 
             RowBox[{"I", " ", "\[Phi]"}], "]"}], " ", 
            RowBox[{"Sin", "[", 
             RowBox[{"\[Theta]", "/", "2"}], "]"}]}]}], "}"}], "]"}], ",", 
        " ", "t"}], "]"}], "[", "\"\<StateVector\>\"", "]"}], " ", "//", " ", 
     "Normal"}], ")"}]}], "]"}]], "Input",
 CellLabel->"In[9]:= ",ExpressionUUID->"35115500-6d2c-4b61-b6e3-650919c78336"],

Cell[TextData[{
 "All three return the same evolved state ",
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     RowBox[{
       StyleBox["\[Psi]", "TI"], 
       StyleBox["(", SpanMaxSize -> 1], 
       StyleBox["t", "TI"], 
       StyleBox[")", SpanMaxSize -> 1]}]},
    "Ket"], "=", 
   RowBox[{
    SuperscriptBox[
     StyleBox["e", "TI"], 
     RowBox[{"-", 
      StyleBox["i", "TI"], 
      OverscriptBox[
       StyleBox["H", "TI"], "^"], 
      StyleBox["t", "TI"]}]], 
    TemplateBox[{
      SubscriptBox[
       StyleBox["\[Psi]", "TI"], "0"]},
     "Ket"]}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "0579ba46-7142-4281-b758-dec2bc8935be"],
 ", which precesses the Bloch vector of ",
 Cell[BoxData[
  TemplateBox[{
    SubscriptBox[
     StyleBox["\[Psi]", "TI"], "0"]},
   "Ket"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "6893c80c-c516-41f2-9e99-c349317a06c5"],
 " about the field axis ",
 Cell[BoxData[
  OverscriptBox[
   StyleBox["n", "TI"], "^"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "576cff52-2c2f-4f69-837a-20dab0b4f46a"],
 " at the Bohr frequency ",
 Cell[BoxData[
  StyleBox["\[Omega]", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "3eb04898-4cb1-4616-b1de-940c0f1d4573"],
 ". The computational-basis populations stay frozen only when the field is \
along ",
 Cell[BoxData[
  StyleBox["z", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "11e49a93-f1f1-4390-9832-71a84081e1a8"],
 " (",
 Cell[BoxData[
  RowBox[{
   SubscriptBox[
    StyleBox["\[Theta]", "TI"], 
    StyleBox["H", "TI"]], "=", "0"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "accd6133-7bb3-47b2-aa37-69181624531f"],
 "), where ",
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     RowBox[{
       StyleBox["\[Psi]", "TI"], 
       StyleBox["(", SpanMaxSize -> 1], 
       StyleBox["t", "TI"], 
       StyleBox[")", SpanMaxSize -> 1]}]},
    "Ket"], "=", "{", 
   StyleBox["cos",
    FontSlant->"Plain"], 
   FractionBox[
    StyleBox["\[Theta]", "TI"], "2"], 
   SuperscriptBox[
    StyleBox["e", "TI"], 
    RowBox[{"-", 
     StyleBox["i", "TI"], 
     StyleBox["\[Omega]", "TI"], 
     StyleBox["t", "TI"], "/", "2"}]], ",", 
   SuperscriptBox[
    StyleBox["e", "TI"], 
    RowBox[{
     StyleBox["i", "TI"], "\[CurlyPhi]"}]], 
   StyleBox["sin",
    FontSlant->"Plain"], 
   FractionBox[
    StyleBox["\[Theta]", "TI"], "2"], 
   SuperscriptBox[
    StyleBox["e", "TI"], 
    RowBox[{"+", 
     StyleBox["i", "TI"], 
     StyleBox["\[Omega]", "TI"], 
     StyleBox["t", "TI"], "/", "2"}]], "}"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "837ef892-8f70-4947-b9e0-913675f7e46a"],
 " and only the ",
 StyleBox["relative", "TI"],
 " phase advances at ",
 Cell[BoxData[
  StyleBox["\[Omega]", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "931ce4de-0daf-4fee-83eb-105604ae91e7"],
 "; off that axis the populations oscillate."
}], "Text",ExpressionUUID->"cc746d86-e304-41e2-a3bd-0684c328c147"],

Cell["\<\
7.2 [BSc] How do I find stationary states and show they evolve only by a \
phase?\
\>", "Subsection",ExpressionUUID->"aed6d070-8c3a-47a6-af97-01ae5cccda4c"],

Cell[TextData[{
 "A stationary state is an eigenstate of ",
 Cell[BoxData[
  OverscriptBox[
   StyleBox["H", "TI"], "^"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "5d133a9a-232b-436d-a95a-ee1b54bd0eb3"],
 ": if ",
 Cell[BoxData[
  RowBox[{
   RowBox[{
    OverscriptBox[
     StyleBox["H", "TI"], "^"], 
    TemplateBox[{
      StyleBox["E", "TI"]},
     "Ket"]}], "=", 
   RowBox[{
    StyleBox["E", "TI"], 
    TemplateBox[{
      StyleBox["E", "TI"]},
     "Ket"]}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "4d18342e-fe6e-485a-a8ae-2dbbae62f79f"],
 " then ",
 Cell[BoxData[
  RowBox[{
   RowBox[{
    StyleBox["U", "TI"], 
    RowBox[{
     StyleBox["(",
      SpanMaxSize->1], 
     StyleBox["t", "TI"], 
     StyleBox[")",
      SpanMaxSize->1]}], 
    TemplateBox[{
      StyleBox["E", "TI"]},
     "Ket"]}], "=", 
   RowBox[{
    SuperscriptBox[
     StyleBox["e", "TI"], 
     RowBox[{"-", 
      StyleBox["i", "TI"], 
      StyleBox["E", "TI"], 
      StyleBox["t", "TI"]}]], 
    TemplateBox[{
      StyleBox["E", "TI"]},
     "Ket"]}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "d7d3c971-c0f1-4c0b-af35-e78c9f3693a5"],
 ", a pure global phase, so every measurable prediction is time-independent. \
Take a generic single-qubit Hamiltonian ",
 Cell[BoxData[
  RowBox[{
   OverscriptBox[
    StyleBox["H", "TI"], "^"], "=", 
   StyleBox["a", "TI"], " ", 
   StyleBox["Z", "TI"], "+", 
   StyleBox["b", "TI"], " ", 
   StyleBox["X", "TI"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "44a50dc5-960f-47b8-970b-1a5f01c65dee"],
 " (energies ",
 Cell[BoxData[
  RowBox[{"\[PlusMinus]", 
   SqrtBox[
    RowBox[{
     SuperscriptBox[
      StyleBox["a", "TI"], "2"], "+", 
     SuperscriptBox[
      StyleBox["b", "TI"], "2"]}]]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "1dbf4c01-08bc-49fe-85da-6b6dfebdf7b9"],
 "), find an eigenstate, and evolve it."
}], "Text",ExpressionUUID->"43f1d4be-592d-43b3-9afe-7a45bb52d6a0"],

Cell[TextData[{
 StyleBox["WL",
  FontWeight->"Bold"],
 " : diagonalize ",
 Cell[BoxData[
  OverscriptBox[
   StyleBox["H", "TI"], "^"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "c70d4bd4-96b3-4130-b1a4-23d579c442cf"],
 ", then evolve its lower eigenstate; the amplitudes carry one common, \
time-dependent phase factor."
}], "Text",ExpressionUUID->"d0a58b96-0434-41fd-8701-b20d1b4264f0"],

Cell[BoxData[
 RowBox[{"With", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"es", " ", "=", " ", 
     RowBox[{"Eigensystem", "[", 
      RowBox[{
       RowBox[{"a", " ", 
        RowBox[{"PauliMatrix", "[", "3", "]"}]}], " ", "+", " ", 
       RowBox[{"b", " ", 
        RowBox[{"PauliMatrix", "[", "1", "]"}]}]}], "]"}]}], "}"}], ",", " ", 
   
   RowBox[{"With", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"en", " ", "=", " ", 
        RowBox[{"es", "[", 
         RowBox[{"[", 
          RowBox[{"1", ",", " ", "1"}], "]"}], "]"}]}], ",", " ", 
       RowBox[{"v", " ", "=", " ", 
        RowBox[{"Normalize", "[", 
         RowBox[{"es", "[", 
          RowBox[{"[", 
           RowBox[{"2", ",", " ", "1"}], "]"}], "]"}], "]"}]}]}], "}"}], ",", 
     " ", 
     RowBox[{"Simplify", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"MatrixExp", "[", 
         RowBox[{
          RowBox[{"-", "I"}], " ", 
          RowBox[{"(", 
           RowBox[{
            RowBox[{"a", " ", 
             RowBox[{"PauliMatrix", "[", "3", "]"}]}], " ", "+", " ", 
            RowBox[{"b", " ", 
             RowBox[{"PauliMatrix", "[", "1", "]"}]}]}], ")"}], " ", "t"}], 
         "]"}], " ", ".", " ", "v"}], ",", " ", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"a", ",", " ", "b", ",", " ", "t"}], "}"}], " ", "\[Element]",
         " ", "Reals"}]}], "]"}]}], "]"}]}], "]"}]], "Input",
 CellLabel->
  "In[10]:= ",ExpressionUUID->"a98697d0-6778-498d-8e85-4efbef3ebbd0"],

Cell[TextData[{
 StyleBox["QF",
  FontWeight->"Bold"],
 " : ",
 Cell[BoxData["QuantumEvolve"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "fdf644df-d268-478c-8095-a50a06514ac6"],
 " on the same eigenstate returns the state with an overall ",
 Cell[BoxData[
  SuperscriptBox[
   StyleBox["e", "TI"], 
   RowBox[{"-", 
    StyleBox["i", "TI"], 
    StyleBox["E", "TI"], 
    StyleBox["t", "TI"]}]]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "40d9bf9b-4049-4969-801e-60cf701f73b1"],
 "; the outcome probabilities never move."
}], "Text",ExpressionUUID->"5c71df7b-e80e-4be5-8712-6cb30b620e3a"],

Cell[BoxData[
 RowBox[{"With", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"es", " ", "=", " ", 
     RowBox[{
      RowBox[{"QuantumOperator", "[", 
       RowBox[{
        RowBox[{"a", " ", 
         RowBox[{"PauliMatrix", "[", "3", "]"}]}], " ", "+", " ", 
        RowBox[{"b", " ", 
         RowBox[{"PauliMatrix", "[", "1", "]"}]}]}], "]"}], 
      "[", "\"\<Eigensystem\>\"", "]"}]}], "}"}], ",", " ", 
   RowBox[{"Simplify", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"QuantumEvolve", "[", 
       RowBox[{
        RowBox[{"QuantumOperator", "[", 
         RowBox[{
          RowBox[{"a", " ", 
           RowBox[{"PauliMatrix", "[", "3", "]"}]}], " ", "+", " ", 
          RowBox[{"b", " ", 
           RowBox[{"PauliMatrix", "[", "1", "]"}]}]}], "]"}], ",", " ", 
        RowBox[{"QuantumState", "[", 
         RowBox[{"Normalize", "[", 
          RowBox[{"es", "[", 
           RowBox[{"[", 
            RowBox[{"2", ",", " ", "1"}], "]"}], "]"}], "]"}], "]"}], ",", 
        " ", "t"}], "]"}], "[", "\"\<ProbabilitiesList\>\"", "]"}], ",", " ", 
     
     RowBox[{
      RowBox[{"{", 
       RowBox[{"a", ",", " ", "b", ",", " ", "t"}], "}"}], " ", "\[Element]", 
      " ", "Reals"}]}], "]"}]}], "]"}]], "Input",
 CellLabel->
  "In[11]:= ",ExpressionUUID->"d89ca254-7aad-4a75-8efa-d20457e2f744"],

Cell["\<\
The WL evolution multiplies the whole eigenvector by a single phase, and the \
QF probabilities come out constant: a stationary state is stationary \
precisely because the only thing that changes, a global phase, is the one \
thing no measurement can see (Part 1, 1.4).\
\>", "Text",ExpressionUUID->"32e17aa6-2737-45fb-89f4-3b3d8049ef27"],

Cell["\<\
7.3 [BSc] How do I compute Rabi oscillations of a two-level system under a \
resonant classical drive?\
\>", "Subsection",ExpressionUUID->"d3c0b85d-4435-4608-baab-24762f84e1ec"],

Cell[TextData[{
 "A resonant classical drive of Rabi frequency ",
 Cell[BoxData["\[CapitalOmega]"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "94b68f13-aff3-4f0c-b097-6dddd2fcc450"],
 " reduces, in the frame rotating with the drive, to the static transverse \
Hamiltonian ",
 Cell[BoxData[
  RowBox[{
   OverscriptBox[
    StyleBox["H", "TI"], "^"], "=", 
   FractionBox["\[CapitalOmega]", "2"], 
   StyleBox["X", "TI"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "8ccd9eed-e3d2-47c9-9824-5865ea1fe234"],
 "; we take that static form as given here and evolve under it, leaving its \
rotating-frame derivation to the later MSc treatment of the driven problem. \
Starting in ",
 Cell[BoxData[
  TemplateBox[{"0"},
   "Ket"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "a25b3249-fb9d-458c-8a6a-070d71acb425"],
 ", the population sloshes completely to ",
 Cell[BoxData[
  TemplateBox[{"1"},
   "Ket"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "2e46328a-6b44-4da9-b280-d5e2416723e8"],
 " and back: ",
 Cell[BoxData[
  RowBox[{
   SubscriptBox[
    StyleBox["P", "TI"], "1"], 
   StyleBox["(",
    SpanMaxSize->1], 
   StyleBox["t", "TI"], 
   StyleBox[")",
    SpanMaxSize->1], "=", 
   SuperscriptBox[
    StyleBox["sin",
     FontSlant->"Plain"], "2"], "\[ThinSpace]", 
   FractionBox[
    RowBox[{"\[CapitalOmega]", 
     StyleBox["t", "TI"]}], "2"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "90e7d93c-1416-4ace-8062-f7c6ee14d7f5"],
 ". Evolve ",
 Cell[BoxData[
  TemplateBox[{"0"},
   "Ket"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "f6610225-9e04-4f5a-9c6d-bf2ef23f966b"],
 " and read the probabilities."
}], "Text",ExpressionUUID->"17b505fa-b017-4365-9980-22118a712f49"],

Cell[TextData[{
 StyleBox["WL",
  FontWeight->"Bold"],
 " : the evolved amplitudes are ",
 Cell[BoxData[
  RowBox[{
   StyleBox["U", "TI"], 
   RowBox[{
    StyleBox["(",
     SpanMaxSize->1], 
    StyleBox["t", "TI"], 
    StyleBox[")",
     SpanMaxSize->1]}], 
   TemplateBox[{"0"},
    "Ket"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "33b980a5-619c-4943-8dbe-d8a7761104f6"],
 "; the excited population is the modulus-squared of the lower amplitude."
}], "Text",ExpressionUUID->"7b29fac7-9602-48f7-ac22-ea172d1e1e13"],

Cell[BoxData[
 RowBox[{"With", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"\[Psi]", " ", "=", " ", 
     RowBox[{
      RowBox[{"MatrixExp", "[", 
       RowBox[{
        RowBox[{"-", "I"}], " ", 
        RowBox[{"(", 
         RowBox[{"\[CapitalOmega]", "/", "2"}], ")"}], " ", 
        RowBox[{"PauliMatrix", "[", "1", "]"}], " ", "t"}], "]"}], " ", ".", 
      " ", 
      RowBox[{"{", 
       RowBox[{"1", ",", " ", "0"}], "}"}]}]}], "}"}], ",", " ", 
   RowBox[{"Simplify", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"Abs", "[", "\[Psi]", "]"}], "^", "2"}], ",", " ", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"\[CapitalOmega]", ",", " ", "t"}], "}"}], " ", "\[Element]", 
      " ", "Reals"}]}], "]"}]}], "]"}]], "Input",
 CellLabel->
  "In[12]:= ",ExpressionUUID->"715dfb61-6070-47a8-8d5f-43dec054a4a7"],

Cell[TextData[{
 StyleBox["QF",
  FontWeight->"Bold"],
 " : ",
 Cell[BoxData["QuantumEvolve"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "c355ad0e-7ea3-4355-a78d-62aaeb2acd7b"],
 " gives the evolved state object; its ",
 Cell[BoxData["\"\<ProbabilitiesList\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "180f339d-559a-4cdf-adf1-20bb9a2334f0"],
 " is the pair ",
 Cell[BoxData[
  RowBox[{
   RowBox[{"{", 
    SubscriptBox[
     StyleBox["P", "TI"], "0"]}], ",", 
   RowBox[{
    SubscriptBox[
     StyleBox["P", "TI"], "1"], "}"}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "1eb1b9df-f116-4603-9d85-9ab1ff507699"],
 "."
}], "Text",ExpressionUUID->"0d44426c-2dd3-4417-b316-0df17cc679a4"],

Cell[BoxData[
 RowBox[{"Simplify", "[", 
  RowBox[{
   RowBox[{
    RowBox[{"QuantumEvolve", "[", 
     RowBox[{
      RowBox[{"QuantumOperator", "[", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{"\[CapitalOmega]", "/", "2"}], ")"}], " ", 
        RowBox[{"PauliMatrix", "[", "1", "]"}]}], "]"}], ",", " ", 
      RowBox[{"QuantumState", "[", "\"\<0\>\"", "]"}], ",", " ", "t"}], "]"}],
     "[", "\"\<ProbabilitiesList\>\"", "]"}], ",", " ", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"\[CapitalOmega]", ",", " ", "t"}], "}"}], " ", "\[Element]", 
    " ", "Reals"}]}], "]"}]], "Input",
 CellLabel->
  "In[13]:= ",ExpressionUUID->"d9458e78-cb49-4bf6-a435-ef89bce19202"],

Cell[TextData[{
 "Both give ",
 Cell[BoxData[
  RowBox[{
   RowBox[{"{", 
    SuperscriptBox[
     StyleBox["cos",
      FontSlant->"Plain"], "2"], "\[ThinSpace]", 
    FractionBox[
     RowBox[{"\[CapitalOmega]", 
      StyleBox["t", "TI"]}], "2"]}], ",", 
   RowBox[{
    SuperscriptBox[
     StyleBox["sin",
      FontSlant->"Plain"], "2"], "\[ThinSpace]", 
    FractionBox[
     RowBox[{"\[CapitalOmega]", 
      StyleBox["t", "TI"]}], "2"], "}"}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "5ba91d2e-3600-46a3-a14e-1c279deec696"],
 ": the qubit oscillates fully between the two levels at the Rabi frequency \
",
 Cell[BoxData["\[CapitalOmega]"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "b69d9fa4-778a-424c-b93e-ec63eea087dc"],
 ", reaching the excited state at ",
 Cell[BoxData[
  RowBox[{
   StyleBox["t", "TI"], "=", "\[Pi]", "/", "\[CapitalOmega]"}]], 
  "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "5b81c435-55b9-486b-b53a-b685aed58bb9"],
 " (a ",
 Cell[BoxData["\[Pi]"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "9f45d20f-8f21-4961-a9b9-892eccf1b3af"],
 "-pulse)."
}], "Text",ExpressionUUID->"1de04021-5a13-4e26-8550-3259f3bb067e"],

Cell["\<\
7.4 [BSc] How do I compute the Larmor precession of a spin in a static \
magnetic field?\
\>", "Subsection",ExpressionUUID->"d889e2e5-3ada-4cdb-90e8-18bcd8d71a4c"],

Cell[TextData[{
 "A spin in a field along ",
 Cell[BoxData[
  StyleBox["z", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "d2904721-f7b7-400d-8d41-b5b60467febc"],
 " has ",
 Cell[BoxData[
  RowBox[{
   OverscriptBox[
    StyleBox["H", "TI"], "^"], "=", 
   FractionBox[
    StyleBox["\[Omega]", "TI"], "2"], 
   StyleBox["Z", "TI"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "efc1fa1c-40c0-4862-a27a-9b43925320a5"],
 ". A spin prepared in the equatorial state ",
 Cell[BoxData[
  TemplateBox[{"+"},
   "Ket"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "382dee70-3c22-4e8a-ad19-fece838b5f29"],
 " keeps ",
 Cell[BoxData[
  RowBox[{
   StyleBox["\[LeftAngleBracket]",
    SpanMaxSize->1], 
   StyleBox["Z", "TI"], "\[VeryThinSpace]", 
   StyleBox["\[RightAngleBracket]",
    SpanMaxSize->1], "=", "0"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "f02932c9-cf0e-4767-bfc7-7d78db2ecb92"],
 " while its transverse Bloch components rotate: ",
 Cell[BoxData[
  RowBox[{
   StyleBox["\[LeftAngleBracket]",
    SpanMaxSize->1], 
   StyleBox["X", "TI"], "\[VeryThinSpace]", 
   StyleBox["\[RightAngleBracket]",
    SpanMaxSize->1], "=", 
   StyleBox["cos",
    FontSlant->"Plain"], "\[ThinSpace]", 
   StyleBox["\[Omega]", "TI"], 
   StyleBox["t", "TI"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "aebba1da-b849-4309-a834-a80d50d2031a"],
 ", ",
 Cell[BoxData[
  RowBox[{
   StyleBox["\[LeftAngleBracket]",
    SpanMaxSize->1], 
   StyleBox["Y", "TI"], "\[VeryThinSpace]", 
   StyleBox["\[RightAngleBracket]",
    SpanMaxSize->1], "=", 
   StyleBox["sin",
    FontSlant->"Plain"], "\[ThinSpace]", 
   StyleBox["\[Omega]", "TI"], 
   StyleBox["t", "TI"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "da8cf768-87f9-4b65-a857-a9bf645d0a8d"],
 ". The Bloch vector precesses about the field at the Larmor frequency ",
 Cell[BoxData[
  StyleBox["\[Omega]", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "301dea97-782b-484c-a53e-7f57dcb99dd5"],
 "."
}], "Text",ExpressionUUID->"b91a0947-952c-46da-9a58-c64a0f9c96a1"],

Cell[TextData[{
 StyleBox["WL",
  FontWeight->"Bold"],
 " : evolve ",
 Cell[BoxData[
  TemplateBox[{"+"},
   "Ket"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "cfcc0345-6971-433d-9fcb-a228af5af3f7"],
 ", form the density matrix, and read the three Pauli expectation values."
}], "Text",ExpressionUUID->"b54d3511-cb4a-4202-9ae2-99420b3b56d8"],

Cell[BoxData[
 RowBox[{"With", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"\[Psi]", " ", "=", " ", 
     RowBox[{"MatrixExp", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"-", "I"}], " ", 
        RowBox[{"(", 
         RowBox[{"\[Omega]", "/", "2"}], ")"}], " ", 
        RowBox[{"PauliMatrix", "[", "3", "]"}], " ", "t"}], ",", " ", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"1", ",", " ", "1"}], "}"}], "/", 
        RowBox[{"Sqrt", "[", "2", "]"}]}]}], "]"}]}], "}"}], ",", " ", 
   RowBox[{"Simplify", "[", 
    RowBox[{
     RowBox[{"ComplexExpand", "[", 
      RowBox[{"Table", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"Conjugate", "[", "\[Psi]", "]"}], " ", ".", " ", 
         RowBox[{"PauliMatrix", "[", "k", "]"}], " ", ".", " ", "\[Psi]"}], ",",
         " ", 
        RowBox[{"{", 
         RowBox[{"k", ",", " ", "3"}], "}"}]}], "]"}], "]"}], ",", " ", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"\[Omega]", ",", " ", "t"}], "}"}], " ", "\[Element]", " ", 
      "Reals"}]}], "]"}]}], "]"}]], "Input",
 CellLabel->
  "In[14]:= ",ExpressionUUID->"a0cc0368-e7f4-4920-8923-113fc71ba2df"],

Cell[TextData[{
 StyleBox["QF",
  FontWeight->"Bold"],
 " : evolve the named ",
 Cell[BoxData["\"\<Plus\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "f86d5333-6a2b-4946-baf4-efa6d5763c54"],
 " state and take the expectation of each Pauli operator through a ",
 Cell[BoxData["QuantumMeasurementOperator"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "d37f8a5e-68ca-4f9d-ab5c-6d9f363a0389"],
 "."
}], "Text",ExpressionUUID->"cee70c33-742b-4d8f-9c3b-a136e493ac6c"],

Cell[BoxData[
 RowBox[{"With", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"qs", " ", "=", " ", 
     RowBox[{"QuantumEvolve", "[", 
      RowBox[{
       RowBox[{"QuantumOperator", "[", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{"\[Omega]", "/", "2"}], ")"}], " ", 
         RowBox[{"PauliMatrix", "[", "3", "]"}]}], "]"}], ",", " ", 
       RowBox[{"QuantumState", "[", "\"\<Plus\>\"", "]"}], ",", " ", "t"}], 
      "]"}]}], "}"}], ",", " ", 
   RowBox[{"Simplify", "[", 
    RowBox[{
     RowBox[{"ExpToTrig", "[", 
      RowBox[{"ComplexExpand", "[", 
       RowBox[{"Table", "[", 
        RowBox[{
         RowBox[{
          RowBox[{
           RowBox[{"QuantumMeasurementOperator", "[", 
            RowBox[{"QuantumOperator", "[", 
             RowBox[{"PauliMatrix", "[", "k", "]"}], "]"}], "]"}], "[", "qs", 
           "]"}], "[", "\"\<Mean\>\"", "]"}], ",", " ", 
         RowBox[{"{", 
          RowBox[{"k", ",", " ", "3"}], "}"}]}], "]"}], "]"}], "]"}], ",", 
     " ", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"\[Omega]", ",", " ", "t"}], "}"}], " ", "\[Element]", " ", 
      "Reals"}]}], "]"}]}], "]"}]], "Input",
 CellLabel->
  "In[15]:= ",ExpressionUUID->"0a770830-7705-45f3-86ce-31e470888f69"],

Cell[TextData[{
 "Both return the Bloch vector ",
 Cell[BoxData[
  RowBox[{
   RowBox[{"{", 
    StyleBox["cos",
     FontSlant->"Plain"], "\[ThinSpace]", 
    StyleBox["\[Omega]", "TI"], 
    StyleBox["t", "TI"]}], ",", 
   RowBox[{
    StyleBox["sin",
     FontSlant->"Plain"], "\[ThinSpace]", 
    StyleBox["\[Omega]", "TI"], 
    StyleBox["t", "TI"]}], ",", 
   RowBox[{"0", "}"}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "543ef881-92f2-4c36-8fd4-767d2ed3eae7"],
 ": a unit vector sweeping the equator at angular velocity ",
 Cell[BoxData[
  StyleBox["\[Omega]", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "e774ee40-301a-4317-b4e1-a536ed2e73f5"],
 ", the quantum image of a classical magnetic moment precessing about the \
field."
}], "Text",ExpressionUUID->"4f4deac7-4572-4401-9902-9fa5bce66029"],

Cell[TextData[{
 "7.5a [BSc] How do I evolve an observable in the Heisenberg picture, ",
 Cell[BoxData[
  RowBox[{
   SubscriptBox[
    StyleBox["A", "TI"], 
    StyleBox["H", "TI"]], 
   StyleBox["(",
    SpanMaxSize->1], 
   StyleBox["t", "TI"], 
   StyleBox[")",
    SpanMaxSize->1], "=", 
   SuperscriptBox[
    StyleBox["U", "TI"], "\[Dagger]"], 
   StyleBox["(",
    SpanMaxSize->1], 
   StyleBox["t", "TI"], 
   StyleBox[")",
    SpanMaxSize->1], " ", 
   StyleBox["A", "TI"], " ", 
   StyleBox["U", "TI"], 
   StyleBox["(",
    SpanMaxSize->1], 
   StyleBox["t", "TI"], 
   StyleBox[")",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "05a291d2-b7a2-4f6b-a535-9b0f6b2b2497"],
 "?"
}], "Subsection",ExpressionUUID->"5cf7a408-e981-40c4-a892-7cd3c2569dee"],

Cell[TextData[{
 "In the Heisenberg picture the state is frozen and the operators carry the \
time dependence, ",
 Cell[BoxData[
  RowBox[{
   SubscriptBox[
    StyleBox["A", "TI"], 
    StyleBox["H", "TI"]], 
   StyleBox["(",
    SpanMaxSize->1], 
   StyleBox["t", "TI"], 
   StyleBox[")",
    SpanMaxSize->1], "=", 
   SuperscriptBox[
    StyleBox["U", "TI"], "\[Dagger]"], 
   StyleBox["(",
    SpanMaxSize->1], 
   StyleBox["t", "TI"], 
   StyleBox[")",
    SpanMaxSize->1], " ", 
   StyleBox["A", "TI"], " ", 
   StyleBox["U", "TI"], 
   StyleBox["(",
    SpanMaxSize->1], 
   StyleBox["t", "TI"], 
   StyleBox[")",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "95e95897-b770-4bf2-b87a-950036ca804e"],
 ". For ",
 Cell[BoxData[
  RowBox[{
   OverscriptBox[
    StyleBox["H", "TI"], "^"], "=", 
   FractionBox[
    StyleBox["\[Omega]", "TI"], "2"], 
   StyleBox["Z", "TI"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "34616026-19a6-490f-a4f3-b36ce7d9ad16"],
 " the observable ",
 Cell[BoxData[
  StyleBox["X", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "bbcb1bfc-61b9-423b-a7e6-e1dfaa9e6c69"],
 " rotates into a combination of ",
 Cell[BoxData[
  StyleBox["X", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "22301020-3965-4fff-9d8c-e24f49f049ae"],
 " and ",
 Cell[BoxData[
  StyleBox["Y", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "ff5abcc8-1fb2-4a16-8f03-8dfc8e8cac5d"],
 ": ",
 Cell[BoxData[
  RowBox[{
   SubscriptBox[
    StyleBox["X", "TI"], 
    StyleBox["H", "TI"]], 
   StyleBox["(",
    SpanMaxSize->1], 
   StyleBox["t", "TI"], 
   StyleBox[")",
    SpanMaxSize->1], "=", 
   StyleBox["cos",
    FontSlant->"Plain"], "\[ThinSpace]", 
   StyleBox["(",
    SpanMaxSize->1], 
   StyleBox[
    RowBox[{"\[Omega]", "t"}], "TI"], 
   StyleBox[")",
    SpanMaxSize->1], " ", 
   StyleBox["X", "TI"], "-", 
   StyleBox["sin",
    FontSlant->"Plain"], "\[ThinSpace]", 
   StyleBox["(",
    SpanMaxSize->1], 
   StyleBox[
    RowBox[{"\[Omega]", "t"}], "TI"], 
   StyleBox[")",
    SpanMaxSize->1], " ", 
   StyleBox["Y", "TI"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "b47fdda7-ff22-4b73-ac70-3cfcc651f159"],
 "."
}], "Text",ExpressionUUID->"abb285a0-a974-4761-9f87-e220a7274b90"],

Cell[TextData[{
 StyleBox["WL",
  FontWeight->"Bold"],
 " : conjugate the matrix of ",
 Cell[BoxData[
  StyleBox["X", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "8facd298-091f-4a85-9f75-95a44937b1a5"],
 " by the propagator."
}], "Text",ExpressionUUID->"07dffa0a-332a-4ba2-84c7-9c7e9f9480fe"],

Cell[BoxData[
 RowBox[{"With", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"u", " ", "=", " ", 
     RowBox[{"MatrixExp", "[", 
      RowBox[{
       RowBox[{"-", "I"}], " ", 
       RowBox[{"(", 
        RowBox[{"\[Omega]", "/", "2"}], ")"}], " ", 
       RowBox[{"PauliMatrix", "[", "3", "]"}], " ", "t"}], "]"}]}], "}"}], ",",
    " ", 
   RowBox[{"Simplify", "[", 
    RowBox[{
     RowBox[{"ComplexExpand", "[", 
      RowBox[{
       RowBox[{"ConjugateTranspose", "[", "u", "]"}], " ", ".", " ", 
       RowBox[{"PauliMatrix", "[", "1", "]"}], " ", ".", " ", "u"}], "]"}], ",",
      " ", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"\[Omega]", ",", " ", "t"}], "}"}], " ", "\[Element]", " ", 
      "Reals"}]}], "]"}]}], "]"}]], "Input",
 CellLabel->
  "In[16]:= ",ExpressionUUID->"022bf6d2-1632-48a8-824b-633e2c3ffbd9"],

Cell[TextData[{
 StyleBox["QF",
  FontWeight->"Bold"],
 " : the same conjugation at the operator level, ",
 Cell[BoxData[
  RowBox[{
   SuperscriptBox[
    StyleBox["U", "TI"], "\[Dagger]"], " ", 
   StyleBox["X", "TI"], " ", 
   StyleBox["U", "TI"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "e70b022e-45a1-4fc4-986f-3dacc30f4b22"],
 ", keeping ",
 Cell[BoxData[
  StyleBox["U", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "3fae6d37-038e-4fa4-967d-9069d0fafd51"],
 " and ",
 Cell[BoxData[
  StyleBox["X", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "d3812499-422a-42d0-a28b-71c7157a015a"],
 " as ",
 Cell[BoxData["QuantumOperator"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "c77851f8-684f-4bf0-8865-948a732b8a83"],
 "s and composing with ",
 Cell[BoxData["@"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "2b004569-86d4-4b8f-8992-3cfc282039e2"],
 "."
}], "Text",ExpressionUUID->"d134d70b-dcf7-41f0-a736-13c2286a4bc2"],

Cell[BoxData[
 RowBox[{"With", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"u", " ", "=", " ", 
     RowBox[{"QuantumOperator", "[", 
      RowBox[{"MatrixExp", "[", 
       RowBox[{
        RowBox[{"-", "I"}], " ", 
        RowBox[{"(", 
         RowBox[{"\[Omega]", "/", "2"}], ")"}], " ", 
        RowBox[{"PauliMatrix", "[", "3", "]"}], " ", "t"}], "]"}], "]"}]}], 
    "}"}], ",", " ", 
   RowBox[{"Simplify", "[", 
    RowBox[{
     RowBox[{"ComplexExpand", "[", 
      RowBox[{"Normal", "[", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{
          RowBox[{"u", "[", "\"\<Dagger\>\"", "]"}], " ", "@", " ", 
          RowBox[{
           RowBox[{"QuantumOperator", "[", "\"\<X\>\"", "]"}], " ", "@", " ", 
           "u"}]}], ")"}], "[", "\"\<Matrix\>\"", "]"}], "]"}], "]"}], ",", 
     " ", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"\[Omega]", ",", " ", "t"}], "}"}], " ", "\[Element]", " ", 
      "Reals"}]}], "]"}]}], "]"}]], "Input",
 CellLabel->
  "In[17]:= ",ExpressionUUID->"8d624edb-b72d-4075-a119-6e4f482f5da5"],

Cell[TextData[{
 "Both return the matrix of ",
 Cell[BoxData[
  RowBox[{
   StyleBox["cos",
    FontSlant->"Plain"], "\[ThinSpace]", 
   StyleBox["(",
    SpanMaxSize->1], 
   StyleBox[
    RowBox[{"\[Omega]", "t"}], "TI"], 
   StyleBox[")",
    SpanMaxSize->1], " ", 
   StyleBox["X", "TI"], "-", 
   StyleBox["sin",
    FontSlant->"Plain"], "\[ThinSpace]", 
   StyleBox["(",
    SpanMaxSize->1], 
   StyleBox[
    RowBox[{"\[Omega]", "t"}], "TI"], 
   StyleBox[")",
    SpanMaxSize->1], " ", 
   StyleBox["Y", "TI"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "278352fa-b0bf-4ee4-a4d2-b825e3d719e1"],
 ": the Heisenberg observable precesses in the opposite sense to the Larmor \
state (7.4), which is why the Schrodinger and Heisenberg pictures agree on \
every expectation value."
}], "Text",ExpressionUUID->"fd604f2e-004a-44c9-a59a-400cc645142e"],

Cell[TextData[{
 "7.5b [BSc] How do I check Ehrenfest's theorem, ",
 Cell[BoxData[
  RowBox[{
   FractionBox[
    StyleBox["d", "TI"], 
    StyleBox[
     RowBox[{"d", "t"}], "TI"]], 
   StyleBox["\[LeftAngleBracket]",
    SpanMaxSize->1], 
   StyleBox["A", "TI"], "\[VeryThinSpace]", 
   StyleBox["\[RightAngleBracket]",
    SpanMaxSize->1], "=", 
   StyleBox["i", "TI"], 
   StyleBox["\[LeftAngleBracket]",
    SpanMaxSize->1], 
   RowBox[{
    StyleBox["[",
     SpanMaxSize->1], 
    RowBox[{
     OverscriptBox[
      StyleBox["H", "TI"], "^"], ",", 
     StyleBox["A", "TI"]}], 
    StyleBox["]",
     SpanMaxSize->1]}], 
   StyleBox["\[RightAngleBracket]",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "080c14c2-7efb-41ec-9c71-a8a93f545d4c"],
 ", for a time-independent observable?"
}], "Subsection",ExpressionUUID->"f0355494-685e-4c71-b50f-c04724022d45"],

Cell[TextData[{
 "Ehrenfest's theorem is the equation of motion for expectation values: for \
an observable ",
 Cell[BoxData[
  StyleBox["A", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "52167851-941c-4b5b-9f9e-2a934e6cd7fb"],
 " with no explicit time dependence, ",
 Cell[BoxData[
  RowBox[{
   FractionBox[
    StyleBox["d", "TI"], 
    StyleBox[
     RowBox[{"d", "t"}], "TI"]], 
   StyleBox["\[LeftAngleBracket]",
    SpanMaxSize->1], 
   StyleBox["A", "TI"], "\[VeryThinSpace]", 
   StyleBox["\[RightAngleBracket]",
    SpanMaxSize->1], "=", 
   StyleBox["i", "TI"], 
   StyleBox["\[LeftAngleBracket]",
    SpanMaxSize->1], 
   RowBox[{
    StyleBox["[",
     SpanMaxSize->1], 
    RowBox[{
     OverscriptBox[
      StyleBox["H", "TI"], "^"], ",", 
     StyleBox["A", "TI"]}], 
    StyleBox["]",
     SpanMaxSize->1]}], 
   StyleBox["\[RightAngleBracket]",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "63351fb7-d6ea-4583-9533-c917cff0c824"],
 ". Verify it on a general pure qubit evolving under ",
 Cell[BoxData[
  RowBox[{
   OverscriptBox[
    StyleBox["H", "TI"], "^"], "=", 
   FractionBox[
    StyleBox["\[Omega]", "TI"], "2"], 
   StyleBox["Z", "TI"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "82ef9ce6-aed3-4f33-8da8-1380ebb4d18f"],
 ", with ",
 Cell[BoxData[
  RowBox[{
   StyleBox["A", "TI"], "=", 
   StyleBox["X", "TI"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "be885139-5859-4cc8-a828-1b721c4361ef"],
 "."
}], "Text",ExpressionUUID->"8d3a29d4-64ac-4541-880b-ab0d6249fb61"],

Cell[TextData[{
 StyleBox["WL",
  FontWeight->"Bold"],
 " : evolve ",
 Cell[BoxData[
  RowBox[{
   RowBox[{"{", 
    StyleBox["cos",
     FontSlant->"Plain"], "\[ThinSpace]", 
    FractionBox[
     StyleBox["\[Theta]", "TI"], "2"]}], ",", 
   RowBox[{
    SuperscriptBox[
     StyleBox["e", "TI"], 
     RowBox[{
      StyleBox["i", "TI"], "\[CurlyPhi]"}]], 
    StyleBox["sin",
     FontSlant->"Plain"], "\[ThinSpace]", 
    FractionBox[
     StyleBox["\[Theta]", "TI"], "2"], "}"}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "39a9f6e1-d92e-4c2b-a093-36ab75a3aaf8"],
 ", then compare the time derivative of ",
 Cell[BoxData[
  RowBox[{
   StyleBox["\[LeftAngleBracket]",
    SpanMaxSize->1], 
   StyleBox["X", "TI"], "\[VeryThinSpace]", 
   StyleBox["\[RightAngleBracket]",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "2a46489d-8220-478b-947c-ab7eeba0d7d0"],
 " with the expectation of ",
 Cell[BoxData[
  RowBox[{
   StyleBox["i", "TI"], 
   StyleBox["[",
    SpanMaxSize->1], 
   RowBox[{
    OverscriptBox[
     StyleBox["H", "TI"], "^"], ",", 
    StyleBox["X", "TI"]}], 
   StyleBox["]",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "57f37e22-c730-4f7f-8420-fd37d0efa4db"],
 "."
}], "Text",ExpressionUUID->"1717fd68-3b76-4917-86ca-098297b6d56a"],

Cell[BoxData[
 RowBox[{"With", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{"h", " ", "=", " ", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{"\[Omega]", "/", "2"}], ")"}], " ", 
       RowBox[{"PauliMatrix", "[", "3", "]"}]}]}], ",", " ", 
     RowBox[{"\[Psi]", " ", "=", " ", 
      RowBox[{
       RowBox[{"MatrixExp", "[", 
        RowBox[{
         RowBox[{"-", "I"}], " ", 
         RowBox[{"(", 
          RowBox[{"\[Omega]", "/", "2"}], ")"}], " ", 
         RowBox[{"PauliMatrix", "[", "3", "]"}], " ", "t"}], "]"}], " ", ".", 
       " ", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"Cos", "[", 
          RowBox[{"\[Theta]", "/", "2"}], "]"}], ",", " ", 
         RowBox[{
          RowBox[{"Exp", "[", 
           RowBox[{"I", " ", "\[Phi]"}], "]"}], " ", 
          RowBox[{"Sin", "[", 
           RowBox[{"\[Theta]", "/", "2"}], "]"}]}]}], "}"}]}]}]}], "}"}], ",",
    " ", 
   RowBox[{"With", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"ev", " ", "=", " ", 
       RowBox[{
        RowBox[{"Simplify", "[", 
         RowBox[{
          RowBox[{"ComplexExpand", "[", 
           RowBox[{
            RowBox[{"Conjugate", "[", "\[Psi]", "]"}], " ", ".", " ", "#", 
            " ", ".", " ", "\[Psi]"}], "]"}], ",", " ", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{
            "\[Omega]", ",", " ", "t", ",", " ", "\[Theta]", ",", " ", 
             "\[Phi]"}], "}"}], " ", "\[Element]", " ", "Reals"}]}], "]"}], 
        " ", "&"}]}], "}"}], ",", " ", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"D", "[", 
        RowBox[{
         RowBox[{"ev", "[", 
          RowBox[{"PauliMatrix", "[", "1", "]"}], "]"}], ",", " ", "t"}], 
        "]"}], ",", " ", 
       RowBox[{"ev", "[", 
        RowBox[{"I", " ", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{"h", " ", ".", " ", 
            RowBox[{"PauliMatrix", "[", "1", "]"}]}], " ", "-", " ", 
           RowBox[{
            RowBox[{"PauliMatrix", "[", "1", "]"}], " ", ".", " ", "h"}]}], 
          ")"}]}], "]"}]}], "}"}]}], "]"}]}], "]"}]], "Input",
 CellLabel->
  "In[18]:= ",ExpressionUUID->"a98de276-58b5-40bd-abe6-9ad647bb1467"],

Cell["The two entries should be equal; confirm.", "Text",ExpressionUUID->"43175855-2ebf-4a84-b38f-237947890b62"],

Cell[BoxData[
 RowBox[{"With", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{"h", " ", "=", " ", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{"\[Omega]", "/", "2"}], ")"}], " ", 
       RowBox[{"PauliMatrix", "[", "3", "]"}]}]}], ",", " ", 
     RowBox[{"\[Psi]", " ", "=", " ", 
      RowBox[{
       RowBox[{"MatrixExp", "[", 
        RowBox[{
         RowBox[{"-", "I"}], " ", 
         RowBox[{"(", 
          RowBox[{"\[Omega]", "/", "2"}], ")"}], " ", 
         RowBox[{"PauliMatrix", "[", "3", "]"}], " ", "t"}], "]"}], " ", ".", 
       " ", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"Cos", "[", 
          RowBox[{"\[Theta]", "/", "2"}], "]"}], ",", " ", 
         RowBox[{
          RowBox[{"Exp", "[", 
           RowBox[{"I", " ", "\[Phi]"}], "]"}], " ", 
          RowBox[{"Sin", "[", 
           RowBox[{"\[Theta]", "/", "2"}], "]"}]}]}], "}"}]}]}]}], "}"}], ",",
    " ", 
   RowBox[{"With", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"ev", " ", "=", " ", 
       RowBox[{
        RowBox[{"Simplify", "[", 
         RowBox[{
          RowBox[{"ComplexExpand", "[", 
           RowBox[{
            RowBox[{"Conjugate", "[", "\[Psi]", "]"}], " ", ".", " ", "#", 
            " ", ".", " ", "\[Psi]"}], "]"}], ",", " ", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{
            "\[Omega]", ",", " ", "t", ",", " ", "\[Theta]", ",", " ", 
             "\[Phi]"}], "}"}], " ", "\[Element]", " ", "Reals"}]}], "]"}], 
        " ", "&"}]}], "}"}], ",", " ", 
     RowBox[{"Simplify", "[", 
      RowBox[{
       RowBox[{"D", "[", 
        RowBox[{
         RowBox[{"ev", "[", 
          RowBox[{"PauliMatrix", "[", "1", "]"}], "]"}], ",", " ", "t"}], 
        "]"}], " ", "==", " ", 
       RowBox[{"ev", "[", 
        RowBox[{"I", " ", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{"h", " ", ".", " ", 
            RowBox[{"PauliMatrix", "[", "1", "]"}]}], " ", "-", " ", 
           RowBox[{
            RowBox[{"PauliMatrix", "[", "1", "]"}], " ", ".", " ", "h"}]}], 
          ")"}]}], "]"}]}], "]"}]}], "]"}]}], "]"}]], "Input",
 CellLabel->
  "In[19]:= ",ExpressionUUID->"583f3464-3900-4d85-93b0-606708f5653f"],

Cell[TextData[{
 StyleBox["QF",
  FontWeight->"Bold"],
 " : the right-hand side through the paclet's ",
 Cell[BoxData["Commutator"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "0624c1a3-55af-4e97-ad0c-5c38ed783fbe"],
 ", which reduces the operator product ",
 Cell[BoxData[
  RowBox[{
   StyleBox["[",
    SpanMaxSize->1], 
   RowBox[{
    OverscriptBox[
     StyleBox["H", "TI"], "^"], ",", 
    StyleBox["X", "TI"]}], 
   StyleBox["]",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "ad311067-6f50-4b8b-aea3-f3191f31e7aa"],
 " to a single ",
 Cell[BoxData["QuantumOperator"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "c91a8a65-d74b-4f20-a31c-b1c7864e18b4"],
 "; its expectation matches the derivative."
}], "Text",ExpressionUUID->"a21966c0-0772-43e0-b490-f522f002be03"],

Cell[BoxData[
 RowBox[{"With", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{"h", " ", "=", " ", 
      RowBox[{"QuantumOperator", "[", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{"\[Omega]", "/", "2"}], ")"}], " ", 
        RowBox[{"PauliMatrix", "[", "3", "]"}]}], "]"}]}], ",", " ", 
     RowBox[{"qs", " ", "=", " ", 
      RowBox[{"QuantumEvolve", "[", 
       RowBox[{
        RowBox[{"QuantumOperator", "[", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{"\[Omega]", "/", "2"}], ")"}], " ", 
          RowBox[{"PauliMatrix", "[", "3", "]"}]}], "]"}], ",", " ", 
        RowBox[{"QuantumState", "[", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{"Cos", "[", 
            RowBox[{"\[Theta]", "/", "2"}], "]"}], ",", " ", 
           RowBox[{
            RowBox[{"Exp", "[", 
             RowBox[{"I", " ", "\[Phi]"}], "]"}], " ", 
            RowBox[{"Sin", "[", 
             RowBox[{"\[Theta]", "/", "2"}], "]"}]}]}], "}"}], "]"}], ",", 
        " ", "t"}], "]"}]}]}], "}"}], ",", " ", 
   RowBox[{"Simplify", "[", 
    RowBox[{
     RowBox[{"ComplexExpand", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"QuantumMeasurementOperator", "[", 
         RowBox[{"I", " ", 
          RowBox[{"Commutator", "[", 
           RowBox[{"h", ",", " ", 
            RowBox[{"QuantumOperator", "[", "\"\<X\>\"", "]"}]}], "]"}]}], 
         "]"}], "[", "qs", "]"}], "[", "\"\<Mean\>\"", "]"}], "]"}], ",", " ", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
       "\[Omega]", ",", " ", "t", ",", " ", "\[Theta]", ",", " ", "\[Phi]"}], 
       "}"}], " ", "\[Element]", " ", "Reals"}]}], "]"}]}], "]"}]], "Input",
 CellLabel->
  "In[20]:= ",ExpressionUUID->"eeb8c23b-bf58-49c1-ad8b-2a3d8843bb0b"],

Cell[TextData[{
 "The derivative of ",
 Cell[BoxData[
  RowBox[{
   StyleBox["\[LeftAngleBracket]",
    SpanMaxSize->1], 
   StyleBox["X", "TI"], "\[VeryThinSpace]", 
   StyleBox["\[RightAngleBracket]",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "65a6e864-3fb8-4280-82bf-b9f293b6164c"],
 " equals ",
 Cell[BoxData[
  RowBox[{
   StyleBox["i", "TI"], 
   StyleBox["\[LeftAngleBracket]",
    SpanMaxSize->1], 
   RowBox[{
    StyleBox["[",
     SpanMaxSize->1], 
    RowBox[{
     OverscriptBox[
      StyleBox["H", "TI"], "^"], ",", 
     StyleBox["X", "TI"]}], 
    StyleBox["]",
     SpanMaxSize->1]}], 
   StyleBox["\[RightAngleBracket]",
    SpanMaxSize->1], "=", "-", 
   StyleBox["\[Omega]", "TI"], 
   StyleBox["\[LeftAngleBracket]",
    SpanMaxSize->1], 
   StyleBox["Y", "TI"], "\[VeryThinSpace]", 
   StyleBox["\[RightAngleBracket]",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "b183079f-98b5-4bd4-bfa8-b2ed9f78d23d"],
 ": the transverse components chase each other exactly as classical \
precession would, the content of Ehrenfest's theorem for a spin."
}], "Text",ExpressionUUID->"e74a35fe-1b3b-43f3-87ad-86e0a16ee2f9"],

Cell["\<\
7.6 [MSc] How do I transform between the Schrodinger, Heisenberg, and \
interaction pictures and show they agree on expectation values?\
\>", "Subsection",ExpressionUUID->"2b3fd4dc-1c75-41f2-a552-4fcd1410ed7c"],

Cell[TextData[{
 "The three pictures move the time dependence between state and operator but \
leave every expectation value invariant. Schrodinger evolves the state, ",
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     RowBox[{
       StyleBox["\[Psi]", "TI"], 
       StyleBox["(", SpanMaxSize -> 1], 
       StyleBox["t", "TI"], 
       StyleBox[")", SpanMaxSize -> 1]}]},
    "Bra"], 
   StyleBox["A", "TI"], 
   TemplateBox[{
     RowBox[{
       StyleBox["\[Psi]", "TI"], 
       StyleBox["(", SpanMaxSize -> 1], 
       StyleBox["t", "TI"], 
       StyleBox[")", SpanMaxSize -> 1]}]},
    "Ket"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "ebff892d-f246-4a0e-9d23-7ba36abd7593"],
 "; Heisenberg evolves the operator, ",
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     SubscriptBox[
      StyleBox["\[Psi]", "TI"], "0"]},
    "Bra"], 
   SubscriptBox[
    StyleBox["A", "TI"], 
    StyleBox["H", "TI"]], 
   RowBox[{
    StyleBox["(",
     SpanMaxSize->1], 
    StyleBox["t", "TI"], 
    StyleBox[")",
     SpanMaxSize->1]}], 
   TemplateBox[{
     SubscriptBox[
      StyleBox["\[Psi]", "TI"], "0"]},
    "Ket"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "f1c27081-b3ac-4907-9830-5e169639f303"],
 " with ",
 Cell[BoxData[
  RowBox[{
   SubscriptBox[
    StyleBox["A", "TI"], 
    StyleBox["H", "TI"]], "=", 
   SuperscriptBox[
    StyleBox["U", "TI"], "\[Dagger]"], 
   StyleBox["A", "TI"], 
   StyleBox["U", "TI"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "875e7502-920f-40b8-8eaa-a5db4c9b48e7"],
 "; the interaction picture splits ",
 Cell[BoxData[
  RowBox[{
   OverscriptBox[
    StyleBox["H", "TI"], "^"], "=", 
   SubscriptBox[
    OverscriptBox[
     StyleBox["H", "TI"], "^"], "0"], "+", 
   OverscriptBox[
    StyleBox["V", "TI"], "^"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "4c5601f9-335a-4a2e-8f8d-9547e7495f19"],
 " and evolves the state by ",
 Cell[BoxData[
  OverscriptBox[
   StyleBox["V", "TI"], "^"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "0c5236ea-b002-4b5b-aa63-c2c1217d623b"],
 " and the operator by ",
 Cell[BoxData[
  SubscriptBox[
   OverscriptBox[
    StyleBox["H", "TI"], "^"], "0"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "3c903b58-b1cd-4ce6-b184-8766c829a27b"],
 ". Take ",
 Cell[BoxData[
  RowBox[{
   SubscriptBox[
    OverscriptBox[
     StyleBox["H", "TI"], "^"], "0"], "=", 
   FractionBox[
    StyleBox["\[Omega]", "TI"], "2"], 
   StyleBox["Z", "TI"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "2dbf4c82-31c0-43c5-ac9a-4ada814b0aa1"],
 ", ",
 Cell[BoxData[
  RowBox[{
   OverscriptBox[
    StyleBox["V", "TI"], "^"], "=", 
   FractionBox[
    StyleBox["g", "TI"], "2"], 
   StyleBox["X", "TI"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "73b1dada-8512-435f-8e6d-e14c30f9549b"],
 ", observable ",
 Cell[BoxData[
  RowBox[{
   StyleBox["A", "TI"], "=", 
   StyleBox["Z", "TI"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "6062490d-e554-4273-ad44-7fc6b269e2f1"],
 ", initial state ",
 Cell[BoxData[
  TemplateBox[{"0"},
   "Ket"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "386e07d7-bea9-4980-867e-a98a5548b0d8"],
 ", and compute ",
 Cell[BoxData[
  RowBox[{
   StyleBox["\[LeftAngleBracket]",
    SpanMaxSize->1], 
   StyleBox["Z", "TI"], "\[VeryThinSpace]", 
   StyleBox["\[RightAngleBracket]",
    SpanMaxSize->1], 
   StyleBox["(",
    SpanMaxSize->1], 
   StyleBox["t", "TI"], 
   StyleBox[")",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "97bc9499-3709-4017-9023-73a3893b514e"],
 " three ways."
}], "Text",ExpressionUUID->"73f025c1-7f6f-46e6-9820-0cf4a9c3af0c"],

Cell[TextData[{
 StyleBox["WL",
  FontWeight->"Bold"],
 " : all three expectation values from the one propagator ",
 Cell[BoxData[
  RowBox[{
   StyleBox["U", "TI"], "=", 
   SuperscriptBox[
    StyleBox["e", "TI"], 
    RowBox[{"-", 
     StyleBox["i", "TI"], 
     StyleBox["(",
      SpanMaxSize->1], 
     RowBox[{
      SubscriptBox[
       OverscriptBox[
        StyleBox["H", "TI"], "^"], "0"], "+", 
      OverscriptBox[
       StyleBox["V", "TI"], "^"]}], 
     StyleBox[")",
      SpanMaxSize->1], 
     StyleBox["t", "TI"]}]]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "1f3918cc-d907-4df4-828b-1c7d5f5a840b"],
 ", with ",
 Cell[BoxData[
  RowBox[{
   SubscriptBox[
    StyleBox["U", "TI"], "0"], "=", 
   SuperscriptBox[
    StyleBox["e", "TI"], 
    RowBox[{"-", 
     StyleBox["i", "TI"], 
     SubscriptBox[
      OverscriptBox[
       StyleBox["H", "TI"], "^"], "0"], 
     StyleBox["t", "TI"]}]]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "79e1f249-e168-447f-86ea-110e83c6f18a"],
 " the free part."
}], "Text",ExpressionUUID->"f48adcbb-abe1-4981-b6f8-86b5702d9e14"],

Cell[BoxData[
 RowBox[{"With", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{"h0", " ", "=", " ", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{"\[Omega]", "/", "2"}], ")"}], " ", 
       RowBox[{"PauliMatrix", "[", "3", "]"}]}]}], ",", " ", 
     RowBox[{"v", " ", "=", " ", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{"g", "/", "2"}], ")"}], " ", 
       RowBox[{"PauliMatrix", "[", "1", "]"}]}]}], ",", " ", 
     RowBox[{"a", " ", "=", " ", 
      RowBox[{"PauliMatrix", "[", "3", "]"}]}], ",", " ", 
     RowBox[{"\[Psi]0", " ", "=", " ", 
      RowBox[{"{", 
       RowBox[{"1", ",", " ", "0"}], "}"}]}]}], "}"}], ",", " ", 
   RowBox[{"With", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"u", " ", "=", " ", 
        RowBox[{"MatrixExp", "[", 
         RowBox[{
          RowBox[{"-", "I"}], " ", 
          RowBox[{"(", 
           RowBox[{"h0", " ", "+", " ", "v"}], ")"}], " ", "t"}], "]"}]}], ",",
        " ", 
       RowBox[{"u0", " ", "=", " ", 
        RowBox[{"MatrixExp", "[", 
         RowBox[{
          RowBox[{"-", "I"}], " ", "h0", " ", "t"}], "]"}]}]}], "}"}], ",", 
     " ", 
     RowBox[{"With", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{"\[Psi]S", " ", "=", " ", 
          RowBox[{"u", " ", ".", " ", "\[Psi]0"}]}], ",", " ", 
         RowBox[{"\[Psi]I", " ", "=", " ", 
          RowBox[{
           RowBox[{"ConjugateTranspose", "[", "u0", "]"}], " ", ".", " ", 
           RowBox[{"(", 
            RowBox[{"u", " ", ".", " ", "\[Psi]0"}], ")"}]}]}]}], "}"}], ",", 
       " ", 
       RowBox[{"Simplify", "[", 
        RowBox[{
         RowBox[{"ComplexExpand", "[", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{
             RowBox[{"Conjugate", "[", "\[Psi]S", "]"}], " ", ".", " ", "a", 
             " ", ".", " ", "\[Psi]S"}], ",", " ", 
            RowBox[{
             RowBox[{"Conjugate", "[", "\[Psi]0", "]"}], " ", ".", " ", 
             RowBox[{"(", 
              RowBox[{
               RowBox[{"ConjugateTranspose", "[", "u", "]"}], " ", ".", " ", 
               "a", " ", ".", " ", "u"}], ")"}], " ", ".", " ", "\[Psi]0"}], ",",
             " ", 
            RowBox[{
             RowBox[{"Conjugate", "[", "\[Psi]I", "]"}], " ", ".", " ", 
             RowBox[{"(", 
              RowBox[{
               RowBox[{"ConjugateTranspose", "[", "u0", "]"}], " ", ".", " ", 
               "a", " ", ".", " ", "u0"}], ")"}], " ", ".", " ", 
             "\[Psi]I"}]}], "}"}], "]"}], ",", " ", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{"\[Omega]", ",", " ", "g", ",", " ", "t"}], "}"}], " ", "\[Element]",
           " ", "Reals"}]}], "]"}]}], "]"}]}], "]"}]}], "]"}]], "Input",
 CellLabel->
  "In[21]:= ",ExpressionUUID->"49b41b83-6223-4dfd-99f5-143f8c28f0c4"],

Cell[TextData[{
 StyleBox["QF",
  FontWeight->"Bold"],
 " : the Schrodinger value through ",
 Cell[BoxData["QuantumEvolve"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "2d47b0e4-8cd1-435d-89f4-e0c2bd6f1624"],
 " and a ",
 Cell[BoxData["QuantumMeasurementOperator"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "b7fda187-fe50-4d82-bff2-6543310e40a8"],
 ", to be compared against those three."
}], "Text",ExpressionUUID->"661b36ce-da0b-4ec0-9a58-17757ef0a10b"],

Cell[BoxData[
 RowBox[{"With", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"qs", " ", "=", " ", 
     RowBox[{"QuantumEvolve", "[", 
      RowBox[{
       RowBox[{"QuantumOperator", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"(", 
           RowBox[{"\[Omega]", "/", "2"}], ")"}], " ", 
          RowBox[{"PauliMatrix", "[", "3", "]"}]}], " ", "+", " ", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{"g", "/", "2"}], ")"}], " ", 
          RowBox[{"PauliMatrix", "[", "1", "]"}]}]}], "]"}], ",", " ", 
       RowBox[{"QuantumState", "[", "\"\<0\>\"", "]"}], ",", " ", "t"}], 
      "]"}]}], "}"}], ",", " ", 
   RowBox[{"Simplify", "[", 
    RowBox[{
     RowBox[{"ComplexExpand", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"QuantumMeasurementOperator", "[", 
         RowBox[{"QuantumOperator", "[", "\"\<Z\>\"", "]"}], "]"}], "[", "qs",
         "]"}], "[", "\"\<Mean\>\"", "]"}], "]"}], ",", " ", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"\[Omega]", ",", " ", "g", ",", " ", "t"}], "}"}], " ", "\[Element]",
       " ", "Reals"}]}], "]"}]}], "]"}]], "Input",
 CellLabel->
  "In[22]:= ",ExpressionUUID->"f84e96e2-b00d-412d-9d31-396f06b838a2"],

Cell[TextData[{
 "The WL cell returns the ",
 StyleBox["same", "TI"],
 " number three times, and the QF Schrodinger expectation equals it: the \
picture is a bookkeeping choice for where the clock sits, never a physical \
one, because ",
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     SubscriptBox[
      StyleBox["\[Psi]", "TI"], "0"]},
    "Bra"], 
   SuperscriptBox[
    StyleBox["U", "TI"], "\[Dagger]"], 
   StyleBox["A", "TI"], 
   StyleBox["U", "TI"], 
   TemplateBox[{
     SubscriptBox[
      StyleBox["\[Psi]", "TI"], "0"]},
    "Ket"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "dafe5c9f-6bb5-4bed-99ff-c35f2b02765c"],
 " is one expression however you group the factors."
}], "Text",ExpressionUUID->"b4ee6ce8-ce76-4f03-b1a1-ef23282096d2"],

Cell[TextData[{
 "7.7 [MSc] How do I derive the Mandelstam-Tamm quantum speed limit ",
 Cell[BoxData[
  RowBox[{
   StyleBox["t", "TI"], "\[GreaterEqual]", 
   FractionBox[
    RowBox[{
     StyleBox["arccos",
      FontSlant->"Plain"], GridBox[{
       {
        TemplateBox[{
          SubscriptBox[
           StyleBox["\[Psi]", "TI"], "0"], 
          SubscriptBox[
           StyleBox["\[Psi]", "TI"], 
           StyleBox["t", "TI"]]},
         "BraKet"]}
      },
      GridBoxDividers->{"Columns" -> {True, True}, "Rows" -> {}},
      GridBoxSpacings->{"Columns" -> {{0.15}}}]}], 
    RowBox[{"\[CapitalDelta]", 
     StyleBox["E", "TI"]}]]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "b1be2d56-59b1-4956-9af4-c2759146a9c1"],
 " from the time-energy uncertainty relation?"
}], "Subsection",ExpressionUUID->"c0a93f68-3493-4ee0-9a6b-060ad9822e25"],

Cell[TextData[{
 "The Mandelstam-Tamm bound sets a minimum time for a state to reach a given \
fidelity with its start: the Bures angle ",
 Cell[BoxData[
  RowBox[{
   StyleBox["arccos",
    FontSlant->"Plain"], GridBox[{
     {
      TemplateBox[{
        SubscriptBox[
         StyleBox["\[Psi]", "TI"], "0"], 
        SubscriptBox[
         StyleBox["\[Psi]", "TI"], 
         StyleBox["t", "TI"]]},
       "BraKet"]}
    },
    GridBoxDividers->{"Columns" -> {True, True}, "Rows" -> {}},
    GridBoxSpacings->{"Columns" -> {{0.15}}}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "a0fd30ea-9f26-4c74-ad5a-65fc67487228"],
 " cannot grow faster than the energy spread ",
 Cell[BoxData[
  RowBox[{"\[CapitalDelta]", 
   StyleBox["E", "TI"], "=", 
   SqrtBox[
    RowBox[{
     StyleBox["\[LeftAngleBracket]",
      SpanMaxSize->1], 
     SuperscriptBox[
      OverscriptBox[
       StyleBox["H", "TI"], "^"], "2"], 
     StyleBox["\[RightAngleBracket]",
      SpanMaxSize->1], "-", 
     SuperscriptBox[
      RowBox[{
       StyleBox["\[LeftAngleBracket]",
        SpanMaxSize->1], 
       OverscriptBox[
        StyleBox["H", "TI"], "^"], 
       StyleBox["\[RightAngleBracket]",
        SpanMaxSize->1]}], "2"]}]]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "494a0be7-3195-487d-b1a8-1645b3189cf6"],
 ", so ",
 Cell[BoxData[
  RowBox[{
   StyleBox["t", "TI"], "\[GreaterEqual]", 
   StyleBox["arccos",
    FontSlant->"Plain"], GridBox[{
     {
      TemplateBox[{
        SubscriptBox[
         StyleBox["\[Psi]", "TI"], "0"], 
        SubscriptBox[
         StyleBox["\[Psi]", "TI"], 
         StyleBox["t", "TI"]]},
       "BraKet"]}
    },
    GridBoxDividers->{"Columns" -> {True, True}, "Rows" -> {}},
    GridBoxSpacings->{"Columns" -> {{0.15}}}], "/", "\[CapitalDelta]", 
   StyleBox["E", "TI"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "5afa48e8-23d1-4565-ae6c-6fcbd1416655"],
 " (with ",
 Cell[BoxData[
  RowBox[{"\[HBar]", "=", "1"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "c02d5bab-263c-4136-9838-ffdf48f7f3c2"],
 "). Test it on ",
 Cell[BoxData[
  TemplateBox[{"+"},
   "Ket"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "24e26283-dec8-4d1e-8b18-1f8e7c2d2124"],
 " under ",
 Cell[BoxData[
  RowBox[{
   OverscriptBox[
    StyleBox["H", "TI"], "^"], "=", 
   FractionBox[
    StyleBox["\[Omega]", "TI"], "2"], 
   StyleBox["Z", "TI"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "46dfdc37-bef2-42a5-a62b-d9bc7e914931"],
 ", where ",
 Cell[BoxData[
  RowBox[{"\[CapitalDelta]", 
   StyleBox["E", "TI"], "=", 
   FractionBox[
    StyleBox["\[Omega]", "TI"], "2"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "a4e34fa5-63db-45de-a0c4-48ac47f2d329"],
 " and the overlap is ",
 Cell[BoxData[GridBox[{
    {
     RowBox[{
      StyleBox["cos",
       FontSlant->"Plain"], "\[ThinSpace]", 
      FractionBox[
       StyleBox[
        RowBox[{"\[Omega]", "t"}], "TI"], "2"]}]}
   },
   GridBoxDividers->{"Columns" -> {True, True}, "Rows" -> {}},
   GridBoxSpacings->{"Columns" -> {{0.15}}}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "bbfcc7a1-507e-44f3-9206-4920d2209008"],
 "."
}], "Text",ExpressionUUID->"a55381a6-a6d0-4bf2-acf8-30b44d22522f"],

Cell[TextData[{
 StyleBox["WL",
  FontWeight->"Bold"],
 " : evolve ",
 Cell[BoxData[
  TemplateBox[{"+"},
   "Ket"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "0e3475cb-4e64-43f2-a9e4-441b137bd9d1"],
 ", form the overlap with the start, and build the bound's right-hand side; \
on the first quarter-period it equals the elapsed time."
}], "Text",ExpressionUUID->"c0c2b629-d0a2-423c-8089-901037782f6f"],

Cell[BoxData[
 RowBox[{"With", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{"\[Psi]0", " ", "=", " ", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"1", ",", " ", "1"}], "}"}], "/", 
       RowBox[{"Sqrt", "[", "2", "]"}]}]}], ",", " ", 
     RowBox[{"h", " ", "=", " ", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{"\[Omega]", "/", "2"}], ")"}], " ", 
       RowBox[{"PauliMatrix", "[", "3", "]"}]}]}]}], "}"}], ",", " ", 
   RowBox[{"With", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"\[Psi]t", " ", "=", " ", 
        RowBox[{"MatrixExp", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"-", "I"}], " ", "h", " ", "t"}], ",", " ", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{"1", ",", " ", "1"}], "}"}], "/", 
           RowBox[{"Sqrt", "[", "2", "]"}]}]}], "]"}]}], ",", " ", 
       RowBox[{"\[CapitalDelta]E", " ", "=", " ", 
        RowBox[{"Sqrt", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"Conjugate", "[", 
            RowBox[{
             RowBox[{"{", 
              RowBox[{"1", ",", " ", "1"}], "}"}], "/", 
             RowBox[{"Sqrt", "[", "2", "]"}]}], "]"}], " ", ".", " ", "h", 
           " ", ".", " ", "h", " ", ".", " ", 
           RowBox[{"(", 
            RowBox[{
             RowBox[{"{", 
              RowBox[{"1", ",", " ", "1"}], "}"}], "/", 
             RowBox[{"Sqrt", "[", "2", "]"}]}], ")"}]}], " ", "-", " ", 
          RowBox[{
           RowBox[{"(", 
            RowBox[{
             RowBox[{"Conjugate", "[", 
              RowBox[{
               RowBox[{"{", 
                RowBox[{"1", ",", " ", "1"}], "}"}], "/", 
               RowBox[{"Sqrt", "[", "2", "]"}]}], "]"}], " ", ".", " ", "h", 
             " ", ".", " ", 
             RowBox[{"(", 
              RowBox[{
               RowBox[{"{", 
                RowBox[{"1", ",", " ", "1"}], "}"}], "/", 
               RowBox[{"Sqrt", "[", "2", "]"}]}], ")"}]}], ")"}], "^", 
           "2"}]}], "]"}]}]}], "}"}], ",", " ", 
     RowBox[{"With", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"ov", " ", "=", " ", 
         RowBox[{"Simplify", "[", 
          RowBox[{"ComplexExpand", "[", 
           RowBox[{
            RowBox[{"Conjugate", "[", "\[Psi]0", "]"}], " ", ".", " ", 
            "\[Psi]t"}], "]"}], "]"}]}], "}"}], ",", " ", 
       RowBox[{"Simplify", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"ArcCos", "[", 
           RowBox[{"Abs", "[", "ov", "]"}], "]"}], "/", "\[CapitalDelta]E"}], 
         ",", " ", 
         RowBox[{
          RowBox[{"0", " ", "<", " ", 
           RowBox[{"\[Omega]", " ", "t"}], " ", "<", " ", "Pi"}], " ", "&&", 
          " ", 
          RowBox[{"\[Omega]", " ", ">", " ", "0"}]}]}], "]"}]}], "]"}]}], 
    "]"}]}], "]"}]], "Input",
 CellLabel->
  "In[23]:= ",ExpressionUUID->"8093e022-aff0-41a2-b95f-cdeb062131dc"],

Cell[TextData[{
 StyleBox["QF",
  FontWeight->"Bold"],
 " : the same overlap from the evolved ",
 Cell[BoxData["QuantumState"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "bfb99b9d-d84f-4495-a79f-350543d3d3f0"],
 " and the paclet's ",
 Cell[BoxData["QuantumDistance"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "88d86a77-133c-4f7a-a4d8-d904a9305afc"],
 " ",
 Cell[BoxData["\"\<Fidelity\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "1c0e0cdf-7d12-442f-b64b-31c1da173a1d"],
 "; the Bures angle is ",
 Cell[BoxData[
  RowBox[{
   StyleBox["arccos",
    FontSlant->"Plain"], "\[ThinSpace]", 
   SqrtBox[
    StyleBox["F", "TI"]]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "2045c765-2751-4c42-aa1e-f2006aadbc6d"],
 "."
}], "Text",ExpressionUUID->"e827f755-5f4b-42eb-b292-c293f2e99599"],

Cell[BoxData[
 RowBox[{"With", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{"h", " ", "=", " ", 
      RowBox[{"QuantumOperator", "[", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{"\[Omega]", "/", "2"}], ")"}], " ", 
        RowBox[{"PauliMatrix", "[", "3", "]"}]}], "]"}]}], ",", " ", 
     RowBox[{"qs0", " ", "=", " ", 
      RowBox[{"QuantumState", "[", "\"\<Plus\>\"", "]"}]}]}], "}"}], ",", " ", 
   RowBox[{"With", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"qst", " ", "=", " ", 
        RowBox[{"QuantumEvolve", "[", 
         RowBox[{
          RowBox[{"QuantumOperator", "[", 
           RowBox[{
            RowBox[{"(", 
             RowBox[{"\[Omega]", "/", "2"}], ")"}], " ", 
            RowBox[{"PauliMatrix", "[", "3", "]"}]}], "]"}], ",", " ", 
          RowBox[{"QuantumState", "[", "\"\<Plus\>\"", "]"}], ",", " ", "t"}],
          "]"}]}], ",", " ", 
       RowBox[{"\[CapitalDelta]E", " ", "=", " ", 
        RowBox[{"Sqrt", "[", 
         RowBox[{
          RowBox[{
           RowBox[{
            RowBox[{"QuantumMeasurementOperator", "[", 
             RowBox[{
              RowBox[{"QuantumOperator", "[", 
               RowBox[{
                RowBox[{"(", 
                 RowBox[{"\[Omega]", "/", "2"}], ")"}], " ", 
                RowBox[{"PauliMatrix", "[", "3", "]"}]}], "]"}], " ", "@", 
              " ", 
              RowBox[{"QuantumOperator", "[", 
               RowBox[{
                RowBox[{"(", 
                 RowBox[{"\[Omega]", "/", "2"}], ")"}], " ", 
                RowBox[{"PauliMatrix", "[", "3", "]"}]}], "]"}]}], "]"}], "[", 
            RowBox[{"QuantumState", "[", "\"\<Plus\>\"", "]"}], "]"}], 
           "[", "\"\<Mean\>\"", "]"}], " ", "-", " ", 
          RowBox[{
           RowBox[{
            RowBox[{
             RowBox[{"QuantumMeasurementOperator", "[", 
              RowBox[{"QuantumOperator", "[", 
               RowBox[{
                RowBox[{"(", 
                 RowBox[{"\[Omega]", "/", "2"}], ")"}], " ", 
                RowBox[{"PauliMatrix", "[", "3", "]"}]}], "]"}], "]"}], "[", 
             RowBox[{"QuantumState", "[", "\"\<Plus\>\"", "]"}], "]"}], 
            "[", "\"\<Mean\>\"", "]"}], "^", "2"}]}], "]"}]}]}], "}"}], ",", 
     " ", 
     RowBox[{"With", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"ov", " ", "=", " ", 
         RowBox[{"Simplify", "[", 
          RowBox[{"ComplexExpand", "[", 
           RowBox[{
            RowBox[{"(", 
             RowBox[{
              RowBox[{"qs0", "[", "\"\<Dagger\>\"", "]"}], " ", "@", " ", 
              "qst"}], ")"}], "[", "\"\<Scalar\>\"", "]"}], "]"}], "]"}]}], 
        "}"}], ",", " ", 
       RowBox[{"Simplify", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"ArcCos", "[", 
           RowBox[{"Abs", "[", "ov", "]"}], "]"}], "/", "\[CapitalDelta]E"}], 
         ",", " ", 
         RowBox[{
          RowBox[{"0", " ", "<", " ", 
           RowBox[{"\[Omega]", " ", "t"}], " ", "<", " ", "Pi"}], " ", "&&", 
          " ", 
          RowBox[{"\[Omega]", " ", ">", " ", "0"}]}]}], "]"}]}], "]"}]}], 
    "]"}]}], "]"}]], "Input",
 CellLabel->
  "In[24]:= ",ExpressionUUID->"bbb41ef9-5efb-4b1d-a486-33610208d256"],

Cell[TextData[{
 "Both collapse the right-hand side to exactly ",
 Cell[BoxData[
  StyleBox["t", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "6507d7df-9f5f-4f8e-bea9-3706ec70fd61"],
 " on the first quarter-period: this state saturates the Mandelstam-Tamm \
bound, evolving as fast as its energy uncertainty allows, so the \"speed \
limit\" is attained, not merely respected."
}], "Text",ExpressionUUID->"7ad0f49c-05cd-4432-b4ac-0aa006d7873e"],

Cell["\<\
7.8 [MSc] How do I solve a classically driven two-level system in the \
rotating frame (the Rabi problem)?\
\>", "Subsection",ExpressionUUID->"e4f34b5c-b0ac-4f04-b45c-e431efe571c8"],

Cell[TextData[{
 "A two-level atom driven by a classical field has ",
 Cell[BoxData[
  RowBox[{
   OverscriptBox[
    StyleBox["H", "TI"], "^"], 
   StyleBox["(",
    SpanMaxSize->1], 
   StyleBox["t", "TI"], 
   StyleBox[")",
    SpanMaxSize->1], "=", 
   FractionBox[
    SubscriptBox[
     StyleBox["\[Omega]", "TI"], "0"], "2"], 
   StyleBox["Z", "TI"], "+", "\[CapitalOmega]", 
   StyleBox["cos",
    FontSlant->"Plain"], "\[ThinSpace]", 
   StyleBox["(",
    SpanMaxSize->1], 
   RowBox[{
    SubscriptBox[
     StyleBox["\[Omega]", "TI"], 
     StyleBox["d", "TI"]], 
    StyleBox["t", "TI"]}], 
   StyleBox[")",
    SpanMaxSize->1], 
   StyleBox["X", "TI"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "c701b62c-f7d3-49a8-8b26-84ea61275c1f"],
 ". Moving to the frame rotating at the drive frequency, ",
 Cell[BoxData[
  RowBox[{
   StyleBox["R", "TI"], 
   StyleBox["(",
    SpanMaxSize->1], 
   StyleBox["t", "TI"], 
   StyleBox[")",
    SpanMaxSize->1], "=", 
   SuperscriptBox[
    StyleBox["e", "TI"], 
    RowBox[{
     StyleBox["i", "TI"], 
     SubscriptBox[
      StyleBox["\[Omega]", "TI"], 
      StyleBox["d", "TI"]], 
     StyleBox["t", "TI"], " ", 
     StyleBox["Z", "TI"], "/", "2"}]]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "6c9c234c-d737-491e-a671-b5450fad16ca"],
 ", and dropping the fast counter-rotating terms (the rotating-wave \
approximation) turns this into the ",
 StyleBox["static", "TI"],
 " Hamiltonian ",
 Cell[BoxData[
  RowBox[{
   SubscriptBox[
    OverscriptBox[
     StyleBox["H", "TI"], "^"], 
    StyleBox["rot",
     FontSlant->"Plain"]], "=", 
   FractionBox["\[CapitalDelta]", "2"], 
   StyleBox["Z", "TI"], "+", 
   FractionBox["\[CapitalOmega]", "2"], 
   StyleBox["X", "TI"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "e477cbd3-7745-4462-b8ed-b64c4f16a8f2"],
 " with detuning ",
 Cell[BoxData[
  RowBox[{"\[CapitalDelta]", "=", 
   SubscriptBox[
    StyleBox["\[Omega]", "TI"], "0"], "-", 
   SubscriptBox[
    StyleBox["\[Omega]", "TI"], 
    StyleBox["d", "TI"]]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "c97a2683-c5f7-4c64-95fa-198eedf1a344"],
 ". On resonance (",
 Cell[BoxData[
  RowBox[{"\[CapitalDelta]", "=", "0"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "9f4c496c-ff33-4184-a8ee-d726cd5b225b"],
 ") it is the Rabi drive of 7.3."
}], "Text",ExpressionUUID->"fab8c774-95f8-43a9-8ab1-975e5af36deb"],

Cell[TextData[{
 StyleBox["WL",
  FontWeight->"Bold"],
 " : form the rotating-frame Hamiltonian ",
 Cell[BoxData[
  RowBox[{
   StyleBox["R", "TI"], 
   OverscriptBox[
    StyleBox["H", "TI"], "^"], 
   SuperscriptBox[
    StyleBox["R", "TI"], "\[Dagger]"], "-", 
   FractionBox[
    SubscriptBox[
     StyleBox["\[Omega]", "TI"], 
     StyleBox["d", "TI"]], "2"], 
   StyleBox["Z", "TI"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "fa90a819-8911-44e7-9161-4f3c4fcf0650"],
 ", expand the trigonometry, and keep the slow (non-oscillating) part."
}], "Text",ExpressionUUID->"5a1f7d1b-e2f1-4115-a918-6bdb54585acf"],

Cell[BoxData[
 RowBox[{"With", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{"r", " ", "=", " ", 
      RowBox[{"MatrixExp", "[", 
       RowBox[{"I", " ", "\[Omega]d", " ", "t", " ", 
        RowBox[{
         RowBox[{"PauliMatrix", "[", "3", "]"}], "/", "2"}]}], "]"}]}], ",", 
     " ", 
     RowBox[{"hdrive", " ", "=", " ", 
      RowBox[{
       RowBox[{
        RowBox[{"(", 
         RowBox[{"\[Omega]0", "/", "2"}], ")"}], " ", 
        RowBox[{"PauliMatrix", "[", "3", "]"}]}], " ", "+", " ", 
       RowBox[{"\[CapitalOmega]", " ", 
        RowBox[{"Cos", "[", 
         RowBox[{"\[Omega]d", " ", "t"}], "]"}], " ", 
        RowBox[{"PauliMatrix", "[", "1", "]"}]}]}]}]}], "}"}], ",", " ", 
   RowBox[{
    RowBox[{"TrigReduce", "[", 
     RowBox[{"ComplexExpand", "[", 
      RowBox[{
       RowBox[{"r", " ", ".", " ", "hdrive", " ", ".", " ", 
        RowBox[{"ConjugateTranspose", "[", "r", "]"}]}], " ", "-", " ", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{"\[Omega]d", "/", "2"}], ")"}], " ", 
        RowBox[{"PauliMatrix", "[", "3", "]"}]}]}], "]"}], "]"}], " ", "/.", 
    " ", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{
       RowBox[{"Cos", "[", 
        RowBox[{"2", " ", "t", " ", "\[Omega]d"}], "]"}], " ", "->", " ", 
       "0"}], ",", " ", 
      RowBox[{
       RowBox[{"Sin", "[", 
        RowBox[{"2", " ", "t", " ", "\[Omega]d"}], "]"}], " ", "->", " ", 
       "0"}]}], "}"}]}]}], "]"}]], "Input",
 CellLabel->
  "In[25]:= ",ExpressionUUID->"0d8cc60e-ffd0-4694-abfe-f44e97f23eb8"],

Cell[TextData[{
 StyleBox["QF",
  FontWeight->"Bold"],
 " : the resonant (",
 Cell[BoxData[
  RowBox[{
   SubscriptBox[
    StyleBox["\[Omega]", "TI"], 
    StyleBox["d", "TI"]], "=", 
   SubscriptBox[
    StyleBox["\[Omega]", "TI"], "0"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "7c151357-90d1-4c57-a32e-6e350f2e8c21"],
 ", so ",
 Cell[BoxData[
  RowBox[{"\[CapitalDelta]", "=", "0"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "432d5ead-528e-467b-8204-ba3519193845"],
 ") rotating-frame problem is the static drive ",
 Cell[BoxData[
  RowBox[{
   FractionBox["\[CapitalOmega]", "2"], 
   StyleBox["X", "TI"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "2cd8bd9d-9657-4a1c-97bf-a9abbfd504c9"],
 "; evolve ",
 Cell[BoxData[
  TemplateBox[{"0"},
   "Ket"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "f5253efb-df6a-448a-bd55-1ed00da510ef"],
 " under it and recover the Rabi population."
}], "Text",ExpressionUUID->"d95da21c-55cf-4d6b-aaac-529fbd82cfb2"],

Cell[BoxData[
 RowBox[{"Simplify", "[", 
  RowBox[{
   RowBox[{
    RowBox[{"QuantumEvolve", "[", 
     RowBox[{
      RowBox[{"QuantumOperator", "[", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{"\[CapitalOmega]", "/", "2"}], ")"}], " ", 
        RowBox[{"PauliMatrix", "[", "1", "]"}]}], "]"}], ",", " ", 
      RowBox[{"QuantumState", "[", "\"\<0\>\"", "]"}], ",", " ", "t"}], "]"}],
     "[", "\"\<ProbabilitiesList\>\"", "]"}], ",", " ", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"\[CapitalOmega]", ",", " ", "t"}], "}"}], " ", "\[Element]", 
    " ", "Reals"}]}], "]"}]], "Input",
 CellLabel->
  "In[26]:= ",ExpressionUUID->"4398c39f-61bf-4847-8ea3-3f7c21d96a6b"],

Cell[TextData[{
 "Averaging away the ",
 Cell[BoxData[
  RowBox[{"2", 
   SubscriptBox[
    StyleBox["\[Omega]", "TI"], 
    StyleBox["d", "TI"]]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "58466ab3-595a-4e02-93d2-2bb275fc3b56"],
 " terms leaves ",
 Cell[BoxData[
  RowBox[{
   FractionBox["\[CapitalDelta]", "2"], 
   StyleBox["Z", "TI"], "+", 
   FractionBox["\[CapitalOmega]", "2"], 
   StyleBox["X", "TI"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "996d9a57-7e20-4e4c-bc3f-b7503a49015d"],
 ": the drive dresses the qubit with an effective static field whose ",
 Cell[BoxData[
  StyleBox["z", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "7f50136b-c65f-4ac5-a4a7-c753d7a25c9a"],
 "-component is the detuning and whose ",
 Cell[BoxData[
  StyleBox["x", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "d82d3c6d-853f-4ad3-b94c-f97976916893"],
 "-component is half the drive amplitude. On resonance the field is purely \
transverse and the qubit Rabi-flops completely, ",
 Cell[BoxData[
  RowBox[{
   SubscriptBox[
    StyleBox["P", "TI"], "1"], 
   StyleBox["(",
    SpanMaxSize->1], 
   StyleBox["t", "TI"], 
   StyleBox[")",
    SpanMaxSize->1], "=", 
   SuperscriptBox[
    StyleBox["sin",
     FontSlant->"Plain"], "2"], "\[ThinSpace]", 
   FractionBox[
    RowBox[{"\[CapitalOmega]", 
     StyleBox["t", "TI"]}], "2"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "e50a6d47-cbb9-451c-b846-b05668db68b0"],
 "; off resonance the flopping is faster but incomplete."
}], "Text",ExpressionUUID->"c9172a19-4621-488a-a64f-a9d103e7c416"],

Cell[TextData[{
 "7.9a [MSc] How do I compute the first-order transition probability under a \
periodic perturbation ",
 Cell[BoxData[
  RowBox[{
   SuperscriptBox[
    StyleBox["H", "TI"], "\[Prime]"], 
   StyleBox["(",
    SpanMaxSize->1], 
   StyleBox["t", "TI"], 
   StyleBox[")",
    SpanMaxSize->1], "=", 
   StyleBox["V", "TI"], 
   StyleBox["cos",
    FontSlant->"Plain"], "\[ThinSpace]", 
   StyleBox["(",
    SpanMaxSize->1], 
   StyleBox[
    RowBox[{"\[Omega]", "t"}], "TI"], 
   StyleBox[")",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "7b58a319-d083-4d0e-9be5-8f8552c6a66b"],
 "?"
}], "Subsection",ExpressionUUID->"78fb7e66-dd82-4f9b-8439-bf8c23e18bfb"],

Cell[TextData[{
 "First-order time-dependent perturbation theory gives the amplitude to hop \
from ",
 Cell[BoxData[
  TemplateBox[{
    StyleBox["i", "TI"]},
   "Ket"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "441879e4-a807-4b61-a1bf-12a91999166d"],
 " to ",
 Cell[BoxData[
  TemplateBox[{
    StyleBox["f", "TI"]},
   "Ket"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "44dcff0b-1c4c-403d-a9d2-edd77272f1af"],
 " under ",
 Cell[BoxData[
  RowBox[{
   SuperscriptBox[
    StyleBox["H", "TI"], "\[Prime]"], 
   StyleBox["(",
    SpanMaxSize->1], 
   StyleBox["t", "TI"], 
   StyleBox[")",
    SpanMaxSize->1], "=", 
   StyleBox["V", "TI"], 
   StyleBox["cos",
    FontSlant->"Plain"], "\[ThinSpace]", 
   StyleBox["(",
    SpanMaxSize->1], 
   StyleBox[
    RowBox[{"\[Omega]", "t"}], "TI"], 
   StyleBox[")",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "c103da34-107f-4c49-8342-5c749a83d8da"],
 " as ",
 Cell[BoxData[
  RowBox[{
   SubscriptBox[
    StyleBox["c", "TI"], 
    StyleBox["f", "TI"]], 
   StyleBox["(",
    SpanMaxSize->1], 
   StyleBox["t", "TI"], 
   StyleBox[")",
    SpanMaxSize->1], "=", "-", 
   StyleBox["i", "TI"], 
   SubscriptBox[
    StyleBox["V", "TI"], 
    StyleBox[
     RowBox[{"f", "i"}], "TI"]], 
   UnderoverscriptBox["\[Integral]", "0", 
    StyleBox["t", "TI"],
    LimitsPositioning->False], 
   StyleBox["cos",
    FontSlant->"Plain"], "\[ThinSpace]", 
   StyleBox["(",
    SpanMaxSize->1], 
   RowBox[{
    StyleBox["\[Omega]", "TI"], 
    SuperscriptBox[
     StyleBox["t", "TI"], "\[Prime]"]}], 
   StyleBox[")",
    SpanMaxSize->1], " ", 
   SuperscriptBox[
    StyleBox["e", "TI"], 
    RowBox[{
     StyleBox["i", "TI"], 
     SubscriptBox[
      StyleBox["\[Omega]", "TI"], 
      StyleBox[
       RowBox[{"f", "i"}], "TI"]], 
     SuperscriptBox[
      StyleBox["t", "TI"], "\[Prime]"]}]], 
   StyleBox["d", "TI"], 
   SuperscriptBox[
    StyleBox["t", "TI"], "\[Prime]"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "656dff5a-944a-4668-968c-fcb5c2396558"],
 ", with ",
 Cell[BoxData[
  RowBox[{
   SubscriptBox[
    StyleBox["V", "TI"], 
    StyleBox[
     RowBox[{"f", "i"}], "TI"]], "=", 
   RowBox[{
    TemplateBox[{
      StyleBox["f", "TI"]},
     "Bra"], 
    StyleBox["V", "TI"], 
    TemplateBox[{
      StyleBox["i", "TI"]},
     "Ket"]}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "fcf18e11-3bed-4eab-990c-5d1dd2b64f7a"],
 " and ",
 Cell[BoxData[
  RowBox[{
   SubscriptBox[
    StyleBox["\[Omega]", "TI"], 
    StyleBox[
     RowBox[{"f", "i"}], "TI"]], "=", 
   SubscriptBox[
    StyleBox["E", "TI"], 
    StyleBox["f", "TI"]], "-", 
   SubscriptBox[
    StyleBox["E", "TI"], 
    StyleBox["i", "TI"]]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "cd7af802-8142-4408-9244-e9342218996f"],
 ". The near-resonant term gives ",
 Cell[BoxData[
  RowBox[{
   SubscriptBox[
    StyleBox["P", "TI"], 
    RowBox[{
     StyleBox["i", "TI"], "\[Rule]", 
     StyleBox["f", "TI"]}]], 
   StyleBox["(",
    SpanMaxSize->1], 
   StyleBox["t", "TI"], 
   StyleBox[")",
    SpanMaxSize->1], "=", 
   SuperscriptBox[GridBox[{
      {
       RowBox[{
        SubscriptBox[
         StyleBox["c", "TI"], 
         StyleBox["f", "TI"]], 
        StyleBox["(",
         SpanMaxSize->1], 
        StyleBox["t", "TI"], 
        StyleBox[")",
         SpanMaxSize->1]}]}
     },
     GridBoxDividers->{"Columns" -> {True, True}, "Rows" -> {}},
     GridBoxSpacings->{"Columns" -> {{0.15}}}], "2"], "\[TildeTilde]", 
   SuperscriptBox[GridBox[{
      {
       SubscriptBox[
        StyleBox["V", "TI"], 
        StyleBox[
         RowBox[{"f", "i"}], "TI"]]}
     },
     GridBoxDividers->{"Columns" -> {True, True}, "Rows" -> {}},
     GridBoxSpacings->{"Columns" -> {{0.15}}}], "2"], " ", 
   FractionBox[
    SuperscriptBox[
     StyleBox["t", "TI"], "2"], "4"], " ", 
   SuperscriptBox[
    StyleBox["sinc",
     FontSlant->"Plain"], "2"], 
   FractionBox[
    RowBox[{
     StyleBox["(",
      SpanMaxSize->1], 
     RowBox[{
      SubscriptBox[
       StyleBox["\[Omega]", "TI"], 
       StyleBox[
        RowBox[{"f", "i"}], "TI"]], "-", 
      StyleBox["\[Omega]", "TI"]}], 
     StyleBox[")",
      SpanMaxSize->1], 
     StyleBox["t", "TI"]}], "2"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "9548a52b-9385-40de-942b-11564a4ac574"],
 ", sharply peaked at the resonance ",
 Cell[BoxData[
  RowBox[{
   StyleBox["\[Omega]", "TI"], "=", 
   SubscriptBox[
    StyleBox["\[Omega]", "TI"], 
    StyleBox[
     RowBox[{"f", "i"}], "TI"]]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "8e6c5bb6-dae0-409e-8fa0-e67c893e91da"],
 "."
}], "Text",ExpressionUUID->"4da939d7-642f-444e-9ef7-8d91611b1192"],

Cell[TextData[{
 StyleBox["WL",
  FontWeight->"Bold"],
 " : do the amplitude integral, keep the resonant (",
 Cell[BoxData[
  SuperscriptBox[
   StyleBox["e", "TI"], 
   RowBox[{
    StyleBox["i", "TI"], 
    StyleBox["(",
     SpanMaxSize->1], 
    RowBox[{
     SubscriptBox[
      StyleBox["\[Omega]", "TI"], 
      StyleBox[
       RowBox[{"f", "i"}], "TI"]], "-", 
     StyleBox["\[Omega]", "TI"]}], 
    StyleBox[")",
     SpanMaxSize->1], 
    SuperscriptBox[
     StyleBox["t", "TI"], "\[Prime]"]}]]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "3e46175b-98f6-47f9-a726-861eec8fd054"],
 ") term, and read the probability near resonance."
}], "Text",ExpressionUUID->"feaadd5c-e7af-4c2d-89d8-53c7d5f53128"],

Cell[BoxData[
 RowBox[{"With", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{"\[CapitalDelta]", " ", "=", " ", 
      RowBox[{"\[Omega]fi", " ", "-", " ", "\[Omega]"}]}], ",", " ", 
     RowBox[{"amp", " ", "=", " ", 
      RowBox[{"Integrate", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"Exp", "[", 
          RowBox[{"I", " ", 
           RowBox[{"(", 
            RowBox[{"\[Omega]fi", " ", "-", " ", "\[Omega]"}], ")"}], " ", 
           "t2"}], "]"}], "/", "2"}], ",", " ", 
        RowBox[{"{", 
         RowBox[{"t2", ",", " ", "0", ",", " ", "t"}], "}"}]}], "]"}]}]}], 
    "}"}], ",", " ", 
   RowBox[{"FullSimplify", "[", 
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{"Abs", "[", "Vfi", "]"}], "^", "2"}], " ", 
       RowBox[{"ComplexExpand", "[", 
        RowBox[{"amp", " ", 
         RowBox[{"Conjugate", "[", "amp", "]"}]}], "]"}]}], " ", "==", " ", 
      RowBox[{
       RowBox[{
        RowBox[{"Abs", "[", "Vfi", "]"}], "^", "2"}], " ", 
       RowBox[{"(", 
        RowBox[{
         RowBox[{"t", "^", "2"}], "/", "4"}], ")"}], " ", 
       RowBox[{
        RowBox[{"Sinc", "[", 
         RowBox[{"\[CapitalDelta]", " ", 
          RowBox[{"t", "/", "2"}]}], "]"}], "^", "2"}]}]}], ",", " ", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"\[CapitalDelta]", ",", " ", "t"}], "}"}], " ", "\[Element]", 
      " ", "Reals"}]}], "]"}]}], "]"}]], "Input",
 CellLabel->
  "In[27]:= ",ExpressionUUID->"9282e495-b705-4b59-8405-8344ee4ed0ef"],

Cell[TextData[{
 StyleBox["QF",
  FontWeight->"Bold"],
 " : the matrix element ",
 Cell[BoxData[
  RowBox[{
   SubscriptBox[
    StyleBox["V", "TI"], 
    StyleBox[
     RowBox[{"f", "i"}], "TI"]], "=", 
   RowBox[{
    TemplateBox[{
      StyleBox["f", "TI"]},
     "Bra"], 
    StyleBox["V", "TI"], 
    TemplateBox[{
      StyleBox["i", "TI"]},
     "Ket"]}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "47e108ca-4713-4d14-8ce8-2f938f944def"],
 " that sets the strength, here for a ",
 Cell[BoxData[
  RowBox[{
   OverscriptBox[
    StyleBox["V", "TI"], "^"], "=", 
   StyleBox["v", "TI"], " ", 
   StyleBox["X", "TI"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "5645121a-e28c-403a-8543-6fdcc81ab80e"],
 " coupling between the two levels ",
 Cell[BoxData[
  RowBox[{
   TemplateBox[{"0"},
    "Ket"], ",", 
   TemplateBox[{"1"},
    "Ket"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "390187c8-2877-48f7-baa7-0057ceb8eb76"],
 ", via the object sandwich."
}], "Text",ExpressionUUID->"b14d5358-c9a9-4343-964c-83c619d5ebdb"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(", 
   RowBox[{
    RowBox[{
     RowBox[{"QuantumState", "[", "\"\<1\>\"", "]"}], "[", "\"\<Dagger\>\"", 
     "]"}], " ", "@", " ", 
    RowBox[{
     RowBox[{"QuantumOperator", "[", 
      RowBox[{"v", " ", 
       RowBox[{"PauliMatrix", "[", "1", "]"}]}], "]"}], " ", "@", " ", 
     RowBox[{"QuantumState", "[", "\"\<0\>\"", "]"}]}]}], ")"}], 
  "[", "\"\<Scalar\>\"", "]"}]], "Input",
 CellLabel->
  "In[28]:= ",ExpressionUUID->"717ea256-a45c-42a1-887d-52c27ad36b53"],

Cell[TextData[{
 "The probability grows as ",
 Cell[BoxData[
  RowBox[{
   SuperscriptBox[GridBox[{
      {
       SubscriptBox[
        StyleBox["V", "TI"], 
        StyleBox[
         RowBox[{"f", "i"}], "TI"]]}
     },
     GridBoxDividers->{"Columns" -> {True, True}, "Rows" -> {}},
     GridBoxSpacings->{"Columns" -> {{0.15}}}], "2"], " ", 
   FractionBox[
    SuperscriptBox[
     StyleBox["t", "TI"], "2"], "4"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "522f0dc5-9cb9-43e1-97c5-5e3cf0eec7e1"],
 " exactly on resonance and is throttled off it by the ",
 Cell[BoxData[
  SuperscriptBox[
   StyleBox["sinc",
    FontSlant->"Plain"], "2"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "0a5ec9d5-b28f-4bfb-b432-32cc461c7a9a"],
 " factor whose central lobe narrows as ",
 Cell[BoxData[
  RowBox[{"1", "/", 
   StyleBox["t", "TI"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "5b1a0ff7-36e4-4557-b1a0-8bfc0b7b21d8"],
 ": as time passes the response concentrates ever more sharply on states with \
",
 Cell[BoxData[
  RowBox[{
   SubscriptBox[
    StyleBox["E", "TI"], 
    StyleBox["f", "TI"]], "-", 
   SubscriptBox[
    StyleBox["E", "TI"], 
    StyleBox["i", "TI"]], "=", 
   StyleBox["\[Omega]", "TI"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "5cbb6a01-2149-4fdd-8998-4014d50e61f8"],
 ", the seed of energy conservation."
}], "Text",ExpressionUUID->"bc19a08d-9815-43fe-afe2-0df33f100aef"],

Cell[TextData[{
 "7.9b [MSc] How do I recover Fermi's golden rule rate ",
 Cell[BoxData[
  RowBox[{"\[CapitalGamma]", "=", "2", "\[Pi]", 
   SuperscriptBox[GridBox[{
      {
       SubscriptBox[
        StyleBox["V", "TI"], 
        StyleBox[
         RowBox[{"f", "i"}], "TI"]]}
     },
     GridBoxDividers->{"Columns" -> {True, True}, "Rows" -> {}},
     GridBoxSpacings->{"Columns" -> {{0.15}}}], "2"], 
   StyleBox["\[Rho]", "TI"], 
   StyleBox["(",
    SpanMaxSize->1], 
   SubscriptBox[
    StyleBox["E", "TI"], 
    StyleBox["f", "TI"]], 
   StyleBox[")",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "479e5cd4-59e5-46d7-9e25-1bee1855b4e7"],
 " from a finite dense band of final states in the dense-band limit?"
}], "Subsection",ExpressionUUID->"6bea2f5b-7fa6-42dd-8baf-2b3cec054f66"],

Cell[TextData[{
 "Fermi's golden rule is the golden-rule ",
 StyleBox["rate", "TI"],
 ": for a coupling of strength ",
 Cell[BoxData[GridBox[{
    {
     SubscriptBox[
      StyleBox["V", "TI"], 
      StyleBox[
       RowBox[{"f", "i"}], "TI"]]}
   },
   GridBoxDividers->{"Columns" -> {True, True}, "Rows" -> {}},
   GridBoxSpacings->{"Columns" -> {{0.15}}}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "505dc290-2119-44ed-91a5-20cad7e86e4d"],
 " switched on at ",
 Cell[BoxData[
  RowBox[{
   StyleBox["t", "TI"], "=", "0"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "e67487ab-3f40-4e8e-b2f3-a18028ad6675"],
 ", each final state at detuning ",
 Cell[BoxData[
  RowBox[{"\[CapitalDelta]", "=", 
   SubscriptBox[
    StyleBox["E", "TI"], 
    StyleBox["f", "TI"]], "-", 
   SubscriptBox[
    StyleBox["E", "TI"], 
    StyleBox["i", "TI"]]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "6e41bf9f-e8c7-4127-b20b-15caaacb96c6"],
 " receives probability ",
 Cell[BoxData[
  RowBox[{
   SuperscriptBox[GridBox[{
      {
       SubscriptBox[
        StyleBox["V", "TI"], 
        StyleBox[
         RowBox[{"f", "i"}], "TI"]]}
     },
     GridBoxDividers->{"Columns" -> {True, True}, "Rows" -> {}},
     GridBoxSpacings->{"Columns" -> {{0.15}}}], "2"], " ", 
   SuperscriptBox[
    StyleBox["t", "TI"], "2"], " ", 
   SuperscriptBox[
    StyleBox["sinc",
     FontSlant->"Plain"], "2"], 
   FractionBox[
    RowBox[{"\[CapitalDelta]", 
     StyleBox["t", "TI"]}], "2"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "cec13faf-9922-4185-b245-fb3ed41a40c1"],
 " (the constant-coupling companion of 7.9a's periodic line shape). When the \
single final state is replaced by a dense band with density of states ",
 Cell[BoxData[
  RowBox[{
   StyleBox["\[Rho]", "TI"], 
   StyleBox["(",
    SpanMaxSize->1], 
   SubscriptBox[
    StyleBox["E", "TI"], 
    StyleBox["f", "TI"]], 
   StyleBox[")",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "92a21201-7e1e-4695-aadf-26e25590e2d5"],
 ", the summed probability grows ",
 StyleBox["linearly", "TI"],
 " in time, its slope the golden-rule rate ",
 Cell[BoxData[
  RowBox[{"\[CapitalGamma]", "=", "2", "\[Pi]", 
   SuperscriptBox[GridBox[{
      {
       SubscriptBox[
        StyleBox["V", "TI"], 
        StyleBox[
         RowBox[{"f", "i"}], "TI"]]}
     },
     GridBoxDividers->{"Columns" -> {True, True}, "Rows" -> {}},
     GridBoxSpacings->{"Columns" -> {{0.15}}}], "2"], 
   StyleBox["\[Rho]", "TI"], 
   StyleBox["(",
    SpanMaxSize->1], 
   SubscriptBox[
    StyleBox["E", "TI"], 
    StyleBox["f", "TI"]], 
   StyleBox[")",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "b097ea5b-f63a-4a7e-baa6-adc2244adc7d"],
 ". This is a continuum limit, so it is shown here on a finite but dense \
band, watching ",
 Cell[BoxData[
  RowBox[{
   SubscriptBox[
    StyleBox["P", "TI"], 
    StyleBox["tot",
     FontSlant->"Plain"]], 
   StyleBox["(",
    SpanMaxSize->1], 
   StyleBox["t", "TI"], 
   StyleBox[")",
    SpanMaxSize->1], "/", 
   StyleBox["t", "TI"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "9a476436-543a-4d92-85a0-595d275ec634"],
 " approach the golden-rule value as the band is refined."
}], "Text",ExpressionUUID->"913029a4-e070-4845-9bec-af788a724414"],

Cell[TextData[{
 StyleBox["WL",
  FontWeight->"Bold"],
 " : lay a dense band of final energies around resonance, sum the ",
 Cell[BoxData[
  SuperscriptBox[
   StyleBox["sinc",
    FontSlant->"Plain"], "2"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "f35e7173-9750-43a4-876d-4a3690cc233f"],
 " probabilities, and compare ",
 Cell[BoxData[
  RowBox[{
   SubscriptBox[
    StyleBox["P", "TI"], 
    StyleBox["tot",
     FontSlant->"Plain"]], 
   StyleBox["(",
    SpanMaxSize->1], 
   StyleBox["t", "TI"], 
   StyleBox[")",
    SpanMaxSize->1], "/", 
   StyleBox["t", "TI"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "7ccf0dd5-ad7b-436c-98b2-83880516d9eb"],
 " to ",
 Cell[BoxData[
  RowBox[{"2", "\[Pi]", 
   SuperscriptBox[GridBox[{
      {
       SubscriptBox[
        StyleBox["V", "TI"], 
        StyleBox[
         RowBox[{"f", "i"}], "TI"]]}
     },
     GridBoxDividers->{"Columns" -> {True, True}, "Rows" -> {}},
     GridBoxSpacings->{"Columns" -> {{0.15}}}], "2"], 
   StyleBox["\[Rho]", "TI"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "c3b7cc44-fb88-476a-93de-2849cbc3e5eb"],
 "."
}], "Text",ExpressionUUID->"4f68562f-9649-408d-8069-cfe1d2a90143"],

Cell[BoxData[
 RowBox[{"With", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{"Vfi", " ", "=", " ", "0.1"}], ",", " ", 
     RowBox[{"\[Rho]", " ", "=", " ", "40"}], ",", " ", 
     RowBox[{"tval", " ", "=", " ", "30"}], ",", " ", 
     RowBox[{"halfwidth", " ", "=", " ", "2."}]}], "}"}], ",", " ", 
   RowBox[{"With", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"levels", " ", "=", " ", 
       RowBox[{"Range", "[", 
        RowBox[{
         RowBox[{"-", "halfwidth"}], ",", " ", "halfwidth", ",", " ", 
         RowBox[{"1", "/", "\[Rho]"}]}], "]"}]}], "}"}], ",", " ", 
     RowBox[{"With", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"Ptot", " ", "=", " ", 
         RowBox[{"Total", "[", 
          RowBox[{
           RowBox[{
            RowBox[{
             RowBox[{"(", 
              RowBox[{
               RowBox[{"Vfi", "^", "2"}], " ", 
               RowBox[{"tval", "^", "2"}]}], ")"}], " ", 
             RowBox[{
              RowBox[{"Sinc", "[", 
               RowBox[{"#", " ", 
                RowBox[{"tval", "/", "2"}]}], "]"}], "^", "2"}]}], " ", "&"}],
            " ", "/@", " ", "levels"}], "]"}]}], "}"}], ",", " ", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"Ptot", "/", "tval"}], ",", " ", 
         RowBox[{"2", " ", "Pi", " ", 
          RowBox[{"Vfi", "^", "2"}], " ", "\[Rho]"}]}], "}"}]}], "]"}]}], 
    "]"}]}], "]"}]], "Input",
 CellLabel->
  "In[29]:= ",ExpressionUUID->"5a7c1b1c-55c2-45d9-8d18-aadca67c9417"],

Cell[TextData[{
 StyleBox["QF",
  FontWeight->"Bold"],
 " : the coupling strength ",
 Cell[BoxData[
  SuperscriptBox[GridBox[{
     {
      SubscriptBox[
       StyleBox["V", "TI"], 
       StyleBox[
        RowBox[{"f", "i"}], "TI"]]}
    },
    GridBoxDividers->{"Columns" -> {True, True}, "Rows" -> {}},
    GridBoxSpacings->{"Columns" -> {{0.15}}}], "2"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "a3a3e80b-9690-4b53-a084-4c23e7009966"],
 " that scales the rate, read from the same matrix element as an object \
sandwich for a ",
 Cell[BoxData[
  RowBox[{
   OverscriptBox[
    StyleBox["V", "TI"], "^"], "=", 
   SubscriptBox[
    StyleBox["V", "TI"], 
    StyleBox[
     RowBox[{"f", "i"}], "TI"]], " ", 
   StyleBox["X", "TI"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "ee929a35-4eeb-48f2-81db-2806e05908e8"],
 " coupling."
}], "Text",ExpressionUUID->"0a4bb922-d6c1-4a16-b7b7-44cb82b17b23"],

Cell[BoxData[
 RowBox[{
  RowBox[{"Abs", "[", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{
      RowBox[{
       RowBox[{"QuantumState", "[", "\"\<1\>\"", "]"}], "[", "\"\<Dagger\>\"",
        "]"}], " ", "@", " ", 
      RowBox[{
       RowBox[{"QuantumOperator", "[", 
        RowBox[{"0.1", " ", 
         RowBox[{"PauliMatrix", "[", "1", "]"}]}], "]"}], " ", "@", " ", 
       RowBox[{"QuantumState", "[", "\"\<0\>\"", "]"}]}]}], ")"}], 
    "[", "\"\<Scalar\>\"", "]"}], "]"}], "^", "2"}]], "Input",
 CellLabel->
  "In[30]:= ",ExpressionUUID->"ceacc085-f292-4fbc-915b-83df3ed10cf8"],

Cell[TextData[{
 "The summed probability per unit time lands within a few percent of ",
 Cell[BoxData[
  RowBox[{"2", "\[Pi]", 
   SuperscriptBox[GridBox[{
      {
       SubscriptBox[
        StyleBox["V", "TI"], 
        StyleBox[
         RowBox[{"f", "i"}], "TI"]]}
     },
     GridBoxDividers->{"Columns" -> {True, True}, "Rows" -> {}},
     GridBoxSpacings->{"Columns" -> {{0.15}}}], "2"], 
   StyleBox["\[Rho]", "TI"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "f466dd41-aecf-49d4-a831-90963ad5ec69"],
 ", and the match tightens as the band is made denser and ",
 Cell[BoxData[
  StyleBox["t", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "91b9a717-679d-4434-9965-1cc52e1fcbd9"],
 " longer: a discrete spectrum of closely spaced levels mimics a continuum, \
and the interference of many near-resonant channels produces the \
irreversible, constant-rate decay that a single level (7.9a) could never show."
}], "Text",ExpressionUUID->"c4c26264-5f51-4c94-bb0b-c0eb4fd00e47"],

Cell[TextData[{
 "7.10a [MSc] How do I find a symmetry operator ",
 Cell[BoxData[
  StyleBox["S", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "3ec848bc-1055-436b-87f8-c0408a2b3776"],
 " that commutes with ",
 Cell[BoxData[
  OverscriptBox[
   StyleBox["H", "TI"], "^"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "c0794c02-4fce-4a60-bfb2-58be8e61900e"],
 " and use its eigenvalue as a conserved quantum number?"
}], "Subsection",ExpressionUUID->"b3a8280f-83b5-4e91-abc7-29f01ef876a8"],

Cell[TextData[{
 "A symmetry is a unitary ",
 Cell[BoxData[
  StyleBox["S", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "d48d2a5f-1abf-4f0e-8abe-c2376f99e3a9"],
 " with ",
 Cell[BoxData[
  RowBox[{
   StyleBox["[",
    SpanMaxSize->1], 
   RowBox[{
    StyleBox["S", "TI"], ",", 
    OverscriptBox[
     StyleBox["H", "TI"], "^"]}], 
   StyleBox["]",
    SpanMaxSize->1], "=", "0"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "a09b4aae-cdc4-40f6-9cef-fc6e5e6984d0"],
 ". Then ",
 Cell[BoxData[
  StyleBox["S", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "17cce40e-9248-4f08-8290-548ce0c947e4"],
 " and ",
 Cell[BoxData[
  OverscriptBox[
   StyleBox["H", "TI"], "^"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "2520cea4-01eb-49aa-9af1-1672c9e4dcfa"],
 " share eigenstates, ",
 Cell[BoxData[
  StyleBox["S", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "8273e052-3a37-48ac-a2a5-c4512aa42df2"],
 " is a constant of the motion (",
 Cell[BoxData[
  RowBox[{
   FractionBox[
    StyleBox["d", "TI"], 
    StyleBox[
     RowBox[{"d", "t"}], "TI"]], 
   StyleBox["\[LeftAngleBracket]",
    SpanMaxSize->1], 
   StyleBox["S", "TI"], "\[VeryThinSpace]", 
   StyleBox["\[RightAngleBracket]",
    SpanMaxSize->1], "=", 
   StyleBox["i", "TI"], 
   StyleBox["\[LeftAngleBracket]",
    SpanMaxSize->1], 
   RowBox[{
    StyleBox["[",
     SpanMaxSize->1], 
    RowBox[{
     OverscriptBox[
      StyleBox["H", "TI"], "^"], ",", 
     StyleBox["S", "TI"]}], 
    StyleBox["]",
     SpanMaxSize->1]}], 
   StyleBox["\[RightAngleBracket]",
    SpanMaxSize->1], "=", "0"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "e2a05091-4129-499c-8c40-45fe3c8f663b"],
 "), and its eigenvalue labels states by a conserved quantum number. Take the \
two-spin Heisenberg exchange ",
 Cell[BoxData[
  RowBox[{
   OverscriptBox[
    StyleBox["H", "TI"], "^"], "=", 
   StyleBox["J", "TI"], 
   StyleBox["(",
    SpanMaxSize->1], 
   RowBox[{
    StyleBox["X", "TI"], "\[CircleTimes]", 
    StyleBox["X", "TI"], "+", 
    StyleBox["Y", "TI"], "\[CircleTimes]", 
    StyleBox["Y", "TI"], "+", 
    StyleBox["Z", "TI"], "\[CircleTimes]", 
    StyleBox["Z", "TI"]}], 
   StyleBox[")",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "60dfa106-baa2-41e3-b97a-bc758386f589"],
 "; the swap ",
 Cell[BoxData[
  RowBox[{
   StyleBox["S", "TI"], "=", 
   StyleBox["SWAP",
    FontSlant->"Plain"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "1a6a11d6-2415-405d-b859-eb8c72335262"],
 " that exchanges the two spins commutes with it."
}], "Text",ExpressionUUID->"ce45c751-3e2d-492d-bf47-cf26522d738c"],

Cell[TextData[{
 StyleBox["WL",
  FontWeight->"Bold"],
 " : build ",
 Cell[BoxData[
  OverscriptBox[
   StyleBox["H", "TI"], "^"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "997a74d4-8f77-4746-b9d2-6fa32012227f"],
 " and ",
 Cell[BoxData[
  StyleBox["S", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "16ef137d-0120-4a65-b26d-298166ee7576"],
 " as Kronecker products and test that their commutator vanishes."
}], "Text",ExpressionUUID->"efaaedec-27b0-4b74-81db-534a0bca3a90"],

Cell[BoxData[
 RowBox[{"With", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{"h", " ", "=", " ", 
      RowBox[{"j", " ", 
       RowBox[{"(", 
        RowBox[{
         RowBox[{"KroneckerProduct", "[", 
          RowBox[{
           RowBox[{"PauliMatrix", "[", "1", "]"}], ",", " ", 
           RowBox[{"PauliMatrix", "[", "1", "]"}]}], "]"}], " ", "+", " ", 
         RowBox[{"KroneckerProduct", "[", 
          RowBox[{
           RowBox[{"PauliMatrix", "[", "2", "]"}], ",", " ", 
           RowBox[{"PauliMatrix", "[", "2", "]"}]}], "]"}], " ", "+", " ", 
         RowBox[{"KroneckerProduct", "[", 
          RowBox[{
           RowBox[{"PauliMatrix", "[", "3", "]"}], ",", " ", 
           RowBox[{"PauliMatrix", "[", "3", "]"}]}], "]"}]}], ")"}]}]}], ",", 
     " ", 
     RowBox[{"s", " ", "=", " ", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"1", ",", " ", "0", ",", " ", "0", ",", " ", "0"}], "}"}], ",",
         " ", 
        RowBox[{"{", 
         RowBox[{"0", ",", " ", "0", ",", " ", "1", ",", " ", "0"}], "}"}], ",",
         " ", 
        RowBox[{"{", 
         RowBox[{"0", ",", " ", "1", ",", " ", "0", ",", " ", "0"}], "}"}], ",",
         " ", 
        RowBox[{"{", 
         RowBox[{"0", ",", " ", "0", ",", " ", "0", ",", " ", "1"}], "}"}]}], 
       "}"}]}]}], "}"}], ",", " ", 
   RowBox[{
    RowBox[{
     RowBox[{"h", " ", ".", " ", "s"}], " ", "-", " ", 
     RowBox[{"s", " ", ".", " ", "h"}]}], " ", "==", " ", 
    RowBox[{"0", " ", 
     RowBox[{"IdentityMatrix", "[", "4", "]"}]}]}]}], "]"}]], "Input",
 CellLabel->
  "In[31]:= ",ExpressionUUID->"7128da1e-c4fd-47c1-83fb-eafc053004f1"],

Cell[TextData[{
 StyleBox["QF",
  FontWeight->"Bold"],
 " : the same test at the operator level, ",
 Cell[BoxData[
  RowBox[{
   StyleBox["[",
    SpanMaxSize->1], 
   RowBox[{
    OverscriptBox[
     StyleBox["H", "TI"], "^"], ",", 
    StyleBox["SWAP",
     FontSlant->"Plain"]}], 
   StyleBox["]",
    SpanMaxSize->1], "=", "0"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "0216217c-b9a9-428c-9e6c-a2e4003570f3"],
 ", with ",
 Cell[BoxData["Commutator"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "5eb33bc3-e18d-4263-be8e-2210e4467747"],
 " and the named ",
 Cell[BoxData["\"\<SWAP\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "a85e8d7e-fbd9-4391-9d5e-2f3de00a5924"],
 " gate."
}], "Text",ExpressionUUID->"aad58a2f-192a-42ff-a420-420e5e92bd3f"],

Cell[BoxData[
 RowBox[{"With", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"h", " ", "=", " ", 
     RowBox[{
      RowBox[{"j", " ", 
       RowBox[{"QuantumTensorProduct", "[", 
        RowBox[{
         RowBox[{"QuantumOperator", "[", "\"\<X\>\"", "]"}], ",", " ", 
         RowBox[{"QuantumOperator", "[", "\"\<X\>\"", "]"}]}], "]"}]}], " ", "+",
       " ", 
      RowBox[{"j", " ", 
       RowBox[{"QuantumTensorProduct", "[", 
        RowBox[{
         RowBox[{"QuantumOperator", "[", "\"\<Y\>\"", "]"}], ",", " ", 
         RowBox[{"QuantumOperator", "[", "\"\<Y\>\"", "]"}]}], "]"}]}], " ", "+",
       " ", 
      RowBox[{"j", " ", 
       RowBox[{"QuantumTensorProduct", "[", 
        RowBox[{
         RowBox[{"QuantumOperator", "[", "\"\<Z\>\"", "]"}], ",", " ", 
         RowBox[{"QuantumOperator", "[", "\"\<Z\>\"", "]"}]}], "]"}]}]}]}], 
    "}"}], ",", " ", 
   RowBox[{
    RowBox[{"Commutator", "[", 
     RowBox[{"h", ",", " ", 
      RowBox[{"QuantumOperator", "[", "\"\<SWAP\>\"", "]"}]}], "]"}], " ", "==",
     " ", 
    RowBox[{"0", " ", 
     RowBox[{"QuantumOperator", "[", 
      RowBox[{
       RowBox[{"IdentityMatrix", "[", "4", "]"}], ",", " ", 
       RowBox[{"{", 
        RowBox[{"1", ",", " ", "2"}], "}"}]}], "]"}]}]}]}], "]"}]], "Input",
 CellLabel->
  "In[32]:= ",ExpressionUUID->"78b412f8-9560-4e5a-92de-65bafb50be11"],

Cell[TextData[{
 "Both confirm ",
 Cell[BoxData[
  RowBox[{
   StyleBox["[",
    SpanMaxSize->1], 
   RowBox[{
    OverscriptBox[
     StyleBox["H", "TI"], "^"], ",", 
    StyleBox["SWAP",
     FontSlant->"Plain"]}], 
   StyleBox["]",
    SpanMaxSize->1], "=", "0"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "043a6ab3-af64-4535-8316-e8d2e634cff4"],
 ": exchange symmetry is exact for the Heisenberg coupling, so the swap \
parity (symmetric versus antisymmetric under exchange) is conserved and every \
eigenstate of ",
 Cell[BoxData[
  OverscriptBox[
   StyleBox["H", "TI"], "^"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "6423cbe2-88a2-4d3a-8776-6cf51fb06fff"],
 " can be labelled by it, which is exactly what block-diagonalizes ",
 Cell[BoxData[
  OverscriptBox[
   StyleBox["H", "TI"], "^"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "ef6d7522-8224-472c-9156-601a94e9cba0"],
 " into symmetry sectors."
}], "Text",ExpressionUUID->"700ee82e-88dd-4adf-acec-141a42e02c21"],

Cell[TextData[{
 "7.10b [MSc] How do I block-diagonalize ",
 Cell[BoxData[
  OverscriptBox[
   StyleBox["H", "TI"], "^"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "ca274133-12a9-4820-a4da-fea0ad30daac"],
 " into symmetry sectors using the eigenspaces of a commuting symmetry ",
 Cell[BoxData[
  StyleBox["S", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "6716ea52-1c2e-4931-b51a-3deb83aec8dd"],
 "?"
}], "Subsection",ExpressionUUID->"ceb42e9e-6fc8-4cf9-a51d-89bb08fd9d02"],

Cell[TextData[{
 "When ",
 Cell[BoxData[
  RowBox[{
   StyleBox["[",
    SpanMaxSize->1], 
   RowBox[{
    StyleBox["S", "TI"], ",", 
    OverscriptBox[
     StyleBox["H", "TI"], "^"]}], 
   StyleBox["]",
    SpanMaxSize->1], "=", "0"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "455438b5-bd0f-4eaf-87df-e5479c99d73e"],
 ", the eigenspaces of ",
 Cell[BoxData[
  StyleBox["S", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "042a98ab-129a-43e7-af60-815a98b120cd"],
 " are invariant under ",
 Cell[BoxData[
  OverscriptBox[
   StyleBox["H", "TI"], "^"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "a65d344d-ed2a-4fd7-bd21-5f2f294506ee"],
 ": in a basis sorted by ",
 Cell[BoxData[
  StyleBox["S", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "90859cfe-e5a3-4337-81ea-31820d29eff2"],
 "'s eigenvalue, ",
 Cell[BoxData[
  OverscriptBox[
   StyleBox["H", "TI"], "^"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "d0cc57a5-ec2f-41d7-95d2-64a5a341cf41"],
 " is block-diagonal, one block per symmetry sector, and each block can be \
diagonalized on its own. Continue with the Heisenberg dimer and ",
 Cell[BoxData[
  RowBox[{
   StyleBox["S", "TI"], "=", 
   StyleBox["SWAP",
    FontSlant->"Plain"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "72256a5f-eaac-4a81-bdb6-4a80973222b8"],
 " of 7.10a, whose eigenvalues are ",
 Cell[BoxData[
  RowBox[{"+", "1"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "a369e41e-114a-4139-b5e1-433c75ee9741"],
 " (the symmetric triplet, threefold) and ",
 Cell[BoxData[
  RowBox[{"-", "1"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "255b7397-074e-4457-a1f6-7d4628f3e59b"],
 " (the antisymmetric singlet)."
}], "Text",ExpressionUUID->"2a7f5289-1093-44d4-8aca-1f077a882a05"],

Cell[TextData[{
 StyleBox["WL",
  FontWeight->"Bold"],
 " : change to the eigenbasis of ",
 Cell[BoxData[
  StyleBox["S", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "bca6c2c0-5d44-4d0d-b88c-9cb54e728118"],
 " (its eigenvectors as rows) and conjugate ",
 Cell[BoxData[
  OverscriptBox[
   StyleBox["H", "TI"], "^"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "4128413c-ee53-4aee-a5f4-e8d7c069553d"],
 " into it; the result is block-diagonal."
}], "Text",ExpressionUUID->"05f90e89-abb9-469c-8939-4b0f00d4bb22"],

Cell[BoxData[
 RowBox[{"With", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{"h", " ", "=", " ", 
      RowBox[{"j", " ", 
       RowBox[{"(", 
        RowBox[{
         RowBox[{"KroneckerProduct", "[", 
          RowBox[{
           RowBox[{"PauliMatrix", "[", "1", "]"}], ",", " ", 
           RowBox[{"PauliMatrix", "[", "1", "]"}]}], "]"}], " ", "+", " ", 
         RowBox[{"KroneckerProduct", "[", 
          RowBox[{
           RowBox[{"PauliMatrix", "[", "2", "]"}], ",", " ", 
           RowBox[{"PauliMatrix", "[", "2", "]"}]}], "]"}], " ", "+", " ", 
         RowBox[{"KroneckerProduct", "[", 
          RowBox[{
           RowBox[{"PauliMatrix", "[", "3", "]"}], ",", " ", 
           RowBox[{"PauliMatrix", "[", "3", "]"}]}], "]"}]}], ")"}]}]}], ",", 
     " ", 
     RowBox[{"w", " ", "=", " ", 
      RowBox[{"Orthogonalize", "[", 
       RowBox[{"Eigenvectors", "[", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{"1", ",", " ", "0", ",", " ", "0", ",", " ", "0"}], "}"}], 
          ",", " ", 
          RowBox[{"{", 
           RowBox[{"0", ",", " ", "0", ",", " ", "1", ",", " ", "0"}], "}"}], 
          ",", " ", 
          RowBox[{"{", 
           RowBox[{"0", ",", " ", "1", ",", " ", "0", ",", " ", "0"}], "}"}], 
          ",", " ", 
          RowBox[{"{", 
           RowBox[{"0", ",", " ", "0", ",", " ", "0", ",", " ", "1"}], 
           "}"}]}], "}"}], "]"}], "]"}]}]}], "}"}], ",", " ", 
   RowBox[{"Simplify", "[", 
    RowBox[{"w", " ", ".", " ", "h", " ", ".", " ", 
     RowBox[{"Transpose", "[", "w", "]"}]}], "]"}]}], "]"}]], "Input",
 CellLabel->
  "In[33]:= ",ExpressionUUID->"d2acfc87-58e3-4655-a577-40c109bf6bf3"],

Cell[TextData[{
 StyleBox["QF",
  FontWeight->"Bold"],
 " : the same conjugation with ",
 Cell[BoxData["QuantumOperator"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "2e974bca-139a-485f-bf68-23eb42df0c3a"],
 "s, the sector-sorting change of basis ",
 Cell[BoxData[
  RowBox[{
   StyleBox["W", "TI"], 
   OverscriptBox[
    StyleBox["H", "TI"], "^"], 
   SuperscriptBox[
    StyleBox["W", "TI"], "\[Dagger]"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "71c3eb78-ccd2-453d-815e-e0d1a61dfb65"],
 "."
}], "Text",ExpressionUUID->"4aaf3399-40a3-4c0a-a8aa-4ba67ab516b2"],

Cell[BoxData[
 RowBox[{"With", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{"h", " ", "=", " ", 
      RowBox[{
       RowBox[{"j", " ", 
        RowBox[{"QuantumTensorProduct", "[", 
         RowBox[{
          RowBox[{"QuantumOperator", "[", "\"\<X\>\"", "]"}], ",", " ", 
          RowBox[{"QuantumOperator", "[", "\"\<X\>\"", "]"}]}], "]"}]}], " ", 
       "+", " ", 
       RowBox[{"j", " ", 
        RowBox[{"QuantumTensorProduct", "[", 
         RowBox[{
          RowBox[{"QuantumOperator", "[", "\"\<Y\>\"", "]"}], ",", " ", 
          RowBox[{"QuantumOperator", "[", "\"\<Y\>\"", "]"}]}], "]"}]}], " ", 
       "+", " ", 
       RowBox[{"j", " ", 
        RowBox[{"QuantumTensorProduct", "[", 
         RowBox[{
          RowBox[{"QuantumOperator", "[", "\"\<Z\>\"", "]"}], ",", " ", 
          RowBox[{"QuantumOperator", "[", "\"\<Z\>\"", "]"}]}], "]"}]}]}]}], ",",
      " ", 
     RowBox[{"w", " ", "=", " ", 
      RowBox[{"QuantumOperator", "[", 
       RowBox[{
        RowBox[{"Orthogonalize", "[", 
         RowBox[{"Eigenvectors", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"QuantumOperator", "[", "\"\<SWAP\>\"", "]"}], 
            "[", "\"\<Matrix\>\"", "]"}], " ", "//", " ", "Normal"}], "]"}], 
         "]"}], ",", " ", 
        RowBox[{"{", 
         RowBox[{"1", ",", " ", "2"}], "}"}]}], "]"}]}]}], "}"}], ",", " ", 
   RowBox[{"Simplify", "[", 
    RowBox[{"Normal", "[", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{"w", " ", "@", " ", 
        RowBox[{"h", " ", "@", " ", 
         RowBox[{"w", "[", "\"\<Dagger\>\"", "]"}]}]}], ")"}], 
      "[", "\"\<Matrix\>\"", "]"}], "]"}], "]"}]}], "]"}]], "Input",
 CellLabel->
  "In[34]:= ",ExpressionUUID->"51081191-c1ce-4ac0-9495-69c989ab7ecf"],

Cell[TextData[{
 "In the swap-sorted basis ",
 Cell[BoxData[
  OverscriptBox[
   StyleBox["H", "TI"], "^"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "c28eed35-f5ca-449e-ae29-087c1c74ae11"],
 " splits into a ",
 Cell[BoxData[
  RowBox[{"3", "\[Times]", "3"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "405ec622-701a-440e-b15f-ae6173137f92"],
 " triplet block (all with energy ",
 Cell[BoxData[
  RowBox[{"+", 
   StyleBox["J", "TI"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "23dfb373-f57e-46bf-a7cb-5327100f8df9"],
 ") and a ",
 Cell[BoxData[
  RowBox[{"1", "\[Times]", "1"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "d4928840-641a-4f57-838a-7975d08f000f"],
 " singlet block (energy ",
 Cell[BoxData[
  RowBox[{"-", "3", 
   StyleBox["J", "TI"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "8830f3e4-05b1-4da2-9137-3b7f36e9eaa7"],
 "): a ",
 Cell[BoxData[
  RowBox[{"4", "\[Times]", "4"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "7b9b4b16-55ba-4a6a-b190-671ea01f1cec"],
 " diagonalization has become two independent, smaller ones, which is why \
exploiting symmetry is the first move in any serious many-body calculation."
}], "Text",ExpressionUUID->"8122247e-64df-44db-b603-ef9c53358d74"],

Cell[TextData[{
 "7.11 [MSc] How do I implement a Trotter-Suzuki decomposition to simulate ",
 Cell[BoxData[
  SuperscriptBox[
   StyleBox["e", "TI"], 
   RowBox[{"-", 
    StyleBox["i", "TI"], 
    OverscriptBox[
     StyleBox["H", "TI"], "^"], 
    StyleBox["t", "TI"]}]]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "7687cee7-8d16-415a-8b6c-ef9f4f46c870"],
 " for a sum of noncommuting terms?"
}], "Subsection",ExpressionUUID->"1be86607-2015-4ae9-ae88-ea67c38613ba"],

Cell[TextData[{
 "When ",
 Cell[BoxData[
  RowBox[{
   OverscriptBox[
    StyleBox["H", "TI"], "^"], "=", 
   StyleBox["A", "TI"], "+", 
   StyleBox["B", "TI"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "6084a7b3-bf45-492a-8692-b27420b4b398"],
 " with ",
 Cell[BoxData[
  RowBox[{
   StyleBox["[",
    SpanMaxSize->1], 
   RowBox[{
    StyleBox["A", "TI"], ",", 
    StyleBox["B", "TI"]}], 
   StyleBox["]",
    SpanMaxSize->1], "\[NotEqual]", "0"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "0682966c-9900-44a2-92e7-3da8bc7c8e3a"],
 ", the exponential does not factor, but the first-order Trotter-Suzuki \
formula approximates it by many small alternating steps, ",
 Cell[BoxData[
  RowBox[{
   SuperscriptBox[
    StyleBox["e", "TI"], 
    RowBox[{"-", 
     StyleBox["i", "TI"], 
     StyleBox["(",
      SpanMaxSize->1], 
     RowBox[{
      StyleBox["A", "TI"], "+", 
      StyleBox["B", "TI"]}], 
     StyleBox[")",
      SpanMaxSize->1], 
     StyleBox["t", "TI"]}]], "\[TildeTilde]", 
   StyleBox["(",
    FontSize->1.2 Inherited], 
   SuperscriptBox[
    StyleBox["e", "TI"], 
    RowBox[{"-", 
     StyleBox["i", "TI"], 
     StyleBox["A", "TI"], 
     StyleBox["t", "TI"], "/", 
     StyleBox["n", "TI"]}]], " ", 
   SuperscriptBox[
    StyleBox["e", "TI"], 
    RowBox[{"-", 
     StyleBox["i", "TI"], 
     StyleBox["B", "TI"], 
     StyleBox["t", "TI"], "/", 
     StyleBox["n", "TI"]}]], 
   SuperscriptBox[
    StyleBox[")",
     FontSize->1.2 Inherited], 
    StyleBox["n", "TI"]]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "18fa0e40-ff3c-4325-a2a1-bd64ceced799"],
 ", with an error that falls as ",
 Cell[BoxData[
  RowBox[{"1", "/", 
   StyleBox["n", "TI"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "d33e1eeb-bd46-4fa7-838f-b9105d408ae1"],
 ". Take the noncommuting pair ",
 Cell[BoxData[
  RowBox[{
   StyleBox["A", "TI"], "=", 
   StyleBox["X", "TI"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "21b36ea1-992c-4dbd-a158-8a1394cdbc19"],
 ", ",
 Cell[BoxData[
  RowBox[{
   StyleBox["B", "TI"], "=", 
   StyleBox["Z", "TI"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "c8bd6bf0-44a0-4ef4-a9a1-8964e2ae033a"],
 "."
}], "Text",ExpressionUUID->"558b0b3e-32ac-4667-89e9-914f7d5d54e5"],

Cell[TextData[{
 StyleBox["WL",
  FontWeight->"Bold"],
 " : compare the exact propagator with the ",
 Cell[BoxData[
  StyleBox["n", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "3d9eee1f-e887-4b46-986d-cc953a607f78"],
 "-step Trotter product and measure the error as ",
 Cell[BoxData[
  StyleBox["n", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "a7b7347f-e1b3-4771-8f26-f3e4ea9bf935"],
 " grows."
}], "Text",ExpressionUUID->"0d6d3032-d80d-4b2a-a7bf-63737795a1f8"],

Cell[BoxData[
 RowBox[{"With", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{"a", " ", "=", " ", 
      RowBox[{"PauliMatrix", "[", "1", "]"}]}], ",", " ", 
     RowBox[{"b", " ", "=", " ", 
      RowBox[{"PauliMatrix", "[", "3", "]"}]}], ",", " ", 
     RowBox[{"tval", " ", "=", " ", "1."}]}], "}"}], ",", " ", 
   RowBox[{"Table", "[", 
    RowBox[{
     RowBox[{"Norm", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"MatrixExp", "[", 
         RowBox[{
          RowBox[{"-", "I"}], " ", 
          RowBox[{"(", 
           RowBox[{"a", " ", "+", " ", "b"}], ")"}], " ", "tval"}], "]"}], 
        " ", "-", " ", 
        RowBox[{"MatrixPower", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"MatrixExp", "[", 
            RowBox[{
             RowBox[{"-", "I"}], " ", "a", " ", 
             RowBox[{"tval", "/", "n"}]}], "]"}], " ", ".", " ", 
           RowBox[{"MatrixExp", "[", 
            RowBox[{
             RowBox[{"-", "I"}], " ", "b", " ", 
             RowBox[{"tval", "/", "n"}]}], "]"}]}], ",", " ", "n"}], "]"}]}], 
       ",", " ", "\"\<Frobenius\>\""}], "]"}], ",", " ", 
     RowBox[{"{", 
      RowBox[{"n", ",", " ", 
       RowBox[{"{", 
        RowBox[{
        "1", ",", " ", "2", ",", " ", "5", ",", " ", "20", ",", " ", "100"}], 
        "}"}]}], "}"}]}], "]"}]}], "]"}]], "Input",
 CellLabel->
  "In[35]:= ",ExpressionUUID->"d2d2f6b1-9a7b-47b2-8ffa-4117f1b11396"],

Cell[TextData[{
 StyleBox["QF",
  FontWeight->"Bold"],
 " : the paclet's named ",
 Cell[BoxData["\"\<Trotterization\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "5802632a-3974-44ba-a303-4b2f07e26bda"],
 " circuit builds the same alternating sequence directly from the term list; \
its overall operator approaches the exact propagator."
}], "Text",ExpressionUUID->"ab077f1c-672d-4f1d-80b8-a9fe94f0d91a"],

Cell[BoxData[
 RowBox[{"With", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"tval", " ", "=", " ", "1."}], "}"}], ",", " ", 
   RowBox[{"Table", "[", 
    RowBox[{
     RowBox[{"Norm", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"MatrixExp", "[", 
         RowBox[{
          RowBox[{"-", "I"}], " ", 
          RowBox[{"(", 
           RowBox[{
            RowBox[{"PauliMatrix", "[", "1", "]"}], " ", "+", " ", 
            RowBox[{"PauliMatrix", "[", "3", "]"}]}], ")"}], " ", "tval"}], 
         "]"}], " ", "-", " ", 
        RowBox[{"Normal", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"QuantumCircuitOperator", "[", 
            RowBox[{"\"\<Trotterization\>\"", "[", 
             RowBox[{
              RowBox[{"{", 
               RowBox[{
                RowBox[{"QuantumOperator", "[", "\"\<X\>\"", "]"}], ",", " ", 
                
                RowBox[{"QuantumOperator", "[", "\"\<Z\>\"", "]"}]}], "}"}], ",",
               " ", "1", ",", " ", "n", ",", " ", "tval"}], "]"}], "]"}], 
           "[", "\"\<QuantumOperator\>\"", "]"}], "[", "\"\<Matrix\>\"", 
          "]"}], "]"}]}], ",", " ", "\"\<Frobenius\>\""}], "]"}], ",", " ", 
     RowBox[{"{", 
      RowBox[{"n", ",", " ", 
       RowBox[{"{", 
        RowBox[{
        "1", ",", " ", "2", ",", " ", "5", ",", " ", "20", ",", " ", "100"}], 
        "}"}]}], "}"}]}], "]"}]}], "]"}]], "Input",
 CellLabel->
  "In[36]:= ",ExpressionUUID->"881c06ac-85d4-4808-a256-f6dbb559e67f"],

Cell[TextData[{
 "Both error sequences decrease toward zero as ",
 Cell[BoxData[
  StyleBox["n", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "e4d9d3f9-31bc-443b-ae04-c7aa18cfbe92"],
 " increases, and the WL product and the QF circuit track each other: \
splitting the evolution into fine slices lets a quantum simulator build ",
 Cell[BoxData[
  SuperscriptBox[
   StyleBox["e", "TI"], 
   RowBox[{"-", 
    StyleBox["i", "TI"], 
    OverscriptBox[
     StyleBox["H", "TI"], "^"], 
    StyleBox["t", "TI"]}]]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "7cfeafdb-4204-477b-8428-7e949d87de68"],
 " from elementary gates for each term, the workhorse of digital Hamiltonian \
simulation, at the cost of a controllable Trotter error set by the terms' \
noncommutativity ",
 Cell[BoxData[
  RowBox[{
   StyleBox["[",
    SpanMaxSize->1], 
   RowBox[{
    StyleBox["A", "TI"], ",", 
    StyleBox["B", "TI"]}], 
   StyleBox["]",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "2d212c2c-3fc8-460c-9663-7ee34a3d87b1"],
 "."
}], "Text",ExpressionUUID->"0eabb3b6-5bea-4e98-81a9-5223b1b1e7b5"],

Cell["\<\
7.12 [MSc] How do I verify the adiabatic theorem's gap and rate condition \
(the transition probability vanishing when the sweep is slow compared to the \
inverse gap squared)?\
\>", "Subsection",ExpressionUUID->"f5201090-9529-41e3-862c-b37a208ba39d"],

Cell[TextData[{
 "The adiabatic theorem says a system stays in an instantaneous eigenstate if \
the Hamiltonian changes slowly compared to the square of its spectral gap. \
The clean finite-dimensional test is a Landau-Zener sweep, ",
 Cell[BoxData[
  RowBox[{
   OverscriptBox[
    StyleBox["H", "TI"], "^"], 
   StyleBox["(",
    SpanMaxSize->1], 
   StyleBox["t", "TI"], 
   StyleBox[")",
    SpanMaxSize->1], "=", "\[CapitalDelta]", " ", 
   StyleBox["X", "TI"], "+", 
   StyleBox["v", "TI"], 
   StyleBox["t", "TI"], " ", 
   StyleBox["Z", "TI"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "495e59d6-24a1-4fce-95c7-78f994c72ce2"],
 ": start in the ground state at large negative ",
 Cell[BoxData[
  StyleBox["t", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "3ed8b951-68a3-4b88-b8aa-538b58f12351"],
 " and measure the excited-state population at large positive ",
 Cell[BoxData[
  StyleBox["t", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "c2d7221d-7499-43a0-beab-6853e1f689b6"],
 "; the Landau-Zener formula predicts ",
 Cell[BoxData[
  RowBox[{
   SubscriptBox[
    StyleBox["P", "TI"], 
    StyleBox["exc",
     FontSlant->"Plain"]], "=", 
   SuperscriptBox[
    StyleBox["e", "TI"], 
    RowBox[{"-", "\[Pi]", 
     SuperscriptBox["\[CapitalDelta]", "2"], "/", 
     StyleBox["v", "TI"]}]]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "da143189-c355-4065-acee-8be0f38de9e7"],
 ", which vanishes as the sweep rate ",
 Cell[BoxData[
  RowBox[{
   StyleBox["v", "TI"], "\[Rule]", "0"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "f5b77b50-cde4-41b2-a0c0-bea8432972c0"],
 " (slow) and the gap ",
 Cell[BoxData["\[CapitalDelta]"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "49e0c1ed-51a8-4388-9a64-02234eb8e319"],
 " grows."
}], "Text",ExpressionUUID->"ffd9d557-d5a5-4388-84dc-c444f0287e22"],

Cell[TextData[{
 StyleBox["WL",
  FontWeight->"Bold"],
 " : integrate the time-dependent Schrodinger equation across the crossing \
with ",
 Cell[BoxData["NDSolve"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "6e830671-70cb-462a-9ee5-1b831b3f2049"],
 " for a few sweep rates, and compare the final excited population with the \
Landau-Zener prediction."
}], "Text",ExpressionUUID->"0bc932a6-7f85-4eeb-b370-6dbdcffe9295"],

Cell[BoxData[
 RowBox[{"With", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{"\[CapitalDelta]", " ", "=", " ", "1."}], ",", " ", 
     RowBox[{"T", " ", "=", " ", "40."}]}], "}"}], ",", " ", 
   RowBox[{"Table", "[", 
    RowBox[{
     RowBox[{"With", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{"ground", " ", "=", " ", 
          RowBox[{"Normalize", "[", 
           RowBox[{
            RowBox[{"First", "[", 
             RowBox[{"SortBy", "[", 
              RowBox[{
               RowBox[{"Transpose", "[", 
                RowBox[{"Eigensystem", "[", 
                 RowBox[{
                  RowBox[{"\[CapitalDelta]", " ", 
                   RowBox[{"PauliMatrix", "[", "1", "]"}]}], " ", "-", " ", 
                  RowBox[{"v", " ", "T", " ", 
                   RowBox[{"PauliMatrix", "[", "3", "]"}]}]}], "]"}], "]"}], ",",
                " ", "First"}], "]"}], "]"}], "[", 
            RowBox[{"[", "2", "]"}], "]"}], "]"}]}], ",", " ", 
         RowBox[{"excited", " ", "=", " ", 
          RowBox[{"Normalize", "[", 
           RowBox[{
            RowBox[{"Last", "[", 
             RowBox[{"SortBy", "[", 
              RowBox[{
               RowBox[{"Transpose", "[", 
                RowBox[{"Eigensystem", "[", 
                 RowBox[{
                  RowBox[{"\[CapitalDelta]", " ", 
                   RowBox[{"PauliMatrix", "[", "1", "]"}]}], " ", "+", " ", 
                  RowBox[{"v", " ", "T", " ", 
                   RowBox[{"PauliMatrix", "[", "3", "]"}]}]}], "]"}], "]"}], ",",
                " ", "First"}], "]"}], "]"}], "[", 
            RowBox[{"[", "2", "]"}], "]"}], "]"}]}]}], "}"}], ",", " ", 
       RowBox[{"With", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"sol", " ", "=", " ", 
           RowBox[{"NDSolveValue", "[", 
            RowBox[{
             RowBox[{"{", 
              RowBox[{
               RowBox[{
                RowBox[{"I", " ", 
                 RowBox[{
                  RowBox[{"\[Psi]", "'"}], "[", "t", "]"}]}], " ", "==", " ", 
                
                RowBox[{
                 RowBox[{"(", 
                  RowBox[{
                   RowBox[{"\[CapitalDelta]", " ", 
                    RowBox[{"PauliMatrix", "[", "1", "]"}]}], " ", "+", " ", 
                   RowBox[{"v", " ", "t", " ", 
                    RowBox[{"PauliMatrix", "[", "3", "]"}]}]}], ")"}], " ", ".",
                  " ", 
                 RowBox[{"\[Psi]", "[", "t", "]"}]}]}], ",", " ", 
               RowBox[{
                RowBox[{"\[Psi]", "[", 
                 RowBox[{"-", "T"}], "]"}], " ", "==", " ", "ground"}]}], 
              "}"}], ",", " ", "\[Psi]", ",", " ", 
             RowBox[{"{", 
              RowBox[{"t", ",", " ", 
               RowBox[{"-", "T"}], ",", " ", "T"}], "}"}]}], "]"}]}], "}"}], ",",
          " ", 
         RowBox[{"{", 
          RowBox[{"v", ",", " ", 
           RowBox[{
            RowBox[{"Abs", "[", 
             RowBox[{
              RowBox[{"Conjugate", "[", "excited", "]"}], " ", ".", " ", 
              RowBox[{"sol", "[", "T", "]"}]}], "]"}], "^", "2"}], ",", " ", 
           RowBox[{"Exp", "[", 
            RowBox[{
             RowBox[{"-", "Pi"}], " ", 
             RowBox[{
              RowBox[{"\[CapitalDelta]", "^", "2"}], "/", "v"}]}], "]"}]}], 
          "}"}]}], "]"}]}], "]"}], ",", " ", 
     RowBox[{"{", 
      RowBox[{"v", ",", " ", 
       RowBox[{"{", 
        RowBox[{"2.", ",", " ", "1.", ",", " ", "0.5"}], "}"}]}], "}"}]}], 
    "]"}]}], "]"}]], "Input",
 CellLabel->
  "In[37]:= ",ExpressionUUID->"54c7b547-d37b-4bce-8762-c67b4e5517a5"],

Cell[TextData[{
 StyleBox["QF",
  FontWeight->"Bold"],
 " : the instantaneous gap that controls the sweep, the difference of the two \
eigenvalues of ",
 Cell[BoxData[
  RowBox[{
   OverscriptBox[
    StyleBox["H", "TI"], "^"], 
   StyleBox["(",
    SpanMaxSize->1], 
   StyleBox["t", "TI"], 
   StyleBox[")",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "cf51d947-9e9b-4bd2-bf6f-a60a2709c75c"],
 ", read from a ",
 Cell[BoxData["QuantumOperator"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "1093dc80-40cf-49e8-8750-9db81bb5f0da"],
 " at the crossing ",
 Cell[BoxData[
  RowBox[{
   StyleBox["t", "TI"], "=", "0"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "eee8e9d2-6a27-44de-a3ad-9fc451d39402"],
 " where it is smallest."
}], "Text",ExpressionUUID->"3ca62f00-fba3-41c5-809f-f7c2a7b6ef00"],

Cell[BoxData[
 RowBox[{"With", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"\[CapitalDelta]", " ", "=", " ", "1."}], "}"}], ",", " ", 
   RowBox[{"Differences", "[", 
    RowBox[{
     RowBox[{"QuantumOperator", "[", 
      RowBox[{"\[CapitalDelta]", " ", 
       RowBox[{"PauliMatrix", "[", "1", "]"}]}], "]"}], 
     "[", "\"\<Eigenvalues\>\"", "]"}], "]"}]}], "]"}]], "Input",
 CellLabel->
  "In[38]:= ",ExpressionUUID->"1c029a82-9bb7-431a-a2c4-6476b04b822f"],

Cell[TextData[{
 "As the sweep slows the measured excited population drops toward zero and \
tracks ",
 Cell[BoxData[
  SuperscriptBox[
   StyleBox["e", "TI"], 
   RowBox[{"-", "\[Pi]", 
    SuperscriptBox["\[CapitalDelta]", "2"], "/", 
    StyleBox["v", "TI"]}]]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "e3ccae4c-36f4-49b4-ae72-841272cd6813"],
 ": the crossing is traversed adiabatically when the time spent near the \
minimum gap ",
 Cell[BoxData[
  RowBox[{"2", "\[CapitalDelta]"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "1b55cfd0-26be-4458-bf4f-85a10b38d932"],
 " is long compared to ",
 Cell[BoxData[
  RowBox[{"1", "/", "\[CapitalDelta]"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "1341232d-2af9-42ea-9226-1a16daf4d7f3"],
 ", so a larger gap or a slower sweep both protect the ground state, the \
principle behind adiabatic quantum computation."
}], "Text",ExpressionUUID->"8aa11d73-8fb7-4b10-a371-917634470a2e"],

Cell[TextData[{
 "7.13 [MSc] How do I compute Berry's geometric phase around a closed loop as \
the discrete Bargmann invariant ",
 Cell[BoxData[
  RowBox[{
   StyleBox["\[Gamma]", "TI"], "=", 
   RowBox[{
    RowBox[{"-", 
     StyleBox["arg",
      FontSlant->"Plain"]}], 
    RowBox[{
     UnderscriptBox["\[Product]", 
      StyleBox["k", "TI"],
      LimitsPositioning->False], 
     TemplateBox[{
       SubscriptBox[
        StyleBox["\[Psi]", "TI"], 
        StyleBox["k", "TI"]], 
       SubscriptBox[
        StyleBox["\[Psi]", "TI"], 
        RowBox[{
          StyleBox["k", "TI"], "+", "1"}]]},
      "BraKet"]}]}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "10350671-3ebf-49de-b9c3-8f6420fc8998"],
 "?"
}], "Subsection",ExpressionUUID->"0b1373a9-d72c-4244-a080-20ee8f8a2438"],

Cell[TextData[{
 "Berry's phase is the geometric (basis- and gauge-independent) phase a state \
acquires around a closed loop in parameter space, over and above the \
dynamical phase. Discretized, it is the Bargmann invariant ",
 Cell[BoxData[
  RowBox[{
   StyleBox["\[Gamma]", "TI"], "=", 
   RowBox[{
    RowBox[{"-", 
     StyleBox["arg",
      FontSlant->"Plain"]}], 
    RowBox[{
     UnderscriptBox["\[Product]", 
      StyleBox["k", "TI"],
      LimitsPositioning->False], 
     TemplateBox[{
       SubscriptBox[
        StyleBox["\[Psi]", "TI"], 
        StyleBox["k", "TI"]], 
       SubscriptBox[
        StyleBox["\[Psi]", "TI"], 
        RowBox[{
          StyleBox["k", "TI"], "+", "1"}]]},
      "BraKet"]}]}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "4ba6d449-8fdd-4755-873b-269c1b451670"],
 " over a closed chain ",
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     SubscriptBox[
      StyleBox["\[Psi]", "TI"], 
      StyleBox["N", "TI"]]},
    "Ket"], "\[Congruent]", 
   TemplateBox[{
     SubscriptBox[
      StyleBox["\[Psi]", "TI"], "0"]},
    "Ket"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "5f351fb9-d642-4597-8cea-da075da082f9"],
 ", which needs no derivative or gauge choice. For a spin-1/2 following the \
ground state of ",
 Cell[BoxData[
  RowBox[{
   OverscriptBox[
    StyleBox["n", "TI"], "^"], 
   StyleBox["(",
    SpanMaxSize->1], 
   StyleBox["s", "TI"], 
   StyleBox[")",
    SpanMaxSize->1], "\[CenterDot]", 
   OverscriptBox[
    StyleBox["\[Sigma]", "TI"], "\[RightVector]"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "3b10f4ac-f543-48af-88c7-cca1dcc224dd"],
 " as ",
 Cell[BoxData[
  OverscriptBox[
   StyleBox["n", "TI"], "^"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "75fa257e-56df-4856-b1fb-65d5c18a340b"],
 " traces a cone of half-angle ",
 Cell[BoxData[
  StyleBox["\[Chi]", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "df7fb26a-44c9-4762-b140-7320d9e1519a"],
 ", the Berry phase is minus half the enclosed solid angle, ",
 Cell[BoxData[
  RowBox[{
   StyleBox["\[Gamma]", "TI"], "=", "-", "\[Pi]", 
   StyleBox["(",
    SpanMaxSize->1], 
   RowBox[{"1", "-", 
    StyleBox["cos",
     FontSlant->"Plain"], "\[ThinSpace]", 
    StyleBox["\[Chi]", "TI"]}], 
   StyleBox[")",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "1db4d4d2-5c53-47e5-a2a3-a439a553e4b6"],
 "."
}], "Text",ExpressionUUID->"6b66e176-f6ab-4d4b-ad09-35677ae8944f"],

Cell[TextData[{
 StyleBox["WL",
  FontWeight->"Bold"],
 " : place ",
 Cell[BoxData[
  StyleBox["N", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "ef1c93be-1fc4-4b98-866e-75bb19ffdc45"],
 " spin-down states around the cone, form the ordered product of \
nearest-neighbour overlaps, and take minus its argument; compare with ",
 Cell[BoxData[
  RowBox[{"-", "\[Pi]", 
   StyleBox["(",
    SpanMaxSize->1], 
   RowBox[{"1", "-", 
    StyleBox["cos",
     FontSlant->"Plain"], "\[ThinSpace]", 
    StyleBox["\[Chi]", "TI"]}], 
   StyleBox[")",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "625699ab-4d9f-401b-aecb-5c3bef8cb685"],
 "."
}], "Text",ExpressionUUID->"3e0e26b3-9e4b-4c90-8a51-a1770beb9f97"],

Cell[BoxData[
 RowBox[{"With", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{"\[Chi]", " ", "=", " ", 
      RowBox[{"Pi", "/", "3"}]}], ",", " ", 
     RowBox[{"n", " ", "=", " ", "200"}]}], "}"}], ",", " ", 
   RowBox[{"With", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"states", " ", "=", " ", 
       RowBox[{"Table", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{
           RowBox[{"Cos", "[", 
            RowBox[{"\[Chi]", "/", "2"}], "]"}], ",", " ", 
           RowBox[{
            RowBox[{"Exp", "[", 
             RowBox[{"I", " ", "2", " ", "Pi", " ", 
              RowBox[{"k", "/", "n"}]}], "]"}], " ", 
            RowBox[{"Sin", "[", 
             RowBox[{"\[Chi]", "/", "2"}], "]"}]}]}], "}"}], ",", " ", 
         RowBox[{"{", 
          RowBox[{"k", ",", " ", "0", ",", " ", "n"}], "}"}]}], "]"}]}], 
      "}"}], ",", " ", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"-", 
        RowBox[{"Total", "[", 
         RowBox[{"Table", "[", 
          RowBox[{
           RowBox[{"Arg", "[", 
            RowBox[{"N", "[", 
             RowBox[{
              RowBox[{"Conjugate", "[", 
               RowBox[{"states", "[", 
                RowBox[{"[", "k", "]"}], "]"}], "]"}], " ", ".", " ", 
              RowBox[{"states", "[", 
               RowBox[{"[", 
                RowBox[{"k", " ", "+", " ", "1"}], "]"}], "]"}]}], "]"}], 
            "]"}], ",", " ", 
           RowBox[{"{", 
            RowBox[{"k", ",", " ", "n"}], "}"}]}], "]"}], "]"}]}], ",", " ", 
       RowBox[{"N", "[", 
        RowBox[{
         RowBox[{"-", "Pi"}], " ", 
         RowBox[{"(", 
          RowBox[{"1", " ", "-", " ", 
           RowBox[{"Cos", "[", "\[Chi]", "]"}]}], ")"}]}], "]"}]}], "}"}]}], 
    "]"}]}], "]"}]], "Input",
 CellLabel->
  "In[39]:= ",ExpressionUUID->"f66980eb-9f3c-4b66-9a8c-de6a2ff91b13"],

Cell[TextData[{
 StyleBox["QF",
  FontWeight->"Bold"],
 " : the same loop with the overlaps taken as object inner products ",
 Cell[BoxData[
  TemplateBox[{
    SubscriptBox[
     StyleBox["\[Psi]", "TI"], 
     StyleBox["k", "TI"]], 
    SubscriptBox[
     StyleBox["\[Psi]", "TI"], 
     RowBox[{
       StyleBox["k", "TI"], "+", "1"}]]},
   "BraKet"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "e5c25052-191e-4513-a01f-773ae1e6c73d"],
 " through ",
 Cell[BoxData["QuantumState"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "b85dd6fc-5dbf-48ee-9ce5-3e8ffb8af147"],
 ", ",
 Cell[BoxData["\"\<Dagger\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "d5401a02-cd0c-4ec2-9509-41a327dd6546"],
 ", and ",
 Cell[BoxData["\"\<Scalar\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "c6da153e-e4bc-4e25-915b-44d26de4fe2f"],
 "."
}], "Text",ExpressionUUID->"57338f48-6caf-425d-a79d-afe3d320d162"],

Cell[BoxData[
 RowBox[{"With", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{"\[Chi]", " ", "=", " ", 
      RowBox[{"Pi", "/", "3"}]}], ",", " ", 
     RowBox[{"n", " ", "=", " ", "200"}]}], "}"}], ",", " ", 
   RowBox[{"With", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"states", " ", "=", " ", 
       RowBox[{"Table", "[", 
        RowBox[{
         RowBox[{"QuantumState", "[", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"Cos", "[", 
             RowBox[{"\[Chi]", "/", "2"}], "]"}], ",", " ", 
            RowBox[{
             RowBox[{"Exp", "[", 
              RowBox[{"I", " ", "2", " ", "Pi", " ", 
               RowBox[{"k", "/", "n"}]}], "]"}], " ", 
             RowBox[{"Sin", "[", 
              RowBox[{"\[Chi]", "/", "2"}], "]"}]}]}], "}"}], "]"}], ",", " ", 
         RowBox[{"{", 
          RowBox[{"k", ",", " ", "0", ",", " ", "n"}], "}"}]}], "]"}]}], 
      "}"}], ",", " ", 
     RowBox[{"-", 
      RowBox[{"Total", "[", 
       RowBox[{"Table", "[", 
        RowBox[{
         RowBox[{"Arg", "[", 
          RowBox[{"N", "[", 
           RowBox[{
            RowBox[{"(", 
             RowBox[{
              RowBox[{
               RowBox[{"states", "[", 
                RowBox[{"[", "k", "]"}], "]"}], "[", "\"\<Dagger\>\"", "]"}], 
              " ", "@", " ", 
              RowBox[{"states", "[", 
               RowBox[{"[", 
                RowBox[{"k", " ", "+", " ", "1"}], "]"}], "]"}]}], ")"}], 
            "[", "\"\<Scalar\>\"", "]"}], "]"}], "]"}], ",", " ", 
         RowBox[{"{", 
          RowBox[{"k", ",", " ", "n"}], "}"}]}], "]"}], "]"}]}]}], "]"}]}], 
  "]"}]], "Input",
 CellLabel->
  "In[40]:= ",ExpressionUUID->"21f9fdfb-7993-4673-8859-8ce5ffdba063"],

Cell[TextData[{
 "Both return ",
 Cell[BoxData[
  RowBox[{"-", "\[Pi]", 
   StyleBox["(",
    SpanMaxSize->1], 
   RowBox[{"1", "-", 
    StyleBox["cos",
     FontSlant->"Plain"], "\[ThinSpace]", 
    FractionBox["\[Pi]", "3"]}], 
   StyleBox[")",
    SpanMaxSize->1], "=", "-", 
   FractionBox["\[Pi]", "2"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "3d6ef02f-407f-4813-9866-64ad8ba3306b"],
 ": the accumulated phase depends only on the ",
 StyleBox["geometry", "TI"],
 " of the loop (the solid angle it subtends), not on how fast or by what \
schedule it is traversed, which is what makes Berry's phase observable and \
robust."
}], "Text",ExpressionUUID->"19292be6-38ef-40eb-ba66-a579179be0e7"],

Cell["\<\
7.14 [MSc] How do I simulate a quantum quench and compute the Loschmidt echo?\
\
\>", "Subsection",ExpressionUUID->"7a768980-2b34-4e25-899b-9e4f9e921c46"],

Cell[TextData[{
 "A quench prepares the ground state of one Hamiltonian and then suddenly \
evolves it under a different one. The Loschmidt echo ",
 Cell[BoxData[
  RowBox[{
   RowBox[{
    StyleBox["L", "TI"], 
    RowBox[{
     StyleBox["(",
      SpanMaxSize->1], 
     StyleBox["t", "TI"], 
     StyleBox[")",
      SpanMaxSize->1]}]}], "=", 
   SuperscriptBox[GridBox[{
      {
       RowBox[{
        TemplateBox[{
          SubscriptBox[
           StyleBox["\[Psi]", "TI"], "0"]},
         "Bra"], 
        SuperscriptBox[
         StyleBox["e", "TI"], 
         RowBox[{"-", 
          StyleBox["i", "TI"], 
          SubscriptBox[
           OverscriptBox[
            StyleBox["H", "TI"], "^"], "1"], 
          StyleBox["t", "TI"]}]], 
        TemplateBox[{
          SubscriptBox[
           StyleBox["\[Psi]", "TI"], "0"]},
         "Ket"]}]}
     },
     GridBoxDividers->{"Columns" -> {True, True}, "Rows" -> {}},
     GridBoxSpacings->{"Columns" -> {{0.15}}}], "2"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "1a026df2-2796-48cb-ab0a-f0990c64c084"],
 " measures how fast the state runs away from its start, a diagnostic of the \
quench strength. Prepare the ground state ",
 Cell[BoxData[
  TemplateBox[{"1"},
   "Ket"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "6555e529-f639-48a3-9215-37b217ccdb1f"],
 " of ",
 Cell[BoxData[
  RowBox[{
   SubscriptBox[
    OverscriptBox[
     StyleBox["H", "TI"], "^"], "0"], "=", 
   FractionBox[
    StyleBox["\[Omega]", "TI"], "2"], 
   StyleBox["Z", "TI"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "b95fb375-e4eb-4e83-91f5-695dfd6674b3"],
 " (",
 Cell[BoxData[
  RowBox[{
   StyleBox["\[Omega]", "TI"], ">", "0"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "23842d75-012d-4e30-b0bb-47d3a69ff456"],
 ") and quench to ",
 Cell[BoxData[
  RowBox[{
   SubscriptBox[
    OverscriptBox[
     StyleBox["H", "TI"], "^"], "1"], "=", 
   FractionBox["\[CapitalOmega]", "2"], 
   StyleBox["X", "TI"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "d8ac2e37-6f82-4875-88b5-f0a4ec335aed"],
 "."
}], "Text",ExpressionUUID->"bda8a014-ab8a-4b71-8857-984b32b9b470"],

Cell[TextData[{
 StyleBox["WL",
  FontWeight->"Bold"],
 " : evolve ",
 Cell[BoxData[
  TemplateBox[{"1"},
   "Ket"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "0053ae55-0eb3-40c9-9a1f-19d55fde51f8"],
 " under ",
 Cell[BoxData[
  SubscriptBox[
   OverscriptBox[
    StyleBox["H", "TI"], "^"], "1"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "50565142-f5b9-463b-a10e-0314bf62d38e"],
 " and take the modulus-squared overlap with ",
 Cell[BoxData[
  TemplateBox[{"1"},
   "Ket"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "0b9ee0b4-af7c-41b5-b162-d6fa03e87105"],
 "."
}], "Text",ExpressionUUID->"cd5fc225-ef04-40bb-a8c1-eb5393685f01"],

Cell[BoxData[
 RowBox[{"With", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"\[Psi]0", " ", "=", " ", 
     RowBox[{"{", 
      RowBox[{"0", ",", " ", "1"}], "}"}]}], "}"}], ",", " ", 
   RowBox[{"Simplify", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"Abs", "[", 
       RowBox[{
        RowBox[{"Conjugate", "[", "\[Psi]0", "]"}], " ", ".", " ", 
        RowBox[{"(", 
         RowBox[{
          RowBox[{"MatrixExp", "[", 
           RowBox[{
            RowBox[{"-", "I"}], " ", 
            RowBox[{"(", 
             RowBox[{"\[CapitalOmega]", "/", "2"}], ")"}], " ", 
            RowBox[{"PauliMatrix", "[", "1", "]"}], " ", "t"}], "]"}], " ", ".",
           " ", "\[Psi]0"}], ")"}]}], "]"}], "^", "2"}], ",", " ", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"\[CapitalOmega]", ",", " ", "t"}], "}"}], " ", "\[Element]", 
      " ", "Reals"}]}], "]"}]}], "]"}]], "Input",
 CellLabel->
  "In[41]:= ",ExpressionUUID->"d751c716-8108-44aa-aeb6-e2282f2e5c38"],

Cell[TextData[{
 StyleBox["QF",
  FontWeight->"Bold"],
 " : evolve the named ",
 Cell[BoxData["\"\<1\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "318ef3ab-6727-402c-9032-62dce5bcb7e1"],
 " state under ",
 Cell[BoxData[
  SubscriptBox[
   OverscriptBox[
    StyleBox["H", "TI"], "^"], "1"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "9252f90b-3481-49e3-9f8c-7260831f5d2b"],
 " with ",
 Cell[BoxData["QuantumEvolve"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "dddd2c31-5416-4211-b94d-a55f18747ae7"],
 " and take its overlap with the start through the object sandwich."
}], "Text",ExpressionUUID->"dac39511-4749-4fd0-8654-35704fd0dbfe"],

Cell[BoxData[
 RowBox[{"With", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"qs0", " ", "=", " ", 
     RowBox[{"QuantumState", "[", "\"\<1\>\"", "]"}]}], "}"}], ",", " ", 
   RowBox[{"Simplify", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"Abs", "[", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{
          RowBox[{"qs0", "[", "\"\<Dagger\>\"", "]"}], " ", "@", " ", 
          RowBox[{"QuantumEvolve", "[", 
           RowBox[{
            RowBox[{"QuantumOperator", "[", 
             RowBox[{
              RowBox[{"(", 
               RowBox[{"\[CapitalOmega]", "/", "2"}], ")"}], " ", 
              RowBox[{"PauliMatrix", "[", "1", "]"}]}], "]"}], ",", " ", 
            RowBox[{"QuantumState", "[", "\"\<1\>\"", "]"}], ",", " ", "t"}], 
           "]"}]}], ")"}], "[", "\"\<Scalar\>\"", "]"}], "]"}], "^", "2"}], ",",
      " ", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"\[CapitalOmega]", ",", " ", "t"}], "}"}], " ", "\[Element]", 
      " ", "Reals"}]}], "]"}]}], "]"}]], "Input",
 CellLabel->
  "In[42]:= ",ExpressionUUID->"9b792272-11ed-4bef-bb8e-6e66295a0b67"],

Cell[TextData[{
 "Both give ",
 Cell[BoxData[
  RowBox[{
   StyleBox["L", "TI"], 
   StyleBox["(",
    SpanMaxSize->1], 
   StyleBox["t", "TI"], 
   StyleBox[")",
    SpanMaxSize->1], "=", 
   SuperscriptBox[
    StyleBox["cos",
     FontSlant->"Plain"], "2"], "\[ThinSpace]", 
   FractionBox[
    RowBox[{"\[CapitalOmega]", 
     StyleBox["t", "TI"]}], "2"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "0fe14135-1e04-43cb-9753-3a62d62c279e"],
 ": the echo dips from ",
 Cell[BoxData["1"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "a7fd7f2f-97c2-464f-b857-3650c4cdd813"],
 " as the state explores the new Hamiltonian and revives fully at ",
 Cell[BoxData[
  RowBox[{
   StyleBox["t", "TI"], "=", "2", "\[Pi]", "/", "\[CapitalOmega]"}]], 
  "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "55599f28-dd09-4d65-bbf1-69d47d77e8eb"],
 " because a single qubit has only one Bohr frequency; in a many-body system \
the many incommensurate frequencies would make the echo decay and \
(generically) never fully revive."
}], "Text",ExpressionUUID->"afecd323-1e86-4109-b38a-b8e40c718821"],

Cell["\<\
7.15 [MSc] How do I exhibit the quantum Zeno effect, freezing evolution under \
a Hamiltonian by frequent projective measurement?\
\>", "Subsection",ExpressionUUID->"6c8a762f-530b-423c-8aeb-d2149694e735"],

Cell[TextData[{
 "The quantum Zeno effect freezes a state by watching it: under ",
 Cell[BoxData[
  OverscriptBox[
   StyleBox["H", "TI"], "^"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "e862940b-2358-42e2-8fee-dbb798252c19"],
 ", the survival probability after a short time ",
 Cell[BoxData[
  StyleBox["\[Tau]", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "2127dbd4-ba75-4644-8e7e-399c954b0ffb"],
 " is ",
 Cell[BoxData[
  RowBox[{"1", "-", 
   StyleBox["O", "TI"], 
   StyleBox["(",
    SpanMaxSize->1], 
   SuperscriptBox[
    StyleBox["\[Tau]", "TI"], "2"], 
   StyleBox[")",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "f8847329-ffcd-480c-897c-221c6bab2321"],
 ", so ",
 Cell[BoxData[
  StyleBox["n", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "fa3826bf-8df3-4eb8-9fc7-9bcb672df5b6"],
 " measurements spaced ",
 Cell[BoxData[
  RowBox[{
   StyleBox["\[Tau]", "TI"], "=", 
   StyleBox["t", "TI"], "/", 
   StyleBox["n", "TI"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "48a92d3b-bbf5-4b37-824e-2072bbfdd403"],
 " apart give a total survival ",
 Cell[BoxData[
  RowBox[{"\[TildeTilde]", 
   SuperscriptBox[
    RowBox[{
     StyleBox["(",
      SpanMaxSize->1], 
     RowBox[{"1", "-", 
      StyleBox["O", "TI"], 
      StyleBox["(",
       SpanMaxSize->1], 
      RowBox[{
       SuperscriptBox[
        StyleBox["t", "TI"], "2"], "/", 
       SuperscriptBox[
        StyleBox["n", "TI"], "2"]}], 
      StyleBox[")",
       SpanMaxSize->1]}], 
     StyleBox[")",
      SpanMaxSize->1]}], 
    StyleBox["n", "TI"]], "\[Rule]", "1"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "68d137bc-a664-41ba-becd-4c750d0119bb"],
 " as ",
 Cell[BoxData[
  RowBox[{
   StyleBox["n", "TI"], "\[Rule]", "\[Infinity]"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "27809b97-5aa0-4a91-8c23-121db6140d15"],
 ". Take ",
 Cell[BoxData[
  RowBox[{
   OverscriptBox[
    StyleBox["H", "TI"], "^"], "=", 
   FractionBox["\[CapitalOmega]", "2"], 
   StyleBox["X", "TI"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "1419e958-2c2a-4095-bf50-c12fd2852325"],
 " evolving ",
 Cell[BoxData[
  TemplateBox[{"0"},
   "Ket"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "68f8204b-4896-4341-9ac4-b8214578ee6f"],
 " (which without measurement Rabi-flops to ",
 Cell[BoxData[
  TemplateBox[{"1"},
   "Ket"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "db4af344-5220-4300-a2b0-5b27cf139cab"],
 "), and interleave projective ",
 Cell[BoxData[
  StyleBox["Z", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "a88bc0ee-3a30-46ae-9904-5f237d5a90a7"],
 " measurements."
}], "Text",ExpressionUUID->"3af953d6-9e17-4744-860b-992dc2b26612"],

Cell[TextData[{
 StyleBox["WL",
  FontWeight->"Bold"],
 " : after each short evolution project back with ",
 Cell[BoxData[
  RowBox[{
   SubscriptBox[
    StyleBox["P", "TI"], "0"], "=", 
   RowBox[{
    TemplateBox[{"0"},
     "Ket"], 
    TemplateBox[{"0"},
     "Bra"]}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "67d5aeab-6814-4aeb-bca8-97b1eef3ca07"],
 "; the surviving amplitude is ",
 Cell[BoxData[
  RowBox[{
   SuperscriptBox[
    RowBox[{
     StyleBox["(",
      SpanMaxSize->1], 
     RowBox[{
      SubscriptBox[
       StyleBox["P", "TI"], "0"], 
      StyleBox["U", "TI"], 
      StyleBox["(",
       SpanMaxSize->1], 
      StyleBox["\[Tau]", "TI"], 
      StyleBox[")",
       SpanMaxSize->1]}], 
     StyleBox[")",
      SpanMaxSize->1]}], 
    StyleBox["n", "TI"]], 
   TemplateBox[{"0"},
    "Ket"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "d6ec307d-0893-4534-8e61-8e5991717ee3"],
 ", and its norm-squared is the survival probability. Watch it rise toward ",
 Cell[BoxData["1"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "2a2d30cd-1415-4ccf-93ff-dc7e165b0978"],
 "."
}], "Text",ExpressionUUID->"8d1672ee-3fbf-4fdb-94e0-a352f0f0c9a4"],

Cell[BoxData[
 RowBox[{"With", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{"\[CapitalOmega]", " ", "=", " ", "1."}], ",", " ", 
     RowBox[{"ttot", " ", "=", " ", "Pi"}], ",", " ", 
     RowBox[{"p0", " ", "=", " ", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"1", ",", " ", "0"}], "}"}], ",", " ", 
        RowBox[{"{", 
         RowBox[{"0", ",", " ", "0"}], "}"}]}], "}"}]}]}], "}"}], ",", " ", 
   RowBox[{"Table", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"Norm", "[", 
       RowBox[{
        RowBox[{"MatrixPower", "[", 
         RowBox[{
          RowBox[{"p0", " ", ".", " ", 
           RowBox[{"MatrixExp", "[", 
            RowBox[{
             RowBox[{"-", "I"}], " ", 
             RowBox[{"(", 
              RowBox[{"\[CapitalOmega]", "/", "2"}], ")"}], " ", 
             RowBox[{"PauliMatrix", "[", "1", "]"}], " ", 
             RowBox[{"(", 
              RowBox[{"ttot", "/", "n"}], ")"}]}], "]"}]}], ",", " ", "n"}], 
         "]"}], " ", ".", " ", 
        RowBox[{"{", 
         RowBox[{"1", ",", " ", "0"}], "}"}]}], "]"}], "^", "2"}], ",", " ", 
     RowBox[{"{", 
      RowBox[{"n", ",", " ", 
       RowBox[{"{", 
        RowBox[{
        "1", ",", " ", "2", ",", " ", "5", ",", " ", "20", ",", " ", "100"}], 
        "}"}]}], "}"}]}], "]"}]}], "]"}]], "Input",
 CellLabel->
  "In[43]:= ",ExpressionUUID->"322ecd4a-0298-4f38-afc9-6dad9568ebae"],

Cell[TextData[{
 StyleBox["QF",
  FontWeight->"Bold"],
 " : the single-step survival probability ",
 Cell[BoxData[
  RowBox[{
   SuperscriptBox[
    StyleBox["cos",
     FontSlant->"Plain"], "2"], "\[ThinSpace]", 
   FractionBox[
    RowBox[{"\[CapitalOmega]", 
     StyleBox["\[Tau]", "TI"]}], "2"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "c6ab2d91-146f-4796-be6e-dcc3ddbb2486"],
 " read from the evolved state's ",
 Cell[BoxData["\"\<ProbabilitiesList\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "dd1c8480-6bdc-4414-a3ad-96b61f993f85"],
 ", the ground-state weight after one interval ",
 Cell[BoxData[
  StyleBox["\[Tau]", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "78668e05-9c47-4b0a-9ca5-35d79cfb28a8"],
 "."
}], "Text",ExpressionUUID->"7b40ba90-b5ea-4405-88b4-29721636695f"],

Cell[BoxData[
 RowBox[{"Simplify", "[", 
  RowBox[{
   RowBox[{"First", "[", 
    RowBox[{
     RowBox[{"QuantumEvolve", "[", 
      RowBox[{
       RowBox[{"QuantumOperator", "[", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{"\[CapitalOmega]", "/", "2"}], ")"}], " ", 
         RowBox[{"PauliMatrix", "[", "1", "]"}]}], "]"}], ",", " ", 
       RowBox[{"QuantumState", "[", "\"\<0\>\"", "]"}], ",", " ", "\[Tau]"}], 
      "]"}], "[", "\"\<ProbabilitiesList\>\"", "]"}], "]"}], ",", " ", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"\[CapitalOmega]", ",", " ", "\[Tau]"}], "}"}], " ", "\[Element]",
     " ", "Reals"}]}], "]"}]], "Input",
 CellLabel->
  "In[44]:= ",ExpressionUUID->"98953177-6ae7-4285-ae34-888751e29186"],

Cell[TextData[{
 "Without measurement (",
 Cell[BoxData[
  RowBox[{
   StyleBox["n", "TI"], "=", "1"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "2f5cf209-1323-44ba-a881-75e9d87f6ea8"],
 ") the ",
 Cell[BoxData["\[Pi]"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "352b3607-1081-4739-8907-031178636b8f"],
 "-pulse fully flips the qubit and the survival is ",
 Cell[BoxData["0"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "2202c97e-3601-4b9c-becb-6affcf7fb51b"],
 "; with increasingly frequent measurement the survival climbs toward ",
 Cell[BoxData["1"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "9ebb88c7-1610-413e-9809-c2401996bf23"],
 ", because each single-step survival ",
 Cell[BoxData[
  RowBox[{
   SuperscriptBox[
    StyleBox["cos",
     FontSlant->"Plain"], "2"], "\[ThinSpace]", 
   FractionBox[
    RowBox[{"\[CapitalOmega]", 
     StyleBox["\[Tau]", "TI"]}], "2"], "=", "1", "-", 
   StyleBox["O", "TI"], 
   StyleBox["(",
    SpanMaxSize->1], 
   SuperscriptBox[
    StyleBox["\[Tau]", "TI"], "2"], 
   StyleBox[")",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "3c9137cf-1587-42b5-aa5f-ca8521f9281c"],
 " and ",
 Cell[BoxData[
  StyleBox["n", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "077e09d7-f274-43f1-836b-928e573b7a8d"],
 " such factors with ",
 Cell[BoxData[
  RowBox[{
   StyleBox["\[Tau]", "TI"], "=", 
   StyleBox["t", "TI"], "/", 
   StyleBox["n", "TI"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "597aa44e-2462-46fe-9957-3f6f66ad04e1"],
 " tend to ",
 Cell[BoxData["1"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "a8470331-b702-4785-90de-75342197b12e"],
 ": continuous observation pins the state in place."
}], "Text",ExpressionUUID->"a88449c8-47cf-4897-aa21-057397f538c2"],

Cell["\<\
7.16 [BSc] How do I encode each quantum postulate as a one-line WL operation \
(state, observable, evolution, measurement, composite)?\
\>", "Subsection",ExpressionUUID->"d8ddbf95-304c-4cf4-a28f-882f786cfc29"],

Cell[TextData[{
 "The postulates of quantum mechanics each have a one-line finite-dimensional \
realization: a ",
 StyleBox["state",
  FontWeight->"Bold"],
 " is a unit vector (or density operator); an ",
 StyleBox["observable",
  FontWeight->"Bold"],
 " is a Hermitian matrix; ",
 StyleBox["evolution",
  FontWeight->"Bold"],
 " is a unitary; a ",
 StyleBox["measurement",
  FontWeight->"Bold"],
 " returns outcome ",
 Cell[BoxData[
  StyleBox["k", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "6c637ccc-854c-462d-85a0-9833b6c52f7a"],
 " with the Born probability ",
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     StyleBox["\[Psi]", "TI"]},
    "Bra"], 
   SubscriptBox[
    StyleBox["P", "TI"], 
    StyleBox["k", "TI"]], 
   TemplateBox[{
     StyleBox["\[Psi]", "TI"]},
    "Ket"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "1d24c61f-ed0c-41ab-8018-571a402a515a"],
 "; a ",
 StyleBox["composite",
  FontWeight->"Bold"],
 " system is a tensor product. Here they are, each in one line."
}], "Text",ExpressionUUID->"18937b48-2abb-4a3c-bbba-b189db1d8263"],

Cell[TextData[{
 StyleBox["WL",
  FontWeight->"Bold"],
 " : the five postulates as five native operations, collected in an \
association keyed by name."
}], "Text",ExpressionUUID->"df7806f7-8ccc-4918-bf52-f260bfd64df2"],

Cell[BoxData[
 RowBox[{"<|", 
  RowBox[{
   RowBox[{"\"\<State\>\"", " ", "->", " ", 
    RowBox[{"Normalize", "[", 
     RowBox[{"{", 
      RowBox[{"3", ",", " ", 
       RowBox[{"4", " ", "I"}]}], "}"}], "]"}]}], ",", " ", 
   RowBox[{"\"\<Observable\>\"", " ", "->", " ", 
    RowBox[{"HermitianMatrixQ", "[", 
     RowBox[{"PauliMatrix", "[", "2", "]"}], "]"}]}], ",", " ", 
   RowBox[{"\"\<Evolution\>\"", " ", "->", " ", 
    RowBox[{"UnitaryMatrixQ", "[", 
     RowBox[{"MatrixExp", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"-", "I"}], " ", 
        RowBox[{"PauliMatrix", "[", "1", "]"}], " ", "t"}], " ", "/.", " ", 
       RowBox[{"t", " ", "->", " ", "0.7"}]}], "]"}], "]"}]}], ",", " ", 
   RowBox[{"\"\<Measurement\>\"", " ", "->", " ", 
    RowBox[{"With", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"\[Psi]", " ", "=", " ", 
        RowBox[{"Normalize", "[", 
         RowBox[{"{", 
          RowBox[{"3", ",", " ", 
           RowBox[{"4", " ", "I"}]}], "}"}], "]"}]}], "}"}], ",", " ", 
      RowBox[{
       RowBox[{"Conjugate", "[", "\[Psi]", "]"}], " ", ".", " ", 
       RowBox[{"(", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{"1", ",", " ", "0"}], "}"}], ",", " ", 
           RowBox[{"{", 
            RowBox[{"0", ",", " ", "0"}], "}"}]}], "}"}], " ", ".", " ", 
         "\[Psi]"}], ")"}]}]}], "]"}]}], ",", " ", 
   RowBox[{"\"\<Composite\>\"", " ", "->", " ", 
    RowBox[{"Flatten", "[", 
     RowBox[{"KroneckerProduct", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"1", ",", " ", "0"}], "}"}], ",", " ", 
       RowBox[{"{", 
        RowBox[{"0", ",", " ", "1"}], "}"}]}], "]"}], "]"}]}]}], 
  "|>"}]], "Input",
 CellLabel->
  "In[45]:= ",ExpressionUUID->"a4cddeaa-fa73-4f3e-b11b-0d03cab8c284"],

Cell[TextData[{
 StyleBox["QF",
  FontWeight->"Bold"],
 " : the same five, each carried by the matching QF object, one property call \
apiece."
}], "Text",ExpressionUUID->"9686ef5c-07ad-4d60-8ab4-e47cee6921b1"],

Cell[BoxData[
 RowBox[{"<|", 
  RowBox[{
   RowBox[{"\"\<State\>\"", " ", "->", " ", 
    RowBox[{"Normal", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"QuantumState", "[", 
        RowBox[{"{", 
         RowBox[{"3", ",", " ", 
          RowBox[{"4", " ", "I"}]}], "}"}], "]"}], "[", "\"\<Normalized\>\"", 
       "]"}], "[", "\"\<StateVector\>\"", "]"}], "]"}]}], ",", " ", 
   RowBox[{"\"\<Observable\>\"", " ", "->", " ", 
    RowBox[{
     RowBox[{"QuantumOperator", "[", "\"\<Y\>\"", "]"}], 
     "[", "\"\<HermitianQ\>\"", "]"}]}], ",", " ", 
   RowBox[{"\"\<Evolution\>\"", " ", "->", " ", 
    RowBox[{
     RowBox[{"QuantumOperator", "[", "\"\<X\>\"", "]"}], 
     "[", "\"\<UnitaryQ\>\"", "]"}]}], ",", " ", 
   RowBox[{"\"\<Measurement\>\"", " ", "->", " ", 
    RowBox[{"First", "[", 
     RowBox[{
      RowBox[{
       RowBox[{
       "QuantumMeasurementOperator", "[", "\"\<Computational\>\"", "]"}], "[", 
       RowBox[{"QuantumState", "[", 
        RowBox[{"{", 
         RowBox[{"3", ",", " ", 
          RowBox[{"4", " ", "I"}]}], "}"}], "]"}], "]"}], 
      "[", "\"\<ProbabilitiesList\>\"", "]"}], "]"}]}], ",", " ", 
   RowBox[{"\"\<Composite\>\"", " ", "->", " ", 
    RowBox[{"Normal", "[", 
     RowBox[{
      RowBox[{"QuantumTensorProduct", "[", 
       RowBox[{
        RowBox[{"QuantumState", "[", "\"\<0\>\"", "]"}], ",", " ", 
        RowBox[{"QuantumState", "[", "\"\<1\>\"", "]"}]}], "]"}], 
      "[", "\"\<StateVector\>\"", "]"}], "]"}]}]}], "|>"}]], "Input",
 CellLabel->
  "In[46]:= ",ExpressionUUID->"1d70c751-bf52-48fa-8e0c-83023db93df5"],

Cell["\<\
Each postulate is a single constructor or property: unit vector, Hermitian \
test, unitary test, Born probability, tensor product. The QF column reads the \
same facts off objects that also know their own dimension, basis, and order, \
so the one-liners scale to qudits and many-body systems without rewriting, \
which is the throughline of this whole manual.\
\>", "Text",ExpressionUUID->"8ec76d6e-d97f-4631-afea-3336872334fa"]
},
CreateCellID->True,
FrontEndVersion->"15.0 for Mac OS X ARM (64-bit) (February 17, 2026)",
StyleDefinitions->"Default.nb",
ExpressionUUID->"9dd06bfa-f98d-4a75-a65a-285a610883c5"
]
