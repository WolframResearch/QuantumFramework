Notebook[{
Cell[554, 20, 156, 2, 70, "Title",ExpressionUUID->"ebc42fbe-a354-49c5-bb3b-7e76668d123a"],
Cell[713, 24, 306, 8, 70, "Text",ExpressionUUID->"2aa24450-5f07-4d77-a908-13a04e6e5bdb"],
Cell[1022, 34, 803, 20, 70, "ItemNumbered",ExpressionUUID->"1ef40314-9221-4217-91aa-1c4ee83426c9"],
Cell[1828, 56, 852, 18, 70, "ItemNumbered",ExpressionUUID->"0aed5f11-5b16-455f-b42d-39db11c18188"],
Cell[2683, 76, 1872, 44, 70, "Text",ExpressionUUID->"c33125a4-6a8f-4245-bb00-33f20397f468"],
Cell[4558, 122, 1255, 44, 70, "Text",ExpressionUUID->"29dc3e33-0d93-40ac-9d0e-43b9bd2af3a9"],
Cell[5816, 168, 79, 0, 70, "Section",ExpressionUUID->"7e41eeaa-18df-4cf8-9960-71984172e1be"],
