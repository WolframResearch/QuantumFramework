Cell[713, 24, 306, 8, 70, "Text",ExpressionUUID->"c8552066-a896-40fe-952e-5f55a26370a1"],
Cell[1022, 34, 940, 24, 70, "ItemNumbered",ExpressionUUID->"6346cb4b-4c83-443f-ba21-836574f1ee1e"],
Cell[1965, 60, 852, 18, 70, "ItemNumbered",ExpressionUUID->"74885922-7b38-41cb-a62e-dd5a71fcbb2a"],
Cell[2820, 80, 1505, 37, 70, "Text",ExpressionUUID->"bd9d229d-d19b-4c05-8141-5f72f50f46d7"],
Cell[4328, 119, 79, 0, 70, "Section",ExpressionUUID->"afb63be0-8b7b-4779-a237-b47a53e41109"],
Cell[4410, 121, 107, 0, 70, "Text",ExpressionUUID->"d0174434-902b-48a1-bdce-51cb6dccea36"],
Cell[4520, 123, 169, 2, 70, "Input",ExpressionUUID->"cb9cde69-2765-41f8-8c5c-3186e32cb5af"],
