(* Beginning of Notebook Content *)
Notebook[{
Cell["\<\
Quantum in Finite Dimensions: Answers in WL and in QuantumFramework\
\>", "Title",ExpressionUUID->"1e42120c-c414-4ef6-a5b3-d8cfbe3652d9"],

Cell[TextData[{
 "A companion answer key to ",
 Cell["Question-List.md", "InlineCode",ExpressionUUID->
  "8e098f87-d6fa-4b54-9d97-4008b8433ac7"],
 ". For each question it gives ",
 StyleBox["two",
  FontWeight->"Bold"],
 " worked answers:"
}], "Text",ExpressionUUID->"45b1c8b7-ad95-47b2-8668-49b40d73d3bd"],

Cell[TextData[{
 StyleBox["WL",
  FontWeight->"Bold"],
 " : native Wolfram Language only (plain vectors and matrices, ",
 Cell[BoxData["PauliMatrix"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "c1b58daa-615c-45f7-b92a-73a1cf66d7ab"],
 ", ",
 Cell[BoxData["Conjugate"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "c8baf4d4-49a1-4ea2-87fb-3fa4b61a3a2d"],
 ", ",
 Cell[BoxData["Normalize"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "e2e7375e-9300-41ca-90b8-e5e3fed27a7b"],
 ", ",
 Cell[BoxData["Eigenvectors"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "53ed4d64-5f0e-481d-8ce1-fcc42580cc74"],
 ", ",
 Cell[BoxData["MatrixExp"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "901e1217-eb38-4e9b-9db1-c98a563902aa"],
 ", and friends). Nothing beyond the built-in language."
}], "ItemNumbered",ExpressionUUID->"16c8b6d5-6269-4614-bd4a-2e7cbf2e7029"],

Cell[TextData[{
 StyleBox["QF",
  FontWeight->"Bold"],
 " : the same task done through the ",
 StyleBox["QuantumFramework",
  FontWeight->"Bold"],
 " paclet, leaning on its objects and property downvalues (",
 Cell[BoxData[
  RowBox[{
   RowBox[{"QuantumState", "[", "...", "]"}], "[", "\"\<...\>\"", "]"}]], 
  "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "d8ff1efc-1a48-4910-9a89-0673eedb9530"],
 ") rather than rebuilding matrices by hand. A QF result is a rich object, a \
state or an operator, not a bare array: it can act on a target, compose with \
others, report its spectrum, change basis, and more. The answers keep results \
as objects and treat a matrix or amplitude vector as just one of the object's \
many representations, not the thing itself."
}], "ItemNumbered",ExpressionUUID->"46cde8d3-68fe-4921-a607-b472ea032c72"],

Cell[TextData[{
 "Three habits run through the answers. They stay ",
 StyleBox["symbolic",
  FontWeight->"Bold"],
 " wherever possible (general amplitudes ",
 Cell[BoxData[
  StyleBox[
   RowBox[{"\|01d6fc", ",", "\|01d6fd"}],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "33f68022-9d87-4d52-958f-cde0b8c219f5"],
 ", general angles ",
 Cell[BoxData[
  StyleBox[
   RowBox[{"\|01d703", ",", "\[Phi]"}],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "b3d39171-07b6-44d4-8411-6cfa11c6ec00"],
 "), so each operation is exercised in full generality rather than on a lucky \
special case. They write the computation ",
 StyleBox["explicitly",
  FontWeight->"Bold"],
 " rather than hiding it in a helper function, because the code is itself \
part of the explanation. And they prefer ",
 StyleBox["built-in features",
  FontWeight->"Bold"],
 " (a ",
 Cell[BoxData["Normalize"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "32fe421b-b8ee-478b-82c7-da32044fc9fd"],
 ", a named state) over hand-rolled constructions, so nothing is hardcoded: \
every cell computes its result. Each cell does ",
 StyleBox["one",
  FontWeight->"Bold"],
 " thing and is preceded by a sentence saying what, so the notebook reads as \
a sequence of single, captioned computations. Run the WL answers in a bare \
kernel; the QF answers need the paclet loaded once."
}], "Text",ExpressionUUID->"dd65334a-3800-4073-ad59-89bdf67e4bc2"],

Cell["Setup", "Section",ExpressionUUID->"bc264d1d-cd9e-4a85-b534-0859578bc80c"],

Cell["The QF answers load the paclet once:", "Text",ExpressionUUID->"d11bef43-86b4-4066-a741-7a04bb236338"],

Cell[BoxData[
 RowBox[{"Needs", "[", "\"\<Wolfram`QuantumFramework`\>\"", "]"}]], "Input",
 CellLabel->"In[1]:= ",ExpressionUUID->"e531cfbd-12a2-495b-b2ae-5b2a4cc4468c"],

Cell["Part 1. Pure states and the Born rule", "Section",ExpressionUUID->"6fcbd12d-ea88-40b1-9400-f79b2f7b0aa9"],

Cell[TextData[{
 "1.1 [BSc] How do I represent a qubit as a state vector ",
 Cell[BoxData[
  StyleBox[
   RowBox[{
    RowBox[{"{", "\|01d6fc"}], ",", 
    RowBox[{"\|01d6fd", "}"}]}],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "c8016cdf-b258-47ed-8902-ee488e3fbe2f"],
 " in ",
 Cell[BoxData[
  StyleBox[
   SuperscriptBox["\:2102", "2"],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "f9e22c99-032d-4043-927b-fbee0a4e5c07"],
 "?"
}], "Subsection",ExpressionUUID->"8fc4596d-5e96-40c0-b971-b814746119dc"],

Cell[TextData[{
 "A pure qubit is a two-component complex vector ",
 Cell[BoxData[
  StyleBox[
   RowBox[{
    TemplateBox[{
      StyleBox["\|01d713"]},
     "Ket"], "=", 
    RowBox[{
     RowBox[{"\|01d6fc", 
      TemplateBox[{"0"},
       "Ket"]}], "+", 
     RowBox[{"\|01d6fd", 
      TemplateBox[{"1"},
       "Ket"]}]}]}],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "c2a77e6c-08cd-4989-9183-158f15fdfe55"],
 "."
}], "Text",ExpressionUUID->"5bccdabd-033a-4438-abcc-5144aa2f655e"],

Cell[TextData[{
 StyleBox["WL",
  FontWeight->"Bold"],
 " : a qubit is literally a length-2 complex list, kept fully general."
}], "Text",ExpressionUUID->"af58d706-0447-4d49-abd9-3bbd3f83e5cf"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"\[Alpha]", ",", " ", "\[Beta]"}], "}"}]], "Input",
 CellLabel->"In[2]:= ",ExpressionUUID->"7829ca37-f333-430e-a973-28d92c4fccfe"],

Cell[TextData[{
 StyleBox["QF",
  FontWeight->"Bold"],
 " : wrap the amplitudes in ",
 Cell[BoxData["QuantumState"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "797f6ce5-337e-4173-b790-5424dae21c74"],
 ". Evaluated without a trailing semicolon, the construction displays as its ",
 StyleBox["summary box",
  FontWeight->"Bold"],
 ": a compact panel that ",
 StyleBox["is", "TI"],
 " the live object, showing its type, dimension, and basis, not a printout of \
a matrix. Properties are read off that object on demand."
}], "Text",ExpressionUUID->"e9905181-24c5-413c-a3c5-c48ccf6048e7"],

Cell[BoxData[
 RowBox[{"qs", " ", "=", " ", 
  RowBox[{"QuantumState", "[", 
   RowBox[{"{", 
    RowBox[{"\[Alpha]", ",", " ", "\[Beta]"}], "}"}], "]"}]}]], "Input",
 CellLabel->"In[3]:= ",ExpressionUUID->"a27647b4-d928-4936-b749-f6684f79be76"],

Cell[TextData[{
 "Then ",
 Cell[BoxData["\"\<StateVector\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "3043ef05-b0e3-4356-b932-eee75b1ec978"],
 " reads one representation, the amplitudes, back out:"
}], "Text",ExpressionUUID->"85cf6ef5-bb2c-416b-a32c-1f5e94551dc3"],

Cell[BoxData[
 RowBox[{
  RowBox[{"qs", "[", "\"\<StateVector\>\"", "]"}], " ", "//", " ", 
  "Normal"}]], "Input",
 CellLabel->"In[4]:= ",ExpressionUUID->"f8dec6f7-4226-41de-b56f-b49e5c79e340"],

Cell[TextData[{
 "Both hold the amplitudes ",
 Cell[BoxData[
  StyleBox[
   RowBox[{
    RowBox[{"{", "\|01d6fc"}], ",", 
    RowBox[{"\|01d6fd", "}"}]}],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "29dcb78e-c72c-459c-8800-cabc018a7cb8"],
 "; the QF object additionally knows it is a single qubit in the \
computational basis, and the summary box is that object itself, with the \
amplitude vector just one field read from it."
}], "Text",ExpressionUUID->"e5c9a3f9-98bd-4b9a-926c-c119650bce0c"],

Cell["\<\
1.2 [BSc] How do I read the Born-rule probabilities of a state?\
\>", "Subsection",ExpressionUUID->"e702ca6c-c957-41f4-87e4-705c3f1c38b3"],

Cell[TextData[{
 "The probability of outcome ",
 Cell[BoxData[
  StyleBox["\|01d456",
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "5b16ad4e-b375-487e-ad54-af1581edb7d1"],
 " is ",
 Cell[BoxData[
  StyleBox[
   SuperscriptBox[
    RowBox[{
     StyleBox["\[LeftBracketingBar]",
      SpanMinSize->1.9], 
     TemplateBox[{
       StyleBox["\|01d456"], 
       StyleBox["\|01d713"]},
      "BraKet"], 
     StyleBox["\[RightBracketingBar]",
      SpanMinSize->1.9]}], "2"],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "0e526af9-3f95-4484-ba66-be8b6ded15bb"],
 ", i.e. the squared modulus of the amplitude (divided by the norm if the \
state is not yet normalized)."
}], "Text",ExpressionUUID->"408946c4-1ae9-4045-8030-f3b526755cb7"],

Cell[TextData[{
 StyleBox["WL",
  FontWeight->"Bold"],
 " : square the moduli of the normalized amplitudes; ",
 Cell[BoxData["FullSimplify"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "10e7c660-b33d-45c7-9394-cdc3dfe13ba5"],
 " reduces the nested modulus to a single ratio (the numerator ",
 Cell[BoxData[
  StyleBox[
   RowBox[{"\|01d6fc", 
    OverscriptBox["\|01d6fc", "_"]}],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "5e5cdc7a-1074-43f7-a783-0f8de3dd4868"],
 " is ",
 Cell[BoxData[
  StyleBox[
   SuperscriptBox[
    RowBox[{
    "\[LeftBracketingBar]", "\|01d6fc", "\[VeryThinSpace]", 
     "\[RightBracketingBar]"}], "2"],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "bb7c35c8-5006-4faf-8ec7-33a350417ea2"],
 ")."
}], "Text",ExpressionUUID->"90a8a819-0f74-421d-a699-8f862bca8663"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"Abs", "[", 
    RowBox[{"Normalize", "[", 
     RowBox[{"{", 
      RowBox[{"\[Alpha]", ",", " ", "\[Beta]"}], "}"}], "]"}], "]"}], "^", 
   "2"}], " ", "//", " ", "FullSimplify"}]], "Input",
 CellLabel->"In[5]:= ",ExpressionUUID->"a531170b-7ecf-4aed-b489-c7ed41e0d811"],

Cell[TextData[{
 StyleBox["QF",
  FontWeight->"Bold"],
 " : ask the state for its probabilities; ",
 Cell[BoxData["\"\<ProbabilitiesList\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "79e3474b-9804-4365-8f4d-d273273a7b22"],
 " normalizes internally and returns them in basis order."
}], "Text",ExpressionUUID->"b2a30fe0-d848-4b81-ae28-b3f4952e089f"],

Cell[BoxData[
 RowBox[{
  RowBox[{"QuantumState", "[", 
   RowBox[{"{", 
    RowBox[{"\[Alpha]", ",", " ", "\[Beta]"}], "}"}], "]"}], 
  "[", "\"\<ProbabilitiesList\>\"", "]"}]], "Input",
 CellLabel->"In[6]:= ",ExpressionUUID->"7aa2e468-db43-4a13-aa03-a44004b4cf01"],

Cell[TextData[{
 "Both give ",
 Cell[BoxData[
  StyleBox[
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{
       StyleBox["{",
        FontSize->1.2 Inherited], 
       SuperscriptBox[
        RowBox[{
        "\[LeftBracketingBar]", "\|01d6fc", "\[VeryThinSpace]", 
         "\[RightBracketingBar]"}], "2"]}], ",", " ", 
      SuperscriptBox[
       RowBox[{
       "\[LeftBracketingBar]", "\|01d6fd", "\[VeryThinSpace]", 
        "\[RightBracketingBar]"}], "2"]}], 
     StyleBox["}",
      FontSize->1.2 Inherited]}], "/", 
    RowBox[{
     StyleBox["(",
      SpanMaxSize->1], 
     RowBox[{
      SuperscriptBox[
       RowBox[{
       "\[LeftBracketingBar]", "\|01d6fc", "\[VeryThinSpace]", 
        "\[RightBracketingBar]"}], "2"], "+", 
      SuperscriptBox[
       RowBox[{
       "\[LeftBracketingBar]", "\|01d6fd", "\[VeryThinSpace]", 
        "\[RightBracketingBar]"}], "2"]}], 
     StyleBox[")",
      SpanMaxSize->1]}]}],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "788bdf4e-6c6f-44ab-a4d9-25de47f6f43c"],
 ": the Born rule weights the outcomes by the squared amplitudes, unequally \
in general, and the weights sum to one."
}], "Text",ExpressionUUID->"eae61985-563b-4308-ad4a-cea70c3c15c5"],

Cell["\<\
1.3 [BSc] How do I check that a state is normalized, and normalize one that \
is not?\
\>", "Subsection",ExpressionUUID->"777fac97-5c1f-4df3-9422-a0c7563af4a1"],

Cell[TextData[{
 "A physical state vector must have unit norm, ",
 Cell[BoxData[
  StyleBox[
   RowBox[{
    TemplateBox[{
      StyleBox["\|01d713"], 
      StyleBox["\|01d713"]},
     "BraKet"], "=", "1"}],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "55832aa9-3bdf-4a6d-bb90-44dfaede60b8"],
 "."
}], "Text",ExpressionUUID->"339a891c-02fb-45ad-8d84-5cc0132ddab6"],

Cell[TextData[{
 StyleBox["WL",
  FontWeight->"Bold"],
 " : ",
 Cell[BoxData["Norm"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "71ad7558-2f13-4a8e-8ea7-07fa618cdfc5"],
 " measures the length of the raw amplitude vector."
}], "Text",ExpressionUUID->"8c9af211-bbcf-41f5-9caf-422ecb9d498a"],

Cell[BoxData[
 RowBox[{"Norm", "[", 
  RowBox[{"{", 
   RowBox[{"\[Alpha]", ",", " ", "\[Beta]"}], "}"}], "]"}]], "Input",
 CellLabel->"In[7]:= ",ExpressionUUID->"5b184294-d52c-4944-a644-aa23073437ad"],

Cell[TextData[{
 Cell[BoxData["Normalize"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "3e754a6b-cdf0-4824-acdf-44729d06ea91"],
 " rescales it to unit length, so the norm of the normalized vector is ",
 Cell[BoxData[
  StyleBox["1",
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "94872638-492d-491a-aef5-600a6b0c9929"],
 "."
}], "Text",ExpressionUUID->"edde8a2f-28d0-454e-8b1e-54c280d2a4a1"],

Cell[BoxData[
 RowBox[{"Simplify", "[", 
  RowBox[{"Norm", " ", "@", " ", 
   RowBox[{"Normalize", "[", 
    RowBox[{"{", 
     RowBox[{"\[Alpha]", ",", " ", "\[Beta]"}], "}"}], "]"}]}], 
  "]"}]], "Input",
 CellLabel->"In[8]:= ",ExpressionUUID->"16da6d95-1c1e-4080-936a-e17d6ff63c7f"],

Cell[TextData[{
 StyleBox["QF",
  FontWeight->"Bold"],
 " : the ",
 Cell[BoxData["\"\<Norm\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "1f937797-d588-4404-9fad-829d8c9fedc6"],
 " property reports the same raw length."
}], "Text",ExpressionUUID->"0881413a-8aef-43b5-82cb-e43ad8faea81"],

Cell[BoxData[
 RowBox[{
  RowBox[{"QuantumState", "[", 
   RowBox[{"{", 
    RowBox[{"\[Alpha]", ",", " ", "\[Beta]"}], "}"}], "]"}], 
  "[", "\"\<Norm\>\"", "]"}]], "Input",
 CellLabel->"In[9]:= ",ExpressionUUID->"820df842-e4b2-4d74-a916-c50dbc1a2441"],

Cell[TextData[{
 Cell[BoxData["\"\<Normalize\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "7a001643-cf5b-4f9a-aada-b90a299e226d"],
 " returns a new, unit-norm state object, whose ",
 Cell[BoxData["\"\<Norm\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "98a8926a-8eb6-404f-bc2a-ee890ba26e1a"],
 " is then ",
 Cell[BoxData[
  StyleBox["1",
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "599fdea8-b7e1-4e30-8506-1593483d23a9"],
 "."
}], "Text",ExpressionUUID->"055764c6-c6ef-4707-a8c6-f002a6c8d35b"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"QuantumState", "[", 
    RowBox[{"{", 
     RowBox[{"\[Alpha]", ",", " ", "\[Beta]"}], "}"}], "]"}], 
   "[", "\"\<Normalize\>\"", "]"}], "[", "\"\<Norm\>\"", "]"}]], "Input",
 CellLabel->
  "In[10]:= ",ExpressionUUID->"3df587e9-0fb1-42ac-87bb-d7847fa2e2a3"],

Cell[TextData[{
 "Both report the raw norm ",
 Cell[BoxData[
  StyleBox[
   SqrtBox[
    RowBox[{
     SuperscriptBox[
      RowBox[{
      "\[LeftBracketingBar]", "\|01d6fc", "\[VeryThinSpace]", 
       "\[RightBracketingBar]"}], "2"], "+", 
     SuperscriptBox[
      RowBox[{
      "\[LeftBracketingBar]", "\|01d6fd", "\[VeryThinSpace]", 
       "\[RightBracketingBar]"}], "2"]}]],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "43086bdb-dea4-44ba-b659-9bee4a983a23"],
 " and confirm the normalized state has norm ",
 Cell[BoxData[
  StyleBox["1",
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "154d4fc5-7eae-4ee5-9f74-d0cc94fcb61a"],
 "."
}], "Text",ExpressionUUID->"917062c9-ffb3-4c7e-9e87-19c72e220959"],

Cell["\<\
1.4 [BSc] How do I show that a global phase is physically unobservable?\
\>", "Subsection",ExpressionUUID->"40195b63-f92c-4b90-908b-f1bd3efa55fd"],

Cell[TextData[{
 "Multiplying ",
 Cell[BoxData[
  StyleBox[
   TemplateBox[{
     StyleBox["\|01d713"]},
    "Ket"],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "2fa24e72-bfcf-4f4f-ac30-dff68fccd1b6"],
 " by ",
 Cell[BoxData[
  StyleBox[
   SuperscriptBox["\|01d452", 
    RowBox[{"\|01d456", "\[CurlyPhi]"}]],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "012e4aa9-b431-452a-8f5d-42b935ca911b"],
 " changes no measurable prediction, because every probability depends only \
on ",
 Cell[BoxData[
  StyleBox[
   SuperscriptBox[
    RowBox[{"\[LeftBracketingBar]", 
     SubscriptBox["\|01d450", "\|01d456"], "\[RightBracketingBar]"}], "2"],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "a32ac724-17e1-4898-bea9-80ba2f69cd16"],
 "."
}], "Text",ExpressionUUID->"fa756c67-5666-40fd-9a79-5d7da36f5b8c"],

Cell[TextData[{
 StyleBox["WL",
  FontWeight->"Bold"],
 " : compare the two probability vectors symbolically for all real phases."
}], "Text",ExpressionUUID->"ce59f795-3236-4628-b846-97e31c0f8f10"],

Cell[BoxData[
 RowBox[{"FullSimplify", "[", "\n", " ", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"Abs", "[", 
      RowBox[{"{", 
       RowBox[{"\[Alpha]", ",", " ", "\[Beta]"}], "}"}], "]"}], "^", "2"}], 
    " ", "==", " ", 
    RowBox[{
     RowBox[{"Abs", "[", 
      RowBox[{
       RowBox[{"Exp", "[", 
        RowBox[{"I", " ", "\[CurlyPhi]"}], "]"}], " ", 
       RowBox[{"{", 
        RowBox[{"\[Alpha]", ",", " ", "\[Beta]"}], "}"}]}], "]"}], "^", 
     "2"}]}], ",", "\n", " ", 
   RowBox[{"\[CurlyPhi]", " ", "\[Element]", " ", "Reals"}]}], "]"}]], "Input",\

 CellLabel->
  "In[11]:= ",ExpressionUUID->"bb0ad461-744e-43a1-baee-5be7e460e956"],

Cell[TextData[{
 StyleBox["QF",
  FontWeight->"Bold"],
 " : compare the two state objects directly. QuantumFramework's ",
 Cell[BoxData["=="], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "e7592830-b379-48d6-b32d-315e9d3f4494"],
 " is a ",
 StyleBox["physical", "TI"],
 " comparison: it equates states that differ only by a global phase (it uses \
an inner-product oracle, not the raw amplitudes, so ",
 Cell[BoxData["==="], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "574e10ea-9a59-466a-8113-8ba8d646958b"],
 " would still see them as distinct)."
}], "Text",ExpressionUUID->"263386f1-18b2-496a-91dd-74221fdbc2a6"],

Cell[BoxData[
 RowBox[{
  RowBox[{"QuantumState", "[", 
   RowBox[{"{", 
    RowBox[{"\[Alpha]", ",", " ", "\[Beta]"}], "}"}], "]"}], " ", "==", " ", 
  RowBox[{"QuantumState", "[", 
   RowBox[{
    RowBox[{"Exp", "[", 
     RowBox[{"I", " ", "\[CurlyPhi]"}], "]"}], " ", 
    RowBox[{"{", 
     RowBox[{"\[Alpha]", ",", " ", "\[Beta]"}], "}"}]}], "]"}]}]], "Input",
 CellLabel->
  "In[12]:= ",ExpressionUUID->"3cb85b84-848f-438c-9605-1dac1d274cad"],

Cell[TextData[{
 "Both return ",
 Cell[BoxData["True"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "0307d371-0114-463e-9d16-aedcb9266255"],
 ", symbolically, for every phase ",
 Cell[BoxData[
  StyleBox["\[CurlyPhi]",
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "cf036dcb-cba1-4221-bba4-efb3b04aa765"],
 ": the WL test shows the Born probabilities are phase-independent, and \
QuantumFramework declares the two state objects ",
 StyleBox["equal", "TI"],
 ". The phase labels no physical degree of freedom."
}], "Text",ExpressionUUID->"3fece4a9-5af1-4905-ae6d-1a44e4adaa0d"],

Cell[TextData[{
 "1.5 [BSc] How do I count the real parameters of a pure qubit and a pure \
qudit in ",
 Cell[BoxData[
  StyleBox[
   SuperscriptBox["\:2102", "\|01d451"],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "34b4d388-2c8d-45c1-bdc0-1834da1c7ef3"],
 "?"
}], "Subsection",ExpressionUUID->"0d37ec81-bc4c-4895-b7d6-cace1f978482"],

Cell[TextData[{
 "A pure state in ",
 Cell[BoxData[
  StyleBox[
   SuperscriptBox["\:2102", "\|01d451"],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "2d0fa326-106a-4d13-8bc3-9ea80b0bfca8"],
 " has ",
 Cell[BoxData[
  StyleBox[
   RowBox[{"2", "\|01d451"}],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "26183c13-85eb-46a7-b84d-8947dffb4fb6"],
 " real amplitude components; normalization removes one and the global phase \
removes another, leaving ",
 Cell[BoxData[
  StyleBox[
   RowBox[{"2", "\|01d451", "-", "2"}],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "4a5c00d3-d04f-4f73-b10c-d1272597396a"],
 ". The rigorous count is the generic rank of the parametrization's Jacobian: \
embed the family in ",
 Cell[BoxData[
  StyleBox[
   SuperscriptBox["\:211d", "4"],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "84f5a2af-c692-47dc-9ba9-a4e4ddcaf1d2"],
 " and count independent real directions."
}], "Text",ExpressionUUID->"3e3681f1-5336-4c24-85aa-bdf838ae6295"],

Cell[TextData[{
 StyleBox["WL",
  FontWeight->"Bold"],
 " : keep the global phase ",
 Cell[BoxData[
  StyleBox["\|01d454",
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "3dd4eb4a-4cf3-4c39-b756-45e27d11855b"],
 ", and the qubit family ",
 Cell[BoxData[
  StyleBox[
   RowBox[{
    RowBox[{
     RowBox[{
      SuperscriptBox["\|01d452", 
       RowBox[{"\|01d456", "\|01d454"}]], "{", 
      StyleBox["cos",
       FontSlant->"Plain"], "\[ThinSpace]", 
      StyleBox["(",
       SpanMaxSize->1], 
      RowBox[{"\|01d703", "/", "2"}], 
      StyleBox[")",
       SpanMaxSize->1]}], ",", " ", 
     RowBox[{
      SuperscriptBox["\|01d452", 
       RowBox[{"\|01d456", "\[Phi]"}]], 
      StyleBox["sin",
       FontSlant->"Plain"], "\[ThinSpace]", 
      RowBox[{
       StyleBox["(",
        SpanMaxSize->1], 
       RowBox[{"\|01d703", "/", "2"}], 
       StyleBox[")",
        SpanMaxSize->1]}]}]}], "}"}],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "aae91173-ac8b-4c1f-882c-c8550edf15e2"],
 " fills the 3-sphere of normalized states, Jacobian rank ",
 Cell[BoxData[
  StyleBox["3",
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "c822c467-a5cc-4828-8c20-c36d0caa00f0"],
 "."
}], "Text",ExpressionUUID->"7ed504b8-226f-4e34-a37a-0ee852b4c787"],

Cell[BoxData[
 RowBox[{"With", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"psi", " ", "=", " ", 
     RowBox[{
      RowBox[{"Exp", "[", 
       RowBox[{"I", " ", "g"}], "]"}], " ", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"Cos", "[", 
         RowBox[{"\[Theta]", "/", "2"}], "]"}], ",", " ", 
        RowBox[{
         RowBox[{"Exp", "[", 
          RowBox[{"I", " ", "\[Phi]"}], "]"}], " ", 
         RowBox[{"Sin", "[", 
          RowBox[{"\[Theta]", "/", "2"}], "]"}]}]}], "}"}]}]}], "}"}], ",", 
   "\n", " ", 
   RowBox[{"MatrixRank", "[", 
    RowBox[{"D", "[", 
     RowBox[{
      RowBox[{"Flatten", "[", 
       RowBox[{"ReIm", "[", 
        RowBox[{"ComplexExpand", "[", "psi", "]"}], "]"}], "]"}], ",", " ", 
      RowBox[{"{", 
       RowBox[{"{", 
        RowBox[{"\[Theta]", ",", " ", "\[Phi]", ",", " ", "g"}], "}"}], 
       "}"}]}], "]"}], "]"}]}], "]"}]], "Input",
 CellLabel->
  "In[13]:= ",ExpressionUUID->"499b4e22-b3c9-4e8e-b963-8fb5a468c076"],

Cell[TextData[{
 "Quotient the global phase (drop ",
 Cell[BoxData[
  StyleBox["\|01d454",
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "eb7770ca-a470-42f9-b07d-2f06aa4058f0"],
 ") and the rank falls to ",
 Cell[BoxData[
  StyleBox["2",
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "4ec0a334-f011-4918-a5eb-478c99ed6bfa"],
 ", the physical degrees of freedom."
}], "Text",ExpressionUUID->"75bda168-bccb-4c2e-a4ea-befbd302d9da"],

Cell[BoxData[
 RowBox[{"With", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"psi", " ", "=", " ", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"Cos", "[", 
        RowBox[{"\[Theta]", "/", "2"}], "]"}], ",", " ", 
       RowBox[{
        RowBox[{"Exp", "[", 
         RowBox[{"I", " ", "\[Phi]"}], "]"}], " ", 
        RowBox[{"Sin", "[", 
         RowBox[{"\[Theta]", "/", "2"}], "]"}]}]}], "}"}]}], "}"}], ",", "\n",
    " ", 
   RowBox[{"MatrixRank", "[", 
    RowBox[{"D", "[", 
     RowBox[{
      RowBox[{"Flatten", "[", 
       RowBox[{"ReIm", "[", 
        RowBox[{"ComplexExpand", "[", "psi", "]"}], "]"}], "]"}], ",", " ", 
      RowBox[{"{", 
       RowBox[{"{", 
        RowBox[{"\[Theta]", ",", " ", "\[Phi]"}], "}"}], "}"}]}], "]"}], 
    "]"}]}], "]"}]], "Input",
 CellLabel->
  "In[14]:= ",ExpressionUUID->"8984ad64-25fb-4c99-a2e8-afe8463d9282"],

Cell[TextData[{
 "The general count for ",
 Cell[BoxData[
  StyleBox[
   SuperscriptBox["\:2102", "\|01d451"],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "e1e3673a-befc-485f-a832-23d0d1361e35"],
 " is ",
 Cell[BoxData[
  StyleBox[
   RowBox[{"2", "\|01d451", "-", "2"}],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "2b58c37a-e7fc-4014-b87a-7624ccd8442c"],
 " (",
 Cell[BoxData[
  StyleBox[
   RowBox[{"2", "\|01d451"}],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "16b36b89-718c-4768-9809-8b64d1b091b8"],
 " components, less normalization, less global phase)."
}], "Text",ExpressionUUID->"d863c41d-f0d9-405c-9c79-a41fb23dd051"],

Cell[BoxData[
 RowBox[{"Table", "[", 
  RowBox[{
   RowBox[{
    RowBox[{"2", " ", "d"}], " ", "-", " ", "2"}], ",", " ", 
   RowBox[{"{", 
    RowBox[{"d", ",", " ", "2", ",", " ", "5"}], "}"}]}], "]"}]], "Input",
 CellLabel->
  "In[15]:= ",ExpressionUUID->"17ccc343-d7cb-4dce-bf4c-7b44897fb989"],

Cell[TextData[{
 StyleBox["QF",
  FontWeight->"Bold"],
 " : drive the general count from the object's own Hilbert-space dimension \
rather than a literal."
}], "Text",ExpressionUUID->"fb443849-8e40-4d11-9cee-c87202dfe752"],

Cell[BoxData[
 RowBox[{"Table", "[", 
  RowBox[{
   RowBox[{"2", " ", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{
       RowBox[{"QuantumState", "[", 
        RowBox[{"\"\<0\>\"", ",", " ", "d"}], "]"}], "[", "\"\<Dimension\>\"",
        "]"}], " ", "-", " ", "1"}], ")"}]}], ",", " ", 
   RowBox[{"{", 
    RowBox[{"d", ",", " ", "2", ",", " ", "5"}], "}"}]}], "]"}]], "Input",
 CellLabel->
  "In[16]:= ",ExpressionUUID->"133154a2-a23d-4eb2-9122-400325ff09b7"],

Cell[TextData[{
 "The Jacobian rank is ",
 Cell[BoxData[
  StyleBox["3",
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "57334854-e70f-4bf1-b138-c7491d81a1dc"],
 " with the phase and ",
 Cell[BoxData[
  StyleBox["2",
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "523859a8-1158-4823-bc99-644dd525e602"],
 " without it: a qubit has exactly two physical real parameters (the two \
Bloch angles), and the difference of one is the unobservable global phase. \
The general count is ",
 Cell[BoxData[
  StyleBox[
   RowBox[{
    RowBox[{"{", "2"}], ",", 
    RowBox[{"4", ",", "6"}], ",", 
    RowBox[{"8", "}"}]}],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "2e8cf745-fdf7-4abf-88e1-c03972924e44"],
 " for ",
 Cell[BoxData[
  StyleBox[
   RowBox[{
    RowBox[{"\|01d451", "=", "2"}], ",", 
    RowBox[{"3", ",", "4", ",", "5"}]}],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "0170b9e8-37da-492c-aa81-549ef32b2525"],
 "."
}], "Text",ExpressionUUID->"7fd10996-e96e-4ad5-854d-ae98ac27f1ca"],

Cell[TextData[{
 "1.6 [BSc] How do I compute an inner product ",
 Cell[BoxData[
  StyleBox[
   TemplateBox[{
     StyleBox["\[Phi]"], 
     StyleBox["\|01d713"]},
    "BraKet"],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "b2523043-9f43-4b2e-95df-7f175a13e610"],
 ", its modulus, and the transition probability ",
 Cell[BoxData[
  StyleBox[
   SuperscriptBox[
    RowBox[{
     StyleBox["\[LeftBracketingBar]",
      SpanMinSize->1.9], 
     TemplateBox[{
       StyleBox["\[Phi]"], 
       StyleBox["\|01d713"]},
      "BraKet"], 
     StyleBox["\[RightBracketingBar]",
      SpanMinSize->1.9]}], "2"],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "5da5ea6d-fe4e-4362-9810-b4ae584dbc54"],
 "?"
}], "Subsection",ExpressionUUID->"15d2b200-cc34-4644-89e9-356a440103af"],

Cell["\<\
The overlap of two states, its absolute value, and its absolute square give \
the amplitude and the probability to find one state in the other.\
\>", "Text",ExpressionUUID->"347593cc-9d77-4d02-bddf-7d5fa8657053"],

Cell[TextData[{
 StyleBox["WL",
  FontWeight->"Bold"],
 " : the inner product is the ",
 StyleBox["conjugated", "TI"],
 " dot product; the conjugation acts on the bra ",
 Cell[BoxData[
  StyleBox[
   TemplateBox[{
     StyleBox["\[Phi]"]},
    "Bra"],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "5f12850f-2564-403d-9a9c-380918731154"],
 ", which is why ",
 Cell[BoxData[
  StyleBox[
   RowBox[{
    SubscriptBox["\|01d6fc", "1"], ",", 
    SubscriptBox["\|01d6fd", "1"]}],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "b9a4eede-8efb-4d4a-9c18-371358ce3340"],
 " appear conjugated. The cell returns the overlap, its modulus, and its \
square together, as one inner product read three ways."
}], "Text",ExpressionUUID->"8bdf54a3-aad5-43d5-9613-99f43a67d06e"],

Cell[BoxData[
 RowBox[{"With", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{"phi", " ", "=", " ", 
      RowBox[{"{", 
       RowBox[{"\[Alpha]1", ",", " ", "\[Beta]1"}], "}"}]}], ",", " ", 
     RowBox[{"psi", " ", "=", " ", 
      RowBox[{"{", 
       RowBox[{"\[Alpha]2", ",", " ", "\[Beta]2"}], "}"}]}]}], "}"}], ",", 
   "\n", " ", 
   RowBox[{"With", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"ip", " ", "=", " ", 
       RowBox[{
        RowBox[{"Conjugate", "[", "phi", "]"}], " ", ".", " ", "psi"}]}], 
      "}"}], ",", " ", 
     RowBox[{"{", 
      RowBox[{"ip", ",", " ", 
       RowBox[{"Abs", "[", "ip", "]"}], ",", " ", 
       RowBox[{
        RowBox[{"Abs", "[", "ip", "]"}], "^", "2"}]}], "}"}]}], "]"}]}], 
  "]"}]], "Input",
 CellLabel->
  "In[17]:= ",ExpressionUUID->"978f4737-fa13-4a80-bda6-4f070518ad4c"],

Cell[TextData[{
 StyleBox["QF",
  FontWeight->"Bold"],
 " : build the bra with ",
 Cell[BoxData["\"\<Dagger\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "b31ad99e-2c88-452d-9d37-a7cc7a4ecaed"],
 ", compose with the ket, and read the same three numbers off the scalar."
}], "Text",ExpressionUUID->"3ba2a191-ac2d-4096-b43f-e6507189113f"],

Cell[BoxData[
 RowBox[{"With", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{"bra", " ", "=", " ", 
      RowBox[{
       RowBox[{"QuantumState", "[", 
        RowBox[{"{", 
         RowBox[{"\[Alpha]1", ",", " ", "\[Beta]1"}], "}"}], "]"}], 
       "[", "\"\<Dagger\>\"", "]"}]}], ",", " ", 
     RowBox[{"ket", " ", "=", " ", 
      RowBox[{"QuantumState", "[", 
       RowBox[{"{", 
        RowBox[{"\[Alpha]2", ",", " ", "\[Beta]2"}], "}"}], "]"}]}]}], "}"}], 
   ",", "\n", " ", 
   RowBox[{"With", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"ip", " ", "=", " ", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{"bra", " ", "@", " ", "ket"}], ")"}], "[", "\"\<Scalar\>\"", 
        "]"}]}], "}"}], ",", " ", 
     RowBox[{"{", 
      RowBox[{"ip", ",", " ", 
       RowBox[{"Abs", "[", "ip", "]"}], ",", " ", 
       RowBox[{
        RowBox[{"Abs", "[", "ip", "]"}], "^", "2"}]}], "}"}]}], "]"}]}], 
  "]"}]], "Input",
 CellLabel->
  "In[18]:= ",ExpressionUUID->"d99ebf1f-395c-4477-82eb-8aca4b742703"],

Cell[TextData[{
 "Both give ",
 Cell[BoxData[
  StyleBox[
   RowBox[{
    TemplateBox[{
      StyleBox["\[Phi]"], 
      StyleBox["\|01d713"]},
     "BraKet"], "=", 
    SubscriptBox["\|01d6fc", "2"], 
    SubscriptBox[
     OverscriptBox["\|01d6fc", "_"], "1"], "+", 
    SubscriptBox["\|01d6fd", "2"], 
    SubscriptBox[
     OverscriptBox["\|01d6fd", "_"], "1"]}],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "7ac25fc1-1cdf-4fa6-9454-5d4fcd91844e"],
 ", with its modulus and its square. The conjugation on the bra is what makes \
this a sesquilinear inner product rather than a plain bilinear dot product."
}], "Text",ExpressionUUID->"6840d073-26b4-4d2f-b6a4-00bd6cf9130d"],

Cell[TextData[{
 "1.7 [BSc] How do I write a state both as a column vector of amplitudes and \
as a Dirac superposition ",
 Cell[BoxData[
  StyleBox[
   RowBox[{
    UnderscriptBox["\[Sum]", "\|01d456",
     LimitsPositioning->False], 
    RowBox[{
     SubscriptBox["\|01d450", "\|01d456"], 
     TemplateBox[{
       StyleBox["\|01d456"]},
      "Ket"]}]}],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "9e100499-8511-4265-b243-01b3f6a612ee"],
 "?"
}], "Subsection",ExpressionUUID->"6b7089b6-c0dc-4fe7-b650-f8f0671a8909"],

Cell["\<\
The amplitude list and the ket-superposition are two views of one object.\
\>", "Text",ExpressionUUID->"57f40037-0e26-4c21-bd6e-7dc60ddde0a1"],

Cell[TextData[{
 StyleBox["WL",
  FontWeight->"Bold"],
 " : the amplitude vector is the list itself."
}], "Text",ExpressionUUID->"8a6fe3c0-32e7-4b3a-868e-662cc5721994"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"\[Alpha]", ",", " ", "\[Beta]"}], "}"}]], "Input",
 CellLabel->
  "In[19]:= ",ExpressionUUID->"2e8cb176-4b78-490c-85f8-e65838d71b66"],

Cell["\<\
The Dirac form is the same numbers against the computational basis; the \
identity confirms the expansion.\
\>", "Text",ExpressionUUID->"8f586479-98ea-4766-9cb6-2b3f192d764d"],

Cell[BoxData[
 RowBox[{
  RowBox[{"{", 
   RowBox[{"\[Alpha]", ",", " ", "\[Beta]"}], "}"}], " ", "==", " ", 
  RowBox[{
   RowBox[{"\[Alpha]", " ", 
    RowBox[{"{", 
     RowBox[{"1", ",", " ", "0"}], "}"}]}], " ", "+", " ", 
   RowBox[{"\[Beta]", " ", 
    RowBox[{"{", 
     RowBox[{"0", ",", " ", "1"}], "}"}]}]}]}]], "Input",
 CellLabel->
  "In[20]:= ",ExpressionUUID->"cb230e00-e8ee-45d2-957d-c4f860201766"],

Cell[TextData[{
 StyleBox["QF",
  FontWeight->"Bold"],
 " : the state object, shown first as its summary box."
}], "Text",ExpressionUUID->"4c04a5c7-f3e0-41bd-b3e4-386229fdc63c"],

Cell[BoxData[
 RowBox[{"qs", " ", "=", " ", 
  RowBox[{"QuantumState", "[", 
   RowBox[{"{", 
    RowBox[{"\[Alpha]", ",", " ", "\[Beta]"}], "}"}], "]"}]}]], "Input",
 CellLabel->
  "In[21]:= ",ExpressionUUID->"7e719b24-1ab6-4ee4-b26a-ae8f42568646"],

Cell[TextData[{
 Cell[BoxData["\"\<StateVector\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "db84522e-a799-418a-af0b-0592f51b636f"],
 " reads the amplitudes:"
}], "Text",ExpressionUUID->"aa1428dc-e319-4bcd-ab37-c3f43c61b9e7"],

Cell[BoxData[
 RowBox[{
  RowBox[{"qs", "[", "\"\<StateVector\>\"", "]"}], " ", "//", " ", 
  "Normal"}]], "Input",
 CellLabel->
  "In[22]:= ",ExpressionUUID->"da9a6a25-bf5e-4d98-ab81-78125317fe90"],

Cell[TextData[{
 Cell[BoxData["\"\<Formula\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "7ad971a7-bffa-41dc-b179-21c82cf74202"],
 " typesets the same object as the Dirac superposition ",
 Cell[BoxData[
  StyleBox[
   RowBox[{
    UnderscriptBox["\[Sum]", "\|01d456",
     LimitsPositioning->False], 
    RowBox[{
     SubscriptBox["\|01d450", "\|01d456"], 
     TemplateBox[{
       StyleBox["\|01d456"]},
      "Ket"]}]}],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "27f99957-8c08-413b-b188-f20a60eaea0c"],
 ":"
}], "Text",ExpressionUUID->"013b3273-1962-4f93-b58f-3d4ceabd353e"],

Cell[BoxData[
 RowBox[{"qs", "[", "\"\<Formula\>\"", "]"}]], "Input",
 CellLabel->
  "In[23]:= ",ExpressionUUID->"5243d3cf-66c4-403a-9150-8fac0f9fc33c"],

Cell[TextData[{
 "The amplitude vector and the superposition ",
 Cell[BoxData[
  StyleBox[
   RowBox[{
    RowBox[{"\|01d6fc", 
     TemplateBox[{"0"},
      "Ket"]}], "+", 
    RowBox[{"\|01d6fd", 
     TemplateBox[{"1"},
      "Ket"]}]}],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "d4fe2ada-e7eb-40de-87cc-09ecf3f7595e"],
 " carry identical information; both are representations read from the one \
object whose summary box is shown above."
}], "Text",ExpressionUUID->"d0277cb2-891d-4357-a063-e4adf449ed80"],

Cell["\<\
1.8 [BSc] How do I get the Bloch vector of a qubit, and the Bloch-sphere \
angles?\
\>", "Subsection",ExpressionUUID->"c7aa8995-b204-438b-90b8-4b350f227321"],

Cell[TextData[{
 "The Bloch vector ",
 Cell[BoxData[
  StyleBox[
   RowBox[{
    OverscriptBox["\|01d45f", "\[RightVector]"], "=", 
    StyleBox["(",
     SpanMaxSize->1], 
    RowBox[{
     RowBox[{
      StyleBox["\[LeftAngleBracket]",
       SpanMaxSize->1], 
      SubscriptBox["\|01d70e", "\|01d465"], 
      StyleBox["\[RightAngleBracket]",
       SpanMaxSize->1]}], ",", 
     RowBox[{
      StyleBox["\[LeftAngleBracket]",
       SpanMaxSize->1], 
      SubscriptBox["\|01d70e", "\|01d466"], 
      StyleBox["\[RightAngleBracket]",
       SpanMaxSize->1]}], ",", 
     RowBox[{
      StyleBox["\[LeftAngleBracket]",
       SpanMaxSize->1], 
      SubscriptBox["\|01d70e", "\|01d467"], 
      StyleBox["\[RightAngleBracket]",
       SpanMaxSize->1]}]}], 
    StyleBox[")",
     SpanMaxSize->1]}],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "d4d2deb7-c847-489b-a7f7-086369085dcf"],
 " places a pure qubit on the unit sphere, with ",
 Cell[BoxData[
  StyleBox[
   RowBox[{
    StyleBox["(",
     SpanMaxSize->1], 
    RowBox[{"\|01d703", ",", "\[Phi]"}], 
    StyleBox[")",
     SpanMaxSize->1]}],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "a2fea32e-7036-4987-95ae-1431920b3749"],
 " its spherical angles."
}], "Text",ExpressionUUID->"c423c63d-8a98-4627-9c43-b576f026da56"],

Cell[TextData[{
 StyleBox["WL",
  FontWeight->"Bold"],
 " : the Bloch vector is, ",
 StyleBox["by definition", "TI"],
 ", the triple of Pauli expectation values ",
 Cell[BoxData[
  StyleBox[
   RowBox[{
    TemplateBox[{
      StyleBox["\|01d713"]},
     "Bra"], 
    SubscriptBox["\|01d70e", "\|01d457"], 
    TemplateBox[{
      StyleBox["\|01d713"]},
     "Ket"]}],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "53b69978-904b-445b-b85b-c79db86d875e"],
 ". Evaluate that definition for a general ",
 Cell[BoxData[
  StyleBox[
   RowBox[{
    RowBox[{"{", "\|01d6fc"}], ",", 
    RowBox[{"\|01d6fd", "}"}]}],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "48d830c8-af1a-43d7-890a-46c8de0a27bd"],
 " to get the familiar component formula."
}], "Text",ExpressionUUID->"37bd400c-fb28-4af3-8f4b-83c0b5c7f945"],

Cell[BoxData[
 RowBox[{"FullSimplify", " ", "@", " ", 
  RowBox[{"Table", "[", 
   RowBox[{
    RowBox[{
     RowBox[{"Conjugate", "[", 
      RowBox[{"{", 
       RowBox[{"\[Alpha]", ",", " ", "\[Beta]"}], "}"}], "]"}], " ", ".", " ", 
     RowBox[{"PauliMatrix", "[", "j", "]"}], " ", ".", " ", 
     RowBox[{"{", 
      RowBox[{"\[Alpha]", ",", " ", "\[Beta]"}], "}"}]}], ",", " ", 
    RowBox[{"{", 
     RowBox[{"j", ",", " ", "3"}], "}"}]}], "]"}]}]], "Input",
 CellLabel->
  "In[24]:= ",ExpressionUUID->"54e7af29-22a8-41f9-bc32-a034fd954647"],

Cell["\<\
For the angle-parametrized state the same definition gives the geometric \
vector on the sphere.\
\>", "Text",ExpressionUUID->"5e19dbd4-8596-4d3c-9740-e936011315c8"],

Cell[BoxData[
 RowBox[{"rvec", " ", "=", " ", 
  RowBox[{"With", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"\[Psi]", " ", "=", " ", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"Cos", "[", 
         RowBox[{"\[Theta]", "/", "2"}], "]"}], ",", " ", 
        RowBox[{
         RowBox[{"Exp", "[", 
          RowBox[{"I", " ", "\[Phi]"}], "]"}], " ", 
         RowBox[{"Sin", "[", 
          RowBox[{"\[Theta]", "/", "2"}], "]"}]}]}], "}"}]}], "}"}], ",", 
    "\n", "  ", 
    RowBox[{"FullSimplify", "[", 
     RowBox[{
      RowBox[{"Table", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"Conjugate", "[", "\[Psi]", "]"}], " ", ".", " ", 
         RowBox[{"PauliMatrix", "[", "j", "]"}], " ", ".", " ", "\[Psi]"}], ",",
         " ", 
        RowBox[{"{", 
         RowBox[{"j", ",", " ", "3"}], "}"}]}], "]"}], ",", " ", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"\[Theta]", ",", " ", "\[Phi]"}], "}"}], " ", "\[Element]", 
       " ", "Reals"}]}], "]"}]}], "]"}]}]], "Input",
 CellLabel->
  "In[25]:= ",ExpressionUUID->"659ba32d-51a3-437e-b213-434f03f86a93"],

Cell["\<\
A built-in coordinate transform turns that Cartesian vector into spherical \
angles.\
\>", "Text",ExpressionUUID->"a7530c01-4bf8-4d0f-a738-989c9b147296"],

Cell[BoxData[
 RowBox[{"FullSimplify", "[", 
  RowBox[{
   RowBox[{"ToSphericalCoordinates", "[", "rvec", "]"}], ",", " ", 
   RowBox[{
    RowBox[{"0", " ", "<", " ", "\[Theta]", " ", "<", " ", "Pi"}], " ", "&&", 
    " ", 
    RowBox[{
     RowBox[{"-", "Pi"}], " ", "<", " ", "\[Phi]", " ", "<", " ", "Pi"}]}]}], 
  "]"}]], "Input",
 CellLabel->
  "In[26]:= ",ExpressionUUID->"7358f973-4ec2-4b1f-8435-8b9e2e6fa681"],

Cell[TextData[{
 StyleBox["QF",
  FontWeight->"Bold"],
 " : the state object, shown as its summary box."
}], "Text",ExpressionUUID->"b099dca7-4b7d-4591-a7c7-7940ba614510"],

Cell[BoxData[
 RowBox[{"qs", " ", "=", " ", 
  RowBox[{"QuantumState", "[", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"Cos", "[", 
      RowBox[{"\[Theta]", "/", "2"}], "]"}], ",", " ", 
     RowBox[{
      RowBox[{"Exp", "[", 
       RowBox[{"I", " ", "\[Phi]"}], "]"}], " ", 
      RowBox[{"Sin", "[", 
       RowBox[{"\[Theta]", "/", "2"}], "]"}]}]}], "}"}], "]"}]}]], "Input",
 CellLabel->
  "In[27]:= ",ExpressionUUID->"e617927d-a9e4-4877-b30f-705caf64aff8"],

Cell[TextData[{
 Cell[BoxData["\"\<BlochVector\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "74434ada-6f97-4fa7-a7cd-d74ab1134702"],
 " computes the same Pauli expectation values internally (as ",
 Cell[BoxData[
  StyleBox[
   RowBox[{
    StyleBox["Tr",
     FontSlant->"Plain"], 
    StyleBox["[",
     SpanMaxSize->1], 
    RowBox[{"\|01d70c", " ", 
     SubscriptBox["\|01d70e", "\|01d457"]}], 
    StyleBox["]",
     SpanMaxSize->1]}],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "e18d29ff-b296-4ae3-896f-d89b0f2104a0"],
 ")."
}], "Text",ExpressionUUID->"c488b612-2391-4782-a1d0-89303779dd6c"],

Cell[BoxData[
 RowBox[{"FullSimplify", "[", 
  RowBox[{
   RowBox[{"qs", "[", "\"\<BlochVector\>\"", "]"}], ",", " ", 
   RowBox[{
    RowBox[{"0", " ", "<", " ", "\[Theta]", " ", "<", " ", "Pi"}], " ", "&&", 
    " ", 
    RowBox[{
     RowBox[{"-", "Pi"}], " ", "<", " ", "\[Phi]", " ", "<", " ", "Pi"}]}]}], 
  "]"}]], "Input",
 CellLabel->
  "In[28]:= ",ExpressionUUID->"da63aecd-a0c6-41c3-95db-af61a993f4c0"],

Cell[TextData[{
 Cell[BoxData["\"\<BlochSphericalCoordinates\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "0c79cb35-c1d7-4b6e-a492-e22f1135d311"],
 " gives the polar and azimuthal angles."
}], "Text",ExpressionUUID->"5b344f68-6269-4960-8458-254b109749af"],

Cell[BoxData[
 RowBox[{"FullSimplify", "[", 
  RowBox[{
   RowBox[{"qs", "[", "\"\<BlochSphericalCoordinates\>\"", "]"}], ",", " ", 
   RowBox[{
    RowBox[{"0", " ", "<", " ", "\[Theta]", " ", "<", " ", "Pi"}], " ", "&&", 
    " ", 
    RowBox[{
     RowBox[{"-", "Pi"}], " ", "<", " ", "\[Phi]", " ", "<", " ", "Pi"}]}]}], 
  "]"}]], "Input",
 CellLabel->
  "In[29]:= ",ExpressionUUID->"be175180-abc1-4285-b1bc-e4760cd146e6"],

Cell[TextData[{
 "Evaluating the definition returns ",
 Cell[BoxData[
  StyleBox[
   RowBox[{
    RowBox[{
     RowBox[{"{", "2", " ", 
      StyleBox["Re",
       FontSlant->"Plain"], " ", 
      OverscriptBox["\|01d6fc", "_"], "\|01d6fd"}], ",", " ", 
     RowBox[{"2", " ", 
      StyleBox["Im",
       FontSlant->"Plain"], " ", 
      OverscriptBox["\|01d6fc", "_"], "\|01d6fd"}], ",", " ", 
     RowBox[{
      SuperscriptBox[
       RowBox[{
       "\[LeftBracketingBar]", "\|01d6fc", "\[VeryThinSpace]", 
        "\[RightBracketingBar]"}], "2"], "-", 
      SuperscriptBox[
       RowBox[{
       "\[LeftBracketingBar]", "\|01d6fd", "\[VeryThinSpace]", 
        "\[RightBracketingBar]"}], "2"]}]}], "}"}],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "95633848-aee2-4692-95df-92a56266b954"],
 " for a general state and ",
 Cell[BoxData[
  StyleBox[
   RowBox[{
    StyleBox["(",
     SpanMaxSize->1], 
    RowBox[{
     RowBox[{
      StyleBox["sin",
       FontSlant->"Plain"], "\[ThinSpace]", "\|01d703", 
      StyleBox["cos",
       FontSlant->"Plain"], "\[ThinSpace]", "\[Phi]"}], ",", " ", 
     RowBox[{
      StyleBox["sin",
       FontSlant->"Plain"], "\[ThinSpace]", "\|01d703", 
      StyleBox["sin",
       FontSlant->"Plain"], "\[ThinSpace]", "\[Phi]"}], ",", " ", 
     RowBox[{
      StyleBox["cos",
       FontSlant->"Plain"], "\[ThinSpace]", "\|01d703"}]}], 
    StyleBox[")",
     SpanMaxSize->1]}],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "0e5288e8-47ea-4801-a19b-b388bd702baf"],
 " for the parametrized one, with spherical coordinates ",
 Cell[BoxData[
  StyleBox[
   RowBox[{
    StyleBox["(",
     SpanMaxSize->1], 
    RowBox[{"1", ",", "\|01d703", ",", "\[Phi]"}], 
    StyleBox[")",
     SpanMaxSize->1]}],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "3f253b52-6912-4a55-aa02-758fe4e2f03c"],
 ". So the component formula is a ",
 StyleBox["result", "TI"],
 " of evaluating the Pauli expectation values, not the definition itself, and \
the parametrization angles are exactly the polar and azimuthal angles on the \
Bloch sphere."
}], "Text",ExpressionUUID->"f628f884-4b1c-45d7-b742-b66a3a5a446c"],

Cell[TextData[{
 "1.9 [BSc] How do I prepare a qudit in ",
 Cell[BoxData[
  StyleBox[
   SuperscriptBox["\:2102", "\|01d451"],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "48d4c6b7-6290-4942-8af2-b42c8727dc87"],
 " and a uniform superposition?"
}], "Subsection",ExpressionUUID->"e1375b32-f24f-4d07-b28d-324202019776"],

Cell[TextData[{
 "A qudit lives in ",
 Cell[BoxData[
  StyleBox[
   SuperscriptBox["\:2102", "\|01d451"],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "43c62593-d8a5-4263-afb1-1b7836c57baf"],
 "; the computational state ",
 Cell[BoxData[
  StyleBox[
   TemplateBox[{"0"},
    "Ket"],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "93e275c7-393e-4e7b-ad4e-2156a2253a50"],
 " and the equal-weight superposition ",
 Cell[BoxData[
  StyleBox[
   RowBox[{
    FractionBox["1", 
     SqrtBox["\|01d451"]], 
    RowBox[{
     UnderscriptBox["\[Sum]", "\|01d458",
      LimitsPositioning->False], 
     TemplateBox[{
       StyleBox["\|01d458"]},
      "Ket"]}]}],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "ab510b54-d44e-4c64-ac6f-bef392a9943b"],
 " are the basic preparations."
}], "Text",ExpressionUUID->"0236d718-6abe-4f3b-8437-ec41e9d27a8d"],

Cell[TextData[{
 StyleBox["WL",
  FontWeight->"Bold"],
 " : ",
 Cell[BoxData[
  StyleBox[
   TemplateBox[{"0"},
    "Ket"],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "af0ef071-3e95-48de-88d3-7bcc9509aa47"],
 " is a unit vector."
}], "Text",ExpressionUUID->"013d3341-f3dc-4243-9c26-5c3eb285e177"],

Cell[BoxData[
 RowBox[{"With", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"d", " ", "=", " ", "3"}], "}"}], ",", " ", 
   RowBox[{"UnitVector", "[", 
    RowBox[{"d", ",", " ", "1"}], "]"}]}], "]"}]], "Input",
 CellLabel->
  "In[30]:= ",ExpressionUUID->"785d0a97-722b-4fd4-ae08-f2e45a75df0a"],

Cell[TextData[{
 "The uniform state is a constant vector handed to ",
 Cell[BoxData["Normalize"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "b136a413-89ca-4ad9-ae89-d203bc624189"],
 " (no hardcoded ",
 Cell[BoxData[
  StyleBox[
   RowBox[{"1", "/", 
    SqrtBox["\|01d451"]}],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "c3706f9e-529d-4a81-aa2e-ef531fa714f1"],
 ")."
}], "Text",ExpressionUUID->"f081d7a3-23ce-4f23-b7ae-8055289b18b7"],

Cell[BoxData[
 RowBox[{"With", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"d", " ", "=", " ", "3"}], "}"}], ",", " ", 
   RowBox[{"Normalize", " ", "@", " ", 
    RowBox[{"ConstantArray", "[", 
     RowBox[{"1", ",", " ", "d"}], "]"}]}]}], "]"}]], "Input",
 CellLabel->
  "In[31]:= ",ExpressionUUID->"b4268b13-eb27-49e3-a1d8-f41363e80a4e"],

Cell[TextData[{
 StyleBox["QF",
  FontWeight->"Bold"],
 " : name the basis state with its dimension."
}], "Text",ExpressionUUID->"7d7d32c9-2c18-47b9-b88f-b86980d72478"],

Cell[BoxData[
 RowBox[{"With", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"d", " ", "=", " ", "3"}], "}"}], ",", " ", 
   RowBox[{
    RowBox[{
     RowBox[{"QuantumState", "[", 
      RowBox[{"\"\<0\>\"", ",", " ", "d"}], "]"}], "[", "\"\<StateVector\>\"",
      "]"}], " ", "//", " ", "Normal"}]}], "]"}]], "Input",
 CellLabel->
  "In[32]:= ",ExpressionUUID->"f429ac2a-993f-43c0-a7c7-cb0e0d9fc024"],

Cell[TextData[{
 "Use the built-in ",
 Cell[BoxData["\"\<UniformSuperposition\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "1cfde58a-13dc-4ec2-8514-fbb22828adc5"],
 " state rather than constructing it by hand."
}], "Text",ExpressionUUID->"2a4b237b-7b84-42e6-9586-697b5b89b4aa"],

Cell[BoxData[
 RowBox[{"With", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"d", " ", "=", " ", "3"}], "}"}], ",", " ", 
   RowBox[{
    RowBox[{
     RowBox[{"QuantumState", "[", 
      RowBox[{"\"\<UniformSuperposition\>\"", ",", " ", "d"}], "]"}], 
     "[", "\"\<StateVector\>\"", "]"}], " ", "//", " ", "Normal"}]}], 
  "]"}]], "Input",
 CellLabel->
  "In[33]:= ",ExpressionUUID->"c94e7e6d-a0f8-4778-9510-84b635f1acbf"],

Cell[TextData[{
 "Both give ",
 Cell[BoxData[
  StyleBox[
   RowBox[{
    TemplateBox[{"0"},
     "Ket"], "=", 
    StyleBox["(",
     SpanMaxSize->1], 
    RowBox[{"1", ",", "0", ",", "0"}], 
    StyleBox[")",
     SpanMaxSize->1]}],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "efd10863-55bf-4c73-bcf5-0408a90e6fa7"],
 " and the uniform qutrit ",
 Cell[BoxData[
  StyleBox[
   RowBox[{
    FractionBox["1", 
     SqrtBox["3"]], 
    StyleBox["(",
     SpanMaxSize->1], 
    RowBox[{"1", ",", "1", ",", "1"}], 
    StyleBox[")",
     SpanMaxSize->1]}],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "7fbe4123-6ba9-4bed-8e11-a6b1e0e7895d"],
 "; the construction is written in ",
 Cell[BoxData[
  StyleBox["\|01d451",
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "ae5f94a0-ab36-475a-b8d5-b581ce500400"],
 ", so it works for any dimension."
}], "Text",ExpressionUUID->"80f8c93a-7534-4501-b556-eaab63617198"],

Cell["Part 2. Observables, spectra, and approximation", "Section",ExpressionUUID->"62d467f5-a894-4156-a20d-655ac344ae1a"],

Cell["\<\
2.1 [BSc] How do I compute a commutator and an anticommutator of two \
operators?\
\>", "Subsection",ExpressionUUID->"f9b9a32a-4e7b-4f53-b90f-b77435452e18"],

Cell[TextData[{
 "The commutator ",
 Cell[BoxData[
  StyleBox[
   RowBox[{
    StyleBox["[",
     SpanMaxSize->1], 
    RowBox[{"\|01d434", ",", "\|01d435"}], 
    StyleBox["]",
     SpanMaxSize->1], "=", "\|01d434", "\|01d435", "-", "\|01d435", 
    "\|01d434"}],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "e6a94de0-5e5b-4333-832e-f1a0a9ae9bb0"],
 " measures the failure to commute; the anticommutator ",
 Cell[BoxData[
  StyleBox[
   RowBox[{
    RowBox[{"{", "\|01d434"}], ",", 
    RowBox[{
    "\|01d435", "}", "=", "\|01d434", "\|01d435", "+", "\|01d435", 
     "\|01d434"}]}],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "59ef3a26-138e-4ed7-a366-aed3af48ff3d"],
 ". Together they split the product, ",
 Cell[BoxData[
  StyleBox[
   RowBox[{"\|01d434", "\|01d435", "=", 
    FractionBox["1", "2"], 
    StyleBox["(",
     SpanMaxSize->1], 
    RowBox[{
     RowBox[{"{", "\|01d434"}], ",", 
     RowBox[{"\|01d435", "}", "+", 
      StyleBox["[",
       SpanMaxSize->1], 
      RowBox[{"\|01d434", ",", "\|01d435"}], 
      StyleBox["]",
       SpanMaxSize->1]}]}], 
    StyleBox[")",
     SpanMaxSize->1]}],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "99037bea-b4ce-4d73-bcb7-6d24021616b5"],
 "."
}], "Text",ExpressionUUID->"2a93bd8b-ab51-437a-9fd8-df0ca255e1ea"],

Cell[TextData[{
 StyleBox["WL",
  FontWeight->"Bold"],
 " : the commutator is ",
 Cell[BoxData[
  StyleBox[
   RowBox[{"\|01d434", "\|01d435", "-", "\|01d435", "\|01d434"}],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "27363fde-48ba-4c4a-83bf-4aee77c0ee0d"],
 " on two general operators."
}], "Text",ExpressionUUID->"2d4b9c17-da08-41f8-b6c0-e4cdd4e8b2ab"],

Cell[BoxData[
 RowBox[{"With", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{"a", " ", "=", " ", 
      RowBox[{"Array", "[", 
       RowBox[{"\[FormalA]", ",", " ", 
        RowBox[{"{", 
         RowBox[{"2", ",", " ", "2"}], "}"}]}], "]"}]}], ",", " ", 
     RowBox[{"b", " ", "=", " ", 
      RowBox[{"Array", "[", 
       RowBox[{"\[FormalB]", ",", " ", 
        RowBox[{"{", 
         RowBox[{"2", ",", " ", "2"}], "}"}]}], "]"}]}]}], "}"}], ",", " ", 
   RowBox[{
    RowBox[{"a", " ", ".", " ", "b"}], " ", "-", " ", 
    RowBox[{"b", " ", ".", " ", "a"}]}]}], "]"}]], "Input",
 CellLabel->
  "In[34]:= ",ExpressionUUID->"10d79e22-921a-409f-8c09-b437967692cb"],

Cell[TextData[{
 "The anticommutator is ",
 Cell[BoxData[
  StyleBox[
   RowBox[{"\|01d434", "\|01d435", "+", "\|01d435", "\|01d434"}],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "d9651a89-b66f-4953-8c36-1b6df2defc8d"],
 "."
}], "Text",ExpressionUUID->"c9a0b065-43e6-4598-b39d-6f30604c30bb"],

Cell[BoxData[
 RowBox[{"With", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{"a", " ", "=", " ", 
      RowBox[{"Array", "[", 
       RowBox[{"\[FormalA]", ",", " ", 
        RowBox[{"{", 
         RowBox[{"2", ",", " ", "2"}], "}"}]}], "]"}]}], ",", " ", 
     RowBox[{"b", " ", "=", " ", 
      RowBox[{"Array", "[", 
       RowBox[{"\[FormalB]", ",", " ", 
        RowBox[{"{", 
         RowBox[{"2", ",", " ", "2"}], "}"}]}], "]"}]}]}], "}"}], ",", " ", 
   RowBox[{
    RowBox[{"a", " ", ".", " ", "b"}], " ", "+", " ", 
    RowBox[{"b", " ", ".", " ", "a"}]}]}], "]"}]], "Input",
 CellLabel->
  "In[35]:= ",ExpressionUUID->"7c998f7f-a7be-47ce-9ff2-455c9025ff48"],

Cell[TextData[{
 "The Wolfram Language also provides them as built-ins (passing ",
 Cell[BoxData["Dot"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "930bf44f-2efa-491a-abca-2bea88e9d91a"],
 " as the product). The commutator:"
}], "Text",ExpressionUUID->"8b353867-089d-4533-bb9f-6a21b5b248e4"],

Cell[BoxData[
 RowBox[{"With", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{"a", " ", "=", " ", 
      RowBox[{"Array", "[", 
       RowBox[{"\[FormalA]", ",", " ", 
        RowBox[{"{", 
         RowBox[{"2", ",", " ", "2"}], "}"}]}], "]"}]}], ",", " ", 
     RowBox[{"b", " ", "=", " ", 
      RowBox[{"Array", "[", 
       RowBox[{"\[FormalB]", ",", " ", 
        RowBox[{"{", 
         RowBox[{"2", ",", " ", "2"}], "}"}]}], "]"}]}]}], "}"}], ",", " ", 
   RowBox[{"Commutator", "[", 
    RowBox[{"a", ",", " ", "b", ",", " ", "Dot"}], "]"}]}], "]"}]], "Input",
 CellLabel->
  "In[36]:= ",ExpressionUUID->"9cab14f6-4847-4ffb-ae82-bb24a157a529"],

Cell["and the anticommutator:", "Text",ExpressionUUID->"d43379fb-9566-4589-8be9-e5afe31b96b8"],

Cell[BoxData[
 RowBox[{"With", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{"a", " ", "=", " ", 
      RowBox[{"Array", "[", 
       RowBox[{"\[FormalA]", ",", " ", 
        RowBox[{"{", 
         RowBox[{"2", ",", " ", "2"}], "}"}]}], "]"}]}], ",", " ", 
     RowBox[{"b", " ", "=", " ", 
      RowBox[{"Array", "[", 
       RowBox[{"\[FormalB]", ",", " ", 
        RowBox[{"{", 
         RowBox[{"2", ",", " ", "2"}], "}"}]}], "]"}]}]}], "}"}], ",", " ", 
   RowBox[{"Anticommutator", "[", 
    RowBox[{"a", ",", " ", "b", ",", " ", "Dot"}], "]"}]}], "]"}]], "Input",
 CellLabel->
  "In[37]:= ",ExpressionUUID->"514c844f-0866-4553-8a86-4b55859c571c"],

Cell[TextData[{
 StyleBox["QF",
  FontWeight->"Bold"],
 " : here the operands are ",
 StyleBox["operators", "TI"],
 ", so the results are again operators, not arrays. The built-in ",
 Cell[BoxData["Commutator"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "c10ebe72-b30d-40c9-b7a1-495f9293218c"],
 " reduces directly on QuantumOperators (QF teaches it the operator product), \
and returns a ",
 Cell[BoxData["QuantumOperator"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "435e6676-3e2f-47ee-af8c-71f724d38d6d"],
 "."
}], "Text",ExpressionUUID->"43388ce7-3e04-4a2a-a317-b992a220c781"],

Cell[BoxData[
 RowBox[{"With", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{"a", " ", "=", " ", 
      RowBox[{"QuantumOperator", "[", 
       RowBox[{"Array", "[", 
        RowBox[{"\[FormalA]", ",", " ", 
         RowBox[{"{", 
          RowBox[{"2", ",", " ", "2"}], "}"}]}], "]"}], "]"}]}], ",", " ", 
     RowBox[{"b", " ", "=", " ", 
      RowBox[{"QuantumOperator", "[", 
       RowBox[{"Array", "[", 
        RowBox[{"\[FormalB]", ",", " ", 
         RowBox[{"{", 
          RowBox[{"2", ",", " ", "2"}], "}"}]}], "]"}], "]"}]}]}], "}"}], ",",
    "\n", " ", 
   RowBox[{"Commutator", "[", 
    RowBox[{"a", ",", " ", "b"}], "]"}]}], "]"}]], "Input",
 CellLabel->
  "In[38]:= ",ExpressionUUID->"bbb4e500-cd05-4d83-8857-d31fa9085b9e"],

Cell[TextData[{
 "The built-in ",
 Cell[BoxData["Anticommutator"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "36a3d1e4-5fe8-4ead-b9f5-7474176e30f3"],
 " does ",
 StyleBox["not", "TI"],
 " reduce on operators, so write it as ",
 Cell[BoxData[
  RowBox[{
   RowBox[{"a", " ", "@", " ", "b"}], " ", "+", " ", 
   RowBox[{"b", " ", "@", " ", "a"}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "421f66a4-26ed-4650-b895-51f2cae22774"],
 ", with ",
 Cell[BoxData["@"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "9d412555-5415-4b60-bad7-d7dfd08abbd1"],
 " the operator product."
}], "Text",ExpressionUUID->"81c7901a-58f3-43d7-9b12-6e37606277ca"],

Cell[BoxData[
 RowBox[{"With", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{"a", " ", "=", " ", 
      RowBox[{"QuantumOperator", "[", 
       RowBox[{"Array", "[", 
        RowBox[{"\[FormalA]", ",", " ", 
         RowBox[{"{", 
          RowBox[{"2", ",", " ", "2"}], "}"}]}], "]"}], "]"}]}], ",", " ", 
     RowBox[{"b", " ", "=", " ", 
      RowBox[{"QuantumOperator", "[", 
       RowBox[{"Array", "[", 
        RowBox[{"\[FormalB]", ",", " ", 
         RowBox[{"{", 
          RowBox[{"2", ",", " ", "2"}], "}"}]}], "]"}], "]"}]}]}], "}"}], ",",
    "\n", " ", 
   RowBox[{
    RowBox[{"a", " ", "@", " ", "b"}], " ", "+", " ", 
    RowBox[{"b", " ", "@", " ", "a"}]}]}], "]"}]], "Input",
 CellLabel->
  "In[39]:= ",ExpressionUUID->"0d96d37a-a17c-4297-b348-e3f672fe9dd8"],

Cell[TextData[{
 "An operator does far more than carry a matrix. Take the concrete Pauli case \
",
 Cell[BoxData[
  StyleBox[
   RowBox[{
    StyleBox["[",
     SpanMaxSize->1], 
    RowBox[{"\|01d44b", ",", "\|01d44c"}], 
    StyleBox["]",
     SpanMaxSize->1], "=", "2", "\|01d456", "\|01d44d"}],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "ae51cdae-6f67-4dcb-9521-29745f912261"],
 ": the commutator is itself an operator object, shown here as its summary \
box."
}], "Text",ExpressionUUID->"cb9ab075-9ef9-4d4b-93da-c4aa0c3082af"],

Cell[BoxData[
 RowBox[{"c", " ", "=", " ", 
  RowBox[{"Commutator", "[", 
   RowBox[{
    RowBox[{"QuantumOperator", "[", "\"\<X\>\"", "]"}], ",", " ", 
    RowBox[{"QuantumOperator", "[", "\"\<Y\>\"", "]"}]}], "]"}]}]], "Input",
 CellLabel->
  "In[40]:= ",ExpressionUUID->"8a4b5cd4-58e1-470c-917d-c5ef65ae27cf"],

Cell[TextData[{
 "It acts on a state, sending ",
 Cell[BoxData[
  StyleBox[
   TemplateBox[{"0"},
    "Ket"],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "bd4b380a-a613-4b84-8594-06483f00d70e"],
 " to ",
 Cell[BoxData[
  StyleBox[
   RowBox[{"2", "\|01d456", 
    TemplateBox[{"0"},
     "Ket"]}],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "0ef60190-5b30-4e14-a6a3-6cb9647883fe"],
 "."
}], "Text",ExpressionUUID->"3a54c105-f3d6-4573-9017-a92becc90083"],

Cell[BoxData[
 RowBox[{"c", "[", 
  RowBox[{"QuantumState", "[", "\"\<0\>\"", "]"}], "]"}]], "Input",
 CellLabel->
  "In[41]:= ",ExpressionUUID->"78188509-3d55-4030-8e03-703d9df543ff"],

Cell[TextData[{
 "It answers whether it is Hermitian (a commutator of Hermitian operators is \
anti-Hermitian, so ",
 Cell[BoxData["False"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "02b29386-f3de-4c9e-a5e0-f03208f0cb45"],
 ")."
}], "Text",ExpressionUUID->"c0c33fed-59a8-4833-91da-ce4f1bc8637f"],

Cell[BoxData[
 RowBox[{"c", "[", "\"\<HermitianQ\>\"", "]"}]], "Input",
 CellLabel->
  "In[42]:= ",ExpressionUUID->"32ef0395-f95a-4942-823f-9aee30bdf41d"],

Cell[TextData[{
 "Its eigenvalues are imaginary, ",
 Cell[BoxData[
  StyleBox[
   RowBox[{"\[PlusMinus]", "2", "\|01d456"}],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "cd382fba-4729-41e9-bdb7-e7b4f455f94c"],
 "."
}], "Text",ExpressionUUID->"73ff25f3-f9cf-47ff-8187-6f22d99e1efa"],

Cell[BoxData[
 RowBox[{"c", "[", "\"\<Eigenvalues\>\"", "]"}]], "Input",
 CellLabel->
  "In[43]:= ",ExpressionUUID->"5908ef9f-6c0e-48c7-9255-2746dc914e9c"],

Cell[TextData[{
 "And only last of all does it hand back its matrix, ",
 Cell[BoxData[
  StyleBox[
   RowBox[{"2", "\|01d456", 
    SubscriptBox["\|01d70e", "\|01d467"]}],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "f4dc1d53-83a9-47e4-a4be-e05b0b2ae3c0"],
 "."
}], "Text",ExpressionUUID->"1c31921c-7cb4-4c0f-b9f6-e5dc56bf5070"],

Cell[BoxData[
 RowBox[{
  RowBox[{"c", "[", "\"\<Matrix\>\"", "]"}], " ", "//", " ", 
  "Normal"}]], "Input",
 CellLabel->
  "In[44]:= ",ExpressionUUID->"c8700d32-b60b-438c-bbb2-34182225699a"],

Cell["\<\
The matrix is one view of a much richer object; that is the difference \
between QuantumFramework and bare linear algebra.\
\>", "Text",ExpressionUUID->"dc4fc986-d0a4-4217-9e43-b1af6b9fca74"],

Cell["\<\
2.2 [BSc] How do I build the Pauli operators and verify their algebra \
(Levi-Civita product rule)?\
\>", "Subsection",ExpressionUUID->"b6afc226-8d5d-4b7c-902a-6a530af165af"],

Cell[TextData[{
 "The Pauli operators close under commutation, ",
 Cell[BoxData[
  StyleBox[
   RowBox[{
    StyleBox["[",
     SpanMaxSize->1], 
    RowBox[{
     SubscriptBox["\|01d70e", "\|01d456"], ",", 
     SubscriptBox["\|01d70e", "\|01d457"]}], 
    StyleBox["]",
     SpanMaxSize->1], "=", "2", "\|01d456", " ", 
    SubscriptBox["\|01d700", 
     RowBox[{"\|01d456", "\|01d457", "\|01d458"}]], " ", 
    SubscriptBox["\|01d70e", "\|01d458"]}],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "fb15f6b2-5c4a-47cc-8414-02ea09f1fee7"],
 "."
}], "Text",ExpressionUUID->"eab4f59c-d890-4fab-a8fd-8df93973a250"],

Cell[TextData[{
 StyleBox["WL",
  FontWeight->"Bold"],
 " : assemble the Pauli vector and check all nine commutators at once against \
the Levi-Civita tensor."
}], "Text",ExpressionUUID->"d1a005b4-b4e4-41c0-b4a7-79dd44c383c0"],

Cell[BoxData[
 RowBox[{"With", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"\[Sigma]", " ", "=", " ", 
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{"PauliMatrix", "[", "j", "]"}], ",", " ", 
       RowBox[{"{", 
        RowBox[{"j", ",", " ", "3"}], "}"}]}], "]"}]}], "}"}], ",", "\n", " ", 
   RowBox[{
    RowBox[{"Outer", "[", 
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{"#1", " ", ".", " ", "#2"}], " ", "-", " ", 
        RowBox[{"#2", " ", ".", " ", "#1"}]}], " ", "&"}], ",", " ", 
      "\[Sigma]", ",", " ", "\[Sigma]", ",", " ", "1"}], "]"}], " ", "==", 
    "\n", "  ", 
    RowBox[{"2", " ", "I", " ", 
     RowBox[{"TensorContract", "[", 
      RowBox[{
       RowBox[{"TensorProduct", "[", 
        RowBox[{
         RowBox[{"LeviCivitaTensor", "[", "3", "]"}], ",", " ", "\[Sigma]"}], 
        "]"}], ",", " ", 
       RowBox[{"{", 
        RowBox[{"3", ",", " ", "4"}], "}"}]}], "]"}]}]}]}], "]"}]], "Input",
 CellLabel->
  "In[45]:= ",ExpressionUUID->"3dec541d-5a4d-4888-8e80-50aa69ae4d3b"],

Cell[TextData[{
 StyleBox["QF",
  FontWeight->"Bold"],
 " : the same check staying at the ",
 StyleBox["operator", "TI"],
 " level. Each ",
 Cell[BoxData[
  RowBox[{"Commutator", "[", 
   RowBox[{"#1", ",", " ", "#2"}], "]"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "1264b06a-31ae-4174-9998-2b421e0fc746"],
 " is an operator, and every entry is compared directly to the operator ",
 Cell[BoxData[
  StyleBox[
   RowBox[{"2", "\|01d456", " ", 
    SubscriptBox["\|01d700", 
     RowBox[{"\|01d456", "\|01d457", "\|01d458"}]], 
    SubscriptBox["\|01d70e", "\|01d458"]}],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "e613af44-9b15-4c8d-ab9e-01326e759fcf"],
 ", with no matrices extracted."
}], "Text",ExpressionUUID->"5fbc9563-191f-4d17-963a-dc95bb3ca223"],

Cell[BoxData[
 RowBox[{"With", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"\[Sigma]", " ", "=", " ", 
     RowBox[{"QuantumOperator", " ", "/@", " ", 
      RowBox[{"{", 
       RowBox[{"\"\<X\>\"", ",", " ", "\"\<Y\>\"", ",", " ", "\"\<Z\>\""}], 
       "}"}]}]}], "}"}], ",", " ", 
   RowBox[{"{", 
    RowBox[{"com", " ", "=", "\n", "   ", 
     RowBox[{"Outer", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"Commutator", "[", 
         RowBox[{"#1", ",", " ", "#2"}], "]"}], " ", "&"}], ",", " ", 
       "\[Sigma]", ",", " ", "\[Sigma]", ",", " ", "1"}], "]"}]}], "}"}], ",",
    "\n", " ", 
   RowBox[{"Table", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"com", "[", 
       RowBox[{"[", 
        RowBox[{"i", ",", " ", "j"}], "]"}], "]"}], " ", "==", " ", 
      RowBox[{"2", " ", "I", " ", 
       RowBox[{"Sum", "[", 
        RowBox[{
         RowBox[{
          RowBox[{
           RowBox[{"LeviCivitaTensor", "[", "3", "]"}], "[", 
           RowBox[{"[", 
            RowBox[{"i", ",", " ", "j", ",", " ", "k"}], "]"}], "]"}], " ", 
          RowBox[{"\[Sigma]", "[", 
           RowBox[{"[", "k", "]"}], "]"}]}], ",", " ", 
         RowBox[{"{", 
          RowBox[{"k", ",", " ", "3"}], "}"}]}], "]"}]}]}], ",", " ", 
     RowBox[{"{", 
      RowBox[{"i", ",", " ", "3"}], "}"}], ",", " ", 
     RowBox[{"{", 
      RowBox[{"j", ",", " ", "3"}], "}"}]}], "]"}]}], "]"}]], "Input",
 CellLabel->
  "In[46]:= ",ExpressionUUID->"ebeebf65-f79e-4bb1-9b5c-674bcb198d69"],

Cell[TextData[{
 "The WL line returns ",
 Cell[BoxData["True"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "08b92cf5-2787-42bd-b96b-8ad048b127c6"],
 " and the QF line returns a ",
 Cell[BoxData[
  StyleBox[
   RowBox[{"3", "\[Times]", "3"}],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "1bccd97e-00e7-463a-9aaa-1e6d05430092"],
 " table of ",
 Cell[BoxData["True"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "c69e24e0-21d5-4ce7-99cc-ba5e27e178d6"],
 ": every commutator operator ",
 Cell[BoxData[
  StyleBox[
   RowBox[{
    StyleBox["[",
     SpanMaxSize->1], 
    RowBox[{
     SubscriptBox["\|01d70e", "\|01d456"], ",", 
     SubscriptBox["\|01d70e", "\|01d457"]}], 
    StyleBox["]",
     SpanMaxSize->1]}],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "b37bc53e-192b-429f-bbe1-56c8a53f7613"],
 " equals the operator ",
 Cell[BoxData[
  StyleBox[
   RowBox[{"2", "\|01d456", " ", 
    SubscriptBox["\|01d700", 
     RowBox[{"\|01d456", "\|01d457", "\|01d458"}]], 
    SubscriptBox["\|01d70e", "\|01d458"]}],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "d4915769-93a0-41c1-87e2-287fe428f17b"],
 " (the diagonal ",
 Cell[BoxData[
  StyleBox[
   RowBox[{
    StyleBox["[",
     SpanMaxSize->1], 
    RowBox[{
     SubscriptBox["\|01d70e", "\|01d456"], ",", 
     SubscriptBox["\|01d70e", "\|01d456"]}], 
    StyleBox["]",
     SpanMaxSize->1]}],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "0ce3a4a8-db61-4ded-bcde-99d673c07bb3"],
 " vanishing), so the whole ",
 Cell[BoxData[
  StyleBox[
   RowBox[{"\|01d530", "\|01d532", 
    StyleBox["(",
     SpanMaxSize->1], "2", 
    StyleBox[")",
     SpanMaxSize->1]}],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "822e34c9-f159-48ec-ac08-14a30f180e3d"],
 " algebra is verified through operator equality, never touching a matrix."
}], "Text",ExpressionUUID->"1a1bbf35-4911-407b-a5c2-644391e99a98"],

Cell["\<\
2.3 [BSc] How do I test that an operator is Hermitian, and why must \
observables be Hermitian?\
\>", "Subsection",ExpressionUUID->"0fb46d85-bcd9-43d2-9978-818dc2003af7"],

Cell[TextData[{
 "An observable is Hermitian, ",
 Cell[BoxData[
  StyleBox[
   RowBox[{"\|01d434", "=", 
    SuperscriptBox["\|01d434", "\[Dagger]"]}],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "f185288a-07d0-4e19-be23-5ee43524488c"],
 ", and that is exactly what forces its eigenvalues (the possible measurement \
outcomes) to be real."
}], "Text",ExpressionUUID->"e68c007b-9aa2-4a5f-8c5b-249f591a3c93"],

Cell[TextData[{
 StyleBox["WL",
  FontWeight->"Bold"],
 " : test Hermiticity directly."
}], "Text",ExpressionUUID->"2534b944-6970-4ed1-ae3d-b0b398fa4022"],

Cell[BoxData[
 RowBox[{"HermitianMatrixQ", "[", 
  RowBox[{"PauliMatrix", "[", "1", "]"}], "]"}]], "Input",
 CellLabel->
  "In[47]:= ",ExpressionUUID->"f8ec6fa2-d39f-438e-b4ee-7672da4ea492"],

Cell["A generic Hermitian matrix then has real eigenvalues.", "Text",ExpressionUUID->"52704a2a-eca5-47d6-ab0a-a778fa626e8f"],

Cell[BoxData[
 RowBox[{"FullSimplify", "[", 
  RowBox[{
   RowBox[{
    RowBox[{"Eigenvalues", "[", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"a1", ",", " ", 
         RowBox[{"a2", " ", "+", " ", 
          RowBox[{"I", " ", "a3"}]}]}], "}"}], ",", " ", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"a2", " ", "-", " ", 
          RowBox[{"I", " ", "a3"}]}], ",", " ", "a4"}], "}"}]}], "}"}], "]"}],
     " ", "\[Element]", " ", "Reals"}], ",", "\n", " ", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{
     "a1", " ", "|", " ", "a2", " ", "|", " ", "a3", " ", "|", " ", "a4"}], 
     ")"}], " ", "\[Element]", " ", "Reals"}]}], "]"}]], "Input",
 CellLabel->
  "In[48]:= ",ExpressionUUID->"3f45d05c-9f73-4018-b276-3e069fa5b9bb"],

Cell[TextData[{
 StyleBox["QF",
  FontWeight->"Bold"],
 " : the operator answers ",
 Cell[BoxData["\"\<HermitianQ\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "9eef8c77-bfd9-47f0-9737-a9921e44af45"],
 "."
}], "Text",ExpressionUUID->"a6010258-8875-41a9-b46e-78c6bd50a710"],

Cell[BoxData[
 RowBox[{
  RowBox[{"QuantumOperator", "[", "\"\<X\>\"", "]"}], 
  "[", "\"\<HermitianQ\>\"", "]"}]], "Input",
 CellLabel->
  "In[49]:= ",ExpressionUUID->"7308a7c9-4d61-436e-b095-57746a8d1b13"],

Cell[TextData[{
 "And its ",
 Cell[BoxData["\"\<Eigenvalues\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "30d9ba24-cae5-451f-ac72-906a5e7d1fe7"],
 " are real."
}], "Text",ExpressionUUID->"e73117ae-ac39-4094-91e5-6c85805c5229"],

Cell[BoxData[
 RowBox[{"FullSimplify", "[", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"QuantumOperator", "[", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"a1", ",", " ", 
          RowBox[{"a2", " ", "+", " ", 
           RowBox[{"I", " ", "a3"}]}]}], "}"}], ",", " ", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"a2", " ", "-", " ", 
           RowBox[{"I", " ", "a3"}]}], ",", " ", "a4"}], "}"}]}], "}"}], 
      "]"}], "[", "\"\<Eigenvalues\>\"", "]"}], " ", "\[Element]", " ", 
    "Reals"}], ",", "\n", " ", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{
     "a1", " ", "|", " ", "a2", " ", "|", " ", "a3", " ", "|", " ", "a4"}], 
     ")"}], " ", "\[Element]", " ", "Reals"}]}], "]"}]], "Input",
 CellLabel->
  "In[50]:= ",ExpressionUUID->"126dc7d0-587c-4e46-bc9f-add7e1031cdf"],

Cell[TextData[{
 "Both report ",
 Cell[BoxData["True"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "b5b0ecde-bac6-4f46-b6a5-e997763dcb62"],
 " twice: the operator is Hermitian, and Hermiticity guarantees a real \
spectrum."
}], "Text",ExpressionUUID->"9113d922-a022-4332-b7bc-77740a3f41d6"],

Cell["\<\
2.4 [BSc] How do I compute eigenvalues and eigenvectors and form the spectral \
decomposition?\
\>", "Subsection",ExpressionUUID->"56716389-fd54-47f0-ae53-e4733a541a9c"],

Cell[TextData[{
 "Every observable is its own spectral sum, ",
 Cell[BoxData[
  StyleBox[
   RowBox[{"\|01d434", "=", 
    RowBox[{
     UnderscriptBox["\[Sum]", "\|01d44e",
      LimitsPositioning->False], 
     RowBox[{"\|01d44e", 
      TemplateBox[{
        StyleBox["\|01d44e"]},
       "Ket"], 
      TemplateBox[{
        StyleBox["\|01d44e"]},
       "Bra"]}]}]}],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "be40a7a1-bb1f-4c13-a6e7-7a5e89a21d64"],
 ". The built-in ",
 Cell[BoxData["EigenvalueDecomposition"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "c40836bc-72bb-4b6b-908b-70c18d93c0da"],
 " packages exactly this: it returns ",
 Cell[BoxData[
  StyleBox[
   RowBox[{
    RowBox[{"{", "\|01d446"}], ",", 
    RowBox[{"\|01d437", "}"}]}],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "60c1d7a4-eccf-4e97-a492-09a46b167bf5"],
 " with the eigenvectors as the columns of ",
 Cell[BoxData[
  StyleBox["\|01d446",
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "510acd53-2f0d-4e22-96a9-8a3e6362b6eb"],
 ", the eigenvalues on the diagonal of ",
 Cell[BoxData[
  StyleBox["\|01d437",
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "0299f32f-4a9f-4d2d-9c17-763b470e7929"],
 ", and ",
 Cell[BoxData[
  StyleBox[
   RowBox[{"\|01d434", "=", "\|01d446", " ", "\|01d437", " ", 
    SuperscriptBox["\|01d446", 
     RowBox[{"-", "1"}]]}],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "75720d3f-6ae4-4ed5-9da4-63f8f9a05c88"],
 "."
}], "Text",ExpressionUUID->"f8f9c3d4-7e68-441e-8fe7-f033cb7b3b70"],

Cell[TextData[{
 StyleBox["WL",
  FontWeight->"Bold"],
 " : compute the decomposition once and bind it."
}], "Text",ExpressionUUID->"de16cb1d-cd8e-48ce-8e7d-28db906a3054"],

Cell[BoxData[
 RowBox[{
  RowBox[{"evd", " ", "=", " ", 
   RowBox[{"EigenvalueDecomposition", "[", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"a1", ",", " ", 
        RowBox[{"a2", " ", "+", " ", 
         RowBox[{"I", " ", "a3"}]}]}], "}"}], ",", " ", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"a2", " ", "-", " ", 
         RowBox[{"I", " ", "a3"}]}], ",", " ", "a4"}], "}"}]}], "}"}], 
    "]"}]}], ";"}]], "Input",
 CellLabel->
  "In[51]:= ",ExpressionUUID->"7f4f2372-f2d1-476f-938c-054d6f38182d"],

Cell[TextData[{
 "The eigenvalues are the diagonal of ",
 Cell[BoxData[
  StyleBox["\|01d437",
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "d95e4043-b785-441f-8770-79c7fe84bf59"],
 "."
}], "Text",ExpressionUUID->"4bba4daf-0cba-46a0-a6c0-974e14ab867b"],

Cell[BoxData[
 RowBox[{"Diagonal", "[", 
  RowBox[{"evd", "[", 
   RowBox[{"[", "2", "]"}], "]"}], "]"}]], "Input",
 CellLabel->
  "In[52]:= ",ExpressionUUID->"f325dc13-e43c-4a1a-b702-705de27b30f3"],

Cell[TextData[{
 "The eigenvectors are the columns of ",
 Cell[BoxData[
  StyleBox["\|01d446",
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "52328a6b-5a05-4acb-9b7f-54a8f062b2eb"],
 " (rows of its transpose)."
}], "Text",ExpressionUUID->"fb9fd8b8-60d3-4d98-9bb0-4c0e9c66674d"],

Cell[BoxData[
 RowBox[{"Transpose", "[", 
  RowBox[{"evd", "[", 
   RowBox[{"[", "1", "]"}], "]"}], "]"}]], "Input",
 CellLabel->
  "In[53]:= ",ExpressionUUID->"dd845dfa-29ab-483b-8ba9-5324f32e52ec"],

Cell[TextData[{
 "And the reconstruction ",
 Cell[BoxData[
  StyleBox[
   RowBox[{"\|01d434", "=", "\|01d446", " ", "\|01d437", " ", 
    SuperscriptBox["\|01d446", 
     RowBox[{"-", "1"}]]}],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "e80aeb23-6643-4d1a-8458-30659a365580"],
 " holds."
}], "Text",ExpressionUUID->"bc11dc58-2ed6-4953-8a7b-640cceb0251f"],

Cell[BoxData[
 RowBox[{"FullSimplify", "[", 
  RowBox[{
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"a1", ",", " ", 
        RowBox[{"a2", " ", "+", " ", 
         RowBox[{"I", " ", "a3"}]}]}], "}"}], ",", " ", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"a2", " ", "-", " ", 
         RowBox[{"I", " ", "a3"}]}], ",", " ", "a4"}], "}"}]}], "}"}], " ", "==",
     " ", 
    RowBox[{
     RowBox[{"evd", "[", 
      RowBox[{"[", "1", "]"}], "]"}], " ", ".", " ", 
     RowBox[{"evd", "[", 
      RowBox[{"[", "2", "]"}], "]"}], " ", ".", " ", 
     RowBox[{"Inverse", "[", 
      RowBox[{"evd", "[", 
       RowBox[{"[", "1", "]"}], "]"}], "]"}]}]}], ",", "\n", " ", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{
     "a1", " ", "|", " ", "a2", " ", "|", " ", "a3", " ", "|", " ", "a4"}], 
     ")"}], " ", "\[Element]", " ", "Reals"}]}], "]"}]], "Input",
 CellLabel->
  "In[54]:= ",ExpressionUUID->"561e2733-66ab-4234-9809-b82a3d6c6f86"],

Cell[TextData[{
 StyleBox["QF",
  FontWeight->"Bold"],
 " : keep it in the object model. The operator, shown as its summary box."
}], "Text",ExpressionUUID->"fb532432-63ef-4d71-ad39-08f092b72834"],

Cell[BoxData[
 RowBox[{"qo", " ", "=", " ", 
  RowBox[{"QuantumOperator", "[", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"a1", ",", " ", 
       RowBox[{"a2", " ", "+", " ", 
        RowBox[{"I", " ", "a3"}]}]}], "}"}], ",", " ", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"a2", " ", "-", " ", 
        RowBox[{"I", " ", "a3"}]}], ",", " ", "a4"}], "}"}]}], "}"}], 
   "]"}]}]], "Input",
 CellLabel->
  "In[55]:= ",ExpressionUUID->"3b7031f0-3e8f-4228-ba9c-ea2d5d97862e"],

Cell["It hands back its eigenvalues,", "Text",ExpressionUUID->"8096e616-10a1-4fc0-bfb3-0a801aa517d7"],

Cell[BoxData[
 RowBox[{"qo", "[", "\"\<Eigenvalues\>\"", "]"}]], "Input",
 CellLabel->
  "In[56]:= ",ExpressionUUID->"d6bd1244-eab4-4102-a083-97732464387b"],

Cell["its eigenvectors,", "Text",ExpressionUUID->"109da758-f0aa-45ab-8196-ae8477ebab74"],

Cell[BoxData[
 RowBox[{"qo", "[", "\"\<Eigenvectors\>\"", "]"}]], "Input",
 CellLabel->
  "In[57]:= ",ExpressionUUID->"b3fea886-ef62-479f-b021-3bbc72a4739b"],

Cell[TextData[{
 "and ",
 Cell[BoxData["\"\<Diagonalize\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "66469e85-8646-4e54-b308-f4ebdeaf4055"],
 " returns the ",
 StyleBox["operator", "TI"],
 " expressed in its own eigenbasis, a ",
 Cell[BoxData["QuantumOperator"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "f9aceb91-d547-44ac-93f2-ddf22634d033"],
 " whose matrix is diagonal with the eigenvalues on it."
}], "Text",ExpressionUUID->"bfd1a369-5e23-4621-8447-df637d6f9f65"],

Cell[BoxData[
 RowBox[{"qo", "[", "\"\<Diagonalize\>\"", "]"}]], "Input",
 CellLabel->
  "In[58]:= ",ExpressionUUID->"d5fe01af-4d42-4870-85f3-c1630f78d4eb"],

Cell[TextData[{
 "Both report the same two real eigenvalues ",
 Cell[BoxData[
  StyleBox[
   RowBox[{
    FractionBox["1", "2"], 
    StyleBox["(",
     FontSize->1.2 Inherited], 
    SubscriptBox["\|01d44e", "1"], "+", 
    SubscriptBox["\|01d44e", "4"], "\[PlusMinus]", 
    SqrtBox[
     RowBox[{
      SuperscriptBox[
       RowBox[{
        StyleBox["(",
         SpanMaxSize->1], 
        RowBox[{
         SubscriptBox["\|01d44e", "1"], "-", 
         SubscriptBox["\|01d44e", "4"]}], 
        StyleBox[")",
         SpanMaxSize->1]}], "2"], "+", "4", 
      StyleBox["(",
       SpanMaxSize->1], 
      RowBox[{
       SubsuperscriptBox["\|01d44e", "2", "2"], "+", 
       SubsuperscriptBox["\|01d44e", "3", "2"]}], 
      StyleBox[")",
       SpanMaxSize->1]}]], 
    StyleBox[")",
     FontSize->1.2 Inherited]}],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "fbc011db-0450-4747-b9af-1222da767d8b"],
 ". On the WL side ",
 Cell[BoxData["EigenvalueDecomposition"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "d2cd9a68-72d6-498b-b906-12563fce9c6e"],
 " reconstructs ",
 Cell[BoxData[
  StyleBox[
   RowBox[{"\|01d434", "=", "\|01d446", "\|01d437", 
    SuperscriptBox["\|01d446", 
     RowBox[{"-", "1"}]]}],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "1fed3d90-40b4-47b6-b53c-4a4ebde3bb2e"],
 " (for a Hermitian operator the eigenvectors are orthogonal, so normalizing ",
 Cell[BoxData[
  StyleBox["\|01d446",
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "44038d80-3607-4101-ba90-25d4a2706359"],
 " to a unitary ",
 Cell[BoxData[
  StyleBox["\|01d448",
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "81d43eee-83ee-4d23-80fc-3a09ddd41675"],
 " turns this into the spectral form ",
 Cell[BoxData[
  StyleBox[
   RowBox[{"\|01d434", "=", 
    RowBox[{
     RowBox[{"\|01d448", "\|01d437", 
      SuperscriptBox["\|01d448", "\[Dagger]"]}], "=", 
     RowBox[{
      UnderscriptBox["\[Sum]", "\|01d44e",
       LimitsPositioning->False], 
      RowBox[{"\|01d44e", 
       TemplateBox[{
         StyleBox["\|01d44e"]},
        "Ket"], 
       TemplateBox[{
         StyleBox["\|01d44e"]},
        "Bra"]}]}]}]}],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "49ae58c2-de1e-46b1-9781-6a3fde8a121d"],
 "). On the QF side ",
 Cell[BoxData["\"\<Diagonalize\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "6c438a43-105e-463f-88bd-289a3c4938b0"],
 " ",
 StyleBox["is", "TI"],
 " that spectral form, the operator already diagonal in its eigenbasis, still \
an object rather than a bare array."
}], "Text",ExpressionUUID->"6abdd1db-e410-476d-bc2f-043be4ee033f"],

Cell[TextData[{
 "2.5 [BSc] How do I evaluate a function of an operator ",
 Cell[BoxData[
  StyleBox[
   RowBox[{"\|01d453", 
    StyleBox["(",
     SpanMaxSize->1], 
    OverscriptBox["\|01d434", "^"], 
    StyleBox[")",
     SpanMaxSize->1]}],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "060062f7-d702-415a-8856-7bd7c1372344"],
 " by functional calculus?"
}], "Subsection",ExpressionUUID->"cd351bb3-c143-4750-92b5-105ea663cb37"],

Cell[TextData[{
 "By definition ",
 Cell[BoxData[
  StyleBox[
   RowBox[{"\|01d453", 
    StyleBox["(",
     SpanMaxSize->1], "\|01d434", 
    StyleBox[")",
     SpanMaxSize->1]}],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "0e315545-f9f6-488b-b31b-216d1a6171a7"],
 " acts on the eigenvalues in the eigenbasis, ",
 Cell[BoxData[
  StyleBox[
   RowBox[{
    RowBox[{"\|01d453", 
     RowBox[{
      StyleBox["(",
       SpanMaxSize->1], "\|01d434", 
      StyleBox[")",
       SpanMaxSize->1]}]}], "=", 
    RowBox[{
     UnderscriptBox["\[Sum]", "\|01d44e",
      LimitsPositioning->False], 
     RowBox[{"\|01d453", 
      RowBox[{
       StyleBox["(",
        SpanMaxSize->1], "\|01d44e", 
       StyleBox[")",
        SpanMaxSize->1]}], 
      TemplateBox[{
        StyleBox["\|01d44e"]},
       "Ket"], 
      TemplateBox[{
        StyleBox["\|01d44e"]},
       "Bra"]}]}]}],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "05472956-cc56-47dc-9517-615c02ebd3a1"],
 "."
}], "Text",ExpressionUUID->"8c10693d-9c76-42b8-ba2d-b01cff0f2016"],

Cell[TextData[{
 StyleBox["WL",
  FontWeight->"Bold"],
 " : build that spectral sum with a symbolic ",
 Cell[BoxData[
  StyleBox["\|01d453",
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "1f7474df-998f-435b-b1c5-b369e4ffe249"],
 " from the operator's eigensystem."
}], "Text",ExpressionUUID->"736a6743-938a-4a51-953c-25ea34dfb452"],

Cell[BoxData[
 RowBox[{"spec", " ", "=", " ", 
  RowBox[{"With", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"sys", " ", "=", " ", 
      RowBox[{"Eigensystem", "[", 
       RowBox[{"PauliMatrix", "[", "1", "]"}], "]"}]}], "}"}], ",", "\n", 
    "  ", 
    RowBox[{"Total", "[", 
     RowBox[{"MapThread", "[", 
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{"f", "[", "#1", "]"}], " ", 
         RowBox[{"KroneckerProduct", "[", 
          RowBox[{"#2", ",", " ", 
           RowBox[{"Conjugate", "[", "#2", "]"}]}], "]"}]}], " ", "&"}], ",", 
       " ", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"sys", "[", 
          RowBox[{"[", "1", "]"}], "]"}], ",", " ", 
         RowBox[{"Normalize", " ", "/@", " ", 
          RowBox[{"sys", "[", 
           RowBox[{"[", "2", "]"}], "]"}]}]}], "}"}]}], "]"}], "]"}]}], 
   "]"}]}]], "Input",
 CellLabel->
  "In[59]:= ",ExpressionUUID->"8e4cd71d-3267-46f8-bb23-984243501119"],

Cell[TextData[{
 "Confirm it equals the built-in ",
 Cell[BoxData["MatrixFunction"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "04c45363-b7c3-4cb7-8698-666f72ca770f"],
 "."
}], "Text",ExpressionUUID->"edc1b8d2-a933-4853-bd1a-c5296585da40"],

Cell[BoxData[
 RowBox[{"spec", " ", "==", " ", 
  RowBox[{"MatrixFunction", "[", 
   RowBox[{"f", ",", " ", 
    RowBox[{"PauliMatrix", "[", "1", "]"}]}], "]"}]}]], "Input",
 CellLabel->
  "In[60]:= ",ExpressionUUID->"6e0830b2-c02f-4cb5-9045-2a34b1de914b"],

Cell[TextData[{
 StyleBox["QF",
  FontWeight->"Bold"],
 " : the same definition driven by the operator's own ",
 Cell[BoxData["\"\<Eigensystem\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "b73ad613-29a9-4ec7-be29-51a565bd7c23"],
 "."
}], "Text",ExpressionUUID->"ec82e1c4-3da0-4f13-a438-27b0812ae83a"],

Cell[BoxData[
 RowBox[{"With", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"sys", " ", "=", " ", 
     RowBox[{
      RowBox[{"QuantumOperator", "[", "\"\<X\>\"", "]"}], 
      "[", "\"\<Eigensystem\>\"", "]"}]}], "}"}], ",", "\n", " ", 
   RowBox[{"Total", "[", 
    RowBox[{"MapThread", "[", 
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{"f", "[", "#1", "]"}], " ", 
        RowBox[{"KroneckerProduct", "[", 
         RowBox[{"#2", ",", " ", 
          RowBox[{"Conjugate", "[", "#2", "]"}]}], "]"}]}], " ", "&"}], ",", 
      " ", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"sys", "[", 
         RowBox[{"[", "1", "]"}], "]"}], ",", " ", 
        RowBox[{"Normalize", " ", "/@", " ", 
         RowBox[{"sys", "[", 
          RowBox[{"[", "2", "]"}], "]"}]}]}], "}"}]}], "]"}], "]"}]}], 
  "]"}]], "Input",
 CellLabel->
  "In[61]:= ",ExpressionUUID->"82efa597-33e3-4800-a584-ed9874a50171"],

Cell[TextData[{
 "The result ",
 Cell[BoxData[
  StyleBox[
   RowBox[{"\|01d453", 
    StyleBox["(",
     SpanMaxSize->1], 
    SubscriptBox["\|01d70e", "\|01d465"], 
    StyleBox[")",
     SpanMaxSize->1], "=", 
    FractionBox["1", "2"], "(", GridBox[{
      {
       RowBox[{"\|01d453", 
        StyleBox["(",
         SpanMaxSize->1], "1", 
        StyleBox[")",
         SpanMaxSize->1], "+", "\|01d453", 
        StyleBox["(",
         SpanMaxSize->1], 
        RowBox[{"-", "1"}], 
        StyleBox[")",
         SpanMaxSize->1]}], 
       RowBox[{"\|01d453", 
        StyleBox["(",
         SpanMaxSize->1], "1", 
        StyleBox[")",
         SpanMaxSize->1], "-", "\|01d453", 
        StyleBox["(",
         SpanMaxSize->1], 
        RowBox[{"-", "1"}], 
        StyleBox[")",
         SpanMaxSize->1]}]},
      {
       RowBox[{"\|01d453", 
        StyleBox["(",
         SpanMaxSize->1], "1", 
        StyleBox[")",
         SpanMaxSize->1], "-", "\|01d453", 
        StyleBox["(",
         SpanMaxSize->1], 
        RowBox[{"-", "1"}], 
        StyleBox[")",
         SpanMaxSize->1]}], 
       RowBox[{"\|01d453", 
        StyleBox["(",
         SpanMaxSize->1], "1", 
        StyleBox[")",
         SpanMaxSize->1], "+", "\|01d453", 
        StyleBox["(",
         SpanMaxSize->1], 
        RowBox[{"-", "1"}], 
        StyleBox[")",
         SpanMaxSize->1]}]}
     }], ")"}],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "b179f854-a7cc-4a0e-bd67-b2cac698ddd2"],
 " shows ",
 Cell[BoxData[
  StyleBox["\|01d453",
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "4d8a681e-5894-40a6-8d37-46a5b1d16097"],
 " acting through the eigenbasis, not entry by entry, and the WL check \
confirms it agrees with ",
 Cell[BoxData["MatrixFunction"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "809f735a-332d-4927-ae0c-39be126fa035"],
 "."
}], "Text",ExpressionUUID->"d89f4481-ed86-4a7c-87d1-a9f7bb7a27ff"],

Cell[TextData[{
 "2.6 [BSc] How do I compute an expectation value and a variance on a pure \
state as ",
 Cell[BoxData[
  StyleBox[
   RowBox[{
    TemplateBox[{
      StyleBox["\|01d713"]},
     "Bra"], 
    OverscriptBox["\|01d434", "^"], 
    TemplateBox[{
      StyleBox["\|01d713"]},
     "Ket"]}],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "1b0ab523-6189-49b4-94c7-f863aff11d6f"],
 "?"
}], "Subsection",ExpressionUUID->"a08e131f-adba-43e3-b2e8-368ed0f7c5f1"],

Cell[TextData[{
 "The mean is ",
 Cell[BoxData[
  StyleBox[
   RowBox[{
    RowBox[{
     StyleBox["\[LeftAngleBracket]",
      SpanMaxSize->1], "\|01d434", 
     StyleBox["\[RightAngleBracket]",
      SpanMaxSize->1]}], "=", 
    RowBox[{
     TemplateBox[{
       StyleBox["\|01d713"]},
      "Bra"], "\|01d434", 
     TemplateBox[{
       StyleBox["\|01d713"]},
      "Ket"]}]}],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "8a893081-0f3a-4dd9-8c6e-750fbb7568bf"],
 " and the variance is ",
 Cell[BoxData[
  StyleBox[
   RowBox[{
    StyleBox["\[LeftAngleBracket]",
     SpanMaxSize->1], 
    SuperscriptBox["\|01d434", "2"], 
    StyleBox["\[RightAngleBracket]",
     SpanMaxSize->1], "-", 
    SuperscriptBox[
     RowBox[{
      StyleBox["\[LeftAngleBracket]",
       SpanMaxSize->1], "\|01d434", "\[VeryThinSpace]", 
      StyleBox["\[RightAngleBracket]",
       SpanMaxSize->1]}], "2"]}],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "d6532a92-9b36-4891-bf9b-968f6fbaf44e"],
 "."
}], "Text",ExpressionUUID->"66bb816f-0ebf-4dd8-b905-ce729ae5a7f9"],

Cell[TextData[{
 StyleBox["WL",
  FontWeight->"Bold"],
 " : contract the bra, operator, and ket for the mean."
}], "Text",ExpressionUUID->"110e1462-23a9-4f5b-9b13-2c96127b197a"],

Cell[BoxData[
 RowBox[{"With", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{"a", " ", "=", " ", 
      RowBox[{"PauliMatrix", "[", "3", "]"}]}], ",", " ", 
     RowBox[{"psi", " ", "=", " ", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"Cos", "[", 
         RowBox[{"\[Theta]", "/", "2"}], "]"}], ",", " ", 
        RowBox[{
         RowBox[{"Exp", "[", 
          RowBox[{"I", " ", "\[Phi]"}], "]"}], " ", 
         RowBox[{"Sin", "[", 
          RowBox[{"\[Theta]", "/", "2"}], "]"}]}]}], "}"}]}]}], "}"}], ",", 
   "\n", " ", 
   RowBox[{"FullSimplify", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"Conjugate", "[", "psi", "]"}], " ", ".", " ", "a", " ", ".", 
      " ", "psi"}], ",", " ", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"\[Theta]", ",", " ", "\[Phi]"}], "}"}], " ", "\[Element]", 
      " ", "Reals"}]}], "]"}]}], "]"}]], "Input",
 CellLabel->
  "In[62]:= ",ExpressionUUID->"92ac8928-6632-46b9-9e0a-1e769e9b4f82"],

Cell[TextData[{
 "The variance reuses ",
 Cell[BoxData[
  StyleBox[
   SuperscriptBox["\|01d434", "2"],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "17ab352c-2d1a-4c7e-bdf1-215b73656349"],
 "."
}], "Text",ExpressionUUID->"54bf338c-f79e-4dd6-9c2a-468fe67504bd"],

Cell[BoxData[
 RowBox[{"With", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{"a", " ", "=", " ", 
      RowBox[{"PauliMatrix", "[", "3", "]"}]}], ",", " ", 
     RowBox[{"psi", " ", "=", " ", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"Cos", "[", 
         RowBox[{"\[Theta]", "/", "2"}], "]"}], ",", " ", 
        RowBox[{
         RowBox[{"Exp", "[", 
