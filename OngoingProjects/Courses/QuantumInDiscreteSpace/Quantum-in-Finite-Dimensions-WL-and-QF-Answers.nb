Cell[17692, 525, 197, 4, 70, "Text",ExpressionUUID->"ce59f795-3236-4628-b846-97e31c0f8f10"],
Cell[17892, 531, 663, 20, 70, "Input",ExpressionUUID->"bb0ad461-744e-43a1-baee-5be7e460e956"],
Cell[18558, 553, 650, 15, 70, "Text",ExpressionUUID->"263386f1-18b2-496a-91dd-74221fdbc2a6"],
