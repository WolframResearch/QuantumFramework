          RowBox[{"\[Theta]", "/", "2"}], "]"}]}]}], "}"}]}]}], "}"}], ",", 
   "\n", " ", 
   RowBox[{"FullSimplify", "[", 
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{"Conjugate", "[", "psi", "]"}], " ", ".", " ", "a", " ", ".", 
       " ", "a", " ", ".", " ", "psi"}], " ", "-", " ", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{
         RowBox[{"Conjugate", "[", "psi", "]"}], " ", ".", " ", "a", " ", ".",
          " ", "psi"}], ")"}], "^", "2"}]}], ",", " ", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"\[Theta]", ",", " ", "\[Phi]"}], "}"}], " ", "\[Element]", 
      " ", "Reals"}]}], "]"}]}], "]"}]], "Input",
 CellLabel->
  "In[63]:= ",ExpressionUUID->"fed6b855-b936-44ff-9a0d-cd3b04cdd909"],

Cell[TextData[{
 StyleBox["QF",
  FontWeight->"Bold"],
 " : the mean as a bra-operator-ket scalar."
}], "Text",ExpressionUUID->"6ae0aee2-2863-416d-b942-2e39cb1d630b"],

Cell[BoxData[
 RowBox[{"With", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{"a", " ", "=", " ", 
      RowBox[{"QuantumOperator", "[", "\"\<Z\>\"", "]"}]}], ",", " ", 
     RowBox[{"ps", " ", "=", " ", 
      RowBox[{"QuantumState", "[", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"Cos", "[", 
          RowBox[{"\[Theta]", "/", "2"}], "]"}], ",", " ", 
         RowBox[{
          RowBox[{"Exp", "[", 
           RowBox[{"I", " ", "\[Phi]"}], "]"}], " ", 
          RowBox[{"Sin", "[", 
           RowBox[{"\[Theta]", "/", "2"}], "]"}]}]}], "}"}], "]"}]}]}], "}"}],
    ",", "\n", " ", 
   RowBox[{"FullSimplify", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"(", 
       RowBox[{
        RowBox[{"ps", "[", "\"\<Dagger\>\"", "]"}], " ", "@", " ", 
        RowBox[{"a", " ", "@", " ", "ps"}]}], ")"}], "[", "\"\<Scalar\>\"", 
      "]"}], ",", " ", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"\[Theta]", ",", " ", "\[Phi]"}], "}"}], " ", "\[Element]", 
      " ", "Reals"}]}], "]"}]}], "]"}]], "Input",
 CellLabel->
  "In[64]:= ",ExpressionUUID->"d1df88d0-438a-4080-b64f-a40f53790073"],

Cell["The variance, again as scalars.", "Text",ExpressionUUID->"7194e9fa-a203-4386-9a1a-7aa495f3a651"],

Cell[BoxData[
 RowBox[{"With", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{"a", " ", "=", " ", 
      RowBox[{"QuantumOperator", "[", "\"\<Z\>\"", "]"}]}], ",", " ", 
     RowBox[{"ps", " ", "=", " ", 
      RowBox[{"QuantumState", "[", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"Cos", "[", 
          RowBox[{"\[Theta]", "/", "2"}], "]"}], ",", " ", 
         RowBox[{
          RowBox[{"Exp", "[", 
           RowBox[{"I", " ", "\[Phi]"}], "]"}], " ", 
          RowBox[{"Sin", "[", 
           RowBox[{"\[Theta]", "/", "2"}], "]"}]}]}], "}"}], "]"}]}]}], "}"}],
    ",", "\n", " ", 
   RowBox[{"FullSimplify", "[", 
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{"(", 
        RowBox[{
         RowBox[{"ps", "[", "\"\<Dagger\>\"", "]"}], " ", "@", " ", 
         RowBox[{"a", " ", "@", " ", 
          RowBox[{"a", " ", "@", " ", "ps"}]}]}], ")"}], "[", "\"\<Scalar\>\"",
        "]"}], " ", "-", " ", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{
           RowBox[{"ps", "[", "\"\<Dagger\>\"", "]"}], " ", "@", " ", 
           RowBox[{"a", " ", "@", " ", "ps"}]}], ")"}], "[", "\"\<Scalar\>\"",
          "]"}], ")"}], "^", "2"}]}], ",", "\n", "  ", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"\[Theta]", ",", " ", "\[Phi]"}], "}"}], " ", "\[Element]", 
      " ", "Reals"}]}], "]"}]}], "]"}]], "Input",
 CellLabel->
  "In[65]:= ",ExpressionUUID->"7f281ce9-6ede-4ec2-828a-28286d9bb0fb"],

Cell[TextData[{
 "Both give ",
 Cell[BoxData[
  StyleBox[
   RowBox[{
    StyleBox["\[LeftAngleBracket]",
     SpanMaxSize->1], 
    SubscriptBox["\|01d70e", "\|01d467"], 
    StyleBox["\[RightAngleBracket]",
     SpanMaxSize->1], "=", 
    StyleBox["cos",
     FontSlant->"Plain"], "\[ThinSpace]", "\|01d703"}],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "c4eb97e6-e855-4c8f-af25-7c489e648471"],
 " and ",
 Cell[BoxData[
  StyleBox[
   RowBox[{
    StyleBox["Var",
     FontSlant->"Plain"], "=", 
    SuperscriptBox[
     StyleBox["sin",
      FontSlant->"Plain"], "2"], "\[ThinSpace]", "\|01d703"}],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "5b7bc3f0-2114-40ab-9805-9e2914f4b173"],
 ": the spin points along ",
 Cell[BoxData[
  StyleBox["\|01d467",
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "48725c58-a254-4396-96d2-77ddfac85323"],
 " with certainty at the poles and is maximally uncertain on the equator."
}], "Text",ExpressionUUID->"d0bb1f4c-bf01-400b-98a6-9412ffe3d917"],

Cell["\<\
2.7 [BSc] How do I write the resolution of the identity in an orthonormal \
basis?\
\>", "Subsection",ExpressionUUID->"29ad6693-101b-4c0e-aabc-b43c5e53f301"],

Cell[TextData[{
 "Any orthonormal basis is complete, ",
 Cell[BoxData[
  StyleBox[
   RowBox[{
    RowBox[{
     UnderscriptBox["\[Sum]", "\|01d456",
      LimitsPositioning->False], 
     RowBox[{
      TemplateBox[{
        StyleBox["\|01d456"]},
       "Ket"], 
      TemplateBox[{
        StyleBox["\|01d456"]},
       "Bra"]}]}], "=", "\|01d43c"}],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "0ab64c67-9af8-4444-8e55-436434d53560"],
 "."
}], "Text",ExpressionUUID->"c125bbbb-17a6-46f6-9b01-3ace983ae4f8"],

Cell[TextData[{
 StyleBox["WL",
  FontWeight->"Bold"],
 " : sum the eigenprojectors of a generic Hermitian operator."
}], "Text",ExpressionUUID->"80fa5815-5020-4556-a2a5-0d9604f4da12"],

Cell[BoxData[
 RowBox[{"With", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"vecs", " ", "=", " ", 
     RowBox[{"Normalize", " ", "/@", " ", 
      RowBox[{"Eigenvectors", "[", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"a1", ",", " ", 
           RowBox[{"a2", " ", "+", " ", 
            RowBox[{"I", " ", "a3"}]}]}], "}"}], ",", " ", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{"a2", " ", "-", " ", 
            RowBox[{"I", " ", "a3"}]}], ",", " ", "a4"}], "}"}]}], "}"}], 
       "]"}]}]}], "}"}], ",", "\n", " ", 
   RowBox[{"FullSimplify", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"Total", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"KroneckerProduct", "[", 
          RowBox[{"#", ",", " ", 
           RowBox[{"Conjugate", "[", "#", "]"}]}], "]"}], " ", "&"}], " ", "/@",
         " ", "vecs"}], "]"}], " ", "==", " ", 
      RowBox[{"IdentityMatrix", "[", "2", "]"}]}], ",", "\n", "  ", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{
       "a1", " ", "|", " ", "a2", " ", "|", " ", "a3", " ", "|", " ", "a4"}], 
       ")"}], " ", "\[Element]", " ", "Reals"}]}], "]"}]}], "]"}]], "Input",
 CellLabel->
  "In[66]:= ",ExpressionUUID->"778dc443-f31d-4b19-b9b0-ed73a470e7e2"],

Cell[TextData[{
 StyleBox["QF",
  FontWeight->"Bold"],
 " : the same with the operator's ",
 Cell[BoxData["\"\<Eigenvectors\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "b0ca8492-de44-4784-8370-c76d835badaf"],
 "."
}], "Text",ExpressionUUID->"922e7f9c-c40f-4185-b497-c67f690ba99d"],

Cell[BoxData[
 RowBox[{"With", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"vecs", " ", "=", " ", 
     RowBox[{"Normalize", " ", "/@", " ", 
      RowBox[{
       RowBox[{"QuantumOperator", "[", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{"a1", ",", " ", 
            RowBox[{"a2", " ", "+", " ", 
             RowBox[{"I", " ", "a3"}]}]}], "}"}], ",", " ", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"a2", " ", "-", " ", 
             RowBox[{"I", " ", "a3"}]}], ",", " ", "a4"}], "}"}]}], "}"}], 
        "]"}], "[", "\"\<Eigenvectors\>\"", "]"}]}]}], "}"}], ",", "\n", " ", 
   
   RowBox[{"FullSimplify", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"Total", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"KroneckerProduct", "[", 
          RowBox[{"#", ",", " ", 
           RowBox[{"Conjugate", "[", "#", "]"}]}], "]"}], " ", "&"}], " ", "/@",
         " ", "vecs"}], "]"}], " ", "==", " ", 
      RowBox[{"IdentityMatrix", "[", "2", "]"}]}], ",", "\n", "  ", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{
       "a1", " ", "|", " ", "a2", " ", "|", " ", "a3", " ", "|", " ", "a4"}], 
       ")"}], " ", "\[Element]", " ", "Reals"}]}], "]"}]}], "]"}]], "Input",
 CellLabel->
  "In[67]:= ",ExpressionUUID->"f54e023a-6244-4168-96ee-876efb8d8f0f"],

Cell[TextData[{
 "Both return ",
 Cell[BoxData["True"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "510518fa-4739-4a8f-996c-e891b7d0d487"],
 ": the eigenprojectors of any observable sum to the identity."
}], "Text",ExpressionUUID->"815043e3-9068-4742-af7b-e1f5ff7a5406"],

Cell["\<\
2.8 [BSc] How do I decide whether two observables are compatible (commute) \
and find a simultaneous eigenbasis?\
\>", "Subsection",ExpressionUUID->"7358286d-e793-47bc-a295-82351e650134"],

Cell[TextData[{
 "Two observables are compatible exactly when they commute, and then they \
share an eigenbasis. Each of ",
 Cell[BoxData[
  StyleBox[
   RowBox[{"\|01d44b", "\[CircleTimes]", "\|01d44b"}],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "28c5844a-7ef2-4eed-89d0-1a91e8eef61d"],
 " and ",
 Cell[BoxData[
  StyleBox[
   RowBox[{"\|01d44d", "\[CircleTimes]", "\|01d44d"}],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "a42f6f58-70bd-4896-a99d-511149cfe93f"],
 " is degenerate (eigenvalues ",
 Cell[BoxData[
  StyleBox[
   RowBox[{"\[PlusMinus]", "1"}],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "582db50f-5181-48db-8ee6-6c45b889a781"],
 ", each doubled), so neither alone pins the basis down; a generic \
combination ",
 Cell[BoxData[
  StyleBox[
   RowBox[{"\|01d434", "+", "\|01d450", "\|01d435"}],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "ce46b8ad-d68b-464d-9278-cf051c156d92"],
 " is non-degenerate, and ",
 StyleBox["its", "TI"],
 " eigenvectors are the simultaneous eigenbasis. So we find the basis, not \
assume it."
}], "Text",ExpressionUUID->"9fecc605-1b66-4a98-a253-c619921f4fc7"],

Cell[TextData[{
 StyleBox["WL",
  FontWeight->"Bold"],
 " : compatibility is the vanishing commutator."
}], "Text",ExpressionUUID->"1260f8ca-2f80-4fe7-a293-00aa571501aa"],

Cell[BoxData[
 RowBox[{"With", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{"a", " ", "=", " ", 
      RowBox[{"KroneckerProduct", "[", 
       RowBox[{
        RowBox[{"PauliMatrix", "[", "1", "]"}], ",", " ", 
        RowBox[{"PauliMatrix", "[", "1", "]"}]}], "]"}]}], ",", " ", 
     RowBox[{"b", " ", "=", " ", 
      RowBox[{"KroneckerProduct", "[", 
       RowBox[{
        RowBox[{"PauliMatrix", "[", "3", "]"}], ",", " ", 
        RowBox[{"PauliMatrix", "[", "3", "]"}]}], "]"}]}]}], "}"}], ",", "\n",
    " ", 
   RowBox[{
    RowBox[{"a", " ", ".", " ", "b"}], " ", "==", " ", 
    RowBox[{"b", " ", ".", " ", "a"}]}]}], "]"}]], "Input",
 CellLabel->
  "In[68]:= ",ExpressionUUID->"48ce63e6-6f37-4b91-8300-632beb1abde3"],

Cell[TextData[{
 "Diagonalizing ",
 Cell[BoxData[
  StyleBox[
   RowBox[{"\|01d434", "+", "\[Pi]", "\|01d435"}],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "737da561-53ca-40c0-a94c-edbba88defdd"],
 " once gives the candidate common eigenbasis (its rows the simultaneous \
eigenvectors); bind it."
}], "Text",ExpressionUUID->"d5917e77-d98d-414b-889f-7ee23679247b"],

Cell[BoxData[
 RowBox[{
  RowBox[{"u", " ", "=", " ", 
   RowBox[{"With", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"a", " ", "=", " ", 
        RowBox[{"KroneckerProduct", "[", 
         RowBox[{
          RowBox[{"PauliMatrix", "[", "1", "]"}], ",", " ", 
          RowBox[{"PauliMatrix", "[", "1", "]"}]}], "]"}]}], ",", " ", 
       RowBox[{"b", " ", "=", " ", 
        RowBox[{"KroneckerProduct", "[", 
         RowBox[{
          RowBox[{"PauliMatrix", "[", "3", "]"}], ",", " ", 
          RowBox[{"PauliMatrix", "[", "3", "]"}]}], "]"}]}]}], "}"}], ",", 
     "\n", "  ", 
     RowBox[{"Normalize", " ", "/@", " ", 
      RowBox[{"Eigenvectors", "[", 
       RowBox[{"a", " ", "+", " ", 
        RowBox[{"\[Pi]", " ", "b"}]}], "]"}]}]}], "]"}]}], ";"}]], "Input",
 CellLabel->
  "In[69]:= ",ExpressionUUID->"9bcddc0e-12f1-4070-a537-799af2cd9d43"],

Cell[TextData[{
 "That basis diagonalizes ",
 Cell[BoxData[
  StyleBox[
   RowBox[{"\|01d434", "=", "\|01d44b", "\[CircleTimes]", "\|01d44b"}],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "e38bb82e-1960-4cbf-adc0-c74daea4aa0d"],
 "."
}], "Text",ExpressionUUID->"9a258475-4482-462a-b363-854355f9c70e"],

Cell[BoxData[
 RowBox[{"With", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"a", " ", "=", " ", 
     RowBox[{"KroneckerProduct", "[", 
      RowBox[{
       RowBox[{"PauliMatrix", "[", "1", "]"}], ",", " ", 
       RowBox[{"PauliMatrix", "[", "1", "]"}]}], "]"}]}], "}"}], ",", "\n", 
   " ", 
   RowBox[{"DiagonalMatrixQ", "[", 
    RowBox[{"Chop", "[", 
     RowBox[{
      RowBox[{"Conjugate", "[", "u", "]"}], " ", ".", " ", "a", " ", ".", " ", 
      RowBox[{"Transpose", "[", "u", "]"}]}], "]"}], "]"}]}], "]"}]], "Input",\

 CellLabel->
  "In[70]:= ",ExpressionUUID->"8316f026-78fb-4b5c-b608-db84c1b566d4"],

Cell[TextData[{
 "And it diagonalizes ",
 Cell[BoxData[
  StyleBox[
   RowBox[{"\|01d435", "=", "\|01d44d", "\[CircleTimes]", "\|01d44d"}],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "9edd3038-9536-4cd4-8f18-f74a15e65e26"],
 ", so the basis is simultaneous."
}], "Text",ExpressionUUID->"48fc7dcb-76ef-4074-8159-6b175065e87b"],

Cell[BoxData[
 RowBox[{"With", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"b", " ", "=", " ", 
     RowBox[{"KroneckerProduct", "[", 
      RowBox[{
       RowBox[{"PauliMatrix", "[", "3", "]"}], ",", " ", 
       RowBox[{"PauliMatrix", "[", "3", "]"}]}], "]"}]}], "}"}], ",", "\n", 
   " ", 
   RowBox[{"DiagonalMatrixQ", "[", 
    RowBox[{"Chop", "[", 
     RowBox[{
      RowBox[{"Conjugate", "[", "u", "]"}], " ", ".", " ", "b", " ", ".", " ", 
      RowBox[{"Transpose", "[", "u", "]"}]}], "]"}], "]"}]}], "]"}]], "Input",\

 CellLabel->
  "In[71]:= ",ExpressionUUID->"97106e6c-9ab6-4773-8240-4bbdc66f088e"],

Cell[TextData[{
 StyleBox["QF",
  FontWeight->"Bold"],
 " : compatibility is the ",
 StyleBox["operator", "TI"],
 " equality ",
 Cell[BoxData[
  RowBox[{
   RowBox[{"a", " ", "@", " ", "b"}], " ", "==", " ", 
   RowBox[{"b", " ", "@", " ", "a"}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "a65cebcd-54bf-44a4-b596-6eae8f48710f"],
 "."
}], "Text",ExpressionUUID->"f6fb2a3b-08cb-473f-b2ee-09ca4b753e1f"],

Cell[BoxData[
 RowBox[{"With", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{"a", " ", "=", " ", 
      RowBox[{"QuantumTensorProduct", "[", 
       RowBox[{
        RowBox[{"QuantumOperator", "[", "\"\<X\>\"", "]"}], ",", " ", 
        RowBox[{"QuantumOperator", "[", "\"\<X\>\"", "]"}]}], "]"}]}], ",", 
     "\n", "   ", 
     RowBox[{"b", " ", "=", " ", 
      RowBox[{"QuantumTensorProduct", "[", 
       RowBox[{
        RowBox[{"QuantumOperator", "[", "\"\<Z\>\"", "]"}], ",", " ", 
        RowBox[{"QuantumOperator", "[", "\"\<Z\>\"", "]"}]}], "]"}]}]}], 
    "}"}], ",", "\n", " ", 
   RowBox[{
    RowBox[{"a", " ", "@", " ", "b"}], " ", "==", " ", 
    RowBox[{"b", " ", "@", " ", "a"}]}]}], "]"}]], "Input",
 CellLabel->
  "In[72]:= ",ExpressionUUID->"856f77b4-2d7f-4edc-b716-8ee8ada2428c"],

Cell[TextData[{
 "The common eigenbasis is the eigenvectors of ",
 Cell[BoxData[
  RowBox[{"a", " ", "+", " ", 
   RowBox[{"Pi", " ", "b"}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "f6975ace-e375-4761-9493-a51a96086349"],
 ". Each found state is an eigenstate of ",
 Cell[BoxData[
  StyleBox[
   RowBox[{"\|01d434", "=", "\|01d44b", "\[CircleTimes]", "\|01d44b"}],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "72977eb5-a050-428e-bd5f-108e475938be"],
 " (it returns unchanged up to phase), checked without leaving the object \
model."
}], "Text",ExpressionUUID->"2bfaf6b2-ed89-4361-83dc-99d20749fc15"],

Cell[BoxData[
 RowBox[{"With", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{"a", " ", "=", " ", 
      RowBox[{"QuantumTensorProduct", "[", 
       RowBox[{
        RowBox[{"QuantumOperator", "[", "\"\<X\>\"", "]"}], ",", " ", 
        RowBox[{"QuantumOperator", "[", "\"\<X\>\"", "]"}]}], "]"}]}], ",", 
     "\n", "   ", 
     RowBox[{"b", " ", "=", " ", 
      RowBox[{"QuantumTensorProduct", "[", 
       RowBox[{
        RowBox[{"QuantumOperator", "[", "\"\<Z\>\"", "]"}], ",", " ", 
        RowBox[{"QuantumOperator", "[", "\"\<Z\>\"", "]"}]}], "]"}]}]}], 
    "}"}], ",", "\n", " ", 
   RowBox[{"With", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"basis", " ", "=", " ", 
       RowBox[{"QuantumState", " ", "/@", " ", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{"a", " ", "+", " ", 
           RowBox[{"\[Pi]", " ", "b"}]}], ")"}], "[", "\"\<Eigenvectors\>\"", 
         "]"}]}]}], "}"}], ",", "\n", "  ", 
     RowBox[{"AllTrue", "[", 
      RowBox[{"basis", ",", " ", 
       RowBox[{
        RowBox[{
         RowBox[{"a", "[", "#", "]"}], " ", "==", " ", "#"}], " ", "&"}]}], 
      "]"}]}], "]"}]}], "]"}]], "Input",
 CellLabel->
  "In[73]:= ",ExpressionUUID->"15763fec-cd85-47ce-b052-42ebbb087e69"],

Cell[TextData[{
 "And each is equally an eigenstate of ",
 Cell[BoxData[
  StyleBox[
   RowBox[{"\|01d435", "=", "\|01d44d", "\[CircleTimes]", "\|01d44d"}],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "0c1d9276-4483-48e8-a12d-a77f807aace3"],
 ", confirming the basis is simultaneous."
}], "Text",ExpressionUUID->"bcf3319d-b5f1-4680-9bd8-a4848ff479ef"],

Cell[BoxData[
 RowBox[{"With", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{"a", " ", "=", " ", 
      RowBox[{"QuantumTensorProduct", "[", 
       RowBox[{
        RowBox[{"QuantumOperator", "[", "\"\<X\>\"", "]"}], ",", " ", 
        RowBox[{"QuantumOperator", "[", "\"\<X\>\"", "]"}]}], "]"}]}], ",", 
     "\n", "   ", 
     RowBox[{"b", " ", "=", " ", 
      RowBox[{"QuantumTensorProduct", "[", 
       RowBox[{
        RowBox[{"QuantumOperator", "[", "\"\<Z\>\"", "]"}], ",", " ", 
        RowBox[{"QuantumOperator", "[", "\"\<Z\>\"", "]"}]}], "]"}]}]}], 
    "}"}], ",", "\n", " ", 
   RowBox[{"With", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"basis", " ", "=", " ", 
       RowBox[{"QuantumState", " ", "/@", " ", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{"a", " ", "+", " ", 
           RowBox[{"\[Pi]", " ", "b"}]}], ")"}], "[", "\"\<Eigenvectors\>\"", 
         "]"}]}]}], "}"}], ",", "\n", "  ", 
     RowBox[{"AllTrue", "[", 
      RowBox[{"basis", ",", " ", 
       RowBox[{
        RowBox[{
         RowBox[{"b", "[", "#", "]"}], " ", "==", " ", "#"}], " ", "&"}]}], 
      "]"}]}], "]"}]}], "]"}]], "Input",
 CellLabel->
  "In[74]:= ",ExpressionUUID->"9df9d276-7318-4a45-92ac-a4b6f5e94b4b"],

Cell[TextData[{
 "The commutator vanishes and the checks pass. The basis returned by ",
 Cell[BoxData[
  StyleBox[
   RowBox[{"\|01d434", "+", "\[Pi]", "\|01d435"}],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "c02aab01-6900-4291-a257-fa9cbce4e4de"],
 " is the Bell basis, ",
 StyleBox["derived", "TI"],
 " rather than assumed: the coefficient ",
 Cell[BoxData[
  StyleBox["\[Pi]",
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "4560330f-074b-482e-b6c9-6673feb9b886"],
 " only breaks the degeneracy, and any value that does so gives the same \
simultaneous eigenbasis."
}], "Text",ExpressionUUID->"9d50ed97-3249-43b0-a121-386d6745ee07"],

Cell["\<\
2.9 [MSc] How do I construct a complete set of commuting observables (CSCO) \
and label states by their joint spectrum?\
\>", "Subsection",ExpressionUUID->"6d53eb50-7974-4d58-9d5d-77c9b9019f85"],

Cell["\<\
A complete set of commuting observables assigns every basis state a unique \
tuple of eigenvalues.\
\>", "Text",ExpressionUUID->"c33601b1-a50a-4a24-a48a-72940465309a"],

Cell[TextData[{
 StyleBox["WL",
  FontWeight->"Bold"],
 " : first, ",
 Cell[BoxData[
  StyleBox[
   RowBox[{"\|01d44d", "\[CircleTimes]", "\|01d43c"}],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "08c99117-6de9-471f-b113-3e19c448f282"],
 " and ",
 Cell[BoxData[
  StyleBox[
   RowBox[{"\|01d43c", "\[CircleTimes]", "\|01d44d"}],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "a70c37aa-5cfe-458e-836c-ef7738fea8ee"],
 " commute."
}], "Text",ExpressionUUID->"716d90cc-3f82-4b69-8d61-7657ea461ae1"],

Cell[BoxData[
 RowBox[{"With", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{"a", " ", "=", " ", 
      RowBox[{"KroneckerProduct", "[", 
       RowBox[{
        RowBox[{"PauliMatrix", "[", "3", "]"}], ",", " ", 
        RowBox[{"IdentityMatrix", "[", "2", "]"}]}], "]"}]}], ",", " ", 
     RowBox[{"b", " ", "=", " ", 
      RowBox[{"KroneckerProduct", "[", 
       RowBox[{
        RowBox[{"IdentityMatrix", "[", "2", "]"}], ",", " ", 
        RowBox[{"PauliMatrix", "[", "3", "]"}]}], "]"}]}]}], "}"}], ",", "\n",
    " ", 
   RowBox[{
    RowBox[{"a", " ", ".", " ", "b"}], " ", "==", " ", 
    RowBox[{"b", " ", ".", " ", "a"}]}]}], "]"}]], "Input",
 CellLabel->
  "In[75]:= ",ExpressionUUID->"b43cc59c-3309-4549-b8ac-ae9ea13a6ba7"],

Cell["Their joint eigenvalues then label the four states.", "Text",ExpressionUUID->"e1e2d328-93cc-4db2-8d61-dfc2a50a6f78"],

Cell[BoxData[
 RowBox[{"With", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{"a", " ", "=", " ", 
      RowBox[{"KroneckerProduct", "[", 
       RowBox[{
        RowBox[{"PauliMatrix", "[", "3", "]"}], ",", " ", 
        RowBox[{"IdentityMatrix", "[", "2", "]"}]}], "]"}]}], ",", " ", 
     RowBox[{"b", " ", "=", " ", 
      RowBox[{"KroneckerProduct", "[", 
       RowBox[{
        RowBox[{"IdentityMatrix", "[", "2", "]"}], ",", " ", 
        RowBox[{"PauliMatrix", "[", "3", "]"}]}], "]"}]}]}], "}"}], ",", "\n",
    " ", 
   RowBox[{"Transpose", "[", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"Diagonal", "[", "a", "]"}], ",", " ", 
      RowBox[{"Diagonal", "[", "b", "]"}]}], "}"}], "]"}]}], "]"}]], "Input",
 CellLabel->
  "In[76]:= ",ExpressionUUID->"93a66f05-88bd-4cd1-9e1b-ed5e4d5c8389"],

Cell[TextData[{
 StyleBox["QF",
  FontWeight->"Bold"],
 " : the same commutation check with ",
 Cell[BoxData["QuantumTensorProduct"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "8f0bcd08-9a72-4a53-bc78-437b927965e5"],
 "."
}], "Text",ExpressionUUID->"f634cfbd-f6e9-4d54-b6e6-923d00498a35"],

Cell[BoxData[
 RowBox[{"With", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{"a", " ", "=", " ", 
      RowBox[{"QuantumTensorProduct", "[", 
       RowBox[{
        RowBox[{"QuantumOperator", "[", "\"\<Z\>\"", "]"}], ",", " ", 
        RowBox[{"QuantumOperator", "[", "\"\<I\>\"", "]"}]}], "]"}]}], ",", 
     "\n", "   ", 
     RowBox[{"b", " ", "=", " ", 
      RowBox[{"QuantumTensorProduct", "[", 
       RowBox[{
        RowBox[{"QuantumOperator", "[", "\"\<I\>\"", "]"}], ",", " ", 
        RowBox[{"QuantumOperator", "[", "\"\<Z\>\"", "]"}]}], "]"}]}]}], 
    "}"}], ",", "\n", " ", 
   RowBox[{
    RowBox[{"a", " ", "@", " ", "b"}], " ", "==", " ", 
    RowBox[{"b", " ", "@", " ", "a"}]}]}], "]"}]], "Input",
 CellLabel->
  "In[77]:= ",ExpressionUUID->"42962180-37df-4a01-ae6d-bb209929112b"],

Cell["And the joint spectrum, read from the diagonals.", "Text",ExpressionUUID->"75014b99-6931-47dc-ab3d-1f00c71073a3"],

Cell[BoxData[
 RowBox[{"With", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{"a", " ", "=", " ", 
      RowBox[{"QuantumTensorProduct", "[", 
       RowBox[{
        RowBox[{"QuantumOperator", "[", "\"\<Z\>\"", "]"}], ",", " ", 
        RowBox[{"QuantumOperator", "[", "\"\<I\>\"", "]"}]}], "]"}]}], ",", 
     "\n", "   ", 
     RowBox[{"b", " ", "=", " ", 
      RowBox[{"QuantumTensorProduct", "[", 
       RowBox[{
        RowBox[{"QuantumOperator", "[", "\"\<I\>\"", "]"}], ",", " ", 
        RowBox[{"QuantumOperator", "[", "\"\<Z\>\"", "]"}]}], "]"}]}]}], 
    "}"}], ",", "\n", " ", 
   RowBox[{"Transpose", "[", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"Diagonal", "[", 
       RowBox[{"Normal", "[", 
        RowBox[{"a", "[", "\"\<Matrix\>\"", "]"}], "]"}], "]"}], ",", " ", 
      RowBox[{"Diagonal", "[", 
       RowBox[{"Normal", "[", 
        RowBox[{"b", "[", "\"\<Matrix\>\"", "]"}], "]"}], "]"}]}], "}"}], 
    "]"}]}], "]"}]], "Input",
 CellLabel->
  "In[78]:= ",ExpressionUUID->"12335761-46d6-48e3-a82f-db1710d86fc0"],

Cell[TextData[{
 "Both confirm the two observables commute and return the joint spectrum ",
 Cell[BoxData[
  StyleBox[
   RowBox[{
    RowBox[{"{", 
     StyleBox["(",
      SpanMaxSize->1], 
     RowBox[{"+", ",", "+"}], 
     StyleBox[")",
      SpanMaxSize->1]}], ",", 
    RowBox[{
     StyleBox["(",
      SpanMaxSize->1], 
     RowBox[{"+", ",", "-"}], 
     StyleBox[")",
      SpanMaxSize->1]}], ",", 
    RowBox[{
     StyleBox["(",
      SpanMaxSize->1], 
     RowBox[{"-", ",", "+"}], 
     StyleBox[")",
      SpanMaxSize->1]}], ",", 
    RowBox[{
     StyleBox["(",
      SpanMaxSize->1], 
     RowBox[{"-", ",", "-"}], 
     StyleBox[")",
      SpanMaxSize->1], "}"}]}],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "47eca802-a43a-4fb2-a7f3-9aaece6eb5cc"],
 ": the four pairs are distinct, so the two observables form a complete label \
for the basis."
}], "Text",ExpressionUUID->"704868ed-8aeb-46b9-940a-20f13f5867c3"],

Cell[TextData[{
 "2.10 [MSc] How do I define the Hilbert-Schmidt operator inner product ",
 Cell[BoxData[
  StyleBox[
   RowBox[{
    StyleBox["\[LeftAngleBracket]",
     SpanMaxSize->1], 
    RowBox[{"\|01d434", ",", "\|01d435"}], "\[VeryThinSpace]", 
    StyleBox["\[RightAngleBracket]",
     SpanMaxSize->1], "=", 
    StyleBox["Tr",
     FontSlant->"Plain"], 
    StyleBox["[",
     SpanMaxSize->1], 
    RowBox[{
     SuperscriptBox["\|01d434", "\[Dagger]"], "\|01d435"}], 
    StyleBox["]",
     SpanMaxSize->1]}],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "133eed88-d81c-4676-ad3f-cf68f914f4ce"],
 " and expand an operator in the Pauli basis?"
}], "Subsection",ExpressionUUID->"f11c82d6-7e15-43df-8956-c01b8d0cd7bf"],

Cell[TextData[{
 "Operators carry their own inner product, ",
 Cell[BoxData[
  StyleBox[
   RowBox[{
    StyleBox["\[LeftAngleBracket]",
     SpanMaxSize->1], 
    RowBox[{"\|01d434", ",", "\|01d435"}], "\[VeryThinSpace]", 
    StyleBox["\[RightAngleBracket]",
     SpanMaxSize->1], "=", 
    StyleBox["Tr",
     FontSlant->"Plain"], 
    StyleBox["[",
     SpanMaxSize->1], 
    RowBox[{
     SuperscriptBox["\|01d434", "\[Dagger]"], "\|01d435"}], 
    StyleBox["]",
     SpanMaxSize->1]}],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "72985793-b71b-4628-abf9-8d83445cc5b5"],
 ", under which the Paulis are orthogonal; the expansion coefficients are ",
 Cell[BoxData[
  StyleBox[
   RowBox[{
    SubscriptBox["\|01d450", "\|01d457"], "=", 
    FractionBox["1", "2"], 
    StyleBox["Tr",
     FontSlant->"Plain"], 
    StyleBox["[",
     SpanMaxSize->1], 
    RowBox[{
     SubscriptBox["\|01d70e", "\|01d457"], "\|01d434"}], 
    StyleBox["]",
     SpanMaxSize->1]}],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "06096c89-0ba5-4dd2-8d5a-362e2c6058de"],
 "."
}], "Text",ExpressionUUID->"e64a3311-c56c-41dd-a30f-57da8ea3c3ec"],

Cell[TextData[{
 StyleBox["WL",
  FontWeight->"Bold"],
 " : compute the four coefficients directly from the definition."
}], "Text",ExpressionUUID->"95533527-fc24-4ea5-a1fa-47f3a69c9ccd"],

Cell[BoxData[
 RowBox[{"With", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"aa", " ", "=", " ", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"a1", ",", " ", 
         RowBox[{"a2", " ", "+", " ", 
          RowBox[{"I", " ", "a3"}]}]}], "}"}], ",", " ", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"a2", " ", "-", " ", 
          RowBox[{"I", " ", "a3"}]}], ",", " ", "a4"}], "}"}]}], "}"}]}], 
    "}"}], ",", "\n", " ", 
   RowBox[{"AssociationThread", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"\"\<I\>\"", ",", " ", "\"\<X\>\"", ",", " ", "\"\<Y\>\"", ",", 
       " ", "\"\<Z\>\""}], "}"}], ",", " ", 
     RowBox[{"FullSimplify", " ", "@", " ", 
      RowBox[{"Table", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"Tr", "[", 
          RowBox[{
           RowBox[{"ConjugateTranspose", "[", 
            RowBox[{"PauliMatrix", "[", "j", "]"}], "]"}], " ", ".", " ", 
           "aa"}], "]"}], "/", "2"}], ",", " ", 
        RowBox[{"{", 
         RowBox[{"j", ",", " ", "0", ",", " ", "3"}], "}"}]}], "]"}]}]}], 
    "]"}]}], "]"}]], "Input",
 CellLabel->
  "In[79]:= ",ExpressionUUID->"2e936b8a-39c9-4821-8373-e24087a98f42"],

Cell[TextData[{
 StyleBox["QF",
  FontWeight->"Bold"],
 " : the operator decomposes itself."
}], "Text",ExpressionUUID->"43bca300-467f-43bd-9a43-d923c1b6f642"],

Cell[BoxData[
 RowBox[{"FullSimplify", " ", "/@", " ", 
  RowBox[{
   RowBox[{"QuantumOperator", "[", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"a1", ",", " ", 
        RowBox[{"a2", " ", "+", " ", 
         RowBox[{"I", " ", "a3"}]}]}], "}"}], ",", " ", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"a2", " ", "-", " ", 
         RowBox[{"I", " ", "a3"}]}], ",", " ", "a4"}], "}"}]}], "}"}], "]"}], 
   "[", "\"\<PauliDecompose\>\"", "]"}]}]], "Input",
 CellLabel->
  "In[80]:= ",ExpressionUUID->"388e6a41-2198-46ce-8baa-6aa9c1bf3672"],

Cell[TextData[{
 "Both return the coefficients ",
 Cell[BoxData[
  StyleBox[
   RowBox[{
    RowBox[{
     RowBox[{"{", "\|01d43c"}], ":", 
     FractionBox[
      RowBox[{
       SubscriptBox["\|01d44e", "1"], "+", 
       SubscriptBox["\|01d44e", "4"]}], "2"]}], ",", " ", 
    RowBox[{"\|01d44b", ":", 
     SubscriptBox["\|01d44e", "2"]}], ",", " ", 
    RowBox[{"\|01d44c", ":", 
     RowBox[{"-", 
      SubscriptBox["\|01d44e", "3"]}]}], ",", " ", 
    RowBox[{"\|01d44d", ":", 
     RowBox[{
      FractionBox[
       RowBox[{
        SubscriptBox["\|01d44e", "1"], "-", 
        SubscriptBox["\|01d44e", "4"]}], "2"], "}"}]}]}],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "c75e246a-e271-4e93-b9a4-ce176cfebae2"],
 ": the generic Hermitian operator is exactly ",
 Cell[BoxData[
  StyleBox[
   RowBox[{
    FractionBox[
     RowBox[{
      SubscriptBox["\|01d44e", "1"], "+", 
      SubscriptBox["\|01d44e", "4"]}], "2"], "\|01d43c", "+", 
    SubscriptBox["\|01d44e", "2"], 
    SubscriptBox["\|01d70e", "\|01d465"], "-", 
    SubscriptBox["\|01d44e", "3"], 
    SubscriptBox["\|01d70e", "\|01d466"], "+", 
    FractionBox[
     RowBox[{
      SubscriptBox["\|01d44e", "1"], "-", 
      SubscriptBox["\|01d44e", "4"]}], "2"], 
    SubscriptBox["\|01d70e", "\|01d467"]}],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "cfc4ccf2-a630-42d7-a08a-49a9e53feea0"],
 "."
}], "Text",ExpressionUUID->"d03ec813-7a35-4f7f-acb1-2d82f9c8bcc2"],

Cell["\<\
2.11 [BSc] How do I get a Rayleigh-Ritz variational upper bound on the \
ground-state energy from a trial state?\
\>", "Subsection",ExpressionUUID->"3b94815c-a16e-4aae-a2d8-9daeb629d114"],

Cell[TextData[{
 "For any normalized trial state, ",
 Cell[BoxData[
  StyleBox[
   RowBox[{
    RowBox[{
     TemplateBox[{
       StyleBox["\|01d713"]},
      "Bra"], "\|01d43b", 
     TemplateBox[{
       StyleBox["\|01d713"]},
      "Ket"]}], "\[GreaterEqual]", 
    SubscriptBox["\|01d438", "0"]}],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "38ed7620-19e1-414e-b1ad-7022252cba13"],
 ", with equality only at the ground state; minimizing the trial energy is \
the variational method."
}], "Text",ExpressionUUID->"230978af-5768-47f9-a9df-f7d5b8a94224"],

Cell[TextData[{
 StyleBox["WL",
  FontWeight->"Bold"],
 " : the trial energy over a one-parameter family."
}], "Text",ExpressionUUID->"ea229cb6-95cd-4da6-9b33-0ece77dd72ae"],

Cell[BoxData[
 RowBox[{"exp", " ", "=", " ", 
  RowBox[{"With", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{"h", " ", "=", " ", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"1", ",", " ", "1"}], "}"}], ",", " ", 
         RowBox[{"{", 
          RowBox[{"1", ",", " ", 
           RowBox[{"-", "1"}]}], "}"}]}], "}"}]}], ",", " ", 
      RowBox[{"psi", " ", "=", " ", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"Cos", "[", "t", "]"}], ",", " ", 
         RowBox[{"Sin", "[", "t", "]"}]}], "}"}]}]}], "}"}], ",", "\n", "  ", 
    
    RowBox[{"FullSimplify", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"Conjugate", "[", "psi", "]"}], " ", ".", " ", "h", " ", ".", 
       " ", "psi"}], ",", " ", 
      RowBox[{"t", " ", "\[Element]", " ", "Reals"}]}], "]"}]}], 
   "]"}]}]], "Input",
 CellLabel->
  "In[81]:= ",ExpressionUUID->"cdb8543b-82b3-4cd9-8ec5-52ec4a7f2372"],

Cell["The true ground energy is the lowest eigenvalue.", "Text",ExpressionUUID->"5beeb380-de9d-4b30-b7fc-adaec6cfa5ed"],

Cell[BoxData[
 RowBox[{"e0", " ", "=", " ", 
  RowBox[{"Min", "[", 
   RowBox[{"Eigenvalues", "[", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"1", ",", " ", "1"}], "}"}], ",", " ", 
      RowBox[{"{", 
       RowBox[{"1", ",", " ", 
        RowBox[{"-", "1"}]}], "}"}]}], "}"}], "]"}], "]"}]}]], "Input",
 CellLabel->
  "In[82]:= ",ExpressionUUID->"3627da4c-4ddd-4281-b1f2-0bf75f6e190a"],

Cell["Minimizing the trial energy reaches that bound.", "Text",ExpressionUUID->"7d8013ef-cd4b-4296-b702-677e31351d08"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"Minimize", "[", 
    RowBox[{"exp", ",", " ", "t"}], "]"}], "[", 
   RowBox[{"[", "1", "]"}], "]"}], " ", "==", " ", "e0"}]], "Input",
 CellLabel->
  "In[83]:= ",ExpressionUUID->"ce67361e-74b1-46fe-b85d-ec8f34c8c0dd"],

Cell[TextData[{
 StyleBox["QF",
  FontWeight->"Bold"],
 " : the Hamiltonian as a ",
 Cell[BoxData["QuantumOperator"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "4314762f-485b-4abd-9563-7777dbb16f0e"],
 ", the trial energy as a bra-operator-ket scalar."
}], "Text",ExpressionUUID->"251f463d-58e2-4702-b8ee-2fd80c93544e"],

Cell[BoxData[
 RowBox[{"expQF", " ", "=", " ", 
  RowBox[{"With", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{"h", " ", "=", " ", 
       RowBox[{"QuantumOperator", "[", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{"1", ",", " ", "1"}], "}"}], ",", " ", 
          RowBox[{"{", 
           RowBox[{"1", ",", " ", 
            RowBox[{"-", "1"}]}], "}"}]}], "}"}], "]"}]}], ",", " ", 
      RowBox[{"ps", " ", "=", " ", 
       RowBox[{"QuantumState", "[", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"Cos", "[", "t", "]"}], ",", " ", 
          RowBox[{"Sin", "[", "t", "]"}]}], "}"}], "]"}]}]}], "}"}], ",", 
    "\n", "  ", 
    RowBox[{"FullSimplify", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"(", 
        RowBox[{
         RowBox[{"ps", "[", "\"\<Dagger\>\"", "]"}], " ", "@", " ", 
         RowBox[{"h", " ", "@", " ", "ps"}]}], ")"}], "[", "\"\<Scalar\>\"", 
       "]"}], ",", " ", 
      RowBox[{"t", " ", "\[Element]", " ", "Reals"}]}], "]"}]}], 
   "]"}]}]], "Input",
 CellLabel->
  "In[84]:= ",ExpressionUUID->"182f074a-6268-4cbe-9b23-03549a86e03b"],

Cell["The ground energy from the operator's eigenvalues.", "Text",ExpressionUUID->"ab0aa122-dac8-484c-8a21-8666231d5efb"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"QuantumOperator", "[", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"1", ",", " ", "1"}], "}"}], ",", " ", 
      RowBox[{"{", 
       RowBox[{"1", ",", " ", 
        RowBox[{"-", "1"}]}], "}"}]}], "}"}], "]"}], 
   "[", "\"\<Eigenvalues\>\"", "]"}], " ", "//", " ", "Min"}]], "Input",
 CellLabel->
  "In[85]:= ",ExpressionUUID->"3923b2e2-f28a-423c-923a-13a7c565f76a"],

Cell["And the variational minimum reaches it.", "Text",ExpressionUUID->"58bd7ebc-95b8-4fac-b05a-c89d819e6ee7"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"Minimize", "[", 
    RowBox[{"expQF", ",", " ", "t"}], "]"}], "[", 
   RowBox[{"[", "1", "]"}], "]"}], " ", "==", " ", 
  RowBox[{"Min", "[", 
   RowBox[{
    RowBox[{"QuantumOperator", "[", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"1", ",", " ", "1"}], "}"}], ",", " ", 
       RowBox[{"{", 
        RowBox[{"1", ",", " ", 
         RowBox[{"-", "1"}]}], "}"}]}], "}"}], "]"}], 
    "[", "\"\<Eigenvalues\>\"", "]"}], "]"}]}]], "Input",
 CellLabel->
  "In[86]:= ",ExpressionUUID->"84a3af2e-b7e0-400a-a6b4-c77c6e672d19"],

Cell[TextData[{
 "Both give the trial energy ",
 Cell[BoxData[
  StyleBox[
   RowBox[{
    StyleBox["cos",
     FontSlant->"Plain"], "\[ThinSpace]", "2", "\|01d461", "+", 
    StyleBox["sin",
     FontSlant->"Plain"], "\[ThinSpace]", "2", "\|01d461"}],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "4adec641-e74b-4ff5-9044-78bffddfd7a2"],
 ", the true ground energy ",
 Cell[BoxData[
  StyleBox[
   RowBox[{"-", 
    SqrtBox["2"]}],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "3fe3d15f-e602-4c0e-a427-f9637f638089"],
 ", and ",
 Cell[BoxData["True"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "fa6a26d7-b7f6-4813-a34f-040a645d1af5"],
 ": the minimum over the trial family reaches ",
 Cell[BoxData[
  StyleBox[
   SubscriptBox["\|01d438", "0"],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "87f00a6b-f11d-478d-826b-cbbc4e40c6f7"],
 ", so the variational estimate is an upper bound that is tight here."
}], "Text",ExpressionUUID->"1de06e51-8d66-4b3e-bfde-306f76f279fb"],

Cell["\<\
2.12 [MSc] How do I compute first- and second-order energy shifts by \
non-degenerate time-independent perturbation theory?\
\>", "Subsection",ExpressionUUID->"bcf05d33-0af9-4c05-9029-8b4af57d379f"],

Cell[TextData[{
 "The Rayleigh-Schrodinger shifts are ",
 Cell[BoxData[
  StyleBox[
   RowBox[{
    SubsuperscriptBox["\|01d438", "\|01d45b", 
     RowBox[{
      StyleBox["(",
       SpanMaxSize->1], "1", 
      StyleBox[")",
       SpanMaxSize->1]}]], "=", 
    RowBox[{
     TemplateBox[{
       StyleBox["\|01d45b"]},
      "Bra"], "\|01d449", 
     TemplateBox[{
       StyleBox["\|01d45b"]},
      "Ket"]}]}],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "dafd6ccc-6407-4342-aacb-d61b46f0370c"],
 " and ",
 Cell[BoxData[
  StyleBox[
   RowBox[{
    SubsuperscriptBox["\|01d438", "\|01d45b", 
     RowBox[{
      StyleBox["(",
       SpanMaxSize->1], "2", 
      StyleBox[")",
       SpanMaxSize->1]}]], "=", 
    RowBox[{
     UnderscriptBox["\[Sum]", 
      RowBox[{"\|01d45a", "\[NotEqual]", "\|01d45b"}],
      LimitsPositioning->False], 
     FractionBox[
      SuperscriptBox[
       RowBox[{
        StyleBox["\[LeftBracketingBar]",
         SpanMinSize->1.9], 
        RowBox[{
         TemplateBox[{
           StyleBox["\|01d45a"]},
          "Bra"], "\|01d449", 
         TemplateBox[{
           StyleBox["\|01d45b"]},
          "Ket"]}], 
        StyleBox["\[RightBracketingBar]",
         SpanMinSize->1.9]}], "2"], 
      RowBox[{
       SubscriptBox["\|01d438", "\|01d45b"], "-", 
       SubscriptBox["\|01d438", "\|01d45a"]}]]}]}],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "23def86c-0c7b-4811-8536-33e1a90e172b"],
 "."
}], "Text",ExpressionUUID->"e82d3288-805f-4c37-bf84-b52769f22470"],

Cell[TextData[{
 StyleBox["WL",
  FontWeight->"Bold"],
 " : the first-order shifts are the diagonal matrix elements."
}], "Text",ExpressionUUID->"419bb8c1-83cd-43e3-b7ba-26c46a584fb3"],

Cell[BoxData[
 RowBox[{"With", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{"V", " ", "=", " ", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"w", ",", " ", "v"}], "}"}], ",", " ", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"Conjugate", "[", "v", "]"}], ",", " ", 
          RowBox[{"-", "w"}]}], "}"}]}], "}"}]}], ",", " ", 
     RowBox[{"basis", " ", "=", " ", 
      RowBox[{"IdentityMatrix", "[", "2", "]"}]}]}], "}"}], ",", "\n", " ", 
   RowBox[{"Table", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"Conjugate", "[", 
       RowBox[{"basis", "[", 
        RowBox[{"[", "n", "]"}], "]"}], "]"}], " ", ".", " ", "V", " ", ".", 
      " ", 
      RowBox[{"basis", "[", 
       RowBox[{"[", "n", "]"}], "]"}]}], ",", " ", 
     RowBox[{"{", 
      RowBox[{"n", ",", " ", "2"}], "}"}]}], "]"}]}], "]"}]], "Input",
 CellLabel->
  "In[87]:= ",ExpressionUUID->"c79c513b-0ad4-4d68-b530-bd1ae886bf18"],

Cell["\<\
The second-order shifts sum the off-diagonal couplings over the spectrum.\
\>", "Text",ExpressionUUID->"0696da75-956b-4a24-a3d0-62ebc89768db"],

Cell[BoxData[
 RowBox[{"With", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{"en", " ", "=", " ", 
      RowBox[{"{", 
       RowBox[{"e1", ",", " ", "e2"}], "}"}]}], ",", " ", 
     RowBox[{"V", " ", "=", " ", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"w", ",", " ", "v"}], "}"}], ",", " ", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"Conjugate", "[", "v", "]"}], ",", " ", 
          RowBox[{"-", "w"}]}], "}"}]}], "}"}]}], ",", " ", 
     RowBox[{"basis", " ", "=", " ", 
      RowBox[{"IdentityMatrix", "[", "2", "]"}]}]}], "}"}], ",", "\n", " ", 
   RowBox[{"Table", "[", 
    RowBox[{
     RowBox[{"Sum", "[", 
      RowBox[{
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{"m", " ", "==", " ", "n"}], ",", " ", "0", ",", " ", 
         RowBox[{
          RowBox[{
           RowBox[{"Abs", "[", 
            RowBox[{
             RowBox[{"Conjugate", "[", 
              RowBox[{"basis", "[", 
               RowBox[{"[", "m", "]"}], "]"}], "]"}], " ", ".", " ", "V", " ",
              ".", " ", 
             RowBox[{"basis", "[", 
              RowBox[{"[", "n", "]"}], "]"}]}], "]"}], "^", "2"}], "/", 
          RowBox[{"(", 
           RowBox[{
            RowBox[{"en", "[", 
             RowBox[{"[", "n", "]"}], "]"}], " ", "-", " ", 
            RowBox[{"en", "[", 
             RowBox[{"[", "m", "]"}], "]"}]}], ")"}]}]}], "]"}], ",", " ", 
       RowBox[{"{", 
        RowBox[{"m", ",", " ", "2"}], "}"}]}], "]"}], ",", " ", 
     RowBox[{"{", 
      RowBox[{"n", ",", " ", "2"}], "}"}]}], "]"}]}], "]"}]], "Input",
 CellLabel->
  "In[88]:= ",ExpressionUUID->"e4c534a2-b0a5-4902-b7a1-5157c3067f94"],

Cell[TextData[{
 StyleBox["QF",
  FontWeight->"Bold"],
 " : the first-order shifts as bra-operator-ket scalars on the basis states."
}], "Text",ExpressionUUID->"844f2d2a-1208-457c-9051-ece0f737363b"],

Cell[BoxData[
 RowBox[{"With", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{"V", " ", "=", " ", 
      RowBox[{"QuantumOperator", "[", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"w", ",", " ", "v"}], "}"}], ",", " ", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{"Conjugate", "[", "v", "]"}], ",", " ", 
           RowBox[{"-", "w"}]}], "}"}]}], "}"}], "]"}]}], ",", " ", 
     RowBox[{"basis", " ", "=", " ", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"QuantumState", "[", "\"\<0\>\"", "]"}], ",", " ", 
        RowBox[{"QuantumState", "[", "\"\<1\>\"", "]"}]}], "}"}]}]}], "}"}], ",",
    "\n", " ", 
   RowBox[{"Table", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"(", 
       RowBox[{
        RowBox[{
         RowBox[{"basis", "[", 
          RowBox[{"[", "n", "]"}], "]"}], "[", "\"\<Dagger\>\"", "]"}], " ", "@",
         " ", 
        RowBox[{"V", " ", "@", " ", 
         RowBox[{"basis", "[", 
          RowBox[{"[", "n", "]"}], "]"}]}]}], ")"}], "[", "\"\<Scalar\>\"", 
      "]"}], ",", " ", 
     RowBox[{"{", 
      RowBox[{"n", ",", " ", "2"}], "}"}]}], "]"}]}], "]"}]], "Input",
 CellLabel->
  "In[89]:= ",ExpressionUUID->"4f863c3b-34bd-4782-a7ac-65d3c2ed32a0"],

Cell["The second-order shifts, same matrix elements summed.", "Text",ExpressionUUID->"c9c4c77d-44c6-474e-8720-e6272ba229d4"],

Cell[BoxData[
 RowBox[{"With", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{"en", " ", "=", " ", 
      RowBox[{"{", 
       RowBox[{"e1", ",", " ", "e2"}], "}"}]}], ",", " ", 
     RowBox[{"V", " ", "=", " ", 
      RowBox[{"QuantumOperator", "[", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"w", ",", " ", "v"}], "}"}], ",", " ", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{"Conjugate", "[", "v", "]"}], ",", " ", 
           RowBox[{"-", "w"}]}], "}"}]}], "}"}], "]"}]}], ",", " ", 
     RowBox[{"basis", " ", "=", " ", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"QuantumState", "[", "\"\<0\>\"", "]"}], ",", " ", 
        RowBox[{"QuantumState", "[", "\"\<1\>\"", "]"}]}], "}"}]}]}], "}"}], ",",
    "\n", " ", 
   RowBox[{"Table", "[", 
    RowBox[{
     RowBox[{"Sum", "[", 
      RowBox[{
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{"m", " ", "==", " ", "n"}], ",", " ", "0", ",", " ", 
         RowBox[{
          RowBox[{
           RowBox[{"Abs", "[", 
            RowBox[{
             RowBox[{"(", 
              RowBox[{
               RowBox[{
                RowBox[{"basis", "[", 
                 RowBox[{"[", "m", "]"}], "]"}], "[", "\"\<Dagger\>\"", "]"}],
                " ", "@", " ", 
               RowBox[{"V", " ", "@", " ", 
                RowBox[{"basis", "[", 
                 RowBox[{"[", "n", "]"}], "]"}]}]}], ")"}], 
             "[", "\"\<Scalar\>\"", "]"}], "]"}], "^", "2"}], "/", 
          RowBox[{"(", 
           RowBox[{
            RowBox[{"en", "[", 
             RowBox[{"[", "n", "]"}], "]"}], " ", "-", " ", 
            RowBox[{"en", "[", 
             RowBox[{"[", "m", "]"}], "]"}]}], ")"}]}]}], "]"}], ",", " ", 
       RowBox[{"{", 
        RowBox[{"m", ",", " ", "2"}], "}"}]}], "]"}], ",", " ", 
     RowBox[{"{", 
      RowBox[{"n", ",", " ", "2"}], "}"}]}], "]"}]}], "]"}]], "Input",
 CellLabel->
  "In[90]:= ",ExpressionUUID->"77b3926e-8edf-4bae-8ec8-177fbb847824"],

Cell[TextData[{
 "Both give first-order shifts ",
 Cell[BoxData[
  StyleBox[
   RowBox[{
    RowBox[{"{", "\|01d464"}], ",", 
    RowBox[{"-", "\|01d464", "}"}]}],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "f3cb5ff7-3199-4fc1-a905-59be92ead1f1"],
 " (the diagonal of ",
 Cell[BoxData[
  StyleBox["\|01d449",
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "58f0d78e-5f90-404c-897f-72fd87919f22"],
 ") and second-order shifts ",
 Cell[BoxData[
  StyleBox[
   RowBox[{"{", 
    RowBox[{
     FractionBox[
      SuperscriptBox[
       RowBox[{
       "\[LeftBracketingBar]", "\|01d463", "\[VeryThinSpace]", 
        "\[RightBracketingBar]"}], "2"], 
      RowBox[{
       SubscriptBox["\|01d452", "1"], "-", 
       SubscriptBox["\|01d452", "2"]}]], ",", " ", 
     FractionBox[
      SuperscriptBox[
       RowBox[{
       "\[LeftBracketingBar]", "\|01d463", "\[VeryThinSpace]", 
        "\[RightBracketingBar]"}], "2"], 
      RowBox[{
       SubscriptBox["\|01d452", "2"], "-", 
       SubscriptBox["\|01d452", "1"]}]]}], "}"}],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "19658577-9dc1-45d5-a94f-9e3d35fa6773"],
 ": the off-diagonal coupling pushes the levels apart, the lower one down and \
the upper one up."
}], "Text",ExpressionUUID->"f17fa86f-171e-479f-8092-efa6e778e2f1"],

Cell["\<\
2.13 [MSc] How do I resolve an avoided crossing by degenerate perturbation \
theory (level repulsion)?\
\>", "Subsection",ExpressionUUID->"15c4b303-4928-4676-a492-158a843c2174"],

Cell[TextData[{
 "Where two diagonal levels would cross, an off-diagonal coupling ",
 Cell[BoxData[
  StyleBox["\[CapitalDelta]",
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "6d0552ed-ce86-4a4b-84ff-ad60ae96e266"],
 " opens a gap: the eigenvalues of ",
 Cell[BoxData[
  StyleBox[
   RowBox[{"(", GridBox[{
      {"\|01d706", "\[CapitalDelta]"},
      {"\[CapitalDelta]", 
       RowBox[{"-", "\|01d706"}]}
     }], ")"}],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "0ea831c7-7f9c-4c75-b974-f3bcffe53a92"],
 " are ",
 Cell[BoxData[
  StyleBox[
   RowBox[{"\[PlusMinus]", 
    SqrtBox[
     RowBox[{
      SuperscriptBox["\[CapitalDelta]", "2"], "+", 
      SuperscriptBox["\|01d706", "2"]}]]}],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "d0b3a36c-df60-4007-9c03-e8dd24e0c1a5"],
 "."
}], "Text",ExpressionUUID->"9945c3cc-4428-4677-b43c-870be2d81660"],

Cell[TextData[{
 StyleBox["WL",
  FontWeight->"Bold"],
 " : the two eigenvalues of the two-level Hamiltonian."
}], "Text",ExpressionUUID->"68a0cafc-3f0e-4425-9343-5d128f11ca6c"],

Cell[BoxData[
 RowBox[{"With", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"h", " ", "=", " ", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"\[Lambda]", ",", " ", "\[CapitalDelta]"}], "}"}], ",", " ", 
       RowBox[{"{", 
        RowBox[{"\[CapitalDelta]", ",", " ", 
         RowBox[{"-", "\[Lambda]"}]}], "}"}]}], "}"}]}], "}"}], ",", "\n", 
   " ", 
   RowBox[{"FullSimplify", "[", 
    RowBox[{
     RowBox[{"Eigenvalues", "[", "h", "]"}], ",", " ", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{"\[Lambda]", " ", "|", " ", "\[CapitalDelta]"}], ")"}], " ", "\[Element]",
       " ", "Reals"}]}], "]"}]}], "]"}]], "Input",
 CellLabel->
  "In[91]:= ",ExpressionUUID->"de7b3a5f-59bf-49f5-bcb1-7f0dc64603a4"],

Cell["Their difference is the gap.", "Text",ExpressionUUID->"a86cab4d-7f59-4b6d-a007-01e5f210a7b9"],

Cell[BoxData[
 RowBox[{"With", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"h", " ", "=", " ", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"\[Lambda]", ",", " ", "\[CapitalDelta]"}], "}"}], ",", " ", 
       RowBox[{"{", 
        RowBox[{"\[CapitalDelta]", ",", " ", 
         RowBox[{"-", "\[Lambda]"}]}], "}"}]}], "}"}]}], "}"}], ",", "\n", 
   " ", 
   RowBox[{"FullSimplify", "[", 
    RowBox[{
     RowBox[{"Abs", "[", 
      RowBox[{"Subtract", " ", "@@", " ", 
       RowBox[{"Eigenvalues", "[", "h", "]"}]}], "]"}], ",", " ", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{"\[Lambda]", " ", "|", " ", "\[CapitalDelta]"}], ")"}], " ", "\[Element]",
       " ", "Reals"}]}], "]"}]}], "]"}]], "Input",
 CellLabel->
  "In[92]:= ",ExpressionUUID->"30e77e19-aeae-48d8-b9d1-c1504f5ba22f"],

Cell[TextData[{
 StyleBox["QF",
  FontWeight->"Bold"],
 " : the eigenvalues through the operator."
}], "Text",ExpressionUUID->"fcf7b2e0-6a73-4ed8-b07c-c42f1399faad"],

Cell[BoxData[
 RowBox[{"With", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"h", " ", "=", " ", 
     RowBox[{"QuantumOperator", "[", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"\[Lambda]", ",", " ", "\[CapitalDelta]"}], "}"}], ",", " ", 
        
        RowBox[{"{", 
         RowBox[{"\[CapitalDelta]", ",", " ", 
          RowBox[{"-", "\[Lambda]"}]}], "}"}]}], "}"}], "]"}]}], "}"}], ",", 
   "\n", " ", 
   RowBox[{"FullSimplify", "[", 
    RowBox[{
     RowBox[{"h", "[", "\"\<Eigenvalues\>\"", "]"}], ",", " ", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{"\[Lambda]", " ", "|", " ", "\[CapitalDelta]"}], ")"}], " ", "\[Element]",
       " ", "Reals"}]}], "]"}]}], "]"}]], "Input",
 CellLabel->
  "In[93]:= ",ExpressionUUID->"415a16a6-5a00-4a64-8924-0d7808c1d586"],

Cell["And the gap.", "Text",ExpressionUUID->"fb25ee5a-a2c4-4b37-ab35-c18a87999d34"],

Cell[BoxData[
 RowBox[{"With", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"h", " ", "=", " ", 
     RowBox[{"QuantumOperator", "[", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"\[Lambda]", ",", " ", "\[CapitalDelta]"}], "}"}], ",", " ", 
        
        RowBox[{"{", 
         RowBox[{"\[CapitalDelta]", ",", " ", 
          RowBox[{"-", "\[Lambda]"}]}], "}"}]}], "}"}], "]"}]}], "}"}], ",", 
   "\n", " ", 
   RowBox[{"FullSimplify", "[", 
    RowBox[{
     RowBox[{"Abs", "[", 
      RowBox[{"Subtract", " ", "@@", " ", 
       RowBox[{"h", "[", "\"\<Eigenvalues\>\"", "]"}]}], "]"}], ",", " ", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{"\[Lambda]", " ", "|", " ", "\[CapitalDelta]"}], ")"}], " ", "\[Element]",
       " ", "Reals"}]}], "]"}]}], "]"}]], "Input",
 CellLabel->
  "In[94]:= ",ExpressionUUID->"88083476-3cb6-4811-94ce-dc9403f96e2f"],

Cell[TextData[{
 "Both give eigenvalues ",
 Cell[BoxData[
  StyleBox[
   RowBox[{"\[PlusMinus]", 
    SqrtBox[
     RowBox[{
      SuperscriptBox["\[CapitalDelta]", "2"], "+", 
      SuperscriptBox["\|01d706", "2"]}]]}],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "6c8b5cd2-a9fe-43be-8a83-949635b6df40"],
 " and a gap ",
 Cell[BoxData[
  StyleBox[
   RowBox[{"2", 
    SqrtBox[
     RowBox[{
      SuperscriptBox["\[CapitalDelta]", "2"], "+", 
      SuperscriptBox["\|01d706", "2"]}]]}],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "f0caad76-362d-4b88-bf01-4379644db013"],
 ". As ",
 Cell[BoxData[
  StyleBox["\|01d706",
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "37dcb4c1-121e-4553-8e17-640349bba91c"],
 " sweeps through the would-be crossing at ",
 Cell[BoxData[
  StyleBox[
   RowBox[{"\|01d706", "=", "0"}],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "6762853c-a84d-47f0-ae6c-ea83f7952fc0"],
 ", the gap shrinks only to ",
 Cell[BoxData[
  StyleBox[
   RowBox[{"2", "\[CapitalDelta]"}],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "1bbe4c78-8899-455e-bb11-48ea7064fdff"],
 ", never to zero: the coupling turns the crossing into an avoided crossing."
}], "Text",ExpressionUUID->"97121d28-0b83-44af-9ec1-5e0a2e944a0b"],

Cell["Part 3. States as density operators", "Section",ExpressionUUID->"f80dd3dc-6000-448d-88ef-68474e77ebbf"],

Cell[TextData[{
 "3.1 [BSc] How do I build a density matrix from a classical ensemble and \
compute its purity ",
 Cell[BoxData[
  StyleBox[
   RowBox[{
    StyleBox["Tr",
     FontSlant->"Plain"], 
    StyleBox["[",
     SpanMaxSize->1], 
    SuperscriptBox["\|01d70c", "2"], 
    StyleBox["]",
     SpanMaxSize->1]}],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "89ca1fa7-275b-4239-bc3d-8dd3b8062c50"],
 "?"
}], "Subsection",ExpressionUUID->"0b93708f-9a28-4315-8ea8-6374aefb18a8"],

Cell[TextData[{
 "A classical mixture of pure states is ",
 Cell[BoxData[
  StyleBox[
   RowBox[{"\|01d70c", "=", 
    RowBox[{
     UnderscriptBox["\[Sum]", "\|01d456",
      LimitsPositioning->False], 
     RowBox[{
      SubscriptBox["\|01d45d", "\|01d456"], 
      TemplateBox[{
        SubscriptBox[
         StyleBox["\|01d713"], 
         StyleBox["\|01d456"]]},
       "Ket"], 
      TemplateBox[{
        SubscriptBox[
         StyleBox["\|01d713"], 
         StyleBox["\|01d456"]]},
       "Bra"]}]}]}],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "7480e7d5-7392-4ffb-9de2-d29b21981696"],
 "; its purity ",
 Cell[BoxData[
  StyleBox[
   RowBox[{
    StyleBox["Tr",
     FontSlant->"Plain"], 
    StyleBox["[",
     SpanMaxSize->1], 
    SuperscriptBox["\|01d70c", "2"], 
    StyleBox["]",
     SpanMaxSize->1]}],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "30f661ad-7b7c-4743-9087-5673466e0711"],
 " runs from ",
 Cell[BoxData[
  StyleBox[
   RowBox[{"1", "/", "\|01d451"}],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "a3d7fab2-3516-4897-b8d4-1f6c1f88b7b1"],
 " (maximally mixed) to ",
 Cell[BoxData[
  StyleBox["1",
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "c208da82-7203-4f9c-9fcf-2d6801c6e562"],
 " (pure)."
}], "Text",ExpressionUUID->"a2369cd9-2f73-4f0e-a4ed-228bdb19e0ae"],

Cell[TextData[{
 StyleBox["WL",
  FontWeight->"Bold"],
 " : sum the weighted projectors, each ",
 Cell[BoxData[
  StyleBox[
   RowBox[{
    RowBox[{
     TemplateBox[{
       SubscriptBox[
        StyleBox["\|01d713"], 
        StyleBox["\|01d456"]]},
      "Ket"], 
     TemplateBox[{
       SubscriptBox[
        StyleBox["\|01d713"], 
        StyleBox["\|01d456"]]},
      "Bra"]}], "="}],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "739a4d7c-99cd-4da6-82f3-4642ff4d2812"],
 " ",
 Cell[BoxData[
  RowBox[{"KroneckerProduct", "[", 
   RowBox[{"psi", ",", " ", 
    RowBox[{"Conjugate", "[", "psi", "]"}]}], "]"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "75bc2394-a09d-43c2-8d6b-5ab5a3f014c1"],
 "."
}], "Text",ExpressionUUID->"b367b432-2d3f-4819-aa14-7bec80b5f012"],

Cell[BoxData[
 RowBox[{"rho", " ", "=", " ", 
  RowBox[{
   RowBox[{
    RowBox[{"3", "/", "4"}], " ", 
    RowBox[{"KroneckerProduct", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"1", ",", " ", "0"}], "}"}], ",", " ", 
      RowBox[{"Conjugate", "[", 
       RowBox[{"{", 
        RowBox[{"1", ",", " ", "0"}], "}"}], "]"}]}], "]"}]}], " ", "+", "\n",
    "   ", 
   RowBox[{
    RowBox[{"1", "/", "4"}], " ", 
    RowBox[{"KroneckerProduct", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"{", 
        RowBox[{"1", ",", " ", "1"}], "}"}], "/", 
       RowBox[{"Sqrt", "[", "2", "]"}]}], ",", " ", 
      RowBox[{"Conjugate", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"1", ",", " ", "1"}], "}"}], "/", 
        RowBox[{"Sqrt", "[", "2", "]"}]}], "]"}]}], "]"}]}]}]}]], "Input",
 CellLabel->
  "In[95]:= ",ExpressionUUID->"c9f6c7ef-7913-4fdf-87e9-953f681d4ca7"],

Cell[TextData[{
 "The purity is ",
 Cell[BoxData[
  StyleBox[
   RowBox[{
    StyleBox["Tr",
     FontSlant->"Plain"], 
    StyleBox["[",
     SpanMaxSize->1], 
    SuperscriptBox["\|01d70c", "2"], 
    StyleBox["]",
     SpanMaxSize->1]}],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "392405ee-27b6-4676-8d2a-0e3635b76854"],
 "."
}], "Text",ExpressionUUID->"77e45a19-3f69-4a6a-a723-51af6037ca90"],

Cell[BoxData[
 RowBox[{"Tr", "[", 
  RowBox[{"rho", " ", ".", " ", "rho"}], "]"}]], "Input",
 CellLabel->
  "In[96]:= ",ExpressionUUID->"b26bdc2d-f4db-4976-b8e5-d6c38c34333d"],

Cell[TextData[{
 StyleBox["QF",
  FontWeight->"Bold"],
 " : a classical mixture is the sum of the component density matrices (NOT a \
sum of the state vectors, which would build a coherent superposition); wrap \
that matrix as a state object."
}], "Text",ExpressionUUID->"2a836b33-8817-4039-b959-e8ef2346aa82"],

Cell[BoxData[
 RowBox[{"rhoQF", " ", "=", " ", 
  RowBox[{"QuantumState", "[", 
   RowBox[{
    RowBox[{
     RowBox[{"3", "/", "4"}], " ", 
     RowBox[{
      RowBox[{"QuantumState", "[", 
       RowBox[{"{", 
        RowBox[{"1", ",", " ", "0"}], "}"}], "]"}], 
      "[", "\"\<DensityMatrix\>\"", "]"}]}], " ", "+", "\n", "    ", 
    RowBox[{
     RowBox[{"1", "/", "4"}], " ", 
     RowBox[{
      RowBox[{"QuantumState", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"1", ",", " ", "1"}], "}"}], "/", 
        RowBox[{"Sqrt", "[", "2", "]"}]}], "]"}], "[", "\"\<DensityMatrix\>\"",
       "]"}]}]}], "]"}]}]], "Input",
 CellLabel->
  "In[97]:= ",ExpressionUUID->"bb2b1c27-0273-449d-a4c2-0998f53fa83c"],

Cell[TextData[{
 Cell[BoxData["\"\<Purity\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "327d2504-c83c-4968-8cb0-a6cd25b4c5ed"],
 " reads ",
 Cell[BoxData[
  StyleBox[
   RowBox[{
    StyleBox["Tr",
     FontSlant->"Plain"], 
    StyleBox["[",
     SpanMaxSize->1], 
    SuperscriptBox["\|01d70c", "2"], 
    StyleBox["]",
     SpanMaxSize->1]}],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "379ad516-a340-41d9-98bc-2477ce3cef9e"],
 " off the object."
}], "Text",ExpressionUUID->"6a7313d4-718a-4bc0-a451-dc950e761bf2"],

Cell[BoxData[
 RowBox[{"rhoQF", "[", "\"\<Purity\>\"", "]"}]], "Input",
 CellLabel->
  "In[98]:= ",ExpressionUUID->"a0b4f487-7aa9-43eb-b1f0-1acae169a0b3"],

Cell[TextData[{
 "Both give ",
 Cell[BoxData[
  StyleBox[
   RowBox[{
    StyleBox["Tr",
     FontSlant->"Plain"], 
    StyleBox["[",
     SpanMaxSize->1], 
    SuperscriptBox["\|01d70c", "2"], 
    StyleBox["]",
     SpanMaxSize->1], "=", "13", "/", "16", "<", "1"}],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "7c5b731e-aa0e-45bb-9ae1-ba735fff5975"],
 ": the state is mixed. Summing the ",
 StyleBox["state vectors", "TI"],
 " instead would have built a coherent superposition (a pure state, of unit \
purity), a physically different object from this classical mixture."
}], "Text",ExpressionUUID->"304914dd-efa7-491f-b6ba-1535d8c9b044"],

Cell["3.2 [BSc] How do I test whether a state is pure or mixed?", "Subsection",ExpressionUUID->"7ea09d39-a55f-496a-b954-27561b8896be"],

Cell[TextData[{
 "A state is pure iff any one of three equivalent conditions holds: ",
 Cell[BoxData[
  StyleBox[
   RowBox[{
    StyleBox["Tr",
     FontSlant->"Plain"], 
    StyleBox["[",
     SpanMaxSize->1], 
    SuperscriptBox["\|01d70c", "2"], 
    StyleBox["]",
     SpanMaxSize->1], "=", "1"}],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "4c41a534-5d68-4c4d-86fc-68aa2dacd055"],
 ", ",
 Cell[BoxData[
  StyleBox["\|01d70c",
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "d15d91e5-7ce9-4e05-b84b-7cecc93d9621"],
 " has rank one, or ",
 Cell[BoxData[
  StyleBox["\|01d70c",
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "b0cbf46b-58a4-4368-a0e4-bbe2f1e8827e"],
 " is idempotent (",
 Cell[BoxData[
  StyleBox[
   RowBox[{
    SuperscriptBox["\|01d70c", "2"], "=", "\|01d70c"}],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "b0e442c7-1ac7-44b2-a8b5-29e0f228e0a0"],
 ", a projector)."
}], "Text",ExpressionUUID->"6383c6bc-605f-4f9d-a79b-6be86fc346c0"],

Cell[TextData[{
 StyleBox["WL",
  FontWeight->"Bold"],
 " : purity equals one only for a pure state."
}], "Text",ExpressionUUID->"1334b933-4828-4cf3-a007-e920e0a4eebe"],

Cell[BoxData[
 RowBox[{
  RowBox[{"Tr", "[", 
   RowBox[{"rho", " ", ".", " ", "rho"}], "]"}], " ", "==", " ", 
  "1"}]], "Input",
 CellLabel->
  "In[99]:= ",ExpressionUUID->"53af8e79-e928-4723-b4f6-3994a1e81ef7"],

Cell["A pure state's density matrix has rank one.", "Text",ExpressionUUID->"0c433430-be01-4ef1-a00a-c9119ce091b0"],

Cell[BoxData[
 RowBox[{
  RowBox[{"MatrixRank", "[", "rho", "]"}], " ", "==", " ", "1"}]], "Input",
 CellLabel->
  "In[100]:= ",ExpressionUUID->"2aebf625-904d-468a-93d7-829839798b0c"],

Cell[TextData[{
 "A pure state is idempotent, a projector ",
 Cell[BoxData[
  StyleBox[
   RowBox[{
    SuperscriptBox["\|01d70c", "2"], "=", "\|01d70c"}],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "0ffe22de-0ede-4e6e-a23c-9e5bdb4422f0"],
 "."
}], "Text",ExpressionUUID->"e3effec0-d007-4cd0-80ae-be2debfdcb8b"],

Cell[BoxData[
 RowBox[{
  RowBox[{"rho", " ", ".", " ", "rho"}], " ", "==", " ", "rho"}]], "Input",
 CellLabel->
  "In[101]:= ",ExpressionUUID->"5e6af1d0-05e9-4f98-915b-3d3ff857e8c5"],

Cell[TextData[{
 StyleBox["QF",
  FontWeight->"Bold"],
 " : the object answers directly with ",
 Cell[BoxData["\"\<PureStateQ\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "f0416b47-fa12-4ebd-99a8-4bcf09056516"],
 "."
}], "Text",ExpressionUUID->"d27e323d-5a90-42dd-8655-280765528e4e"],

Cell[BoxData[
 RowBox[{"rhoQF", "[", "\"\<PureStateQ\>\"", "]"}]], "Input",
 CellLabel->
  "In[102]:= ",ExpressionUUID->"7e4ed859-9312-4a6c-a75f-4a2aa56b67ed"],

Cell[TextData[{
 "Contrast a genuine pure state, which returns ",
 Cell[BoxData["True"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "9004ea57-2367-4595-a39f-d51889458b69"],
 "."
}], "Text",ExpressionUUID->"5303eec1-1827-4ca5-b897-fda96bce4637"],

Cell[BoxData[
 RowBox[{
  RowBox[{"QuantumState", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"1", ",", " ", "I"}], "}"}], "/", 
    RowBox[{"Sqrt", "[", "2", "]"}]}], "]"}], "[", "\"\<PureStateQ\>\"", 
  "]"}]], "Input",
 CellLabel->
  "In[103]:= ",ExpressionUUID->"d2f91d80-2ea5-4e68-9e71-b1752f86f88e"],

Cell[TextData[{
 "The mixed state fails all three criteria (each cell returns ",
 Cell[BoxData["False"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "f5d5c083-50e0-4b39-a1bd-2cf59e9cf2b5"],
 ", the rank is ",
 Cell[BoxData[
  StyleBox["2",
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "eaa7fc6f-8b29-42d8-a68d-d60f08fe00cc"],
 "); the pure state passes. The three tests are equivalent characterizations \
of the same rank-one property."
}], "Text",ExpressionUUID->"d69dcfbf-45d6-449d-bc0b-d1a78e6a7ee0"],

Cell[TextData[{
 "3.3 [BSc] How do I build the maximally mixed state ",
 Cell[BoxData[
  StyleBox[
   RowBox[{"\|01d43c", "/", "\|01d451"}],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "3c668823-375f-4000-9627-88d7c25674dc"],
 " and read its purity?"
}], "Subsection",ExpressionUUID->"6331bb11-4ef0-4fee-b7be-610f4103418f"],

Cell[TextData[{
 "The maximally mixed state ",
 Cell[BoxData[
  StyleBox[
   RowBox[{"\|01d43c", "/", "\|01d451"}],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "dab9e274-6f43-414f-b6e5-3d8cbe7f678d"],
 " is the unique state of maximal entropy; its purity is the floor ",
 Cell[BoxData[
  StyleBox[
   RowBox[{"1", "/", "\|01d451"}],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "f83c7a18-a653-4bcf-8a59-c5e91934f876"],
 "."
}], "Text",ExpressionUUID->"60dacae1-9caa-4c08-8f2a-84804cab34e7"],

Cell[TextData[{
 StyleBox["WL",
  FontWeight->"Bold"],
 " : the normalized identity, and its purity."
}], "Text",ExpressionUUID->"64b70cad-caf3-48c9-92df-0c7adc615e03"],

Cell[BoxData[
 RowBox[{"With", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"d", " ", "=", " ", "3"}], "}"}], ",", " ", 
   RowBox[{"Tr", "[", 
    RowBox[{
     RowBox[{"(", 
      RowBox[{
       RowBox[{"IdentityMatrix", "[", "d", "]"}], "/", "d"}], ")"}], " ", ".",
      " ", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{"IdentityMatrix", "[", "d", "]"}], "/", "d"}], ")"}]}], 
    "]"}]}], "]"}]], "Input",
 CellLabel->
  "In[104]:= ",ExpressionUUID->"de0ea967-a820-49ab-b471-0b90f062dc71"],

Cell[TextData[{
 StyleBox["QF",
  FontWeight->"Bold"],
 " : the same state as an object, shown as its summary box."
}], "Text",ExpressionUUID->"8859bea9-64a3-4a78-8585-efe4678c25e8"],

Cell[BoxData[
 RowBox[{"QuantumState", "[", 
  RowBox[{
   RowBox[{"IdentityMatrix", "[", "3", "]"}], "/", "3"}], "]"}]], "Input",
 CellLabel->
  "In[105]:= ",ExpressionUUID->"00fcb0a0-b954-476e-9f89-5fe4d8ae42bd"],

Cell[TextData[{
 "Its ",
 Cell[BoxData["\"\<Purity\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "9ee0086d-65bd-4770-ac3a-eee0f78d938e"],
 " is the floor ",
 Cell[BoxData[
  StyleBox[
   RowBox[{"1", "/", "\|01d451"}],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "6ee28cf9-6f52-40ba-98d3-48eba9777862"],
 "."
}], "Text",ExpressionUUID->"aa226ace-fd77-4258-9e0e-e0c6058443ce"],

Cell[BoxData[
 RowBox[{
  RowBox[{"QuantumState", "[", 
   RowBox[{
    RowBox[{"IdentityMatrix", "[", "3", "]"}], "/", "3"}], "]"}], 
  "[", "\"\<Purity\>\"", "]"}]], "Input",
 CellLabel->
  "In[106]:= ",ExpressionUUID->"071aeb45-f0bd-45eb-9883-d341630b7645"],

Cell[TextData[{
 "Both give ",
 Cell[BoxData[
  StyleBox[
   RowBox[{"1", "/", "3", "=", "1", "/", "\|01d451"}],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "2f5b6e16-2ddd-4607-99f9-78e546413ba0"],
 ", the minimum purity in dimension ",
 Cell[BoxData[
  StyleBox[
   RowBox[{"\|01d451", "=", "3"}],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "e123ce0e-8277-4891-8956-37038f1bc860"],
 ": no state is less pure than ",
 Cell[BoxData[
  StyleBox[
   RowBox[{"\|01d43c", "/", "\|01d451"}],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "609ae5db-cd99-43e1-8cb3-17e26f942e30"],
 "."
}], "Text",ExpressionUUID->"0bcd0da4-d93e-4d64-b314-8a7e02245cbd"],

Cell[TextData[{
 "3.4 [BSc] How do I compute an expectation value and a variance of an \
observable on a general (mixed) state as ",
 Cell[BoxData[
  StyleBox[
   RowBox[{
    StyleBox["Tr",
     FontSlant->"Plain"], 
    StyleBox["[",
     SpanMaxSize->1], 
    RowBox[{
     OverscriptBox["\|01d434", "^"], "\|01d70c"}], 
    StyleBox["]",
     SpanMaxSize->1]}],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "74d4b647-f4c7-45a3-ab8d-16d9840338f0"],
 "?"
}], "Subsection",ExpressionUUID->"3db1ffcb-f26f-42e1-a097-a485bfbd5c5f"],

Cell[TextData[{
 "For any state, ",
 Cell[BoxData[
  StyleBox[
   RowBox[{
    StyleBox["\[LeftAngleBracket]",
     SpanMaxSize->1], "\|01d434", "\[VeryThinSpace]", 
    StyleBox["\[RightAngleBracket]",
     SpanMaxSize->1], "=", 
    StyleBox["Tr",
     FontSlant->"Plain"], 
    StyleBox["[",
     SpanMaxSize->1], 
    RowBox[{"\|01d434", "\|01d70c"}], 
    StyleBox["]",
     SpanMaxSize->1]}],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "aacc4a23-70b8-4dfd-8ca7-a681f633b8ba"],
 " and ",
 Cell[BoxData[
  StyleBox[
   RowBox[{
    StyleBox["Var",
     FontSlant->"Plain"], "=", 
    StyleBox["Tr",
     FontSlant->"Plain"], 
    StyleBox["[",
     SpanMaxSize->1], 
    RowBox[{
     SuperscriptBox["\|01d434", "2"], "\|01d70c"}], 
    StyleBox["]",
     SpanMaxSize->1], "-", 
    StyleBox["Tr",
     FontSlant->"Plain"], 
    SuperscriptBox[
     RowBox[{
      StyleBox["[",
       SpanMaxSize->1], 
      RowBox[{"\|01d434", "\|01d70c"}], 
      StyleBox["]",
       SpanMaxSize->1]}], "2"]}],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "537764b6-2c19-4cef-85b0-e1525f54963b"],
 ". Writing a general qubit state in Bloch form ",
 Cell[BoxData[
  StyleBox[
   RowBox[{"\|01d70c", "=", 
    FractionBox["1", "2"], 
    StyleBox["(",
     SpanMaxSize->1], 
    RowBox[{"\|01d43c", "+", 
     OverscriptBox["\|01d45f", "\[RightVector]"], "\[CenterDot]", 
     OverscriptBox["\|01d70e", "\[RightVector]"]}], 
    StyleBox[")",
     SpanMaxSize->1]}],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "bdc26fd4-15be-4b28-95de-ef217039e559"],
 " makes the result transparent."
}], "Text",ExpressionUUID->"8182ceb0-0f26-4c2e-9c71-331167d3172d"],

Cell[TextData[{
 StyleBox["WL",
  FontWeight->"Bold"],
 " : build the general Bloch state and bind it (",
 Cell[BoxData[
  StyleBox[
   RowBox[{
    OverscriptBox["\|01d70e", "\[RightVector]"], "="}],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "0b1d2861-2520-4656-a8e8-d5cbbee22b49"],
 " ",
 Cell[BoxData[
  RowBox[{"PauliMatrix", "[", 
   RowBox[{"{", 
    RowBox[{"1", ",", " ", "2", ",", " ", "3"}], "}"}], "]"}]], 
  "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "79b0bd64-39f2-496a-bec6-4a5bbe6e34d1"],
 ")."
}], "Text",ExpressionUUID->"15cc928d-21ec-4b32-864d-fa3f7cbbd9dd"],

Cell[BoxData[
 RowBox[{
  RowBox[{"rhoB", " ", "=", " ", 
   RowBox[{
    RowBox[{"1", "/", "2"}], " ", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"IdentityMatrix", "[", "2", "]"}], " ", "+", " ", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"rx", ",", " ", "ry", ",", " ", "rz"}], "}"}], " ", ".", " ", 
       
       RowBox[{"PauliMatrix", "[", 
        RowBox[{"{", 
         RowBox[{"1", ",", " ", "2", ",", " ", "3"}], "}"}], "]"}]}]}], 
     ")"}]}]}], ";"}]], "Input",
 CellLabel->
  "In[107]:= ",ExpressionUUID->"c4d4ed14-5749-4f17-9c15-174d96183c26"],

Cell[TextData[{
 "The mean of ",
 Cell[BoxData[
  StyleBox[
   SubscriptBox["\|01d70e", "\|01d467"],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "6e7bf3ac-38b3-46be-a37c-1436478c0b09"],
 " is ",
 Cell[BoxData[
  StyleBox[
   RowBox[{
    StyleBox["Tr",
     FontSlant->"Plain"], 
    StyleBox["[",
     SpanMaxSize->1], 
    RowBox[{
     SubscriptBox["\|01d70e", "\|01d467"], "\|01d70c"}], 
    StyleBox["]",
     SpanMaxSize->1]}],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "2dd4d0b8-25a5-47c3-b39e-569221badcf3"],
 "."
}], "Text",ExpressionUUID->"bb027c84-c6fd-424a-b716-e7e06b13ee1f"],

Cell[BoxData[
 RowBox[{"Tr", "[", 
  RowBox[{
   RowBox[{"PauliMatrix", "[", "3", "]"}], " ", ".", " ", "rhoB"}], 
  "]"}]], "Input",
 CellLabel->
  "In[108]:= ",ExpressionUUID->"6baf398b-c313-4111-93af-c22a980dd1a3"],

Cell[TextData[{
 "The variance reuses ",
 Cell[BoxData[
  StyleBox[
   RowBox[{
    SubsuperscriptBox["\|01d70e", "\|01d467", "2"], "=", "\|01d43c"}],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "af5a44a3-be6e-46f9-a294-5e9309eb8ab7"],
 "."
}], "Text",ExpressionUUID->"ab864f71-5937-4a13-a7c4-6d0c3a687a02"],

Cell[BoxData[
 RowBox[{
  RowBox[{"Tr", "[", 
   RowBox[{
    RowBox[{"PauliMatrix", "[", "3", "]"}], " ", ".", " ", 
    RowBox[{"PauliMatrix", "[", "3", "]"}], " ", ".", " ", "rhoB"}], "]"}], 
  " ", "-", " ", 
  RowBox[{
   RowBox[{"Tr", "[", 
    RowBox[{
     RowBox[{"PauliMatrix", "[", "3", "]"}], " ", ".", " ", "rhoB"}], "]"}], "^",
    "2"}]}]], "Input",
 CellLabel->
  "In[109]:= ",ExpressionUUID->"afdde52f-c7c7-49bb-b8e4-3cba8cfafa69"],

Cell[TextData[{
 StyleBox["QF",
  FontWeight->"Bold"],
 " : the same general state as an object, shown as its summary box."
}], "Text",ExpressionUUID->"90944f46-dd56-4731-a1ff-d01a695ea5e4"],

Cell[BoxData[
 RowBox[{"rhoBQF", " ", "=", " ", 
  RowBox[{"QuantumState", "[", 
   RowBox[{
    RowBox[{"1", "/", "2"}], " ", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"IdentityMatrix", "[", "2", "]"}], " ", "+", " ", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"rx", ",", " ", "ry", ",", " ", "rz"}], "}"}], " ", ".", " ", 
       
       RowBox[{"PauliMatrix", "[", 
        RowBox[{"{", 
         RowBox[{"1", ",", " ", "2", ",", " ", "3"}], "}"}], "]"}]}]}], 
     ")"}]}], "]"}]}]], "Input",
 CellLabel->
  "In[110]:= ",ExpressionUUID->"0e486ab2-c00b-49bd-8eee-727cfb55f768"],

Cell[TextData[{
 "The mean, as a measurement-operator expectation on the state. The ",
 Cell[BoxData["\"\<Mean\>\""], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "8dce0af9-9e23-4881-bd1d-62e8951ae82a"],
 " runs through Born probabilities ",
 Cell[BoxData[
  StyleBox[
   RowBox[{
    StyleBox["(",
     SpanMaxSize->1], 
    RowBox[{"1", "\[PlusMinus]", 
     SubscriptBox["\|01d45f", "\|01d467"]}], 
    StyleBox[")",
     SpanMaxSize->1], "/", "2"}],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "b504eb05-7ade-4921-95a9-98faf7dfbf4f"],
 ", so it is simplified under the physicality assumption ",
 Cell[BoxData[
  StyleBox[
   RowBox[{"\[LeftBracketingBar]", 
    SubscriptBox["\|01d45f", "\|01d467"], "\[RightBracketingBar]", "\[LessEqual]",
     "1"}],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "bf0070af-2a86-483a-be5f-77a01844c903"],
 "."
}], "Text",ExpressionUUID->"929936f0-05f3-4703-9eee-9d2a5c3f9596"],

Cell[BoxData[
 RowBox[{"Simplify", "[", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"QuantumMeasurementOperator", "[", 
      RowBox[{"QuantumOperator", "[", "\"\<Z\>\"", "]"}], "]"}], "[", 
     "rhoBQF", "]"}], "[", "\"\<Mean\>\"", "]"}], ",", " ", 
   RowBox[{
    RowBox[{"-", "1"}], " ", "<=", " ", "rz", " ", "<=", " ", "1"}]}], 
  "]"}]], "Input",
 CellLabel->
  "In[111]:= ",ExpressionUUID->"965082d2-74f9-41f8-ac0e-bd3d932567cc"],

Cell[TextData[{
 "The variance, from ",
 Cell[BoxData[
  StyleBox[
   RowBox[{
    StyleBox["\[LeftAngleBracket]",
     SpanMaxSize->1], 
    SubsuperscriptBox["\|01d70e", "\|01d467", "2"], 
    StyleBox["\[RightAngleBracket]",
     SpanMaxSize->1], "-", 
    SuperscriptBox[
     RowBox[{
      StyleBox["\[LeftAngleBracket]",
       SpanMaxSize->1], 
      SubscriptBox["\|01d70e", "\|01d467"], 
      StyleBox["\[RightAngleBracket]",
       SpanMaxSize->1]}], "2"]}],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "34b1c5b7-5344-494c-b837-8b03b50b833c"],
 ", under the same assumption."
}], "Text",ExpressionUUID->"243c35fe-b46e-4894-8cac-eb9c8cc8c735"],

Cell[BoxData[
 RowBox[{"Simplify", "[", "\n", " ", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{"QuantumMeasurementOperator", "[", 
       RowBox[{
        RowBox[{"QuantumOperator", "[", "\"\<Z\>\"", "]"}], " ", "@", " ", 
        RowBox[{"QuantumOperator", "[", "\"\<Z\>\"", "]"}]}], "]"}], "[", 
      "rhoBQF", "]"}], "[", "\"\<Mean\>\"", "]"}], " ", "-", "\n", "  ", 
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{"QuantumMeasurementOperator", "[", 
        RowBox[{"QuantumOperator", "[", "\"\<Z\>\"", "]"}], "]"}], "[", 
       "rhoBQF", "]"}], "[", "\"\<Mean\>\"", "]"}], "^", "2"}]}], ",", " ", 
   RowBox[{
    RowBox[{"-", "1"}], " ", "<=", " ", "rz", " ", "<=", " ", "1"}]}], 
  "]"}]], "Input",
 CellLabel->
  "In[112]:= ",ExpressionUUID->"093d9e04-1dc1-469b-b291-5e1edcf343df"],

Cell[TextData[{
 "Both give ",
 Cell[BoxData[
  StyleBox[
   RowBox[{
    StyleBox["\[LeftAngleBracket]",
     SpanMaxSize->1], 
    SubscriptBox["\|01d70e", "\|01d467"], 
    StyleBox["\[RightAngleBracket]",
     SpanMaxSize->1], "=", 
    SubscriptBox["\|01d45f", "\|01d467"]}],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "fbdbc7ab-da4e-41f5-91c9-c24b172e67a6"],
 " (the expectation of a Pauli is its Bloch component) and ",
 Cell[BoxData[
  StyleBox[
   RowBox[{
    StyleBox["Var",
     FontSlant->"Plain"], "=", "1", "-", 
    SubsuperscriptBox["\|01d45f", "\|01d467", "2"]}],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "85028657-d62b-4bad-a4a5-01150e87248c"],
 ": the spin is sharp (",
 Cell[BoxData[
  StyleBox[
   RowBox[{
    StyleBox["Var",
     FontSlant->"Plain"], "=", "0"}],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "2564d2ff-5607-42ae-9e0a-699311c2eb2d"],
 ") only at the poles ",
 Cell[BoxData[
  StyleBox[
   RowBox[{
    SubscriptBox["\|01d45f", "\|01d467"], "=", "\[PlusMinus]", "1"}],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "d149c77c-7232-49cc-9bf5-84db8564b3a2"],
 ". (The WL trace ",
 Cell[BoxData[
  StyleBox[
   RowBox[{
    StyleBox["Tr",
     FontSlant->"Plain"], 
    StyleBox["[",
     SpanMaxSize->1], 
    RowBox[{
     SubscriptBox["\|01d70e", "\|01d467"], "\|01d70c"}], 
    StyleBox["]",
     SpanMaxSize->1], "=", 
    SubscriptBox["\|01d45f", "\|01d467"]}],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "bbcd22ee-d87d-48bb-b8e4-6a39a284c5ec"],
 " holds for any ",
 Cell[BoxData[
  StyleBox["\|01d70c",
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "12b9b66d-b050-49e1-9faf-975d6c2541e9"],
 "; the QF measurement form needs ",
 Cell[BoxData[
  StyleBox["\|01d70c",
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "80926b9a-c45e-46e6-9ee5-93596298cb31"],
 " to be a physical state, which is the ",
 Cell[BoxData[
  StyleBox[
   RowBox[{"\[LeftBracketingBar]", 
    SubscriptBox["\|01d45f", "\|01d467"], "\[RightBracketingBar]", "\[LessEqual]",
     "1"}],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "acc14e20-ac5a-46f9-a52a-df8154491fd9"],
 " assumption.)"
}], "Text",ExpressionUUID->"548e6eab-86ba-4f8e-8fa1-2119efcec727"],

Cell[TextData[{
 "3.5 [BSc] How do I count the real parameters of a ",
 Cell[BoxData[
  StyleBox["\|01d451",
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "3c1c54f9-bc08-43f5-af6f-f67ad50b66c3"],
 "-dimensional mixed state (density matrix)?"
}], "Subsection",ExpressionUUID->"72bfb3bf-e18e-4a7f-acf3-aeb7fc83717a"],

Cell[TextData[{
 "A ",
 Cell[BoxData[
  StyleBox[
   RowBox[{"\|01d451", "\[Times]", "\|01d451"}],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "349acac5-92f1-49d4-a1cb-6059b1b797ea"],
 " density matrix is Hermitian (",
 Cell[BoxData[
  StyleBox[
   SuperscriptBox["\|01d451", "2"],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "f288e7dc-b502-409d-8644-30a694bab48a"],
 " real parameters) with unit trace (one constraint), leaving ",
 Cell[BoxData[
  StyleBox[
   RowBox[{
    SuperscriptBox["\|01d451", "2"], "-", "1"}],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "73ddc700-2844-4d92-ab35-058ad0d8ea2f"],
 ". As in 1.5, the rigorous count is a Jacobian rank."
}], "Text",ExpressionUUID->"29bf755b-ff29-46c1-beac-582ae0166063"],

Cell[TextData[{
 StyleBox["WL",
  FontWeight->"Bold"],
 " : the general Hermitian unit-trace qubit ",
 Cell[BoxData[
  StyleBox[
   RowBox[{
    RowBox[{"{", "{", "\|01d44e"}], ",", 
    RowBox[{"\|01d44f", "+", "\|01d456", "\|01d450", "}"}], ",", 
    RowBox[{"{", "\|01d44f", "-", "\|01d456", "\|01d450"}], ",", 
    RowBox[{"1", "-", "\|01d44e", "}", "}"}]}],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "10792b57-bd00-423b-9176-e985acf7e413"],
 " has three real parameters; its real-coordinate embedding has Jacobian rank \
",
 Cell[BoxData[
  StyleBox[
   RowBox[{"3", "=", 
    SuperscriptBox["2", "2"], "-", "1"}],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "5870293a-64a7-403f-b203-a3669091f3a0"],
 "."
}], "Text",ExpressionUUID->"4efbf696-3e16-4ee0-84fa-2f724ca24cdc"],

Cell[BoxData[
 RowBox[{"With", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"rho", " ", "=", " ", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"a", ",", " ", 
         RowBox[{"b", " ", "+", " ", 
          RowBox[{"I", " ", "c"}]}]}], "}"}], ",", " ", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"b", " ", "-", " ", 
          RowBox[{"I", " ", "c"}]}], ",", " ", 
         RowBox[{"1", " ", "-", " ", "a"}]}], "}"}]}], "}"}]}], "}"}], ",", 
   "\n", " ", 
   RowBox[{"MatrixRank", "[", 
    RowBox[{"D", "[", 
     RowBox[{
      RowBox[{"Flatten", "[", 
       RowBox[{"ReIm", "[", 
        RowBox[{"Flatten", "[", "rho", "]"}], "]"}], "]"}], ",", " ", 
      RowBox[{"{", 
       RowBox[{"{", 
        RowBox[{"a", ",", " ", "b", ",", " ", "c"}], "}"}], "}"}]}], "]"}], 
    "]"}]}], "]"}]], "Input",
 CellLabel->
  "In[113]:= ",ExpressionUUID->"5d333644-c91a-4d53-b064-ddfb571702f9"],

Cell[TextData[{
 "The general count for dimension ",
 Cell[BoxData[
  StyleBox["\|01d451",
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "3a40bf92-f969-46ce-9414-7bb4abe22900"],
 " is ",
 Cell[BoxData[
  StyleBox[
   RowBox[{
    SuperscriptBox["\|01d451", "2"], "-", "1"}],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "e2e0cbb4-093e-4dc9-a9fc-44ffb1ace98c"],
 "."
}], "Text",ExpressionUUID->"81e074e9-aafb-4378-82dd-6e9e18bd4dc9"],

Cell[BoxData[
 RowBox[{"Table", "[", 
  RowBox[{
   RowBox[{
    RowBox[{"d", "^", "2"}], " ", "-", " ", "1"}], ",", " ", 
   RowBox[{"{", 
    RowBox[{"d", ",", " ", "2", ",", " ", "4"}], "}"}]}], "]"}]], "Input",
 CellLabel->
  "In[114]:= ",ExpressionUUID->"19ca6ab9-73f9-4adf-a6e0-53877ddd2130"],

Cell[TextData[{
 StyleBox["QF",
  FontWeight->"Bold"],
 " : drive the general count from the object's own dimension."
}], "Text",ExpressionUUID->"df69edd0-0ee0-482c-9d3e-643c5cc5cdfa"],

Cell[BoxData[
 RowBox[{"Table", "[", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{"QuantumState", "[", 
       RowBox[{"\"\<0\>\"", ",", " ", "d"}], "]"}], "[", "\"\<Dimension\>\"", 
      "]"}], "^", "2"}], " ", "-", " ", "1"}], ",", " ", 
   RowBox[{"{", 
    RowBox[{"d", ",", " ", "2", ",", " ", "4"}], "}"}]}], "]"}]], "Input",
 CellLabel->
  "In[115]:= ",ExpressionUUID->"000f0e9e-ae86-44d7-9757-ef4b0782188c"],

Cell[TextData[{
 "The qubit rank is ",
 Cell[BoxData[
  StyleBox[
   RowBox[{"3", "=", 
    SuperscriptBox["2", "2"], "-", "1"}],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "8441b921-f3f2-424b-b242-14ffbfb8c350"],
 "; the general count is ",
 Cell[BoxData[
  StyleBox[
   RowBox[{
    RowBox[{"{", "3"}], ",", "8", ",", 
    RowBox[{"15", "}"}]}],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "83a3de99-5280-4bb5-95cc-aae7fec8e772"],
 " for ",
 Cell[BoxData[
  StyleBox[
   RowBox[{
    RowBox[{"\|01d451", "=", "2"}], ",", 
    RowBox[{"3", ",", "4"}]}],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "5e33efb5-d045-4092-b1ec-9229bfba2b79"],
 ". (The pure-state count ",
 Cell[BoxData[
  StyleBox[
   RowBox[{"2", "\|01d451", "-", "2"}],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "b185bcac-7ba2-4c58-bc41-92c96dc6d2c0"],
 " of 1.5 is smaller: a pure state is a measure-zero boundary of the full \
state space.)"
}], "Text",ExpressionUUID->"62975155-ad10-42d7-8e9e-2c8d90ebeecf"],

Cell["\<\
3.6 [BSc] How do I map a qubit density matrix to its Bloch vector and read \
positivity and the pure-state boundary?\
\>", "Subsection",ExpressionUUID->"b576487c-5e66-4675-8f8c-d5d9a8887a69"],

Cell[TextData[{
 "For a qubit, ",
 Cell[BoxData[
  StyleBox[
   RowBox[{"\|01d70c", "=", 
    FractionBox["1", "2"], 
    StyleBox["(",
     SpanMaxSize->1], 
    RowBox[{"\|01d43c", "+", 
     OverscriptBox["\|01d45f", "\[RightVector]"], "\[CenterDot]", 
     OverscriptBox["\|01d70e", "\[RightVector]"]}], 
    StyleBox[")",
     SpanMaxSize->1]}],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "730659b9-0825-4abf-9163-bbc55c1d2257"],
 " with ",
 Cell[BoxData[
  StyleBox[
   RowBox[{
    SubscriptBox["\|01d45f", "\|01d457"], "=", 
    StyleBox["Tr",
     FontSlant->"Plain"], 
    StyleBox["[",
     SpanMaxSize->1], 
    RowBox[{
     SubscriptBox["\|01d70e", "\|01d457"], "\|01d70c"}], 
    StyleBox["]",
     SpanMaxSize->1]}],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "43dcb36e-5e06-4808-bfd1-25ecd5ac9b7b"],
 "; positivity forces ",
 Cell[BoxData[
  StyleBox[
   RowBox[{"\[LeftBracketingBar]", 
    OverscriptBox["\|01d45f", "\[RightVector]"], "\[RightBracketingBar]", "\[LessEqual]",
     "1"}],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "bfd91e84-32dd-4167-871e-b115d4df19dc"],
 ", and ",
 Cell[BoxData[
  StyleBox[
   RowBox[{"\[LeftBracketingBar]", 
    OverscriptBox["\|01d45f", "\[RightVector]"], "\[RightBracketingBar]", "=",
     "1"}],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "285de89b-fa93-456f-a907-d0608099a7c7"],
 " exactly on the pure states."
}], "Text",ExpressionUUID->"bb53b00e-9eb4-414f-bf24-5e3f07fc58f5"],

Cell[TextData[{
 StyleBox["WL",
  FontWeight->"Bold"],
 " : recover the Bloch vector from the general ",
 Cell[BoxData[
  StyleBox["\|01d70c",
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "2043adea-3dc2-46b1-b503-0501d88491d6"],
 " of 3.4 as the Pauli expectations."
}], "Text",ExpressionUUID->"9f2d32ae-0783-4c2d-84d3-d8f36f16b2da"],

Cell[BoxData[
 RowBox[{"Table", "[", 
  RowBox[{
   RowBox[{"Tr", "[", 
    RowBox[{
     RowBox[{"PauliMatrix", "[", "j", "]"}], " ", ".", " ", "rhoB"}], "]"}], ",",
    " ", 
   RowBox[{"{", 
    RowBox[{"j", ",", " ", "3"}], "}"}]}], "]"}]], "Input",
 CellLabel->
  "In[116]:= ",ExpressionUUID->"26e666de-b471-4adb-bba1-e6f2780d517b"],

Cell[TextData[{
 "Purity and radius are tied by ",
 Cell[BoxData[
  StyleBox[
   RowBox[{
    StyleBox["Tr",
     FontSlant->"Plain"], 
    StyleBox["[",
     SpanMaxSize->1], 
    SuperscriptBox["\|01d70c", "2"], 
    StyleBox["]",
     SpanMaxSize->1], "=", 
    FractionBox["1", "2"], 
    StyleBox["(",
     SpanMaxSize->1], 
    RowBox[{"1", "+", 
     SuperscriptBox[
      RowBox[{"\[LeftBracketingBar]", 
       OverscriptBox["\|01d45f", "\[RightVector]"], "\[RightBracketingBar]"}],
       "2"]}], 
    StyleBox[")",
     SpanMaxSize->1]}],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "d534396d-40fc-42c3-ab7f-2cfd787f304d"],
 ", so ",
 Cell[BoxData[
  StyleBox[
   RowBox[{"\[LeftBracketingBar]", 
    OverscriptBox["\|01d45f", "\[RightVector]"], "\[RightBracketingBar]", "=",
     "1"}],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "ec8d01dd-ee57-47f5-bb13-76eb8876c125"],
 " iff the state is pure."
}], "Text",ExpressionUUID->"596756b6-d696-444d-87fe-1a8fce53e22e"],

Cell[BoxData[
 RowBox[{"FullSimplify", "[", 
  RowBox[{"Tr", "[", 
   RowBox[{"rhoB", " ", ".", " ", "rhoB"}], "]"}], "]"}]], "Input",
 CellLabel->
  "In[117]:= ",ExpressionUUID->"b0be843d-6082-4c64-86dc-2f23706feebf"],

Cell[TextData[{
 StyleBox["QF",
  FontWeight->"Bold"],
 " : the object computes the Bloch vector directly."
}], "Text",ExpressionUUID->"8b17270b-0ebf-4db3-bd09-9eb6381ae9d8"],

Cell[BoxData[
 RowBox[{
  RowBox[{"QuantumState", "[", "rhoB", "]"}], "[", "\"\<BlochVector\>\"", 
  "]"}]], "Input",
 CellLabel->
  "In[118]:= ",ExpressionUUID->"e16f2346-76e0-4f6f-9c77-f7d34eb77025"],

Cell[TextData[{
 "Both recover ",
 Cell[BoxData[
  StyleBox[
   RowBox[{
    OverscriptBox["\|01d45f", "\[RightVector]"], "=", 
    StyleBox["(",
     SpanMaxSize->1], 
    RowBox[{
     SubscriptBox["\|01d45f", "\|01d465"], ",", 
     SubscriptBox["\|01d45f", "\|01d466"], ",", 
     SubscriptBox["\|01d45f", "\|01d467"]}], 
    StyleBox[")",
     SpanMaxSize->1]}],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "e48f133c-e74c-4190-a788-58d2ce151cbd"],
 ", and the purity is ",
 Cell[BoxData[
  StyleBox[
   RowBox[{
    FractionBox["1", "2"], 
    StyleBox["(",
     SpanMaxSize->1], 
    RowBox[{"1", "+", 
     SubsuperscriptBox["\|01d45f", "\|01d465", "2"], "+", 
     SubsuperscriptBox["\|01d45f", "\|01d466", "2"], "+", 
     SubsuperscriptBox["\|01d45f", "\|01d467", "2"]}], 
    StyleBox[")",
     SpanMaxSize->1]}],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "0bf0c9e1-88e1-4f78-be91-1580f8ce3eb9"],
 ": positivity (",
 Cell[BoxData[
  StyleBox[
   RowBox[{"\|01d70c", "\[SucceedsEqual]", "0"}],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "dc41d615-3fed-45b5-9780-c2b6e5e429c7"],
 ") is exactly ",
 Cell[BoxData[
  StyleBox[
   RowBox[{"\[LeftBracketingBar]", 
    OverscriptBox["\|01d45f", "\[RightVector]"], "\[RightBracketingBar]", "\[LessEqual]",
     "1"}],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "4901f09d-65cc-4f46-92be-68b671f4ec20"],
 " (the Bloch ball), and the pure states are its surface ",
 Cell[BoxData[
  StyleBox[
   RowBox[{"\[LeftBracketingBar]", 
    OverscriptBox["\|01d45f", "\[RightVector]"], "\[RightBracketingBar]", "=",
     "1"}],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "c28a9093-17ed-4631-95f7-d01ea1b1bac3"],
 "."
}], "Text",ExpressionUUID->"d7a3d25c-74c0-41e6-bea0-71d88c2da322"],

Cell["\<\
3.7 [MSc] How do I show that the state space is convex, with pure states as \
its extreme points?\
\>", "Subsection",ExpressionUUID->"9516b20c-b8f6-469a-af76-8b6af5bc96b0"],

Cell[TextData[{
 "The density operators form a convex set: any mixture ",
 Cell[BoxData[
  StyleBox[
   RowBox[{"\|01d45d", 
    SubscriptBox["\|01d70c", "1"], "+", 
    StyleBox["(",
     SpanMaxSize->1], 
    RowBox[{"1", "-", "\|01d45d"}], 
    StyleBox[")",
     SpanMaxSize->1], 
    SubscriptBox["\|01d70c", "2"]}],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "cb95a721-0c61-468b-b28f-43cd1506e082"],
 " is again a state. The pure states are its extreme points, which for a \
qubit is the surface of the Bloch ball."
}], "Text",ExpressionUUID->"7e75a83a-d376-43b1-aab9-e5bba084b16e"],

Cell[TextData[{
 StyleBox["WL",
  FontWeight->"Bold"],
 " : every pure qubit sits on the sphere (",
 Cell[BoxData[
  StyleBox[
   RowBox[{"\[LeftBracketingBar]", 
    OverscriptBox["\|01d45f", "\[RightVector]"], "\[RightBracketingBar]", "=",
     "1"}],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "c6838c8a-b1ea-4761-841e-98b6c6811bbb"],
 "), so pure states are extreme."
}], "Text",ExpressionUUID->"60e7722d-3cf3-453e-bb20-e569fb897ce8"],

Cell[BoxData[
 RowBox[{"FullSimplify", "[", "\n", " ", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"Norm", "[", 
      RowBox[{"Table", "[", 
       RowBox[{
        RowBox[{"Tr", "[", 
         RowBox[{
          RowBox[{"PauliMatrix", "[", "j", "]"}], " ", ".", " ", 
          RowBox[{"KroneckerProduct", "[", 
           RowBox[{"#", ",", " ", 
            RowBox[{"Conjugate", "[", "#", "]"}]}], "]"}]}], "]"}], ",", " ", 
        
        RowBox[{"{", 
         RowBox[{"j", ",", " ", "3"}], "}"}]}], "]"}], "]"}], " ", "&"}], " ",
     "@", " ", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"Cos", "[", 
       RowBox[{"\[Theta]", "/", "2"}], "]"}], ",", " ", 
      RowBox[{
       RowBox[{"Exp", "[", 
        RowBox[{"I", " ", "\[Phi]"}], "]"}], " ", 
       RowBox[{"Sin", "[", 
        RowBox[{"\[Theta]", "/", "2"}], "]"}]}]}], "}"}]}], ",", "\n", " ", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"\[Theta]", ",", " ", "\[Phi]"}], "}"}], " ", "\[Element]", " ", 
    "Reals"}]}], "]"}]], "Input",
 CellLabel->
  "In[119]:= ",ExpressionUUID->"c8423923-2ca6-4a27-9b91-c0d3eb138e02"],

Cell[TextData[{
 "A nontrivial mixture of two distinct pure states (here ",
 Cell[BoxData[
  StyleBox[
   TemplateBox[{"0"},
    "Ket"],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "db527404-77b7-4e68-bad8-32890e90c5f4"],
 " and ",
 Cell[BoxData[
  StyleBox[
   RowBox[{
    TemplateBox[{
      StyleBox["\|01d445"]},
     "Ket"], "=", "{", "1", ",", "\|01d456", "}", "/", 
    SqrtBox["2"]}],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "3086159a-2e72-4b76-be1f-7429b6bb62a1"],
 ", the same pair used by the QF cells below) lands strictly inside (purity \
",
 Cell[BoxData[
  StyleBox[
   RowBox[{"<", "1"}],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "68f91286-1845-43d9-a559-64bd6dec90db"],
 ")."
}], "Text",ExpressionUUID->"6fb50856-ead5-46f6-964b-0a01ce5d4a29"],

Cell[BoxData[
 RowBox[{"With", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"p", " ", "=", " ", 
     RowBox[{"1", "/", "3"}]}], "}"}], ",", "\n", " ", 
   RowBox[{
    RowBox[{
     RowBox[{"Tr", "[", 
      RowBox[{"#", ".", "#"}], "]"}], " ", "&"}], "[", 
    RowBox[{
     RowBox[{"p", " ", 
      RowBox[{"KroneckerProduct", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"1", ",", " ", "0"}], "}"}], ",", " ", 
        RowBox[{"Conjugate", "[", 
         RowBox[{"{", 
          RowBox[{"1", ",", " ", "0"}], "}"}], "]"}]}], "]"}]}], " ", "+", 
     " ", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{"1", " ", "-", " ", "p"}], ")"}], " ", 
      RowBox[{"KroneckerProduct", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"{", 
          RowBox[{"1", ",", " ", "I"}], "}"}], "/", 
         RowBox[{"Sqrt", "[", "2", "]"}]}], ",", " ", 
        RowBox[{"Conjugate", "[", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{"1", ",", " ", "I"}], "}"}], "/", 
          RowBox[{"Sqrt", "[", "2", "]"}]}], "]"}]}], "]"}]}]}], "]"}]}], 
  "]"}]], "Input",
 CellLabel->
  "In[120]:= ",ExpressionUUID->"7b64ead7-7488-4901-9773-cf99cde417c0"],

Cell[TextData[{
 StyleBox["QF",
  FontWeight->"Bold"],
 " : build the same mixture as an object."
}], "Text",ExpressionUUID->"384de81c-cbb9-4e3b-8abf-02219fe67a17"],

Cell[BoxData[
 RowBox[{"mix", " ", "=", " ", 
  RowBox[{"QuantumState", "[", 
   RowBox[{
    RowBox[{
     RowBox[{"1", "/", "3"}], " ", 
     RowBox[{
      RowBox[{"QuantumState", "[", 
       RowBox[{"{", 
        RowBox[{"1", ",", " ", "0"}], "}"}], "]"}], 
      "[", "\"\<DensityMatrix\>\"", "]"}]}], " ", "+", " ", 
    RowBox[{
     RowBox[{"2", "/", "3"}], " ", 
     RowBox[{
      RowBox[{"QuantumState", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"1", ",", " ", "I"}], "}"}], "/", 
        RowBox[{"Sqrt", "[", "2", "]"}]}], "]"}], "[", "\"\<DensityMatrix\>\"",
       "]"}]}]}], "]"}]}]], "Input",
 CellLabel->
  "In[121]:= ",ExpressionUUID->"cf76e210-b67a-41d6-ba54-3c0496f7cb0a"],

Cell["Its purity is below one.", "Text",ExpressionUUID->"99dfae95-e24d-42f9-8472-211bfcf17f7f"],

Cell[BoxData[
 RowBox[{"mix", "[", "\"\<Purity\>\"", "]"}]], "Input",
 CellLabel->
  "In[122]:= ",ExpressionUUID->"3431813f-2709-4fc4-b21b-697385a7df84"],

Cell["\<\
Its Bloch radius is below one, so it lies in the interior of the ball.\
\>", "Text",ExpressionUUID->"cb79fd80-c465-4fe1-bdc6-39f29e11fbe7"],

Cell[BoxData[
 RowBox[{"Norm", "[", 
  RowBox[{"mix", "[", "\"\<BlochVector\>\"", "]"}], "]"}]], "Input",
 CellLabel->
  "In[123]:= ",ExpressionUUID->"7d2a5dd9-f144-4b56-9fa2-c573e3c34b2a"],

Cell["\<\
The Bloch map is affine: the mixture's Bloch vector is the convex combination \
of the components'.\
\>", "Text",ExpressionUUID->"eacd64ab-fb69-4ff4-9f4c-b9db5f2fab93"],

Cell[BoxData[
 RowBox[{
  RowBox[{"mix", "[", "\"\<BlochVector\>\"", "]"}], " ", "==", " ", 
  RowBox[{
   RowBox[{
    RowBox[{"1", "/", "3"}], " ", 
    RowBox[{
     RowBox[{"QuantumState", "[", 
      RowBox[{"{", 
       RowBox[{"1", ",", " ", "0"}], "}"}], "]"}], "[", "\"\<BlochVector\>\"",
      "]"}]}], " ", "+", " ", 
   RowBox[{
    RowBox[{"2", "/", "3"}], " ", 
    RowBox[{
     RowBox[{"QuantumState", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"1", ",", " ", "I"}], "}"}], "/", 
       RowBox[{"Sqrt", "[", "2", "]"}]}], "]"}], "[", "\"\<BlochVector\>\"", 
     "]"}]}]}]}]], "Input",
 CellLabel->
  "In[124]:= ",ExpressionUUID->"3bbbaaa8-79d4-45d9-828d-ac83cf44dc4b"],

Cell[TextData[{
 "Pure states have radius ",
 Cell[BoxData[
  StyleBox["1",
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "d3cf9536-cfc6-4996-a670-dac452791559"],
 " (extreme points, not expressible as a nontrivial mixture); every mixture \
has radius and purity below ",
 Cell[BoxData[
  StyleBox["1",
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "fd04bb3f-1096-45fc-9689-db6a05d3d46d"],
 " and lies in the interior; and because the Bloch map is affine, mixing \
states maps to mixing their Bloch vectors. That is the convex geometry of the \
Bloch ball."
}], "Text",ExpressionUUID->"6e131929-e426-41f3-97f3-bd816eeabe9f"],

Cell["\<\
3.8 [BSc] How do I compute the von Neumann entropy of a density matrix?\
\>", "Subsection",ExpressionUUID->"c7f7a10c-c006-4bdb-afc0-c206904d0481"],

Cell[TextData[{
 "The von Neumann entropy ",
 Cell[BoxData[
  StyleBox[
   RowBox[{"\|01d446", 
    StyleBox["(",
     SpanMaxSize->1], "\|01d70c", 
    StyleBox[")",
     SpanMaxSize->1], "=", "-", 
    StyleBox["Tr",
     FontSlant->"Plain"], 
    StyleBox["[",
     SpanMaxSize->1], 
    RowBox[{"\|01d70c", 
     StyleBox["log",
      FontSlant->"Plain"], "\[ThinSpace]", "\|01d70c"}], 
    StyleBox["]",
     SpanMaxSize->1], "=", "-", 
    UnderscriptBox["\[Sum]", "\|01d458",
     LimitsPositioning->False], 
    SubscriptBox["\|01d706", "\|01d458"], 
    StyleBox["log",
     FontSlant->"Plain"], "\[ThinSpace]", 
    SubscriptBox["\|01d706", "\|01d458"]}],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "defce5d7-7214-433f-814d-569878c7d300"],
 " is the Shannon entropy of the eigenvalue spectrum: ",
 Cell[BoxData[
  StyleBox["0",
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "65c4cbfa-ef9c-4c4f-84c7-5590967d0f04"],
 " for a pure state, ",
 Cell[BoxData[
  StyleBox[
   RowBox[{
    SubscriptBox[
     StyleBox["log",
      FontSlant->"Plain"], "2"], "\[ThinSpace]", "\|01d451"}],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "4138fa90-bd0f-4ab1-b526-55be374b5e19"],
 " for the maximally mixed."
}], "Text",ExpressionUUID->"151cb29d-8527-4b3e-b788-d29b363014bf"],

Cell[TextData[{
 StyleBox["WL",
  FontWeight->"Bold"],
 " : the Shannon entropy of the eigenvalues, in bits."
}], "Text",ExpressionUUID->"069ab191-0bc0-4b22-b6ae-5ebb679107fd"],

Cell[BoxData[
 RowBox[{"-", 
  RowBox[{"Total", "[", 
   RowBox[{
    RowBox[{
     RowBox[{"#", " ", 
      RowBox[{"Log2", "[", "#", "]"}]}], " ", "&"}], " ", "/@", " ", 
    RowBox[{"Eigenvalues", "[", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{"3", "/", "4"}], ",", " ", "0"}], "}"}], ",", " ", 
       RowBox[{"{", 
        RowBox[{"0", ",", " ", 
         RowBox[{"1", "/", "4"}]}], "}"}]}], "}"}], "]"}]}], "]"}]}]], "Input",\

 CellLabel->
  "In[125]:= ",ExpressionUUID->"cc3c99b5-6237-465c-9f29-4624a2498cdc"],

Cell[TextData[{
 StyleBox["QF",
  FontWeight->"Bold"],
 " : the object reports it directly (as a ",
 Cell[BoxData["Quantity"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "d3401580-3b1d-4bcb-ab6b-f516b429638e"],
 " in bits)."
}], "Text",ExpressionUUID->"1eca2a28-23ed-4906-95f1-3d5074ab0ab6"],

Cell[BoxData[
 RowBox[{
  RowBox[{"QuantumState", "[", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"3", "/", "4"}], ",", " ", "0"}], "}"}], ",", " ", 
     RowBox[{"{", 
      RowBox[{"0", ",", " ", 
       RowBox[{"1", "/", "4"}]}], "}"}]}], "}"}], "]"}], 
  "[", "\"\<VonNeumannEntropy\>\"", "]"}]], "Input",
 CellLabel->
  "In[126]:= ",ExpressionUUID->"1531d6d1-cd16-4194-92ac-9628553eb487"],

Cell[TextData[{
 "Both give ",
 Cell[BoxData[
  StyleBox[
   RowBox[{"-", 
    FractionBox["3", "4"], 
    SubscriptBox[
     StyleBox["log",
      FontSlant->"Plain"], "2"], "\[ThinSpace]", 
    FractionBox["3", "4"], "-", 
    FractionBox["1", "4"], 
    SubscriptBox[
     StyleBox["log",
      FontSlant->"Plain"], "2"], "\[ThinSpace]", 
    FractionBox["1", "4"], "\[TildeTilde]", "0.811"}],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "55091617-a978-4bcd-8d9e-ca680946268f"],
 " bits: the entropy is the classical uncertainty of the eigenvalue \
distribution, vanishing on a pure state and reaching ",
 Cell[BoxData[
  StyleBox[
   RowBox[{
    SubscriptBox[
     StyleBox["log",
      FontSlant->"Plain"], "2"], "\[ThinSpace]", "\|01d451"}],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "a12c1ada-d1a8-49c4-9bd0-eb89bdc7b069"],
 " on the maximally mixed state."
}], "Text",ExpressionUUID->"415071ed-f532-4981-806e-4b1b36460bf2"]
},
