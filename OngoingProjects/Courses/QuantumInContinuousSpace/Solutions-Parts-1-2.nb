(* Beginning of Notebook Content *)
Notebook[{
Cell["\<\
Quantum in Continuous Space: Worked Solutions (Parts 1 and 2)\
\>", "Title",ExpressionUUID->"99907f72-627f-4c53-9b54-15d30520dbbb"],

Cell[TextData[{
 "Worked, pure Wolfram Language answers to the questions in ",
 Cell[BoxData[
  ButtonBox[
   RowBox[{"Question", "-", 
    RowBox[{"List", ".", "md"}]}],
   BaseStyle->"Hyperlink",
   ButtonData->{
     URL["Question-List.md"], None}]], "InlineFormula",ExpressionUUID->
  "eecb5e4c-0e4e-4d09-a4cc-29f59e4c215a"],
 ", Part 1 (the wavefunction and the state space ",
 Cell[BoxData[
  StyleBox[
   SuperscriptBox["\|01d43f", "2"],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "961c956b-6832-4ad1-87a0-0cfcf29155af"],
 ") and Part 2 (operators, position and momentum, and the Fourier bridge). No \
quantum package is used: everything is ",
 Cell[BoxData["Integrate"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "f05324da-70f6-4038-b4fb-bd6828ae59e2"],
 ", ",
 Cell[BoxData["D"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "fc939bb7-118f-409c-9f73-85f594117998"],
 ", ",
 Cell[BoxData["FourierTransform"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "2d1d3ca0-28c5-4507-a50a-0cb0aa1ea231"],
 ", ",
 Cell[BoxData["Simplify"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "e404d672-1e87-43e8-b421-bcbaece053b9"],
 ", and elementary algebra."
}], "Text",ExpressionUUID->"90afb1e4-0970-41dc-b570-292435e7169c"],

Cell[TextData[{
 StyleBox["The states are chosen to be physically real, not the \
path-of-least-resistance Gaussian.",
  FontWeight->"Bold"],
 " A Gaussian is the ",
 StyleBox["unique", "TI"],
 " minimum-uncertainty state, so it is the natural answer only for the \
saturation question (2.7), where it is the punchline. Everywhere else it \
makes the machinery look trivial (its Fourier transform is itself, its \
current is featureless). So the solutions run on states that actually occur \
in physics, each picked so its symbolic answer is interesting:"
}], "Text",ExpressionUUID->"d36615a3-5bdb-4fba-95c3-602a919d28d4"],

Cell[TextData[{
 "the ",
 StyleBox["cusp state",
  FontWeight->"Bold"],
 " ",
 Cell[BoxData[
  StyleBox[
   RowBox[{"\|01d713", 
    StyleBox["(",
     SpanMaxSize->1], "\|01d465", 
    StyleBox[")",
     SpanMaxSize->1], "=", 
    SqrtBox["\|01d705"], " ", 
    SuperscriptBox["\|01d452", 
     RowBox[{
     "-", "\|01d705", "\[LeftBracketingBar]", "\|01d465", "\[VeryThinSpace]", 
      "\[RightBracketingBar]"}]]}],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "71e7625a-5694-47ef-afaf-8dabd4002395"],
 ", the exact bound state of the attractive Dirac-delta potential and the \
one-dimensional analog of the hydrogen ",
 Cell[BoxData[
  StyleBox[
   RowBox[{"1", "\|01d460"}],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "fbe64948-1c18-46fb-9fd6-d75f5e43d1a8"],
 " orbital (Part 3); its momentum distribution is a heavy-tailed Lorentzian;"
}], "Item",ExpressionUUID->"4a5fc194-8a24-4bdf-b7a1-7d17f8f3ce54"],

Cell[TextData[{
 "the ",
 StyleBox["sech soliton",
  FontWeight->"Bold"],
 " ",
 Cell[BoxData[
  StyleBox[
   RowBox[{"\|01d713", 
    StyleBox["(",
     SpanMaxSize->1], "\|01d465", 
    StyleBox[")",
     SpanMaxSize->1], "=", 
    FractionBox["1", 
     SqrtBox["2"]], 
    StyleBox["sech",
     FontSlant->"Plain"], 
    StyleBox["(",
     SpanMaxSize->1], "\|01d465", 
    StyleBox[")",
     SpanMaxSize->1]}],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "42799f07-6c4a-4661-b78d-0e9a74dbdd6f"],
 ", the bright soliton of the nonlinear Schrodinger equation and the ground \
state of the Poschl-Teller well (Parts 8, 21); its Fourier transform is again \
a sech, and it is nearly (but not exactly) minimum uncertainty;"
}], "Item",ExpressionUUID->"a0ea5085-01d4-4ab0-88ca-7b3af454ec15"],

Cell[TextData[{
 "the ",
 StyleBox["hydrogen ",
  FontWeight->"Bold"],
 Cell[BoxData[
  StyleBox[
   RowBox[{"1", "\|01d460"}],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,
  FontWeight->"Bold",ExpressionUUID->"5d68d856-3c4d-4ac1-84b7-2ae3fc6c28a4"],
 StyleBox[" reduced radial",
  FontWeight->"Bold"],
 " ",
 Cell[BoxData[
  StyleBox[
   RowBox[{"\|01d462", 
    StyleBox["(",
     SpanMaxSize->1], "\|01d465", 
    StyleBox[")",
     SpanMaxSize->1], "=", "2", 
    SuperscriptBox["\|01d705", 
     RowBox[{"3", "/", "2"}]], "\|01d465", " ", 
    SuperscriptBox["\|01d452", 
     RowBox[{"-", "\|01d705", "\|01d465"}]]}],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "98d56069-0660-4489-a357-2e03451bc96e"],
 " on the half-line (Part 12), which gives a clean complex recoil amplitude;"
}], "Item",ExpressionUUID->"8300a6bf-a66e-4932-a3c8-b71e5ae6e767"],

Cell[TextData[{
 "the ",
 StyleBox["Gaussian",
  FontWeight->"Bold"],
 ", used once, in 2.7, as the state that saturates the uncertainty bound."
}], "Item",ExpressionUUID->"af4ea7cc-0f41-46fb-95a6-0fb5e1183810"],

Cell[TextData[{
 "Each is used here as a given function: the computation needs only calculus, \
so introducing the state before its home Part is motivation, not a dependency \
(the textbook habit of meeting the Gaussian in chapter one). Natural units ",
 Cell[BoxData[
  StyleBox[
   RowBox[{"\[HBar]", "=", "\|01d45a", "=", "1"}],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "0023a27b-6ec2-4665-85c6-74efa94bf328"],
 " throughout; ",
 Cell[BoxData[
  StyleBox[
   RowBox[{"\|01d705", ">", "0"}],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "fcde76cf-1365-4ebe-af99-42f1e6d7fc37"],
 " is an inverse length, ",
 Cell[BoxData[
  StyleBox["\|01d458",
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "740c22b6-34d6-4625-b6dd-a78513eb733b"],
 " a wavenumber, ",
 Cell[BoxData[
  StyleBox[
   SubscriptBox["\|01d465", "0"],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "e5560d66-0cb0-4f93-88b7-52a6d2b468d2"],
 " a position."
}], "Text",ExpressionUUID->"c42c9dbb-4535-4b7e-8d89-2d28710cf9e9"],

Cell[TextData[{
 StyleBox["How each answer is checked.",
  FontWeight->"Bold"],
 " A closed form is confirmed by substitution into the defining relation, by \
agreement between two independent routes (a position-space integral against a \
momentum-space integral), or by numerical convergence of a grid sum. The \
companion script ",
 Cell[BoxData[
  ButtonBox[
   RowBox[{"verify", "/", 
    RowBox[{"part12b", ".", "wls"}]}],
   BaseStyle->"Hyperlink",
   ButtonData->{
     URL["verify/part12b.wls"], None}]], "InlineFormula",ExpressionUUID->
  "3e1a7536-5f9f-4b34-adbd-e1a9f5d9a5bf"],
 " reproduces every stated result with a ",
 Cell[BoxData["PASS"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "9129e631-5e08-4026-8ef3-b41e68256af0"],
 "/",
 Cell[BoxData["FAIL"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "bce74ad0-7487-4c57-8f03-389ce7722bef"],
 "."
}], "Text",ExpressionUUID->"872f5740-4236-41e9-b080-4a3f864d168e"],

Cell[TextData[{
 "A note on one convention trap. Wolfram's ",
 Cell[BoxData["FourierTransform"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "00da8457-6df6-4e6c-ad97-bba36e161ced"],
 " defaults to ",
 Cell[BoxData[
  RowBox[{"FourierParameters", " ", "->", " ", 
   RowBox[{"{", 
    RowBox[{"0", ",", " ", "1"}], "}"}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "66ea9963-fcfc-4ab6-8454-d02ccf5e7e4d"],
 ", the kernel ",
 Cell[BoxData[
  StyleBox[
   RowBox[{
    FractionBox["1", 
     SqrtBox[
      RowBox[{"2", "\[Pi]"}]]], 
    StyleBox["\[Integral]",
     FontSize->1.7 Inherited], "\|01d453", 
    StyleBox["(",
     SpanMaxSize->1], "\|01d465", 
    StyleBox[")",
     SpanMaxSize->1], " ", 
    SuperscriptBox["\|01d452", 
     RowBox[{"+", "\|01d456", "\|01d45d", "\|01d465"}]], " ", "\|01d451", 
    "\|01d465"}],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "d0e603e8-82f5-4d64-84e5-1d97e8553f84"],
 ". The quantum-mechanics forward transform carries the opposite sign, ",
 Cell[BoxData[
  StyleBox[
   RowBox[{
    OverscriptBox["\|01d713", "~"], 
    StyleBox["(",
     SpanMaxSize->1], "\|01d45d", 
    StyleBox[")",
     SpanMaxSize->1], "=", 
    FractionBox["1", 
     SqrtBox[
      RowBox[{"2", "\[Pi]"}]]], 
    StyleBox["\[Integral]",
     FontSize->1.7 Inherited], "\|01d713", 
    StyleBox["(",
     SpanMaxSize->1], "\|01d465", 
    StyleBox[")",
     SpanMaxSize->1], " ", 
    SuperscriptBox["\|01d452", 
     RowBox[{"-", "\|01d456", "\|01d45d", "\|01d465"}]], " ", "\|01d451", 
    "\|01d465"}],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "ad012625-0160-4227-a008-b81338479fa1"],
 ", the choice that makes ",
 Cell[BoxData[
  StyleBox[
   RowBox[{
    OverscriptBox["\|01d45d", "^"], "=", "-", "\|01d456", " ", "\|01d451", "/",
     "\|01d451", "\|01d465"}],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "d194fd9f-09ae-4bcf-af72-2bce25e8e9de"],
 " act as multiplication by ",
 Cell[BoxData[
  StyleBox[
   RowBox[{"+", "\|01d45d"}],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "285f2832-5edb-4cbd-82eb-c0f63f73f7f2"],
 ". So the momentum transforms below use ",
 Cell[BoxData[
  RowBox[{"FourierParameters", " ", "->", " ", 
   RowBox[{"{", 
    RowBox[{"0", ",", " ", 
     RowBox[{"-", "1"}]}], "}"}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "8351ad02-6cbd-4b10-9475-577060b5e636"],
 ", cross-checked against the position-space ",
 Cell[BoxData[
  StyleBox[
   RowBox[{
    StyleBox["\[LeftAngleBracket]",
     SpanMaxSize->1], 
    SuperscriptBox["\|01d45d", "2"], 
    StyleBox["\[RightAngleBracket]",
     SpanMaxSize->1]}],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "8ab874bd-8f6a-43b5-8803-95cc1500fa9e"],
 "."
}], "Text",ExpressionUUID->"a2ba7f91-c7a6-4ad4-afa3-4f17494e0488"],

Cell[TextData[{
 "Part 1. The wavefunction and the state space ",
 Cell[BoxData[
  StyleBox[
   SuperscriptBox["\|01d43f", "2"],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "ba183883-92e8-47f7-9d6c-97918d3369b4"]
}], "Section",ExpressionUUID->"269392e2-a452-42c1-8db1-7e5687286642"],

Cell[TextData[{
 "1.1 [BSc] How do I represent a one-dimensional wavefunction ",
 Cell[BoxData[
  StyleBox[
   RowBox[{"\|01d713", 
    StyleBox["(",
     SpanMaxSize->1], "\|01d465", 
    StyleBox[")",
     SpanMaxSize->1]}],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "026deae2-57cb-4ea6-823e-4461f2d9a38d"],
 " as a Wolfram Language function and plot its probability density ",
 Cell[BoxData[
  StyleBox[
   SuperscriptBox[
    RowBox[{"\[LeftBracketingBar]", 
     RowBox[{"\|01d713", 
      StyleBox["(",
       SpanMaxSize->1], "\|01d465", 
      StyleBox[")",
       SpanMaxSize->1]}], "\[RightBracketingBar]"}], "2"],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "a7bf8d63-4519-4645-ad6e-27e16db63d9e"],
 "?"
}], "Subsection",ExpressionUUID->"085e5a0b-f8e2-44b2-bda3-134277909982"],

Cell[TextData[{
 "A state on the line is a complex function ",
 Cell[BoxData[
  StyleBox[
   RowBox[{"\|01d713", 
    StyleBox["(",
     SpanMaxSize->1], "\|01d465", 
    StyleBox[")",
     SpanMaxSize->1]}],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "b7973fc3-836f-4a81-afe6-3d3297a61ca5"],
 " whose observable content is the density ",
 Cell[BoxData[
  StyleBox[
   SuperscriptBox[
    RowBox[{"\[LeftBracketingBar]", 
     RowBox[{"\|01d713", 
      StyleBox["(",
       SpanMaxSize->1], "\|01d465", 
      StyleBox[")",
       SpanMaxSize->1]}], "\[RightBracketingBar]"}], "2"],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "18243616-fdc1-4d37-bad4-1fa4d1615e94"],
 ". We take the bound state of the attractive contact potential ",
 Cell[BoxData[
  StyleBox[
   RowBox[{"\|01d449", 
    StyleBox["(",
     SpanMaxSize->1], "\|01d465", 
    StyleBox[")",
     SpanMaxSize->1], "=", "-", "\|01d454", " ", "\|01d6ff", 
    StyleBox["(",
     SpanMaxSize->1], "\|01d465", 
    StyleBox[")",
     SpanMaxSize->1]}],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "2460c318-ea48-4716-83df-9f4077d49f49"],
 ": a cusped exponential, the one-dimensional cousin of the hydrogen ",
 Cell[BoxData[
  StyleBox[
   RowBox[{"1", "\|01d460"}],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "4aba07ca-636d-461d-8328-481798947fa6"],
 " orbital."
}], "Text",ExpressionUUID->"efc1b6ec-6a53-4be9-9464-b0bf536d1704"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"\[Psi]", "[", "x_", "]"}], " ", ":=", " ", 
  RowBox[{
   RowBox[{"Sqrt", "[", "\[Kappa]", "]"}], " ", 
   RowBox[{"Exp", "[", 
    RowBox[{
     RowBox[{"-", "\[Kappa]"}], " ", 
     RowBox[{"Abs", "[", "x", "]"}]}], "]"}]}]}], "\n", 
 RowBox[{"dens", " ", "=", " ", 
  RowBox[{"Simplify", "[", 
   RowBox[{
    RowBox[{
     RowBox[{"Abs", "[", 
      RowBox[{"\[Psi]", "[", "x", "]"}], "]"}], "^", "2"}], ",", " ", 
    RowBox[{
     RowBox[{"\[Kappa]", " ", ">", " ", "0"}], " ", "&&", " ", 
     RowBox[{"x", " ", "\[Element]", " ", "Reals"}]}]}], "]"}]}]}], "Input",
 CellLabel->"In[1]:= ",ExpressionUUID->"2ca358b9-6f53-49dd-baff-574a99bdef0f"],

Cell[BoxData[
 RowBox[{"Plot", "[", 
  RowBox[{
   RowBox[{"dens", " ", "/.", " ", 
    RowBox[{"\[Kappa]", " ", "->", " ", "1"}]}], ",", " ", 
   RowBox[{"{", 
    RowBox[{"x", ",", " ", 
     RowBox[{"-", "5"}], ",", " ", "5"}], "}"}], ",", " ", 
   RowBox[{"Filling", " ", "->", " ", "Axis"}], ",", " ", 
   RowBox[{"AxesLabel", " ", "->", " ", 
    RowBox[{"{", 
     RowBox[{"\"\<x\>\"", ",", " ", "\"\<|\[Psi]|^2\>\""}], "}"}]}]}], 
  "]"}]], "Input",
 CellLabel->"In[2]:= ",ExpressionUUID->"8711d51b-9205-4d7f-875f-953de40639cb"],

Cell[TextData[{
 "The density is ",
 Cell[BoxData[
  StyleBox[
   RowBox[{
    SuperscriptBox[
     RowBox[{"\[LeftBracketingBar]", 
      RowBox[{"\|01d713", 
       StyleBox["(",
        SpanMaxSize->1], "\|01d465", 
       StyleBox[")",
        SpanMaxSize->1]}], "\[RightBracketingBar]"}], "2"], "=", "\|01d705", " ", 
    SuperscriptBox["\|01d452", 
     RowBox[{
     "-", "2", "\|01d705", "\[LeftBracketingBar]", "\|01d465", 
      "\[VeryThinSpace]", "\[RightBracketingBar]"}]]}],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "cfbad400-0ebc-4e7e-9233-6a53787e6ac9"],
 ", with a sharp cusp at the origin where the delta potential sits. Nothing \
about it is Gaussian: the exponential decay and the kink are the signature of \
binding by a point interaction."
}], "Text",ExpressionUUID->"dac1cd2d-0af1-4216-b009-58209cd5242f"],

Cell[TextData[{
 "1.2 [BSc] How do I normalize a wavefunction with ",
 Cell[BoxData[
  StyleBox[
   RowBox[{
    UnderoverscriptBox["\[Integral]", 
     RowBox[{"-", "\[Infinity]"}], "\[Infinity]",
     LimitsPositioning->False], 
    SuperscriptBox[
     RowBox[{
     "\[LeftBracketingBar]", "\|01d713", "\[VeryThinSpace]", 
      "\[RightBracketingBar]"}], "2"], " ", "\|01d451", "\|01d465", "=", "1"}],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "be4c7db3-36cf-462f-b42c-58e85cbd495f"],
 ", and recognize a state that cannot be normalized?"
}], "Subsection",ExpressionUUID->"00791091-8016-44a8-af9b-9a1ee10577ab"],

Cell[TextData[{
 "Normalizing divides by the square root of the total probability; a state is \
admissible only if that integral is finite (",
 Cell[BoxData[
  StyleBox[
   RowBox[{"\|01d713", "\[Element]", 
    SuperscriptBox["\|01d43f", "2"]}],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "80554a0a-e517-4243-94ce-063f62999a43"],
 "). We normalize the soliton profile ",
 Cell[BoxData[
  StyleBox[
   RowBox[{
    StyleBox["sech",
     FontSlant->"Plain"], 
    StyleBox["(",
     SpanMaxSize->1], "\|01d465", 
    StyleBox[")",
     SpanMaxSize->1]}],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "d5c8bd02-c4de-4d4f-bf5d-3d133ec20ded"],
 "."
}], "Text",ExpressionUUID->"38311be5-2574-49d0-9737-a8316b3e7fe5"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"\[Phi]", "[", "x_", "]"}], " ", ":=", " ", 
  RowBox[{"Sech", "[", "x", "]"}]}], "\n", 
 RowBox[{"norm2", " ", "=", " ", 
  RowBox[{"Integrate", "[", 
   RowBox[{
    RowBox[{
     RowBox[{"Abs", "[", 
      RowBox[{"\[Phi]", "[", "x", "]"}], "]"}], "^", "2"}], ",", " ", 
    RowBox[{"{", 
     RowBox[{"x", ",", " ", 
      RowBox[{"-", "Infinity"}], ",", " ", "Infinity"}], "}"}]}], "]"}]}], "\n", 
 RowBox[{
  RowBox[{"\[Psi]N", " ", "=", " ", 
   RowBox[{
    RowBox[{"\[Phi]", "[", "x", "]"}], "/", 
    RowBox[{"Sqrt", "[", "norm2", "]"}]}]}], ";"}], "\n", 
 RowBox[{"Integrate", "[", 
  RowBox[{
   RowBox[{
    RowBox[{"Abs", "[", "\[Psi]N", "]"}], "^", "2"}], ",", " ", 
   RowBox[{"{", 
    RowBox[{"x", ",", " ", 
     RowBox[{"-", "Infinity"}], ",", " ", "Infinity"}], "}"}]}], 
  "]"}]}], "Input",
 CellLabel->"In[3]:= ",ExpressionUUID->"8f10c392-0c5c-4361-a0f9-86e4e372e23d"],

Cell[BoxData[
 RowBox[{"Integrate", "[", 
  RowBox[{
   RowBox[{
    RowBox[{"Abs", "[", 
     RowBox[{"Exp", "[", 
      RowBox[{"I", " ", "k", " ", "x"}], "]"}], "]"}], "^", "2"}], ",", " ", 
   RowBox[{"{", 
    RowBox[{"x", ",", " ", 
     RowBox[{"-", "Infinity"}], ",", " ", "Infinity"}], "}"}], ",", " ", 
   RowBox[{"Assumptions", " ", "->", " ", 
    RowBox[{"Element", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"k", ",", " ", "x"}], "}"}], ",", " ", "Reals"}], "]"}]}]}], 
  "]"}]], "Input",
 CellLabel->"In[4]:= ",ExpressionUUID->"5de5a853-a24a-46ce-a4c8-c8198767657b"],

Cell[TextData[{
 "Since ",
 Cell[BoxData[
  StyleBox[
   RowBox[{
    StyleBox["\[Integral]",
     FontSize->1.7 Inherited], 
    SuperscriptBox[
     StyleBox["sech",
      FontSlant->"Plain"], "2"], "\|01d465", " ", "\|01d451", "\|01d465", "=",
     "2"}],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "76256a26-9dc4-45ce-9b7a-c14bf02f8f88"],
 ", the normalized soliton is ",
 Cell[BoxData[
  StyleBox[
   RowBox[{"\|01d713", 
    StyleBox["(",
     SpanMaxSize->1], "\|01d465", 
    StyleBox[")",
     SpanMaxSize->1], "=", 
    FractionBox["1", 
     SqrtBox["2"]], 
    StyleBox["sech",
     FontSlant->"Plain"], 
    StyleBox["(",
     SpanMaxSize->1], "\|01d465", 
    StyleBox[")",
     SpanMaxSize->1]}],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "f236e80f-2b3f-4cad-b4da-2c29761b664e"],
 ", which integrates to ",
 Cell[BoxData[
  StyleBox["1",
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "d3762217-fe68-421b-82f7-75ab39f6791a"],
 ". The plane wave ",
 Cell[BoxData[
  StyleBox[
   SuperscriptBox["\|01d452", 
    RowBox[{"\|01d456", "\|01d458", "\|01d465"}]],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "cedc4135-a606-4322-876f-64c700c741c4"],
 " instead has ",
 Cell[BoxData[
  StyleBox[
   RowBox[{
    SuperscriptBox[
     RowBox[{
     "\[LeftBracketingBar]", "\|01d713", "\[VeryThinSpace]", 
      "\[RightBracketingBar]"}], "2"], "=", "1"}],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "f4b9884b-c6b3-4226-a343-3d03e881bbb9"],
 " everywhere and a divergent integral (",
 Cell[BoxData["Infinity"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "c483fa54-a4ca-43f6-badf-5a8b36562d20"],
 "): a momentum eigenstate lives outside ",
 Cell[BoxData[
  StyleBox[
   SuperscriptBox["\|01d43f", "2"],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "e6eac1d7-080f-41c7-8475-0105c94bc4dc"],
 " and must be delta-normalized (see 2.5)."
}], "Text",ExpressionUUID->"b876ee19-fb37-43f1-a607-481cef24f45a"],

Cell[TextData[{
 "1.3 [BSc] How do I compute the Born-rule probability ",
 Cell[BoxData[
  StyleBox[
   RowBox[{
    UnderoverscriptBox["\[Integral]", "\|01d44e", "\|01d44f",
     LimitsPositioning->False], 
    SuperscriptBox[
     RowBox[{
     "\[LeftBracketingBar]", "\|01d713", "\[VeryThinSpace]", 
      "\[RightBracketingBar]"}], "2"], " ", "\|01d451", "\|01d465"}],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "1505f807-0863-4f7d-b817-f495c7e18b86"],
 " of finding the particle in a region?"
}], "Subsection",ExpressionUUID->"daa0e1ee-a196-400d-bd11-10aa45759952"],

Cell[TextData[{
 "The probability of finding the particle in a window is the integral of the \
density over it. For the soliton, the symmetric window ",
 Cell[BoxData[
  StyleBox[
   RowBox[{
    StyleBox["[",
     SpanMaxSize->1], 
    RowBox[{
     RowBox[{"-", "\|01d44e"}], ",", "\|01d44e"}], 
    StyleBox["]",
     SpanMaxSize->1]}],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "1fa9c73e-c1fc-4e83-be51-ef244d702c6f"],
 " gives a strikingly simple answer."
}], "Text",ExpressionUUID->"a9174898-24c5-4a82-9b0c-c9521971e43f"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"\[Psi]", "[", "x_", "]"}], " ", ":=", " ", 
   RowBox[{
    RowBox[{"Sech", "[", "x", "]"}], "/", 
    RowBox[{"Sqrt", "[", "2", "]"}]}]}], ";"}], "\n", 
 RowBox[{"Integrate", "[", 
  RowBox[{
   RowBox[{
    RowBox[{"Abs", "[", 
     RowBox[{"\[Psi]", "[", "x", "]"}], "]"}], "^", "2"}], ",", " ", 
   RowBox[{"{", 
    RowBox[{"x", ",", " ", 
     RowBox[{"-", "a"}], ",", " ", "a"}], "}"}], ",", " ", 
   RowBox[{"Assumptions", " ", "->", " ", 
    RowBox[{"a", " ", ">", " ", "0"}]}]}], "]"}]}], "Input",
 CellLabel->"In[5]:= ",ExpressionUUID->"ad9b9709-fef1-4503-84fa-9777740a1f47"],

Cell[TextData[{
 "The probability is exactly ",
 Cell[BoxData[
  StyleBox[
   RowBox[{
    StyleBox["tanh",
     FontSlant->"Plain"], "\[ThinSpace]", 
    StyleBox["(",
     SpanMaxSize->1], "\|01d44e", 
    StyleBox[")",
     SpanMaxSize->1]}],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "8107fff7-c849-4f3a-862c-a7de215ce659"],
 ": it climbs from ",
 Cell[BoxData[
  StyleBox["0",
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "1ad3a240-5318-4802-9f32-806f5aaf34ac"],
 " and saturates at ",
 Cell[BoxData[
  StyleBox["1",
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "1935065d-271e-4430-8912-ec81817a4284"],
 " as ",
 Cell[BoxData[
  StyleBox[
   RowBox[{"\|01d44e", "\[Rule]", "\[Infinity]"}],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "68dea951-07b3-4169-a0dd-8649fb565dce"],
 ", with ",
 Cell[BoxData[
  StyleBox["tanh",
   FontFamily->"Latin Modern Math",
   FontSlant->"Plain"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "a10348e7-162e-40b2-ab3b-100bc85ae869"],
 " measuring how much of the soliton sits within ",
 Cell[BoxData[
  StyleBox["\|01d44e",
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "06cc3a7f-0c3d-447b-a7f9-8e4fa92a1e00"],
 " of its center. The soliton's width is order one, so a window of a few \
units already captures nearly all of it."
}], "Text",ExpressionUUID->"fae024bc-49ab-4f4e-919d-a47bfd83a216"],

Cell[TextData[{
 "1.4 [BSc] How do I compute the inner product ",
 Cell[BoxData[
  StyleBox[
   RowBox[{
    TemplateBox[{
      StyleBox["\[Phi]"], 
      StyleBox["\|01d713"]},
     "BraKet"], "=", 
    StyleBox["\[Integral]",
     FontSize->1.7 Inherited], 
    SuperscriptBox["\[Phi]", "*"], "\|01d713", "\|01d451", "\|01d465"}],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "d0c37124-dfdd-441c-b436-8d822cc66394"],
 ", its modulus, and the transition probability ",
 Cell[BoxData[
  StyleBox[
   SuperscriptBox[
    RowBox[{
     StyleBox["\[LeftBracketingBar]",
      SpanMinSize->1.9], 
     TemplateBox[{
       StyleBox["\[Phi]"], 
       StyleBox["\|01d713"]},
      "BraKet"], 
     StyleBox["\[RightBracketingBar]",
      SpanMinSize->1.9]}], "2"],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "6720ef80-078c-4b5e-9dfb-c434d88193c2"],
 "?"
}], "Subsection",ExpressionUUID->"64986a28-0d60-4ebb-9b8a-19dcdbc42f9e"],

Cell[TextData[{
 "The overlap of two states is ",
 Cell[BoxData[
  StyleBox[
   RowBox[{
    StyleBox["\[Integral]",
     FontSize->1.7 Inherited], 
    SuperscriptBox["\[Phi]", "*"], "\|01d713", " ", "\|01d451", "\|01d465"}],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "0400185e-3a35-4e89-9484-f96046d2585e"],
 "; its squared modulus is the probability that a system prepared as ",
 Cell[BoxData[
  StyleBox["\|01d713",
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "49948455-03ec-4393-9d8d-1bae5771e8c7"],
 " is found in ",
 Cell[BoxData[
  StyleBox["\[Phi]",
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "e4d95ee3-3513-4227-8621-e1ffd70a66e5"],
 ". We take the hydrogen ",
 Cell[BoxData[
  StyleBox[
   RowBox[{"1", "\|01d460"}],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "3da21fa3-056b-48cb-be08-d57d4f785aeb"],
 " radial state ",
 Cell[BoxData[
  StyleBox["\|01d462",
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "6a2bac72-cd49-464f-8b26-cb9cb897222b"],
 " and the ",
 StyleBox["same", "TI"],
 " state after a sudden momentum kick ",
 Cell[BoxData[
  StyleBox["\|01d45e",
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "c2401a25-ac66-4d7f-8be0-af54c57b1250"],
 ", ",
 Cell[BoxData[
  StyleBox[
   RowBox[{"\[Phi]", "=", 
    SuperscriptBox["\|01d452", 
     RowBox[{"\|01d456", "\|01d45e", "\|01d465"}]], "\|01d462"}],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "bf6bce64-94ed-4704-8505-35a9f686093e"],
 " (the survival amplitude in the sudden approximation)."
}], "Text",ExpressionUUID->"a2bc3975-763d-4dc2-8e21-0bab522e91a8"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"u", "[", "x_", "]"}], " ", ":=", " ", 
   RowBox[{"2", " ", 
    RowBox[{"\[Kappa]", "^", 
     RowBox[{"(", 
      RowBox[{"3", "/", "2"}], ")"}]}], " ", "x", " ", 
    RowBox[{"Exp", "[", 
     RowBox[{
      RowBox[{"-", "\[Kappa]"}], " ", "x"}], "]"}]}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"\[Phi]", "[", "x_", "]"}], " ", ":=", " ", 
   RowBox[{
    RowBox[{"Exp", "[", 
     RowBox[{"I", " ", "q", " ", "x"}], "]"}], " ", 
    RowBox[{"u", "[", "x", "]"}]}]}], ";"}], "\n", 
 RowBox[{"ovl", " ", "=", " ", 
  RowBox[{"Integrate", "[", 
   RowBox[{
    RowBox[{
     RowBox[{"Conjugate", "[", 
      RowBox[{"\[Phi]", "[", "x", "]"}], "]"}], " ", 
     RowBox[{"u", "[", "x", "]"}]}], ",", " ", 
    RowBox[{"{", 
     RowBox[{"x", ",", " ", "0", ",", " ", "Infinity"}], "}"}], ",", " ", 
    RowBox[{"Assumptions", " ", "->", " ", 
     RowBox[{
      RowBox[{"\[Kappa]", " ", ">", " ", "0"}], " ", "&&", " ", 
      RowBox[{"q", " ", "\[Element]", " ", "Reals"}]}]}]}], "]"}]}], "\n", 
 RowBox[{"Simplify", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{"Abs", "[", "ovl", "]"}], ",", " ", 
     RowBox[{
      RowBox[{"Abs", "[", "ovl", "]"}], "^", "2"}]}], "}"}], ",", " ", 
   RowBox[{
    RowBox[{"\[Kappa]", " ", ">", " ", "0"}], " ", "&&", " ", 
    RowBox[{"q", " ", "\[Element]", " ", "Reals"}]}]}], "]"}]}], "Input",
 CellLabel->"In[6]:= ",ExpressionUUID->"5378f3d9-494c-4571-aae2-956e0f92cf4f"],

Cell[TextData[{
 "The overlap is ",
 Cell[BoxData[
  StyleBox[
   RowBox[{
    TemplateBox[{
      StyleBox["\[Phi]"], 
      StyleBox["\|01d713"]},
     "BraKet"], "=", "8", 
    SuperscriptBox["\|01d705", "3"], "/", 
    SuperscriptBox[
     RowBox[{
      StyleBox["(",
       SpanMaxSize->1], 
      RowBox[{"2", "\|01d705", "+", "\|01d456", "\|01d45e"}], 
      StyleBox[")",
       SpanMaxSize->1]}], "3"]}],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "9e98be65-59c1-4303-8a26-066718778e0e"],
 ", genuinely complex: the phase records the momentum kick. Using ",
 Cell[BoxData[
  StyleBox[
   RowBox[{"\[LeftBracketingBar]", 
    RowBox[{"2", "\|01d705", "+", "\|01d456", "\|01d45e"}], 
    "\[VeryThinSpace]", "\[RightBracketingBar]", "=", 
    SqrtBox[
     RowBox[{"4", 
      SuperscriptBox["\|01d705", "2"], "+", 
      SuperscriptBox["\|01d45e", "2"]}]]}],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "81c4cc14-173e-4875-bba3-c7b7a2f48d5f"],
 ", its modulus is ",
 Cell[BoxData[
  StyleBox[
   RowBox[{"8", 
    SuperscriptBox["\|01d705", "3"], "/", 
    SuperscriptBox[
     RowBox[{
      StyleBox["(",
       SpanMaxSize->1], 
      RowBox[{"4", 
       SuperscriptBox["\|01d705", "2"], "+", 
       SuperscriptBox["\|01d45e", "2"]}], 
      StyleBox[")",
       SpanMaxSize->1]}], 
     RowBox[{"3", "/", "2"}]]}],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "520a1698-6b0a-47d8-a9ef-1b0183dc65bd"],
 " and the survival probability is ",
 Cell[BoxData[
  StyleBox[
   RowBox[{"64", 
    SuperscriptBox["\|01d705", "6"], "/", 
    SuperscriptBox[
     RowBox[{
      StyleBox["(",
       SpanMaxSize->1], 
      RowBox[{"4", 
       SuperscriptBox["\|01d705", "2"], "+", 
       SuperscriptBox["\|01d45e", "2"]}], 
      StyleBox[")",
       SpanMaxSize->1]}], "3"]}],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "63ccfa50-8750-4ec9-a3e9-ff3acf3a792f"],
 ", both falling off as the kick ",
 Cell[BoxData[
  StyleBox["\|01d45e",
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "ce9c7db2-d354-4865-9138-bfa9bd40c357"],
 " grows past the orbital's momentum scale ",
 Cell[BoxData[
  StyleBox["\|01d705",
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "301ee6d0-112b-4fa6-88d4-7e5d6899a42a"],
 ". This is the recoil form factor probed when an atom is struck suddenly."
}], "Text",ExpressionUUID->"81664cb1-9ec1-4e26-b35d-92734017600f"],

Cell[TextData[{
 "1.5 [BSc] How do I compute the position expectation ",
 Cell[BoxData[
  StyleBox[
   RowBox[{
    StyleBox["\[LeftAngleBracket]",
     SpanMaxSize->1], "\|01d465", "\[VeryThinSpace]", 
    StyleBox["\[RightAngleBracket]",
     SpanMaxSize->1]}],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "968392a5-1a5a-4eab-9b55-f896c6c028fb"],
 " and the spread ",
 Cell[BoxData[
  StyleBox[
   RowBox[{"\[CapitalDelta]", "\|01d465", "=", 
    SqrtBox[
     RowBox[{
      StyleBox["\[LeftAngleBracket]",
       SpanMaxSize->1], 
      SuperscriptBox["\|01d465", "2"], 
      StyleBox["\[RightAngleBracket]",
       SpanMaxSize->1], "-", 
      SuperscriptBox[
       RowBox[{
        StyleBox["\[LeftAngleBracket]",
         SpanMaxSize->1], "\|01d465", "\[VeryThinSpace]", 
        StyleBox["\[RightAngleBracket]",
         SpanMaxSize->1]}], "2"]}]]}],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "d0d26fad-4367-4ada-ba01-d87bdb5742bb"],
 "?"
}], "Subsection",ExpressionUUID->"ec519506-c962-453d-8f19-03ee1def88a8"],

Cell[TextData[{
 "The mean position is ",
 Cell[BoxData[
  StyleBox[
   RowBox[{
    StyleBox["\[Integral]",
     FontSize->1.7 Inherited], "\|01d465", " ", 
    SuperscriptBox[
     RowBox[{
     "\[LeftBracketingBar]", "\|01d713", "\[VeryThinSpace]", 
      "\[RightBracketingBar]"}], "2"], " ", "\|01d451", "\|01d465"}],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "d09ab2c3-5793-4dd9-a8b1-c849f41ca6e0"],
 " and the spread is the root-variance of that distribution. We place the \
soliton at ",
 Cell[BoxData[
  StyleBox[
   SubscriptBox["\|01d465", "0"],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "b275a665-a076-4ce3-a19e-53ba05aa57b7"],
 "."
}], "Text",ExpressionUUID->"37cd8061-50a6-4df5-bb8f-c6834085ccaa"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"\[Psi]", "[", "x_", "]"}], " ", ":=", " ", 
   RowBox[{
    RowBox[{"Sech", "[", 
     RowBox[{"x", " ", "-", " ", "x0"}], "]"}], "/", 
    RowBox[{"Sqrt", "[", "2", "]"}]}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"mx", " ", "=", " ", 
   RowBox[{"Integrate", "[", 
    RowBox[{
     RowBox[{"x", " ", 
      RowBox[{
       RowBox[{"Abs", "[", 
        RowBox[{"\[Psi]", "[", "x", "]"}], "]"}], "^", "2"}]}], ",", " ", 
     RowBox[{"{", 
      RowBox[{"x", ",", " ", 
       RowBox[{"-", "Infinity"}], ",", " ", "Infinity"}], "}"}], ",", " ", 
     RowBox[{"Assumptions", " ", "->", " ", 
      RowBox[{"x0", " ", "\[Element]", " ", "Reals"}]}]}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"mx2", " ", "=", " ", 
   RowBox[{"Integrate", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"x", "^", "2"}], " ", 
      RowBox[{
       RowBox[{"Abs", "[", 
        RowBox[{"\[Psi]", "[", "x", "]"}], "]"}], "^", "2"}]}], ",", " ", 
     RowBox[{"{", 
      RowBox[{"x", ",", " ", 
       RowBox[{"-", "Infinity"}], ",", " ", "Infinity"}], "}"}], ",", " ", 
     RowBox[{"Assumptions", " ", "->", " ", 
      RowBox[{"x0", " ", "\[Element]", " ", "Reals"}]}]}], "]"}]}], ";"}], "\n", 
 RowBox[{"{", 
  RowBox[{"mx", ",", " ", 
   RowBox[{"Simplify", "[", 
    RowBox[{
     RowBox[{"Sqrt", "[", 
      RowBox[{"mx2", " ", "-", " ", 
       RowBox[{"mx", "^", "2"}]}], "]"}], ",", " ", 
     RowBox[{"x0", " ", "\[Element]", " ", "Reals"}]}], "]"}]}], 
  "}"}]}], "Input",
 CellLabel->"In[7]:= ",ExpressionUUID->"7643293b-9144-4363-883c-9a251ecb7362"],

Cell[TextData[{
 "The soliton sits at ",
 Cell[BoxData[
  StyleBox[
   RowBox[{
    StyleBox["\[LeftAngleBracket]",
     SpanMaxSize->1], "\|01d465", "\[VeryThinSpace]", 
    StyleBox["\[RightAngleBracket]",
     SpanMaxSize->1], "=", 
    SubscriptBox["\|01d465", "0"]}],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "470da268-4cd0-4a23-b7e2-d89f5209dddd"],
 " with spread ",
 Cell[BoxData[
  StyleBox[
   RowBox[{"\[CapitalDelta]", "\|01d465", "=", "\[Pi]", "/", 
    StyleBox["(",
     SpanMaxSize->1], 
    RowBox[{"2", 
     SqrtBox["3"]}], 
    StyleBox[")",
     SpanMaxSize->1]}],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "dca44f90-6750-4787-bd3e-7f0b503d8823"],
 ", a pure number fixed by the ",
 Cell[BoxData[
  StyleBox[
   SuperscriptBox[
    StyleBox["sech",
     FontSlant->"Plain"], "2"],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "a0c23e73-fc4c-4d42-8a44-ab997aedda51"],
 " profile (the ",
 Cell[BoxData[
  StyleBox["\[Pi]",
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "7e2cbd9c-070a-4570-a41b-5719b6fddd43"],
 " comes from ",
 Cell[BoxData[
  StyleBox[
   RowBox[{
    StyleBox["\[Integral]",
     FontSize->1.7 Inherited], 
    SuperscriptBox["\|01d465", "2"], 
    SuperscriptBox[
     StyleBox["sech",
      FontSlant->"Plain"], "2"], "\|01d465", " ", "\|01d451", "\|01d465", "=", 
    SuperscriptBox["\[Pi]", "2"], "/", "6"}],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "7d5c17ea-52f1-4c86-8b3c-62409739729b"],
 "). This ",
 Cell[BoxData[
  StyleBox[
   RowBox[{"\[CapitalDelta]", "\|01d465"}],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "57a12a6c-daf8-4013-9e10-303b20940a50"],
 " is what enters the uncertainty product of 2.7."
}], "Text",ExpressionUUID->"e012af24-cde1-4e11-85ed-06a732060237"],

Cell[TextData[{
 "1.6 [BSc] How do I compute the probability current density ",
 Cell[BoxData[
  StyleBox[
   RowBox[{"\|01d457", 
    StyleBox["(",
     SpanMaxSize->1], 
    RowBox[{"\|01d465", ",", "\|01d461"}], 
    StyleBox[")",
     SpanMaxSize->1]}],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "98f78f88-bfc0-45c3-817a-968394d694e9"],
 " and verify the continuity equation ",
 Cell[BoxData[
  StyleBox[
   RowBox[{
    SubscriptBox["\[PartialD]", "\|01d461"], 
    SuperscriptBox[
     RowBox[{
     "\[LeftBracketingBar]", "\|01d713", "\[VeryThinSpace]", 
      "\[RightBracketingBar]"}], "2"], "+", 
    SubscriptBox["\[PartialD]", "\|01d465"], "\|01d457", "=", "0"}],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "144d92fe-44bd-4d7b-b56b-2d9f379625de"],
 "?"
}], "Subsection",ExpressionUUID->"4fd517c3-acaa-4264-a64b-32d8fa0d0875"],

Cell[TextData[{
 "Probability is locally conserved: the density's rate of change is minus the \
divergence of the current ",
 Cell[BoxData[
  StyleBox[
   RowBox[{"\|01d457", "=", 
    FractionBox["1", 
     RowBox[{"2", "\|01d456"}]], 
    StyleBox["(",
     SpanMaxSize->1], 
    RowBox[{
     SuperscriptBox["\|01d713", "*"], 
     SubscriptBox["\[PartialD]", "\|01d465"], "\|01d713", "-", "\|01d713", " ", 
     SubscriptBox["\[PartialD]", "\|01d465"], 
     SuperscriptBox["\|01d713", "*"]}], 
    StyleBox[")",
     SpanMaxSize->1]}],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "a6115a6c-df97-45b1-bf03-c8625dc5e12b"],
 " (with ",
 Cell[BoxData[
  StyleBox[
   RowBox[{"\[HBar]", "=", "\|01d45a", "=", "1"}],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "b410c6da-30a0-4ed7-b6d3-b33eacf7e083"],
 "). To check continuity in full generality we treat ",
 Cell[BoxData[
  StyleBox["\|01d713",
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "69185948-1210-4cf1-b911-6752f8727403"],
 " and ",
 Cell[BoxData[
  StyleBox[
   SuperscriptBox["\|01d713", "*"],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "e39133e6-c297-4062-9785-159ef3079677"],
 " as independent functions ",
 Cell[BoxData[
  StyleBox[
   RowBox[{"\|01d453", ",", "\|01d454"}],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "0f3c6fa6-0247-4819-82ed-cef8323de644"],
 " and impose the free Schrodinger equation ",
 Cell[BoxData[
  StyleBox[
   RowBox[{
    SubscriptBox["\[PartialD]", "\|01d461"], "\|01d453", "=", 
    FractionBox["\|01d456", "2"], 
    SubsuperscriptBox["\[PartialD]", "\|01d465", "2"], "\|01d453"}],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "90bfe7bf-9e0f-440f-9fd5-da6d4c0ef452"],
 " and its conjugate."
}], "Text",ExpressionUUID->"be36b862-438a-42b6-9ba9-419dd0d6a7d3"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"\[Rho]", " ", "=", " ", 
   RowBox[{
    RowBox[{"g", "[", 
     RowBox[{"x", ",", " ", "t"}], "]"}], " ", 
    RowBox[{"f", "[", 
     RowBox[{"x", ",", " ", "t"}], "]"}]}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"j", " ", "=", " ", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{
      RowBox[{
       RowBox[{"g", "[", 
        RowBox[{"x", ",", " ", "t"}], "]"}], " ", 
       RowBox[{"D", "[", 
        RowBox[{
         RowBox[{"f", "[", 
          RowBox[{"x", ",", " ", "t"}], "]"}], ",", " ", "x"}], "]"}]}], " ", 
      "-", " ", 
      RowBox[{
       RowBox[{"f", "[", 
        RowBox[{"x", ",", " ", "t"}], "]"}], " ", 
       RowBox[{"D", "[", 
        RowBox[{
         RowBox[{"g", "[", 
          RowBox[{"x", ",", " ", "t"}], "]"}], ",", " ", "x"}], "]"}]}]}], 
     ")"}], "/", 
    RowBox[{"(", 
     RowBox[{"2", " ", "I"}], ")"}]}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"cont", " ", "=", " ", 
   RowBox[{
    RowBox[{
     RowBox[{"D", "[", 
      RowBox[{"\[Rho]", ",", " ", "t"}], "]"}], " ", "+", " ", 
     RowBox[{"D", "[", 
      RowBox[{"j", ",", " ", "x"}], "]"}]}], " ", "/.", "\n", "   ", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{"Derivative", "[", 
          RowBox[{"0", ",", " ", "1"}], "]"}], "[", "f", "]"}], "[", 
        RowBox[{"x", ",", " ", "t"}], "]"}], " ", "->", " ", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{"I", "/", "2"}], ")"}], " ", 
        RowBox[{"D", "[", 
         RowBox[{
          RowBox[{"f", "[", 
           RowBox[{"x", ",", " ", "t"}], "]"}], ",", " ", 
          RowBox[{"{", 
           RowBox[{"x", ",", " ", "2"}], "}"}]}], "]"}]}]}], ",", "\n", 
      "    ", 
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{"Derivative", "[", 
          RowBox[{"0", ",", " ", "1"}], "]"}], "[", "g", "]"}], "[", 
        RowBox[{"x", ",", " ", "t"}], "]"}], " ", "->", " ", 
       RowBox[{
        RowBox[{"-", 
         RowBox[{"(", 
          RowBox[{"I", "/", "2"}], ")"}]}], " ", 
        RowBox[{"D", "[", 
         RowBox[{
          RowBox[{"g", "[", 
           RowBox[{"x", ",", " ", "t"}], "]"}], ",", " ", 
          RowBox[{"{", 
           RowBox[{"x", ",", " ", "2"}], "}"}]}], "]"}]}]}]}], "}"}]}]}], 
  ";"}], "\n", 
 RowBox[{"Simplify", "[", "cont", "]"}]}], "Input",
 CellLabel->"In[8]:= ",ExpressionUUID->"87d72919-b315-4465-9154-54c05eb5cbd2"],

Cell[TextData[{
 "The residual is exactly ",
 Cell[BoxData[
  StyleBox["0",
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "913c081e-bdb8-490d-9226-33c6053b6b15"],
 ": density and current satisfy ",
 Cell[BoxData[
  StyleBox[
   RowBox[{
    SubscriptBox["\[PartialD]", "\|01d461"], 
    SuperscriptBox[
     RowBox[{
     "\[LeftBracketingBar]", "\|01d713", "\[VeryThinSpace]", 
      "\[RightBracketingBar]"}], "2"], "+", 
    SubscriptBox["\[PartialD]", "\|01d465"], "\|01d457", "=", "0"}],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "b8831171-ee74-4979-b31f-bf9495bdd5ad"],
 " for ",
 StyleBox["any", "TI"],
 " solution of the free Schrodinger equation. The argument used only the \
equation of motion, so it holds for every state, the soliton and the cusp \
state included."
}], "Text",ExpressionUUID->"7c413d5b-cf7f-4f97-b3c4-f8e59e0d7a80"],

Cell[TextData[{
 "1.7 [BSc] How do I represent a state on a discrete spatial grid so that \
integrals become sums, building the bridge from ",
 Cell[BoxData[
  StyleBox[
   SuperscriptBox["\|01d43f", "2"],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "d65412a3-0f83-40e9-a947-3dd9b52ea315"],
 " to the finite vector a computer can hold?"
}], "Subsection",ExpressionUUID->"c34a7b0e-15ae-4c68-aae0-955f1461bf01"],

Cell[TextData[{
 "Every numerical method replaces ",
 Cell[BoxData[
  StyleBox[
   RowBox[{"\|01d713", 
    StyleBox["(",
     SpanMaxSize->1], "\|01d465", 
    StyleBox[")",
     SpanMaxSize->1]}],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "b2c43e73-bf65-4614-86af-f6cf3d3aa8b4"],
 " by its samples and every integral by a Riemann sum ",
 Cell[BoxData[
  StyleBox[
   RowBox[{
    StyleBox["\[Integral]",
     FontSize->1.7 Inherited], 
    SuperscriptBox[
     RowBox[{
     "\[LeftBracketingBar]", "\|01d713", "\[VeryThinSpace]", 
      "\[RightBracketingBar]"}], "2"], " ", "\|01d451", "\|01d465", "\[TildeTilde]", 
    UnderscriptBox["\[Sum]", "\|01d45b",
     LimitsPositioning->False], 
    SuperscriptBox[
     RowBox[{"\[LeftBracketingBar]", 
      SubscriptBox["\|01d713", "\|01d45b"], "\[RightBracketingBar]"}], "2"], " ",
     "\[CapitalDelta]", "\|01d465"}],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "ef6710f3-dcd9-4a5e-a60f-6b08ae26185b"],
 ". We test it on the cusp state, whose kink at the origin is exactly the \
feature a grid must resolve."
}], "Text",ExpressionUUID->"ad9a7707-d7ef-493d-8973-610dbb140833"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"\[Psi]", "[", "x_", "]"}], " ", ":=", " ", 
   RowBox[{
    RowBox[{"Sqrt", "[", "\[Kappa]", "]"}], " ", 
    RowBox[{"Exp", "[", 
     RowBox[{
      RowBox[{"-", "\[Kappa]"}], " ", 
      RowBox[{"Abs", "[", "x", "]"}]}], "]"}]}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"grid", " ", "=", " ", 
   RowBox[{"Subdivide", "[", 
    RowBox[{
     RowBox[{"-", "12."}], ",", " ", "12.", ",", " ", "6000"}], "]"}]}], ";", 
  " ", 
  RowBox[{"dx", " ", "=", " ", 
   RowBox[{
    RowBox[{"grid", "[", 
     RowBox[{"[", "2", "]"}], "]"}], " ", "-", " ", 
    RowBox[{"grid", "[", 
     RowBox[{"[", "1", "]"}], "]"}]}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"Total", "[", 
   RowBox[{
    RowBox[{"Abs", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"(", 
        RowBox[{
         RowBox[{"\[Psi]", "[", "#", "]"}], " ", "/.", " ", 
         RowBox[{"\[Kappa]", " ", "->", " ", "1."}]}], ")"}], " ", "&"}], " ",
       "/@", " ", "grid"}], "]"}], "^", "2"}], "]"}], " ", "dx"}]}], "Input",
 CellLabel->"In[9]:= ",ExpressionUUID->"1df9ebff-521b-41d4-8088-2f3bd35fc584"],

Cell[TextData[{
 "The sum returns ",
 Cell[BoxData[
  StyleBox[
   RowBox[{"1.0000", "\[Ellipsis]"}],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "8c46e2f2-6e96-4521-9465-6797bcc9aef4"],
 ", converging to the exact norm as the grid is refined. The cusp costs a \
little accuracy near ",
 Cell[BoxData[
  StyleBox[
   RowBox[{"\|01d465", "=", "0"}],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "a3deff3c-3613-4266-ada4-b7dbdf19afd3"],
 " (the density is not smooth there), which is why a state with a \
point-interaction kink is a more honest numerical test than a smooth \
Gaussian. Every later numerical Part (eigenvalues by ",
 Cell[BoxData["NDEigensystem"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "36777249-3875-4b3a-82e6-14d7c269395a"],
 ", propagation by split-step) rests on this sampling."
}], "Text",ExpressionUUID->"8365f402-1c8e-43fb-8212-f0b4cebcf757"],

Cell[TextData[{
 "1.8 [BSc] How do I show that an overall constant phase is unobservable, \
while the local phase gradient ",
 Cell[BoxData[
  StyleBox[
   RowBox[{
    SubscriptBox["\[PartialD]", "\|01d465"], 
    StyleBox["arg",
     FontSlant->"Plain"], "\[ThinSpace]", "\|01d713"}],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "768926d1-1437-4b07-bc0b-4404dc0dead5"],
 " carries the current (the velocity field)?"
}], "Subsection",ExpressionUUID->"0e9ebbe3-3b3e-4d2c-9a1d-d122c237171f"],

Cell[TextData[{
 "A global phase ",
 Cell[BoxData[
  StyleBox[
   SuperscriptBox["\|01d452", 
    RowBox[{"\|01d456", "\|01d6fc"}]],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "96d89e60-c5c4-4c3e-acc9-866d1c079e64"],
 " cancels in ",
 Cell[BoxData[
  StyleBox[
   SuperscriptBox[
    RowBox[{
    "\[LeftBracketingBar]", "\|01d713", "\[VeryThinSpace]", 
     "\[RightBracketingBar]"}], "2"],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "94b61786-1940-4225-b16e-07789cb53224"],
 " and every expectation value, so it is pure gauge. A ",
 StyleBox["position-dependent", "TI"],
 " phase is physical: its gradient is the local velocity ",
 Cell[BoxData[
  StyleBox[
   RowBox[{"\|01d463", "=", "\|01d457", "/", 
    SuperscriptBox[
     RowBox[{
     "\[LeftBracketingBar]", "\|01d713", "\[VeryThinSpace]", 
      "\[RightBracketingBar]"}], "2"]}],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "1db61f90-3392-4797-89a7-acffc2c3aa8c"],
 ". We take a chirped soliton ",
 Cell[BoxData[
  StyleBox[
   RowBox[{"\|01d713", "=", 
    FractionBox["1", 
     SqrtBox["2"]], 
    StyleBox["sech",
     FontSlant->"Plain"], 
    StyleBox["(",
     SpanMaxSize->1], "\|01d465", 
    StyleBox[")",
     SpanMaxSize->1], " ", 
    SuperscriptBox["\|01d452", 
     RowBox[{"\|01d456", "\|01d6fd", 
      SuperscriptBox["\|01d465", "2"]}]]}],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "4fc0dc41-aa6e-4965-9af5-900516d456ad"],
 ", whose phase ",
 Cell[BoxData[
  StyleBox[
   RowBox[{"\|01d446", 
    StyleBox["(",
     SpanMaxSize->1], "\|01d465", 
    StyleBox[")",
     SpanMaxSize->1], "=", "\|01d6fd", 
    SuperscriptBox["\|01d465", "2"]}],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "affd2907-5adf-4d05-8ecb-bce08a98e3da"],
 " varies across the packet."
}], "Text",ExpressionUUID->"dacd5633-ace9-480f-a498-17c9dfa5f678"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"\[Psi]", "[", "x_", "]"}], " ", ":=", " ", 
   RowBox[{
    RowBox[{"Sech", "[", "x", "]"}], " ", 
    RowBox[{
     RowBox[{"Exp", "[", 
      RowBox[{"I", " ", "\[Beta]", " ", 
       RowBox[{"x", "^", "2"}]}], "]"}], "/", 
     RowBox[{"Sqrt", "[", "2", "]"}]}]}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"\[Psi]c", "[", "x_", "]"}], " ", ":=", " ", 
   RowBox[{
    RowBox[{"Sech", "[", "x", "]"}], " ", 
    RowBox[{
     RowBox[{"Exp", "[", 
      RowBox[{
       RowBox[{"-", "I"}], " ", "\[Beta]", " ", 
       RowBox[{"x", "^", "2"}]}], "]"}], "/", 
     RowBox[{"Sqrt", "[", "2", "]"}]}]}]}], ";"}], "\n", 
 RowBox[{"Simplify", "[", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"Abs", "[", 
      RowBox[{
       RowBox[{"Exp", "[", 
        RowBox[{"I", " ", "\[Alpha]"}], "]"}], " ", 
       RowBox[{"\[Psi]", "[", "x", "]"}]}], "]"}], "^", "2"}], " ", "-", " ", 
    
    RowBox[{
     RowBox[{"Abs", "[", 
      RowBox[{"\[Psi]", "[", "x", "]"}], "]"}], "^", "2"}]}], ",", " ", 
   RowBox[{"Element", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"\[Alpha]", ",", " ", "\[Beta]", ",", " ", "x"}], "}"}], ",", 
     " ", "Reals"}], "]"}]}], "]"}]}], "Input",
 CellLabel->
  "In[10]:= ",ExpressionUUID->"585d5690-19b8-41db-9318-393858c801ab"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"j", " ", "=", " ", 
   RowBox[{"Simplify", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"(", 
       RowBox[{
        RowBox[{
         RowBox[{"\[Psi]c", "[", "x", "]"}], " ", 
         RowBox[{"D", "[", 
          RowBox[{
           RowBox[{"\[Psi]", "[", "x", "]"}], ",", " ", "x"}], "]"}]}], " ", "-",
         " ", 
        RowBox[{
         RowBox[{"\[Psi]", "[", "x", "]"}], " ", 
         RowBox[{"D", "[", 
          RowBox[{
           RowBox[{"\[Psi]c", "[", "x", "]"}], ",", " ", "x"}], "]"}]}]}], 
       ")"}], "/", 
      RowBox[{"(", 
       RowBox[{"2", " ", "I"}], ")"}]}], ",", " ", 
     RowBox[{"Element", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"\[Beta]", ",", " ", "x"}], "}"}], ",", " ", "Reals"}], 
      "]"}]}], "]"}]}], ";"}], "\n", 
 RowBox[{"Simplify", "[", 
  RowBox[{
   RowBox[{"j", "/", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"\[Psi]c", "[", "x", "]"}], " ", 
      RowBox[{"\[Psi]", "[", "x", "]"}]}], ")"}]}], ",", " ", 
   RowBox[{"Element", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"\[Beta]", ",", " ", "x"}], "}"}], ",", " ", "Reals"}], "]"}]}],
   "]"}]}], "Input",
 CellLabel->
  "In[11]:= ",ExpressionUUID->"ac1af5b9-5bbd-4caf-b61c-83d046024cf6"],

Cell[TextData[{
 "The first cell returns ",
 Cell[BoxData[
  StyleBox["0",
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "e2971ff3-95ba-4c82-8a63-498863097e73"],
 ": the global phase changes nothing. The velocity field is ",
 Cell[BoxData[
  StyleBox[
   RowBox[{"\|01d463", 
    StyleBox["(",
     SpanMaxSize->1], "\|01d465", 
    StyleBox[")",
     SpanMaxSize->1], "=", "\|01d457", "/", 
    SuperscriptBox[
     RowBox[{
     "\[LeftBracketingBar]", "\|01d713", "\[VeryThinSpace]", 
      "\[RightBracketingBar]"}], "2"], "=", "2", "\|01d6fd", "\|01d465", "=", 
    
    SubscriptBox["\[PartialD]", "\|01d465"], 
    StyleBox["(",
     SpanMaxSize->1], 
    RowBox[{"\|01d6fd", 
     SuperscriptBox["\|01d465", "2"]}], 
    StyleBox[")",
     SpanMaxSize->1]}],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "fae90928-9027-4249-a8c7-5a63f6c2adb7"],
 ", the slope of the local phase. Unlike a plain plane-wave phase ",
 Cell[BoxData[
  StyleBox[
   RowBox[{"\|01d458", "\|01d465"}],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "2a066c7b-f264-45fc-8549-bb4e9daa08ee"],
 " (uniform flow), the chirp gives a position-dependent velocity, an outflow \
that grows linearly with ",
 Cell[BoxData[
  StyleBox["\|01d465",
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "bb5f8694-17bb-468e-b206-c4299bb90be3"],
 ": this is exactly the phase profile that makes a free packet spread."
}], "Text",ExpressionUUID->"20c8a45d-7471-4e30-8dcc-61ffcc1cd6ce"],

Cell[TextData[{
 "1.9 [BSc] How does a Galilean boost transform a wave packet (the boost \
phase factor), and why is ",
 Cell[BoxData[
  StyleBox[
   SuperscriptBox[
    RowBox[{"\[LeftBracketingBar]", 
     RowBox[{"\|01d713", 
      StyleBox["(",
       SpanMaxSize->1], "\|01d465", 
      StyleBox[")",
       SpanMaxSize->1]}], "\[RightBracketingBar]"}], "2"],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "c1d6a711-31aa-40cf-bf0e-27a2af9cfcf0"],
 " unchanged in shape?"
}], "Subsection",ExpressionUUID->"eefa374f-075c-4837-a2ab-4eee1503c2dc"],

Cell[TextData[{
 "Viewing a state from a frame moving at velocity ",
 Cell[BoxData[
  StyleBox["\|01d463",
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "0e3ccdc0-bdc4-49a7-9a3e-60c5dd952f2c"],
 " multiplies it by the boost phase ",
 Cell[BoxData[
  StyleBox[
   SuperscriptBox["\|01d452", 
    RowBox[{"\|01d456", 
     StyleBox["(",
      SpanMaxSize->1], 
     RowBox[{"\|01d463", "\|01d465", "-", 
      SuperscriptBox["\|01d463", "2"], "\|01d461", "/", "2"}], 
     StyleBox[")",
      SpanMaxSize->1]}]],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "fecd1799-c641-4db3-8f8d-35146dc40bc9"],
 " (with ",
 Cell[BoxData[
  StyleBox[
   RowBox[{"\|01d45a", "=", "1"}],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "b0215d25-6a9c-4404-acbd-03ccbaed3fee"],
 ") and translates its argument: ",
 Cell[BoxData[
  StyleBox[
   RowBox[{
    SubscriptBox["\|01d713", "\|01d463"], 
    StyleBox["(",
     SpanMaxSize->1], 
    RowBox[{"\|01d465", ",", "\|01d461"}], 
    StyleBox[")",
     SpanMaxSize->1], "=", 
    SuperscriptBox["\|01d452", 
     RowBox[{"\|01d456", 
      StyleBox["(",
       SpanMaxSize->1], 
      RowBox[{"\|01d463", "\|01d465", "-", 
       SuperscriptBox["\|01d463", "2"], "\|01d461", "/", "2"}], 
      StyleBox[")",
       SpanMaxSize->1]}]], " ", "\|01d713", 
    StyleBox["(",
     SpanMaxSize->1], 
    RowBox[{
     RowBox[{"\|01d465", "-", "\|01d463", "\|01d461"}], ",", "\|01d461"}], 
    StyleBox[")",
     SpanMaxSize->1]}],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "ce32c2b5-9d7b-44b4-95d1-537de2d05007"],
 ". We apply it to the soliton."
}], "Text",ExpressionUUID->"415bc5b0-3e61-4801-a567-c28571852bf0"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"boost", " ", "=", " ", 
   RowBox[{"Exp", "[", 
    RowBox[{"I", " ", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{"v", " ", "x"}], " ", "-", " ", 
       RowBox[{
        RowBox[{"v", "^", "2"}], " ", 
        RowBox[{"t", "/", "2"}]}]}], ")"}]}], "]"}]}], ";"}], "\n", 
 RowBox[{"Simplify", "[", 
  RowBox[{
   RowBox[{
    RowBox[{"Abs", "[", "boost", "]"}], "^", "2"}], ",", " ", 
   RowBox[{"Element", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"v", ",", " ", "x", ",", " ", "t"}], "}"}], ",", " ", "Reals"}],
     "]"}]}], "]"}]}], "Input",
 CellLabel->
  "In[12]:= ",ExpressionUUID->"aa546c94-0664-4c93-b6de-e6f07f6facc7"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"\[Psi]sol", "[", "x_", "]"}], " ", ":=", " ", 
   RowBox[{
    RowBox[{"Sech", "[", "x", "]"}], "/", 
    RowBox[{"Sqrt", "[", "2", "]"}]}]}], ";"}], "\n", 
 RowBox[{"Simplify", "[", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"Abs", "[", 
      RowBox[{"boost", " ", 
       RowBox[{"\[Psi]sol", "[", 
        RowBox[{"x", " ", "-", " ", 
         RowBox[{"v", " ", "t"}]}], "]"}]}], "]"}], "^", "2"}], " ", "-", " ", 
    RowBox[{
     RowBox[{"Abs", "[", 
      RowBox[{"\[Psi]sol", "[", 
       RowBox[{"x", " ", "-", " ", 
        RowBox[{"v", " ", "t"}]}], "]"}], "]"}], "^", "2"}]}], ",", " ", 
   RowBox[{"Element", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"v", ",", " ", "x", ",", " ", "t"}], "}"}], ",", " ", "Reals"}],
     "]"}]}], "]"}]}], "Input",
 CellLabel->
  "In[13]:= ",ExpressionUUID->"b14facb4-2721-417a-b1d1-0ce5490cc51c"],

Cell[TextData[{
 "The boost factor has unit modulus, so ",
 Cell[BoxData[
  StyleBox[
   RowBox[{
    SuperscriptBox[
     RowBox[{"\[LeftBracketingBar]", 
      RowBox[{
       SubscriptBox["\|01d713", "\|01d463"], 
       StyleBox["(",
        SpanMaxSize->1], 
       RowBox[{"\|01d465", ",", "\|01d461"}], 
       StyleBox[")",
        SpanMaxSize->1]}], "\[RightBracketingBar]"}], "2"], "=", 
    SuperscriptBox[
     RowBox[{"\[LeftBracketingBar]", 
      RowBox[{"\|01d713", 
       StyleBox["(",
        SpanMaxSize->1], 
       RowBox[{
        RowBox[{"\|01d465", "-", "\|01d463", "\|01d461"}], ",", "\|01d461"}], 
       
       StyleBox[")",
        SpanMaxSize->1]}], "\[RightBracketingBar]"}], "2"]}],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "10c0d4b1-8915-4cc1-ad62-5bb2b1bdf3fb"],
 ": the soliton is carried along rigidly at speed ",
 Cell[BoxData[
  StyleBox["\|01d463",
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "f5805b35-0003-4c8e-8666-bf1e36596989"],
 ", its ",
 Cell[BoxData[
  StyleBox[
   SuperscriptBox[
    StyleBox["sech",
     FontSlant->"Plain"], "2"],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "62ba6efe-51d1-4bc3-b897-92ba398e88f5"],
 " shape untouched. The boost lives entirely in the phase, invisible to a \
position measurement yet adding ",
 Cell[BoxData[
  StyleBox["\|01d463",
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "57ae0ce3-7443-4278-8538-1ae059ade47d"],
 " to every momentum component, the hallmark of a soliton that translates \
without distortion."
}], "Text",ExpressionUUID->"9578c6bc-3e4f-4900-b06c-7e519e0c308c"],

Cell["\<\
Part 2. Operators, position and momentum, and the Fourier bridge\
\>", "Section",ExpressionUUID->"1079afb3-93d8-489f-ad66-2e53e38c0f03"],

Cell[TextData[{
 "2.1 [BSc] How do I represent the position operator ",
 Cell[BoxData[
  StyleBox[
   OverscriptBox["\|01d465", "^"],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "07199707-90d6-44ae-9917-ace8a98a8cc8"],
 " as multiplication and the momentum operator ",
 Cell[BoxData[
  StyleBox[
   RowBox[{
    OverscriptBox["\|01d45d", "^"], "=", "-", "\|01d456", " ", "\|01d451", "/",
     "\|01d451", "\|01d465"}],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "3ea15a87-13fa-45fe-bed2-0341ef95be93"],
 " as differentiation, acting on a test function?"
}], "Subsection",ExpressionUUID->"4201dc61-2a7e-4120-82a0-e22735555919"],

Cell[TextData[{
 "In the position representation ",
 Cell[BoxData[
  StyleBox[
   OverscriptBox["\|01d465", "^"],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "663ac320-69ad-4c5e-8798-cc62029c92eb"],
 " multiplies by ",
 Cell[BoxData[
  StyleBox["\|01d465",
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "bcf99903-dd7f-4831-8fbe-e45014673ccc"],
 " and ",
 Cell[BoxData[
  StyleBox[
   OverscriptBox["\|01d45d", "^"],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "22b631d4-9b63-4dd3-845e-ac6080cec552"],
 " differentiates. We define them as operations and apply them to a plane \
wave."
}], "Text",ExpressionUUID->"79ec590c-afca-49d0-bafe-923c1a360cb9"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"xop", "[", "f_", "]"}], " ", ":=", " ", 
   RowBox[{"x", " ", "f"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"pop", "[", "f_", "]"}], " ", ":=", " ", 
   RowBox[{
    RowBox[{"-", "I"}], " ", 
    RowBox[{"D", "[", 
     RowBox[{"f", ",", " ", "x"}], "]"}]}]}], ";"}], "\n", 
 RowBox[{"{", 
  RowBox[{
   RowBox[{"xop", "[", 
    RowBox[{"Exp", "[", 
     RowBox[{"I", " ", "k", " ", "x"}], "]"}], "]"}], ",", " ", 
   RowBox[{"pop", "[", 
    RowBox[{"Exp", "[", 
     RowBox[{"I", " ", "k", " ", "x"}], "]"}], "]"}]}], "}"}]}], "Input",
 CellLabel->
  "In[14]:= ",ExpressionUUID->"fbdec02e-da11-4717-a51b-62ca8c207b2b"],

Cell[TextData[{
 Cell[BoxData[
  StyleBox[
   OverscriptBox["\|01d465", "^"],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "0364de4b-2377-48be-8468-505a0232031b"],
 " returns ",
 Cell[BoxData[
  StyleBox[
   RowBox[{"\|01d465", " ", 
    SuperscriptBox["\|01d452", 
     RowBox[{"\|01d456", "\|01d458", "\|01d465"}]]}],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "6c11ef6b-41ff-4718-ae28-ec99103ddf58"],
 " and ",
 Cell[BoxData[
  StyleBox[
   OverscriptBox["\|01d45d", "^"],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "0a0891fc-6eab-49a2-b959-9b135917d7c6"],
 " returns ",
 Cell[BoxData[
  StyleBox[
   RowBox[{"\|01d458", " ", 
    SuperscriptBox["\|01d452", 
     RowBox[{"\|01d456", "\|01d458", "\|01d465"}]]}],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "64047e27-dfb8-4934-96d4-4450d49a5e26"],
 ": the plane wave is an eigenfunction of momentum with eigenvalue ",
 Cell[BoxData[
  StyleBox["\|01d458",
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "58ec3949-33b0-49c7-ab1f-0d33b5e1b776"],
 ". That is the precise sense in which ",
 Cell[BoxData[
  StyleBox[
   SuperscriptBox["\|01d452", 
    RowBox[{"\|01d456", "\|01d458", "\|01d465"}]],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "00e2bd1f-06e2-4e29-9713-2afffc49acd5"],
 " carries momentum ",
 Cell[BoxData[
  StyleBox["\|01d458",
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "46704403-0ae2-43f6-81ed-ec80eeac1c50"],
 "."
}], "Text",ExpressionUUID->"1b60fe34-a38c-4937-a32e-6402212f320c"],

Cell[TextData[{
 "2.2 [BSc] How do I verify the canonical commutator ",
 Cell[BoxData[
  StyleBox[
   RowBox[{
    StyleBox["[",
     SpanMaxSize->1], 
    RowBox[{
     OverscriptBox["\|01d465", "^"], ",", 
     OverscriptBox["\|01d45d", "^"]}], 
    StyleBox["]",
     SpanMaxSize->1], "=", "\|01d456"}],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "6ab521bd-6828-463d-bfbf-03bbd8802449"],
 " by letting it act on an arbitrary function?"
}], "Subsection",ExpressionUUID->"c0a4104b-c1c1-45e5-b662-1d8a6c857a78"],

Cell[TextData[{
 "The defining relation ",
 Cell[BoxData[
  StyleBox[
   RowBox[{
    StyleBox["[",
     SpanMaxSize->1], 
    RowBox[{
     OverscriptBox["\|01d465", "^"], ",", 
     OverscriptBox["\|01d45d", "^"]}], 
    StyleBox["]",
     SpanMaxSize->1], "=", "\|01d456"}],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "677511db-ed84-4594-a2c4-bfcb108bbd03"],
 " is an operator identity, so we check it on a generic test function ",
 Cell[BoxData[
  StyleBox[
   RowBox[{"\|01d453", 
    StyleBox["(",
     SpanMaxSize->1], "\|01d465", 
    StyleBox[")",
     SpanMaxSize->1]}],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "39820464-81f6-470b-a7a3-b21dc8ef40df"],
 "."
}], "Text",ExpressionUUID->"cbc9b1a2-085a-4f5f-8f25-1056ed9518d8"],

Cell[BoxData[
 RowBox[{"Simplify", "[", 
  RowBox[{
   RowBox[{"xop", "[", 
    RowBox[{"pop", "[", 
     RowBox[{"f", "[", "x", "]"}], "]"}], "]"}], " ", "-", " ", 
   RowBox[{"pop", "[", 
    RowBox[{"xop", "[", 
     RowBox[{"f", "[", "x", "]"}], "]"}], "]"}]}], "]"}]], "Input",
 CellLabel->
  "In[15]:= ",ExpressionUUID->"8749d31a-2d65-4078-ba26-32de979ce7f7"],

Cell[TextData[{
 "The result is ",
 Cell[BoxData[
  StyleBox[
   RowBox[{"\|01d456", " ", "\|01d453", 
    StyleBox["(",
     SpanMaxSize->1], "\|01d465", 
    StyleBox[")",
     SpanMaxSize->1]}],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "e5bbd398-fa86-45e7-a8c6-aacf1789083d"],
 " for arbitrary ",
 Cell[BoxData[
  StyleBox["\|01d453",
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "fcd92826-aa95-48b9-bb94-d83b27f9e34e"],
 ", i.e. ",
 Cell[BoxData[
  StyleBox[
   RowBox[{
    StyleBox["[",
     SpanMaxSize->1], 
    RowBox[{
     OverscriptBox["\|01d465", "^"], ",", 
     OverscriptBox["\|01d45d", "^"]}], 
    StyleBox["]",
     SpanMaxSize->1], "=", "\|01d456"}],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "27056330-6bd6-47fe-9ab5-b24e4e00cd8e"],
 ". The surviving term comes from differentiating the product ",
 Cell[BoxData[
  StyleBox[
   RowBox[{"\|01d465", "\|01d453"}],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "90f8f565-9f02-4dd9-8740-14ddfc7d180a"],
 ": position and momentum fail to commute by exactly one unit."
}], "Text",ExpressionUUID->"9c422a5f-ff5d-44ed-ba69-1f5db3724869"],

Cell[TextData[{
 "2.3 [BSc] How do I compute the momentum expectation ",
 Cell[BoxData[
  StyleBox[
   RowBox[{
    StyleBox["\[LeftAngleBracket]",
     SpanMaxSize->1], "\|01d45d", "\[VeryThinSpace]", 
    StyleBox["\[RightAngleBracket]",
     SpanMaxSize->1]}],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "11ca5a7b-a7b4-429a-b1da-2706309b8b53"],
 " and spread ",
 Cell[BoxData[
  StyleBox[
   RowBox[{"\[CapitalDelta]", "\|01d45d"}],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "d78a0415-d8d1-4f0b-b45a-d03392ac5712"],
 " in the position representation?"
}], "Subsection",ExpressionUUID->"45678ee7-ebbf-428d-9c43-6352b24cb861"],

Cell[TextData[{
 "Without leaving position space, ",
 Cell[BoxData[
  StyleBox[
   RowBox[{
    StyleBox["\[LeftAngleBracket]",
     SpanMaxSize->1], "\|01d45d", "\[VeryThinSpace]", 
    StyleBox["\[RightAngleBracket]",
     SpanMaxSize->1], "=", 
    StyleBox["\[Integral]",
     FontSize->1.7 Inherited], 
    SuperscriptBox["\|01d713", "*"], 
    StyleBox["(",
     SpanMaxSize->1], 
    RowBox[{"-", "\|01d456", 
     SubscriptBox["\[PartialD]", "\|01d465"]}], 
    StyleBox[")",
     SpanMaxSize->1], "\|01d713", " ", "\|01d451", "\|01d465"}],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "c233d02c-b627-4359-9804-adf64184d8e4"],
 ". For ",
 Cell[BoxData[
  StyleBox[
   RowBox[{
    StyleBox["\[LeftAngleBracket]",
     SpanMaxSize->1], 
    SuperscriptBox["\|01d45d", "2"], 
    StyleBox["\[RightAngleBracket]",
     SpanMaxSize->1]}],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "1bc7e950-5644-4057-ad46-ca977e9d2713"],
 " we use the manifestly positive, boundary-term-free form ",
 Cell[BoxData[
  StyleBox[
   RowBox[{
    StyleBox["\[LeftAngleBracket]",
     SpanMaxSize->1], 
    SuperscriptBox["\|01d45d", "2"], 
    StyleBox["\[RightAngleBracket]",
     SpanMaxSize->1], "=", 
    StyleBox["\[Integral]",
     FontSize->1.7 Inherited], 
    SuperscriptBox[
     RowBox[{"\[LeftBracketingBar]", 
      RowBox[{
       OverscriptBox["\|01d45d", "^"], "\|01d713"}], "\[VeryThinSpace]", 
      "\[RightBracketingBar]"}], "2"], " ", "\|01d451", "\|01d465", "=", 
    StyleBox["\[Integral]",
     FontSize->1.7 Inherited], 
    SuperscriptBox[
     RowBox[{"\[LeftBracketingBar]", 
      RowBox[{
       SubscriptBox["\[PartialD]", "\|01d465"], "\|01d713"}], 
      "\[VeryThinSpace]", "\[RightBracketingBar]"}], "2"], " ", "\|01d451", 
    "\|01d465"}],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "382c257e-8bbf-432d-bd70-9aeba03d996c"],
 " (equal because ",
 Cell[BoxData[
  StyleBox[
   OverscriptBox["\|01d45d", "^"],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "94129765-1a43-44c3-9c2b-a2ac72845e5e"],
 " is Hermitian), which sidesteps the delta that the cusp would put into ",
 Cell[BoxData[
  StyleBox[
   RowBox[{
    SubsuperscriptBox["\[PartialD]", "\|01d465", "2"], "\|01d713"}],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "f2836f52-fb26-4603-bd62-bab6ea237b10"],
 ". We take the moving cusp state ",
 Cell[BoxData[
  StyleBox[
   RowBox[{"\|01d713", "=", 
    SqrtBox["\|01d705"], " ", 
    SuperscriptBox["\|01d452", 
     RowBox[{
     "-", "\|01d705", "\[LeftBracketingBar]", "\|01d465", "\[VeryThinSpace]", 
      "\[RightBracketingBar]"}]], 
    SuperscriptBox["\|01d452", 
     RowBox[{"\|01d456", "\|01d458", "\|01d465"}]]}],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "6c2b0e75-4945-46fd-9879-0dd236b8f7d8"],
 "."
}], "Text",ExpressionUUID->"5f0ae488-a665-4590-b02c-7117a8cac6f9"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"\[Psi]", "[", "x_", "]"}], " ", ":=", " ", 
   RowBox[{
    RowBox[{"Sqrt", "[", "\[Kappa]", "]"}], " ", 
    RowBox[{"Exp", "[", 
     RowBox[{
      RowBox[{"-", "\[Kappa]"}], " ", 
      RowBox[{"Abs", "[", "x", "]"}]}], "]"}], " ", 
    RowBox[{"Exp", "[", 
     RowBox[{"I", " ", "k", " ", "x"}], "]"}]}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"mp", " ", "=", " ", 
   RowBox[{"Integrate", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"Conjugate", "[", 
       RowBox[{"\[Psi]", "[", "x", "]"}], "]"}], " ", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{"-", "I"}], " ", 
        RowBox[{"D", "[", 
         RowBox[{
          RowBox[{"\[Psi]", "[", "x", "]"}], ",", " ", "x"}], "]"}]}], 
       ")"}]}], ",", " ", 
     RowBox[{"{", 
      RowBox[{"x", ",", " ", 
       RowBox[{"-", "Infinity"}], ",", " ", "Infinity"}], "}"}], ",", " ", 
     RowBox[{"Assumptions", " ", "->", " ", 
      RowBox[{
       RowBox[{"\[Kappa]", " ", ">", " ", "0"}], " ", "&&", " ", 
       RowBox[{"k", " ", "\[Element]", " ", "Reals"}]}]}]}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"p2", " ", "=", " ", 
   RowBox[{"Integrate", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"Abs", "[", 
       RowBox[{"D", "[", 
        RowBox[{
         RowBox[{"\[Psi]", "[", "x", "]"}], ",", " ", "x"}], "]"}], "]"}], "^",
       "2"}], ",", " ", 
     RowBox[{"{", 
      RowBox[{"x", ",", " ", 
       RowBox[{"-", "Infinity"}], ",", " ", "Infinity"}], "}"}], ",", " ", 
     RowBox[{"Assumptions", " ", "->", " ", 
      RowBox[{
       RowBox[{"\[Kappa]", " ", ">", " ", "0"}], " ", "&&", " ", 
       RowBox[{"k", " ", "\[Element]", " ", "Reals"}]}]}]}], "]"}]}], ";"}], "\n", 
 RowBox[{"{", 
  RowBox[{
   RowBox[{"Simplify", "[", 
    RowBox[{"mp", ",", " ", 
     RowBox[{
      RowBox[{"\[Kappa]", " ", ">", " ", "0"}], " ", "&&", " ", 
      RowBox[{"k", " ", "\[Element]", " ", "Reals"}]}]}], "]"}], ",", " ", 
   RowBox[{"Simplify", "[", 
    RowBox[{
     RowBox[{"Sqrt", "[", 
      RowBox[{"p2", " ", "-", " ", 
       RowBox[{"mp", "^", "2"}]}], "]"}], ",", " ", 
     RowBox[{
      RowBox[{"\[Kappa]", " ", ">", " ", "0"}], " ", "&&", " ", 
      RowBox[{"k", " ", "\[Element]", " ", "Reals"}]}]}], "]"}]}], 
  "}"}]}], "Input",
 CellLabel->
  "In[16]:= ",ExpressionUUID->"79a2ad54-890b-4196-a932-404565b615e6"],

Cell[TextData[{
 "The mean momentum is ",
 Cell[BoxData[
  StyleBox[
   RowBox[{
    StyleBox["\[LeftAngleBracket]",
     SpanMaxSize->1], "\|01d45d", "\[VeryThinSpace]", 
    StyleBox["\[RightAngleBracket]",
     SpanMaxSize->1], "=", "\|01d458"}],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "0b0b68ee-ebb0-4c5a-ac7e-524c81de7b80"],
 " (the drift stamped into the phase), while ",
 Cell[BoxData[
  StyleBox[
   RowBox[{
    StyleBox["\[LeftAngleBracket]",
     SpanMaxSize->1], 
    SuperscriptBox["\|01d45d", "2"], 
    StyleBox["\[RightAngleBracket]",
     SpanMaxSize->1], "=", 
    SuperscriptBox["\|01d458", "2"], "+", 
    SuperscriptBox["\|01d705", "2"]}],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "84b0e581-c5d3-4eee-863c-b839c5d2e72a"],
 ", so the intrinsic spread is ",
 Cell[BoxData[
  StyleBox[
   RowBox[{"\[CapitalDelta]", "\|01d45d", "=", "\|01d705"}],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "88c02a1e-50b0-4c85-98d7-8c3c23b4a0d9"],
 ". The cusp sets the momentum width: a more sharply bound state (larger ",
 Cell[BoxData[
  StyleBox["\|01d705",
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "f8fc8b87-8c7a-4e78-992d-4e94f2a69ad8"],
 ") is broader in momentum, the uncertainty relation at work."
}], "Text",ExpressionUUID->"d8f8563a-7802-445a-8c82-a082e9454407"],

Cell[TextData[{
 "2.4 [BSc] How do I show that ",
 Cell[BoxData[
  StyleBox[
   OverscriptBox["\|01d45d", "^"],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "84d41ceb-1498-4ff2-97d5-b95304478f51"],
 " is Hermitian by integration by parts, and see that the boundary terms \
vanish for an ",
 Cell[BoxData[
  StyleBox[
   SuperscriptBox["\|01d43f", "2"],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "954cbde5-5887-4d90-9e06-3c07faca5384"],
 " state?"
}], "Subsection",ExpressionUUID->"52fef10e-edd4-4a04-aa76-985252332cd0"],

Cell[TextData[{
 "Hermiticity of ",
 Cell[BoxData[
  StyleBox[
   OverscriptBox["\|01d45d", "^"],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "38eeb15d-8dcb-48c2-bf65-6c9462ea8306"],
 " is ",
 Cell[BoxData[
  StyleBox[
   RowBox[{
    TemplateBox[{
      StyleBox["\[Phi]"], 
      RowBox[{
        OverscriptBox[
         StyleBox["\|01d45d"], "^"], 
        StyleBox["\|01d712"]}]},
     "BraKet"], "=", 
    TemplateBox[{
      RowBox[{
        OverscriptBox[
         StyleBox["\|01d45d"], "^"], 
        StyleBox["\[Phi]"]}], 
      StyleBox["\|01d712"]},
     "BraKet"]}],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "8c8dc318-1e27-4535-8259-449993482881"],
 ", which integration by parts turns into the boundary term ",
 Cell[BoxData[
  StyleBox[
   RowBox[{"-", "\|01d456", 
    SubsuperscriptBox[" ", 
     RowBox[{"-", "\[Infinity]"}], "\[Infinity]"]}],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "937979aa-fc54-46bd-932d-212071b81c5b"],
 ": the matrix-element difference ",
 StyleBox["equals", "TI"],
 " that surface term. We take two smooth solitons; their momentum matrix \
elements have no elementary closed form, so we read off the surface term \
symbolically and confirm the equality by quadrature."
}], "Text",ExpressionUUID->"939670ce-fa3e-4caa-9e39-547a29f27d82"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"\[Phi]", "[", "x_", "]"}], " ", ":=", " ", 
   RowBox[{
    RowBox[{"Sech", "[", "x", "]"}], "/", 
    RowBox[{"Sqrt", "[", "2", "]"}]}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"\[Chi]", "[", "x_", "]"}], " ", ":=", " ", 
   RowBox[{
    RowBox[{"Sech", "[", 
     RowBox[{"x", " ", "-", " ", "1"}], "]"}], " ", 
    RowBox[{
     RowBox[{"Exp", "[", 
      RowBox[{"I", " ", "x"}], "]"}], "/", 
     RowBox[{"Sqrt", "[", "2", "]"}]}]}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"Limit", "[", 
   RowBox[{
    RowBox[{
     RowBox[{"-", "I"}], " ", 
     RowBox[{"Conjugate", "[", 
      RowBox[{"\[Phi]", "[", "x", "]"}], "]"}], " ", 
     RowBox[{"\[Chi]", "[", "x", "]"}]}], ",", " ", 
    RowBox[{"x", " ", "->", " ", "Infinity"}]}], "]"}], " ", "-", "\n", "  ", 
  
  RowBox[{"Limit", "[", 
   RowBox[{
    RowBox[{
     RowBox[{"-", "I"}], " ", 
     RowBox[{"Conjugate", "[", 
      RowBox[{"\[Phi]", "[", "x", "]"}], "]"}], " ", 
     RowBox[{"\[Chi]", "[", "x", "]"}]}], ",", " ", 
    RowBox[{"x", " ", "->", " ", 
     RowBox[{"-", "Infinity"}]}]}], "]"}]}]}], "Input",
 CellLabel->
  "In[17]:= ",ExpressionUUID->"f7044712-1a22-4ed7-848a-da02f46c8fd1"],

Cell[BoxData[
 RowBox[{"Chop", "[", 
  RowBox[{
   RowBox[{"NIntegrate", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"Conjugate", "[", 
       RowBox[{"\[Phi]", "[", "x", "]"}], "]"}], " ", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{"-", "I"}], " ", 
        RowBox[{"D", "[", 
         RowBox[{
          RowBox[{"\[Chi]", "[", "x", "]"}], ",", " ", "x"}], "]"}]}], 
       ")"}]}], ",", " ", 
     RowBox[{"{", 
      RowBox[{"x", ",", " ", 
       RowBox[{"-", "Infinity"}], ",", " ", "Infinity"}], "}"}], ",", " ", 
     RowBox[{"WorkingPrecision", " ", "->", " ", "30"}]}], "]"}], " ", "-", 
   "\n", "     ", 
   RowBox[{"NIntegrate", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"Conjugate", "[", 
       RowBox[{
        RowBox[{"-", "I"}], " ", 
        RowBox[{"D", "[", 
         RowBox[{
          RowBox[{"\[Phi]", "[", "x", "]"}], ",", " ", "x"}], "]"}]}], "]"}], 
      " ", 
      RowBox[{"\[Chi]", "[", "x", "]"}]}], ",", " ", 
     RowBox[{"{", 
      RowBox[{"x", ",", " ", 
       RowBox[{"-", "Infinity"}], ",", " ", "Infinity"}], "}"}], ",", " ", 
     RowBox[{"WorkingPrecision", " ", "->", " ", "30"}]}], "]"}]}], 
  "]"}]], "Input",
 CellLabel->
  "In[18]:= ",ExpressionUUID->"f622a7c0-6cc4-4549-b941-159c2c70aef7"],

Cell[TextData[{
 "The boundary term is ",
 Cell[BoxData[
  StyleBox["0",
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "6d0ab7df-10ba-4fa8-a967-c8f6535bb660"],
 " (the solitons decay at infinity), and the high-precision quadrature \
returns numerical zero, so the two matrix elements agree. Because the \
difference ",
 StyleBox["is", "TI"],
 " that surface term, Hermiticity of ",
 Cell[BoxData[
  StyleBox[
   OverscriptBox["\|01d45d", "^"],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "47a7ae95-f6bf-471c-88c9-ec3279b649f9"],
 " is exactly its vanishing, a point that turns subtle on a finite domain \
(2.9)."
}], "Text",ExpressionUUID->"10c53397-59ca-4236-8c13-59281cddc568"],

Cell[TextData[{
 "2.5 [BSc] How do I write the momentum eigenfunctions ",
 Cell[BoxData[
  StyleBox[
   SuperscriptBox["\|01d452", 
    RowBox[{"\|01d456", "\|01d45d", "\|01d465"}]],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "b3980509-256d-49a2-82ff-0f78cd8e7aa3"],
 ", see that they are not square-integrable, and normalize them to a Dirac \
delta?"
}], "Subsection",ExpressionUUID->"69bc3532-5012-439c-b4af-13afd91744ff"],

Cell[TextData[{
 "The momentum eigenfunctions ",
 Cell[BoxData[
  StyleBox[
   SuperscriptBox["\|01d452", 
    RowBox[{"\|01d456", "\|01d45d", "\|01d465"}]],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "affa62ad-f025-4c91-a89e-7f694a643932"],
 " are not in ",
 Cell[BoxData[
  StyleBox[
   SuperscriptBox["\|01d43f", "2"],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "c88caca1-da33-49df-9a15-7b4a59e92244"],
 " (1.2), so they cannot be normalized to ",
 Cell[BoxData[
  StyleBox["1",
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "fcf4dda8-2791-458d-a3d8-f941d3441614"],
 "; instead ",
 Cell[BoxData[
  StyleBox[
   RowBox[{
    TemplateBox[{
      SuperscriptBox[
       StyleBox["\|01d45d"], "\[Prime]"], 
      StyleBox["\|01d45d"]},
     "BraKet"], "=", "\|01d6ff", 
    StyleBox["(",
     SpanMaxSize->1], "\|01d45d", "-", 
    SuperscriptBox["\|01d45d", "\[Prime]"], 
    StyleBox[")",
     SpanMaxSize->1]}],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "65c485bf-3615-4701-bc90-5748d526f843"],
 " for ",
 Cell[BoxData[
  StyleBox[
   RowBox[{
    SubscriptBox["\|01d462", "\|01d45d"], 
    StyleBox["(",
     SpanMaxSize->1], "\|01d465", 
    StyleBox[")",
     SpanMaxSize->1], "=", 
    FractionBox["1", 
     SqrtBox[
      RowBox[{"2", "\[Pi]"}]]], 
    SuperscriptBox["\|01d452", 
     RowBox[{"\|01d456", "\|01d45d", "\|01d465"}]]}],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "86f170e2-b636-4d28-aefe-4398d677b101"],
 ". The ",
 Cell[BoxData[
  StyleBox[
   RowBox[{"2", "\[Pi]"}],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "5b8285b9-531e-4171-b5ac-204cc5f2f5dc"],
 " that makes this work is the Fourier integral of a constant."
}], "Text",ExpressionUUID->"784cf581-e5e8-4505-9868-5559f9a2d2bc"],

Cell[BoxData[
 RowBox[{"FourierTransform", "[", 
  RowBox[{"1", ",", " ", "x", ",", " ", "q"}], "]"}]], "Input",
 CellLabel->
  "In[19]:= ",ExpressionUUID->"c376f2b4-8dbf-43ba-b290-35aaaeedc183"],

Cell[BoxData[
 RowBox[{"FourierTransform", "[", 
  RowBox[{
   RowBox[{
    RowBox[{"1", "/", 
     RowBox[{"Sqrt", "[", 
      RowBox[{"2", " ", "Pi"}], "]"}]}], " ", 
    RowBox[{"Exp", "[", 
     RowBox[{"I", " ", "p", " ", "x"}], "]"}]}], ",", " ", "x", ",", " ", 
   "pp", ",", " ", 
   RowBox[{"FourierParameters", " ", "->", " ", 
    RowBox[{"{", 
     RowBox[{"0", ",", " ", 
      RowBox[{"-", "1"}]}], "}"}]}]}], "]"}]], "Input",
 CellLabel->
  "In[20]:= ",ExpressionUUID->"ceab8680-7a56-4f8d-b5d1-2050e5da54c5"],

Cell[TextData[{
 "The first cell gives ",
 Cell[BoxData[
  StyleBox[
   RowBox[{
    SqrtBox[
     RowBox[{"2", "\[Pi]"}]], " ", "\|01d6ff", 
    StyleBox["(",
     SpanMaxSize->1], "\|01d45e", 
    StyleBox[")",
     SpanMaxSize->1]}],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "676960e9-f85a-4095-985b-b70474541de5"],
 ", i.e. ",
 Cell[BoxData[
  StyleBox[
   RowBox[{
    StyleBox["\[Integral]",
     FontSize->1.7 Inherited], 
    SuperscriptBox["\|01d452", 
     RowBox[{"\|01d456", "\|01d45e", "\|01d465"}]], " ", "\|01d451", 
    "\|01d465", "=", "2", "\[Pi]", " ", "\|01d6ff", 
    StyleBox["(",
     SpanMaxSize->1], "\|01d45e", 
    StyleBox[")",
     SpanMaxSize->1]}],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "3a84404f-4689-4032-b781-627c990f3a6c"],
 ". The second transforms the normalized eigenstate ",
 Cell[BoxData[
  StyleBox[
   SubscriptBox["\|01d462", "\|01d45d"],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "195db457-f825-4ccc-ae6d-c98f60f6b0af"],
 " into momentum space and returns exactly ",
 Cell[BoxData[
  StyleBox[
   RowBox[{"\|01d6ff", 
    StyleBox["(",
     SpanMaxSize->1], 
    RowBox[{"\|01d45d", "-", 
     SuperscriptBox["\|01d45d", "\[Prime]"]}], 
    StyleBox[")",
     SpanMaxSize->1]}],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "6cf44670-57ef-403e-b68f-ba170169c0dd"],
 ": a sharp momentum state is a delta spike at its eigenvalue, the continuum \
analog of an orthonormal basis vector."
}], "Text",ExpressionUUID->"ae43f353-69cd-4764-b2f6-9c37623b886f"],

Cell[TextData[{
 "2.6 [BSc] How do I obtain the momentum-space wavefunction ",
 Cell[BoxData[
  StyleBox[
   RowBox[{
    OverscriptBox["\|01d713", "~"], 
    StyleBox["(",
     SpanMaxSize->1], "\|01d45d", 
    StyleBox[")",
     SpanMaxSize->1]}],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "9735d981-25e4-4917-8730-846e196ce1f4"],
 " by Fourier transform and compute ",
 Cell[BoxData[
  StyleBox[
   RowBox[{
    StyleBox["\[LeftAngleBracket]",
     SpanMaxSize->1], 
    SuperscriptBox["\|01d45d", "\|01d45b"], 
    StyleBox["\[RightAngleBracket]",
     SpanMaxSize->1]}],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "74d008f9-1ea2-4e28-a48b-627408edcff6"],
 " as a moment in ",
 Cell[BoxData[
  StyleBox["\|01d45d",
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "f777f461-2d3a-45db-92e3-e60c7f2282f7"],
 "?"
}], "Subsection",ExpressionUUID->"78919765-2be5-47a9-9ca4-e1a16ae3d57a"],

Cell[TextData[{
 "The momentum-space wavefunction is ",
 Cell[BoxData[
  StyleBox[
   RowBox[{
    OverscriptBox["\|01d713", "~"], 
    StyleBox["(",
     SpanMaxSize->1], "\|01d45d", 
    StyleBox[")",
     SpanMaxSize->1], "=", 
    FractionBox["1", 
     SqrtBox[
      RowBox[{"2", "\[Pi]"}]]], 
    StyleBox["\[Integral]",
     FontSize->1.7 Inherited], "\|01d713", 
    StyleBox["(",
     SpanMaxSize->1], "\|01d465", 
    StyleBox[")",
     SpanMaxSize->1], 
    SuperscriptBox["\|01d452", 
     RowBox[{"-", "\|01d456", "\|01d45d", "\|01d465"}]], " ", "\|01d451", 
    "\|01d465"}],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "55bd76e4-1d70-4991-8aa8-9bc5f2f9cb7f"],
 " (",
 Cell[BoxData[
  RowBox[{"FourierParameters", " ", "->", " ", 
   RowBox[{"{", 
    RowBox[{"0", ",", " ", 
     RowBox[{"-", "1"}]}], "}"}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "789bb24a-c807-4205-a3b8-f6b12c44733f"],
 "), after which ",
 Cell[BoxData[
  StyleBox[
   RowBox[{
    StyleBox["\[LeftAngleBracket]",
     SpanMaxSize->1], 
    SuperscriptBox["\|01d45d", "\|01d45b"], 
    StyleBox["\[RightAngleBracket]",
     SpanMaxSize->1], "=", 
    StyleBox["\[Integral]",
     FontSize->1.7 Inherited], 
    SuperscriptBox["\|01d45d", "\|01d45b"], 
    SuperscriptBox[
     RowBox[{"\[LeftBracketingBar]", 
      RowBox[{
       OverscriptBox["\|01d713", "~"], 
       StyleBox["(",
        SpanMaxSize->1], "\|01d45d", 
       StyleBox[")",
        SpanMaxSize->1]}], "\[RightBracketingBar]"}], "2"], " ", "\|01d451", 
    "\|01d45d"}],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "64390e49-a562-40eb-8d7d-f64cf1b12a5c"],
 " is an ordinary moment. We transform the soliton."
}], "Text",ExpressionUUID->"58bd80bf-5c8f-45ab-be5a-d949597ffc5f"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"\[Psi]", "[", "x_", "]"}], " ", ":=", " ", 
   RowBox[{
    RowBox[{"Sech", "[", "x", "]"}], "/", 
    RowBox[{"Sqrt", "[", "2", "]"}]}]}], ";"}], "\n", 
 RowBox[{"\[Psi]T", " ", "=", " ", 
  RowBox[{"FullSimplify", "[", 
   RowBox[{"FourierTransform", "[", 
    RowBox[{
     RowBox[{"\[Psi]", "[", "x", "]"}], ",", " ", "x", ",", " ", "p", ",", 
     " ", 
     RowBox[{"FourierParameters", " ", "->", " ", 
      RowBox[{"{", 
       RowBox[{"0", ",", " ", 
        RowBox[{"-", "1"}]}], "}"}]}]}], "]"}], "]"}]}]}], "Input",
 CellLabel->
  "In[21]:= ",ExpressionUUID->"fb24848e-7210-45fe-a857-7b87b99a4135"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{"Integrate", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"Abs", "[", "\[Psi]T", "]"}], "^", "2"}], ",", " ", 
     RowBox[{"{", 
      RowBox[{"p", ",", " ", 
       RowBox[{"-", "Infinity"}], ",", " ", "Infinity"}], "}"}]}], "]"}], ",",
    "\n", " ", 
   RowBox[{"Integrate", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"p", "^", "2"}], " ", 
      RowBox[{
       RowBox[{"Abs", "[", "\[Psi]T", "]"}], "^", "2"}]}], ",", " ", 
     RowBox[{"{", 
      RowBox[{"p", ",", " ", 
       RowBox[{"-", "Infinity"}], ",", " ", "Infinity"}], "}"}]}], "]"}]}], 
  "}"}]], "Input",
 CellLabel->
  "In[22]:= ",ExpressionUUID->"f5a062b7-db97-4602-9e97-63443a82da02"],

Cell[TextData[{
 "The transform is ",
 Cell[BoxData[
  StyleBox[
   RowBox[{
    OverscriptBox["\|01d713", "~"], 
    StyleBox["(",
     SpanMaxSize->1], "\|01d45d", 
    StyleBox[")",
     SpanMaxSize->1], "=", 
    FractionBox[
     SqrtBox["\[Pi]"], "2"], 
    StyleBox["sech",
     FontSlant->"Plain"], "\[NegativeThinSpace]", 
    StyleBox["(",
     FontSize->1.2 Inherited], 
    FractionBox[
     RowBox[{"\[Pi]", "\|01d45d"}], "2"], 
    StyleBox[")",
     FontSize->1.2 Inherited]}],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "20fe2b6c-1105-469e-b902-4e75fc90ac6f"],
 ": the Fourier transform of a sech is again a sech, a self-similarity \
special to this profile. Its norm is ",
 Cell[BoxData[
  StyleBox["1",
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "db4ea179-a8ea-4e11-ae8f-344868f6ea66"],
 " and ",
 Cell[BoxData[
  StyleBox[
   RowBox[{
    StyleBox["\[LeftAngleBracket]",
     SpanMaxSize->1], 
    SuperscriptBox["\|01d45d", "2"], 
    StyleBox["\[RightAngleBracket]",
     SpanMaxSize->1], "=", 
    FractionBox["1", "3"]}],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "4f3895f6-8aaf-4439-abce-fb9a4ac64f8c"],
 ", matching the position-space value ",
 Cell[BoxData[
  StyleBox[
   RowBox[{
    StyleBox["\[Integral]",
     FontSize->1.7 Inherited], 
    SuperscriptBox[
     RowBox[{"\[LeftBracketingBar]", 
      RowBox[{
       SubscriptBox["\[PartialD]", "\|01d465"], "\|01d713"}], 
      "\[VeryThinSpace]", "\[RightBracketingBar]"}], "2"], " ", "\|01d451", 
    "\|01d465"}],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "95074bc7-7948-423b-a2f4-9c08d6b15d47"],
 ". (A boost ",
 Cell[BoxData[
  StyleBox[
   SuperscriptBox["\|01d452", 
    RowBox[{"\|01d456", "\|01d458", "\|01d465"}]],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "5387d33d-5279-4182-9d41-b21b60371c3d"],
 " would shift the whole momentum profile to center ",
 Cell[BoxData[
  StyleBox["\|01d458",
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "3e847a3b-0ac8-42d0-9bfe-2315c16336b3"],
 " without changing its width.)"
}], "Text",ExpressionUUID->"df955837-c85f-4aa8-aa83-c2d482823931"],

Cell[TextData[{
 "2.7 [BSc] How do I verify the position-momentum uncertainty relation ",
 Cell[BoxData[
  StyleBox[
   RowBox[{
   "\[CapitalDelta]", "\|01d465", " ", "\[CapitalDelta]", "\|01d45d", "\[GreaterEqual]",
     "1", "/", "2"}],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "7edfbc36-4ffb-42e3-a9ef-3e7a31815897"],
 " and show that a Gaussian saturates it?"
}], "Subsection",ExpressionUUID->"1a6f8a42-3481-4fde-8b43-60cbb4d5b67a"],

Cell[TextData[{
 "Here the Gaussian earns its keep. The bound ",
 Cell[BoxData[
  StyleBox[
   RowBox[{
   "\[CapitalDelta]", "\|01d465", " ", "\[CapitalDelta]", "\|01d45d", "\[GreaterEqual]", 
    FractionBox["1", "2"]}],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "2640fec2-fa62-41c6-89d4-40a8f3239014"],
 " (with ",
 Cell[BoxData[
  StyleBox[
   RowBox[{"\[HBar]", "=", "1"}],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "ecf34b9d-1b05-46e8-948b-ebbabdc5fbd7"],
 ") is saturated by a Gaussian and by nothing else. We compute the product \
for the soliton, then for the Gaussian, side by side."
}], "Text",ExpressionUUID->"95edc319-a919-4c86-8f1b-fbbddefde924"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"\[Psi]sol", "[", "x_", "]"}], " ", ":=", " ", 
   RowBox[{
    RowBox[{"Sech", "[", "x", "]"}], "/", 
    RowBox[{"Sqrt", "[", "2", "]"}]}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"dxSol", " ", "=", " ", 
   RowBox[{"Sqrt", "[", 
    RowBox[{"Integrate", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"x", "^", "2"}], " ", 
       RowBox[{
        RowBox[{"Abs", "[", 
         RowBox[{"\[Psi]sol", "[", "x", "]"}], "]"}], "^", "2"}]}], ",", " ", 
      
      RowBox[{"{", 
       RowBox[{"x", ",", " ", 
        RowBox[{"-", "Infinity"}], ",", " ", "Infinity"}], "}"}]}], "]"}], 
    "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"dpSol", " ", "=", " ", 
   RowBox[{"Sqrt", "[", 
    RowBox[{"Integrate", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"Abs", "[", 
        RowBox[{"D", "[", 
         RowBox[{
          RowBox[{"\[Psi]sol", "[", "x", "]"}], ",", " ", "x"}], "]"}], "]"}],
        "^", "2"}], ",", " ", 
      RowBox[{"{", 
       RowBox[{"x", ",", " ", 
        RowBox[{"-", "Infinity"}], ",", " ", "Infinity"}], "}"}]}], "]"}], 
    "]"}]}], ";"}], "\n", 
 RowBox[{"dxSol", " ", "dpSol"}]}], "Input",
 CellLabel->
  "In[23]:= ",ExpressionUUID->"4a7afc53-3ee7-4234-a53b-a92825caade1"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"\[Psi]G", "[", "x_", "]"}], " ", ":=", " ", 
   RowBox[{
    RowBox[{"Pi", "^", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{"-", "1"}], "/", "4"}], ")"}]}], " ", 
    RowBox[{"\[Sigma]", "^", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{"-", "1"}], "/", "2"}], ")"}]}], " ", 
    RowBox[{"Exp", "[", 
     RowBox[{
      RowBox[{"-", 
       RowBox[{"x", "^", "2"}]}], "/", 
      RowBox[{"(", 
       RowBox[{"2", " ", 
        RowBox[{"\[Sigma]", "^", "2"}]}], ")"}]}], "]"}]}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"dxG", " ", "=", " ", 
   RowBox[{"Sqrt", "[", 
    RowBox[{"Integrate", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"x", "^", "2"}], " ", 
       RowBox[{
        RowBox[{"Abs", "[", 
         RowBox[{"\[Psi]G", "[", "x", "]"}], "]"}], "^", "2"}]}], ",", " ", 
      RowBox[{"{", 
       RowBox[{"x", ",", " ", 
        RowBox[{"-", "Infinity"}], ",", " ", "Infinity"}], "}"}], ",", " ", 
      RowBox[{"Assumptions", " ", "->", " ", 
       RowBox[{"\[Sigma]", " ", ">", " ", "0"}]}]}], "]"}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"dpG", " ", "=", " ", 
   RowBox[{"Sqrt", "[", 
    RowBox[{"Integrate", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"Abs", "[", 
        RowBox[{"D", "[", 
         RowBox[{
          RowBox[{"\[Psi]G", "[", "x", "]"}], ",", " ", "x"}], "]"}], "]"}], "^",
        "2"}], ",", " ", 
      RowBox[{"{", 
       RowBox[{"x", ",", " ", 
        RowBox[{"-", "Infinity"}], ",", " ", "Infinity"}], "}"}], ",", " ", 
      RowBox[{"Assumptions", " ", "->", " ", 
       RowBox[{"\[Sigma]", " ", ">", " ", "0"}]}]}], "]"}], "]"}]}], ";"}], "\n", 
 RowBox[{"Simplify", "[", 
  RowBox[{
   RowBox[{"dxG", " ", "dpG"}], ",", " ", 
   RowBox[{"\[Sigma]", " ", ">", " ", "0"}]}], "]"}]}], "Input",
 CellLabel->
  "In[24]:= ",ExpressionUUID->"4565eb4c-ae91-4fa6-a13d-f617a5015730"],

Cell[TextData[{
 "The soliton gives ",
 Cell[BoxData[
  StyleBox[
   RowBox[{
   "\[CapitalDelta]", "\|01d465", " ", "\[CapitalDelta]", "\|01d45d", "=", 
    "\[Pi]", "/", "6", "\[TildeTilde]", "0.524"}],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "1587b894-7095-467f-90ba-139a936e017b"],
 ", just above the floor: a state can be beautifully localized and still not \
minimal. The Gaussian gives exactly ",
 Cell[BoxData[
  StyleBox[
   FractionBox["1", "2"],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "36f3bf8a-702e-4a8d-af5a-e4ca35578dc9"],
 " for every width ",
 Cell[BoxData[
  StyleBox["\|01d70e",
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "ca2a02d9-bf9c-4f10-b9ce-dd06a2a4e1f9"],
 ", sitting right on the boundary. Squeezing it in position inflates it in \
momentum and vice versa, tracing the edge of the allowed region; every \
non-Gaussian state, the soliton included, lies strictly above."
}], "Text",ExpressionUUID->"aa190907-57b5-49d7-82a7-f21f8a557458"],

Cell[TextData[{
 "2.8 [MSc] How do I build a function ",
 Cell[BoxData[
  StyleBox[
   RowBox[{"\|01d453", 
    StyleBox["(",
     SpanMaxSize->1], 
    RowBox[{
     OverscriptBox["\|01d465", "^"], ",", 
     OverscriptBox["\|01d45d", "^"]}], 
    StyleBox[")",
     SpanMaxSize->1]}],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "35acc94c-adb9-4004-afe7-2ec32265bcaa"],
 " of noncommuting operators, and resolve the ordering ambiguity by Weyl \
symmetric ordering?"
}], "Subsection",ExpressionUUID->"1b9327ec-c344-4b65-bdde-ced0139f6d4f"],

Cell[TextData[{
 "Because ",
 Cell[BoxData[
  StyleBox[
   OverscriptBox["\|01d465", "^"],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "29301608-a47d-4808-97ff-6910fa7814da"],
 " and ",
 Cell[BoxData[
  StyleBox[
   OverscriptBox["\|01d45d", "^"],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "f9db8be6-0c88-43a4-9379-6691f2020595"],
 " do not commute, the classical product ",
 Cell[BoxData[
  StyleBox[
   RowBox[{"\|01d465", "\|01d45d"}],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "e24a90bd-e6ed-4b48-8827-046a4479cf1a"],
 " has several inequivalent quantizations. The Weyl (symmetric) prescription, \
",
 Cell[BoxData[
  StyleBox[
   RowBox[{
    FractionBox["1", "2"], 
    StyleBox["(",
     SpanMaxSize->1], 
    RowBox[{
     OverscriptBox["\|01d465", "^"], 
     OverscriptBox["\|01d45d", "^"], "+", 
     OverscriptBox["\|01d45d", "^"], 
     OverscriptBox["\|01d465", "^"]}], 
    StyleBox[")",
     SpanMaxSize->1]}],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "c2c8c77f-ad18-4b64-aaba-a7a948ea330e"],
 ", is the unique Hermitian choice."
}], "Text",ExpressionUUID->"73ae81a8-2fc3-4dee-a1aa-0fb7e87c8d5b"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"sym", "[", "h_", "]"}], " ", ":=", " ", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{
      RowBox[{"xop", "[", 
       RowBox[{"pop", "[", "h", "]"}], "]"}], " ", "+", " ", 
      RowBox[{"pop", "[", 
       RowBox[{"xop", "[", "h", "]"}], "]"}]}], ")"}], "/", "2"}]}], ";"}], "\n", 
 RowBox[{"Simplify", "[", 
  RowBox[{"sym", "[", 
   RowBox[{"h", "[", "x", "]"}], "]"}], "]"}]}], "Input",
 CellLabel->
  "In[25]:= ",ExpressionUUID->"c0bda954-c9cf-41fd-9266-7c766248213d"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"u", "[", "x_", "]"}], " ", ":=", " ", 
   RowBox[{
    RowBox[{"Pi", "^", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{"-", "1"}], "/", "4"}], ")"}]}], " ", 
    RowBox[{"Exp", "[", 
     RowBox[{
      RowBox[{"-", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{"x", " ", "-", " ", "1"}], ")"}], "^", "2"}]}], "/", "2"}], 
     "]"}]}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"w", "[", "x_", "]"}], " ", ":=", " ", 
   RowBox[{
    RowBox[{"Pi", "^", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{"-", "1"}], "/", "4"}], ")"}]}], " ", 
    RowBox[{"Exp", "[", 
     RowBox[{
      RowBox[{"-", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{"x", " ", "+", " ", "1"}], ")"}], "^", "2"}]}], "/", "2"}], 
     "]"}], " ", 
    RowBox[{"Exp", "[", 
     RowBox[{"I", " ", "x"}], "]"}]}]}], ";"}], "\n", 
 RowBox[{"{", 
  RowBox[{
   RowBox[{
    RowBox[{"Integrate", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"Conjugate", "[", 
        RowBox[{"u", "[", "x", "]"}], "]"}], " ", 
       RowBox[{"sym", "[", 
        RowBox[{"w", "[", "x", "]"}], "]"}]}], ",", " ", 
      RowBox[{"{", 
       RowBox[{"x", ",", " ", 
        RowBox[{"-", "Infinity"}], ",", " ", "Infinity"}], "}"}]}], "]"}], 
    " ", "-", "\n", "   ", 
    RowBox[{"Integrate", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"Conjugate", "[", 
        RowBox[{"sym", "[", 
         RowBox[{"u", "[", "x", "]"}], "]"}], "]"}], " ", 
       RowBox[{"w", "[", "x", "]"}]}], ",", " ", 
      RowBox[{"{", 
       RowBox[{"x", ",", " ", 
        RowBox[{"-", "Infinity"}], ",", " ", "Infinity"}], "}"}]}], "]"}]}], ",",
    "\n", " ", 
   RowBox[{
    RowBox[{"Integrate", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"Conjugate", "[", 
        RowBox[{"u", "[", "x", "]"}], "]"}], " ", 
       RowBox[{"xop", "[", 
        RowBox[{"pop", "[", 
         RowBox[{"w", "[", "x", "]"}], "]"}], "]"}]}], ",", " ", 
      RowBox[{"{", 
       RowBox[{"x", ",", " ", 
        RowBox[{"-", "Infinity"}], ",", " ", "Infinity"}], "}"}]}], "]"}], 
    " ", "-", "\n", "   ", 
    RowBox[{"Integrate", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"Conjugate", "[", 
        RowBox[{"xop", "[", 
         RowBox[{"pop", "[", 
          RowBox[{"u", "[", "x", "]"}], "]"}], "]"}], "]"}], " ", 
       RowBox[{"w", "[", "x", "]"}]}], ",", " ", 
      RowBox[{"{", 
       RowBox[{"x", ",", " ", 
        RowBox[{"-", "Infinity"}], ",", " ", "Infinity"}], "}"}]}], "]"}]}]}],
   "}"}]}], "Input",
 CellLabel->
  "In[26]:= ",ExpressionUUID->"eb2ba346-b240-4cad-90c4-83d9fae13e73"],

Cell[TextData[{
 "The symmetric operator acts as ",
 Cell[BoxData[
  StyleBox[
   RowBox[{"-", "\|01d456", 
    StyleBox["(",
     FontSize->1.2 Inherited], 
    FractionBox["1", "2"], "\|01d453", "+", "\|01d465", 
    SuperscriptBox["\|01d453", "\[Prime]"], 
    StyleBox[")",
     FontSize->1.2 Inherited]}],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "8e4dd1a5-4e57-4b0f-8639-02e7809ca287"],
 ", and its matrix-element difference is ",
 Cell[BoxData[
  StyleBox["0",
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "5b2882e6-2f11-454f-946f-f47b8b8878ec"],
 " while the naive ordering ",
 Cell[BoxData[
  StyleBox[
   RowBox[{
    OverscriptBox["\|01d465", "^"], 
    OverscriptBox["\|01d45d", "^"]}],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "ac67c8a9-7d25-4862-a4e1-dd068a1c1263"],
 " gives a nonzero difference. Only ",
 Cell[BoxData[
  StyleBox[
   RowBox[{
    FractionBox["1", "2"], 
    StyleBox["(",
     SpanMaxSize->1], 
    RowBox[{
     OverscriptBox["\|01d465", "^"], 
     OverscriptBox["\|01d45d", "^"], "+", 
     OverscriptBox["\|01d45d", "^"], 
     OverscriptBox["\|01d465", "^"]}], 
    StyleBox[")",
     SpanMaxSize->1]}],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "9d0edae5-847e-4c73-8a5c-edaeeed5b808"],
 " is Hermitian, so only it can represent an observable; the ambiguity ",
 Cell[BoxData[
  StyleBox[
   RowBox[{
    OverscriptBox["\|01d465", "^"], 
    OverscriptBox["\|01d45d", "^"]}],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "6aa51696-fd4b-4b9f-8fd0-d4f6718926a3"],
 " versus ",
 Cell[BoxData[
  StyleBox[
   RowBox[{
    OverscriptBox["\|01d45d", "^"], 
    OverscriptBox["\|01d465", "^"]}],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "ee4703af-075e-4260-a1e8-e552aec8042b"],
 " is the commutator ",
 Cell[BoxData[
  StyleBox[
   RowBox[{
    StyleBox["[",
     SpanMaxSize->1], 
    RowBox[{
     OverscriptBox["\|01d465", "^"], ",", 
     OverscriptBox["\|01d45d", "^"]}], 
    StyleBox["]",
     SpanMaxSize->1], "=", "\|01d456"}],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "230cfe39-38e9-4c39-a810-6ac153ca711d"],
 " of 2.2. (The two probe states here are displaced Gaussians, used only as \
convenient smooth test functions, not as the object of study.)"
}], "Text",ExpressionUUID->"af114a1d-1bc8-4972-b2cd-20e260bfcb9d"],

Cell["\<\
2.9 [MSc] How do I distinguish self-adjointness from formal Hermiticity \
through the operator domain and boundary conditions (the box versus the \
half-line)?\
\>", "Subsection",ExpressionUUID->"636538b9-d7a4-475d-8e84-c89c1ab035bd"],

Cell[TextData[{
 "Formal Hermiticity is the bulk identity of 2.4; self-adjointness \
additionally needs the boundary term ",
 Cell[BoxData[
  StyleBox[
   RowBox[{"-", "\|01d456", 
    StyleBox["[",
     SpanMaxSize->1], 
    RowBox[{
     SuperscriptBox["\[Phi]", "*"], "\|01d713"}], 
    StyleBox["]",
     SpanMaxSize->1]}],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "43be49c2-0d53-4b20-9a01-b1b1cbb1d086"],
 " to vanish on a domain the operator preserves. On a box this is achievable; \
on the half-line (the natural home of the radial state ",
 Cell[BoxData[
  StyleBox["\|01d462",
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "099c30af-17a2-40fd-8b59-b482b87a6a2b"],
 " of 1.4) it is not."
}], "Text",ExpressionUUID->"b119cf38-29ff-4e46-addd-432fb08c00fa"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{
     RowBox[{"box", " ", "[", 
      RowBox[{"0", ",", "L"}], "]"}], " ", "with", " ", "twisted", " ", 
     "boundary", " ", "condition", " ", "\[Psi]", 
     RowBox[{"(", "L", ")"}]}], " ", "=", " ", 
    RowBox[{
     RowBox[{"e", "^", 
      RowBox[{"{", "i\[Theta]", "}"}]}], " ", "\[Psi]", 
     RowBox[{"(", "0", ")"}]}]}], " ", "*)"}], "\n", 
  RowBox[{
   RowBox[{
    RowBox[{"bt", " ", "=", " ", 
     RowBox[{
      RowBox[{
       RowBox[{"-", "I"}], " ", 
       RowBox[{"(", 
        RowBox[{
         RowBox[{
          RowBox[{"Conjugate", "[", "pL", "]"}], " ", "sL"}], " ", "-", " ", 
         RowBox[{
          RowBox[{"Conjugate", "[", "p0", "]"}], " ", "s0"}]}], ")"}]}], " ", 
      "/.", " ", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"sL", " ", "->", " ", 
         RowBox[{
          RowBox[{"Exp", "[", 
           RowBox[{"I", " ", "\[Theta]"}], "]"}], " ", "s0"}]}], ",", " ", 
        RowBox[{"pL", " ", "->", " ", 
         RowBox[{
          RowBox[{"Exp", "[", 
           RowBox[{"I", " ", "\[Theta]"}], "]"}], " ", "p0"}]}]}], "}"}]}]}], 
    ";"}], "\n", 
   RowBox[{"Simplify", "[", 
    RowBox[{"bt", ",", " ", 
     RowBox[{"\[Theta]", " ", "\[Element]", " ", "Reals"}]}], 
    "]"}]}]}]], "Input",
 CellLabel->
  "In[27]:= ",ExpressionUUID->"6fe54b65-d620-4ac8-a8ca-369e667e0142"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
    RowBox[{
     RowBox[{" ", 
      RowBox[{"half", "-", 
       RowBox[{"line", " ", "[", 
        RowBox[{"0", ",", "\[Infinity]"}]}]}], ")"}], ":", " ", 
     RowBox[{"\[Psi]", 
      RowBox[{"(", "\[Infinity]", ")"}]}]}], " ", "=", " ", 
    RowBox[{"0", " ", "but", " ", "\[Psi]", 
     RowBox[{"(", "0", ")"}], " ", "is", " ", "free"}]}], " ", "*)"}], "\n", 
  RowBox[{
   RowBox[{"-", "I"}], " ", 
   RowBox[{"(", 
    RowBox[{"0", " ", "-", " ", 
     RowBox[{
      RowBox[{"Conjugate", "[", "p0", "]"}], " ", "s0"}]}], 
    ")"}]}]}]], "Input",
 CellLabel->
  "In[28]:= ",ExpressionUUID->"ec2353b6-b829-4b42-adfe-2d9ab63a17ca"],

Cell[TextData[{
 "On the box the twisted condition ",
 Cell[BoxData[
  StyleBox[
   RowBox[{"\|01d713", 
    StyleBox["(",
     SpanMaxSize->1], "\|01d43f", 
    StyleBox[")",
     SpanMaxSize->1], "=", 
    SuperscriptBox["\|01d452", 
     RowBox[{"\|01d456", "\|01d703"}]], "\|01d713", 
    StyleBox["(",
     SpanMaxSize->1], "0", 
    StyleBox[")",
     SpanMaxSize->1]}],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "a9b39224-8148-4b1f-b8ed-a1f5d04c5f4b"],
 " makes the surface term vanish for every real ",
 Cell[BoxData[
  StyleBox["\|01d703",
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "78226bce-ef65-472f-81e4-43fc341c0a67"],
 ", so each ",
 Cell[BoxData[
  StyleBox["\|01d703",
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "e2ddd1df-0d76-41d1-a9bc-bc3c820ef84e"],
 " defines a genuine self-adjoint momentum operator (a one-parameter family \
of extensions). On the half-line the term reduces to ",
 Cell[BoxData[
  StyleBox[
   RowBox[{"\|01d456", " ", 
    SuperscriptBox["\[Phi]", "*"], 
    StyleBox["(",
     SpanMaxSize->1], "0", 
    StyleBox[")",
     SpanMaxSize->1], "\|01d713", 
    StyleBox["(",
     SpanMaxSize->1], "0", 
    StyleBox[")",
     SpanMaxSize->1]}],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "2fae78c5-cd7e-4beb-a209-fb2e42b54d97"],
 ", which cannot vanish for all admissible states: ",
 Cell[BoxData[
  StyleBox[
   RowBox[{
    OverscriptBox["\|01d45d", "^"], "=", "-", "\|01d456", " ", "\|01d451", "/",
     "\|01d451", "\|01d465"}],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "9edbbc95-7eea-4236-88cb-09d1827df996"],
 " on ",
 Cell[BoxData[
  StyleBox[
   RowBox[{"[", "0", ",", "\[Infinity]", ")"}],
   FontFamily->"Latin Modern Math"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "c1fdbebb-1b72-4eef-a931-b6a959fcb1e9"],
 " is Hermitian but has ",
 StyleBox["no", "TI"],
 " self-adjoint extension. Hermiticity is a property of a formula; \
self-adjointness is a property of a formula together with its domain."
}], "Text",ExpressionUUID->"758cbc58-1c76-407c-9888-13d05895fe8f"]
},
CreateCellID->True,
