Cell[698, 24, 1346, 35, 70, "Text",ExpressionUUID->"34e2a41c-881e-4115-b9af-fdb3d0dbcc7f"],
Cell[2047, 61, 622, 11, 70, "Text",ExpressionUUID->"a9c42919-947f-4244-bfd1-9a3562acf337"],
Cell[2672, 74, 1021, 29, 70, "Item",ExpressionUUID->"659d5962-3d55-42be-b3ac-fdf2d4fd710a"],
Cell[3696, 105, 846, 26, 70, "Item",ExpressionUUID->"e38f9900-d5a7-4f78-9425-e61b1e7f6fcd"],
Cell[4545, 133, 946, 28, 70, "Item",ExpressionUUID->"c1c8c99d-b276-44ac-8975-0ed347fcc876"],
