}], "Text",
 CellID->1242041249,ExpressionUUID->"58c79d73-4cc7-4beb-adaf-5e6b4205851c"],

Cell[TextData[{
 "Pick an arbitrary ",
 Cell[BoxData[
  FormBox["n", TraditionalForm]],ExpressionUUID->
  "fc8b2373-e34e-ed40-9949-964dde87d526"],
 " within the cutoff to verify how the ladder operators act on Fock states."
}], "Text",
