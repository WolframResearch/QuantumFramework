   RowBox[{"a", ",", 
    RowBox[{"FockState", "[", 
     RowBox[{"$FockSize", " ", "-", "1"}], "]"}], ",", "$FockSize"}], "]"}], "//",
   "TraditionalForm"}]], "Input",
