Cell[CellGroupData[{

Cell["Vocabulary", "VocabularySection",
 CellID->192590836,ExpressionUUID->"de11f7cd-a980-2743-9a74-690306dc6994"],

Cell[BoxData[GridBox[{
   {"AnnihilationOperator", " ", Cell["\<\
defines the bosonic annihilation operator in\[LineSeparator]a finite \
dimensional space\
\>", "VocabularyText",ExpressionUUID->"a015e162-2c3f-854f-99e7-8900543a7562"]},
   {
    RowBox[{"FockState", "[", "n", "]"}], " ", Cell["\<\
represents the states of the truncated Fock space basis\[LineSeparator]for a \
single mode\
\>", "VocabularyText",ExpressionUUID->"0a2df026-1206-bf4f-a790-182361c71ad9"]},
   {"QuadratureOperators", " ", Cell["\<\
returns the position and momentum quadrature\[LineSeparator]operators in a \
finite dimensional space\
\>", "VocabularyText",ExpressionUUID->"2fe1afce-d6cb-0243-9b82-d264f0693146"]},
   {"OperatorVariance", " ", Cell["\<\
calculates the variance of an operator for a \[LineSeparator]particular state\
\
\>", "VocabularyText",ExpressionUUID->"f3e0cb83-1a12-6f45-8bf8-0749568ba12a"]},
   {"ThermalState", " ", Cell["\<\
defines a quantum thermal state following the\[LineSeparator]canonical \
ensemble formalism\
\>", "VocabularyText",ExpressionUUID->
     "11deb237-dfc6-3349-a6a4-3594821d7b06"]}
  }]], "VocabularyTable",
 CellChangeTimes->{{3.9714526494320374`*^9, 3.9714526780128746`*^9}, {
  3.9714527141377544`*^9, 3.971452904526533*^9}, {3.9714529410794144`*^9, 
  3.971452946094986*^9}, {3.9714531707900295`*^9, 3.971453210644682*^9}, {
  3.971953623781128*^9, 3.971953741356119*^9}},
 CellID->371414833,ExpressionUUID->"540a4fe9-3f8f-cd4d-880f-b095cdb8ced9"],

