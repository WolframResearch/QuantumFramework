Cell[BoxData[{
 RowBox[{
  RowBox[{"Cphase", " ", "=", " ", 
   RowBox[{
    RowBox[{"1", "/", "2"}], 
    RowBox[{"(", 
     RowBox[{"Ephase", "+", 
      SuperscriptBox["Ephase", "\[Dagger]"]}], ")"}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Sphase", " ", "=", " ", 
   RowBox[{
    FractionBox["1", 
     RowBox[{"2", "\[ImaginaryI]"}]], 
    RowBox[{"(", 
     RowBox[{"Ephase", " ", "-", 
      SuperscriptBox["Ephase", "\[Dagger]"]}], ")"}]}]}], ";"}]}], "Input",
