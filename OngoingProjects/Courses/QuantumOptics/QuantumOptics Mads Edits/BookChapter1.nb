 CellID->13641621,ExpressionUUID->"681c53ee-2f7e-e344-b3fc-389b9d7fe6a7"],

Cell[TextData[{
 "Even when n = 0 the mean field is zero but the uncertainty is not; this is \
vacuum fluctuations. This follows from the uncertainty principle because ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    OverscriptBox["n", "^"], " ", "and", " ", 
    OverscriptBox[
     SubscriptBox["E", "x"], "^"]}], TraditionalForm]],ExpressionUUID->
  "56b71ede-b6c7-d246-ae83-acb0c4c7b974"],
 " do not commute."
}], "Text",
 CellChangeTimes->{3.965154718362097*^9},
 CellID->209550954,ExpressionUUID->"3da52841-244b-3b47-b49c-d18a919ddb19"]
}, Open  ]],

