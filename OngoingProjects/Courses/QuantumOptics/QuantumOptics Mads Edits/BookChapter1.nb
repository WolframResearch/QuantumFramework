Cell[TextData[{
 StyleBox["Show numerically \[ScriptCapitalP](\[Phi]) = ",
  FontWeight->"Plain"],
 Cell[BoxData[
  FormBox[
   FractionBox["1", 
    RowBox[{"2", "\[Pi]"}]], TraditionalForm]],
  FontWeight->"Plain",ExpressionUUID->
  "2ae90074-5fa8-3241-b025-f1dbb10fd18a"],
 StyleBox[" for a thermal state",
  FontWeight->"Plain"]
}], "Exercise",
 FontWeight->"Bold",
 CellID->116301621,ExpressionUUID->"adb0ab91-fe6c-4f48-b638-5906b956073b"],

Cell[CellGroupData[{

Cell[TextData[{
 StyleBox["A thermal state is not a pure state, so to calculate the phase \
distribution we use  \[ScriptCapitalP](\[Phi]) = \[LeftAngleBracket] \[Phi] | \
", "Exercise"],
 StyleBox[Cell[BoxData[
  FormBox[
   SubscriptBox["\[Rho]", "thermal"], TraditionalForm]], "Exercise",
  ExpressionUUID->"2f0e370b-7666-9540-b662-d881a0faf376"], "Exercise"],
 StyleBox[" | \[Phi] \[RightAngleBracket], let\[CloseCurlyQuote]s pick ", 
  "Exercise"],
 StyleBox[Cell[BoxData[
  FormBox[
   OverscriptBox["n", "\[LongDash]"], TraditionalForm]], "Exercise",
  ExpressionUUID->"c4b35d8e-015b-6343-b001-c35cf433c1df"], "Exercise"],
 StyleBox[" = 0.5 . Use \[OpenCurlyDoubleQuote]Operator\
\[CloseCurlyDoubleQuote] property to treat the quantum state as an operator:",
   "Exercise"]
}], "ExerciseNote",
 CellID->493495060,ExpressionUUID->"5eee3a16-5439-e341-8b19-da4f17935ff0"],

Cell[BoxData[
 RowBox[{
  RowBox[{"\[Phi]thermal", " ", "=", 
   RowBox[{
    FractionBox["1", 
     RowBox[{"2", "\[Pi]"}]], 
    RowBox[{"Simplify", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"(", 
        RowBox[{
         SuperscriptBox["phistate", "\[Dagger]"], "@", 
         RowBox[{
          RowBox[{
           RowBox[{"ThermalState", "[", "0.5", "]"}], "[", "\"\<Operator\>\"",
            "]"}], "@", "phistate"}]}], ")"}], "[", "\"\<Scalar\>\"", "]"}], ",", 
      RowBox[{"\[Phi]", " ", "\[Element]", " ", "Reals"}]}], "]"}]}]}], 
  ";"}]], "ExerciseInput",
 CellChangeTimes->{{3.973693405331623*^9, 3.9736934105626564`*^9}, {
  3.973696591328043*^9, 3.973696704364126*^9}, {3.9736967452838707`*^9, 
  3.973696830925974*^9}},
 CellLabel->"In[114]:=",
 CellID->788460936,ExpressionUUID->"9306cda6-82aa-7f41-af92-4788764787eb"]
}, Open  ]],

