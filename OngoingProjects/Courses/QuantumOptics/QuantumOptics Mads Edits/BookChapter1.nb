           RowBox[{"Axes", "->", "False"}], ",", 
           RowBox[{"PlotRange", "->", 
            RowBox[{"{", 
             RowBox[{
              RowBox[{"{", 
               RowBox[{
                RowBox[{"-", "xmax"}], ",", "xmax"}], "}"}], ",", 
              RowBox[{"{", 
               RowBox[{"0", ",", "ymax"}], "}"}]}], "}"}]}], ",", 
