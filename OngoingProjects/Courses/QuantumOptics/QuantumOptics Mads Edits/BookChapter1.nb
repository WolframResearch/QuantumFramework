Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{
   FractionBox[
    SuperscriptBox[
     RowBox[{"(", 
      SuperscriptBox["a", "\[Dagger]"], ")"}], "n"], 
    SqrtBox[
     RowBox[{"n", "!"}]]], "@", 
   RowBox[{"FockState", "[", "0", "]"}]}], " ", "==", " ", 
  RowBox[{"FockState", "[", "n", "]"}]}]], "Input",
 CellChangeTimes->{{3.9344022953369083`*^9, 3.934402329617464*^9}, {
  3.953732606256687*^9, 3.953732615151417*^9}},
