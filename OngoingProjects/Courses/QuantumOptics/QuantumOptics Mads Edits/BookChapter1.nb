Cell[TextData[StyleBox["We can check that if we normalize the state, mean \
number of photons doubles so the previous plot is valid:", "Exercise"]], \
"ExerciseNote",
 CellID->541040002,ExpressionUUID->"3f287dff-b6b5-2340-99a3-8abe9c0659d8"],

