Cell[CellGroupData[{

Cell[TextData[StyleBox["Thermal fields", "Subsection"]], "Subsection",
 CellChangeTimes->{{3.927723625747513*^9, 3.9277236289367485`*^9}},
 CellID->86846476,ExpressionUUID->"0a76adb5-384a-554b-86d2-06d6e62b5009"],

Cell[TextData[{
 "Consider a single-mode field in thermal equilibrium in a cavity at \
temperature ",
 Cell[BoxData[
  FormBox["T", TraditionalForm]],ExpressionUUID->
  "1601ad39-37e6-3640-a67b-4076f9b9217f"],
 ". Statistical mechanics gives the photon-number distribution ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox["P", "n"], " ", "that", " ", "the", " ", "n"}], "-", 
    RowBox[{"th", " ", "level", " ", "is", " ", "excited", " ", "is"}]}], 
   TraditionalForm]],ExpressionUUID->"3b7a837f-6145-d94a-a7ec-973553b0aafd"],
 ":"
}], "Text",
 CellChangeTimes->{{3.926596212657816*^9, 3.92659627797184*^9}, {
  3.9265964284169884`*^9, 3.926596439428404*^9}, {3.926596471075287*^9, 
