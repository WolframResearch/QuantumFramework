Cell[TextData[{
 "For any number state |n\[RightAngleBracket] the phase distribution is \
uniform, \[ScriptCapitalP](\[Phi]) = 1/(2\[Pi]). It has mean \[Pi] and \
fluctuations ",
 Cell[BoxData[
  FormBox["\[CapitalDelta]\[Phi]", TraditionalForm]],ExpressionUUID->
  "62fc721f-c31b-e44e-aa6f-34de9400b769"],
 " = ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Pi]", "/", 
    SqrtBox["3"]}], TraditionalForm]],ExpressionUUID->
  "ad1d4e51-c5dc-2d43-8b45-d801ab589f2f"],
 ". This holds for all number states, including the vacuum."
}], "Text",
 CellChangeTimes->{3.9652136316343594`*^9},
 CellID->336549743,ExpressionUUID->"f9e642eb-4470-754b-a1c7-90c4ca18af9b"],

Cell[TextData[StyleBox["Phase distribution for Fock States:", "Text"]], \
"CodeText",
 CellChangeTimes->{{3.9652136630596256`*^9, 3.965213671532074*^9}},
 CellID->253001813,ExpressionUUID->"c4e7f120-bfde-db42-aedb-b89b38d242de"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Simplify", "[", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{
      FractionBox["1", 
       RowBox[{"2", "\[Pi]"}]], 
      SuperscriptBox[
       RowBox[{"Abs", "[", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{
           RowBox[{"phistate", "[", "\"\<Dagger\>\"", "]"}], "@", "#"}], 
          ")"}], "[", "\"\<Scalar\>\"", "]"}], "]"}], "2"]}], "&"}], " ", "/@",
     " ", 
    RowBox[{"Array", "[", 
     RowBox[{"FockState", ",", 
      RowBox[{"$FockSize", "-", "1"}], ",", "0"}], "]"}]}], ",", 
   RowBox[{"\[Phi]", "\[Element]", "Reals"}]}], "]"}]], "Input",
 CellChangeTimes->{{3.9340460134314213`*^9, 3.9340460558524055`*^9}, {
  3.9340460965564976`*^9, 3.9340462674318886`*^9}, {3.9537379535653286`*^9, 
  3.9537379538336163`*^9}},
 CellLabel->"In[128]:=",
 CellID->169369309,ExpressionUUID->"b4500b51-a792-1c4b-9151-dd58004910c8"],

Cell[BoxData[
 FormBox[
  RowBox[{"{", 
   RowBox[{
    FractionBox["1", 
     RowBox[{"2", " ", "\[Pi]"}]], ",", 
    FractionBox["1", 
     RowBox[{"2", " ", "\[Pi]"}]], ",", 
    FractionBox["1", 
