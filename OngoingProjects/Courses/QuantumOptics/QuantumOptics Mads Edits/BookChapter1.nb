Cell[BoxData[
 RowBox[{
  RowBox[{"Ex", " ", ":=", " ", 
   RowBox[{"\[ImaginaryI]", " ", 
    SqrtBox[
     FractionBox[
      RowBox[{"h", " ", "\[Omega]"}], 
      RowBox[{"2", " ", 
       SubscriptBox["\[Epsilon]", "0"], " ", "V"}]]], 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"a", " ", 
       RowBox[{"Exp", "[", 
        RowBox[{"\[ImaginaryI]", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{"Dot", "[", 
            RowBox[{"k", ",", "r"}], "]"}], "-", 
           RowBox[{"\[Omega]", " ", "t"}]}], ")"}]}], "]"}]}], "-", 
      RowBox[{
       SuperscriptBox["a", "\[Dagger]"], 
       RowBox[{"Exp", "[", 
        RowBox[{
         RowBox[{"-", "\[ImaginaryI]"}], 
         RowBox[{"(", 
          RowBox[{
           RowBox[{"Dot", "[", 
            RowBox[{"k", ",", "r"}], "]"}], "-", 
           RowBox[{"\[Omega]", " ", "t"}]}], ")"}]}], "]"}]}]}], ")"}]}]}], 
  ";"}]], "Input",
 CellChangeTimes->{{3.930238955349174*^9, 3.930238957600128*^9}, {
  3.930239003982691*^9, 3.930239042572607*^9}, {3.933954918725052*^9, 
  3.933954923326961*^9}, {3.9537341482341404`*^9, 3.9537341589235992`*^9}, {
