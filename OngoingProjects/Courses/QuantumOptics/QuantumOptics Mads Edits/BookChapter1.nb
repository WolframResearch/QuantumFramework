Cell[CellGroupData[{

Cell["Quantization of a single mode field", "Subsection",
 CellChangeTimes->{{3.9301378405803437`*^9, 3.930137848464155*^9}, 
   3.965153094566614*^9},
 CellID->53355393,ExpressionUUID->"6a1ffa9d-3c0b-3c48-9014-1c9bf0bbac46"],

Cell[TextData[{
 "The opening example that you usually find in most quantum textbook is the \
particle-in-a-box. In quantum optics, the \
\[OpenCurlyDoubleQuote]1-dimensional cavity along an axis such as ",
 Cell[BoxData[
  FormBox["z", TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "23e05677-8aa5-4fdb-89f6-ff02e5511b43"],
 "\[CloseCurlyDoubleQuote] is basically the simplest physical situation where \
all the core ideas show up clearly, without the messiness of real 3D \
geometry, complicated materials, or boundaries."
}], "Text",
 CellID->2081977860,ExpressionUUID->"15cb3d20-d177-4172-b4a6-581220912917"],

Cell[TextData[{
 "Let\[CloseCurlyQuote]s begin with a 1-dimensional cavity along the ",
 Cell[BoxData[
  FormBox["z", TraditionalForm]],ExpressionUUID->
  "b5608b46-ab59-48fb-9fc7-28d3b9d7e9d6"],
 " axis with perfectly conducting walls at ",
 Cell[BoxData[
  FormBox[
   RowBox[{"z", "=", "0"}], TraditionalForm]],ExpressionUUID->
  "ecb15376-f636-4689-8d56-ac5383244962"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{"z", "=", "L"}], TraditionalForm]],ExpressionUUID->
  "aa68c142-0bf9-4451-affc-bf072f1da80a"],
 " (two idea mirrors facing each other). We consider an empty cavity with no \
charges or currents. Because electromagnetic radiation is transverse, there \
are two independent polarization families; to keep the model minimal we \
choose a single polarization, say along ",
 Cell[BoxData[
  FormBox["x", TraditionalForm]],ExpressionUUID->
  "26a1dd2d-462c-46e2-841d-309a835405f4"],
 ", so the electric field can be written as a fixed unit vector ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["e", "x"], TraditionalForm]],ExpressionUUID->
  "6613a8a3-8be8-4af1-a98f-984b813f6cea"],
 "  times a scalar amplitude that depends only on ",
 Cell[BoxData[
  FormBox["z", TraditionalForm]],ExpressionUUID->
  "81517ab5-15c3-4207-baa8-07b5669fb873"],
 " and ",
 Cell[BoxData[
  FormBox["t", TraditionalForm]],ExpressionUUID->
  "c2cd041d-4190-42a2-85ac-e17aac318a47"],
 ". So one gets ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"E", "(", 
     RowBox[{"r", ",", "t"}], ")"}], " ", "=", 
    RowBox[{
     RowBox[{
      SubscriptBox["e", "x"], " ", 
      SubscriptBox["E", "x"], " ", 
      RowBox[{"(", 
       RowBox[{"z", ",", "t"}], ")"}]}], "=", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{
        SubscriptBox["E", "x"], " ", 
        RowBox[{"(", 
         RowBox[{"z", ",", "t"}], ")"}]}], ",", "0", ",", "0"}], "}"}]}]}], 
   TraditionalForm]],ExpressionUUID->"9d4eaf91-7806-4bb5-a921-3e6e048150f1"],
 " . From Maxwell\[CloseCurlyQuote]s equations, Gauss for electric field, ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"\[Del]", ".", "E"}], "=", "0"}], TraditionalForm]],
  ExpressionUUID->"0479cbaf-9a9a-4de9-83ed-93462a12b441"],
 ", is automatically satisfied."
}], "Text",
 CellID->2138895035,ExpressionUUID->"640ad0be-414d-4d6a-b535-7d5c963f5199"],

Cell[TextData[{
 "Confirm that ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"\[Del]", ".", "E"}], "=", "0"}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "985089a7-0ef9-4970-bc90-257817ed843f"],
 " is automatically satisfied for the ansatz ",
 Cell[BoxData[
  FormBox[
   RowBox[{"E", 
    RowBox[{"(", 
     RowBox[{"r", ",", "t"}], ")"}], " "}], TraditionalForm]],ExpressionUUID->
  "4e9b3811-33b6-4b80-9e1d-e58cb956f3c2"],
 " = ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["e", "x"], " ", 
    SubscriptBox["E", "x"], " ", 
    RowBox[{"(", 
     RowBox[{"z", ",", "t"}], ")"}]}], TraditionalForm]],ExpressionUUID->
  "12241a4e-08ed-48dc-baac-7c30b5f56924"],
 ":"
}], "Text",
 CellID->1072286949,ExpressionUUID->"c6b8e45e-1324-43dc-9d0d-9418308e71a6"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{"ClearAll", "[", "Ex", "]"}], "\[IndentingNewLine]", 
 RowBox[{"Div", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{"Ex", "[", 
      RowBox[{"z", ",", "t"}], "]"}], ",", "0", ",", "0"}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{"x", ",", "y", ",", "z"}], "}"}]}], "]"}]}], "Input",
 CellLabel->"In[26]:=",
 CellID->570706554,ExpressionUUID->"b4683372-cecf-4cb7-8c56-21fb6916c68a"],

Cell[BoxData["0"], "Output",
 CellLabel->"Out[27]=",
 CellID->1787004280,ExpressionUUID->"d9b2cca5-24b5-416c-a1b6-87d791711605"]
}, Open  ]],

Cell[TextData[{
 "The left-hand-side of Faraday equation, ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"\[Del]", "\[Times]", "E"}], "=", 
    RowBox[{"-", 
     RowBox[{
      SubscriptBox["\[PartialD]", "t"], "B"}]}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "ef36e60c-1cc2-41c4-8d0a-ea21f799a11a"],
 ", implies that the magnetic field contains only ",
 Cell[BoxData[
  FormBox["y", TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "19a924e2-da75-4e3d-9751-73f38b050be2"],
 "-component (",
 Cell[BoxData[
  FormBox[
   RowBox[{"B", "=", 
    RowBox[{"{", 
     RowBox[{"0", ",", 
      RowBox[{
       SubscriptBox["B", "y"], "(", 
       RowBox[{"z", ",", "t"}], ")"}], ",", "0"}], "}"}]}], TraditionalForm]],
  
  FormatType->TraditionalForm,ExpressionUUID->
  "9bd04124-252d-42d0-b1dd-18f91229fd3e"],
 "):"
}], "Text",
 CellID->108660529,ExpressionUUID->"e95b8d4f-8123-4ced-a473-65218eb303c9"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Curl", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{"Ex", "[", 
      RowBox[{"z", ",", "t"}], "]"}], ",", "0", ",", "0"}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{"x", ",", "y", ",", "z"}], "}"}]}], "]"}]], "Input",
 CellLabel->"In[29]:=",
 CellID->1448282455,ExpressionUUID->"da9bca30-5760-485d-a501-7b7478af9dbd"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"0", ",", 
   RowBox[{
    SuperscriptBox["Ex", 
     TagBox[
      RowBox[{"(", 
       RowBox[{"1", ",", "0"}], ")"}],
      Derivative],
     MultilineFunction->None], "[", 
    RowBox[{"z", ",", "t"}], "]"}], ",", "0"}], "}"}]], "Output",
 CellLabel->"Out[29]=",
 CellID->234598003,ExpressionUUID->"c734c48e-650d-409a-94cc-69cfa9bfa3b0"]
}, Open  ]],

Cell[TextData[{
 "Then the Gauss equation for magnetic field, ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"\[Del]", ".", "B"}], "=", "0"}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "a298eff6-e832-42e6-bf18-23b19256ddb5"],
 " is also automatically satisfied:"
}], "Text",
 CellID->1909985346,ExpressionUUID->"f89e7313-e774-4f37-89eb-e132a2194520"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{"ClearAll", "[", "By", "]"}], "\[IndentingNewLine]", 
 RowBox[{"Div", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"0", ",", 
     RowBox[{"By", "[", 
      RowBox[{"z", ",", "t"}], "]"}], ",", "0"}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{"x", ",", "y", ",", "z"}], "}"}]}], "]"}]}], "Input",
 CellLabel->"In[30]:=",
 CellID->1812694742,ExpressionUUID->"3bac2e42-9238-41d7-a848-34ada80678bc"],

Cell[BoxData["0"], "Output",
 CellLabel->"Out[31]=",
 CellID->1226077785,ExpressionUUID->"e71957e0-2fce-4210-8160-e72a8a4b38f3"]
}, Open  ]],

Cell[TextData[{
 "Therefore all four Maxwell equations reduce to two coupled first-order \
PDEs: ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox["\[PartialD]", "z"], 
     RowBox[{
      SubscriptBox["E", "x"], "(", 
      RowBox[{"z", ",", "t"}], ")"}]}], "=", 
    RowBox[{"-", 
     RowBox[{
      SubscriptBox["\[PartialD]", "t"], 
      RowBox[{
       SubscriptBox["B", "y"], "(", 
       RowBox[{"z", ",", "t"}], ")"}]}]}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "dd342b5f-ee9d-4d26-853d-d17d0b12f605"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"-", 
     RowBox[{
      SubscriptBox["\[PartialD]", "z"], 
      RowBox[{
       SubscriptBox["B", "y"], "(", 
       RowBox[{"z", ",", "t"}], ")"}]}]}], "=", 
    RowBox[{
     SubscriptBox["\[Mu]", "0"], 
     SubscriptBox["\[Epsilon]", "0"], 
     RowBox[{
      SubscriptBox["\[PartialD]", "t"], 
      RowBox[{
       SubscriptBox["E", "x"], "(", 
       RowBox[{"z", ",", "t"}], ")"}]}]}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "d66a0516-73ee-451a-9fa3-6db61369a202"],
 ". In other words, you started with four vector equations, but symmetry + \
transversality collapses them to two scalar dynamical relations, exactly one \
propagating degree of freedom (per polarization). From these equations, one \
can get standard wave equations ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox["\[PartialD]", 
      RowBox[{"t", ",", "t"}]], 
     SubscriptBox["E", "x"]}], "=", 
    RowBox[{
     SuperscriptBox["c", "2"], 
     RowBox[{
      SubscriptBox["\[PartialD]", 
       RowBox[{"z", ",", "z"}]], 
      SubscriptBox["E", "x"]}]}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "c0d2a8ef-f469-40a0-ada3-63f15a975d15"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox["\[PartialD]", 
      RowBox[{"t", ",", "t"}]], 
     SubscriptBox["B", "y"]}], "=", 
    RowBox[{
     SuperscriptBox["c", "2"], 
     RowBox[{
      SubscriptBox["\[PartialD]", 
       RowBox[{"z", ",", "z"}]], 
      SubscriptBox["B", "y"]}]}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "292149a9-d998-42ce-8718-adcaecd0788e"],
 "."
}], "Text",
 CellID->501522245,ExpressionUUID->"1f5211f9-205d-48c5-8d05-2232b34f0064"],

Cell[TextData[{
 "For ideal mirrors at ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"z", "=", "0"}], ",", "L"}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "a80405a0-5f78-4c43-8710-80307193d4f1"],
 ", the tangential electric field must vanish at the surface. Since \|01d438 \
is along x (tangential at those planes) the boundary conditions imply: ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox["E", "x"], "(", 
     RowBox[{"0", ",", "t"}], ")"}], "=", 
    RowBox[{
     RowBox[{
      SubscriptBox["E", "x"], "(", 
      RowBox[{"L", ",", "t"}], ")"}], "=", "0"}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "7b883964-8bb7-45ac-937b-8f7c505bd4f1"],
 ". The boundary conditions of electric field automatically imply ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox["\[PartialD]", "z"], 
     RowBox[{
      SubscriptBox["B", "y"], "(", 
      RowBox[{"0", ",", "t"}], ")"}]}], "=", 
    RowBox[{
     RowBox[{
      SubscriptBox["\[PartialD]", "z"], 
      RowBox[{
       SubscriptBox["B", "y"], "(", 
       RowBox[{"L", ",", "t"}], ")"}]}], "=", "0"}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "483ded99-0ec1-4d6b-9eee-d63db894fac7"],
 "."
}], "Text",
 CellID->132006021,ExpressionUUID->"5ade4599-8262-a24c-b2b2-936a1b8af2b0"],

Cell["Solve wave equation for the electric field:", "Text",
 CellID->1851764381,ExpressionUUID->"e02a9ea2-79ae-4842-a4a8-1947faeed667"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"DSolveValue", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{
      RowBox[{"D", "[", 
       RowBox[{
        RowBox[{"Ex", "[", 
         RowBox[{"z", ",", "t"}], "]"}], ",", 
        RowBox[{"{", 
         RowBox[{"t", ",", "2"}], "}"}]}], "]"}], "==", 
      RowBox[{
       SuperscriptBox["c", "2"], 
       RowBox[{"D", "[", 
        RowBox[{
         RowBox[{"Ex", "[", 
          RowBox[{"z", ",", "t"}], "]"}], ",", 
         RowBox[{"{", 
          RowBox[{"z", ",", "2"}], "}"}]}], "]"}]}]}], ",", 
     RowBox[{
      RowBox[{"Ex", "[", 
       RowBox[{"0", ",", "t"}], "]"}], "==", "0"}], ",", 
     RowBox[{
      RowBox[{"Ex", "[", 
       RowBox[{"L", ",", "t"}], "]"}], "==", "0"}]}], "}"}], ",", 
   RowBox[{"Ex", "[", 
    RowBox[{"z", ",", "t"}], "]"}], ",", 
   RowBox[{"{", 
    RowBox[{"z", ",", "t"}], "}"}], ",", 
   RowBox[{"Assumptions", "->", 
    RowBox[{
     RowBox[{"c", ">", "0"}], "&&", 
     RowBox[{"L", ">", "0"}]}]}]}], "]"}]], "Input",
 CellLabel->"In[56]:=",
 CellID->1652204063,ExpressionUUID->"b59c8305-ca7d-498c-9443-169c0718de02"],

Cell[BoxData[
 TagBox[GridBox[{
    {"\[Piecewise]", GridBox[{
       {
        TemplateBox[{
          RowBox[{
            SqrtBox["2"], " ", 
            SqrtBox[
             FractionBox["1", "L"]], " ", 
            RowBox[{"(", 
              RowBox[{
                RowBox[{
                  RowBox[{"Cos", "[", 
                    FractionBox[
                    RowBox[{"c", " ", "\[Pi]", " ", "t", " ", 
                    RowBox[{"K", "[", "1", "]"}]}], "L"], "]"}], " ", 
                  RowBox[{
                    SubsuperscriptBox["\[Integral]", "0", "L"], 
                    RowBox[{
                    RowBox[{
                    SqrtBox["2"], " ", 
                    SqrtBox[
                    FractionBox["1", "L"]], " ", 
                    RowBox[{"Ex", "[", 
                    RowBox[{"z", ",", "0"}], "]"}], " ", 
                    RowBox[{"Sin", "[", 
                    FractionBox[
                    RowBox[{"\[Pi]", " ", "z", " ", 
                    RowBox[{"K", "[", "1", "]"}]}], "L"], "]"}]}], 
                    RowBox[{"\[DifferentialD]", "z"}]}]}]}], "+", 
                FractionBox[
                 RowBox[{"L", " ", 
                   RowBox[{"(", 
                    RowBox[{
                    SubsuperscriptBox["\[Integral]", "0", "L"], 
                    RowBox[{
                    FractionBox[
                    RowBox[{
                    SqrtBox["2"], " ", 
                    RowBox[{"Sin", "[", 
                    FractionBox[
                    RowBox[{"\[Pi]", " ", "z", " ", 
                    RowBox[{"K", "[", "1", "]"}]}], "L"], "]"}], " ", 
                    RowBox[{
                    SuperscriptBox["Ex", 
                    TagBox[
                    RowBox[{"(", 
                    RowBox[{"0", ",", "1"}], ")"}], Derivative], 
                    MultilineFunction -> None], "[", 
                    RowBox[{"z", ",", "0"}], "]"}]}], 
                    SqrtBox["L"]], 
                    RowBox[{"\[DifferentialD]", "z"}]}]}], ")"}], " ", 
                   RowBox[{"Sin", "[", 
                    FractionBox[
                    RowBox[{"c", " ", "\[Pi]", " ", "t", " ", 
                    RowBox[{"K", "[", "1", "]"}]}], "L"], "]"}]}], 
                 RowBox[{"c", " ", "\[Pi]", " ", 
                   RowBox[{"K", "[", "1", "]"}]}]]}], ")"}], " ", 
            RowBox[{"Sin", "[", 
              FractionBox[
               RowBox[{"\[Pi]", " ", "z", " ", 
                 RowBox[{"K", "[", "1", "]"}]}], "L"], "]"}]}], 
          RowBox[{"K", "[", "1", "]"}], "1", "\[Infinity]"},
         "InactiveSum",
         DisplayFunction->(RowBox[{
            UnderoverscriptBox[
             StyleBox["\[Sum]", "Inactive"], 
             RowBox[{#2, "=", #3}], #4], #}]& ),
         InterpretationFunction->(RowBox[{
            RowBox[{"Inactive", "[", "Sum", "]"}], "[", 
            RowBox[{#, ",", 
              RowBox[{"{", 
                RowBox[{#2, ",", #3, ",", #4}], "}"}]}], "]"}]& )], 
        RowBox[{
         RowBox[{
          RowBox[{"K", "[", "1", "]"}], "\[Element]", 
          TemplateBox[{},
           "Integers"]}], "&&", 
         RowBox[{
          RowBox[{"K", "[", "1", "]"}], "\[GreaterEqual]", "1"}]}]},
       {"Indeterminate", 
        TagBox["True",
         "PiecewiseDefault",
         AutoDelete->True]}
      },
