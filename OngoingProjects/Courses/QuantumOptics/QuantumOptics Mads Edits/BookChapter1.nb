Cell[TextData[{
 "The creation and annihilation operators are non-Hermitian and obey the \
commutator ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"[", 
     RowBox[{
      OverscriptBox["a", "^"], ",", 
      SuperscriptBox[
       OverscriptBox["a", "^"], "\[Dagger]"]}], "]"}], "=", "1"}], 
   TraditionalForm]],ExpressionUUID->"b24d0c20-9ea3-492d-bb6e-c50186dc1d56"],
 ". In the truncated space the commutator deviates at the edge (note the last \
diagonal element), which is one manifestation of truncation error."
}], "Text",
 CellID->323651212,ExpressionUUID->"3e9db934-504a-1949-8107-06dd52995dd2"],

Cell["\<\
Compute the commutator of the annihilation and creation operators:\
\>", "Text",
 CellID->1510092863,ExpressionUUID->"2deb6af4-076c-4ffd-8a9c-0ec768caab5a"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"Commutator", "[", 
   RowBox[{"a", ",", 
    SuperscriptBox["a", "\[Dagger]"]}], "]"}], "//", 
  "TraditionalForm"}]], "Input",
 CellLabel->"In[73]:=",
