         "your", " ", "picture"}], "*)"}], 
       RowBox[{"labelsR", "=", 
        RowBox[{"Table", "[", 
         RowBox[{
          RowBox[{"Text", "[", 
           RowBox[{
            RowBox[{"Style", "[", 
             RowBox[{
              RowBox[{"TraditionalForm", "[", 
               RowBox[{
                RowBox[{"(", 
                 RowBox[{
                  RowBox[{"2", " ", "k"}], "+", "1"}], ")"}], " ", 
                RowBox[{"\[HBar]\[Omega]", "/", "2"}]}], "]"}], ",", "16", ",",
               "blue"}], "]"}], ",", 
            RowBox[{"{", 
             RowBox[{
              RowBox[{
               RowBox[{"xT", "[", "k", "]"}], "+", "1.0"}], ",", 
              RowBox[{"En", "[", "k", "]"}]}], "}"}]}], "]"}], ",", 
          RowBox[{"{", 
           RowBox[{"k", ",", "0", ",", "nSolid"}], "}"}]}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"Show", "[", 
        RowBox[{
         RowBox[{"Plot", "[", 
          RowBox[{
           RowBox[{"V", "[", "x", "]"}], ",", 
           RowBox[{"{", 
            RowBox[{"x", ",", 
             RowBox[{"-", "xmax"}], ",", "xmax"}], "}"}], ",", 
           RowBox[{"PlotStyle", "->", 
