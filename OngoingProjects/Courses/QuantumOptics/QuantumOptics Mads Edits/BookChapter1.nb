Cell[TextData[{
 "As one can see, the generic result as the form ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox["E", "x"], "(", 
     RowBox[{"z", ",", "t"}], ")"}], "=", 
    RowBox[{
     UnderoverscriptBox["\[Sum]", 
      RowBox[{"n", "=", "1"}], "\[Infinity]"], 
     RowBox[{
      RowBox[{
       SubscriptBox["q", "n"], "(", "t", ")"}], " ", 
      RowBox[{"sin", "(", 
       RowBox[{
        FractionBox[
         RowBox[{"n", " ", "\[Pi]"}], "L"], "z"}], ")"}]}]}]}], 
   TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "fbdbd26d-3bbc-4709-b831-714d7513b5aa"],
 " where ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox["q", "n"], "(", "t", ")"}], " "}], TraditionalForm]],
  ExpressionUUID->"2ba079fc-3368-49f4-8be4-a8b997fe3e62"],
 " is a time-dependent canonical coordinate of the mode ",
 Cell[BoxData[
  FormBox["n", TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "281b96f2-f571-498c-a655-7497018c8639"],
 ". The terms ",
 Cell[BoxData[
  FormBox[
   RowBox[{"sin", "(", 
    RowBox[{
     SubscriptBox["k", "n"], "z"}], ")"}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "4faab1e7-b889-4ea7-a189-6f733bd94af4"],
 " with the wave number ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["k", "n"], "=", 
    RowBox[{"n", " ", 
     RowBox[{"\[Pi]", "/", "L"}]}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "7254b1cd-5a03-4263-a764-44ea387a23cd"],
 " are the spatial mode function of the cavity, i.e. a standing-wave \
eigenfunction (or normal mode) in the ",
 Cell[BoxData[
  FormBox["z", TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "81623d46-b507-4a2f-8f2c-d41a3704bb90"],
 "-direction."
}], "Text",
 CellID->1259862085,ExpressionUUID->"1626e88c-e3ba-44ee-9df6-984946e51e5d"],

