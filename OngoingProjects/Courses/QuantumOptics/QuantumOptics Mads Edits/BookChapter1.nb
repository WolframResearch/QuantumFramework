Cell[TextData[{
 "The trigonometric identity cos^2 + sin^2 = 1 has an analogous operator \
form, except for a vacuum term ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SuperscriptBox[
      OverscriptBox["C", "^"], 
      RowBox[{" ", "2"}]], "+", 
     SuperscriptBox[
      OverscriptBox["S", "^"], 
      RowBox[{" ", "2"}]]}], " ", "=", 
    RowBox[{"1", "-", 
     RowBox[{
      FractionBox["1", "2"], Cell[
      "|0\[RightAngleBracket]",ExpressionUUID->
       "46bdd38c-f550-9847-baa1-5e9e42f0683d"], Cell[
      "\[LeftAngleBracket]0|",ExpressionUUID->
       "9dfdb1ef-7c2e-d946-9fb7-7cfd4368b5d7"]}]}]}], TraditionalForm]], 
  "Text",ExpressionUUID->"da3d0941-93b4-7840-8b0e-06e13f1925eb"],
 " (and a small truncation error in the last term):"
}], "Text",
 CellChangeTimes->{{3.9314497618648205`*^9, 3.9314497854794807`*^9}, {
  3.9314498164347553`*^9, 3.9314499389594555`*^9}, {3.965157336410887*^9, 
  3.965157346083885*^9}, {3.971453969265772*^9, 3.971453985746771*^9}},
 CellID->346309539,ExpressionUUID->"d3194428-a90b-a749-a9a9-0294fc666f20"],

