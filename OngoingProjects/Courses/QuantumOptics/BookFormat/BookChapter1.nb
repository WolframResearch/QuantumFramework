Cell[BoxData[Cell[TextData[{
  Cell[BoxData[
   FormBox[
    RowBox[{"Z", "=", " ", 
     UnderscriptBox[
      OverscriptBox[
       StyleBox[
        OverscriptBox["\[Sum]", " "],
        FontWeight->"Bold"], "\[Infinity]"], 
      RowBox[{"n", " ", "=", "0"}]]}], TraditionalForm]],ExpressionUUID->
   "770c8e06-71d6-5247-9a62-ccdc3366f904"],
  "\[LeftAngleBracket]",
  Cell[BoxData[
   FormBox["n", TraditionalForm]],ExpressionUUID->
   "3edfefeb-2284-a649-a544-915f69988925"],
  "|",
  Cell[BoxData[
   FormBox[
    RowBox[{"exp", "(", 
     RowBox[{
      RowBox[{
       RowBox[{"-", 
        OverscriptBox["H", "^"]}], "/", 
       SubscriptBox["k", "B"]}], "T"}], ")"}], TraditionalForm]],
   ExpressionUUID->"f918cfd8-1dbf-0e4b-8731-645af25c416f"],
  "|",
  Cell[BoxData[
   FormBox[
    RowBox[{
     RowBox[{"n", "\[RightAngleBracket]"}], "=", " ", 
     RowBox[{
      UnderscriptBox[
       OverscriptBox[
