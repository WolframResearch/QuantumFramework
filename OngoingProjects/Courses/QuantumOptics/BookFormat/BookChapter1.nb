Cell[TextData[{
 "The trigonometric identity ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox["cos", "2"], "x"}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "677de80c-be0a-0941-ab2e-e68f70afb2df"],
 " + ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox["sin", "2"], "x"}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "a219bb70-0fae-1c42-983d-ca7ce0d1a39c"],
 " = 1 has similar form using ",
 Cell[BoxData[
  FormBox[
   OverscriptBox["C", "^"], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "5eb0ac17-e966-9a4b-b54b-efbcd07fc470"],
 " and ",
 Cell[BoxData[
  FormBox[
   OverscriptBox["S", "^"], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "0e4fc631-1e5b-d848-bd3e-1358a35d037e"],
 ", except for a vacuum term ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SuperscriptBox[
      OverscriptBox["C", "^"], "2"], "+", 
     SuperscriptBox[
      OverscriptBox["S", "^"], "2"]}], "=", 
    RowBox[{
     StyleBox["1",
      FontSize->24], 
     StyleBox["-",
      FontSize->24], 
     FractionBox["1", "2"]}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "7c22d866-c0ce-7b47-a990-a8cd9cf0eadb"],
 Cell[BoxData[
  FormBox["|", TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "02b110ae-f8fc-df4e-bf0b-17eeacd96fa4"],
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"0", "\[RightAngleBracket]"}], 
    RowBox[{"\[LeftAngleBracket]", "0"}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "bb188bb4-550e-b74e-9cec-cd8121eb8eaa"],
 Cell[BoxData[
  FormBox["|", TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "121aa83e-75a3-2c43-a615-cc9cc6029fc7"],
 " , and in the finite basis representation truncation error appears in the \
last term:"
}], "Text",
 CellID->346309539,ExpressionUUID->"d3194428-a90b-a749-a9a9-0294fc666f20"],

