Cell[TextData[{
 "Conversely, the ",
 Cell[BoxData[
  FormBox["n", TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "adc5af33-39b4-4c31-9185-c0b0c49b9c13"],
 "-th Fock state can be constructed from the vacuum as follows:"
}], "Text",
 CellID->1568044885,ExpressionUUID->"e8fe3c2e-fe8a-46c7-be58-f10de12889bf"],

Cell[BoxData[
 RowBox[{" ", 
  StyleBox[Cell[TextData[{
    "|",
    Cell[BoxData[
     FormBox[
      RowBox[{
       RowBox[{"n", "\[RightAngleBracket]"}], "=", 
       StyleBox[
        FractionBox[
         SuperscriptBox[
          RowBox[{"(", 
           SuperscriptBox[
            OverscriptBox["a", "^"], "\[Dagger]"], ")"}], "n"], 
         SqrtBox[
          RowBox[{"n", "!"}]]],
        FontSize->24]}], TraditionalForm]],ExpressionUUID->
     "09d1d079-68c3-6349-814a-d03b96d03cef"],
    "|",
    Cell[BoxData[
     FormBox[
      RowBox[{"0", "\[RightAngleBracket]"}], TraditionalForm]],ExpressionUUID->
     "23bce681-353e-c743-ab6b-8c4028f39b41"]
   }], "Text",ExpressionUUID->"78ff1f8b-94d1-fb42-9316-0253f2416b0c"], 
   "CodeText"]}]], "DisplayFormula",
 FontSize->18,
 CellID->522614731,ExpressionUUID->"9f6c85da-1faa-614d-a301-2ab6d0320f08"],

Cell["Verify the relation above:", "Text",
 CellChangeTimes->{{3.9695614651306477`*^9, 3.969561474196035*^9}},
 CellID->140086052,ExpressionUUID->"14aa108b-7f75-412d-9b03-6c9fc5af4581"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{
   FractionBox[
    SuperscriptBox[
     RowBox[{"(", 
      SuperscriptBox["a", "\[Dagger]"], ")"}], "n"], 
    SqrtBox[
     RowBox[{"n", "!"}]]], "@", 
   RowBox[{"FockState", "[", "0", "]"}]}], " ", "==", " ", 
  RowBox[{"FockState", "[", "n", "]"}]}]], "Input",
 CellChangeTimes->{{3.9344022953369083`*^9, 3.934402329617464*^9}, {
  3.953732606256687*^9, 3.953732615151417*^9}},
 CellLabel->"In[29]:=",
 CellID->530829014,ExpressionUUID->"7e76c346-1042-7844-a544-b16c0becc253"],

Cell[BoxData["True"], "Output",
 CellLabel->"Out[29]=",
 CellID->255007,ExpressionUUID->"442a86c2-d0f9-5048-934f-e5960f5436c5"]
}, Open  ]],

Cell["Define the photon-number operator (an observable):", "Text",
 CellChangeTimes->{{3.9248772734692326`*^9, 3.924877287828541*^9}, {
   3.927906675011785*^9, 3.927906678832299*^9}, {3.927910896570865*^9, 
   3.9279109009617653`*^9}, 3.928256517987934*^9, 3.9302324565569115`*^9, {
   3.969561482712605*^9, 3.9695614861310043`*^9}},
 CellID->60558424,ExpressionUUID->"d83d1c4d-ca46-964b-a97a-78baade46004"],

Cell[BoxData[
 RowBox[{"numberOp", ":=", 
  RowBox[{
   SuperscriptBox["a", "\[Dagger]"], "@", " ", "a"}]}]], "Input",
 CellChangeTimes->{{3.924691464086172*^9, 3.924691520777363*^9}, {
  3.924691591484843*^9, 3.9246916606612606`*^9}, {3.925122746755462*^9, 
  3.925122747192772*^9}, {3.9301484481711407`*^9, 3.930148473658407*^9}, {
  3.9301485719008007`*^9, 3.930148575620529*^9}, {3.933954588328438*^9, 
  3.933954652325661*^9}, {3.934042427727779*^9, 3.934042460401836*^9}, {
  3.934042517954012*^9, 3.9340425364388285`*^9}, {3.9344023888527937`*^9, 
  3.934402389049616*^9}},
 CellLabel->"In[39]:=",
 CellID->21509498,ExpressionUUID->"6858252e-6091-444c-bb44-31f59a2aba3d"],

Cell[TextData[{
 "Verify ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox[
     OverscriptBox["a", "^"], "\[Dagger]"], 
    OverscriptBox["a", "^"]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "13ac6057-346e-9142-8fc4-a8da41149a21"],
 "|",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"n", "\[RightAngleBracket]"}], "=", "n"}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "c131a8df-79ac-6b48-90b9-2b51996a675f"],
 "|",
 Cell[BoxData[
  FormBox[
   RowBox[{"n", "\[RightAngleBracket]"}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "85f484a2-956f-1c4e-901c-7e070bf0dfd1"],
 ":"
}], "Text",
 CellID->256872373,ExpressionUUID->"83f6e6a3-bcbb-2e46-aa17-f098478be9c1"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"numberOp", " ", "@", " ", 
   RowBox[{"FockState", "[", "n", "]"}]}], " ", "==", " ", 
  RowBox[{"n", " ", 
   RowBox[{"FockState", "[", "n", "]"}]}]}]], "Input",
 CellChangeTimes->{{3.934402392696373*^9, 3.934402401166301*^9}, {
  3.953733029866392*^9, 3.9537330520882893`*^9}},
