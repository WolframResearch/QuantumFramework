  RowBox[{"Table", "[", 
   RowBox[{
    RowBox[{
     RowBox[{"ThermalState", "[", "x", "]"}], "[", 
     RowBox[{"\"\<ProbabilitiesPlot\>\"", ",", 
      InterpretationBox[
       DynamicModuleBox[{Typeset`open = False}, 
