 CellID->31324677,ExpressionUUID->"5fa913e3-92e2-9841-9b4a-053934e6788c"],

Cell["\<\
This distribution can be used to compute averages of functions of \[Phi].\
\>", "Text",
 CellChangeTimes->{3.9652136030789413`*^9},
 CellID->140744982,ExpressionUUID->"fbb34fae-f7b5-224c-9e21-407248ce58f4"],

Cell[BoxData[
 FormBox[
  RowBox[{
   RowBox[{"\[LeftAngleBracket]", 
    RowBox[{"f", "(", "\[Phi]", ")"}], "\[RightAngleBracket]"}], "=", 
   RowBox[{
    SubsuperscriptBox["\[Integral]", "0", 
     RowBox[{"2", "\[Pi]"}]], 
    RowBox[{
     RowBox[{"f", "(", "\[Phi]", ")"}], " ", 
     RowBox[{"\[ScriptCapitalP]", "(", "\[Phi]", ")"}], 
     RowBox[{"\[DifferentialD]", "\[Phi]"}]}]}]}], 
  TraditionalForm]], "DisplayFormula",
 CellID->670935116,ExpressionUUID->"6cabb0e4-92cb-f74d-a1c6-79a5983a05df"],

Cell[TextData[{
 "For any number state |",
 Cell[BoxData[
  FormBox["n", TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "d6d29ddb-fefb-0844-9a2f-1236d52ec4dc"],
 "\[RightAngleBracket] the phase distribution is uniform, \[ScriptCapitalP](\
\[Phi]) = 1/(2\[Pi]). It has mean \[Pi] and fluctuations ",
 Cell[BoxData[
  FormBox["\[CapitalDelta]\[Phi]", TraditionalForm]],ExpressionUUID->
  "62fc721f-c31b-e44e-aa6f-34de9400b769"],
 " = ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Pi]", "/", 
    SqrtBox["3"]}], TraditionalForm]],ExpressionUUID->
  "ad1d4e51-c5dc-2d43-8b45-d801ab589f2f"],
 ". This holds for all number states, including the vacuum."
}], "Text",
 CellID->336549743,ExpressionUUID->"f9e642eb-4470-754b-a1c7-90c4ca18af9b"],

