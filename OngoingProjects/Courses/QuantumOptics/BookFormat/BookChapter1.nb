Cell["\<\
However, the mean of the squared electric field is not zero; therefore the \
field has nonzero variance for all Fock states:\
\>", "Text",
 CellID->38306157,ExpressionUUID->"f7d922ca-5bfe-fb4e-987c-10d748961b07"],

Cell[BoxData[
 FormBox[
  StyleBox[
   RowBox[{" ", 
    RowBox[{
     RowBox[{"\[LeftAngleBracket]", 
      RowBox[{"n", "|", 
       SuperscriptBox[
        OverscriptBox["E", "^"], "2"], "|", "n"}], "\[RightAngleBracket]"}], "=", 
     RowBox[{
      FractionBox["1", "2"], 
      FractionBox[
       RowBox[{"\[HBar]", " ", "\[Omega]"}], 
       RowBox[{" ", 
        RowBox[{"V", " ", 
         SubscriptBox["\[CurlyEpsilon]", "0"]}]}]], 
      RowBox[{"(", 
       RowBox[{
        RowBox[{"2", "n"}], "+", "1"}], ")"}]}]}]}],
   FontSize->18], TraditionalForm]], "DisplayFormula",
 CellID->30814013,ExpressionUUID->"0d0b5acb-9424-5a40-bb94-72cf95d7177c"],

Cell["Verify the variance relation:", "Text",
 CellID->85171276,ExpressionUUID->"0f100eaa-732d-1b4b-9f68-a5b40f76125a"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"(", 
      RowBox[{
       RowBox[{"#", "[", "\"\<Dagger\>\"", "]"}], "@", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{"Ex", "@", "Ex"}], ")"}], " ", "@", " ", "#"}]}], ")"}], 
     "[", "\"\<Scalar\>\"", "]"}], "&"}], " ", "/@", " ", 
   RowBox[{"Table", "[", 
    RowBox[{
     RowBox[{"FockState", "[", "n", "]"}], ",", 
     RowBox[{"{", 
      RowBox[{"n", ",", "0", ",", 
       RowBox[{"$FockSize", "-", "2"}]}], "}"}]}], "]"}]}], "//", 
  "FullSimplify"}]], "Input",
 CellChangeTimes->{{3.930239600115579*^9, 3.9302396025317*^9}, {
  3.93023969917198*^9, 3.930239699528406*^9}, {3.933954980183679*^9, 
