Cell[TextData[{
 "The phase eigenstates resolve to the identity ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox[
     FractionBox["1", 
      RowBox[{"2", "\[Pi]"}]], " "], 
    SuperscriptBox[
     SubsuperscriptBox["\[Integral]", "0", 
      RowBox[{"2", "\[Pi]"}]], " "]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "97dbcea3-7b25-e242-862f-4df0fca6e293"],
 Cell[BoxData[
  FormBox["|", TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "e29d57d1-eaa3-5145-b072-22f45837cdde"],
 "\[Phi]",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[RightAngleBracket]", 
    RowBox[{"\[LeftAngleBracket]", "\[Phi]"}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "19ef98e5-beeb-cc48-b5fb-196471283a33"],
 Cell[BoxData[
  FormBox["|", TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "35d8e204-5921-f242-b41f-6a52100317aa"],
 " \[DifferentialD]",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Phi]", "=", 
    StyleBox["1",
     FontSize->24]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "af6df1c8-f47a-cd49-a7ac-0f6664aeed72"]
}], "Text",
 CellID->9045586,ExpressionUUID->"f0a3026d-69c8-e84f-ac43-d3c038c12bc6"],

Cell["Compute the phase-eigenstate projectors:", "Text",
 CellChangeTimes->{{3.971454106220743*^9, 3.9714541206352425`*^9}, {
  3.971454216915924*^9, 3.9714542191807137`*^9}},
 CellID->322321442,ExpressionUUID->"84c4ac52-ccc2-d843-958f-38acad1852d1"],

Cell[BoxData[
 RowBox[{
  RowBox[{"phiProj", " ", "=", 
   RowBox[{"FullSimplify", "[", 
    RowBox[{
     RowBox[{"QuantumOperator", "[", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{"phistate", " ", "@", 
         SuperscriptBox["phistate", "\[Dagger]"]}], ")"}], ",", "$FockSize"}],
       "]"}], ",", 
     RowBox[{"Element", "[", 
      RowBox[{"\[Phi]", ",", "Reals"}], "]"}]}], "]"}]}], ";"}]], "Input",
 CellChangeTimes->{{3.931444476106804*^9, 3.93144447742678*^9}, {
   3.931444534848106*^9, 3.9314445783310986`*^9}, {3.931444613838375*^9, 
   3.931444643266405*^9}, {3.931444783104896*^9, 3.9314447898564644`*^9}, 
   3.931445016207098*^9, {3.9340452609971447`*^9, 3.9340452851597195`*^9}, {
   3.953737881073498*^9, 3.9537378887991085`*^9}},
 CellLabel->"In[85]:=",
 CellID->83125948,ExpressionUUID->"3c8028a3-46e8-2540-b7a7-98f209371653"],

Cell["\<\
Verify that integrating the matrix elements yields the identity operator:\
\>", "Text",
 CellID->313029995,ExpressionUUID->"7a3e91a3-50f9-3f4a-aa99-eab22a353c73"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  FormBox[
   RowBox[{"QuantumOperator", "(", 
    RowBox[{
     FractionBox[
      RowBox[{
       SubsuperscriptBox["\[Integral]", "0", 
        RowBox[{"2", " ", "\[Pi]"}]], 
       RowBox[{
        RowBox[{"phiProj", "(", "\"\<Matrix\>\"", ")"}], 
        RowBox[{"\[DifferentialD]", "\[Phi]"}]}]}], 
      RowBox[{"2", " ", "\[Pi]"}]], ",", "$FockSize"}], ")"}],
   TraditionalForm], " ", "==", 
  RowBox[{"QuantumOperator", "[", 
   RowBox[{"\"\<I\>\"", "[", "$FockSize", "]"}], "]"}]}]], "Input",
 CellLabel->"In[87]:=",
 CellID->218103319,ExpressionUUID->"655b2d94-9dab-a745-b0ac-22e9c93eee7e"],

Cell[BoxData["True"], "Output",
 CellLabel->"Out[87]=",
 CellID->95834168,ExpressionUUID->"fdd49fa6-1a52-1943-a33f-f6314f68265d"]
}, Open  ]],

Cell["For a state |\[Psi]\[RightAngleBracket], the phase distribution \
\[ScriptCapitalP](\[Phi]) is computed as:", "Text",
