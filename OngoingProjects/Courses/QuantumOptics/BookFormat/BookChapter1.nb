Cell[CellGroupData[{
Cell[TextData[{
 StyleBox[
 CounterBox["Section"], "Section"],
 StyleBox[" | Field Quantization", "Section"]
}], "Section",
 CellChangeTimes->{
  3.652728456208679*^9, 3.652728527108994*^9, {3.965151169198908*^9, 
   3.965151172933218*^9}},
 CounterAssignments->{{"Section", 0}},
 CellID->499368744,ExpressionUUID->"989a1512-491e-ab47-964c-3c6fc9c2d9e3"],

Cell[TextData[StyleBox["We introduce quantization of the electromagnetic \
field for a single mode using second quantization and show how it is \
implemented in Wolfram Mathematica via the Wolfram Quantum Framework. To make \
computations tractable we work in a truncated Fock space, then build \
operators and states, examine their algebra, and compute basic expectation \
values.", "Abstract"]], "Text",
 CellChangeTimes->{{3.965151223238022*^9, 3.9651512729345226`*^9}, {
  3.965151315779661*^9, 3.96515144582942*^9}, {3.9651515666873913`*^9, 
  3.9651515948158417`*^9}, {3.9651517762376385`*^9, 3.9651517829817944`*^9}, {
  3.965151941327116*^9, 3.965152040501852*^9}, {3.969033541673687*^9, 
  3.9690335640024643`*^9}},
 TextJustification->1.,
 CellID->492392629,ExpressionUUID->"bbed3e3b-5ba3-8d47-83b3-2fe7f5d9ca18"],

Cell[CellGroupData[{

Cell["Key Concepts", "Subsection",
 CellChangeTimes->{{3.957967917860298*^9, 3.9579679223142796`*^9}},
 CellID->1278319,ExpressionUUID->"749eedf4-8609-e84f-900f-98ae7d1de4bf"],

