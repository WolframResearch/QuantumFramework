Cell[TextData[StyleBox["Calculate the commutator of the number operator with \
the annihilation operator (suggested to use non commutative algebra)",
 FontWeight->"Plain"]], "Exercise",
 CellFrame->{{0, 0}, {0, 0.5}},
 CellFrameColor->GrayLevel[0.75],
 CellChangeTimes->{{3.9714550345390224`*^9, 3.971455038596079*^9}, {
  3.971455091176773*^9, 3.9714551037269*^9}, {3.971455145730034*^9, 
  3.971455149758003*^9}, {3.9714556421038933`*^9, 3.9714556573365116`*^9}, {
  3.9714557565179806`*^9, 3.9714557573266907`*^9}},
 FontWeight->"Bold",
 CellID->274948136,ExpressionUUID->"4ad556bb-34b0-694d-94e6-4eb00603da33"],

Cell[CellGroupData[{

Cell["Solution", "ExerciseSolution",
 CellID->75102694,ExpressionUUID->"d4f0ca01-e039-de49-8a13-88ba29b0033b"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"NonCommutativePolynomialReduce", "[", 
   RowBox[{
    RowBox[{"Commutator", "[", 
     RowBox[{
      RowBox[{
       SuperscriptBox["\[FormalA]", "\[Dagger]"], "**", "\[FormalA]"}], ",", 
      "\[FormalA]"}], "]"}], ",", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"Commutator", "[", 
       RowBox[{"\[FormalA]", ",", 
        SuperscriptBox["\[FormalA]", "\[Dagger]"]}], "]"}], "-", "1"}], "}"}],
     ",", 
    RowBox[{"{", 
     RowBox[{"\[FormalA]", ",", 
      SuperscriptBox["\[FormalA]", "\[Dagger]"]}], "}"}]}], "]"}], "[", 
  RowBox[{"[", 
   RowBox[{"-", "1"}], "]"}], "]"}]], "ExerciseInput",
 CellChangeTimes->{{3.9714551803176823`*^9, 3.9714551891856575`*^9}, {
  3.971455284477104*^9, 3.971455364563675*^9}},
 CellLabel->"In[161]:=",
 CellID->200322094,ExpressionUUID->"79d2f286-c8fd-e742-95d6-d830c5806f4e"],

Cell[BoxData[
 RowBox[{"-", "\[FormalA]"}]], "ExerciseOutput",
 CellChangeTimes->{
  3.9714552981541996`*^9, {3.971455360966627*^9, 3.9714553647696877`*^9}},
 CellLabel->"Out[161]=",
 CellID->229409830,ExpressionUUID->"b438a2f0-5dcc-e143-934c-d62b03d4dab4"]
}, Open  ]]
}, Open  ]],

Cell[TextData[{
 "Compute the phase distribution for the state ",
 Cell[BoxData[
  FormBox[
   FractionBox["1", 
    SqrtBox["2"]], TraditionalForm]],ExpressionUUID->
  "e1ab9946-0259-2042-a21e-3d11148afa15"],
 "(|0\[RightAngleBracket] + |1\[RightAngleBracket] ). Is it still uniform? \
Prove it is a proper probability distribution"
}], "Exercise",
 CellFrame->{{0, 0}, {0, 0.5}},
 CellFrameColor->GrayLevel[0.75],
 CellID->243367988,ExpressionUUID->"690f63bc-b42d-6b40-aefb-ff0f24aa062f"],

Cell["Solution", "ExerciseSolution",
 CellID->701135951,ExpressionUUID->"d60eae30-df79-f344-91db-9ec480af8a9b"],

Cell[CellGroupData[{

Cell["Calculate the phase distribution:", "ExerciseNote",
 CellID->217333738,ExpressionUUID->"6a517ec6-4093-d540-9536-7a58cf9a19ea"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  FractionBox["1", 
   RowBox[{"2", "\[Pi]"}]], 
  SuperscriptBox[
   RowBox[{"Abs", "[", 
    RowBox[{
     RowBox[{"(", 
      RowBox[{
       RowBox[{"phistate", "[", "\"\<Dagger\>\"", "]"}], "@", 
       RowBox[{"QuantumState", "[", 
        RowBox[{"\"\<+\>\"", ",", "$FockSize"}], "]"}]}], ")"}], 
     "[", "\"\<Scalar\>\"", "]"}], "]"}], "2"]}]], "ExerciseInput",
 CellChangeTimes->{{3.971457187219248*^9, 3.9714572709944687`*^9}, {
   3.971457324190853*^9, 3.9714573282900486`*^9}, 3.9714574539225254`*^9},
 CellLabel->"In[96]:=",
 CellID->94932940,ExpressionUUID->"ca8bd204-b4c1-1243-90a0-92e340f86a9a"],

Cell[BoxData[
 FormBox[
  FractionBox[
   SuperscriptBox[
    TemplateBox[{
      RowBox[{
        FractionBox[
         SuperscriptBox["\[ExponentialE]", 
          RowBox[{
            RowBox[{"-", "\[ImaginaryI]"}], " ", 
            
            TemplateBox[{"\[Phi]"}, "Conjugate", SyntaxForm -> 
             SuperscriptBox]}]], 
         SqrtBox["2"]], "+", 
        FractionBox["1", 
         SqrtBox["2"]]}]},
     "Abs"], "2"], 
   RowBox[{"2", " ", "\[Pi]"}]], TraditionalForm]], "ExerciseOutput",
 CellChangeTimes->{
  3.9714571890548725`*^9, {3.9714572485703773`*^9, 3.9714572712427807`*^9}, {
   3.971457328679617*^9, 3.971457343117668*^9}, {3.971457434419121*^9, 
   3.971457455069544*^9}, 3.9714576568048325`*^9, {3.973693295040781*^9, 
   3.973693318046425*^9}},
 CellLabel->"Out[96]=",
 CellID->24343962,ExpressionUUID->"49fcb2b6-9b2e-5042-b5d1-5bd3741ac1d9"]
}, Open  ]]
}, Open  ]],

