Cell[CellGroupData[{

Cell[TextData[{
 StyleBox["Calculating the variances of the quadrature operators, without \
loss of generality we take \[Alpha] real, the replacement is to do a plot as \
function of |\[Alpha]", "Exercise"],
 StyleBox[Cell[BoxData[
  FormBox[
   SuperscriptBox["|", "2"], TraditionalForm]], "Exercise",ExpressionUUID->
  "0677ec8a-a64c-ef43-81e9-5567a8fe0a95"], "Exercise"],
 StyleBox[":", "Exercise"]
}], "ExerciseNote",
 CellChangeTimes->{
  3.9736996524487877`*^9, {3.9736996967538776`*^9, 3.9736997127569847`*^9}, {
   3.973700007939293*^9, 3.9737000303230324`*^9}},
 CellID->60966819,ExpressionUUID->"f8d99dd6-4d05-d64b-b50f-6790c539a3da"],

Cell[BoxData[
 RowBox[{
  RowBox[{"variances", " ", "=", 
   RowBox[{
    RowBox[{"FullSimplify", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"(", 
        RowBox[{
         RowBox[{
          RowBox[{"OperatorVariance", "[", 
           RowBox[{"\[Psi]", ",", "#"}], "]"}], "&"}], "/@", 
         RowBox[{"QuadratureOperators", "[", "]"}]}], ")"}], "//.", 
       RowBox[{"{", 
        RowBox[{"\[Beta]", "->", 
         RowBox[{
          SqrtBox[
           RowBox[{"1", "-", 
            SuperscriptBox[
             RowBox[{"Abs", "[", "\[Alpha]", "]"}], "2"]}]], 
          SuperscriptBox["\[ExponentialE]", 
           RowBox[{"\[ImaginaryI]", " ", "\[Phi]"}]]}]}], "}"}]}], ",", 
      RowBox[{
       RowBox[{"Element", "[", 
        RowBox[{
         RowBox[{"{", "\[Phi]", "}"}], ",", "Reals"}], "]"}], "&&", " ", 
       RowBox[{"0", "<", "\[Alpha]", "<=", "1"}]}]}], "]"}], "/.", 
    RowBox[{"\[Alpha]", "->", 
     SqrtBox["x"]}]}]}], ";"}]], "ExerciseInput",
 CellLabel->"In[121]:=",
 CellID->259754128,ExpressionUUID->"5160fb28-2821-6a4c-b008-3e965434b04e"]
}, Open  ]],

Cell[CellGroupData[{

Cell[TextData[{
 StyleBox["Plots of the variances considering ", "Exercise"],
 StyleBox[Cell[BoxData[
  FormBox[
   RowBox[{"\[Phi]", "=", "0"}], TraditionalForm]], "Exercise",ExpressionUUID->
  "b2f45410-d766-784f-b6e1-f2dd668b265d"], "Exercise"],
 StyleBox[", the extreme cases are just the quadrature variances of |0\
\[RightAngleBracket] and |1\[RightAngleBracket]:", "Exercise"]
}], "ExerciseNote",
 CellChangeTimes->{
  3.9736997788073826`*^9, {3.9737000519760494`*^9, 3.973700071756218*^9}},
 CellID->160055362,ExpressionUUID->"4c42b8e6-e2de-b041-ad60-c09fe742210a"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Plot", "[", 
  RowBox[{
   RowBox[{"Evaluate", "[", 
    RowBox[{
     RowBox[{"Append", "[", 
      RowBox[{"variances", ",", 
       SqrtBox[
        RowBox[{"Times", "@@", "variances"}]]}], "]"}], "/.", 
     RowBox[{"\[Phi]", "->", "0"}]}], "]"}], ",", 
   RowBox[{"{", 
    RowBox[{"x", ",", "0", ",", "1"}], "}"}], ",", 
   RowBox[{"PlotRange", "->", "All"}], ",", 
   RowBox[{"PlotLegends", "->", 
    RowBox[{"{", 
     RowBox[{"\"\<\!\(\*SuperscriptBox[SubscriptBox[\(\[CapitalDelta]X\), \(1\
\)], \(2\)]\)\>\"", 
      ",", "\"\<\!\(\*SuperscriptBox[SubscriptBox[\(\[CapitalDelta]X\), \
\(2\)], \(2\)]\)\>\"", 
      ",", "\"\<\!\(\*SubscriptBox[\(\[CapitalDelta]X\), \
\(1\)]\)\!\(\*SubscriptBox[\(\[CapitalDelta]X\), \(2\)]\)\>\""}], "}"}]}], ",", 
   RowBox[{"Epilog", "->", 
    RowBox[{"{", 
     RowBox[{"Style", "[", 
      RowBox[{
       RowBox[{"Line", "[", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{"0", ",", "0.25"}], "}"}], ",", 
          RowBox[{"{", 
           RowBox[{"1", ",", "0.25"}], "}"}]}], "}"}], "]"}], ",", "Dashed"}],
       "]"}], "}"}]}], ",", 
   RowBox[{"Frame", "->", "True"}], ",", 
   RowBox[{"FrameLabel", "->", 
    RowBox[{"{", 
     RowBox[{"\"\<|\[Alpha]\!\(\*SuperscriptBox[\(|\), \(2\)]\)\>\"", 
      ",", "\"\<\>\""}], "}"}]}], ",", 
   RowBox[{"LabelStyle", "->", "12"}], ",", 
   RowBox[{"ImageSize", "->", "350"}]}], "]"}]], "ExerciseInput",
 CellChangeTimes->{{3.9736998021340904`*^9, 3.9736998048439064`*^9}},
 CellLabel->"In[123]:=",
 CellID->128019290,ExpressionUUID->"793045d4-96be-cc4d-bdf2-6b2497dff2b1"],

