Cell["Solve wave equation for the magnetic field:", "Text",
 CellID->257167719,ExpressionUUID->"14a334d4-ed35-4129-9b50-fdb8fecb8b36"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"DSolveValue", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{
       RowBox[{"D", "[", 
        RowBox[{
         RowBox[{"By", "[", 
          RowBox[{"z", ",", "t"}], "]"}], ",", 
         RowBox[{"{", 
          RowBox[{"t", ",", "2"}], "}"}]}], "]"}], "==", 
       RowBox[{
        SuperscriptBox["c", "2"], 
        RowBox[{"D", "[", 
         RowBox[{
          RowBox[{"By", "[", 
           RowBox[{"z", ",", "t"}], "]"}], ",", 
          RowBox[{"{", 
           RowBox[{"z", ",", "2"}], "}"}]}], "]"}]}]}], ",", 
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{"Derivative", "[", 
          RowBox[{"1", ",", "0"}], "]"}], "[", "By", "]"}], "[", 
        RowBox[{"0", ",", "t"}], "]"}], "==", "0"}], ",", 
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{"Derivative", "[", 
          RowBox[{"1", ",", "0"}], "]"}], "[", "By", "]"}], "[", 
        RowBox[{"L", ",", "t"}], "]"}], "==", "0"}]}], "}"}], ",", 
    RowBox[{"By", "[", 
     RowBox[{"z", ",", "t"}], "]"}], ",", 
    RowBox[{"{", 
     RowBox[{"z", ",", "t"}], "}"}], ",", 
    RowBox[{"Assumptions", "->", 
     RowBox[{
      RowBox[{"c", ">", "0"}], "&&", 
      RowBox[{"L", ">", "0"}]}]}]}], "]"}], "[", 
  RowBox[{"[", 
   RowBox[{"1", ",", "1", ",", "1"}], "]"}], "]"}]], "Input",
 CellLabel->"In[11]:=",
 CellID->1270872264,ExpressionUUID->"70877f3a-394c-45fb-9622-00200ea8263e"],

Cell[BoxData[
 FormBox[
  RowBox[{
   TemplateBox[{
     FractionBox[
      RowBox[{
        SqrtBox["2"], " ", 
        RowBox[{"cos", "(", 
          FractionBox[
           RowBox[{"\[Pi]", " ", "z", " ", 
             RowBox[{"K", "[", "1", "]"}]}], "L"], ")"}], " ", 
        RowBox[{"(", 
          RowBox[{
            RowBox[{
              RowBox[{"cos", "(", 
                FractionBox[
                 RowBox[{"c", " ", "\[Pi]", " ", "t", " ", 
                   RowBox[{"K", "[", "1", "]"}]}], "L"], ")"}], " ", 
              RowBox[{
                SubsuperscriptBox["\[Integral]", "0", "L"], 
                RowBox[{
                  FractionBox[
                   RowBox[{
                    SqrtBox["2"], " ", 
                    RowBox[{"By", "(", 
                    RowBox[{"z", ",", "0"}], ")"}], " ", 
                    RowBox[{"cos", "(", 
                    FractionBox[
                    RowBox[{"\[Pi]", " ", "z", " ", 
                    RowBox[{"K", "[", "1", "]"}]}], "L"], ")"}]}], 
                   SqrtBox["L"]], 
                  RowBox[{"\[DifferentialD]", "z"}]}]}]}], "+", 
            FractionBox[
             RowBox[{"L", " ", 
               RowBox[{"(", 
                 RowBox[{
                   SubsuperscriptBox["\[Integral]", "0", "L"], 
                   RowBox[{
                    FractionBox[
                    RowBox[{
                    SqrtBox["2"], " ", 
                    RowBox[{"cos", "(", 
                    FractionBox[
                    RowBox[{"\[Pi]", " ", "z", " ", 
                    RowBox[{"K", "[", "1", "]"}]}], "L"], ")"}], " ", 
                    RowBox[{
                    SuperscriptBox["By", 
                    TagBox[
                    RowBox[{"(", 
                    RowBox[{"0", ",", "1"}], ")"}], Derivative], 
                    MultilineFunction -> None], "(", 
                    RowBox[{"z", ",", "0"}], ")"}]}], 
                    SqrtBox["L"]], 
                    RowBox[{"\[DifferentialD]", "z"}]}]}], ")"}], " ", 
               RowBox[{"sin", "(", 
                 FractionBox[
                  RowBox[{"c", " ", "\[Pi]", " ", "t", " ", 
                    RowBox[{"K", "[", "1", "]"}]}], "L"], ")"}]}], 
             RowBox[{"c", " ", "\[Pi]", " ", 
               RowBox[{"K", "[", "1", "]"}]}]]}], ")"}]}], 
      SqrtBox["L"]], 
     RowBox[{"K", "[", "1", "]"}], "1", "\[Infinity]"},
    "InactiveSum",
    DisplayFunction->(RowBox[{
       UnderoverscriptBox[
        StyleBox["\[Sum]", "InactiveTraditional"], 
        RowBox[{#2, "=", #3}], #4], #}]& ),
    InterpretationFunction->(RowBox[{
       RowBox[{"Inactive", "[", "Sum", "]"}], "[", 
       RowBox[{#, ",", 
         RowBox[{"{", 
           RowBox[{#2, ",", #3, ",", #4}], "}"}]}], "]"}]& )], "+", 
   FractionBox[
    RowBox[{
     RowBox[{"t", " ", 
      RowBox[{
       SubsuperscriptBox["\[Integral]", "0", "L"], 
       RowBox[{
        FractionBox[
         RowBox[{
          SuperscriptBox["By", 
           TagBox[
            RowBox[{"(", 
             RowBox[{"0", ",", "1"}], ")"}],
            Derivative],
           MultilineFunction->None], "(", 
          RowBox[{"z", ",", "0"}], ")"}], 
         SqrtBox["L"]], 
        RowBox[{"\[DifferentialD]", "z"}]}]}]}], "+", 
     RowBox[{
      SubsuperscriptBox["\[Integral]", "0", "L"], 
      RowBox[{
       FractionBox[
        RowBox[{"By", "(", 
         RowBox[{"z", ",", "0"}], ")"}], 
        SqrtBox["L"]], 
       RowBox[{"\[DifferentialD]", "z"}]}]}]}], 
    SqrtBox["L"]]}], TraditionalForm]], "Output",
 CellLabel->"Out[11]=",
 CellID->312718229,ExpressionUUID->"6d98e728-1a89-ff43-978f-fe5150dbe7c9"]
}, Open  ]],

Cell[TextData[{
 "As one can see, the generic result as the form ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox["B", "y"], "(", 
     RowBox[{"z", ",", "t"}], ")"}], "=", 
    RowBox[{
     SubscriptBox["h", "0"], "+", 
     RowBox[{
      UnderoverscriptBox["\[Sum]", 
       RowBox[{"n", "=", "1"}], "\[Infinity]"], 
      RowBox[{
       RowBox[{
        SubscriptBox["p", "n"], "(", "t", ")"}], " ", 
       RowBox[{"cos", "(", 
        RowBox[{
         FractionBox[
          RowBox[{"n", " ", "\[Pi]"}], "L"], "z"}], ")"}]}]}]}]}], 
   TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "b0101910-7865-41e0-a250-7ad08031ff74"],
 " where ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox["p", "n"], "(", "t", ")"}], "=", 
    RowBox[{
     FractionBox["1", 
      RowBox[{
       SuperscriptBox["c", "2"], 
       SubscriptBox["k", "n"]}]], 
     FractionBox[
      RowBox[{"\[DifferentialD]", 
       RowBox[{
        SubscriptBox["q", "n"], "(", "t", ")"}]}], 
      RowBox[{"\[DifferentialD]", "t"}]], " "}]}], TraditionalForm]],
  ExpressionUUID->"645f2106-018b-4f60-9e7a-76a70b0c410e"],
 " is a time-dependent canonical momentum of the mode ",
 Cell[BoxData[
  FormBox["n", TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "9881a58b-10ce-4479-81f9-267cac44c57c"],
 ". The terms ",
 Cell[BoxData[
  FormBox[
   RowBox[{"cos", "(", 
    RowBox[{
     SubscriptBox["k", "n"], "z"}], ")"}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "dd3f9a8b-1f4c-454e-865d-2fbb2ad6a449"],
 " are magnetic standing-wave mode function, and ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["h", "0"], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "e7f95c23-35ba-450e-961c-993491dac4ab"],
 " is the spatially uniform (static) magnetic field that represents a \
constant background magnetic field inside the cavity that does not vary with ",
 Cell[BoxData[
  FormBox["z", TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "05c20080-fc33-4f7b-bd7c-8ab765b854a0"],
 " and (in this idealized model) does not evolve in time."
}], "Text",
 CellID->1073373322,ExpressionUUID->"6affbc99-357d-462f-8486-70b04b8315a9"],

Cell[TextData[{
 "The field energy, which plays the role of the Hamiltonian ",
 Cell[BoxData[
  FormBox["H", TraditionalForm]],ExpressionUUID->
  "265e7f6a-4027-1a4e-afc0-7ec9ece8d87b"],
 ", is: ",
 Cell[BoxData[
  FormBox[
   RowBox[{"H", "=", 
    RowBox[{
     FractionBox["A", "2"], 
     RowBox[{
      SubsuperscriptBox["\[Integral]", "0", "L"], 
      RowBox[{
       RowBox[{"(", 
        RowBox[{
         RowBox[{
          SubscriptBox["\[Epsilon]", "0"], " ", 
          SuperscriptBox[
           SubscriptBox["E", "x"], "2"]}], "+", 
         RowBox[{
          FractionBox["1", 
           SuperscriptBox[
            SubscriptBox["\[Mu]", "0"], "2"]], 
          SuperscriptBox[
           SubscriptBox["B", "y"], "2"]}]}], ")"}], 
       RowBox[{"\[DifferentialD]", "z"}]}]}]}]}], TraditionalForm]],
  ExpressionUUID->"10a64425-9b2e-40cd-b38e-33709d78316a"],
 " with ",
 Cell[BoxData[
  FormBox["A", TraditionalForm]],ExpressionUUID->
  "6024d7e5-5912-4abd-9d13-2419fefad3bd"],
 " the cross-section. Use orthogonality of sine/cosine modes, one finds: ",
 Cell[BoxData[
  FormBox[
   RowBox[{"H", "=", 
    RowBox[{
     RowBox[{
      FractionBox["V", 
       RowBox[{"2", 
        SubscriptBox["\[Mu]", "0"]}]], 
      SuperscriptBox[
       SubscriptBox["h", "0"], "2"]}], "+", 
     RowBox[{
      FractionBox[
       RowBox[{
        SubscriptBox["\[Epsilon]", "0"], "V"}], "4"], 
      RowBox[{
       UnderoverscriptBox["\[Sum]", 
        RowBox[{"n", "=", "1"}], "\[Infinity]"], 
       RowBox[{"(", 
        RowBox[{
         SuperscriptBox[
          RowBox[{
           SubscriptBox["q", "n"], "(", "t", ")"}], "2"], "+", 
         RowBox[{
          SuperscriptBox["c", "2"], 
          SuperscriptBox[
           RowBox[{
            SubscriptBox["p", "n"], "(", "t", ")"}], "2"]}]}], ")"}]}]}]}]}], 
   TraditionalForm]],ExpressionUUID->"36d318f2-c18b-466c-be48-9e47df9cab19"],
 " where ",
 Cell[BoxData[
  FormBox[
   RowBox[{"V", "=", 
    RowBox[{"A", " ", "L"}]}], TraditionalForm]],ExpressionUUID->
  "7cc98572-dd37-4018-927c-8f9b05021eef"],
 ". With rescaled mode variables ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["Q", "n"], "=", 
    RowBox[{
     SqrtBox[
      FractionBox[
       RowBox[{
        SubscriptBox["\[Epsilon]", "0"], "V"}], "2"]], 
     FractionBox[
      SubscriptBox["q", "n"], 
      SubscriptBox["\[Omega]", "n"]]}]}], TraditionalForm]],ExpressionUUID->
  "fcaeb67b-9ed9-4b4f-a5a8-c0333ecc274e"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["P", "n"], "=", 
    RowBox[{
     SqrtBox[
      FractionBox["V", 
       RowBox[{"2", 
        SubscriptBox["\[Mu]", "0"]}]]], 
     SubscriptBox["p", "n"]}]}], TraditionalForm]],ExpressionUUID->
  "b9b66ae0-a500-45f3-bd29-59cd19263e20"],
 " where ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["\[Omega]", "n"], "=", 
    RowBox[{"c", " ", 
     SubscriptBox["k", "n"]}]}], TraditionalForm]],ExpressionUUID->
  "62872e40-f804-4e9b-be09-34a7d56f4e5a"],
 ", one can rewrite the Hamiltonian as ",
 Cell[BoxData[
  FormBox[
   RowBox[{"H", "=", 
    RowBox[{
     RowBox[{
      FractionBox["V", 
       RowBox[{"2", 
        SubscriptBox["\[Mu]", "0"]}]], 
      SuperscriptBox[
       SubscriptBox["h", "0"], "2"]}], "+", 
     RowBox[{
      UnderoverscriptBox["\[Sum]", 
       RowBox[{"n", "=", "1"}], "\[Infinity]"], 
      RowBox[{
       FractionBox["1", "2"], 
       RowBox[{"(", 
        RowBox[{
         SuperscriptBox[
          SubscriptBox["P", "n"], "2"], "+", 
         RowBox[{
          SuperscriptBox[
           SubscriptBox["\[Omega]", "n"], "2"], 
          SuperscriptBox[
           SubscriptBox["Q", "n"], "2"]}]}], ")"}]}]}]}]}], TraditionalForm]],
  ExpressionUUID->"02e4f208-1c78-4582-8270-248447c9122e"],
 ". This is the clean \[OpenCurlyDoubleQuote]harmonic oscillator \
decomposition\[CloseCurlyDoubleQuote] of the cavity field energy. "
}], "Text",
 CellID->25320954,ExpressionUUID->"5589dee2-c4b9-fe49-94b2-f06d4d595d6c"],

Cell[TextData[{
 "Using the Maxwell relations above, one can show that the rescaled variables \
satisfy: ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    FractionBox[
     RowBox[{"\[DifferentialD]", 
      RowBox[{
       SubscriptBox["Q", "n"], "(", "t", ")"}]}], 
     RowBox[{"\[DifferentialD]", "t"}]], "=", 
    RowBox[{
     SubscriptBox["P", "n"], "(", "t", ")"}]}], TraditionalForm]],
  ExpressionUUID->"a293413f-5964-4820-a093-2b7d5012d7ca"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    FractionBox[
     RowBox[{"\[DifferentialD]", 
      RowBox[{
       SubscriptBox["P", "n"], "(", "t", ")"}]}], 
     RowBox[{"\[DifferentialD]", "t"}]], "=", 
    RowBox[{
     RowBox[{"-", 
      SuperscriptBox[
       SubscriptBox["\[Omega]", "n"], "2"]}], 
     RowBox[{
      SubscriptBox["Q", "n"], "(", "t", ")"}]}]}], TraditionalForm]],
  ExpressionUUID->"1ec426f0-65aa-428d-b3af-e7731dcce690"],
 ". In other words, these canonical variables evolve exactly like oscillator \
coordinate and momentum. Without losing generality, one can drop ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["h", "0"], TraditionalForm]],ExpressionUUID->
  "13aaca96-f76c-43ae-85af-beb94debf1f9"],
 " from the Hamiltonian. Also, instead of all modes in the Hamiltonian (i.e. \
summation over ",
 Cell[BoxData[
  FormBox["n", TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "195abfbd-b13f-4518-9eba-2386199d18cf"],
 "), one can consider only a single mode case. In many quantum optics \
situations, only one cavity resonance matters and we shall consider that one, \
only. Therefore, the Hamiltonian becomes ",
 Cell[BoxData[
  FormBox[
   RowBox[{"H", "=", 
    RowBox[{
     FractionBox["1", "2"], 
     RowBox[{"(", 
      RowBox[{
       SuperscriptBox["P", "2"], "+", 
       RowBox[{
        SuperscriptBox["\[Omega]", "2"], 
        SuperscriptBox["Q", "2"]}]}], ")"}]}]}], TraditionalForm]],
  ExpressionUUID->"bf085922-c0a3-47b9-a800-21682fb2b733"],
 ". "
}], "Text",
 CellID->832064149,ExpressionUUID->"3d246e76-857b-419d-bcab-d934e9e1f0de"],

Cell[TextData[{
 "In a similar manner, the electric and magnetic fields would be given by ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox["E", "x"], "(", 
     RowBox[{"z", ",", "t"}], ")"}], "=", 
    RowBox[{
     SqrtBox[
      RowBox[{
       FractionBox["2", 
        RowBox[{
         SubscriptBox["\[Epsilon]", "0"], "V"}]], " "}]], "\[Omega]", " ", 
     RowBox[{"Q", "(", "t", ")"}], " ", 
     RowBox[{"sin", "(", 
      RowBox[{"k", " ", "z"}], ")"}]}]}], TraditionalForm]],ExpressionUUID->
  "52e8c858-ae63-48da-9583-f99ae87d8d18"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox["B", "y"], "(", 
     RowBox[{"z", ",", "t"}], ")"}], "=", 
    RowBox[{
     SqrtBox[
      RowBox[{
       FractionBox[
        RowBox[{"2", 
         SubscriptBox["\[Mu]", "0"]}], "V"], " "}]], " ", 
     RowBox[{"P", "(", "t", ")"}], " ", 
     RowBox[{"cos", "(", 
      RowBox[{"k", " ", "z"}], ")"}]}]}], TraditionalForm]],ExpressionUUID->
  "8fda653e-9190-4aa6-82e4-477eca38cf97"],
 ". Now let\[CloseCurlyQuote]s clarify an important fact. The variables ",
 Cell[BoxData[
  FormBox["Q", TraditionalForm]],ExpressionUUID->
  "931aba40-e8bc-4039-9ed1-121aa74938a0"],
 " and ",
 Cell[BoxData[
  FormBox["P", TraditionalForm]],ExpressionUUID->
  "251ac5ee-42a4-472e-a5b2-675cd3472cd7"],
 " are not arbitrary\[LongDash]they are the canonical coordinate and momentum \
of cavity mode. ",
 Cell[BoxData[
  FormBox[
   RowBox[{"Q", "(", "t", ")"}], TraditionalForm]],ExpressionUUID->
  "f24d7507-af38-4790-b116-e6766a50c602"],
 " is the \[OpenCurlyDoubleQuote]electric-like quadrature\
\[CloseCurlyDoubleQuote]. ",
 Cell[BoxData[
  FormBox[
   RowBox[{"P", 
    RowBox[{"(", "t", ")"}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "75095d23-3d77-4cca-b320-8daab8469ffd"],
 " is the \[OpenCurlyDoubleQuote]magnetic-like quadrature\
\[CloseCurlyDoubleQuote]. In quantum theory, they become noncommuting \
quadrature operators (like position and momentum), and their phase-space \
structure leads directly to uncertainty, vacuum noise, coherent states, \
squeezing, etc. Let\[CloseCurlyQuote]s explore some more details for ",
 Cell[BoxData[
  FormBox["Q", TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "ddb20ad0-32c8-4d90-b5bf-ee78ceb29d0a"],
 " and ",
 Cell[BoxData[
  FormBox["P", TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "74780648-8819-4760-a911-6280b5fea042"],
 "."
}], "Text",
 CellID->1253539976,ExpressionUUID->"b7463c35-4b9c-43b5-a8e6-f31bdd69ef2e"],

Cell[TextData[{
 "Recall the coupled first-order system for canonical variables is ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    FractionBox[
     RowBox[{"\[DifferentialD]", 
      RowBox[{"Q", "(", "t", ")"}]}], 
     RowBox[{"\[DifferentialD]", "t"}]], "=", 
    RowBox[{"P", "(", "t", ")"}]}], TraditionalForm]],ExpressionUUID->
  "e51636e8-089f-4d2d-a961-8fb9a55b2dff"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    FractionBox[
     RowBox[{"\[DifferentialD]", 
      RowBox[{"P", "(", "t", ")"}]}], 
     RowBox[{"\[DifferentialD]", "t"}]], "=", 
    RowBox[{
     RowBox[{"-", 
      SuperscriptBox["\[Omega]", "2"]}], 
     RowBox[{"Q", "(", "t", ")"}]}]}], TraditionalForm]],ExpressionUUID->
  "94a76912-077e-4b59-b1a2-410eb527862c"],
 ". Thus one finds: ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    FractionBox[
     RowBox[{
      SuperscriptBox["\[DifferentialD]", "2"], 
      RowBox[{"Q", "(", "t", ")"}]}], 
     RowBox[{"\[DifferentialD]", 
      SuperscriptBox["t", "2"]}]], "=", 
    RowBox[{
     RowBox[{"-", 
      SuperscriptBox["\[Omega]", "2"]}], 
     RowBox[{"Q", "(", "t", ")"}]}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "919d2a50-5b4e-47c0-be17-1afb2a4c4559"],
 ". That is the standard harmonic oscillator equation."
}], "Text",
 CellID->2047183869,ExpressionUUID->"62d154ab-f3ca-4a04-aef6-a7dd5be14334"],

Cell[TextData[{
 "Solve harmonic oscillator equation for ",
 Cell[BoxData[
  FormBox[
   RowBox[{"Q", "(", "t", ")"}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "4076f078-066d-4ddf-b561-b590d15363d2"],
 ":"
}], "Text",
 CellID->882111277,ExpressionUUID->"1f824ea6-a23d-48bf-829a-ff8d3b1b21a8"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"DSolveValue", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{
       RowBox[{"D", "[", 
        RowBox[{
         RowBox[{"Q", "[", "t", "]"}], ",", 
         RowBox[{"{", 
          RowBox[{"t", ",", "2"}], "}"}]}], "]"}], "==", 
       RowBox[{
        RowBox[{"-", 
         SuperscriptBox["\[Omega]", "2"]}], 
        RowBox[{"Q", "[", "t", "]"}]}]}], ",", 
      RowBox[{
       RowBox[{"Q", "[", "0", "]"}], "==", "Q0"}], ",", 
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{"Derivative", "[", "1", "]"}], "[", "Q", "]"}], "[", "0", 
        "]"}], "==", "P0"}]}], "}"}], ",", 
    RowBox[{"Q", "[", "t", "]"}], ",", "t"}], "]"}], "//", 
  "FullSimplify"}]], "Input",
 CellLabel->"In[12]:=",
 CellID->946743980,ExpressionUUID->"05b0bbb6-cdea-42f9-b803-6e614111f060"],

Cell[BoxData[
 RowBox[{
  RowBox[{"Q0", " ", 
   RowBox[{"Cos", "[", 
    RowBox[{"t", " ", "\[Omega]"}], "]"}]}], "+", 
  FractionBox[
   RowBox[{"P0", " ", 
    RowBox[{"Sin", "[", 
     RowBox[{"t", " ", "\[Omega]"}], "]"}]}], "\[Omega]"]}]], "Output",
 CellLabel->"Out[12]=",
 CellID->155513044,ExpressionUUID->"dce27604-0a33-cc44-b13b-f51da5a17a81"]
}, Open  ]],

Cell[TextData[{
 "Given the solution, find ",
 Cell[BoxData[
  FormBox[
   RowBox[{"P", "(", "t", ")"}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "aa2d4e61-c605-4b33-8f23-780583da1593"],
 " using ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    FractionBox[
     RowBox[{"\[DifferentialD]", 
      RowBox[{"Q", "(", "t", ")"}]}], 
     RowBox[{"\[DifferentialD]", "t"}]], "=", 
    RowBox[{"P", "(", "t", ")"}]}], TraditionalForm]],ExpressionUUID->
  "ce9f4fc5-4528-48c6-914e-72e604f181d4"],
 ":"
}], "Text",
 CellID->1715506605,ExpressionUUID->"c438a4b5-2187-414f-b95b-2477ecf851c1"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"D", "[", 
  RowBox[{"%", ",", "t"}], "]"}]], "Input",
 CellLabel->"In[13]:=",
 CellID->1827226378,ExpressionUUID->"4b619949-2041-4f82-afdd-33545e9e8f13"],

Cell[BoxData[
 RowBox[{
  RowBox[{"P0", " ", 
   RowBox[{"Cos", "[", 
    RowBox[{"t", " ", "\[Omega]"}], "]"}]}], "-", 
  RowBox[{"Q0", " ", "\[Omega]", " ", 
   RowBox[{"Sin", "[", 
    RowBox[{"t", " ", "\[Omega]"}], "]"}]}]}]], "Output",
 CellLabel->"Out[13]=",
 CellID->100383653,ExpressionUUID->"34eb717c-ecff-d04a-a888-ca6f66f76934"]
}, Open  ]],

Cell[TextData[{
 "It can be shown that the transformation from the pair ",
 Cell[BoxData[
  FormBox[
   RowBox[{"(", GridBox[{
      {
       RowBox[{"\[Omega]", " ", 
        SubscriptBox["Q", "0"]}]},
      {
       StyleBox[
        SubscriptBox["", 
         SubscriptBox["P", "0"]],
        FontSize->24]}
     }], ")"}], TraditionalForm]],ExpressionUUID->
  "d4ba817d-425e-45ce-ae33-19fbd09cdf66"],
 " into ",
 Cell[BoxData[
  FormBox[
   RowBox[{"(", GridBox[{
      {
       RowBox[{"\[Omega]", " ", 
        RowBox[{"Q", "(", "t", ")"}]}]},
      {
       StyleBox[
        SubscriptBox["", 
         RowBox[{"P", "(", "t", ")"}]],
        FontSize->24]}
     }], ")"}], TraditionalForm]],ExpressionUUID->
  "482ad5cb-131d-4f41-8273-f21804a25f82"],
 " is described by a rotation in phase space at angular frequency \[Omega]:"
}], "Text",
 CellID->486900138,ExpressionUUID->"afc6034b-21ac-43f4-a054-15510ecf1d54"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"RotationMatrix", "[", 
   RowBox[{
    RowBox[{"-", "\[Omega]"}], " ", "t"}], "]"}], ".", 
  RowBox[{"{", 
   RowBox[{
    RowBox[{"\[Omega]", " ", 
     SubscriptBox["Q", "0"]}], ",", 
    SubscriptBox["P", "0"]}], "}"}]}]], "Input",
 CellLabel->"In[14]:=",
 CellID->1243455131,ExpressionUUID->"6e061752-4c11-42c3-9603-f956820622aa"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"Sin", "[", 
      RowBox[{"t", " ", "\[Omega]"}], "]"}], " ", 
     SubscriptBox["P", "0"]}], "+", 
    RowBox[{"\[Omega]", " ", 
     RowBox[{"Cos", "[", 
      RowBox[{"t", " ", "\[Omega]"}], "]"}], " ", 
     SubscriptBox["Q", "0"]}]}], ",", 
   RowBox[{
    RowBox[{
     RowBox[{"Cos", "[", 
      RowBox[{"t", " ", "\[Omega]"}], "]"}], " ", 
     SubscriptBox["P", "0"]}], "-", 
    RowBox[{"\[Omega]", " ", 
     RowBox[{"Sin", "[", 
      RowBox[{"t", " ", "\[Omega]"}], "]"}], " ", 
     SubscriptBox["Q", "0"]}]}]}], "}"}]], "Output",
 CellLabel->"Out[14]=",
 CellID->67537263,ExpressionUUID->"6911b247-da95-004a-8ffb-0d71752b2533"]
}, Open  ]],

Cell[TextData[{
 "Therefore, the time-dependent electric and magnetic fields become ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox["E", "x"], "(", 
     RowBox[{"z", ",", "t"}], ")"}], "=", 
    RowBox[{
     SqrtBox[
      FractionBox["2", 
       RowBox[{
        SubscriptBox["\[Epsilon]", "0"], "V"}]]], 
     RowBox[{"sin", "(", 
      RowBox[{"k", " ", "z"}], ")"}], 
     RowBox[{"(", 
      RowBox[{
       RowBox[{"\[Omega]", " ", 
        SubscriptBox["Q", "0"], " ", 
        RowBox[{"cos", "(", 
         RowBox[{"\[Omega]", " ", "t"}], ")"}]}], "+", 
       RowBox[{
        SubscriptBox["P", "0"], 
        RowBox[{"sin", "(", 
         RowBox[{"\[Omega]", " ", "t"}], ")"}]}]}], ")"}]}]}], 
   TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "e5bb91af-e953-44ea-ae9c-ef63f3c47226"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox["B", "y"], "(", 
     RowBox[{"z", ",", "t"}], ")"}], "=", 
    RowBox[{
     SqrtBox[
      FractionBox[
       RowBox[{"2", 
        SubscriptBox["\[Mu]", "0"]}], "V"]], 
     RowBox[{"cos", "(", 
      RowBox[{"k", " ", "z"}], ")"}], 
     RowBox[{"(", 
      RowBox[{
       RowBox[{
        RowBox[{"-", "\[Omega]"}], " ", 
        SubscriptBox["Q", "0"], " ", 
        RowBox[{"sin", "(", 
         RowBox[{"\[Omega]", " ", "t"}], ")"}]}], "+", 
       RowBox[{
        SubscriptBox["P", "0"], 
        RowBox[{"cos", "(", 
         RowBox[{"\[Omega]", " ", "t"}], ")"}]}]}], ")"}]}]}], 
   TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "0fd66135-2b14-40a2-97cd-5b4864b89298"],
 "."
}], "Text",
 CellID->1915082729,ExpressionUUID->"7728b293-6abd-410d-a0df-9a73ce5964db"],

Cell[TextData[{
 "Quantization promotes the canonical variables ",
 Cell[BoxData[
  FormBox["P", TraditionalForm]],ExpressionUUID->
  "aa242e31-9a12-a543-bc32-110d45a17743"],
 " and ",
 Cell[BoxData[
  FormBox["Q", TraditionalForm]],ExpressionUUID->
  "44a73c03-6123-b644-b72a-3dad52cd8bda"],
 " to operators ",
 Cell[BoxData[
  FormBox[
   OverscriptBox["P", "^"], TraditionalForm]],ExpressionUUID->
  "f1a9be7a-b3e7-db4b-8c0e-72445512e9fd"],
 " and ",
 Cell[BoxData[
  FormBox[
   OverscriptBox["Q", "^"], TraditionalForm]],ExpressionUUID->
  "c5a5333b-f486-40fd-a91a-cfdb87d27cca"],
 " that satisfy the canonical commutation relation: ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"[", 
     RowBox[{
      OverscriptBox["Q", "^"], ",", 
      OverscriptBox["P", "^"]}], "]"}], "=", "\[ImaginaryI]\[HBar]"}], 
   TraditionalForm]],ExpressionUUID->"487bf46c-597e-4dea-a646-653df698c07e"],
 ". With these operators, the Hamiltonian becomes: ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    OverscriptBox["H", "^"], "=", 
    RowBox[{
     FractionBox["1", "2"], 
     RowBox[{"(", 
      RowBox[{
       SuperscriptBox[
        OverscriptBox["P", "^"], "2"], "+", 
       RowBox[{
        SuperscriptBox["\[Omega]", "2"], 
        SuperscriptBox[
         OverscriptBox["Q", "^"], "2"]}]}], ")"}]}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "608c860f-62a2-4b2e-9327-6189dc7446c2"],
 "."
}], "Text",
 CellID->228418903,ExpressionUUID->"b94125ab-c936-dd42-b132-7746154802f4"],

Cell[TextData[{
 "It is standard to introduce the non-Hermitian (non-observable) ladder \
operators ",
 Cell[BoxData[
  FormBox[
   OverscriptBox["a", "^"], TraditionalForm]],ExpressionUUID->
  "7400c7e5-013d-394f-83ac-6cc62f8d32b6"],
 " and ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox[
    OverscriptBox["a", "^"], "\[Dagger]"], TraditionalForm]],ExpressionUUID->
  "6e34d17d-3847-a348-805b-5507a63d20e3"],
 ", which simplify the algebra and encode how the field exchanges quanta: ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    OverscriptBox["a", "^"], "=", 
    RowBox[{
     SqrtBox[
      FractionBox["\[Omega]", 
       RowBox[{"2", "\[HBar]"}]]], 
     RowBox[{"(", 
      RowBox[{
       OverscriptBox["Q", "^"], "+", 
       RowBox[{
        FractionBox["\[ImaginaryI]", 
         SqrtBox[
          RowBox[{"2", "\[HBar]", " ", "\[Omega]"}]]], 
        OverscriptBox["P", "^"]}]}], ")"}]}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "f0e5dbef-daf4-42c1-a329-68634fc8e213"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox[
     OverscriptBox["a", "^"], "\[Dagger]"], "=", 
    RowBox[{
     SqrtBox[
      FractionBox["\[Omega]", 
       RowBox[{"2", "\[HBar]"}]]], 
     RowBox[{"(", 
      RowBox[{
       OverscriptBox["Q", "^"], "-", 
       RowBox[{
        FractionBox["\[ImaginaryI]", 
         SqrtBox[
          RowBox[{"2", "\[HBar]", " ", "\[Omega]"}]]], 
        OverscriptBox["P", "^"]}]}], ")"}]}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "a369073e-f05b-4f45-9a29-fad832cebaad"],
 "."
}], "Text",
 CellID->286578574,ExpressionUUID->"52e2374a-e73c-5841-95fe-be93e71a0c13"],

Cell[TextData[{
 "The ladder operators ",
 Cell[BoxData[
  FormBox[
   OverscriptBox["a", "^"], TraditionalForm]],ExpressionUUID->
  "a28c40a7-2e33-864a-93eb-8a027546b716"],
 " and ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox[
    OverscriptBox["a", "^"], "\[Dagger]"], TraditionalForm]],ExpressionUUID->
  "91a37a45-8eed-f74b-8d43-648c75ce2940"],
 " satisfy the commutation relation ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"[", 
     RowBox[{
      OverscriptBox["a", "^"], ",", 
      SuperscriptBox[
       OverscriptBox["a", "^"], "\[Dagger]"]}], "]"}], "=", "1"}], 
   TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "e4833c38-413f-43ed-8806-3dca61b6900a"],
 ". Consequently, the Hamiltonian can be written as ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    OverscriptBox["H", "^"], "=", 
    RowBox[{"\[HBar]", " ", "\[Omega]", " ", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{
        SuperscriptBox[
         OverscriptBox["a", "^"], "\[Dagger]"], 
        OverscriptBox["a", "^"]}], "+", 
       RowBox[{"1", "/", "2"}]}], ")"}]}]}], TraditionalForm]],ExpressionUUID->
  "6fa9af9f-6807-47e6-bf87-60f125d570ad"],
 ". Additionally, the operators for electric and magnetic fields become ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox[
      OverscriptBox["E", "^"], "x"], "(", 
     RowBox[{"z", ",", "t"}], ")"}], "=", 
    RowBox[{
     SqrtBox[
      FractionBox[
       RowBox[{"\[HBar]", " ", "\[Omega]"}], 
       RowBox[{
        SubscriptBox["\[Epsilon]", "0"], "V"}]]], 
     RowBox[{"sin", "(", 
      RowBox[{"k", " ", "z"}], ")"}], 
     RowBox[{"(", 
      RowBox[{
       RowBox[{
        OverscriptBox["a", "^"], " ", 
        SuperscriptBox["\[ExponentialE]", 
         RowBox[{
          RowBox[{"-", "\[ImaginaryI]"}], " ", "\[Omega]", " ", "t"}]]}], "+", 
       RowBox[{
        SuperscriptBox[
         OverscriptBox["a", "^"], "\[Dagger]"], " ", 
        SuperscriptBox["\[ExponentialE]", 
         RowBox[{"\[ImaginaryI]", " ", "\[Omega]", " ", "t"}]]}]}], ")"}]}]}],
    TraditionalForm]],ExpressionUUID->
  "fae17df1-d074-4b7b-894d-89df81f96848"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox[
      OverscriptBox["B", "^"], "y"], "(", 
     RowBox[{"z", ",", "t"}], ")"}], "=", 
    RowBox[{
     RowBox[{"-", "\[ImaginaryI]"}], 
     SqrtBox[
      FractionBox[
       RowBox[{
        SubscriptBox["\[Mu]", "0"], "\[HBar]", " ", "\[Omega]"}], "V"]], 
     RowBox[{"cos", "(", 
      RowBox[{"k", " ", "z"}], ")"}], 
     RowBox[{"(", 
      RowBox[{
       RowBox[{
        OverscriptBox["a", "^"], " ", 
        SuperscriptBox["\[ExponentialE]", 
         RowBox[{
          RowBox[{"-", "\[ImaginaryI]"}], " ", "\[Omega]", " ", "t"}]]}], "-", 
       RowBox[{
        SuperscriptBox[
         OverscriptBox["a", "^"], "\[Dagger]"], " ", 
        SuperscriptBox["\[ExponentialE]", 
         RowBox[{"\[ImaginaryI]", " ", "\[Omega]", " ", "t"}]]}]}], ")"}]}]}],
    TraditionalForm]],ExpressionUUID->
  "50915d12-611e-472f-835b-c21c95171ef1"],
 "."
}], "Text",
 CellID->15129139,ExpressionUUID->"6b5b83f9-c375-0848-875f-7a3d18b926ba"],

Cell[TextData[{
 "The operator ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox[
     OverscriptBox["a", "^"], "\[Dagger]"], 
    OverscriptBox["a", "^"]}], TraditionalForm]],ExpressionUUID->
  "d3bff6ff-2a34-4563-bc92-535ca309695e"],
 " is called the number operator and is also Hermitian with eigenstates ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{"n"},
    "Ket"], TraditionalForm]],ExpressionUUID->
  "5c51973c-95fd-40ab-a201-a5466681a363"],
 " where ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SuperscriptBox[
      OverscriptBox["a", "^"], "\[Dagger]"], 
     OverscriptBox["a", "^"], 
     TemplateBox[{"n"},
      "Ket"]}], "=", 
    RowBox[{"n", 
     TemplateBox[{"n"},
      "Ket"]}]}], TraditionalForm]],ExpressionUUID->
  "96248b0e-178b-4505-9947-9114a8ff26b7"],
 ". The commutation relations ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"[", 
     RowBox[{
      RowBox[{
       SuperscriptBox[
        OverscriptBox["a", "^"], "\[Dagger]"], 
       OverscriptBox["a", "^"]}], ",", 
      OverscriptBox["a", "^"]}], "]"}], "=", 
    RowBox[{"-", 
     OverscriptBox["a", "^"]}]}], TraditionalForm]],ExpressionUUID->
  "a00ccb82-6832-4812-a982-837d38c950b6"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"[", 
     RowBox[{
      RowBox[{
       SuperscriptBox[
        OverscriptBox["a", "^"], "\[Dagger]"], 
       OverscriptBox["a", "^"]}], ",", 
      SuperscriptBox[
       OverscriptBox["a", "^"], "\[Dagger]"]}], "]"}], "=", 
    SuperscriptBox[
     OverscriptBox["a", "^"], "\[Dagger]"]}], TraditionalForm]],
  ExpressionUUID->"12279c57-4004-488d-868e-de0b1ffa24b9"],
 " can be obtained from ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"[", 
     RowBox[{
      OverscriptBox["a", "^"], ",", 
      SuperscriptBox[
       OverscriptBox["a", "^"], "\[Dagger]"]}], "]"}], "=", "1"}], 
   TraditionalForm]],ExpressionUUID->"021f98d9-5a7f-4ff4-9466-a9454a70b804"],
 " and useful identity such as ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"[", 
     RowBox[{
      RowBox[{"A", " ", "B"}], ",", "C"}], "]"}], "=", " ", 
    RowBox[{
     RowBox[{"A", " ", "[", 
      RowBox[{"B", ",", "C"}], "]"}], "+", " ", 
     RowBox[{
      RowBox[{"[", 
       RowBox[{"A", ",", "C"}], "]"}], " ", "B"}]}]}], TraditionalForm]],
  ExpressionUUID->"8f5afe46-8178-4449-a153-a7762182a1a1"],
 ". These commutators tell you how eigenvalues shift: ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox[
    OverscriptBox["a", "^"], "\[Dagger]"], TraditionalForm]],ExpressionUUID->
  "ee493127-ff49-432e-863a-142c759d02de"],
 " raises ",
 Cell[BoxData[
  FormBox["n", TraditionalForm]],ExpressionUUID->
  "915c8919-476d-435f-9a75-508e3b6851b4"],
 " while ",
 Cell[BoxData[
  FormBox[
   OverscriptBox["a", "^"], TraditionalForm]],ExpressionUUID->
  "028b4d7a-d73d-4a71-bc52-6ea6b512968a"],
 " lowers ",
 Cell[BoxData[
  FormBox["n", TraditionalForm]],ExpressionUUID->
  "b768a1fc-7158-4239-8276-a6a03229fd2d"],
 "; and all together ",
 Cell[BoxData[
  FormBox[
   RowBox[{"n", ">=", "0"}], TraditionalForm]],ExpressionUUID->
  "ab4fbc27-0ead-437b-8975-22acab692fe1"],
 " and must be integer. We will explore these properties computationally."
}], "Text",
 CellID->577854810,ExpressionUUID->"47186cf6-3a2f-4d89-ae85-0618e4b188d6"],

Cell[TextData[{
 "For eigenstate ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{"n"},
    "Ket"], TraditionalForm]],ExpressionUUID->
  "46593b38-9203-46fd-a53f-0f6224eacb17"],
 ", the Hamiltonian eigenvalue equation becomes ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     OverscriptBox["H", "^"], 
     TemplateBox[{"n"},
      "Ket"]}], "=", 
    RowBox[{
     SubscriptBox["E", "n"], 
     TemplateBox[{"n"},
      "Ket"]}]}], TraditionalForm]],ExpressionUUID->
  "ce65d054-10cc-461e-a880-f2dedc56b49c"],
 " with ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["E", "n"], "=", 
    RowBox[{"\[HBar]\[Omega]", "(", 
     RowBox[{"n", "+", 
      RowBox[{"1", "/", "2"}]}], ")"}]}], TraditionalForm]],ExpressionUUID->
  "334b84af-c410-491d-9823-9e3eb10d2b5e"],
 ". The eigenstate ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{"0"},
    "Ket"], TraditionalForm]],ExpressionUUID->
  "44ca3223-a27b-4060-8fee-84414d4e5de3"],
 " is usually called the vacuum state and ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{"n"},
    "Ket"], TraditionalForm]],ExpressionUUID->
  "3bb99616-9a81-41eb-9e62-ddcf1be42d02"],
 " the ",
 Cell[BoxData[
  FormBox["n", TraditionalForm]],ExpressionUUID->
  "65ce7607-3f0a-4873-b9bb-df5ce56ab585"],
 "-photon ",
 StyleBox["Fock",
  FontSlant->"Italic"],
 " state. Because there\[CloseCurlyQuote]s no upper limit to how many photons \
you could, in principle, have, you need infinitely many basis states, i.e., \
",
 Cell[BoxData[
  FormBox["n", TraditionalForm]],ExpressionUUID->
  "514ef9d3-cb3d-463b-bf5f-2d846f22ee13"],
 " goes to infinity. That\[CloseCurlyQuote]s why this Hilbert space is \
infinite-dimensional. Fock space is simply the name for a Hilbert space \
organized by ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{"n"},
    "Ket"], TraditionalForm]],ExpressionUUID->
  "f2e627da-3488-4bb0-bd99-b3b92b10b39c"],
 ". You can think of it as being built from \[OpenCurlyDoubleQuote]sectors\
\[CloseCurlyDoubleQuote] with fixed numbers of quanta: \
there\[CloseCurlyQuote]s a vacuum sector (no quanta), a one-quantum sector, a \
two-quantum sector, etc. For a single mode (which is the case we are focused \
now), each sector is one-dimensional and the whole space looks like an \
infinite ladder of number states. For many modes, Fock space contains all \
combinations of occupation numbers across modes."
}], "Text",
 CellID->1600208771,ExpressionUUID->"16c9e38e-e08b-4bff-b032-e5ff0845ed32"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"ClearAll", "[", "HODiagram", "]"}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"HODiagram", "[", 
     RowBox[{
      RowBox[{"nSolid_", ":", "2"}], ",", 
      RowBox[{"nDashedMax_", ":", "5"}], ",", 
      RowBox[{"nTop_", ":", "6"}], ",", 
      RowBox[{"opts", ":", 
       RowBox[{"OptionsPattern", "[", "]"}]}]}], "]"}], ":=", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{"m", "=", "1."}], ",", 
        RowBox[{"\[Omega]", "=", "1."}], ",", 
        RowBox[{"\[HBar]", "=", "1."}], ",", "En", ",", "V", ",", "xT", ",", 
        "blue", ",", "xmax", ",", "ymax", ",", "yRule", ",", "dash", ",", 
        "gap", ",", "dot", ",", "solid", ",", "dashed", ",", "top", ",", 
        "labelsL", ",", "labelsR"}], "}"}], ",", 
      RowBox[{
       RowBox[{
        RowBox[{"En", "[", "k_", "]"}], ":=", 
        RowBox[{"\[HBar]", " ", "\[Omega]", " ", 
         RowBox[{"(", 
          RowBox[{"k", "+", 
           RowBox[{"1", "/", "2"}]}], ")"}]}]}], ";", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"V", "[", 
         RowBox[{"x_", "?", "NumericQ"}], "]"}], ":=", 
        RowBox[{
         RowBox[{"1", "/", "2"}], " ", "m", " ", 
         RowBox[{"\[Omega]", "^", "2"}], " ", 
         RowBox[{"x", "^", "2"}]}]}], ";", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"xT", "[", "k_", "]"}], ":=", 
        RowBox[{"Sqrt", "[", 
         RowBox[{"2", " ", 
          RowBox[{
           RowBox[{"En", "[", "k", "]"}], "/", 
           RowBox[{"(", 
            RowBox[{"m", " ", 
             RowBox[{"\[Omega]", "^", "2"}]}], ")"}]}]}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"blue", "=", 
        RowBox[{"RGBColor", "[", 
         RowBox[{"0.18", ",", "0.46", ",", "0.78"}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"xmax", "=", 
        RowBox[{
         RowBox[{"xT", "[", "nTop", "]"}], "+", "1.2"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"ymax", "=", 
        RowBox[{
         RowBox[{"En", "[", "nTop", "]"}], "+", "1.2"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"yRule", "=", 
        RowBox[{"ymax", "-", "0.25"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"(*", 
        RowBox[{
         RowBox[{"shorter", " ", "dash", " ", "pattern"}], "+", 
         RowBox[{"smaller", " ", "gaps", " ", 
          RowBox[{"(", 
           RowBox[{"fix", " ", "\"\<too apart\>\""}], ")"}]}]}], "*)"}], 
       "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"solid", "[", "k_", "]"}], ":=", 
        RowBox[{"{", 
         RowBox[{"Black", ",", "Thick", ",", 
          RowBox[{"Line", "[", 
           RowBox[{"{", 
            RowBox[{
             RowBox[{"{", 
              RowBox[{
               RowBox[{"-", 
                RowBox[{"xT", "[", "k", "]"}]}], ",", 
               RowBox[{"En", "[", "k", "]"}]}], "}"}], ",", 
             RowBox[{"{", 
              RowBox[{
               RowBox[{"xT", "[", "k", "]"}], ",", 
               RowBox[{"En", "[", "k", "]"}]}], "}"}]}], "}"}], "]"}]}], 
         "}"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"dashed", "[", "k_", "]"}], ":=", 
        RowBox[{"{", 
         RowBox[{"Black", ",", "Thick", ",", "Dashed", ",", 
          RowBox[{"Line", "[", 
           RowBox[{"{", 
            RowBox[{
             RowBox[{"{", 
              RowBox[{
               RowBox[{"-", 
                RowBox[{"xT", "[", "k", "]"}]}], ",", 
               RowBox[{"En", "[", "k", "]"}]}], "}"}], ",", 
             RowBox[{"{", 
              RowBox[{
               RowBox[{"xT", "[", "k", "]"}], ",", 
               RowBox[{"En", "[", "k", "]"}]}], "}"}]}], "}"}], "]"}]}], 
         "}"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"dot", "[", "k_", "]"}], ":=", 
        RowBox[{"{", 
         RowBox[{"Black", ",", 
          RowBox[{"PointSize", "[", "0.015", "]"}], ",", 
          RowBox[{"Point", "[", 
           RowBox[{"{", 
            RowBox[{
             RowBox[{"{", 
              RowBox[{
               RowBox[{"-", 
                RowBox[{"xT", "[", "k", "]"}]}], ",", 
               RowBox[{"En", "[", "k", "]"}]}], "}"}], ",", 
             RowBox[{"{", 
              RowBox[{
               RowBox[{"xT", "[", "k", "]"}], ",", 
               RowBox[{"En", "[", "k", "]"}]}], "}"}]}], "}"}], "]"}]}], 
         "}"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"top", "=", 
        RowBox[{"{", 
         RowBox[{"Black", ",", "Thick", ",", 
          RowBox[{"Line", "[", 
           RowBox[{"{", 
            RowBox[{
             RowBox[{"{", 
              RowBox[{
               RowBox[{
                RowBox[{"-", "0.78"}], " ", "xmax"}], ",", "yRule"}], "}"}], ",", 
             RowBox[{"{", 
              RowBox[{
               RowBox[{"0.78", " ", "xmax"}], ",", "yRule"}], "}"}]}], "}"}], 
           "]"}], ",", 
          RowBox[{"Text", "[", 
           RowBox[{
            RowBox[{"Style", "[", 
             RowBox[{"\"\<n\>\"", ",", "18", ",", "Italic", ",", "blue"}], 
             "]"}], ",", 
            RowBox[{"{", 
             RowBox[{
              RowBox[{
               RowBox[{"-", "0.72"}], " ", "xmax"}], ",", 
              RowBox[{"yRule", "+", "0.28"}]}], "}"}]}], "]"}], ",", 
          RowBox[{"(*", 
           RowBox[{"fix", ":", 
            RowBox[{
            "show", " ", "\:0127\[Omega]", " ", "clearly", " ", "using", " ", 
             "\[HBar]\[Omega]", " ", "and", " ", "HoldForm"}]}], "*)"}], 
          RowBox[{"Text", "[", 
           RowBox[{
            RowBox[{"Style", "[", 
             RowBox[{
              RowBox[{"TraditionalForm", "[", 
               RowBox[{"HoldForm", "[", 
                RowBox[{"\[HBar]\[Omega]", " ", 
                 RowBox[{"(", 
                  RowBox[{"n", "+", 
                   RowBox[{"1", "/", "2"}]}], ")"}]}], "]"}], "]"}], ",", 
              "18", ",", "blue"}], "]"}], ",", 
            RowBox[{"{", 
             RowBox[{
              RowBox[{"0.40", " ", "xmax"}], ",", 
              RowBox[{"yRule", "+", "0.28"}]}], "}"}]}], "]"}]}], "}"}]}], ";",
        "\[IndentingNewLine]", 
       RowBox[{"labelsL", "=", 
        RowBox[{"Table", "[", 
         RowBox[{
          RowBox[{"Text", "[", 
           RowBox[{
            RowBox[{"Style", "[", 
             RowBox[{
              RowBox[{"Row", "[", 
               RowBox[{"{", 
                RowBox[{"\"\<n = \>\"", ",", "k"}], "}"}], "]"}], ",", "16", ",",
               "Italic", ",", "blue"}], "]"}], ",", 
            RowBox[{"{", 
             RowBox[{
              RowBox[{
               RowBox[{"-", 
                RowBox[{"xT", "[", "k", "]"}]}], "-", "1.0"}], ",", 
              RowBox[{"En", "[", "k", "]"}]}], "}"}]}], "]"}], ",", 
          RowBox[{"{", 
           RowBox[{"k", ",", "0", ",", "nSolid"}], "}"}]}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"(*", 
        RowBox[{"show", " ", "numeric", " ", "multiples", " ", 
         RowBox[{"(", 
          RowBox[{"0.5", ",", "1.5", ",", "2.5"}], ")"}], " ", "like", " ", 
         "your", " ", "picture"}], "*)"}], 
       RowBox[{"labelsR", "=", 
        RowBox[{"Table", "[", 
         RowBox[{
          RowBox[{"Text", "[", 
           RowBox[{
            RowBox[{"Style", "[", 
             RowBox[{
              RowBox[{"TraditionalForm", "[", 
               RowBox[{
                RowBox[{"(", 
                 RowBox[{
                  RowBox[{"2", " ", "k"}], "+", "1"}], ")"}], " ", 
                RowBox[{"\[HBar]\[Omega]", "/", "2"}]}], "]"}], ",", "16", ",",
               "blue"}], "]"}], ",", 
            RowBox[{"{", 
             RowBox[{
              RowBox[{
               RowBox[{"xT", "[", "k", "]"}], "+", "1.0"}], ",", 
              RowBox[{"En", "[", "k", "]"}]}], "}"}]}], "]"}], ",", 
