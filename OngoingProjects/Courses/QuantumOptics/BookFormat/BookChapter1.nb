Cell[CellGroupData[{

Cell["Quantum fluctuations for a single mode field", "Subsection",
 CellChangeTimes->{{3.9302358409620667`*^9, 3.9302358472274265`*^9}},
 CellID->471845087,ExpressionUUID->"531fe8b8-6873-fd4e-8830-7959bdd0fd70"],

Cell[TextData[{
 "Define the electric-field operator ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     OverscriptBox["E", "^"], "(", 
     RowBox[{"r", ",", "t"}], ")"}], "=", 
    RowBox[{"\[ImaginaryI]", 
     SqrtBox[
      FractionBox[
       RowBox[{"\[HBar]", " ", "\[Omega]"}], 
       RowBox[{"2", " ", 
        SubscriptBox["\[CurlyEpsilon]", "0"], " ", "V"}]]], 
     RowBox[{"(", 
      RowBox[{
       RowBox[{
        OverscriptBox["a", "^"], " ", 
        SuperscriptBox["\[ExponentialE]", 
         RowBox[{"\[ImaginaryI]", " ", 
          RowBox[{"(", 
           RowBox[{
            RowBox[{"k", " ", "\[CenterDot]", " ", "r"}], " ", "-", " ", 
            RowBox[{"\[Omega]", " ", "t"}]}], ")"}]}]]}], "-", 
       RowBox[{
        SuperscriptBox[
         OverscriptBox["a", "^"], "\[Dagger]"], 
        SuperscriptBox["\[ExponentialE]", 
         RowBox[{
          RowBox[{"-", "\[ImaginaryI]"}], " ", 
          RowBox[{"(", 
           RowBox[{
            RowBox[{"k", " ", "\[CenterDot]", " ", "r"}], " ", "-", " ", 
            RowBox[{"\[Omega]", " ", "t"}]}], ")"}]}]]}]}], ")"}]}]}], 
   TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "47db8e73-9192-8b46-88e5-599dd94fc174"],
 ":"
}], "Text",
 CellID->70780184,ExpressionUUID->"6e6fd5fc-83c0-c14b-bc2b-f48f089225a5"],

Cell[BoxData[
 RowBox[{
  FormBox[
   RowBox[{"Ex", ":=", 
    RowBox[{"\[ImaginaryI]", " ", 
     SqrtBox[
      FractionBox[
       RowBox[{"h", " ", "\[Omega]"}], 
       RowBox[{"2", " ", "V", " ", 
        SubscriptBox["\[Epsilon]", "0"]}]]], " ", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{"a", " ", 
        RowBox[{"exp", "(", 
         RowBox[{"\[ImaginaryI]", " ", 
          RowBox[{"(", 
           RowBox[{
            RowBox[{"k", ".", "r"}], "-", 
            RowBox[{"t", " ", "\[Omega]"}]}], ")"}]}], ")"}]}], "-", 
       RowBox[{
        SuperscriptBox["a", "\[Dagger]"], " ", 
        RowBox[{"exp", "(", 
         RowBox[{
          RowBox[{"-", "\[ImaginaryI]"}], " ", 
          RowBox[{"(", 
           RowBox[{
            RowBox[{"k", ".", "r"}], "-", 
            RowBox[{"t", " ", "\[Omega]"}]}], ")"}]}], ")"}]}]}], ")"}]}]}],
   TraditionalForm], ";"}]], "Input",
 CellLabel->"In[42]:=",
 CellID->630486553,ExpressionUUID->"27b529e0-43a0-f647-8777-2de650901529"],

Cell[TextData[{
 "The energy eigenstate |",
 Cell[BoxData[
  FormBox["n", TraditionalForm]],ExpressionUUID->
  "7b8d5b22-f701-c242-a84b-bd18c0d1a772"],
 "\[RightAngleBracket] has a definite energy but no definite electric field. \
Using the ladder-operator action, it is straightforward to show that any Fock \
state has zero mean field:"
}], "Text",
 CellChangeTimes->{{3.9302392978839817`*^9, 3.930239543346224*^9}, {
  3.933684359942332*^9, 3.933684361907503*^9}, {3.9336844972336793`*^9, 
