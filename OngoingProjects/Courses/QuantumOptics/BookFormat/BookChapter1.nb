Cell[TextData[{
 "Verify the relation ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox[
    OverscriptBox["a", "^"], "\[Dagger]"], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "94c0c309-1fed-2f4a-8541-74db663577dd"],
 "|",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"n", "\[RightAngleBracket]"}], "=", 
    SqrtBox[
     RowBox[{"n", "+", "1"}]]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "a9f02c0a-cd19-d044-ba82-edc5c180bf38"],
 "|",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"n", "+", "1"}], "\[RightAngleBracket]"}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "bc871635-6537-9c49-9328-322421b830df"],
 ":"
}], "Text",
 CellID->2012237946,ExpressionUUID->"25a991f1-1a5c-4618-9f00-1838fc290324"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{
   SuperscriptBox["a", "\[Dagger]"], " ", "@", " ", 
