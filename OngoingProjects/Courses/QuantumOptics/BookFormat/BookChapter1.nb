Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"\[Psi]", " ", "=", " ", 
  RowBox[{
   RowBox[{"\[Alpha]", " ", 
    RowBox[{"FockState", "[", "0", "]"}]}], "+", 
   RowBox[{"\[Beta]", " ", 
    RowBox[{"FockState", "[", "1", "]"}]}]}]}]], "ExerciseInput",
