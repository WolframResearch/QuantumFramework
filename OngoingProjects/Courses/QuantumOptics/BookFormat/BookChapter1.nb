      SubscriptBox["\[Epsilon]", "0"]}]], ",", 
    FractionBox[
     RowBox[{"9", " ", "h", " ", "\[Omega]"}], 
     RowBox[{"2", " ", "V", " ", 
      SubscriptBox["\[Epsilon]", "0"]}]], ",", 
    FractionBox[
     RowBox[{"11", " ", "h", " ", "\[Omega]"}], 
     RowBox[{"2", " ", "V", " ", 
      SubscriptBox["\[Epsilon]", "0"]}]], ",", 
    FractionBox[
     RowBox[{"13", " ", "h", " ", "\[Omega]"}], 
     RowBox[{"2", " ", "V", " ", 
      SubscriptBox["\[Epsilon]", "0"]}]], ",", 
    FractionBox[
     RowBox[{"15", " ", "h", " ", "\[Omega]"}], 
     RowBox[{"2", " ", "V", " ", 
      SubscriptBox["\[Epsilon]", "0"]}]], ",", 
    FractionBox[
     RowBox[{"17", " ", "h", " ", "\[Omega]"}], 
     RowBox[{"2", " ", "V", " ", 
      SubscriptBox["\[Epsilon]", "0"]}]], ",", 
    FractionBox[
     RowBox[{"19", " ", "h", " ", "\[Omega]"}], 
     RowBox[{"2", " ", "V", " ", 
      SubscriptBox["\[Epsilon]", "0"]}]], ",", 
    FractionBox[
     RowBox[{"21", " ", "h", " ", "\[Omega]"}], 
     RowBox[{"2", " ", "V", " ", 
      SubscriptBox["\[Epsilon]", "0"]}]]}], "}"}], TraditionalForm]], "Output",\

 CellLabel->"Out[45]=",
 CellID->735206781,ExpressionUUID->"2f96099d-34d6-0248-84c4-33e74185204e"]
}, Open  ]],

Cell[TextData[{
 "For an operator, the variance is defined as ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox[
     RowBox[{"(", 
      RowBox[{"\[CapitalDelta]", " ", 
       OverscriptBox["X", "^"]}], ")"}], "2"], "=", 
    RowBox[{
     RowBox[{"\[LeftAngleBracket]", 
      SuperscriptBox[
       OverscriptBox["X", "^"], "2"], "\[RightAngleBracket]"}], "-", 
     SuperscriptBox[
      RowBox[{"\[LeftAngleBracket]", 
       OverscriptBox["X", "^"], "\[RightAngleBracket]"}], "2"]}]}], 
   TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "11f38766-1049-ee44-a2d0-065fc0dbd0f5"],
 ", and the standard deviation (uncertainty) is its square root. For a number \
state we obtain:"
}], "Text",
 CellID->456143393,ExpressionUUID->"1d53e729-ec62-6541-9af1-39d4708b2ada"],

Cell[BoxData[Cell[TextData[Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["\[CapitalDelta]E", "x"], "=", 
    RowBox[{
     SqrtBox[
      FractionBox[
       RowBox[{"\[HBar]", " ", "\[Omega]"}], 
       RowBox[{"V", " ", 
        SubscriptBox["\[CurlyEpsilon]", "0"]}]]], 
     SubscriptBox["\[CurlyEpsilon]", "0"], 
     RowBox[{"sin", "(", 
      RowBox[{"k", " ", "z"}], ")"}], 
     SqrtBox[
      RowBox[{"n", "+", 
       RowBox[{"1", "/", "2"}]}]]}]}], TraditionalForm]],ExpressionUUID->
  "f77ed082-74ae-9c4b-b911-c5b391eaa7b2"]], "Text",ExpressionUUID->
  "608db262-f865-e04f-b433-93ae647c2fe3"]], "DisplayFormula",
 CellID->13641621,ExpressionUUID->"681c53ee-2f7e-e344-b3fc-389b9d7fe6a7"],

Cell[TextData[{
 "Even when n = 0 the mean field is zero but the uncertainty is not; this is \
vacuum fluctuations. This follows from the uncertainty principle because ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    OverscriptBox["n", "^"], " ", "and", " ", 
    OverscriptBox[
     SubscriptBox["E", "x"], "^"]}], TraditionalForm]],ExpressionUUID->
  "56b71ede-b6c7-d246-ae83-acb0c4c7b974"],
 " do not commute."
}], "Text",
 CellChangeTimes->{3.965154718362097*^9},
 CellID->209550954,ExpressionUUID->"3da52841-244b-3b47-b49c-d18a919ddb19"]
}, Open  ]],

Cell[CellGroupData[{

Cell[TextData[StyleBox["Quadrature operators of a single mode field", \
"Subsection"]], "Subsection",
 CellChangeTimes->{{3.927723450549315*^9, 3.927723457197167*^9}},
 CellID->119452477,ExpressionUUID->"f429c8e5-9b60-4f42-9935-a85479b9f26f"],

Cell["Define the quadrature operators:", "Text",
 CellChangeTimes->{{3.927724248766546*^9, 3.927724270498722*^9}, {
   3.927904051022519*^9, 3.927904057193896*^9}, {3.9279041606540813`*^9, 
   3.9279041633229694`*^9}, {3.92790635143997*^9, 3.927906352082363*^9}, {
   3.92825985596776*^9, 3.928259885918638*^9}, {3.9302403066843033`*^9, 
   3.9302403186959076`*^9}, {3.953734983034912*^9, 3.9537349925583096`*^9}, 
   3.953735196896982*^9, {3.965154758978466*^9, 3.965154761924591*^9}},
 CellID->133410571,ExpressionUUID->"890df4ba-8216-e74a-9322-69a0ca369857"],

Cell[BoxData[
 FormBox[
  RowBox[{
   RowBox[{
    SubscriptBox[
     OverscriptBox["X", "^"], "1"], "=", 
    RowBox[{
     FractionBox["1", "2"], 
     RowBox[{"(", 
      RowBox[{
       SuperscriptBox[
        OverscriptBox["a", "^"], "\[Dagger]"], "+", 
       OverscriptBox["a", "^"]}], ")"}]}]}], " ", ",", "         ", 
   RowBox[{
    SubscriptBox["X", "2"], "=", 
    RowBox[{
     FractionBox["1", 
      RowBox[{"2", " ", "\[ImaginaryI]"}]], 
     RowBox[{"(", 
      RowBox[{
       OverscriptBox["a", "^"], "-", 
       SuperscriptBox[
        OverscriptBox["a", "^"], "\[Dagger]"]}], ")"}]}]}]}], 
  TraditionalForm]], "DisplayFormula",
 FontSize->18,
 CellID->651568837,ExpressionUUID->"177cb0a7-b22d-e64a-9cdf-184a10eda05f"],

Cell[TextData[StyleBox["They are supported calling the following function:", \
"Text"]], "CodeText",
 CellChangeTimes->{{3.9651548347702446`*^9, 3.9651548598861847`*^9}},
 CellID->291308480,ExpressionUUID->"26174c67-21b5-e94a-86fe-567f310e9840"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"{", 
    RowBox[{"X1", ",", "X2"}], "}"}], "=", 
   RowBox[{"QuadratureOperators", "[", "]"}]}], ";"}]], "Input",
 CellChangeTimes->{{3.933955070475483*^9, 3.933955107916601*^9}, {
  3.934038079475252*^9, 3.934038096046171*^9}},
 CellLabel->"In[46]:=",
 CellID->10087065,ExpressionUUID->"7dfe5e61-c04f-0f4b-8e54-1e2dc279f7b0"],

Cell[TextData[{
 "Quadratures describe the field in optical phase space, and their commutator \
mirrors the position-momentum relation [",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox[
     OverscriptBox["X", "^"], "1"], ",", 
    SubscriptBox[
     OverscriptBox["X", "^"], "2"]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "49b2a72e-1c5b-0a4d-9c3a-53bf42684e47"],
 "]",
 Cell[BoxData[
  FormBox[
   RowBox[{"=", " ", 
    RowBox[{"\[ImaginaryI]", "/", "2"}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "c10bf025-d8ba-684f-b36f-5eacce5a954f"],
 "."
}], "Text",
 CellID->177971961,ExpressionUUID->"495b82a2-b4ea-f64d-a815-17aca2782e6e"],

Cell["The last term deviates because of truncation:", "Text",
 CellChangeTimes->{{3.953735266346281*^9, 3.9537352781004467`*^9}},
 CellID->368408399,ExpressionUUID->"ce31c8a6-b747-e145-b7a6-4139b7512179"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"MatrixPlot", "[", 
  RowBox[{
   FractionBox[
    RowBox[{"Commutator", "[", 
     RowBox[{"X1", ",", "X2"}], "]"}], 
    RowBox[{"\[ImaginaryI]", "/", "2"}]], "[", "\"\<Matrix\>\"", "]"}], 
  "]"}]], "Input",
