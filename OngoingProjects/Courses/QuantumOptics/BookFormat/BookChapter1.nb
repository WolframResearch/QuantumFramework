Cell["Energy eigenvalues:", "Text",
 CellChangeTimes->{{3.9277239871476173`*^9, 3.9277239984158764`*^9}, {
  3.965155979219145*^9, 3.9651559904541473`*^9}},
 CellID->291847586,ExpressionUUID->"9870cec7-7c6e-c142-8e4d-e06d0f528f35"],

Cell[BoxData[{
 RowBox[{"Clear", "[", "n", "]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"En", " ", "=", " ", 
   RowBox[{"h", " ", "\[Omega]", " ", 
    RowBox[{"(", 
     RowBox[{"n", " ", "+", " ", 
      RowBox[{"1", "/", "2"}]}], ")"}]}]}], ";"}]}], "Input",
 CellChangeTimes->{{3.926606250636841*^9, 3.9266062874497223`*^9}, {
  3.953735443758013*^9, 3.953735448646078*^9}},
 CellLabel->"In[55]:=",
 CellID->70618524,ExpressionUUID->"3ab049d1-a12a-b84f-b7f4-35dd789ad9d0"],

Cell[TextData[{
 "The partition function ",
 Cell[BoxData[
  FormBox["Z", TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "f69eaaca-9cd9-614a-930b-046333e181dd"],
 " is:"
}], "Text",
 CellID->467941185,ExpressionUUID->"840230d2-7f95-8644-8c96-0c692e42ea48"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Z", " ", "=", 
  RowBox[{"Sum", "[", 
   RowBox[{
    RowBox[{"Exp", "[", 
     RowBox[{
      RowBox[{"-", "En"}], "/", 
      RowBox[{"(", 
       RowBox[{"kb", " ", "T"}], ")"}]}], "]"}], ",", 
    RowBox[{"{", 
     RowBox[{"n", ",", "0", ",", "\[Infinity]"}], "}"}]}], "]"}]}]], "Input",
 CellChangeTimes->{{3.9265987090706787`*^9, 3.92659880033202*^9}, {
  3.926598977082314*^9, 3.92659905574194*^9}, {3.926599268318629*^9, 
  3.926599269179224*^9}, {3.926605470455154*^9, 3.926605474755108*^9}, {
  3.926605572680912*^9, 3.926605573414533*^9}, {3.926606275459682*^9, 
  3.926606278184906*^9}, {3.926607490963743*^9, 3.926607491683014*^9}},
 CellLabel->"In[57]:=",
 CellID->251719881,ExpressionUUID->"439f38ed-69f8-6c4e-abcc-cda9f618a0aa"],

Cell[BoxData[
 FractionBox[
  SuperscriptBox["\[ExponentialE]", 
   FractionBox[
    RowBox[{"h", " ", "\[Omega]"}], 
    RowBox[{"2", " ", "kb", " ", "T"}]]], 
  RowBox[{
   RowBox[{"-", "1"}], "+", 
   SuperscriptBox["\[ExponentialE]", 
    FractionBox[
     RowBox[{"h", " ", "\[Omega]"}], 
     RowBox[{"kb", " ", "T"}]]]}]]], "Output",
 CellLabel->"Out[57]=",
 CellID->31265693,ExpressionUUID->"317e8756-96f5-354c-adac-c75a4f32e746"]
}, Open  ]],

Cell[TextData[{
 "The probability of finding ",
 Cell[BoxData[
  FormBox["n", TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "58174778-b1a3-3945-bd9d-f47f65383844"],
 " photons is:"
}], "Text",
 CellID->106381834,ExpressionUUID->"929e4dee-701b-0a4f-aa31-adf0be3b0b81"],

Cell[BoxData[
 FormBox[
  RowBox[{
   SubscriptBox["P", "n"], "=", " ", 
   RowBox[{
    RowBox[{"\[LeftAngleBracket]", 
     RowBox[{"n", "|", 
      SubscriptBox["\[Rho]", "th"], "|", "n"}], "\[RightAngleBracket]"}], "=", 
    RowBox[{
     FractionBox["1", "Z"], "exp", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{
        RowBox[{"-", 
         SubscriptBox["E", "n"]}], "/", 
        SubscriptBox["k", "B"]}], "T"}], ")"}]}]}]}], 
  TraditionalForm]], "DisplayFormula",
 FontSize->18,
 CellID->70568003,ExpressionUUID->"80a9c9d3-fad8-9846-87a0-ea56d921af78"],

Cell["So the thermal state can be expressed as:", "Text",
 CellID->82925858,ExpressionUUID->"eb97303d-f764-9f4f-8bae-ff89cc498268"],

Cell[BoxData[
 StyleBox[
  RowBox[{Cell[BoxData[
    FormBox[
     RowBox[{
      SubscriptBox["\[Rho]", "th"], "=", " ", 
      RowBox[{
       UnderscriptBox[
        OverscriptBox[
         OverscriptBox["\[Sum]", " "], "\[Infinity]"], 
        RowBox[{"n", " ", "=", "0"}]], 
       SubscriptBox["P", "n"]}]}], TraditionalForm]], "DisplayFormula",
    ExpressionUUID->"94f46cf3-21e8-014c-b782-bfd9f6f3fa72"], Cell[BoxData[
    FormBox[
     RowBox[{
      RowBox[{
       RowBox[{"|", "n"}], "\[RightAngleBracket]"}], 
      RowBox[{"\[LeftAngleBracket]", 
       RowBox[{"n", "|"}]}]}], TraditionalForm]], "DisplayFormula",
    ExpressionUUID->"87651956-1259-174a-9022-1f08703bd461"]}], 
  "DisplayFormula",
  FontSize->18]], "DisplayFormula",
 FontSize->36,
 CellID->219386627,ExpressionUUID->"47827aac-4276-a441-b9ed-cc8be569e5f9"],

Cell[TextData[{
 "The average photon number is ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    OverscriptBox["n", "\[LongDash]"], "=", 
    RowBox[{
     RowBox[{"Tr", "(", 
      RowBox[{
       OverscriptBox["n", "^"], " ", 
       SubscriptBox["\[Rho]", "th"]}], ")"}], "=", " ", 
     RowBox[{
      UnderoverscriptBox[
       OverscriptBox["\[Sum]", " "], 
       RowBox[{"n", "=", "0"}], "\[Infinity]"], 
      RowBox[{"\[LeftAngleBracket]", 
       RowBox[{"n", "|", 
        RowBox[{
         OverscriptBox["n", "^"], " ", 
         SubscriptBox["\[Rho]", "th"]}], "|", "n"}], 
       "\[RightAngleBracket]"}]}]}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "39a76701-9fc6-e54f-80c4-1eff7fa417b7"],
 "."
}], "Text",
 CellID->31350705,ExpressionUUID->"47e6692d-bcd0-584d-9fc6-3eabcaf80d97"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"Sum", "[", 
   RowBox[{
    RowBox[{"n", " ", 
     RowBox[{"Exp", "[", 
