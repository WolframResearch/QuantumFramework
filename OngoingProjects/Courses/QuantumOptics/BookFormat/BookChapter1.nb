Cell[CellGroupData[{

Cell[TextData[StyleBox["Thermal fields", "Subsection"]], "Subsection",
 CellChangeTimes->{{3.927723625747513*^9, 3.9277236289367485`*^9}},
 CellID->86846476,ExpressionUUID->"0a76adb5-384a-554b-86d2-06d6e62b5009"],

Cell[TextData[{
 "Consider a single-mode field in thermal equilibrium in a cavity at \
temperature ",
 Cell[BoxData[
  FormBox["T", TraditionalForm]],ExpressionUUID->
  "1601ad39-37e6-3640-a67b-4076f9b9217f"],
 ". Statistical mechanics gives the photon-number distribution ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox["P", "n"], " ", "that", " ", "the", " ", "n"}], "-", 
    RowBox[{"th", " ", "level", " ", "is", " ", "excited", " ", "is"}]}], 
   TraditionalForm]],ExpressionUUID->"3b7a837f-6145-d94a-a7ec-973553b0aafd"],
 ":"
}], "Text",
 CellChangeTimes->{{3.926596212657816*^9, 3.92659627797184*^9}, {
  3.9265964284169884`*^9, 3.926596439428404*^9}, {3.926596471075287*^9, 
  3.926596517305584*^9}},
 CellID->68194063,ExpressionUUID->"b5d1b2b5-0f22-6843-9772-81bfe7734669"],

Cell[BoxData[
 FormBox[
  RowBox[{
   SubscriptBox["P", 
    RowBox[{"n", " "}]], "=", 
   RowBox[{
    FractionBox[
     RowBox[{"exp", "(", 
      RowBox[{
       RowBox[{
        SubscriptBox["E", "n"], "/", 
        SubscriptBox["k", "B"]}], "T"}], ")"}], 
     RowBox[{
      SubscriptBox["E", "n"], " ", 
      RowBox[{"exp", "(", 
       RowBox[{
        RowBox[{
         SubscriptBox["E", "n"], "/", 
         SubscriptBox["k", "B"]}], "T"}], ")"}]}]], " ", "where", " ", 
    SubscriptBox["k", "B"], " ", "is", " ", "the", " ", "Boltzmann", " ", 
    "constant"}]}], TraditionalForm]], "DisplayFormula",
 CellID->225696696,ExpressionUUID->"4a804b1a-e1a1-494d-9133-25c0252d0853"],

Cell[TextData[{
 "Using the Hamiltonian ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    OverscriptBox["H", "^"], "=", " ", 
    RowBox[{"\[HBar]", " ", "\[Omega]", " ", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{
        SuperscriptBox[
         OverscriptBox["a", "^"], "\[Dagger]"], "a"}], "+", 
       RowBox[{"1", "/", "2"}]}], ")"}]}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "6a71174b-ada6-4e4c-a3ae-8fb213a9b889"],
 ", the thermal (mixed) state is described by a density operator built from \
this distribution:"
}], "Text",
 CellID->554727766,ExpressionUUID->"55534f98-315d-7b47-b7a2-60ae73cc4df8"],

Cell[BoxData[
 RowBox[{
  StyleBox[" ", "Text",
   FontSize->18], Cell[TextData[Cell[BoxData[
   FormBox[
    RowBox[{
     SubscriptBox["\[Rho]", "Th"], "=", " ", 
     FractionBox[
      RowBox[{"exp", "(", 
       RowBox[{
        RowBox[{
         RowBox[{"-", 
          OverscriptBox["H", "^"]}], "/", 
         SubscriptBox["k", "B"]}], "T"}], ")"}], 
      RowBox[{"Tr", "[", " ", 
       RowBox[{"exp", "(", 
        RowBox[{
         RowBox[{
          RowBox[{"-", 
           OverscriptBox["H", "^"]}], "/", 
          SubscriptBox["k", "B"]}], "T"}], ")"}], "]"}]]}], TraditionalForm]],
   ExpressionUUID->"ee056db2-5662-5846-aaeb-7204f14c4368"]], "Text",
   ExpressionUUID->
   "b8d27527-8253-2844-8453-62b6a2ab0450"]}]], "DisplayFormula",
 CellID->724883312,ExpressionUUID->"58a02766-ef18-a64d-8595-42825cfedb73"],

Cell[BoxData[
 FormBox[
  RowBox[{
  "The", " ", "denominator", " ", "is", " ", "the", " ", "partition", " ", 
   RowBox[{"function", ":"}]}], TraditionalForm]], "Text",
