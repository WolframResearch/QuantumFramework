  "1ecf4ddc-4c39-5442-8709-f7cc38dbf342"],
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"0", "\[RightAngleBracket]"}], 
    RowBox[{"\[LeftAngleBracket]", "0"}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "d6473ed5-d841-f74f-8c21-9c077d899121"],
 Cell[BoxData[
  FormBox["|", TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "c72d805c-9671-c745-a1d3-f534f8e4d7d4"],
 " (in the truncated basis the last term is affected by truncation)."
}], "Text",
