Cell[CellGroupData[{

Cell[BoxData[
 InterpretationBox["Exercises",
  $Line = 0; Null]], "ExerciseSection",
 CellID->132588827,ExpressionUUID->"08bf0b5e-1694-dc47-be01-3e47923cff78"],

Cell[TextData[{
 StyleBox["Considering a thermal state with ",
  FontWeight->"Bold"],
 Cell[BoxData[
  FormBox["x", TraditionalForm]],
  FontWeight->"Bold",
  FontSlant->"Plain",ExpressionUUID->"25b982bd-60e2-6848-a8cf-5579be53224c"],
 StyleBox[" mean number of photons. What happens to the mean number of \
photons after applying the annihilation operator? Do a plot",
  FontWeight->"Bold"]
}], "Exercise",
 CellChangeTimes->{{3.9714567628251038`*^9, 3.9714568191651764`*^9}, {
  3.971456884854746*^9, 3.9714568869443703`*^9}},
 CellID->52845830,ExpressionUUID->"a9909aa2-688c-9147-a545-b68363c986c1"],

Cell["Solution", "ExerciseSolution",
 CellID->652494427,ExpressionUUID->"27f1c36e-1faa-1c45-924b-8395e68d7f09"],

Cell[CellGroupData[{

Cell[TextData[StyleBox["Surprisingly it doubles, note the state becomes not \
normalized after the annihilation operator application:", "Exercise"]], \
"ExerciseNote",
 CellID->153164176,ExpressionUUID->"064471d2-e42d-814b-ab82-72873cd8c7d3"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Plot", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"x", ",", 
     RowBox[{"Evaluate", "[", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{
         RowBox[{"QuantumMeasurementOperator", "[", "numberOp", "]"}], "@", 
         RowBox[{"(", 
          RowBox[{"a", "@", 
           RowBox[{"ThermalState", "[", "x", "]"}]}], ")"}]}], ")"}], 
       "[", "\"\<Mean\>\"", "]"}], "]"}]}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{"x", ",", "0", ",", "1"}], "}"}], ",", 
   RowBox[{"AxesLabel", "->", 
    RowBox[{"{", 
     RowBox[{"\"\<x\>\"", 
      ",", "\"\<\[LeftAngleBracket]n\[RightAngleBracket]\>\""}], "}"}]}]}], 
  "]"}]], "ExerciseInput",
 CellChangeTimes->{{3.971456084505522*^9, 3.9714561128002167`*^9}, {
  3.971456200738186*^9, 3.971456226562109*^9}, {3.971456276954809*^9, 
