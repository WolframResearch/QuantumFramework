Cell[BoxData[
 FormBox[
  StyleBox[
   RowBox[{Cell[BoxData[
     FormBox[
      RowBox[{
       RowBox[{"\[ScriptCapitalP]", "(", "\[Phi]", ")"}], "=", 
       FractionBox["1", 
        RowBox[{"2", " ", "\[Pi]"}]]}], TraditionalForm]], "DisplayFormula",
     ExpressionUUID->"6f2fef0a-76b9-1d42-86ba-9877ab2805fc"], " ", Cell[
