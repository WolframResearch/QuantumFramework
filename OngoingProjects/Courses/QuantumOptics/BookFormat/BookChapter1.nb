Cell["\<\
You can derive the commutator exactly using the non-commutative algebra tools \
(version 14.3 and later):\
\>", "Text",
 CellChangeTimes->{{3.965155153988455*^9, 3.9651551549682503`*^9}, {
  3.965155794221506*^9, 3.965155802356924*^9}},
 CellID->112948960,ExpressionUUID->"8f78194d-4020-444f-8ede-eacf0c9c5b35"],

Cell[TextData[StyleBox["Define the fundamental non-commuting variables and \
the quadratures in terms of them :", "Text"]], "CodeText",
 CellID->346341127,ExpressionUUID->"e1973c0b-41e5-014c-93e2-7147609ee13c"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"vars", " ", "=", " ", 
   RowBox[{"{", 
    RowBox[{"\[FormalA]", ",", 
     SuperscriptBox["\[FormalA]", "\[Dagger]"]}], "}"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"{", 
    RowBox[{"X1symb", ",", " ", "X2symb"}], "}"}], " ", "=", " ", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{
      FractionBox["1", "2"], 
      RowBox[{"(", 
       RowBox[{"\[FormalA]", "+", 
        SuperscriptBox["\[FormalA]", "\[Dagger]"]}], ")"}]}], ",", " ", 
     RowBox[{
      FractionBox["1", 
       RowBox[{"2", "\[ImaginaryI]"}]], 
      RowBox[{"(", 
       RowBox[{"\[FormalA]", "-", 
        SuperscriptBox["\[FormalA]", "\[Dagger]"]}], ")"}]}]}], "}"}]}], 
  ";"}]}], "Input",
 CellChangeTimes->{{3.965155191832119*^9, 3.965155221790062*^9}, {
  3.9651553983959656`*^9, 3.9651554954741592`*^9}},
 CellLabel->"In[48]:=",
 CellID->165562674,ExpressionUUID->"ea643e47-850b-0142-9aa2-c5d11206b773"],

Cell[TextData[StyleBox["Define the commutation relation:", "Text"]], \
"CodeText",
 CellChangeTimes->{{3.9651552503058834`*^9, 3.9651552674713*^9}, {
  3.965155340215561*^9, 3.9651553425451126`*^9}},
 CellID->667546071,ExpressionUUID->"ed3ebafa-d970-8a4d-8e5c-eadcbe3f45c0"],

Cell[BoxData[
 RowBox[{
  RowBox[{"rel", " ", "=", " ", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"Commutator", "[", 
      RowBox[{"\[FormalA]", ",", " ", 
       SuperscriptBox["\[FormalA]", "\[Dagger]"]}], "]"}], "-", "1"}], 
    "}"}]}], ";"}]], "Input",
 CellChangeTimes->{{3.965155272340454*^9, 3.965155291026375*^9}, 
   3.965155593478113*^9},
 CellLabel->"In[50]:=",
 CellID->572718375,ExpressionUUID->"dafec93f-fb81-9049-9dba-d97803184405"],

Cell[TextData[StyleBox["Reduce the commutator of the quadratures:", "Text"]], \
"CodeText",
 CellChangeTimes->{{3.9651552503058834`*^9, 3.9651552674713*^9}, {
  3.965155340215561*^9, 3.9651553425451126`*^9}, {3.9651556302699337`*^9, 
  3.965155697331236*^9}},
 CellID->139989270,ExpressionUUID->"18a437d3-664d-184f-9044-c88f8b925a34"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"NonCommutativePolynomialReduce", "[", 
   RowBox[{
    RowBox[{"Commutator", "[", 
     RowBox[{"X1symb", ",", "X2symb"}], "]"}], ",", "rel", ",", "vars"}], 
   "]"}], "[", 
  RowBox[{"[", 
   RowBox[{"-", "1"}], "]"}], "]"}]], "Input",
 CellChangeTimes->{{3.965155556446974*^9, 3.9651556112330017`*^9}},
 CellLabel->"In[51]:=",
 CellID->111242763,ExpressionUUID->"d5823a52-06f4-2441-a0e6-31fbbb9f259d"],

Cell[BoxData[
 FractionBox["\[ImaginaryI]", "2"]], "Output",
 CellLabel->"Out[51]=",
 CellID->246557230,ExpressionUUID->"4fde08ce-9f14-4f4e-a077-bbcc4e1c4a07"]
}, Open  ]],

Cell[TextData[{
 "For a Fock state we find ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox[
     SubscriptBox[
      RowBox[{"(", 
       RowBox[{"\[CapitalDelta]", " ", 
        SubscriptBox[
         OverscriptBox["X", "^"], "1"]}], ")"}], "n"], "2"], "=", 
    RowBox[{
     SuperscriptBox[
      SubscriptBox[
       RowBox[{"(", 
        RowBox[{"\[CapitalDelta]", " ", 
         SubscriptBox[
          OverscriptBox["X", "^"], "2"]}], ")"}], "n"], "2"], "=", 
     RowBox[{
      FractionBox["1", "4"], 
      RowBox[{"(", 
       RowBox[{
        RowBox[{"2", "n"}], "+", "1"}], ")"}]}]}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "482e0650-44b1-af4f-80e9-ad9771760939"],
 " . The ground state |0\[RightAngleBracket] attains the minimum value 1/4:"
}], "Text",
 CellID->113213636,ExpressionUUID->"fd746f79-0f20-7b42-b529-a05e2b6f78dc"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Table", "[", 
  RowBox[{
   RowBox[{"{", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"OperatorVariance", "[", 
      RowBox[{
       RowBox[{"FockState", "[", "n", "]"}], ",", "X1"}], "]"}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{"OperatorVariance", "[", " ", 
      RowBox[{
       RowBox[{"FockState", "[", "n", "]"}], ",", "X2"}], "]"}]}], "}"}], " ",
    ",", "\[IndentingNewLine]", 
   RowBox[{"{", 
    RowBox[{"n", ",", "0", ",", 
     RowBox[{"$FockSize", "-", "2"}]}], "}"}]}], "]"}]], "Input",
 CellLabel->"In[54]:=",
 CellID->377854537,ExpressionUUID->"c34e2610-3460-724e-8b2d-ed7571d2570e"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     FractionBox["1", "4"], ",", 
     FractionBox["1", "4"]}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{
     FractionBox["3", "4"], ",", 
     FractionBox["3", "4"]}], "}"}], ",", 
   RowBox[{"{", 
