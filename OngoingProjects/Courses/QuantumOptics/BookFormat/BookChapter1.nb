Cell[TextData[{
 "Consider the superposition state |",
 Cell[BoxData[
  FormBox["\[Psi]", TraditionalForm]],ExpressionUUID->
  "e233b406-0707-4448-95f6-c790e296e860"],
 "\[RightAngleBracket] = \[Alpha] |0\[RightAngleBracket] + \[Beta] |1\
\[RightAngleBracket] , where ",
 Cell[BoxData[
  FormBox["\[Alpha]", TraditionalForm]],ExpressionUUID->
  "1706ef28-277b-9a4e-903c-bc903e92de8c"],
 " and ",
 Cell[BoxData[
  FormBox["\[Beta]", TraditionalForm]],ExpressionUUID->
  "f47f80c0-6443-6746-8595-a7304853b172"],
 " are complex and satisfy ",
 Cell[BoxData[
  FormBox[
   RowBox[{"|", "\[Alpha]", 
    SuperscriptBox["|", "2"], 
    RowBox[{"+", 
     RowBox[{"|", "\[Beta]", 
      SuperscriptBox["|", "2"]}]}]}], TraditionalForm]],ExpressionUUID->
  "fe058b68-3a23-e942-be02-a31f0f09018f"],
 ". Calculate the variances of the operators ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["X", "1"], TraditionalForm]],ExpressionUUID->
  "494bf14f-c725-0a4c-a428-e6d46fd072c2"],
 " and ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["X", "2"], TraditionalForm]],ExpressionUUID->
  "8fc888f1-ab57-fb4e-9fb1-f68620ac7046"],
 ". Are there any values of the parameters ",
 Cell[BoxData[
  FormBox["\[Alpha]", TraditionalForm]],ExpressionUUID->
  "a7634113-dc41-ff4e-bb06-5cdf55d063f7"],
 " and ",
 Cell[BoxData[
  FormBox["\[Beta]", TraditionalForm]],ExpressionUUID->
  "50c1fb0d-12e0-054d-b931-e33f916a5b71"],
 " for which either of the quadratures becomes less than for a vacuum state? \
If so, check if the uncertainty principle is violated"
}], "Exercise",
 CellFrame->{{0, 0}, {0, 0.5}},
 CellFrameColor->GrayLevel[0.75],
 CellID->261244721,ExpressionUUID->"a3257bf7-8fdc-9348-b486-c83151913988"],

Cell["Solution", "ExerciseSolution",
 CellID->355282437,ExpressionUUID->"4c12f947-36d8-0846-8cd6-834975d0b0b6"],

