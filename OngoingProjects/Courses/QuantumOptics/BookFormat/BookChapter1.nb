Cell[TextData[{
 "As expected from how ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     OverscriptBox["E", "^"], " ", "acts", " ", "on", " ", "Fock", " ", 
     "states"}], ","}], TraditionalForm]],ExpressionUUID->
  "0928d57f-7264-f349-a00b-657460c70333"],
 ", the last term fails the eigenstate equation in the truncated space:"
}], "Text",
 CellChangeTimes->{{3.931455373721369*^9, 3.9314554412674866`*^9}, {
  3.9714540786162663`*^9, 3.971454084852062*^9}},
 CellID->275154838,ExpressionUUID->"efb0b2e1-3f87-e343-a0ff-04244a8d9049"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(", " ", 
   RowBox[{
    RowBox[{"Ephase", "@", "phistate"}], "-", 
    RowBox[{
     SuperscriptBox["\[ExponentialE]", 
      RowBox[{"\[ImaginaryI]", " ", "\[Phi]"}]], " ", "phistate"}]}], ")"}], 
  "[", "\"\<AmplitudesList\>\"", "]"}]], "Input",
 CellChangeTimes->{{3.9314441056706667`*^9, 3.931444122822876*^9}, {
   3.9314441568343754`*^9, 3.931444168013551*^9}, {3.931444234518358*^9, 
