Cell[TextData[{
 "For a thermal state ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox["g", 
     RowBox[{"(", "2", ")"}]], "=", "2"}], TraditionalForm]],ExpressionUUID->
  "5645df1b-84cf-2e4c-ad3b-da9061dff3ed"],
 ", so we say thermal light is not second-order coherent and has higher \
probability of detecting coincident photons"
}], "Text",
 CellID->350187346,ExpressionUUID->"29558ef1-a1ca-9342-9008-e709043bd877"],

Cell["\<\
Second order coherence for a symbolic thermal state depending on the mean \
number of photons:\
\>", "Text",
 CellID->91372758,ExpressionUUID->"03d72cd6-86df-8d44-9091-d486f67a36fe"],

Cell[BoxData[
 RowBox[{
  RowBox[{"thermalG2", " ", "=", " ", 
