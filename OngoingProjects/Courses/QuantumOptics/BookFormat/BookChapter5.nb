Cell["Consider monochromatic light propagating in the z direction:", "Text",
 CellID->198737047,ExpressionUUID->"8ce7c035-5bac-7b41-91e7-edf013c93fcd"],

Cell[BoxData[
 RowBox[{
  RowBox[{"Efield", "[", 
   RowBox[{"z_", ",", "t_"}], "]"}], ":=", 
  RowBox[{"E0", " ", 
   SuperscriptBox["\[ExponentialE]", 
    RowBox[{"\[ImaginaryI]", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{"k", " ", "z"}], " ", "-", " ", 
       RowBox[{"\[Omega]", " ", "t"}]}], ")"}]}]]}]}]], "Input",
 CellLabel->"In[7]:=",
 CellID->772471254,ExpressionUUID->"6c6978bc-1f29-2445-8ce2-559fb465de6b"],

Cell[TextData[{
 "Electric field at times ",
 Cell[BoxData[
  FormBox["t", TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "df904dcf-3ac1-e044-8e97-0dc1d1b69e4b"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{"t", "+", "\[Tau]"}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "bce51dcc-86a8-834c-96d1-7cd88c4f3aab"],
 ":"
}], "Text",
 CellID->176519275,ExpressionUUID->"bf2bb570-7ae0-f145-9e49-4874c43c333c"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{"Efield", "[", 
    RowBox[{"z", ",", "t"}], "]"}], ",", 
   RowBox[{"Efield", "[", 
    RowBox[{"z", ",", 
     RowBox[{"t", "+", "\[Tau]"}]}], "]"}]}], "}"}]], "Input",
 CellLabel->"In[8]:=",
 CellID->203535267,ExpressionUUID->"7ddf4661-53bd-7b4c-a4e3-391d5e280df6"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{
    SuperscriptBox["\[ExponentialE]", 
     RowBox[{"\[ImaginaryI]", " ", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{"k", " ", "z"}], "-", 
        RowBox[{"t", " ", "\[Omega]"}]}], ")"}]}]], " ", "E0"}], ",", 
   RowBox[{
    SuperscriptBox["\[ExponentialE]", 
     RowBox[{"\[ImaginaryI]", " ", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{"k", " ", "z"}], "-", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{"t", "+", "\[Tau]"}], ")"}], " ", "\[Omega]"}]}], ")"}]}]], 
    " ", "E0"}]}], "}"}]], "Output",
 CellLabel->"Out[8]=",
 CellID->2573038,ExpressionUUID->"c7a9f3a8-6d5f-f147-bc55-f55a6d9731ba"]
}, Open  ]],

Cell[TextData[{
 "Calculate \[LeftAngleBracket]",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"E", "\[Conjugate]"}], 
    RowBox[{"(", 
     RowBox[{"z", ",", "t"}], ")"}], 
    RowBox[{"E", "(", 
     RowBox[{"z", ",", 
      RowBox[{"t", "+", "\[Tau]"}]}], ")"}]}], TraditionalForm]],
  ExpressionUUID->"ae98d932-0b9c-c340-be50-05db21865c09"],
 "\[RightAngleBracket], at position ",
 Cell[BoxData[
  FormBox["z", TraditionalForm]],ExpressionUUID->
  "d6ad7ff6-d46c-d94f-91fc-35d43c9637be"],
 " and times ",
 Cell[BoxData[
  FormBox["t", TraditionalForm]],ExpressionUUID->
  "5bf8d670-0456-ce49-a95f-586af3e19429"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{"t", "+", "\[Tau]"}], TraditionalForm]],ExpressionUUID->
  "066d8bc8-6042-d94f-8545-a63dcfe08711"],
 ": "
}], "Text",
 CellID->10367696,ExpressionUUID->"744dd2d8-4fa4-924d-8b6d-838782f61bf7"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"TimeExpectation", "[", 
  RowBox[{
   RowBox[{"ComplexExpand", "@", 
    RowBox[{"Conjugate", "@", 
     RowBox[{"Efield", "[", 
      RowBox[{"z", ",", "t"}], "]"}]}]}], 
   RowBox[{"Efield", "[", 
    RowBox[{"z", ",", 
     RowBox[{"t", "+", "\[Tau]"}]}], "]"}]}], "]"}]], "Input",
 CellLabel->"In[9]:=",
 CellID->250283569,ExpressionUUID->"678dc6e6-317c-8845-8a71-bbb21e3cfe1a"],

Cell[BoxData[
 RowBox[{
  SuperscriptBox["\[ExponentialE]", 
   RowBox[{
    RowBox[{"-", "\[ImaginaryI]"}], " ", "\[Tau]", " ", "\[Omega]"}]], " ", 
  SuperscriptBox["E0", "2"]}]], "Output",
 CellLabel->"Out[9]=",
 CellID->258596120,ExpressionUUID->"b9dfe0e8-d3c0-f04a-9cad-b27b3404da2f"]
}, Open  ]],

Cell[TextData[{
 "The auto-correlation function without considering position is ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[LeftAngleBracket]", 
    RowBox[{
     RowBox[{
      SuperscriptBox["E", "*"], "(", "t", ")"}], 
     RowBox[{"E", "(", 
      RowBox[{"t", "+", "\[Tau]"}], ")"}]}], "\[RightAngleBracket]"}], 
   TraditionalForm]],ExpressionUUID->"48b37eee-dbc4-ed4c-a7cb-3a6ea0cc9cd0"],
 ".\[LineSeparator]Hence ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SuperscriptBox["\[Gamma]", 
      RowBox[{"(", "1", ")"}]], "(", "\[Tau]", ")"}], "=", 
    RowBox[{
     RowBox[{
      SuperscriptBox["\[Gamma]", 
       RowBox[{
        RowBox[{"(", "1", ")"}], "*"}]], "(", 
      RowBox[{"-", "\[Tau]"}], ")"}], "=", 
     SuperscriptBox["\[ExponentialE]", 
      RowBox[{
       RowBox[{"-", "\[ImaginaryI]"}], " ", "\[Omega]", " ", "t"}]]}]}], 
   TraditionalForm]],ExpressionUUID->"b67d4238-4135-584f-b6d7-3f3c3e09ff0f"],
 ", which means",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"|", 
     RowBox[{
      SuperscriptBox["\[Gamma]", 
       RowBox[{"(", "1", ")"}]], "(", "\[Tau]", ")"}], "|"}], "=", "1"}], 
   TraditionalForm]],ExpressionUUID->"64c438ed-a671-d349-b021-cb11637f4c9d"],
 " denoting temporal coherence"
}], "Text",
 CellID->859727202,ExpressionUUID->"0ab734bd-bc1b-b247-bd38-147da151b956"],

Cell[TextData[{
 "A more complete model of \[OpenCurlyDoubleQuote]monochromatic\
\[CloseCurlyDoubleQuote] radiation includes random phase contributions of \
light produced by excited atoms when decay. If we call ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Tau]", "0"], TraditionalForm]],ExpressionUUID->
  "988034a0-312d-7f4d-b8bf-7e14e5f99ba1"],
 " the coherence time of the source, that is inversely proportional to the \
width of atomic the spectral lines. We can introduce a function",
 Cell[BoxData[
  FormBox[
   RowBox[{" ", 
    RowBox[{"\[Psi]", "(", "t", ")"}]}], TraditionalForm]],ExpressionUUID->
  "55afb9bb-ce7f-7149-8523-8ef282309248"],
 " that represents a random step function that has a value from ",
 Cell[BoxData[
  FormBox["0", TraditionalForm]],ExpressionUUID->
  "399c8607-edd4-5d4f-9746-fe0d83f46e7b"],
 " to ",
 Cell[BoxData[
  FormBox[
   RowBox[{"2", "\[Pi]"}], TraditionalForm]],ExpressionUUID->
  "0ee9f380-e413-c04f-a341-ac8a7bcbff58"],
 " with some period ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Tau]", "0"], TraditionalForm]],ExpressionUUID->
  "b0c5f890-e32d-e541-8915-dafb5bf962f4"]
}], "Text",
 CellID->179299818,ExpressionUUID->"97e44995-505b-3944-b270-20ace27c7cc6"],

Cell[TextData[{
 "Define ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Psi]", "(", "t", ")"}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "91f335a7-b358-5f4f-9336-fc8cd2fcb655"],
 ":"
}], "Text",
 CellID->121206189,ExpressionUUID->"146f0817-ef5b-ce43-90ef-0f7836054179"],

Cell[BoxData[
 RowBox[{
  RowBox[{"psi", "[", 
   RowBox[{
    RowBox[{"t_", "?", "NumericQ"}], ",", 
    RowBox[{"t0_", "?", "NumericQ"}], ",", 
    RowBox[{"s_", ":", "42"}]}], "]"}], ":=", 
  RowBox[{"BlockRandom", "[", 
   RowBox[{
    RowBox[{"SeedRandom", "[", 
     RowBox[{
      RowBox[{"Floor", "[", 
       RowBox[{"t", "/", "t0"}], "]"}], "+", "s"}], "]"}], ";", 
    RowBox[{"RandomReal", "[", 
     RowBox[{"{", 
      RowBox[{"0", ",", 
       RowBox[{"2", " ", "Pi"}]}], "}"}], "]"}]}], "]"}]}]], "Input",
 CellLabel->"In[10]:=",
 CellID->142550234,ExpressionUUID->"a8568d46-20b2-1546-b74d-a579d5e0627d"],

Cell[TextData[{
 "Visualize the random phase ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Psi]", "(", "t", ")"}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "f381bef2-e34e-4340-a5eb-4723bb60d8e7"],
 " for ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["\[Tau]", "0"], "=", "1"}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "40fec097-4270-6a44-b8e2-63199922d5ce"]
}], "Text",
 CellID->289744843,ExpressionUUID->"b47cd4f7-692a-c44d-a60b-dcf7fbbcee13"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Plot", "[", 
  RowBox[{
   RowBox[{"psi", "[", 
    RowBox[{"t", ",", "1"}], "]"}], ",", 
   RowBox[{"{", 
    RowBox[{"t", ",", "0", ",", "5"}], "}"}], ",", 
   RowBox[{"Frame", "\[Rule]", "True"}], ",", 
   RowBox[{"FrameLabel", "\[Rule]", 
    RowBox[{"{", 
     RowBox[{"\"\<t\>\"", ",", "\"\<\[Psi](t)\>\""}], "}"}]}], ",", 
   RowBox[{"LabelStyle", "\[Rule]", "14"}], ",", 
   RowBox[{"PlotRange", "\[Rule]", 
    RowBox[{"{", 
     RowBox[{"0", ",", 
      RowBox[{"2", " ", "\[Pi]"}]}], "}"}]}], ",", 
   RowBox[{"FrameTicks", "\[Rule]", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{"0", ",", "0"}], "}"}], ",", 
          RowBox[{"{", 
           RowBox[{"\[Pi]", ",", "\"\<\[Pi]\>\""}], "}"}], ",", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"2", " ", "\[Pi]"}], ",", "\"\<2\[Pi]\>\""}], "}"}]}], 
         "}"}], ",", "None"}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"Table", "[", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{"i", ",", 
            RowBox[{"If", "[", 
             RowBox[{
              RowBox[{"i", "\[Equal]", "0"}], ",", "0", ",", 
              RowBox[{"Row", "[", 
               RowBox[{"{", 
                RowBox[{
                "i", ",", "\"\<\\!\\(\\*SubscriptBox[\\(\[Tau]\\), \
\\(0\\)]\\)\>\""}], "}"}], "]"}]}], "]"}]}], "}"}], ",", 
          RowBox[{"{", 
           RowBox[{"i", ",", "0", ",", "5"}], "}"}]}], "]"}], ",", "None"}], 
       "}"}]}], "}"}]}], ",", 
   RowBox[{"ImageSize", "->", "400"}]}], "]"}]], "Input",
 CellLabel->"In[21]:=",
 CellID->157796287,ExpressionUUID->"5377c1d1-3991-e740-99e0-cf05c601f930"],

