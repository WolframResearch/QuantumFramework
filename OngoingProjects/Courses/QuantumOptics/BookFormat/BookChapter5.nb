Cell[TextData[{
 "The electric field on the detector(screen) at time ",
 Cell[BoxData[
  FormBox["t", TraditionalForm]],ExpressionUUID->
  "fbd93cc3-d49c-8a49-a38d-dd25fa7a68c3"],
 " can be written as the superposition of the fields incoming from the slits \
at times ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["t", "1"], "=", 
    RowBox[{"t", "-", 
     RowBox[{
      SubscriptBox["s", "1"], "/", "c"}]}]}], TraditionalForm]],
  ExpressionUUID->"a70ac478-8544-f54b-9547-94d9b659b3e3"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["t", "2"], "=", 
    RowBox[{"t", "-", 
     RowBox[{
      SubscriptBox["s", "2"], "/", "c"}]}]}], TraditionalForm]],
  ExpressionUUID->"fbdc7efb-4ad2-cf41-b697-219544d01b5e"],
 ". The constants ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["K", "1"], TraditionalForm]],ExpressionUUID->
  "693abb07-8d1b-8f4a-a8f2-b1555d95a8c4"],
 ",",
 Cell[BoxData[
  FormBox[
   SubscriptBox["K", "2"], TraditionalForm]],ExpressionUUID->
  "0dd1999e-aaa3-9f49-bf19-1e0e971228b8"],
 " are geometric factors."
}], "Text",
 CellID->258370310,ExpressionUUID->"fdc1913f-2585-9c4f-a7a6-0980e4b94ba4"],

Cell[BoxData[
 FormBox[
  RowBox[{
   RowBox[{"E", "(", 
    RowBox[{
     StyleBox["r", "Bold",
      FontWeight->"Bold"], ",", "t"}], ")"}], "=", 
   RowBox[{
    RowBox[{
     SubscriptBox["K", "1"], " ", 
     RowBox[{"E", "(", 
      RowBox[{
       SubscriptBox[
        StyleBox["r", "Bold",
         FontWeight->"Bold"], "1"], ",", 
       SubscriptBox["t", "1"]}], ")"}]}], "+", 
    RowBox[{
     SubscriptBox["K", "2"], " ", 
     RowBox[{"E", "(", 
      RowBox[{
       SubscriptBox[
        StyleBox["r", "Bold",
         FontWeight->"Bold"], "2"], ",", 
       SubscriptBox["t", "2"]}], ")"}]}]}]}], 
  TraditionalForm]], "DisplayFormula",
 GeneratedCell->True,
 CellAutoOverwrite->True,
 CellChangeTimes->{3.985944117383335*^9, 3.985944176547209*^9},
 FontSize->18,
 CellID->206302987,ExpressionUUID->"56980e82-510e-994d-beaa-ff5d3aa647e5"],

Cell["\<\
Optical light detectors have a long response time so what is measured \
effectively is the average intensity \
\>", "Text",
 CellID->12137789,ExpressionUUID->"234185b7-5a05-1346-8285-a702945ae304"],

Cell[BoxData[
 FormBox[
  RowBox[{
   RowBox[{"I", "(", 
    StyleBox["r", "Bold",
     FontWeight->"Bold"], ")"}], "=", 
   RowBox[{"\[LeftAngleBracket]", 
    RowBox[{"|", 
     RowBox[{"E", "(", 
      RowBox[{
       StyleBox["r", "Bold",
        FontWeight->"Bold"], ",", "t"}], ")"}], 
     SuperscriptBox["|", "2"]}], "\[RightAngleBracket]"}]}], 
  TraditionalForm]], "DisplayFormula",
 GeneratedCell->True,
 CellAutoOverwrite->True,
 CellChangeTimes->{3.985944117383335*^9, 3.985944176547209*^9},
 FontSize->18,
 CellID->56546874,ExpressionUUID->"c1e4a4a4-c358-6844-a4c6-466a5d1aa8fb"],

Cell[TextData[{
 "The time average of a function ",
 Cell[BoxData[
  FormBox[
   RowBox[{"f", "(", "t", ")"}], TraditionalForm]],ExpressionUUID->
  "04d36c91-f867-e14a-b190-f3248f4ecf06"],
 " is defined as:"
}], "Text",
 CellID->94664338,ExpressionUUID->"d8faa0e5-ba78-8540-ab8a-7381f28ad48b"],

Cell[BoxData[
 FormBox[
  RowBox[{
   RowBox[{"\[LeftAngleBracket]", 
    RowBox[{"f", "(", "t", ")"}], "\[RightAngleBracket]"}], "=", 
   RowBox[{
    UnderscriptBox["lim", 
     RowBox[{"T", "\[RightArrow]", "\[Infinity]"}]], 
    FractionBox["1", "T"], 
    SubsuperscriptBox["\[Integral]", "0", 
     RowBox[{" ", "T"}]], 
    RowBox[{"f", "(", "t", ")"}], 
    RowBox[{"\[DifferentialD]", "t"}]}]}], TraditionalForm]], "DisplayFormula",
 FontSize->18,
 CellID->66674447,ExpressionUUID->"e0785b83-7755-8748-b12f-27409d5ff295"],

Cell["Defining a time expectation function:", "Text",
 CellID->285435601,ExpressionUUID->"2ef843d4-1f48-4a46-a5dc-c5be4858d268"],

Cell[BoxData[
 RowBox[{
  RowBox[{"TimeExpectation", "[", "f_", "]"}], ":=", 
  RowBox[{"Limit", "[", 
   RowBox[{
    FractionBox[
     RowBox[{"Integrate", "[", 
      RowBox[{"f", ",", 
       RowBox[{"{", 
        RowBox[{"t", ",", "0", ",", "T"}], "}"}]}], "]"}], "T"], ",", 
    RowBox[{"T", "->", "\[Infinity]"}]}], "]"}]}]], "Input",
 CellLabel->"In[1]:=",
 CellID->183318064,ExpressionUUID->"9874784a-9c8e-7146-a9a9-30bd056eb50b"],

Cell[TextData[{
 "For example, for the function ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox[
    RowBox[{"Sin", "(", "t", ")"}], "2"], TraditionalForm]],ExpressionUUID->
  "c4bded48-0b2c-2f46-82d5-6638501254f2"],
 " we get the expected result of 1/2:"
}], "Text",
 CellID->228761041,ExpressionUUID->"e9edd176-c3fd-9b4d-b199-c836250413c8"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"TimeExpectation", "[", 
  SuperscriptBox[
   RowBox[{"Sin", "[", "t", "]"}], "2"], "]"}]], "Input",
 CellLabel->"In[4]:=",
 CellID->141145344,ExpressionUUID->"dc72febb-d804-3148-8600-f3b6b29c6ef3"],

Cell[BoxData[
 FractionBox["1", "2"]], "Output",
 CellLabel->"Out[4]=",
 CellID->63223356,ExpressionUUID->"38d0e231-347a-8b46-b15d-b76a8761f957"]
}, Open  ]],

Cell["Or a general cosine function:", "Text",
 CellID->209464171,ExpressionUUID->"7e731f99-d48a-5246-b84a-125eb9acbe30"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Simplify", "[", 
  RowBox[{
   RowBox[{"TimeExpectation", "[", 
    SuperscriptBox[
     RowBox[{"Cos", "[", 
      RowBox[{"t", " ", "m", " ", "x"}], " ", "]"}], "2"], "]"}], ",", 
   RowBox[{"Element", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"m", ",", "x", ",", "a"}], "}"}], ",", "Reals"}], "]"}]}], 
  "]"}]], "Input",
 CellLabel->"In[5]:=",
 CellID->49746599,ExpressionUUID->"75f6c5a7-436c-fd45-8899-3946bad44742"],

Cell[BoxData[
 FractionBox["1", "2"]], "Output",
 CellLabel->"Out[5]=",
 CellID->4214845,ExpressionUUID->"f6406ab0-891b-4748-a7d4-395952aaf2ca"]
}, Open  ]],

Cell["The intensity can be expressed as:", "Text",
 CellID->230910707,ExpressionUUID->"a5c367d1-0695-6945-870a-b025a1bf70f0"],

Cell[BoxData[
 FormBox[
  RowBox[{
   RowBox[{"I", "(", 
    StyleBox["r", "Bold",
     FontWeight->"Bold"], ")"}], "=", 
   RowBox[{
    RowBox[{
     SuperscriptBox[
      RowBox[{"|", 
       SubscriptBox["K", "1"], "|"}], "2"], 
     RowBox[{"\[LeftAngleBracket]", 
      RowBox[{"|", 
       RowBox[{"E", "(", 
        RowBox[{
         SubscriptBox[
          StyleBox["r", "Bold",
           FontWeight->"Bold"], "1"], ",", 
         SubscriptBox["t", "1"]}], ")"}], 
       SuperscriptBox["|", "2"]}], "\[RightAngleBracket]"}]}], "+", 
    RowBox[{
     SuperscriptBox[
      RowBox[{"|", 
       SubscriptBox["K", "2"], "|"}], "2"], 
     RowBox[{"\[LeftAngleBracket]", 
      RowBox[{"|", 
       RowBox[{"E", "(", 
        RowBox[{
         SubscriptBox[
          StyleBox["r", "Bold",
           FontWeight->"Bold"], "2"], ",", 
         SubscriptBox["t", "2"]}], ")"}], 
       SuperscriptBox["|", "2"]}], "\[RightAngleBracket]"}]}], "+", 
    "\[LineSeparator]", "                ", 
    RowBox[{"2", " ", 
     RowBox[{"Re", 
      StyleBox["[",
       FontSize->18], 
      RowBox[{
       SuperscriptBox[
        SubscriptBox["K", "1"], "*"], 
       SubscriptBox["K", "2"], 
       RowBox[{"\[LeftAngleBracket]", 
        RowBox[{
         RowBox[{
          SuperscriptBox["E", "*"], "(", 
          RowBox[{
           SubscriptBox[
            StyleBox["r", "Bold",
             FontWeight->"Bold"], "1"], ",", 
           SubscriptBox["t", "1"]}], ")"}], 
         RowBox[{"E", "(", 
          RowBox[{
           SubscriptBox[
            StyleBox["r", "Bold",
             FontWeight->"Bold"], "2"], ",", 
           SubscriptBox["t", "2"]}], ")"}]}], "\[RightAngleBracket]"}]}], 
      StyleBox["]",
       FontSize->18]}]}]}]}], TraditionalForm]], "DisplayFormula",
 CellID->635458857,ExpressionUUID->"54cf3188-e483-4f44-8b1e-c248594505a1"],

Cell[TextData[{
 "the first two terms are related to intensities from each slit ",
 Cell[BoxData[
  FormBox[
   RowBox[{"(", 
    SubscriptBox["I", "1"]}], TraditionalForm]],ExpressionUUID->
  "c2a79b34-b8d4-1c40-b96e-1dfe1ec37570"],
 ", ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["I", "2"], TraditionalForm]],ExpressionUUID->
  "51e30d32-ce87-a749-956c-8e953bd415af"],
 "), and the last term is the interference term"
}], "Text",
 CellID->49057967,ExpressionUUID->"fb322757-8c41-dc4b-a91e-cd795317e409"],

Cell[TextData[{
 "Let ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox["x", "i"], "=", 
     SubscriptBox[
      StyleBox["r",
       FontWeight->"Bold"], "i"]}], ",", 
    SubscriptBox["t", "i"]}], TraditionalForm]],ExpressionUUID->
  "af73ddff-fabf-7f4e-980f-129864df5655"],
 ", the first order normalized coherence function can be defined as:"
}], "Text",
 CellID->197735460,ExpressionUUID->"7ff8e18f-ef68-5644-a0e6-cd0f7b5594bc"],

Cell[BoxData[
 FormBox[
  RowBox[{
   RowBox[{
    SuperscriptBox["\[Gamma]", 
     RowBox[{"(", "1", ")"}]], "(", 
    RowBox[{
     SubscriptBox["x", "1"], ",", 
     SubscriptBox["x", "2"]}], ")"}], "=", 
   FractionBox[
    RowBox[{"\[LeftAngleBracket]", 
     RowBox[{
      SuperscriptBox["E", "*"], "(", 
      SubscriptBox["x", "1"], ")"}], 
     RowBox[{"E", "(", 
      SubscriptBox["x", "2"], ")"}], "\[RightAngleBracket]"}], 
    SqrtBox[
     RowBox[{
      RowBox[{"\[LeftAngleBracket]", 
       SuperscriptBox[
        RowBox[{"|", 
         RowBox[{"E", "(", 
          SubscriptBox["x", "1"], ")"}], "|"}], "2"], 
       "\[RightAngleBracket]"}], 
      RowBox[{"\[LeftAngleBracket]", 
       SuperscriptBox[
        RowBox[{"|", 
         RowBox[{"E", "(", 
          SubscriptBox["x", "2"], ")"}], "|"}], "2"], 
       "\[RightAngleBracket]"}]}]]]}], TraditionalForm]], "DisplayFormula",
 GeneratedCell->True,
 CellAutoOverwrite->True,
 CellChangeTimes->{3.9859441173992004`*^9, 3.985944176547209*^9},
 CellID->113581952,ExpressionUUID->"605bae0c-e238-0b45-a0dd-14fe5d16df93"],

Cell[TextData[{
 "The intensity at the screen can be rewritten in terms of the coherence \
function, using the polar forms of the complex numbers ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["K", "1"], ",", 
    SubscriptBox["K", "2"]}], TraditionalForm]],ExpressionUUID->
  "6f34a1a8-7b76-5a48-9641-35dc297c7d66"],
 " ,and defining ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Theta]", "=", 
    RowBox[{
     SubscriptBox["\[Psi]", "1"], "-", 
     SubscriptBox["\[Psi]", "2"]}]}], TraditionalForm]],ExpressionUUID->
  "0831b624-3432-834a-9859-daaabc170bbb"],
 " the phase difference related to path length difference"
}], "Text",
 CellID->117742202,ExpressionUUID->"02e2ed92-61fd-8545-94ad-2f63b0a9db53"],

Cell[BoxData[
 FormBox[
  RowBox[{
   RowBox[{"I", "(", 
    StyleBox["r", "Bold"], ")"}], "=", 
   RowBox[{
    SubscriptBox["I", "1"], "+", 
    SubscriptBox["I", "2"], "+", 
    RowBox[{"2", 
     SqrtBox[
      RowBox[{
       SubscriptBox["I", "1"], 
       SubscriptBox["I", "2"]}]], "Re", "[", 
     RowBox[{
      SubscriptBox["K", "1"], 
      SubscriptBox["K", "2"], 
      SuperscriptBox["\[Gamma]", 
       RowBox[{"(", "1", ")"}]], "(", 
      RowBox[{
       SubscriptBox["x", "1"], ",", 
       SubscriptBox["x", "2"]}], ")"}], "]"}]}]}], 
  TraditionalForm]], "DisplayFormula",
 GeneratedCell->True,
 CellAutoOverwrite->True,
 CellChangeTimes->{3.9859441173992004`*^9, 3.985944176547209*^9},
 CellID->194803316,ExpressionUUID->"68b26dea-2c6f-cf4e-b2f7-178b0faf628b"],

Cell[BoxData[
 FormBox[
  RowBox[{
   RowBox[{"I", "(", 
    StyleBox["r", "Bold"], ")"}], "=", 
   RowBox[{
    SubscriptBox["I", "1"], "+", 
    SubscriptBox["I", "2"], "+", 
    RowBox[{"2", 
     SqrtBox[
      RowBox[{
       SubscriptBox["I", "1"], 
       SubscriptBox["I", "2"]}]], 
     RowBox[{"|", 
      RowBox[{
       SuperscriptBox["\[Gamma]", 
        RowBox[{"(", "1", ")"}]], "(", 
       RowBox[{
        SubscriptBox["x", "1"], ",", 
        SubscriptBox["x", "2"]}], ")"}], "|"}], "cos", "(", 
     RowBox[{
      SubscriptBox["\[CapitalPhi]", "12"], "-", "\[Theta]"}], ")"}]}]}], 
  TraditionalForm]], "DisplayFormula",
 GeneratedCell->True,
 CellAutoOverwrite->True,
 CellChangeTimes->{3.9859441173992004`*^9, 3.985944176547209*^9},
 CellID->287620654,ExpressionUUID->"afb27071-7438-084e-9e96-c1d1328afc69"],

Cell[TextData[{
 "When ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"|", 
     RowBox[{
      SuperscriptBox["\[Gamma]", 
       RowBox[{"(", "1", ")"}]], "(", 
      RowBox[{
       SubscriptBox["x", "1"], ",", 
       SubscriptBox["x", "2"]}], ")"}], "|"}], "=", "1"}], TraditionalForm]],
  ExpressionUUID->"c98c5534-4563-b24c-b564-c41d72700b6e"],
 " there is complete coherence, ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"|", 
     RowBox[{
      SuperscriptBox["\[Gamma]", 
       RowBox[{"(", "1", ")"}]], "(", 
      RowBox[{
       SubscriptBox["x", "1"], ",", 
       SubscriptBox["x", "2"]}], ")"}], "|"}], "=", "0"}], TraditionalForm]],
  ExpressionUUID->"9dc78482-6e21-f74e-9dd3-f2f54bfb5061"],
 " means there is no coherence at all, intermediate values are related to \
partial coherence"
}], "Text",
 CellID->7800811,ExpressionUUID->"cc105b9f-0a8d-444e-894a-ae3cde4713d9"],

Cell["Fringe visibility is defined as:", "Text",
 CellID->135664952,ExpressionUUID->"4f814863-c83d-b645-b148-95cc01cfd4da"],

Cell[BoxData[
 FormBox[
  RowBox[{"\[ScriptCapitalV]", "=", 
   FractionBox[
    RowBox[{
     SubscriptBox["I", "max"], "-", 
     SubscriptBox["I", "min"]}], 
    RowBox[{
     SubscriptBox["I", "max"], "+", 
     SubscriptBox["I", "min"]}]]}], TraditionalForm]], "DisplayFormula",
 GeneratedCell->True,
 CellAutoOverwrite->True,
 CellChangeTimes->{3.9859441173992004`*^9, 3.9859441765629425`*^9},
 CellID->897405277,ExpressionUUID->"24362ce3-41ea-8e49-adba-b2cd4f088a8b"],

Cell["\<\
So we can express the visibility  in terms of the first order coherence \
function:\
\>", "Text",
 CellID->609280147,ExpressionUUID->"946e7c02-5e86-9d45-9273-1252134e46fe"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"With", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"Imax", " ", "=", " ", 
        RowBox[{
         SubscriptBox["\[FormalCapitalI]", "1"], "+", 
         SubscriptBox["\[FormalCapitalI]", "2"], "+", 
         RowBox[{
          SqrtBox[
           RowBox[{"2", " ", 
            SubscriptBox["\[FormalCapitalI]", "1"], " ", 
            SubscriptBox["\[FormalCapitalI]", "2"]}]], " ", 
          RowBox[{"Abs", "[", "\[Gamma]1", "]"}]}]}]}], ",", 
       RowBox[{"Imin", "=", " ", 
        RowBox[{
         SubscriptBox["\[FormalCapitalI]", "1"], "+", 
         SubscriptBox["\[FormalCapitalI]", "2"], "-", 
         RowBox[{
          SqrtBox[
           RowBox[{"2", " ", 
            SubscriptBox["\[FormalCapitalI]", "1"], " ", 
            SubscriptBox["\[FormalCapitalI]", "2"]}]], " ", 
          RowBox[{"Abs", "[", "\[Gamma]1", "]"}]}]}]}]}], "}"}], ",", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{"Imax", "-", "Imin"}], ")"}], "/", 
      RowBox[{"(", 
       RowBox[{"Imax", "+", "Imin"}], ")"}]}]}], "]"}], "//", "Simplify"}], "//",
   "TraditionalForm"}]], "Input",
 CellLabel->"In[6]:=",
 CellID->262365325,ExpressionUUID->"7dbc65d3-792b-5242-842e-3aa6209f1f3e"],

Cell[BoxData[
 FormBox[
  FractionBox[
   RowBox[{
    SqrtBox["2"], " ", 
    SqrtBox[
     RowBox[{
      SubscriptBox["\[FormalCapitalI]", "1"], " ", 
      SubscriptBox["\[FormalCapitalI]", "2"]}]], " ", 
    TemplateBox[{"\[Gamma]1"},
     "Abs"]}], 
   RowBox[{
    SubscriptBox["\[FormalCapitalI]", "1"], "+", 
    SubscriptBox["\[FormalCapitalI]", "2"]}]], TraditionalForm]], "Output",
 CellLabel->"Out[6]//TraditionalForm=",
 CellID->13947289,ExpressionUUID->"9249525c-1398-2e48-992f-a3bfa4d8e854"]
}, Open  ]],

Cell[TextData[{
 "when ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"|", 
     SuperscriptBox["\[Gamma]", 
      RowBox[{"(", "1", ")"}]], "|"}], "=", 
    StyleBox["1", "CodeText"]}], TraditionalForm]], "DisplayFormula",
  GeneratedCell->True,
  CellAutoOverwrite->True,
  CellChangeTimes->{3.9859441173992004`*^9, 3.9859441765629425`*^9},
  ExpressionUUID->"9e5c53c3-a34b-7440-851f-3249b4c0f37d"],
 ", the maximum value of the visibility is ",
 Cell[BoxData[
  FormBox[
   FractionBox[
    SqrtBox[
     RowBox[{
      StyleBox["2", "CodeText",
       FontSize->14], " ", 
      SubscriptBox["I", "1"], 
      SubscriptBox["I", "2"]}]], 
    RowBox[{
     SubscriptBox["I", "1"], "+", 
     SubscriptBox["I", "2"]}]], TraditionalForm]], "DisplayFormula",
  GeneratedCell->True,
  CellAutoOverwrite->True,
  CellChangeTimes->{3.9859441173992004`*^9, 3.9859441765629425`*^9},
  ExpressionUUID->"aeb91117-6e5e-e54e-846a-e5657dbca644"],
 " , and clearly the minimum is zero where there is complete incoherence"
}], "Text",
 CellID->2848250,ExpressionUUID->"5325011b-3fec-504a-bccc-e597ac66d2cc"],

Cell["Consider monochromatic light propagating in the z direction:", "Text",
 CellID->198737047,ExpressionUUID->"8ce7c035-5bac-7b41-91e7-edf013c93fcd"],

Cell[BoxData[
 RowBox[{
  RowBox[{"Efield", "[", 
   RowBox[{"z_", ",", "t_"}], "]"}], ":=", 
  RowBox[{"E0", " ", 
   SuperscriptBox["\[ExponentialE]", 
    RowBox[{"\[ImaginaryI]", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{"k", " ", "z"}], " ", "-", " ", 
       RowBox[{"\[Omega]", " ", "t"}]}], ")"}]}]]}]}]], "Input",
 CellLabel->"In[7]:=",
 CellID->772471254,ExpressionUUID->"6c6978bc-1f29-2445-8ce2-559fb465de6b"],

Cell[TextData[{
 "Electric field at times ",
 Cell[BoxData[
  FormBox["t", TraditionalForm]],ExpressionUUID->
  "df904dcf-3ac1-e044-8e97-0dc1d1b69e4b"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{"t", "+", "\[Tau]"}], TraditionalForm]],ExpressionUUID->
  "bce51dcc-86a8-834c-96d1-7cd88c4f3aab"],
 ":"
}], "Text",
 CellID->176519275,ExpressionUUID->"bf2bb570-7ae0-f145-9e49-4874c43c333c"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{"Efield", "[", 
    RowBox[{"z", ",", "t"}], "]"}], ",", 
   RowBox[{"Efield", "[", 
    RowBox[{"z", ",", 
     RowBox[{"t", "+", "\[Tau]"}]}], "]"}]}], "}"}]], "Input",
 CellLabel->"In[8]:=",
 CellID->203535267,ExpressionUUID->"7ddf4661-53bd-7b4c-a4e3-391d5e280df6"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{
    SuperscriptBox["\[ExponentialE]", 
     RowBox[{"\[ImaginaryI]", " ", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{"k", " ", "z"}], "-", 
        RowBox[{"t", " ", "\[Omega]"}]}], ")"}]}]], " ", "E0"}], ",", 
   RowBox[{
    SuperscriptBox["\[ExponentialE]", 
     RowBox[{"\[ImaginaryI]", " ", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{"k", " ", "z"}], "-", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{"t", "+", "\[Tau]"}], ")"}], " ", "\[Omega]"}]}], ")"}]}]], 
    " ", "E0"}]}], "}"}]], "Output",
 CellLabel->"Out[8]=",
 CellID->2573038,ExpressionUUID->"c7a9f3a8-6d5f-f147-bc55-f55a6d9731ba"]
}, Open  ]],

Cell[TextData[{
 "Calculate \[LeftAngleBracket]",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"E", "\[Conjugate]"}], 
    RowBox[{"(", 
     RowBox[{"z", ",", "t"}], ")"}], 
    RowBox[{"E", "(", 
     RowBox[{"z", ",", 
      RowBox[{"t", "+", "\[Tau]"}]}], ")"}]}], TraditionalForm]],
  ExpressionUUID->"ae98d932-0b9c-c340-be50-05db21865c09"],
 "\[RightAngleBracket], at position ",
 Cell[BoxData[
  FormBox["z", TraditionalForm]],ExpressionUUID->
  "d6ad7ff6-d46c-d94f-91fc-35d43c9637be"],
 " and times ",
 Cell[BoxData[
  FormBox["t", TraditionalForm]],ExpressionUUID->
  "5bf8d670-0456-ce49-a95f-586af3e19429"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{"t", "+", "\[Tau]"}], TraditionalForm]],ExpressionUUID->
  "066d8bc8-6042-d94f-8545-a63dcfe08711"],
 ": "
}], "Text",
 CellID->10367696,ExpressionUUID->"744dd2d8-4fa4-924d-8b6d-838782f61bf7"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"TimeExpectation", "[", 
  RowBox[{
   RowBox[{"ComplexExpand", "@", 
    RowBox[{"Conjugate", "@", 
     RowBox[{"Efield", "[", 
      RowBox[{"z", ",", "t"}], "]"}]}]}], 
   RowBox[{"Efield", "[", 
    RowBox[{"z", ",", 
     RowBox[{"t", "+", "\[Tau]"}]}], "]"}]}], "]"}]], "Input",
 CellLabel->"In[9]:=",
 CellID->250283569,ExpressionUUID->"678dc6e6-317c-8845-8a71-bbb21e3cfe1a"],

Cell[BoxData[
 RowBox[{
  SuperscriptBox["\[ExponentialE]", 
   RowBox[{
    RowBox[{"-", "\[ImaginaryI]"}], " ", "\[Tau]", " ", "\[Omega]"}]], " ", 
  SuperscriptBox["E0", "2"]}]], "Output",
 CellLabel->"Out[9]=",
 CellID->258596120,ExpressionUUID->"b9dfe0e8-d3c0-f04a-9cad-b27b3404da2f"]
}, Open  ]],

Cell[TextData[{
 "The auto-correlation function without considering position is ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[LeftAngleBracket]", 
    RowBox[{
     RowBox[{
      SuperscriptBox["E", "*"], "(", "t", ")"}], 
     RowBox[{"E", "(", 
      RowBox[{"t", "+", "\[Tau]"}], ")"}]}], "\[RightAngleBracket]"}], 
   TraditionalForm]],ExpressionUUID->"48b37eee-dbc4-ed4c-a7cb-3a6ea0cc9cd0"],
 ".\[LineSeparator]Hence ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SuperscriptBox["\[Gamma]", 
      RowBox[{"(", "1", ")"}]], "(", "\[Tau]", ")"}], "=", 
    RowBox[{
     RowBox[{
      SuperscriptBox["\[Gamma]", 
       RowBox[{
        RowBox[{"(", "1", ")"}], "*"}]], "(", 
      RowBox[{"-", "\[Tau]"}], ")"}], "=", 
     SuperscriptBox["\[ExponentialE]", 
      RowBox[{
       RowBox[{"-", "\[ImaginaryI]"}], " ", "\[Omega]", " ", "t"}]]}]}], 
   TraditionalForm]],ExpressionUUID->"b67d4238-4135-584f-b6d7-3f3c3e09ff0f"],
 ", which means",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"|", 
     RowBox[{
      SuperscriptBox["\[Gamma]", 
       RowBox[{"(", "1", ")"}]], "(", "\[Tau]", ")"}], "|"}], "=", "1"}], 
   TraditionalForm]],ExpressionUUID->"64c438ed-a671-d349-b021-cb11637f4c9d"],
 " denoting temporal coherence"
}], "Text",
 CellID->859727202,ExpressionUUID->"0ab734bd-bc1b-b247-bd38-147da151b956"],

Cell[TextData[{
 "A more complete model of \[OpenCurlyDoubleQuote]monochromatic\
\[CloseCurlyDoubleQuote] radiation includes random phase contributions of \
light produced by excited atoms when decay. If we call ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Tau]", "0"], TraditionalForm]],ExpressionUUID->
  "988034a0-312d-7f4d-b8bf-7e14e5f99ba1"],
 " the coherence time of the source, that is inversely proportional to the \
width of atomic the spectral lines. We can introduce a function",
 Cell[BoxData[
  FormBox[
   RowBox[{" ", 
    RowBox[{"\[Psi]", "(", "t", ")"}]}], TraditionalForm]],ExpressionUUID->
  "55afb9bb-ce7f-7149-8523-8ef282309248"],
 " that represents a random step function that has a value from ",
 Cell[BoxData[
  FormBox["0", TraditionalForm]],ExpressionUUID->
  "399c8607-edd4-5d4f-9746-fe0d83f46e7b"],
 " to ",
 Cell[BoxData[
  FormBox[
   RowBox[{"2", "\[Pi]"}], TraditionalForm]],ExpressionUUID->
  "0ee9f380-e413-c04f-a341-ac8a7bcbff58"],
 " with some period ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Tau]", "0"], TraditionalForm]],ExpressionUUID->
  "b0c5f890-e32d-e541-8915-dafb5bf962f4"]
}], "Text",
 CellID->179299818,ExpressionUUID->"97e44995-505b-3944-b270-20ace27c7cc6"],

Cell[TextData[{
 "Define ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Psi]", "(", "t", ")"}], TraditionalForm]],ExpressionUUID->
  "91f335a7-b358-5f4f-9336-fc8cd2fcb655"],
 ":"
}], "Text",
 CellID->121206189,ExpressionUUID->"146f0817-ef5b-ce43-90ef-0f7836054179"],

Cell[BoxData[
 RowBox[{
  RowBox[{"psi", "[", 
   RowBox[{
    RowBox[{"t_", "?", "NumericQ"}], ",", 
    RowBox[{"t0_", "?", "NumericQ"}], ",", 
    RowBox[{"s_", ":", "42"}]}], "]"}], ":=", 
  RowBox[{"BlockRandom", "[", 
   RowBox[{
    RowBox[{"SeedRandom", "[", 
     RowBox[{
      RowBox[{"Floor", "[", 
       RowBox[{"t", "/", "t0"}], "]"}], "+", "s"}], "]"}], ";", 
    RowBox[{"RandomReal", "[", 
     RowBox[{"{", 
      RowBox[{"0", ",", 
       RowBox[{"2", " ", "Pi"}]}], "}"}], "]"}]}], "]"}]}]], "Input",
 CellLabel->"In[10]:=",
 CellID->142550234,ExpressionUUID->"a8568d46-20b2-1546-b74d-a579d5e0627d"],

Cell[TextData[{
 "Visualize the random phase ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Psi]", "(", "t", ")"}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "f381bef2-e34e-4340-a5eb-4723bb60d8e7"],
 " for ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["\[Tau]", "0"], "=", "1"}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "40fec097-4270-6a44-b8e2-63199922d5ce"]
}], "Text",
 CellID->289744843,ExpressionUUID->"b47cd4f7-692a-c44d-a60b-dcf7fbbcee13"],

