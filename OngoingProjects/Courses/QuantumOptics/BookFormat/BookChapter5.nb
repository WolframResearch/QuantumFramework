      RowBox[{
       SubscriptBox["x", "1"], ",", 
       SubscriptBox["x", "2"]}], ")"}], "|"}], "=", "1"}], TraditionalForm]],
  ExpressionUUID->"c98c5534-4563-b24c-b564-c41d72700b6e"],
 " there is complete coherence, ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"|", 
     RowBox[{
      SuperscriptBox["\[Gamma]", 
       RowBox[{"(", "1", ")"}]], "(", 
      RowBox[{
       SubscriptBox["x", "1"], ",", 
       SubscriptBox["x", "2"]}], ")"}], "|"}], "=", "0"}], TraditionalForm]],
  ExpressionUUID->"9dc78482-6e21-f74e-9dd3-f2f54bfb5061"],
 " means there is no coherence at all, intermediate values are related to \
partial coherence"
}], "Text",
 CellID->7800811,ExpressionUUID->"cc105b9f-0a8d-444e-894a-ae3cde4713d9"],

