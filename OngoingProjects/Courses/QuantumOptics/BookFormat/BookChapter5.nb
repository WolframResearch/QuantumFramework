Cell[TextData[{
 "Following a really similar approach when defining ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["G", 
    RowBox[{"(", "1", ")"}]], TraditionalForm]],ExpressionUUID->
  "60527007-b39b-9c45-9f0d-4c6fb12a87f7"],
 ", we define ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["G", 
    RowBox[{"(", "2", ")"}]], TraditionalForm]],ExpressionUUID->
  "dbb5e4f5-fdc3-2a41-84d3-4389df67faf8"],
 " the second-order quantum correlation as"
}], "Text",
 CellID->168378245,ExpressionUUID->"ccb73d63-8b0a-d240-987e-5971bddeb6b5"],

