Cell[TextData[{
 "A state of light is second-order coherent if ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"|", 
     RowBox[{
      SuperscriptBox["g", 
       RowBox[{"(", "2", ")"}]], "(", 
      RowBox[{
       SubscriptBox["x", "1"], ",", 
       SubscriptBox["x", "2"]}], ")"}], "|"}], "=", "1"}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "760e25fd-4b1b-6942-978e-7981ef0bbd0d"],
 ", such that the factorization ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SuperscriptBox["G", 
      RowBox[{"(", "2", ")"}]], "(", 
     RowBox[{
      SubscriptBox["x", "1"], ",", 
      SubscriptBox["x", "2"]}], ")"}], "=", 
    RowBox[{
     RowBox[{
      SuperscriptBox["G", 
       RowBox[{"(", "1", ")"}]], "(", 
      RowBox[{
       SubscriptBox["x", "1"], ",", 
       SubscriptBox["x", "1"]}], ")"}], 
     RowBox[{
      SuperscriptBox["G", 
       RowBox[{"(", "1", ")"}]], "(", 
      RowBox[{
       SubscriptBox["x", "2"], ",", 
       SubscriptBox["x", "2"]}], ")"}]}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "5397ea04-df4b-e241-9dd7-52a6aa31e2fb"],
 " holds"
}], "Text",
 CellID->57124424,ExpressionUUID->"fdaf408c-f694-234f-99df-01ececdbbc1c"],

Cell[TextData[{
 "If the position has a fixed value, ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["g", 
    RowBox[{"(", "2", ")"}]], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "c0eeb4e8-5922-564f-af39-c28075bf1859"],
 " depends only on the time difference \[Tau]"
}], "Text",
 CellID->889731,ExpressionUUID->"da258418-b3b5-9941-8c78-3a5d7f3c886d"],

