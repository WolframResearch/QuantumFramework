Cell[CellGroupData[{

Cell["Vocabulary", "VocabularySection",
 CellID->37027273,ExpressionUUID->"30f7f02c-c222-7346-9b03-f3960d197201"],

Cell[BoxData[GridBox[{
   {"G2Coherence", " ", Cell[TextData[{
     "Computes ",
     Cell[BoxData[
      FormBox[
       RowBox[{
        RowBox[{
         SuperscriptBox["g", 
          RowBox[{"(", "2", ")"}]], "(", "0", ")"}], Cell[
        "for a single-mode quantum state",ExpressionUUID->
         "590154e2-5ef9-2f47-a4a8-4601e1ebecdf"]}], TraditionalForm]],
      ExpressionUUID->"00ff4838-d7f2-174a-b562-68242bcfc37c"]
    }], "VocabularyText",ExpressionUUID->
     "688e772e-d5df-1c48-8f6a-e9c4fc4509b3"]},
   {"G1Correlation", " ", Cell[TextData[{
     "Computes the first-order correlation ",
     Cell[BoxData[
      FormBox[
       RowBox[{
        SuperscriptBox["G", 
         RowBox[{"(", "1", ")"}]], "(", 
        RowBox[{
         SubscriptBox["x", "1"], ",", 
         SubscriptBox["x", "2"]}], ")"}], TraditionalForm]],
      FormatType->TraditionalForm,ExpressionUUID->
      "7e559e08-0656-a84a-b89d-53ef8b511b1f"],
     " for a single-mode quantum state"
    }], "VocabularyText",ExpressionUUID->
     "5b4a3797-94f6-4c42-ae3a-775e2e687404"]}
  }]], "VocabularyTable",
 CellID->651310115,ExpressionUUID->"25728ae8-2538-7840-826f-18afab85a832"]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[
 InterpretationBox["Exercises",
  $Line = 0; Null]], "ExerciseSection",
 CellID->789234098,ExpressionUUID->"f8daab2c-0f85-6247-8718-53c038a89dd1"],

Cell[TextData[{
 "Analyze the coherent properties (first and second order) of the state ",
 Cell[BoxData[
  FormBox[
   FractionBox["1", 
    SqrtBox["2"]], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "85e0c5df-ba09-724b-ac25-2048fd51c249"],
 "(|\[Alpha]\[RightAngleBracket] + |-\[Alpha]\[RightAngleBracket]) that is a \
superposition of coherent states. Try to approach the limit of large \[Alpha]"
}], "Exercise",
 CellID->99425085,ExpressionUUID->"1ea35773-347b-2e44-982f-82418fc47516"],

Cell["Solution", "ExerciseSolution",
 CellID->652494427,ExpressionUUID->"b030a69f-a6b0-8b45-b6fa-0f76d042754c"],

Cell[CellGroupData[{

Cell[TextData[StyleBox["Define the state symbolically, use a truncation size \
big enough:", "Exercise"]], "ExerciseNote",
 CellID->153164176,ExpressionUUID->"ec14cae7-e89f-664d-ad72-e5a2db860ccf"],

Cell[BoxData[
 RowBox[{
  RowBox[{"state", " ", "=", 
   RowBox[{
    FractionBox["1", 
     SqrtBox["2"]], 
    RowBox[{"(", 
     RowBox[{
      RowBox[{
       RowBox[{"CoherentState", "[", "60", "]"}], "[", "\[Alpha]", "]"}], "+", 
      RowBox[{
       RowBox[{"CoherentState", "[", "60", "]"}], "[", 
       RowBox[{"-", "\[Alpha]"}], "]"}]}], ")"}]}]}], ";"}]], "ExerciseInput",
 CellLabel->"In[20]:=",
 CellID->596095488,ExpressionUUID->"f35cf97c-40a0-4242-a322-926fafc19e7a"]
}, Open  ]],

Cell[CellGroupData[{

Cell[TextData[StyleBox["First order coherence:", "Exercise"]], "ExerciseNote",
 CellID->15193386,ExpressionUUID->"8ec9f377-cb85-8243-807f-6a19f3524555"],

Cell[BoxData[
 RowBox[{
  RowBox[{"firstOrder", " ", "=", 
   RowBox[{"G1Correlation", "[", 
    RowBox[{"state", ",", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"r", ",", "t"}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"r", ",", "t"}], "}"}]}], "}"}]}], "]"}]}], 
  ";"}]], "ExerciseInput",
 CellLabel->"In[16]:=",
 CellID->162024961,ExpressionUUID->"75b05f07-dfcb-5f4a-a27b-c0ce8f77e52e"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Plot", "[", 
  RowBox[{
