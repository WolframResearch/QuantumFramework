  PlotRange->{{0, 524.4}, {0, 139.79999999999998`}}]], "Input",
 CellID->223469040,ExpressionUUID->"2838e500-80eb-9e41-9f59-5aa24a5abe9d"],

Cell[TextData[StyleBox["Three types of behavior of photon statistics",
 FontSlant->"Italic"]], "CodeText",
 TextAlignment->-0.5,
 CellID->370494209,ExpressionUUID->"83411d9d-e995-a246-9eb5-c89d371df89a"],

Cell[TextData[{
 "Following a really similar approach when defining ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["G", 
    RowBox[{"(", "1", ")"}]], TraditionalForm]],ExpressionUUID->
  "60527007-b39b-9c45-9f0d-4c6fb12a87f7"],
 ", we define ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["G", 
    RowBox[{"(", "2", ")"}]], TraditionalForm]],ExpressionUUID->
  "dbb5e4f5-fdc3-2a41-84d3-4389df67faf8"],
 " the second-order quantum correlation as"
}], "Text",
 CellID->168378245,ExpressionUUID->"ccb73d63-8b0a-d240-987e-5971bddeb6b5"],

Cell[BoxData[
 FormBox[
  RowBox[{
   RowBox[{
    SuperscriptBox["G", 
     RowBox[{"(", "2", ")"}]], "(", 
    RowBox[{
     SubscriptBox["x", "1"], ",", 
     SubscriptBox["x", "2"], ";", 
     SubscriptBox["x", "2"], ",", 
     SubscriptBox["x", "1"]}], ")"}], "=", 
   RowBox[{"Tr", "{", 
    RowBox[{
     OverscriptBox["\[Rho]", "^"], 
     SuperscriptBox[
      OverscriptBox["E", "^"], 
      RowBox[{"(", "-", ")"}]], "(", 
     SubscriptBox["x", "1"], ")", 
     SuperscriptBox[
      OverscriptBox["E", "^"], 
      RowBox[{"(", "-", ")"}]], "(", 
     SubscriptBox["x", "2"], ")", 
     SuperscriptBox[
      OverscriptBox["E", "^"], 
      RowBox[{"(", "+", ")"}]], "(", 
     SubscriptBox["x", "2"], ")", 
     SuperscriptBox[
      OverscriptBox["E", "^"], 
      RowBox[{"(", "+", ")"}]], "(", 
     SubscriptBox["x", "1"], ")"}], "}"}]}], 
  TraditionalForm]], "DisplayFormula",
 GeneratedCell->True,
 CellAutoOverwrite->True,
 CellChangeTimes->{3.9859441174155235`*^9, 3.985944176564951*^9},
 FontSize->18,
 CellID->61791917,ExpressionUUID->"55520788-2946-d64e-aa14-34a02124dc4e"],

Cell[TextData[{
 "which is the ensemble average of ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"I", "(", 
     SubscriptBox["x", "1"], ")"}], 
    RowBox[{"I", "(", 
     SubscriptBox["x", "2"], ")"}]}], TraditionalForm]],ExpressionUUID->
  "50233a2a-a855-704f-b742-ae01bc4bd691"],
 " following normal order of field operators"
}], "Text",
 CellID->158305501,ExpressionUUID->"b12e35ef-79f3-2f49-865c-4e3f1c82d386"],

Cell["Similarly the second-order quantum coherence function is:", "Text",
 CellID->101764566,ExpressionUUID->"5ba59328-28d5-214f-b437-63f7c0945987"],

Cell[BoxData[
 FormBox[
  RowBox[{
   RowBox[{
    SuperscriptBox["g", 
     RowBox[{"(", "2", ")"}]], "(", 
    RowBox[{
     SubscriptBox["x", "1"], ",", 
     SubscriptBox["x", "2"], ";", 
     SubscriptBox["x", "2"], ",", 
     SubscriptBox["x", "1"]}], ")"}], "=", 
   FractionBox[
    RowBox[{
     SuperscriptBox["G", 
      RowBox[{"(", "2", ")"}]], "(", 
     RowBox[{
      SubscriptBox["x", "1"], ",", 
      SubscriptBox["x", "2"], ";", 
      SubscriptBox["x", "2"], ",", 
      SubscriptBox["x", "1"]}], ")"}], 
    RowBox[{
     SuperscriptBox["G", 
      RowBox[{"(", "1", ")"}]], "(", 
     RowBox[{
      SubscriptBox["x", "1"], ",", 
      SubscriptBox["x", "1"]}], ")", 
     SuperscriptBox["G", 
      RowBox[{"(", "1", ")"}]], "(", 
     RowBox[{
      SubscriptBox["x", "2"], ",", 
      SubscriptBox["x", "2"]}], ")"}]]}], TraditionalForm]], "DisplayFormula",
 GeneratedCell->True,
 CellAutoOverwrite->True,
 CellChangeTimes->{3.9859441174155235`*^9, 3.985944176564951*^9},
 CellID->80792832,ExpressionUUID->"a0a46f7b-0aa2-dc42-9108-8aae68e60b9b"],

Cell[TextData[{
 "A state of light is second-order coherent if ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"|", 
     RowBox[{
      SuperscriptBox["g", 
       RowBox[{"(", "2", ")"}]], "(", 
      RowBox[{
       SubscriptBox["x", "1"], ",", 
       SubscriptBox["x", "2"]}], ")"}], "|"}], "=", "1"}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "760e25fd-4b1b-6942-978e-7981ef0bbd0d"],
 ", such that the factorization ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SuperscriptBox["G", 
      RowBox[{"(", "2", ")"}]], "(", 
     RowBox[{
      SubscriptBox["x", "1"], ",", 
      SubscriptBox["x", "2"]}], ")"}], "=", 
    RowBox[{
     RowBox[{
      SuperscriptBox["G", 
       RowBox[{"(", "1", ")"}]], "(", 
      RowBox[{
       SubscriptBox["x", "1"], ",", 
       SubscriptBox["x", "1"]}], ")"}], 
     RowBox[{
      SuperscriptBox["G", 
       RowBox[{"(", "1", ")"}]], "(", 
      RowBox[{
       SubscriptBox["x", "2"], ",", 
       SubscriptBox["x", "2"]}], ")"}]}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "5397ea04-df4b-e241-9dd7-52a6aa31e2fb"],
 " holds"
}], "Text",
 CellID->57124424,ExpressionUUID->"fdaf408c-f694-234f-99df-01ececdbbc1c"],

Cell[TextData[{
 "If the position has a fixed value, ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["g", 
    RowBox[{"(", "2", ")"}]], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "c0eeb4e8-5922-564f-af39-c28075bf1859"],
 " depends only on the time difference \[Tau]"
}], "Text",
 CellID->889731,ExpressionUUID->"da258418-b3b5-9941-8c78-3a5d7f3c886d"],

Cell[BoxData[
 FormBox[
  RowBox[{
   RowBox[{
    SuperscriptBox["g", 
     RowBox[{"(", "2", ")"}]], "(", "\[Tau]", ")"}], "=", 
   FractionBox[
    RowBox[{"\[LeftAngleBracket]", 
     RowBox[{
      SuperscriptBox[
       OverscriptBox["E", "^"], 
       RowBox[{"(", "-", ")"}]], "(", "t", ")", 
      SuperscriptBox[
       OverscriptBox["E", "^"], 
       RowBox[{"(", "-", ")"}]], "(", 
      RowBox[{"t", "+", "\[Tau]"}], ")", 
      SuperscriptBox[
       OverscriptBox["E", "^"], 
       RowBox[{"(", "+", ")"}]], "(", 
      RowBox[{"t", "+", "\[Tau]"}], ")", 
      SuperscriptBox[
       OverscriptBox["E", "^"], 
       RowBox[{"(", "+", ")"}]], "(", "t", ")"}], "\[RightAngleBracket]"}], 
    RowBox[{
     RowBox[{"\[LeftAngleBracket]", 
      RowBox[{
       SuperscriptBox[
        OverscriptBox["E", "^"], 
        RowBox[{"(", "-", ")"}]], "(", "t", ")", 
       SuperscriptBox[
        OverscriptBox["E", "^"], 
        RowBox[{"(", "+", ")"}]], "(", "t", ")"}], "\[RightAngleBracket]"}], 
     RowBox[{"\[LeftAngleBracket]", 
      RowBox[{
       SuperscriptBox[
        OverscriptBox["E", "^"], 
        RowBox[{"(", "-", ")"}]], "(", 
       RowBox[{"t", "+", "\[Tau]"}], ")", 
       SuperscriptBox[
        OverscriptBox["E", "^"], 
        RowBox[{"(", "+", ")"}]], "(", 
       RowBox[{"t", "+", "\[Tau]"}], ")"}], "\[RightAngleBracket]"}]}]]}], 
  TraditionalForm]], "DisplayFormula",
 GeneratedCell->True,
 CellAutoOverwrite->True,
 CellChangeTimes->{3.9859441174155235`*^9, 3.985944176564951*^9},
 CellID->69856150,ExpressionUUID->"1ee2a2b5-e9bc-1740-8d3f-78444b31d7a2"],

Cell["\<\
For single-mode states the second-order coherence assumes a simple form\
\>", "Text",
 CellID->89763477,ExpressionUUID->"d2172aea-2d89-c847-9d6e-ff0128ca1d83"],

Cell[BoxData[
 FormBox[
  RowBox[{
   RowBox[{
    SuperscriptBox["g", 
     RowBox[{"(", "2", ")"}]], "(", "\[Tau]", ")"}], "=", 
   RowBox[{
    FractionBox[
     RowBox[{"\[LeftAngleBracket]", 
      RowBox[{
       SuperscriptBox[
        OverscriptBox["a", "^"], "\[Dagger]"], 
       SuperscriptBox[
        OverscriptBox["a", "^"], "\[Dagger]"], 
       OverscriptBox["a", "^"], 
       OverscriptBox["a", "^"]}], "\[RightAngleBracket]"}], 
     SuperscriptBox[
      RowBox[{"\[LeftAngleBracket]", 
       RowBox[{
        SuperscriptBox[
         OverscriptBox["a", "^"], "\[Dagger]"], 
        OverscriptBox["a", "^"]}], "\[RightAngleBracket]"}], "2"]], "=", 
    FractionBox[
     RowBox[{"\[LeftAngleBracket]", 
      RowBox[{
       OverscriptBox["n", "^"], "(", 
       RowBox[{
        OverscriptBox["n", "^"], "-", "1"}], ")"}], "\[RightAngleBracket]"}], 
     SuperscriptBox[
      RowBox[{"\[LeftAngleBracket]", 
       OverscriptBox["n", "^"], "\[RightAngleBracket]"}], "2"]]}]}], 
  TraditionalForm]], "DisplayFormula",
 GeneratedCell->True,
 CellAutoOverwrite->True,
 CellChangeTimes->{3.9859441174155235`*^9, 3.985944176564951*^9},
 CellID->197531003,ExpressionUUID->"1a78d0c0-bdc1-224f-8d17-e17b6c2b5b46"],

Cell[TextData[{
 "and does not depend on \[Tau], so ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SuperscriptBox["g", "2"], "(", "\[Tau]", ")"}], "=", 
    RowBox[{
     SuperscriptBox["g", "2"], "(", "0", ")"}]}], TraditionalForm]],
  ExpressionUUID->"0c245b81-12b1-db4c-a19e-216ae90e5945"],
 " which can be easier to calculate, and it relates to photon statistics and \
not to temporal correlations"
}], "Text",
 CellID->415587589,ExpressionUUID->"bdb62701-9516-bd44-9f26-ca97f032f172"],

Cell[TextData[{
 "For a Fock state ",
 Cell[BoxData[
  FormBox[
   RowBox[{"n", ">=", "1"}], TraditionalForm]],ExpressionUUID->
  "3cc28043-f99c-404f-b30f-114e15ff4aaa"],
 ", the ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox["g", 
     RowBox[{"(", "2", ")"}]], "(", "0", ")"}], TraditionalForm]],
  ExpressionUUID->"07ba1fa1-bdf0-3341-b0d1-5e4de361916f"],
 " has the value of  ",
 Cell[BoxData[
  FormBox[
   RowBox[{"1", "-", 
    RowBox[{"1", "/", "n"}]}], TraditionalForm]],ExpressionUUID->
