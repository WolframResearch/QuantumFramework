Cell[TextData[{
 "The electric field on the detector at time ",
 Cell[BoxData[
  FormBox["t", TraditionalForm]],ExpressionUUID->
  "fbd93cc3-d49c-8a49-a38d-dd25fa7a68c3"],
 " can be written as the superposition of the fields incoming from the slits \
at times ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["t", "1"], "=", 
    RowBox[{"t", "-", 
     RowBox[{
      SubscriptBox["s", "1"], "/", "c"}]}]}], TraditionalForm]],
