Cell["\<\
Compute the second order coherence for a uniform superposition state in the \
truncated Fock space, if the dimension is \[GreaterEqual] 3 find a general \
formula. We expect that the value of such state is > 1 if the truncation size \
is big enough\
\>", "Exercise",
 CellFrame->{{0, 0}, {0, 0.5}},
 CellFrameColor->GrayLevel[0.75],
 CellID->709659892,ExpressionUUID->"93e3f3fd-e9b1-a64c-8540-515a429225f3"],

Cell["Solution", "ExerciseSolution",
 CellID->461563515,ExpressionUUID->"196dba27-74a9-9347-85ae-c4383ec032c1"],

Cell[CellGroupData[{

Cell[TextData[StyleBox["Find the formula:", "Exercise"]], "ExerciseNote",
 CellID->848547238,ExpressionUUID->"f3a5c329-7218-034e-ad71-a9f30ba3ed13"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"FindSequenceFunction", "[", 
  RowBox[{
   RowBox[{"Table", "[", 
    RowBox[{
     RowBox[{"G2Coherence", "[", 
      RowBox[{"QuantumState", "[", 
       RowBox[{"\"\<UniformSuperposition\>\"", ",", "n"}], "]"}], "]"}], ",", 
     RowBox[{"{", 
      RowBox[{"n", ",", "3", ",", "15"}], "}"}]}], "]"}], ",", 
   RowBox[{"n", "-", "2"}]}], "]"}]], "ExerciseInput",
 CellLabel->"In[63]:=",
 CellID->14344262,ExpressionUUID->"5a338d23-16ba-b147-bcb2-6fdf4d86eab9"],

Cell[BoxData[
 FractionBox[
  RowBox[{"4", " ", 
   RowBox[{"(", 
    RowBox[{
     RowBox[{"-", "2"}], "+", "n"}], ")"}]}], 
  RowBox[{"3", " ", 
   RowBox[{"(", 
    RowBox[{
     RowBox[{"-", "1"}], "+", "n"}], ")"}]}]]], "ExerciseOutput",
 CellLabel->"Out[63]=",
 CellID->265013152,ExpressionUUID->"b9e07ce1-8500-b842-a2b8-6569ca439522"]
}, Open  ]]
}, Open  ]],

