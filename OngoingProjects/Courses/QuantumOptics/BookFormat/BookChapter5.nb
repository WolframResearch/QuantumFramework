   "\\begin{aligned}\nI(\\mathbf{r}, t)= & \
\\operatorname{Tr}\\left\\{\\hat{\\rho} \\hat{E}^{(-)}(\\mathbf{r}, t) \
\\hat{E}^{(+)}(\\mathbf{r}, t)\\right\\} \\\\\n= & \\left|K_1\\right|^2 \
G^{(1)}\\left(x_1, x_1\\right)+\\left|K_2\\right|^2 G^{(1)}\\left(x_2, \
x_2\\right) \\\\\n& +2 \\operatorname{Re}\\left[K_1^* K_2 G^{(1)}\\left(x_1, \
x_2\\right)\\right]\n\\end{aligned}", "state" -> "Boxes"|>,
  "TeXAssistantTemplate"]], "Input",
