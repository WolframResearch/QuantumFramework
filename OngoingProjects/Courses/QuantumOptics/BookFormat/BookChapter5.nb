  FormBox[
   RowBox[{"n", ">=", "1"}], TraditionalForm]],ExpressionUUID->
  "3cc28043-f99c-404f-b30f-114e15ff4aaa"],
 ", the ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["g", "2"], "(", "0", ")"}], TraditionalForm]],ExpressionUUID->
  "07ba1fa1-bdf0-3341-b0d1-5e4de361916f"],
 " has the value of  ",
 Cell[BoxData[
  FormBox[
   RowBox[{"1", "-", 
    RowBox[{"1", "/", "n"}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "fd92de22-e006-fe49-8b99-930b2195393c"],
 ":"
}], "Text",
