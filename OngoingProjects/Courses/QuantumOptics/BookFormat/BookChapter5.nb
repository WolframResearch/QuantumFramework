   "state" -> "Boxes"|>,
  "TeXAssistantTemplate"]], "Input",
 CellID->76611528,ExpressionUUID->"504f5474-fe5a-9940-99c9-e410bc397775"],

Cell[TextData[{
 "which is the ensemble average of ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"I", "(", 
     SubscriptBox["x", "1"], ")"}], 
    RowBox[{"I", "(", 
     SubscriptBox["x", "2"], ")"}]}], TraditionalForm]],ExpressionUUID->
  "50233a2a-a855-704f-b742-ae01bc4bd691"],
 " following normal order of field operators"
}], "Text",
 CellID->158305501,ExpressionUUID->"b12e35ef-79f3-2f49-865c-4e3f1c82d386"],

Cell["Similarly the second-order quantum coherence function is:", "Text",
 CellID->101764566,ExpressionUUID->"5ba59328-28d5-214f-b437-63f7c0945987"],

