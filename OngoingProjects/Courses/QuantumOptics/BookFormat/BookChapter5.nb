Cell["\<\
So we can express the visibility  in terms of the first order coherence \
function:\
\>", "Text",
 CellID->609280147,ExpressionUUID->"946e7c02-5e86-9d45-9273-1252134e46fe"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"With", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{"Imax", " ", "=", " ", 
       RowBox[{
        SubscriptBox["\[FormalCapitalI]", "1"], "+", 
        SubscriptBox["\[FormalCapitalI]", "2"], "+", 
        RowBox[{
         SqrtBox[
          RowBox[{"2", " ", 
           SubscriptBox["\[FormalCapitalI]", "1"], " ", 
           SubscriptBox["\[FormalCapitalI]", "2"]}]], " ", 
         RowBox[{"Abs", "[", "\[Gamma]1", "]"}]}]}]}], ",", 
      RowBox[{"Imin", "=", " ", 
       RowBox[{
        SubscriptBox["\[FormalCapitalI]", "1"], "+", 
        SubscriptBox["\[FormalCapitalI]", "2"], "-", 
        RowBox[{
         SqrtBox[
          RowBox[{"2", " ", 
           SubscriptBox["\[FormalCapitalI]", "1"], " ", 
           SubscriptBox["\[FormalCapitalI]", "2"]}]], " ", 
         RowBox[{"Abs", "[", "\[Gamma]1", "]"}]}]}]}]}], "}"}], ",", 
    RowBox[{
     RowBox[{"(", 
      RowBox[{"Imax", "-", "Imin"}], ")"}], "/", 
     RowBox[{"(", 
      RowBox[{"Imax", "+", "Imin"}], ")"}]}]}], "]"}], "//", 
  "Simplify"}]], "Input",
 CellLabel->"In[51]:=",
 CellID->262365325,ExpressionUUID->"7dbc65d3-792b-5242-842e-3aa6209f1f3e"],

Cell[BoxData[
 FormBox[
  FractionBox[
   RowBox[{
    SqrtBox["2"], " ", 
    SqrtBox[
     RowBox[{
      SubscriptBox["\[FormalCapitalI]", "1"], " ", 
      SubscriptBox["\[FormalCapitalI]", "2"]}]], " ", 
    TemplateBox[{"\[Gamma]1"},
     "Abs"]}], 
   RowBox[{
    SubscriptBox["\[FormalCapitalI]", "1"], "+", 
    SubscriptBox["\[FormalCapitalI]", "2"]}]], TraditionalForm]], "Output",
 CellLabel->"Out[51]=",
 CellID->23634988,ExpressionUUID->"01bf9b05-bcf5-6d41-a86d-4337c7a08692"]
}, Open  ]],

