Cell[TextData[{
 "Referring to the previous diagram of Young\[CloseCurlyQuote]s interference \
we can similarly consider the quantum analog ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SuperscriptBox["E", 
      RowBox[{"(", "+", ")"}]], "(", 
     RowBox[{
      StyleBox["r",
       FontWeight->"Bold"], ",", "t"}], ")"}], "=", 
    RowBox[{
     RowBox[{
      SubscriptBox["K", "1"], 
      RowBox[{
       SuperscriptBox["E", 
        RowBox[{"(", "+", ")"}]], "(", 
       RowBox[{
        SubscriptBox[
         StyleBox["r",
          FontWeight->"Bold"], "1"], ",", 
        SubscriptBox["t", "1"]}], ")"}]}], "+", 
     RowBox[{
      SubscriptBox["K", "2"], 
      RowBox[{
       SuperscriptBox["E", 
        RowBox[{"(", "+", ")"}]], "(", 
       RowBox[{
        SubscriptBox[
         StyleBox["r",
          FontWeight->"Bold"], "2"], ",", 
        SubscriptBox["t", "2"]}], ")"}]}]}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "346d71eb-e125-cd49-87ee-cfea7b52c268"],
 " using positive frequency operators. So the intensity at the detector is"
}], "Text",
 CellID->458261786,ExpressionUUID->"ff36595c-5074-ba44-a296-27a473054402"],

