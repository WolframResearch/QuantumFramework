Cell[TextData[{
 "In general, the ",
 Cell[BoxData[
  FormBox["n", TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "4c848980-43ee-4b46-9a5d-3b6c596b2407"],
 "-",
 Cell[BoxData[
  FormBox["th", TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "a867a05a-6a2e-7847-9477-25ad891e483a"],
 " order quantum correlation function is:"
}], "Text",
 CellID->226883297,ExpressionUUID->"322945ef-b9cd-c444-aedc-b7c35c22c956"],

Cell[BoxData[
 FormBox[
  RowBox[{
   RowBox[{
    SuperscriptBox["G", 
     RowBox[{"(", "n", ")"}]], "(", 
    RowBox[{
     SubscriptBox["x", "1"], ",", "\[Ellipsis]", 
     SubscriptBox["x", "n"], ";", 
     SubscriptBox["x", "n"], ",", "\[Ellipsis]", 
     SubscriptBox["x", "1"]}], ")"}], "=", 
   RowBox[{"Tr", "{", 
    RowBox[{
     OverscriptBox["\[Rho]", "^"], 
     SuperscriptBox[
      OverscriptBox["E", "^"], 
      RowBox[{"(", "-", ")"}]], "(", 
     SubscriptBox["x", "1"], ")", "\[Ellipsis]", 
     SuperscriptBox[
      OverscriptBox["E", "^"], 
      RowBox[{"(", "-", ")"}]], "(", 
     SubscriptBox["x", "n"], ")", 
     SuperscriptBox[
      OverscriptBox["E", "^"], 
      RowBox[{"(", "+", ")"}]], "(", 
     SubscriptBox["x", "n"], ")", "\[Ellipsis]", 
     SuperscriptBox[
      OverscriptBox["E", "^"], 
      RowBox[{"(", "+", ")"}]], "(", 
     SubscriptBox["x", "1"], ")"}], "}"}]}], 
  TraditionalForm]], "DisplayFormula",
 GeneratedCell->True,
 CellAutoOverwrite->True,
 CellChangeTimes->{3.9859441174155235`*^9, 3.985944176564951*^9},
 CellID->174714044,ExpressionUUID->"7380c5e4-3e62-df4d-93a7-cf7a7d239744"],

Cell[TextData[{
 "And the ",
 Cell[BoxData[
  FormBox["n", TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "9656afc3-3262-c748-baad-651b84c3b38d"],
 "-",
 Cell[BoxData[
  FormBox["th", TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "a6b366db-e19e-6846-aa0b-d2260b90ed09"],
 " order coherence function can be defined as:"
}], "Text",
 CellID->272316668,ExpressionUUID->"dc3dd4a6-0d64-b74b-a8e2-879e83142196"],

Cell[BoxData[
 FormBox[
  RowBox[{
   RowBox[{
    SuperscriptBox["g", 
     RowBox[{"(", "n", ")"}]], "(", 
    RowBox[{
     SubscriptBox["x", "1"], ",", "\[Ellipsis]", 
     SubscriptBox["x", "n"], ";", 
     SubscriptBox["x", "n"], ",", "\[Ellipsis]", 
     SubscriptBox["x", "1"]}], ")"}], "=", 
   FractionBox[
    RowBox[{
     SuperscriptBox["G", 
      RowBox[{"(", "n", ")"}]], "(", 
     RowBox[{
      SubscriptBox["x", "1"], ",", "\[Ellipsis]", 
      SubscriptBox["x", "n"], ";", 
      SubscriptBox["x", "n"], ",", "\[Ellipsis]", 
      SubscriptBox["x", "1"]}], ")"}], 
    RowBox[{
     SuperscriptBox["G", 
      RowBox[{"(", "1", ")"}]], "(", 
     RowBox[{
      SubscriptBox["x", "1"], ",", 
      SubscriptBox["x", "1"]}], ")", "\[Ellipsis]", 
     SuperscriptBox["G", 
      RowBox[{"(", "1", ")"}]], "(", 
     RowBox[{
      SubscriptBox["x", "n"], ",", 
      SubscriptBox["x", "n"]}], ")"}]]}], TraditionalForm]], "DisplayFormula",
 GeneratedCell->True,
 CellAutoOverwrite->True,
 CellChangeTimes->{3.9859441174155235`*^9, 3.985944176564951*^9},
 CellID->729594796,ExpressionUUID->"c4781aa2-6962-d540-9242-659c9d7d5837"],

