Cell[TextData[{
 "Other interesting example is to analyze the state ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{"(", 
       RowBox[{"1", "-", "p"}], ")"}], "|", "0"}], "\[RightAngleBracket]"}], 
    RowBox[{"\[LeftAngleBracket]", 
     RowBox[{"0", "|", 
      RowBox[{"+", "p"}], "|", "2"}], "\[RightAngleBracket]"}], 
    RowBox[{"\[LeftAngleBracket]", 
     RowBox[{"2", "|"}]}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "b5be542a-da3c-7f4b-b8ad-e2836a5cef3d"],
 ":"
}], "Text",
 CellID->462296374,ExpressionUUID->"c4d80c27-fe14-b442-a43c-1fd5fef6df0b"],

