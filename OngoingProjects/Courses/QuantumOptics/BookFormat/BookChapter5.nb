Cell[TextData[{
 "and does not depend on \[Tau], so ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SuperscriptBox["g", "2"], "(", "\[Tau]", ")"}], "=", 
    RowBox[{
     SuperscriptBox["g", "2"], "(", "0", ")"}]}], TraditionalForm]],
  ExpressionUUID->"0c245b81-12b1-db4c-a19e-216ae90e5945"],
 " which can be easier to calculate, and it relates to photon statistics and \
not to temporal correlations"
}], "Text",
 CellID->415587589,ExpressionUUID->"bdb62701-9516-bd44-9f26-ca97f032f172"],

Cell[TextData[{
 "For a Fock state ",
 Cell[BoxData[
  FormBox[
   RowBox[{"n", ">=", "1"}], TraditionalForm]],ExpressionUUID->
  "3cc28043-f99c-404f-b30f-114e15ff4aaa"],
 ", the ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox["g", 
     RowBox[{"(", "2", ")"}]], "(", "0", ")"}], TraditionalForm]],
  ExpressionUUID->"07ba1fa1-bdf0-3341-b0d1-5e4de361916f"],
 " has the value of  ",
 Cell[BoxData[
  FormBox[
   RowBox[{"1", "-", 
    RowBox[{"1", "/", "n"}]}], TraditionalForm]],ExpressionUUID->
  "fd92de22-e006-fe49-8b99-930b2195393c"],
 ":"
}], "Text",
