Cell[TextData[{
 "if ",
 Cell[BoxData[
  FormBox[
   RowBox[{"p", 
    RowBox[{"<<", "1"}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "5d6d66ce-a07b-2e4a-8e21-aab390f3f2a6"],
 " ,  ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["g", 
    RowBox[{"(", "2", ")"}]], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "42862b80-9c60-0047-ae24-27cf8941e770"],
 " can take big values this is extreme bunching based on the fact the state \
is almost always in the vacuum and suddenly two photons appear"
}], "Text",
 CellID->124462141,ExpressionUUID->"9b1fd62d-c802-034b-80f8-dc2bc77c6c74"],

Cell["Summarizing the results", "Text",
 CellID->278769911,ExpressionUUID->"135d62e2-cef4-fd4a-bc96-13a0efc060e9"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Grid", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"Style", "[", 
        RowBox[{"\"\<Value\>\"", ",", "Bold"}], "]"}], ",", 
       RowBox[{"Style", "[", 
        RowBox[{"\"\<Photon statistics\>\"", ",", "Bold"}], "]"}]}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"Row", "[", 
        RowBox[{"{", 
         RowBox[{
          TemplateBox[{"\"g\"", "\"(2)\""},
           "Superscript"], ",", "\"\< = 1\>\""}], "}"}], "]"}], 
       ",", "\"\<Poissonian statistics (coherent light)\>\""}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"Row", "[", 
        RowBox[{"{", 
         RowBox[{
          TemplateBox[{"\"g\"", "\"(2)\""},
           "Superscript"], ",", "\"\< < 1\>\""}], "}"}], "]"}], 
       ",", "\"\<Sub-Poissonian (non-classical light)\>\""}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"Row", "[", 
        RowBox[{"{", 
         RowBox[{
          TemplateBox[{"\"g\"", "\"(2)\""},
           "Superscript"], ",", "\"\< > 1\>\""}], "}"}], "]"}], 
       ",", "\"\<Super-Poissonian (bunching, thermal light)\>\""}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"Row", "[", 
        RowBox[{"{", 
         RowBox[{
          TemplateBox[{"\"g\"", "\"(2)\""},
           "Superscript"], ",", "\"\< = 0\>\""}], "}"}], "]"}], 
       ",", "\"\<Single-photon state\>\""}], "}"}]}], "}"}], ",", 
   RowBox[{"Frame", "\[Rule]", "All"}], ",", 
   RowBox[{"Spacings", "\[Rule]", 
    RowBox[{"{", 
     RowBox[{"2", ",", "1"}], "}"}]}], ",", 
   RowBox[{"Background", "\[Rule]", 
    RowBox[{"{", 
     RowBox[{"None", ",", 
      RowBox[{"{", 
       RowBox[{"LightGray", ",", 
        RowBox[{"{", "White", "}"}]}], "}"}]}], "}"}]}], ",", 
   RowBox[{"Alignment", "\[Rule]", 
    RowBox[{"{", 
     RowBox[{"Center", ",", "Left"}], "}"}]}], ",", 
   RowBox[{"ItemStyle", "\[Rule]", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"FontFamily", "\[Rule]", "\"\<Times\>\""}], ",", 
      RowBox[{"FontSize", "\[Rule]", "14"}]}], "}"}]}]}], "]"}]], "Input",
 CellLabel->"In[25]:=",
 CellID->49434449,ExpressionUUID->"b6c90487-d428-5644-a6d8-219d47805d80"],

Cell[BoxData[
 TagBox[GridBox[{
    {
     StyleBox["\<\"Value\"\>",
      StripOnInput->False,
      FontWeight->Bold], 
     StyleBox["\<\"Photon statistics\"\>",
      StripOnInput->False,
      FontWeight->Bold]},
    {
     TemplateBox[{
       TemplateBox[{"\"g\"", "\"(2)\""}, "Superscript", SyntaxForm -> 
        SuperscriptBox], "\" = 1\""},
      "RowDefault"], "\<\"Poissonian statistics (coherent light)\"\>"},
    {
     TemplateBox[{
       TemplateBox[{"\"g\"", "\"(2)\""}, "Superscript", SyntaxForm -> 
        SuperscriptBox], "\" < 1\""},
      "RowDefault"], "\<\"Sub-Poissonian (non-classical light)\"\>"},
    {
     TemplateBox[{
       TemplateBox[{"\"g\"", "\"(2)\""}, "Superscript", SyntaxForm -> 
        SuperscriptBox], "\" > 1\""},
      "RowDefault"], "\<\"Super-Poissonian (bunching, thermal light)\"\>"},
    {
     TemplateBox[{
       TemplateBox[{"\"g\"", "\"(2)\""}, "Superscript", SyntaxForm -> 
        SuperscriptBox], "\" = 0\""},
      "RowDefault"], "\<\"Single-photon state\"\>"}
   },
   AutoDelete->False,
   GridBoxAlignment->{"Columns" -> {{Center}}, "Rows" -> {{Left}}},
   GridBoxBackground->{"Columns" -> {{None}}, "Rows" -> {
       GrayLevel[0.85], {
        GrayLevel[1]}}},
   GridBoxFrame->{"Columns" -> {{True}}, "Rows" -> {{True}}},
   GridBoxItemSize->{"Columns" -> {{Automatic}}, "Rows" -> {{Automatic}}},
   GridBoxItemStyle->{
    "Columns" -> {{FontFamily -> "Times"}}, "Rows" -> {{FontSize -> 14}}},
   GridBoxSpacings->{"Columns" -> {{2}}, "Rows" -> {{1}}}],
  "Grid"]], "Output",
 CellLabel->"Out[25]=",
 CellID->28245144,ExpressionUUID->"c78fdae7-27b3-4748-a8b4-ac19f683260e"]
}, {2}]],

Cell[TextData[{
 "It is worth noting that for multi-mode fields that have a width of \
frequencies ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SuperscriptBox["g", 
      RowBox[{"(", "2", ")"}]], "(", "\[Tau]", ")"}], "!=", " ", 
    RowBox[{
     SuperscriptBox["g", 
      RowBox[{"(", "2", ")"}]], "(", "0", ")"}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "fd034e69-c13c-6a4b-b5a5-2139d00e2c24"],
 ". The plot below illustrates the theoretical curve for a typical \
single-photon wave packet. In experimental quantum optics, achieving a low ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox["g", 
     RowBox[{"(", "2", ")"}]], "(", "0", ")"}], TraditionalForm]],
  ExpressionUUID->"3808c6da-5d6c-cd49-b264-327a71298c3d"],
 " value is one of the figures of merit for validating high-purity \
single-photon sources."
}], "Text",
 CellID->339488925,ExpressionUUID->"353b2cb8-2f21-4b49-98e6-2d579ea13b91"],

