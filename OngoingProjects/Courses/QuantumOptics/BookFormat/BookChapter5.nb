Cell[TextData[{
 "and does not depend on \[Tau], so ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SuperscriptBox["g", "2"], "(", "\[Tau]", ")"}], "=", 
    RowBox[{
     SuperscriptBox["g", "2"], "(", "0", ")"}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "0c245b81-12b1-db4c-a19e-216ae90e5945"],
 " which can be easier to calculate"
}], "Text",
 CellID->415587589,ExpressionUUID->"bdb62701-9516-bd44-9f26-ca97f032f172"],

Cell[TextData[{
 "For a Fock state ",
