              RowBox[{"Row", "[", 
               RowBox[{"{", 
                RowBox[{
                "i", ",", "\"\<\\!\\(\\*SubscriptBox[\\(\[Tau]\\), \
\\(0\\)]\\)\>\""}], "}"}], "]"}]}], "]"}]}], "}"}], ",", 
