Cell[TextData[{
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{
       SuperscriptBox["G", 
        RowBox[{"(", "1", ")"}]], "(", 
       RowBox[{
        SubscriptBox["x", "i"], ",", 
        SubscriptBox["x", "i"]}], ")"}], "   ", "i"}], "=", "1"}], ",", "2"}],
    TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "b3802bf3-8738-844a-a60b-2049dcb61bdc"],
 " is the intensity at the detector coming from ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["x", "i"], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "8fd8c9e2-e60e-4445-b096-a91cd01e73ef"],
 ", and the correlation of light arriving from ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["x", "1"], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "a295dbb8-9ef0-624c-b970-59e2ab549b7a"],
 " and ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["x", "2"], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "f5dcae30-c17a-e84f-bb84-8fb0e21fdf16"],
 " is ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox["G", 
     RowBox[{"(", "1", ")"}]], "(", 
    RowBox[{
     SubscriptBox["x", "1"], ",", 
     SubscriptBox["x", "2"]}], ")"}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "1035fd95-6036-f340-bdcd-62e71617c620"],
 " (interference)"
}], "Text",
 CellID->127826847,ExpressionUUID->"cf8d5911-c135-a143-89f9-9afd977f6498"],

Cell[TextData[{
 "Analogously to the classical ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["\[Gamma]", 
    RowBox[{"(", "1", ")"}]], TraditionalForm]],ExpressionUUID->
  "d2e99fb3-62d7-bc46-baa9-5f1080e9e893"],
 ", the normalized first-order coherence function is:"
}], "Text",
 CellID->254482591,ExpressionUUID->"8728f0b2-0d4b-ec47-8488-478342a350eb"],

