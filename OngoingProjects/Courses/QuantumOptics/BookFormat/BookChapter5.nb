Cell[TextData[{
 "The intensity at the screen can be rewritten in terms of the coherence \
function, using the polar form of the complex numbers ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["K", "1"], ",", 
    SubscriptBox["K", "2"]}], TraditionalForm]],ExpressionUUID->
  "6f34a1a8-7b76-5a48-9641-35dc297c7d66"],
 " and defining ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Theta]", "=", 
    RowBox[{
     SubscriptBox["\[Psi]", "1"], "-", 
     SubscriptBox["\[Psi]", "2"]}]}], TraditionalForm]],ExpressionUUID->
  "0831b624-3432-834a-9859-daaabc170bbb"],
 " the phase difference related to path length difference"
}], "Text",
 CellID->117742202,ExpressionUUID->"02e2ed92-61fd-8545-94ad-2f63b0a9db53"],

