Cell[TextData[{
 "For the vacuum state ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["g", 
    RowBox[{"(", "2", ")"}]], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "4043adc9-ea64-8e4e-a344-82d5e22c6b7d"],
 " is not defined from the mathematical definition, we can also see that \
plugging ",
 Cell[BoxData[
  FormBox[
   RowBox[{"n", "=", "0"}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "7ea6a121-d411-424d-ba1d-907d0067778a"],
 " in the above formula. However, the value that makes sense from a \
experimental point of view is just 0, there cannot be coherence with a 0 \
photon state"
}], "Text",
 CellID->832794082,ExpressionUUID->"0b600402-9b8d-fe45-b8c3-eba83e364955"],

