Cell["One way to represent this calculation is:", "Text",
 CellID->602015835,ExpressionUUID->"54393150-d316-5b48-8a64-100d06e4c213"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"autocorrelation", "=", 
  RowBox[{
   SuperscriptBox["E0", "2"], " ", 
   RowBox[{"Exp", "[", 
    RowBox[{
     RowBox[{"-", "\[ImaginaryI]"}], " ", "\[Omega]0", " ", "\[Tau]"}], "]"}],
    " ", 
   RowBox[{"Expectation", "[", 
    RowBox[{
     RowBox[{"Exp", "[", 
      RowBox[{"\[ImaginaryI]", " ", "\[Delta]\[Phi]"}], "]"}], ",", 
     RowBox[{"\[Delta]\[Phi]", "\[Distributed]", 
      RowBox[{"NormalDistribution", "[", 
       RowBox[{"0", ",", 
        SqrtBox[
         FractionBox[
          RowBox[{"2", " ", 
           RowBox[{"Abs", "[", "\[Tau]", "]"}]}], "\[Tau]0"]]}], "]"}]}]}], 
    "]"}]}]}]], "Input",
 CellLabel->"In[47]:=",
 CellID->98603167,ExpressionUUID->"ddbe0d9f-e5fb-1b4c-825a-a0cf3d8aab4b"],

Cell[BoxData[
 RowBox[{
  SuperscriptBox["\[ExponentialE]", 
   RowBox[{
    RowBox[{
     RowBox[{"-", "\[ImaginaryI]"}], " ", "\[Tau]", " ", "\[Omega]0"}], "-", 
    FractionBox[
     RowBox[{"Abs", "[", "\[Tau]", "]"}], "\[Tau]0"]}]], " ", 
  SuperscriptBox["E0", "2"]}]], "Output",
 CellLabel->"Out[47]=",
 CellID->52628125,ExpressionUUID->"a7ba9516-df55-2e48-906e-c21a6047beab"]
}, Open  ]],

Cell["\<\
Get the Lorentzian functional form from the Fourier transform:\
\>", "Text",
 CellID->286187595,ExpressionUUID->"c5ae641e-9225-b646-a092-5c91c9fd8414"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"FourierTransform", "[", 
  RowBox[{"autocorrelation", ",", "\[Tau]", ",", "\[Omega]"}], "]"}]], "Input",
 CellLabel->"In[48]:=",
 CellID->134302027,ExpressionUUID->"2ff8d97e-e0b5-9b46-b671-f3d5566e5ece"],

Cell[BoxData[
 FractionBox[
  RowBox[{
   SuperscriptBox["E0", "2"], " ", 
   SqrtBox[
    FractionBox["2", "\[Pi]"]], " ", "\[Tau]0"}], 
  RowBox[{"1", "+", 
   RowBox[{
    SuperscriptBox["\[Tau]0", "2"], " ", 
    SuperscriptBox[
     RowBox[{"(", 
      RowBox[{"\[Omega]", "-", "\[Omega]0"}], ")"}], "2"]}]}]]], "Output",
 CellLabel->"Out[48]=",
 CellID->414824907,ExpressionUUID->"e08b3bb5-ab51-fe45-8878-6a2ad8da49f8"]
}, Open  ]],

Cell[TextData[{
 "From this ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SuperscriptBox["\[Gamma]", 
      RowBox[{"(", "1", ")"}]], "(", "\[Tau]", ")"}], "=", 
    SuperscriptBox["\[ExponentialE]", 
     RowBox[{
      RowBox[{
       RowBox[{"-", "\[ImaginaryI]"}], " ", 
       SubscriptBox["\[Omega]", "0"], "\[Tau]"}], " ", "-", " ", 
      FractionBox[
       RowBox[{"|", "\[Tau]", "|"}], 
       SubscriptBox["\[Tau]", "0"]]}]]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "cfaecb3b-a2c8-954e-92f5-d204301c5372"],
 ", which clearly has magnitude between 0 and 1 as expected, ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"|", 
     RowBox[{
      SuperscriptBox["\[Gamma]", 
       RowBox[{"(", "1", ")"}]], "(", "\[Tau]", ")"}], "|"}], "\[Rule]", 
    RowBox[{
     RowBox[{"0", " ", "when", " ", "\[Tau]"}], "\[Rule]", " ", 
     "\[Infinity]"}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "97cc1a58-6adc-df4f-92ef-affc0d2a4a64"],
 " which means increasing the time delay reduces the coherence. We can see ",
 Cell[BoxData[
  FormBox[
   RowBox[{"|", "\[Tau]", "|", 
    RowBox[{"<<", 
     SubscriptBox["\[Tau]", "0"]}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "e78b3e13-008e-1a46-83d3-675f91f884e9"],
 " then ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"|", 
     RowBox[{
      SuperscriptBox["\[Gamma]", 
       RowBox[{"(", "1", ")"}]], "(", "\[Tau]", ")"}], "|"}], "\[Rule]", 
    "1"}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "b3382316-521f-f847-9fb3-49e9db04282d"],
 ", also if the average collision time ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Tau]", "0"], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "c318e348-af92-1d48-9fe3-8312341bdb5f"],
 " is reduced the coherence goes to 0 faster when increasing \[Tau]. "
}], "Text",
 CellID->46614057,ExpressionUUID->"61b7d9ff-be47-ea42-adc1-e612899121d2"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Quantum approach to coherence functions", "Subsection",
 CellID->93478736,ExpressionUUID->"e24cd10b-c971-bc4c-aa42-7a7497e23b06"],

Cell[TextData[{
 "When describing the theory of coherence in quantum optics, the measuring \
device can absorb photons. If we think of the detector as some atom, then the \
atom can be excited by the field from a band of wavelengths. The coupling of \
the atom and the quantized field can be described with the electric dipole \
interaction with Hamiltonian ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["H", 
    RowBox[{"(", "I", ")"}]], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "4a104572-bc9e-0c4c-98f7-5d7710877d1e"],
 "."
}], "Text",
 CellID->29643526,ExpressionUUID->"ec62ad97-c1e6-1b43-ba7a-9c684d95a959"],

Cell[TextData[{
 "In this model the electric field can be written using Heisenberg picture \
and the long-wavelength approximation (\[Lambda] >> ",
 Cell[BoxData[
  FormBox["atom", TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "64f23499-239e-5445-aec7-ef7d160adb64"],
 " size) as"
}], "Text",
 CellID->246387956,ExpressionUUID->"24aef34c-4861-2f4f-a45c-a4fc4ee4ed2e"],

Cell[BoxData[
 TemplateBox[<|"boxes" -> AdjustmentBox[
     GraphicsBox[{
       Thickness[0.004592000734720118], 
       StyleBox[{
