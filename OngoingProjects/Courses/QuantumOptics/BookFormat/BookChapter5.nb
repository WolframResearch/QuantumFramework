Cell[TextData[{
 "For example, lets perform the numerical integration for ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox["\[Tau]", "0"], "=", "1"}], ",", 
    RowBox[{"\[Tau]", "=", "0.5"}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "4cef4cf1-bf20-494f-9d29-a11ea99fd539"],
 ", we should get a value close to 0.5:"
}], "Text",
 CellID->344451513,ExpressionUUID->"ce422037-cf33-9645-b496-f072d0ab4f7f"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"With", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"T", "=", 
      SuperscriptBox["10", "6"]}], "}"}], ",", 
    RowBox[{
     RowBox[{"1", "/", "T"}], " ", 
     RowBox[{"NIntegrate", "[", 
      RowBox[{
       RowBox[{"Re", "[", 
        RowBox[{"Exp", "[", 
         RowBox[{"\[ImaginaryI]", 
          RowBox[{"(", 
           RowBox[{
            RowBox[{"psi", "[", 
             RowBox[{"t", ",", "1"}], "]"}], "-", 
            RowBox[{"psi", "[", 
             RowBox[{
              RowBox[{"t", "+", "0.5"}], ",", "1"}], "]"}]}], ")"}]}], "]"}], 
        "]"}], ",", 
       RowBox[{"{", 
        RowBox[{"t", ",", "0", ",", "T"}], "}"}], ",", 
       RowBox[{"Method", "->", "\"\<MultiPeriodic\>\""}]}], "]"}]}]}], "]"}], 
  "//", "Quiet"}]], "Input",
 CellLabel->"In[97]:=",
 CellID->339289702,ExpressionUUID->"0cc0f7d2-6b7b-ae40-832d-53ca4497e4cb"],

Cell[BoxData["0.5036982411388635`"], "Output",
 CellLabel->"Out[97]=",
 CellID->592101515,ExpressionUUID->"7cf5dc4a-948c-9845-8258-1d809d9efc39"]
}, Open  ]],

Cell[TextData[{
 "So ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"|", " ", 
     RowBox[{
      SuperscriptBox["\[Gamma]", 
       RowBox[{"(", "1", ")"}]], "(", "\[Tau]", ")"}], "|"}], "=", 
    RowBox[{"1", "-", 
     RowBox[{"\[Tau]", "/", 
      SubscriptBox["\[Tau]", "0"]}]}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "e6118a29-a548-9249-a011-64a71122b88d"],
 " for ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Tau]", " ", "<", 
    SubscriptBox["\[Tau]", "0"]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "b9080eed-9f0f-5543-ac79-611da5dbf498"],
 ", and zero otherwise. So if the delay is longer than the coherence time of \
the source there is just no coherence at all"
}], "Text",
 CellID->72222704,ExpressionUUID->"f88e28ce-01ed-0942-ba6d-cfe8a0d9cbea"],

Cell[TextData[{
 "Other model is the collision broadened light such that has a Lorentzian \
power spectrum centered at ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Omega]", "0"], TraditionalForm]],ExpressionUUID->
  "66565b5f-618f-2e41-9c4f-60678f78f4f5"],
 ". This case has the following autocorrelation function"
}], "Text",
 CellID->374742155,ExpressionUUID->"adcf6b66-8ca0-c446-a677-ef42c4a68719"],

