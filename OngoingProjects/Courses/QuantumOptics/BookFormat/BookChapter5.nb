           RowBox[{"i", ",", "0", ",", "5"}], "}"}]}], "]"}], ",", "None"}], 
       "}"}]}], "}"}]}], ",", 
   RowBox[{"ImageSize", "->", "400"}]}], "]"}]], "Input",
