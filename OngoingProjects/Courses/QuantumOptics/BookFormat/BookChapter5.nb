Cell["It can be shown that the integral evaluates to", "Text",
 CellID->201289195,ExpressionUUID->"8fefeec1-1be6-f349-898a-ba5ddc818b40"],

Cell[BoxData[
 FormBox[
  RowBox[{"I", "=", 
   TagBox[GridBox[{
      {"\[Piecewise]", GridBox[{
         {
          TagBox[GridBox[{
             {
              RowBox[{"(", 
               RowBox[{"1", "-", 
                FractionBox["\[Tau]", 
                 SubscriptBox["\[Tau]", "0"]]}], ")"}], 
              RowBox[{"    ", 
               RowBox[{"\[Tau]", "<", 
                SubscriptBox["\[Tau]", "0"]}]}]},
             {"0", 
              RowBox[{"    ", 
               RowBox[{"\[Tau]", "\[GreaterEqual]", 
                SubscriptBox["\[Tau]", "0"]}]}]}
            }],
           "Piecewise"], " "}
        },
        AllowedDimensions->{2, Automatic},
        Editable->True,
        GridBoxAlignment->{"Columns" -> {{Left}}, "Rows" -> {{Baseline}}},
        GridBoxItemSize->{"Columns" -> {{Automatic}}, "Rows" -> {{1.}}},
        GridBoxSpacings->{"Columns" -> {
            Offset[0.27999999999999997`], {
             Offset[0.84]}, 
            Offset[0.27999999999999997`]}, "Rows" -> {
            Offset[0.2], {
             Offset[0.4]}, 
            Offset[0.2]}},
        Selectable->True]}
     },
     GridBoxAlignment->{"Columns" -> {{Left}}, "Rows" -> {{Baseline}}},
     GridBoxItemSize->{"Columns" -> {{Automatic}}, "Rows" -> {{1.}}},
     GridBoxSpacings->{"Columns" -> {
         Offset[0.27999999999999997`], {
          Offset[0.35]}, 
         Offset[0.27999999999999997`]}, "Rows" -> {
         Offset[0.2], {
          Offset[0.4]}, 
         Offset[0.2]}}],
    "Piecewise",
    DeleteWithContents->True,
    Editable->False,
    SelectWithContents->True,
    Selectable->False,
    StripWrapperBoxes->True]}], TraditionalForm]], "DisplayFormula",
 CellID->167704493,ExpressionUUID->"9e39207b-bc9c-db43-a38e-c62ab03bac31"],

Cell[TextData[{
 "For example, lets perform the numerical integration for ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox["\[Tau]", "0"], "=", "1"}], ",", 
    RowBox[{"\[Tau]", "=", "0.5"}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "4cef4cf1-bf20-494f-9d29-a11ea99fd539"],
 ", we should get a value close to 0.5:"
}], "Text",
 CellID->344451513,ExpressionUUID->"ce422037-cf33-9645-b496-f072d0ab4f7f"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"With", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"T", "=", 
      SuperscriptBox["10", "6"]}], "}"}], ",", 
    RowBox[{
     RowBox[{"1", "/", "T"}], " ", 
     RowBox[{"NIntegrate", "[", 
      RowBox[{
       RowBox[{"Re", "[", 
        RowBox[{"Exp", "[", 
         RowBox[{"\[ImaginaryI]", 
          RowBox[{"(", 
           RowBox[{
            RowBox[{"psi", "[", 
             RowBox[{"t", ",", "1"}], "]"}], "-", 
            RowBox[{"psi", "[", 
             RowBox[{
              RowBox[{"t", "+", "0.5"}], ",", "1"}], "]"}]}], ")"}]}], "]"}], 
        "]"}], ",", 
       RowBox[{"{", 
        RowBox[{"t", ",", "0", ",", "T"}], "}"}], ",", 
       RowBox[{"Method", "->", "\"\<MultiPeriodic\>\""}]}], "]"}]}]}], "]"}], 
  "//", "Quiet"}]], "Input",
 CellLabel->"In[97]:=",
 CellID->339289702,ExpressionUUID->"0cc0f7d2-6b7b-ae40-832d-53ca4497e4cb"],

Cell[BoxData["0.5036982411388635`"], "Output",
 CellLabel->"Out[97]=",
 CellID->592101515,ExpressionUUID->"7cf5dc4a-948c-9845-8258-1d809d9efc39"]
}, Open  ]],

Cell[TextData[{
 "So ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"|", " ", 
     RowBox[{
      SuperscriptBox["\[Gamma]", 
       RowBox[{"(", "1", ")"}]], "(", "\[Tau]", ")"}], "|"}], "=", 
    RowBox[{"1", "-", 
     RowBox[{"\[Tau]", "/", 
      SubscriptBox["\[Tau]", "0"]}]}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "e6118a29-a548-9249-a011-64a71122b88d"],
 " for ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Tau]", " ", "<", 
    SubscriptBox["\[Tau]", "0"]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "b9080eed-9f0f-5543-ac79-611da5dbf498"],
 ", and zero otherwise. So if the delay is longer than the coherence time of \
the source there is just no coherence at all"
}], "Text",
 CellID->72222704,ExpressionUUID->"f88e28ce-01ed-0942-ba6d-cfe8a0d9cbea"],

Cell[TextData[{
 "Other model is the collision broadened light such that has a Lorentzian \
power spectrum centered at ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Omega]", "0"], TraditionalForm]],ExpressionUUID->
  "66565b5f-618f-2e41-9c4f-60678f78f4f5"],
 ". This case has the following autocorrelation function"
}], "Text",
 CellID->374742155,ExpressionUUID->"adcf6b66-8ca0-c446-a677-ef42c4a68719"],

Cell[BoxData[
 FormBox[
  RowBox[{
   RowBox[{"\[LeftAngleBracket]", 
    RowBox[{
     RowBox[{
      SuperscriptBox["E", "*"], "(", "t", ")"}], 
     RowBox[{"E", "(", 
      RowBox[{"t", "+", "\[Tau]"}], ")"}]}], "\[RightAngleBracket]"}], "=", 
   RowBox[{
    SubsuperscriptBox["E", "0", "2"], 
    SuperscriptBox["e", 
     RowBox[{
      RowBox[{
       RowBox[{"-", "\[ImaginaryI]"}], "\[Omega]", " ", "\[Tau]"}], "-", 
      RowBox[{
       RowBox[{"|", "\[Tau]", "|"}], "/", 
       SubscriptBox["\[Tau]", "0"]}]}]]}]}], 
  TraditionalForm]], "DisplayFormula",
 FontSize->18,
 CellID->80528060,ExpressionUUID->"010bab87-de72-c440-bd4d-86822f06be69"],

Cell["One way to represent this calculation is:", "Text",
 CellID->602015835,ExpressionUUID->"54393150-d316-5b48-8a64-100d06e4c213"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"autocorrelation", "=", 
  RowBox[{
   SuperscriptBox["E0", "2"], " ", 
   RowBox[{"Exp", "[", 
    RowBox[{
     RowBox[{"-", "\[ImaginaryI]"}], " ", "\[Omega]0", " ", "\[Tau]"}], "]"}],
    " ", 
   RowBox[{"Expectation", "[", 
    RowBox[{
     RowBox[{"Exp", "[", 
      RowBox[{"\[ImaginaryI]", " ", "\[Delta]\[Phi]"}], "]"}], ",", 
     RowBox[{"\[Delta]\[Phi]", "\[Distributed]", 
      RowBox[{"NormalDistribution", "[", 
       RowBox[{"0", ",", 
        SqrtBox[
         FractionBox[
          RowBox[{"2", " ", 
           RowBox[{"Abs", "[", "\[Tau]", "]"}]}], "\[Tau]0"]]}], "]"}]}]}], 
    "]"}]}]}]], "Input",
 CellLabel->"In[47]:=",
 CellID->98603167,ExpressionUUID->"ddbe0d9f-e5fb-1b4c-825a-a0cf3d8aab4b"],

Cell[BoxData[
 RowBox[{
  SuperscriptBox["\[ExponentialE]", 
   RowBox[{
    RowBox[{
     RowBox[{"-", "\[ImaginaryI]"}], " ", "\[Tau]", " ", "\[Omega]0"}], "-", 
    FractionBox[
     RowBox[{"Abs", "[", "\[Tau]", "]"}], "\[Tau]0"]}]], " ", 
  SuperscriptBox["E0", "2"]}]], "Output",
 CellLabel->"Out[47]=",
 CellID->52628125,ExpressionUUID->"a7ba9516-df55-2e48-906e-c21a6047beab"]
}, Open  ]],

Cell["\<\
Get the Lorentzian functional form from the Fourier transform:\
\>", "Text",
 CellID->286187595,ExpressionUUID->"c5ae641e-9225-b646-a092-5c91c9fd8414"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"FourierTransform", "[", 
  RowBox[{"autocorrelation", ",", "\[Tau]", ",", "\[Omega]"}], "]"}]], "Input",
 CellLabel->"In[48]:=",
 CellID->134302027,ExpressionUUID->"2ff8d97e-e0b5-9b46-b671-f3d5566e5ece"],

Cell[BoxData[
 FractionBox[
  RowBox[{
   SuperscriptBox["E0", "2"], " ", 
   SqrtBox[
    FractionBox["2", "\[Pi]"]], " ", "\[Tau]0"}], 
  RowBox[{"1", "+", 
   RowBox[{
    SuperscriptBox["\[Tau]0", "2"], " ", 
    SuperscriptBox[
     RowBox[{"(", 
      RowBox[{"\[Omega]", "-", "\[Omega]0"}], ")"}], "2"]}]}]]], "Output",
 CellLabel->"Out[48]=",
 CellID->414824907,ExpressionUUID->"e08b3bb5-ab51-fe45-8878-6a2ad8da49f8"]
}, Open  ]],

Cell[TextData[{
 "From this ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SuperscriptBox["\[Gamma]", 
      RowBox[{"(", "1", ")"}]], "(", "\[Tau]", ")"}], "=", 
    SuperscriptBox["\[ExponentialE]", 
     RowBox[{
      RowBox[{
       RowBox[{"-", "\[ImaginaryI]"}], " ", 
       SubscriptBox["\[Omega]", "0"], "\[Tau]"}], " ", "-", " ", 
      FractionBox[
       RowBox[{"|", "\[Tau]", "|"}], 
       SubscriptBox["\[Tau]", "0"]]}]]}], TraditionalForm]],ExpressionUUID->
  "cfaecb3b-a2c8-954e-92f5-d204301c5372"],
 ", which clearly has magnitude between 0 and 1 as expected, ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"|", 
     RowBox[{
      SuperscriptBox["\[Gamma]", 
       RowBox[{"(", "1", ")"}]], "(", "\[Tau]", ")"}], "|"}], "\[Rule]", 
    RowBox[{
     RowBox[{"0", " ", "when", " ", "\[Tau]"}], "\[Rule]", " ", 
     "\[Infinity]"}]}], TraditionalForm]],ExpressionUUID->
  "97cc1a58-6adc-df4f-92ef-affc0d2a4a64"],
 " which means increasing the time delay reduces the coherence. We can see ",
 Cell[BoxData[
  FormBox[
   RowBox[{"|", "\[Tau]", "|", 
    RowBox[{"<<", 
     SubscriptBox["\[Tau]", "0"]}]}], TraditionalForm]],ExpressionUUID->
  "e78b3e13-008e-1a46-83d3-675f91f884e9"],
 " then ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"|", 
     RowBox[{
      SuperscriptBox["\[Gamma]", 
       RowBox[{"(", "1", ")"}]], "(", "\[Tau]", ")"}], "|"}], "\[Rule]", 
    "1"}], TraditionalForm]],ExpressionUUID->
  "b3382316-521f-f847-9fb3-49e9db04282d"],
 ", also if the average collision time ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Tau]", "0"], TraditionalForm]],ExpressionUUID->
  "c318e348-af92-1d48-9fe3-8312341bdb5f"],
 " is reduced the coherence goes to 0 faster when increasing \[Tau]. "
}], "Text",
 CellID->46614057,ExpressionUUID->"61b7d9ff-be47-ea42-adc1-e612899121d2"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Quantum approach to coherence functions", "Subsection",
 CellID->93478736,ExpressionUUID->"e24cd10b-c971-bc4c-aa42-7a7497e23b06"],

Cell[TextData[{
 "When describing the theory of coherence in quantum optics, the measuring \
device can absorb photons. If we think of the detector as some atom, then the \
atom can be excited by the field from a band of wavelengths. The coupling of \
the atom and the quantized field can be described with the electric dipole \
interaction with Hamiltonian ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["H", 
    RowBox[{"(", "I", ")"}]], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "4a104572-bc9e-0c4c-98f7-5d7710877d1e"],
 "."
}], "Text",
 CellID->29643526,ExpressionUUID->"ec62ad97-c1e6-1b43-ba7a-9c684d95a959"],

Cell[TextData[{
 "In this model the electric field can be written using Heisenberg picture \
and the long-wavelength approximation (\[Lambda] >> ",
 Cell[BoxData[
  FormBox["atom", TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "64f23499-239e-5445-aec7-ef7d160adb64"],
 " size) as"
}], "Text",
 CellID->246387956,ExpressionUUID->"24aef34c-4861-2f4f-a45c-a4fc4ee4ed2e"],

Cell[BoxData[
 FormBox[
  RowBox[{
   StyleBox[
    RowBox[{
     OverscriptBox[
      StyleBox["E", "Bold",
       FontWeight->"Bold"], "^"], "(", 
     RowBox[{
      StyleBox["r", "Bold",
       FontWeight->"Bold"], ",", "t"}], ")"}],
    FontSize->18], "\[TildeTilde]", 
   RowBox[{"\[ImaginaryI]", 
    RowBox[{
     UnderscriptBox["\[Sum]", 
      RowBox[{
       StyleBox["k", "Bold",
        FontWeight->"Bold"], ",", "s"}]], 
     RowBox[{
      SqrtBox[
       FractionBox[
        RowBox[{"\[HBar]", " ", 
         SubscriptBox["\[Omega]", "k"]}], 
        RowBox[{
         StyleBox["2", "CodeText"], " ", 
         SubscriptBox["\[CurlyEpsilon]", "0"], "V"}]]], 
      RowBox[{
       SubscriptBox[
        StyleBox["e", "Bold",
         FontWeight->"Bold"], 
        StyleBox[
         RowBox[{
          StyleBox["k", "Bold",
           FontWeight->"Bold"], "s"}]]], "[", 
       RowBox[{
        RowBox[{
         SubscriptBox[
          OverscriptBox["a", "^"], 
          StyleBox[
           RowBox[{
            StyleBox["k", "Bold",
             FontWeight->"Bold"], "s"}]]], "(", "t", ")"}], "-", 
        RowBox[{
         SubsuperscriptBox[
          OverscriptBox["a", "^"], 
          StyleBox[
           RowBox[{
            StyleBox["k", "Bold",
             FontWeight->"Bold"], "s"}]], "\[Dagger]"], "(", "t", ")"}]}], 
       "]"}]}]}]}]}], TraditionalForm]], "DisplayFormula",
 GeneratedCell->True,
 CellAutoOverwrite->True,
 CellChangeTimes->{3.9859441174155235`*^9, 3.985944176564951*^9},
 CellID->129238133,ExpressionUUID->"3f678131-544a-104c-b8b1-f3109a658f74"],

Cell["\<\
Which has a component describing photon absorption related to the \
annihilation operator, this component is also called the positive frequency \
part\
\>", "Text",
 CellID->448031485,ExpressionUUID->"d12073a9-6568-7e4c-b815-ddd863f90985"],

Cell[BoxData[
 FormBox[
  RowBox[{
   RowBox[{
    SuperscriptBox[
     OverscriptBox[
      StyleBox["E", "Bold",
       FontWeight->"Bold"], "^"], 
     RowBox[{"(", "+", ")"}]], "(", 
    RowBox[{
     StyleBox["r", "Bold",
      FontWeight->"Bold"], ",", "t"}], ")"}], "=", 
   RowBox[{"\[ImaginaryI]", 
    RowBox[{
     UnderscriptBox["\[Sum]", 
      RowBox[{
       StyleBox["k", "Bold",
        FontWeight->"Bold"], ",", "s"}]], 
     RowBox[{
      SuperscriptBox[
       RowBox[{"(", 
        FractionBox[
         RowBox[{"\[HBar]", " ", 
          SubscriptBox["\[Omega]", "k"]}], 
         RowBox[{
          StyleBox["2", "CodeText"], " ", 
          SubscriptBox["\[CurlyEpsilon]", "0"], "V"}]], ")"}], 
       RowBox[{"1", "/", "2"}]], 
      SubscriptBox[
       StyleBox["e", "Bold",
        FontWeight->"Bold"], 
       StyleBox[
        RowBox[{
         StyleBox["k", "Bold",
          FontWeight->"Bold"], "s"}]]], 
      RowBox[{
       SubscriptBox[
        OverscriptBox["a", "^"], 
        StyleBox[
         RowBox[{
          StyleBox["k", "Bold",
           FontWeight->"Bold"], "s"}]]], "(", "t", ")"}]}]}]}]}], 
  TraditionalForm]], "DisplayFormula",
 GeneratedCell->True,
 CellAutoOverwrite->True,
 CellChangeTimes->{3.9859441174155235`*^9, 3.985944176564951*^9},
 CellID->153627307,ExpressionUUID->"d65f84ac-5adb-7d45-8905-60d51a2e6640"],

Cell[TextData[{
 "Assuming the atom is in some initial state ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"|", "g"}], "\[RightAngleBracket]"}], TraditionalForm]],
  ExpressionUUID->"4617b42e-5d55-a749-86e6-4848fab6fdf9"],
 " and transitions to a ionized atomic state",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"|", "e"}], "\[RightAngleBracket]"}], TraditionalForm]],
  ExpressionUUID->"21585f11-6839-f54c-bbca-ac230515b38f"],
 ", and the field transitions to some state ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"|", "i"}], "\[RightAngleBracket]"}], TraditionalForm]],
  ExpressionUUID->"9c67446e-10ff-7f4e-8485-2bb7ad6c7912"],
 " to ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"|", "f"}], "\[RightAngleBracket]"}], TraditionalForm]],
  ExpressionUUID->"d5a9bb3f-5797-2b43-b238-3f7908f18b8c"],
 ". Letting ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{"|", "I"}], "\[RightAngleBracket]"}], " ", "=", 
       RowBox[{"|", "g"}]}], "\[RightAngleBracket]"}], " ", "|", "i"}], 
    "\[RightAngleBracket]"}], TraditionalForm]],ExpressionUUID->
  "69efa624-ba8f-5c43-be50-0bbd6d52c70b"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{"|", "F"}], "\[RightAngleBracket]"}], " ", "=", " ", 
       RowBox[{"|", "e"}]}], "\[RightAngleBracket]"}], " ", "|", "g"}], 
    "\[RightAngleBracket]"}], TraditionalForm]],ExpressionUUID->
  "e8e741bc-70c3-0a4b-8519-d7050e397032"],
 " the transition probability for the full system is ",
 Cell[BoxData[
  FormBox[
   RowBox[{"|", 
    RowBox[{"\[LeftAngleBracket]", 
     RowBox[{"F", "|", 
      SuperscriptBox["H", 
       RowBox[{"(", "I", ")"}]], "|", "I"}], "\[RightAngleBracket]"}], 
    SuperscriptBox["|", "2"]}], TraditionalForm]],ExpressionUUID->
  "3518028f-e603-4342-b8f4-c9739e792fc6"],
 ", and for the field is ",
 Cell[BoxData[
  FormBox[
   RowBox[{"|", 
    RowBox[{"\[LeftAngleBracket]", 
     RowBox[{"f", "|", 
      RowBox[{
       SuperscriptBox["E", 
        RowBox[{"(", "+", ")"}]], "(", 
       RowBox[{
        StyleBox["r",
         FontWeight->"Bold"], ",", "t"}], ")"}], "|", "i"}], 
     "\[RightAngleBracket]"}], 
    SuperscriptBox["|", "2"]}], TraditionalForm]],ExpressionUUID->
  "9e3554aa-5a75-0948-ad93-04146f88954e"],
 ". We only care about the final state of the detector not the field, so we \
have to sum over all the states ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"|", "f"}], "\[RightAngleBracket]"}], TraditionalForm]],
  ExpressionUUID->"cb8765d4-36ce-6544-a23b-530ec98d3aac"],
 " which without loss of generality assume to be complete"
}], "Text",
 CellID->11138904,ExpressionUUID->"517588f3-9bb5-9c4f-b2ab-b343bd7c6186"],

Cell["Performing the sum we get:", "Text",
 CellID->158135442,ExpressionUUID->"e0a4ec5e-2a6c-bc4c-a4ef-8257365a2032"],

Cell[BoxData[
 FormBox[
  RowBox[{"\[LeftAngleBracket]", 
   RowBox[{"i", "|", 
    RowBox[{
     RowBox[{
      SuperscriptBox[
       OverscriptBox[
        StyleBox["E", "Bold",
         FontWeight->"Bold"], "^"], 
       RowBox[{"(", "-", ")"}]], "(", 
      RowBox[{
       StyleBox["r", "Bold",
        FontWeight->"Bold"], ",", "t"}], ")"}], "\[CenterDot]", 
     RowBox[{
      SuperscriptBox[
       OverscriptBox[
        StyleBox["E", "Bold",
         FontWeight->"Bold"], "^"], 
       RowBox[{"(", "+", ")"}]], "(", 
      RowBox[{
       StyleBox["r", "Bold",
        FontWeight->"Bold"], ",", "t"}], ")"}]}], "|", "i"}], 
   "\[RightAngleBracket]"}], TraditionalForm]], "DisplayFormula",
 GeneratedCell->True,
 CellAutoOverwrite->True,
 CellChangeTimes->{3.9859441174155235`*^9, 3.985944176564951*^9},
 CellID->98383331,ExpressionUUID->"dd4d78a6-7c9c-1046-a02f-9013e21371b6"],

Cell[TextData[{
 "Or for mixed states ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Rho]", "F"], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "2eabe1ae-2cef-a84a-ae7f-f2b11caa3aef"],
 ":"
}], "Text",
 CellID->132199762,ExpressionUUID->"4ffb9633-8d61-8146-87b4-890db46b3efa"],

Cell[BoxData[
 FormBox[
  RowBox[{"Tr", 
   RowBox[{"{", 
    RowBox[{
     SubscriptBox[
      OverscriptBox["\[Rho]", "^"], "F"], 
     RowBox[{
      RowBox[{
       SuperscriptBox[
        OverscriptBox[
         StyleBox["E", "Bold",
          FontWeight->"Bold"], "^"], 
        RowBox[{"(", "-", ")"}]], "(", 
       RowBox[{
        StyleBox["r", "Bold",
         FontWeight->"Bold"], ",", "t"}], ")"}], "\[CenterDot]", 
      RowBox[{
       SuperscriptBox[
        OverscriptBox[
         StyleBox["E", "Bold",
          FontWeight->"Bold"], "^"], 
        RowBox[{"(", "+", ")"}]], "(", 
       RowBox[{
        StyleBox["r", "Bold",
         FontWeight->"Bold"], ",", "t"}], ")"}]}]}], "}"}]}], 
  TraditionalForm]], "DisplayFormula",
 GeneratedCell->True,
 CellAutoOverwrite->True,
 CellChangeTimes->{3.9859441174155235`*^9, 3.985944176564951*^9},
 FontSize->18,
 CellID->355498906,ExpressionUUID->"e60969dd-c672-174c-99c8-3a835910f9c1"],

Cell["\<\
Treating the fields as scalars(same polarization) we can define the quantum \
version:  \
\>", "Text",
 CellID->16975560,ExpressionUUID->"6fa67b41-2611-f140-9fa3-0ecdac1e0b02"],

Cell[BoxData[
 FormBox[
  RowBox[{
   RowBox[{
    SuperscriptBox["G", 
     RowBox[{"(", "1", ")"}]], "(", 
    RowBox[{"x", ",", "x"}], ")"}], "=", 
   RowBox[{"Tr", "{", 
    RowBox[{"\[Rho]", " ", 
     SuperscriptBox[
      OverscriptBox["E", "^"], 
      RowBox[{"(", "-", ")"}]], "(", "x", ")", 
     SuperscriptBox[
      OverscriptBox["E", "^"], 
      RowBox[{"(", "+", ")"}]], "(", "x", ")"}], "}"}]}], 
  TraditionalForm]], "DisplayFormula",
 GeneratedCell->True,
 CellAutoOverwrite->True,
 CellChangeTimes->{3.9859441174155235`*^9, 3.985944176564951*^9},
 CellID->572011726,ExpressionUUID->"b7073298-4914-964c-8f2f-3456f3d6314f"],

Cell[TextData[{
 "Referring to the previous diagram of Young\[CloseCurlyQuote]s interference \
we can similarly consider the quantum analog ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SuperscriptBox["E", 
      RowBox[{"(", "+", ")"}]], "(", 
     RowBox[{
      StyleBox["r",
       FontWeight->"Bold"], ",", "t"}], ")"}], "=", 
    RowBox[{
     RowBox[{
      SubscriptBox["K", "1"], 
      RowBox[{
       SuperscriptBox["E", 
        RowBox[{"(", "+", ")"}]], "(", 
       RowBox[{
        SubscriptBox[
         StyleBox["r",
          FontWeight->"Bold"], "1"], ",", 
        SubscriptBox["t", "1"]}], ")"}]}], "+", 
     RowBox[{
      SubscriptBox["K", "2"], 
      RowBox[{
       SuperscriptBox["E", 
        RowBox[{"(", "+", ")"}]], "(", 
       RowBox[{
        SubscriptBox[
         StyleBox["r",
          FontWeight->"Bold"], "2"], ",", 
        SubscriptBox["t", "2"]}], ")"}]}]}]}], TraditionalForm]],
  ExpressionUUID->"346d71eb-e125-cd49-87ee-cfea7b52c268"],
 " using positive frequency operators. So the intensity at the detector is"
}], "Text",
 CellID->458261786,ExpressionUUID->"ff36595c-5074-ba44-a296-27a473054402"],

Cell[BoxData[
 FormBox[
  RowBox[{
   RowBox[{"I", "(", 
    RowBox[{
     StyleBox["r", "Bold"], ",", "t"}], ")"}], "=", 
   RowBox[{
    RowBox[{"Tr", 
     RowBox[{"{", 
      RowBox[{
       OverscriptBox["\[Rho]", "^"], 
       RowBox[{
        SuperscriptBox[
         OverscriptBox["E", "^"], 
         RowBox[{"(", "-", ")"}]], "(", 
        RowBox[{
         StyleBox["r", "Bold",
          FontWeight->"Bold"], ",", "t"}], ")"}], 
       RowBox[{
        SuperscriptBox[
         OverscriptBox["E", "^"], 
         RowBox[{"(", "+", ")"}]], "(", 
        RowBox[{
         StyleBox["r", "Bold",
          FontWeight->"Bold"], ",", "t"}], ")"}]}], "}"}]}], "=", 
    "\[IndentingNewLine]", 
    RowBox[{"|", 
     SubscriptBox["K", "1"], 
     SuperscriptBox["|", "2"], 
     RowBox[{
      RowBox[{
       SuperscriptBox["G", 
        RowBox[{"(", "1", ")"}]], "(", 
       RowBox[{
        SubscriptBox["x", "1"], ",", 
        SubscriptBox["x", "1"]}], ")"}], "+", 
      RowBox[{
       SuperscriptBox[
        RowBox[{"|", 
         SubscriptBox["K", "2"], "|"}], "2"], 
       SuperscriptBox["G", 
        RowBox[{"(", "1", ")"}]], "(", 
       RowBox[{
        SubscriptBox["x", "2"], ",", 
        SubscriptBox["x", "2"]}], ")"}], "+", 
      RowBox[{"2", " ", "Re", "[", 
       RowBox[{
        SuperscriptBox[
         SubscriptBox["K", "1"], "*"], 
        SubscriptBox["K", "2"], 
        SuperscriptBox["G", 
         RowBox[{"(", "1", ")"}]], "(", 
        RowBox[{
         SubscriptBox["x", "1"], ",", 
         SubscriptBox["x", "2"]}], ")"}], "]"}]}]}]}]}], 
  TraditionalForm]], "DisplayFormula",
 CellID->351915792,ExpressionUUID->"252f1354-c858-1c42-bee3-0ac236977b85"],

Cell[TextData[{
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{
       SuperscriptBox["G", 
        RowBox[{"(", "1", ")"}]], "(", 
       RowBox[{
        SubscriptBox["x", "i"], ",", 
        SubscriptBox["x", "i"]}], ")"}], "   ", "i"}], "=", "1"}], ",", "2"}],
    TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "b3802bf3-8738-844a-a60b-2049dcb61bdc"],
 " is the intensity at the detector coming from ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["x", "i"], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "8fd8c9e2-e60e-4445-b096-a91cd01e73ef"],
 ", and the correlation of light arriving from ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["x", "1"], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "a295dbb8-9ef0-624c-b970-59e2ab549b7a"],
 " and ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["x", "2"], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "f5dcae30-c17a-e84f-bb84-8fb0e21fdf16"],
 " is ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox["G", 
     RowBox[{"(", "1", ")"}]], "(", 
    RowBox[{
     SubscriptBox["x", "1"], ",", 
     SubscriptBox["x", "2"]}], ")"}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "1035fd95-6036-f340-bdcd-62e71617c620"],
 " (interference)"
}], "Text",
 CellID->127826847,ExpressionUUID->"cf8d5911-c135-a143-89f9-9afd977f6498"],

Cell[TextData[{
 "Analogously to the classical ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["\[Gamma]", 
    RowBox[{"(", "1", ")"}]], TraditionalForm]],ExpressionUUID->
  "d2e99fb3-62d7-bc46-baa9-5f1080e9e893"],
 ", the normalized first-order coherence function is:"
}], "Text",
 CellID->254482591,ExpressionUUID->"8728f0b2-0d4b-ec47-8488-478342a350eb"],

Cell[BoxData[
 FormBox[
  RowBox[{
   RowBox[{
    SuperscriptBox["g", 
     RowBox[{"(", "1", ")"}]], "(", 
    RowBox[{
     SubscriptBox["x", "1"], ",", 
     SubscriptBox["x", "2"]}], ")"}], "=", 
   FractionBox[
    RowBox[{
     SuperscriptBox["G", 
      RowBox[{"(", "1", ")"}]], "(", 
     RowBox[{
      SubscriptBox["x", "1"], ",", 
      SubscriptBox["x", "2"]}], ")"}], 
    SuperscriptBox[
     RowBox[{"[", 
      RowBox[{
       SuperscriptBox["G", 
        RowBox[{"(", "1", ")"}]], "(", 
       RowBox[{
        SubscriptBox["x", "1"], ",", 
        SubscriptBox["x", "1"]}], ")", 
       SuperscriptBox["G", 
        RowBox[{"(", "1", ")"}]], "(", 
       RowBox[{
        SubscriptBox["x", "2"], ",", 
        SubscriptBox["x", "2"]}], ")"}], "]"}], 
     RowBox[{"1", "/", "2"}]]]}], TraditionalForm]], "DisplayFormula",
 GeneratedCell->True,
 CellAutoOverwrite->True,
 CellChangeTimes->{3.9859441174155235`*^9, 3.985944176564951*^9},
 CellID->71634294,ExpressionUUID->"3bd91761-1c16-3e4d-9a4d-02ec7e39ace3"],

Cell[TextData[{
 "where ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"0", "<="}], "|", 
    SuperscriptBox["g", 
     RowBox[{"(", "1", ")"}]], "|", 
    RowBox[{"<=", "1"}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "361f68e5-e8d4-1e4e-9b16-55b6cddc0e47"],
 " determines if it is coherent, partial coherence or incoherent"
}], "Text",
 CellID->666224448,ExpressionUUID->"5570d8e0-e532-a747-8576-fc57c9343001"],

Cell["Pick a Fock state number:", "Text",
 CellID->72053357,ExpressionUUID->"e3c9dc39-9a0f-3a44-b0c7-676d8e8050b9"],

Cell[BoxData[
 RowBox[{
  RowBox[{"n", "=", " ", 
   RowBox[{"RandomInteger", "[", 
    RowBox[{"{", 
     RowBox[{"1", ",", 
      RowBox[{"$FockSize", "-", "1"}]}], "}"}], "]"}]}], ";"}]], "Input",
 CellLabel->"In[5]:=",
 CellID->247647723,ExpressionUUID->"88d36789-32e0-024b-9eeb-54c39b253837"],

Cell[TextData[{
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SuperscriptBox["G", 
      RowBox[{"(", "1", ")"}]], "(", 
     RowBox[{"x", ",", "x"}], ")"}], "=", "n"}], TraditionalForm]],
  ExpressionUUID->"53574d06-e8c6-3844-9d2e-5e7290915bd9"],
 " for a Fock state:"
}], "Text",
 CellID->748862904,ExpressionUUID->"19189373-e60d-7a4f-a30e-20fc7eb3a8f3"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"G1Correlation", "[", 
   RowBox[{
    RowBox[{"FockState", "[", "n", "]"}], ",", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"r", ",", "t"}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"r", ",", "t"}], "}"}]}], "}"}]}], "]"}], "==", "n"}]], "Input",
 CellLabel->"In[6]:=",
 CellID->261313709,ExpressionUUID->"a4c2be33-3b2d-694a-85b3-2e333d62ce65"],

Cell[BoxData["True"], "Output",
 CellLabel->"Out[6]=",
 CellID->507616,ExpressionUUID->"9c4dc91c-f540-8545-aa5f-79fa6c371345"]
}, Open  ]],

Cell[TextData[{
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox["G", 
     RowBox[{"(", "1", ")"}]], "(", 
    RowBox[{
     SubscriptBox["x", "1"], ",", 
     SubscriptBox["x", "2"]}], ")"}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "46e1845f-630b-6143-a94a-587fabd564f5"],
 " for a Fock state:"
}], "Text",
 CellID->97543443,ExpressionUUID->"645e88ab-1ee7-b345-8c06-43fc8513888b"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"G1Correlation", "[", 
   RowBox[{
    RowBox[{"FockState", "[", "n", "]"}], ",", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"r1", ",", "t1"}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"r2", ",", "t2"}], "}"}]}], "}"}]}], "]"}], "//", 
  "FullSimplify"}]], "Input",
 CellLabel->"In[9]:=",
 CellID->168861056,ExpressionUUID->"f14df542-428b-c642-b899-ec405af49718"],

Cell[BoxData[
 RowBox[{"7", " ", 
  SuperscriptBox["\[ExponentialE]", 
   RowBox[{"\[ImaginaryI]", " ", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"\[FormalOmega]", " ", 
       RowBox[{"(", 
        RowBox[{"t1", "-", "t2"}], ")"}]}], "+", 
      RowBox[{"\[FormalK]", ".", 
       RowBox[{"(", 
        RowBox[{
         RowBox[{"-", "r1"}], "+", "r2"}], ")"}]}]}], ")"}]}]]}]], "Output",
 CellLabel->"Out[9]=",
 CellID->800484549,ExpressionUUID->"b8c30eba-c5a0-d641-ab06-a24270c99410"]
}, Open  ]],

Cell[TextData[{
 "clearly when normalizing we divide by ",
 Cell[BoxData[
  FormBox["n", TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "2d6f106e-7758-7d4e-87d8-9b0e5b22a54f"],
 " , hence |",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     RowBox[{
      SuperscriptBox["g", 
       RowBox[{"(", "1", ")"}]], "(", 
      RowBox[{
       SubscriptBox["x", "1"], ",", 
       SubscriptBox["x", "2"]}], ")"}], "|"}], "=", "1"}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "a6266b0d-1ea3-3543-bd15-1eb0d74472a4"]
}], "Text",
 CellID->312289964,ExpressionUUID->"fbca7c45-f3be-8240-9c83-15963a8eb898"],

Cell["Pick a random complex amplitude:", "Text",
 CellID->101970198,ExpressionUUID->"ab044ca9-b511-6540-bd84-613e67acf1a1"],

Cell[BoxData[
 RowBox[{
  RowBox[{"\[Alpha]", " ", "=", " ", 
   RowBox[{"RandomComplex", "[", "]"}]}], ";"}]], "Input",
 CellLabel->"In[10]:=",
 CellID->289392078,ExpressionUUID->"f93f49fc-16bb-3144-baf7-61934412383e"],

Cell[TextData[{
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SuperscriptBox["G", 
      RowBox[{"(", "1", ")"}]], "(", 
     RowBox[{"x", ",", "x"}], ")"}], "=", 
    RowBox[{"|", "\[Alpha]", 
     SuperscriptBox["|", "2"]}]}], TraditionalForm]],ExpressionUUID->
  "eaeb0612-fb73-a945-8b4e-9de18798eccb"],
 " for a coherent state:"
}], "Text",
 CellID->85741788,ExpressionUUID->"b0c67cc2-622d-4742-93dc-76e7beea8d94"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Chop", "[", 
  RowBox[{
   RowBox[{"G1Correlation", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"CoherentState", "[", "]"}], "[", "\[Alpha]", "]"}], ",", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"r", ",", "t"}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"r", ",", "t"}], "}"}]}], "}"}]}], "]"}], "-", 
   SuperscriptBox[
    RowBox[{"Abs", "[", "\[Alpha]", "]"}], "2"]}], "]"}]], "Input",
 CellLabel->"In[11]:=",
 CellID->251746323,ExpressionUUID->"d833e1e8-c5fc-c84b-929e-ad944be4481e"],

Cell[BoxData["0"], "Output",
 CellLabel->"Out[11]=",
 CellID->747606384,ExpressionUUID->"def9ac59-f5d9-e24e-8336-153eec22091b"]
}, Open  ]],

Cell[TextData[{
 "Calculate ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox["g", 
     RowBox[{"(", "1", ")"}]], "(", 
    RowBox[{
     SubscriptBox["x", "1"], ",", 
     SubscriptBox["x", "2"]}], ")"}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "09d8bccd-5b90-7c47-b55f-0288d95e6878"],
 " for the state |\[Alpha]\[RightAngleBracket]:"
}], "Text",
 CellID->39847487,ExpressionUUID->"437f2d94-0100-8a4f-92aa-d182714a6dd9"],

Cell[BoxData[
 RowBox[{
  RowBox[{"g1Coh", "=", 
   RowBox[{"With", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"s", "=", 
        RowBox[{
         RowBox[{"CoherentState", "[", "]"}], "[", "\[Alpha]", "]"}]}], ",", 
       RowBox[{"pts", "=", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{"r1", ",", "t1"}], "}"}], ",", 
          RowBox[{"{", 
           RowBox[{"r2", ",", "t2"}], "}"}]}], "}"}]}]}], "}"}], ",", 
     RowBox[{
      RowBox[{"G1Correlation", "[", 
       RowBox[{"s", ",", "pts"}], "]"}], "/", 
      RowBox[{"Sqrt", "[", 
       RowBox[{"Times", "@@", 
        RowBox[{"(", 
         RowBox[{
          RowBox[{
           RowBox[{"G1Correlation", "[", 
            RowBox[{"s", ",", 
             RowBox[{"{", 
              RowBox[{"#", ",", "#"}], "}"}]}], "]"}], "&"}], "/@", "pts"}], 
         ")"}]}], "]"}]}]}], "]"}]}], ";"}]], "Input",
 CellLabel->"In[12]:=",
 CellID->21019220,ExpressionUUID->"db070266-7a76-2c41-b87b-2b9068ee8408"],

Cell[TextData[{
 "We see we also get ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"|", 
     RowBox[{
      SuperscriptBox["g", 
       RowBox[{"(", "1", ")"}]], "(", 
      RowBox[{
       SubscriptBox["x", "1"], ",", 
       SubscriptBox["x", "2"]}], ")"}], "|"}], "=", "1"}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "a84f950d-8d0d-d545-9b2e-025b5a2cdef3"],
 ": "
}], "Text",
 CellID->95018641,ExpressionUUID->"5cbfde1b-db30-c94a-ad31-7d01091eee64"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"ComplexExpand", "@", 
  RowBox[{"Abs", "[", "g1Coh", "]"}]}]], "Input",
 CellLabel->"In[13]:=",
 CellID->147893920,ExpressionUUID->"ed5f223e-b3c8-5b47-9512-6818f8b6429e"],

Cell[BoxData[
 RowBox[{"1.`", "\[VeryThinSpace]", "+", 
  RowBox[{"0.`", " ", "\[ImaginaryI]"}]}]], "Output",
 CellLabel->"Out[13]=",
 CellID->133532245,ExpressionUUID->"a0a29cbe-f4d1-9143-88b8-89ad8a4a166a"]
}, Open  ]],

Cell[TextData[{
 "Calculate ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox["g", 
     RowBox[{"(", "1", ")"}]], "(", 
    RowBox[{
     SubscriptBox["x", "1"], ",", 
     SubscriptBox["x", "2"]}], ")"}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "5dbea93a-c2b1-214f-8a0c-0430a8f043bd"],
 " for thermal light with ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    OverscriptBox["n", "\[LongDash]"], "=", "1"}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "43f59b6b-d911-2449-9bff-d965dfb65ebb"],
 " :"
}], "Text",
 CellID->91717223,ExpressionUUID->"cf4f80d9-889e-b848-8a92-6d0272c59430"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"g1Thermal", "=", 
  RowBox[{"With", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{"s", "=", 
       RowBox[{"ThermalState", "[", "1", "]"}]}], ",", 
      RowBox[{"pts", "=", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"r1", ",", "t1"}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"r2", ",", "t2"}], "}"}]}], "}"}]}]}], "}"}], ",", 
    RowBox[{
     RowBox[{"G1Correlation", "[", 
      RowBox[{"s", ",", "pts"}], "]"}], "/", 
     RowBox[{"Sqrt", "[", 
      RowBox[{"Times", "@@", 
       RowBox[{"(", 
        RowBox[{
         RowBox[{
          RowBox[{"G1Correlation", "[", 
           RowBox[{"s", ",", 
            RowBox[{"{", 
             RowBox[{"#", ",", "#"}], "}"}]}], "]"}], "&"}], "/@", "pts"}], 
        ")"}]}], "]"}]}]}], "]"}]}]], "Input",
 CellLabel->"In[14]:=",
 CellID->798828080,ExpressionUUID->"aee32dad-4c56-cf4b-87a1-8fde682a1255"],

Cell[BoxData[
 SuperscriptBox["\[ExponentialE]", 
  RowBox[{
   RowBox[{
    RowBox[{"-", "\[ImaginaryI]"}], " ", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{
       RowBox[{"-", "\[FormalOmega]"}], " ", "t1"}], "+", 
      RowBox[{"\[FormalK]", ".", "r1"}]}], ")"}]}], "+", 
   RowBox[{"\[ImaginaryI]", " ", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{
       RowBox[{"-", "\[FormalOmega]"}], " ", "t2"}], "+", 
      RowBox[{"\[FormalK]", ".", "r2"}]}], ")"}]}]}]]], "Output",
 CellLabel->"Out[14]=",
 CellID->251940493,ExpressionUUID->"bed0b57f-2fa9-4149-bac3-1a1daafee8d5"]
}, Open  ]],

Cell[TextData[{
 "So we see Fock states, coherent states and thermal light are first-order \
coherent\[LineSeparator]which implies the factorization ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SuperscriptBox["G", 
      RowBox[{"(", "1", ")"}]], "(", 
     RowBox[{
      SubscriptBox["x", "1"], ",", 
      SubscriptBox["x", "2"]}], ")"}], "=", 
    RowBox[{
     RowBox[{"\[LeftAngleBracket]", 
      RowBox[{
       RowBox[{
        SuperscriptBox["E", 
         RowBox[{"(", "-", ")"}]], "(", 
        SubscriptBox["x", "1"], ")"}], 
       RowBox[{
        SuperscriptBox["E", 
         RowBox[{"(", "+", ")"}]], "(", 
        SubscriptBox["x", "2"], ")"}]}], "\[RightAngleBracket]"}], " ", "=", 
     RowBox[{
      RowBox[{"\[LeftAngleBracket]", 
       RowBox[{
        SuperscriptBox["E", 
         RowBox[{"(", "-", ")"}]], "(", 
        SubscriptBox["x", "1"], ")"}], "\[RightAngleBracket]"}], 
      RowBox[{"\[LeftAngleBracket]", 
       RowBox[{
        SuperscriptBox["E", 
         RowBox[{"(", "+", ")"}]], "(", 
        SubscriptBox["x", "2"], ")"}], "\[RightAngleBracket]"}]}]}]}], 
   TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "fb224b2f-736e-2c4e-9371-86548eb34da5"]
}], "Text",
 CellID->80525538,ExpressionUUID->"8de05630-b1fd-934a-829d-4a55e8a2cf4c"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Higher-order coherence functions", "Subsection",
 CellID->335018994,ExpressionUUID->"825b685a-f0cc-b342-9d07-82f3cf1d97c0"],

Cell["\<\
We saw for a single-mode field Fock states and coherent states are \
first-order coherent, but that says nothing about their photon statistics, \
for these states that must be different\
\>", "Text",
 CellID->147377513,ExpressionUUID->"aa4ea33d-c438-0646-9098-0cf35c9cffd9"],

Cell["\<\
From a quantum perspective we will see coherent states (such coming from a \
stabilized laser) are second-order coherent and thermal light presents photon \
bunching (a pair of photons coming together)\
\>", "Text",
 CellID->291929164,ExpressionUUID->"0917b4a3-d4f2-874a-8928-43f3db671504"],

