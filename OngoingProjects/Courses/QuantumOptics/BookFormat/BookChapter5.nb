Cell["Defining a time expectation function:", "Text",
 CellID->285435601,ExpressionUUID->"2ef843d4-1f48-4a46-a5dc-c5be4858d268"],

Cell[BoxData[
 RowBox[{
  RowBox[{"TimeExpectation", "[", "f_", "]"}], ":=", 
  RowBox[{"Limit", "[", 
   RowBox[{
    FractionBox[
     RowBox[{"Integrate", "[", 
      RowBox[{"f", ",", 
       RowBox[{"{", 
        RowBox[{"t", ",", "0", ",", "T"}], "}"}]}], "]"}], "T"], ",", 
    RowBox[{"T", "->", "\[Infinity]"}]}], "]"}]}]], "Input",
 CellLabel->"In[48]:=",
 CellID->183318064,ExpressionUUID->"9874784a-9c8e-7146-a9a9-30bd056eb50b"],

Cell[TextData[{
 "For example, for the function ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox[
    RowBox[{"Sin", "(", "t", ")"}], "2"], TraditionalForm]],ExpressionUUID->
  "c4bded48-0b2c-2f46-82d5-6638501254f2"],
 " we get the expected result of 1/2:"
}], "Text",
 CellID->228761041,ExpressionUUID->"e9edd176-c3fd-9b4d-b199-c836250413c8"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"TimeExpectation", "[", 
  SuperscriptBox[
   RowBox[{"Sin", "[", "t", "]"}], "2"], "]"}]], "Input",
 CellLabel->"In[49]:=",
 CellID->141145344,ExpressionUUID->"dc72febb-d804-3148-8600-f3b6b29c6ef3"],

Cell[BoxData[
 FractionBox["1", "2"]], "Output",
 CellLabel->"Out[49]=",
 CellID->616734639,ExpressionUUID->"6ba59b4c-89f9-0f40-8082-9ca325a2a8d9"]
}, Open  ]],

Cell["Or a general cosine function:", "Text",
 CellID->209464171,ExpressionUUID->"7e731f99-d48a-5246-b84a-125eb9acbe30"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Simplify", "[", 
  RowBox[{
   RowBox[{"TimeExpectation", "[", 
    SuperscriptBox[
     RowBox[{"Cos", "[", 
      RowBox[{"t", " ", "m", " ", "x"}], " ", "]"}], "2"], "]"}], ",", 
   RowBox[{"Element", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"m", ",", "x", ",", "a"}], "}"}], ",", "Reals"}], "]"}]}], 
  "]"}]], "Input",
 CellLabel->"In[50]:=",
 CellID->49746599,ExpressionUUID->"75f6c5a7-436c-fd45-8899-3946bad44742"],

Cell[BoxData[
 FractionBox["1", "2"]], "Output",
 CellLabel->"Out[50]=",
 CellID->624835021,ExpressionUUID->"87bfb48c-cf07-1744-b4ee-43101d91eed0"]
}, Open  ]],

