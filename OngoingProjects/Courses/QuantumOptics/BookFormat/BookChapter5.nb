  "TeXAssistantTemplate"]], "Input",
 CellID->716076856,ExpressionUUID->"d4228217-f77e-964b-816a-d21240cb87b7"],

Cell[TextData[{
 "where ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"0", "<="}], "|", 
    SuperscriptBox["g", 
     RowBox[{"(", "1", ")"}]], "|", 
    RowBox[{"<=", "1"}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "361f68e5-e8d4-1e4e-9b16-55b6cddc0e47"],
 " determines if it is coherent, partial coherence or incoherent"
}], "Text",
 CellID->666224448,ExpressionUUID->"5570d8e0-e532-a747-8576-fc57c9343001"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Higher-order coherence functions", "Subsection",
 CellID->335018994,ExpressionUUID->"825b685a-f0cc-b342-9d07-82f3cf1d97c0"],

Cell[TextData[{
 "If the position has a fixed value, ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["g", 
    RowBox[{"(", "2", ")"}]], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "c0eeb4e8-5922-564f-af39-c28075bf1859"],
 " depends only on the time difference \[Tau]"
}], "Text",
