Cell[TextData[{
 "where ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"0", "<="}], "|", 
    SuperscriptBox["g", 
     RowBox[{"(", "1", ")"}]], "|", 
    RowBox[{"<=", "1"}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "361f68e5-e8d4-1e4e-9b16-55b6cddc0e47"],
 " determines if it is coherent, partial coherence or incoherent"
}], "Text",
 CellID->666224448,ExpressionUUID->"5570d8e0-e532-a747-8576-fc57c9343001"],

Cell["Pick a Fock state number:", "Text",
 CellID->72053357,ExpressionUUID->"e3c9dc39-9a0f-3a44-b0c7-676d8e8050b9"],

Cell[BoxData[
 RowBox[{
  RowBox[{"n", "=", " ", 
   RowBox[{"RandomInteger", "[", 
    RowBox[{"{", 
     RowBox[{"1", ",", 
      RowBox[{"$FockSize", "-", "1"}]}], "}"}], "]"}]}], ";"}]], "Input",
 CellLabel->"In[5]:=",
 CellID->247647723,ExpressionUUID->"88d36789-32e0-024b-9eeb-54c39b253837"],

Cell[TextData[{
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SuperscriptBox["G", 
      RowBox[{"(", "1", ")"}]], "(", 
     RowBox[{"x", ",", "x"}], ")"}], "=", "n"}], TraditionalForm]],
  ExpressionUUID->"53574d06-e8c6-3844-9d2e-5e7290915bd9"],
 " for a Fock state:"
}], "Text",
 CellID->748862904,ExpressionUUID->"19189373-e60d-7a4f-a30e-20fc7eb3a8f3"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"G1Correlation", "[", 
   RowBox[{
    RowBox[{"FockState", "[", "n", "]"}], ",", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"r", ",", "t"}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"r", ",", "t"}], "}"}]}], "}"}]}], "]"}], "==", "n"}]], "Input",
 CellLabel->"In[6]:=",
 CellID->261313709,ExpressionUUID->"a4c2be33-3b2d-694a-85b3-2e333d62ce65"],

Cell[BoxData["True"], "Output",
 CellLabel->"Out[6]=",
 CellID->507616,ExpressionUUID->"9c4dc91c-f540-8545-aa5f-79fa6c371345"]
}, Open  ]],

Cell[TextData[{
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox["G", 
     RowBox[{"(", "1", ")"}]], "(", 
    RowBox[{
     SubscriptBox["x", "1"], ",", 
     SubscriptBox["x", "2"]}], ")"}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "46e1845f-630b-6143-a94a-587fabd564f5"],
 " for a Fock state:"
}], "Text",
 CellID->97543443,ExpressionUUID->"645e88ab-1ee7-b345-8c06-43fc8513888b"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"G1Correlation", "[", 
   RowBox[{
    RowBox[{"FockState", "[", "n", "]"}], ",", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"r1", ",", "t1"}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"r2", ",", "t2"}], "}"}]}], "}"}]}], "]"}], "//", 
  "FullSimplify"}]], "Input",
 CellLabel->"In[9]:=",
 CellID->168861056,ExpressionUUID->"f14df542-428b-c642-b899-ec405af49718"],

Cell[BoxData[
 RowBox[{"7", " ", 
  SuperscriptBox["\[ExponentialE]", 
   RowBox[{"\[ImaginaryI]", " ", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"\[FormalOmega]", " ", 
       RowBox[{"(", 
        RowBox[{"t1", "-", "t2"}], ")"}]}], "+", 
      RowBox[{"\[FormalK]", ".", 
       RowBox[{"(", 
        RowBox[{
         RowBox[{"-", "r1"}], "+", "r2"}], ")"}]}]}], ")"}]}]]}]], "Output",
 CellLabel->"Out[9]=",
 CellID->800484549,ExpressionUUID->"b8c30eba-c5a0-d641-ab06-a24270c99410"]
}, Open  ]],

Cell[TextData[{
 "clearly when normalizing we divide by ",
 Cell[BoxData[
  FormBox["n", TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "2d6f106e-7758-7d4e-87d8-9b0e5b22a54f"],
 " , hence |",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     RowBox[{
      SuperscriptBox["g", 
       RowBox[{"(", "1", ")"}]], "(", 
      RowBox[{
       SubscriptBox["x", "1"], ",", 
       SubscriptBox["x", "2"]}], ")"}], "|"}], "=", "1"}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "a6266b0d-1ea3-3543-bd15-1eb0d74472a4"]
}], "Text",
 CellID->312289964,ExpressionUUID->"fbca7c45-f3be-8240-9c83-15963a8eb898"],

Cell["Pick a random complex amplitude:", "Text",
 CellID->101970198,ExpressionUUID->"ab044ca9-b511-6540-bd84-613e67acf1a1"],

Cell[BoxData[
 RowBox[{
  RowBox[{"\[Alpha]", " ", "=", " ", 
   RowBox[{"RandomComplex", "[", "]"}]}], ";"}]], "Input",
 CellLabel->"In[10]:=",
 CellID->289392078,ExpressionUUID->"f93f49fc-16bb-3144-baf7-61934412383e"],

Cell[TextData[{
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SuperscriptBox["G", 
      RowBox[{"(", "1", ")"}]], "(", 
     RowBox[{"x", ",", "x"}], ")"}], "=", 
    RowBox[{"|", "\[Alpha]", 
     SuperscriptBox["|", "2"]}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "eaeb0612-fb73-a945-8b4e-9de18798eccb"],
 " for a coherent state:"
}], "Text",
 CellID->85741788,ExpressionUUID->"b0c67cc2-622d-4742-93dc-76e7beea8d94"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Chop", "[", 
  RowBox[{
   RowBox[{"G1Correlation", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"CoherentState", "[", "]"}], "[", "\[Alpha]", "]"}], ",", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"r", ",", "t"}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"r", ",", "t"}], "}"}]}], "}"}]}], "]"}], "-", 
   SuperscriptBox[
    RowBox[{"Abs", "[", "\[Alpha]", "]"}], "2"]}], "]"}]], "Input",
 CellLabel->"In[11]:=",
 CellID->251746323,ExpressionUUID->"d833e1e8-c5fc-c84b-929e-ad944be4481e"],

Cell[BoxData["0"], "Output",
 CellLabel->"Out[11]=",
 CellID->747606384,ExpressionUUID->"def9ac59-f5d9-e24e-8336-153eec22091b"]
}, Open  ]],

Cell[TextData[{
 "Calculate ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox["g", 
     RowBox[{"(", "1", ")"}]], "(", 
    RowBox[{
     SubscriptBox["x", "1"], ",", 
     SubscriptBox["x", "2"]}], ")"}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "09d8bccd-5b90-7c47-b55f-0288d95e6878"],
 " for the state |\[Alpha]\[RightAngleBracket]:"
}], "Text",
 CellID->39847487,ExpressionUUID->"437f2d94-0100-8a4f-92aa-d182714a6dd9"],

Cell[BoxData[
 RowBox[{
  RowBox[{"g1Coh", "=", 
   RowBox[{"With", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"s", "=", 
        RowBox[{
         RowBox[{"CoherentState", "[", "]"}], "[", "\[Alpha]", "]"}]}], ",", 
       RowBox[{"pts", "=", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{"r1", ",", "t1"}], "}"}], ",", 
          RowBox[{"{", 
           RowBox[{"r2", ",", "t2"}], "}"}]}], "}"}]}]}], "}"}], ",", 
     RowBox[{
      RowBox[{"G1Correlation", "[", 
       RowBox[{"s", ",", "pts"}], "]"}], "/", 
      RowBox[{"Sqrt", "[", 
       RowBox[{"Times", "@@", 
        RowBox[{"(", 
         RowBox[{
          RowBox[{
           RowBox[{"G1Correlation", "[", 
            RowBox[{"s", ",", 
             RowBox[{"{", 
              RowBox[{"#", ",", "#"}], "}"}]}], "]"}], "&"}], "/@", "pts"}], 
         ")"}]}], "]"}]}]}], "]"}]}], ";"}]], "Input",
 CellLabel->"In[12]:=",
 CellID->21019220,ExpressionUUID->"db070266-7a76-2c41-b87b-2b9068ee8408"],

Cell[TextData[{
 "We see we also get ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"|", 
     RowBox[{
      SuperscriptBox["g", 
       RowBox[{"(", "1", ")"}]], "(", 
      RowBox[{
       SubscriptBox["x", "1"], ",", 
       SubscriptBox["x", "2"]}], ")"}], "|"}], "=", "1"}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "a84f950d-8d0d-d545-9b2e-025b5a2cdef3"],
 ": "
}], "Text",
 CellID->95018641,ExpressionUUID->"5cbfde1b-db30-c94a-ad31-7d01091eee64"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"ComplexExpand", "@", 
  RowBox[{"Abs", "[", "g1Coh", "]"}]}]], "Input",
 CellLabel->"In[13]:=",
 CellID->147893920,ExpressionUUID->"ed5f223e-b3c8-5b47-9512-6818f8b6429e"],

Cell[BoxData[
 RowBox[{"1.`", "\[VeryThinSpace]", "+", 
  RowBox[{"0.`", " ", "\[ImaginaryI]"}]}]], "Output",
 CellLabel->"Out[13]=",
 CellID->133532245,ExpressionUUID->"a0a29cbe-f4d1-9143-88b8-89ad8a4a166a"]
}, Open  ]],

Cell[TextData[{
 "Calculate ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox["g", 
     RowBox[{"(", "1", ")"}]], "(", 
    RowBox[{
     SubscriptBox["x", "1"], ",", 
     SubscriptBox["x", "2"]}], ")"}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "5dbea93a-c2b1-214f-8a0c-0430a8f043bd"],
 " for thermal light with ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    OverscriptBox["n", "\[LongDash]"], "=", "1"}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "43f59b6b-d911-2449-9bff-d965dfb65ebb"],
 " :"
}], "Text",
 CellID->91717223,ExpressionUUID->"cf4f80d9-889e-b848-8a92-6d0272c59430"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"g1Thermal", "=", 
  RowBox[{"With", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{"s", "=", 
       RowBox[{"ThermalState", "[", "1", "]"}]}], ",", 
      RowBox[{"pts", "=", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"r1", ",", "t1"}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"r2", ",", "t2"}], "}"}]}], "}"}]}]}], "}"}], ",", 
    RowBox[{
     RowBox[{"G1Correlation", "[", 
      RowBox[{"s", ",", "pts"}], "]"}], "/", 
     RowBox[{"Sqrt", "[", 
      RowBox[{"Times", "@@", 
       RowBox[{"(", 
        RowBox[{
         RowBox[{
          RowBox[{"G1Correlation", "[", 
           RowBox[{"s", ",", 
            RowBox[{"{", 
             RowBox[{"#", ",", "#"}], "}"}]}], "]"}], "&"}], "/@", "pts"}], 
        ")"}]}], "]"}]}]}], "]"}]}]], "Input",
 CellLabel->"In[14]:=",
 CellID->798828080,ExpressionUUID->"aee32dad-4c56-cf4b-87a1-8fde682a1255"],

Cell[BoxData[
 SuperscriptBox["\[ExponentialE]", 
  RowBox[{
   RowBox[{
    RowBox[{"-", "\[ImaginaryI]"}], " ", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{
       RowBox[{"-", "\[FormalOmega]"}], " ", "t1"}], "+", 
      RowBox[{"\[FormalK]", ".", "r1"}]}], ")"}]}], "+", 
   RowBox[{"\[ImaginaryI]", " ", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{
       RowBox[{"-", "\[FormalOmega]"}], " ", "t2"}], "+", 
      RowBox[{"\[FormalK]", ".", "r2"}]}], ")"}]}]}]]], "Output",
 CellLabel->"Out[14]=",
 CellID->251940493,ExpressionUUID->"bed0b57f-2fa9-4149-bac3-1a1daafee8d5"]
}, Open  ]],

Cell[TextData[{
 "So we see Fock states, coherent states and thermal light are first-order \
coherent\[LineSeparator]which implies the factorization ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SuperscriptBox["G", 
      RowBox[{"(", "1", ")"}]], "(", 
     RowBox[{
      SubscriptBox["x", "1"], ",", 
      SubscriptBox["x", "2"]}], ")"}], "=", 
    RowBox[{
     RowBox[{"\[LeftAngleBracket]", 
      RowBox[{
       RowBox[{
        SuperscriptBox["E", 
         RowBox[{"(", "-", ")"}]], "(", 
        SubscriptBox["x", "1"], ")"}], 
       RowBox[{
        SuperscriptBox["E", 
         RowBox[{"(", "+", ")"}]], "(", 
        SubscriptBox["x", "2"], ")"}]}], "\[RightAngleBracket]"}], " ", "=", 
     RowBox[{
      RowBox[{"\[LeftAngleBracket]", 
       RowBox[{
        SuperscriptBox["E", 
         RowBox[{"(", "-", ")"}]], "(", 
        SubscriptBox["x", "1"], ")"}], "\[RightAngleBracket]"}], 
      RowBox[{"\[LeftAngleBracket]", 
       RowBox[{
        SuperscriptBox["E", 
         RowBox[{"(", "+", ")"}]], "(", 
        SubscriptBox["x", "2"], ")"}], "\[RightAngleBracket]"}]}]}]}], 
   TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "fb224b2f-736e-2c4e-9371-86548eb34da5"]
}], "Text",
 CellID->80525538,ExpressionUUID->"8de05630-b1fd-934a-829d-4a55e8a2cf4c"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Higher-order coherence functions", "Subsection",
 CellID->335018994,ExpressionUUID->"825b685a-f0cc-b342-9d07-82f3cf1d97c0"],

Cell["\<\
We saw for a single-mode field Fock states and coherent states are \
first-order coherent, but that says nothing about their photon statistics, \
for these states that must be different\
\>", "Text",
 CellID->147377513,ExpressionUUID->"aa4ea33d-c438-0646-9098-0cf35c9cffd9"],

Cell["\<\
From a quantum perspective we will see coherent states (such coming from a \
stabilized laser) are second-order coherent and thermal light presents photon \
bunching (a pair of photons coming together)\
\>", "Text",
 CellID->291929164,ExpressionUUID->"0917b4a3-d4f2-874a-8928-43f3db671504"],

