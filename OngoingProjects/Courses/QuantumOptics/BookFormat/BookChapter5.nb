Cell["So we can analyze the following electric field:", "Text",
 CellID->56047184,ExpressionUUID->"d7f05178-d858-e645-99d9-6467aea9e841"],

Cell[BoxData[
 FormBox[
  RowBox[{
   StyleBox[
    RowBox[{"E", "(", 
     RowBox[{"z", ",", "t"}], ")"}],
    FontSize->18], "=", 
   RowBox[{
    SubscriptBox["E", "0"], 
    SuperscriptBox["e", 
     RowBox[{"\[ImaginaryI]", "(", 
      RowBox[{
       RowBox[{"k", " ", "z"}], "-", 
       RowBox[{"\[Omega]", " ", "t"}]}], ")"}]], 
    SuperscriptBox["e", 
     RowBox[{"\[ImaginaryI]", " ", "\[Psi]", "(", "t", ")"}]]}]}], 
  TraditionalForm]], "DisplayFormula",
 GeneratedCell->True,
 CellAutoOverwrite->True,
 CellChangeTimes->{3.9859441173992004`*^9, 3.985944176564951*^9},
 CellID->23853073,ExpressionUUID->"9cbb8637-2f8c-a842-929b-3f48b0e134c6"],

Cell[TextData[{
 "Then ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["\[Gamma]", 
    RowBox[{"(", "1", ")"}]], TraditionalForm]],ExpressionUUID->
  "ea945edd-74c4-cd47-8899-861c7c6aaaf8"],
 " takes the form:"
}], "Text",
 CellID->146614662,ExpressionUUID->"9b7aa4e2-aebb-1d43-bd72-e870e39763ff"],

Cell[BoxData[
 FormBox[
  RowBox[{
   RowBox[{
    SuperscriptBox["\[Gamma]", 
     RowBox[{"(", "1", ")"}]], "(", "\[Tau]", ")"}], "=", 
   RowBox[{
    SuperscriptBox["e", 
     RowBox[{
      RowBox[{"-", "\[ImaginaryI]"}], "\[Omega]", " ", "\[Tau]"}]], 
    FractionBox["1", "T"], 
    UnderscriptBox["lim", 
     RowBox[{"T", "\[RightArrow]", "\[Infinity]"}]], 
    SubsuperscriptBox["\[Integral]", "0", 
     RowBox[{" ", "T"}]], 
    SuperscriptBox["e", 
     RowBox[{"\[ImaginaryI]", "[", 
      RowBox[{
       RowBox[{"\[Psi]", "(", 
        RowBox[{"t", "+", "\[Tau]"}], ")"}], "-", 
       RowBox[{"\[Psi]", "(", "t", ")"}]}], "]"}]], 
    RowBox[{"\[DifferentialD]", "t"}]}]}], TraditionalForm]], "DisplayFormula",
 CellID->202556013,ExpressionUUID->"52aa29c0-60cf-b74e-af08-d7cab3bd693f"],

Cell[TextData[{
 "We can plot the real part of the integrand(without diving by ",
 Cell[BoxData[
  FormBox["T", TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "e5e9ab17-e199-2445-95b1-3a9711ed70da"],
 ") varying the relation between ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Tau]", "0"], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "662b0be7-fda0-394c-828c-cda1868da769"],
 " and \[Tau] to gain some intuition of the result. When \[Tau] approaches 0 \
the integrand is 1, and when ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Tau]", "->", 
    SubscriptBox["\[Tau]", "0"]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "650d7242-1593-724e-b0d7-35ab071aaed6"],
 " looks uniformly random from -1 to 1 so the integral in the limit of ",
 Cell[BoxData[
  FormBox[
   RowBox[{"T", "\[Rule]", " ", "\[Infinity]"}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "616d6177-39d7-d14e-bce5-19569f80cc9a"],
 " should be 0 "
}], "Text",
 CellID->138368958,ExpressionUUID->"0a6fdc92-318e-9648-b32b-64c48df44958"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Grid", "@", 
  RowBox[{"Partition", "[", 
   RowBox[{
    RowBox[{"Table", "[", 
     RowBox[{
      RowBox[{"Plot", "[", 
       RowBox[{
        RowBox[{"Re", "[", 
         SuperscriptBox["\[ExponentialE]", 
          RowBox[{"\[ImaginaryI]", 
           RowBox[{"(", 
            RowBox[{
             RowBox[{"psi", "[", 
              RowBox[{"t", ",", "1"}], "]"}], "-", 
             RowBox[{"psi", "[", 
              RowBox[{
               RowBox[{"t", "+", 
                RowBox[{"i", " ", "0.1"}]}], ",", "1"}], "]"}]}], ")"}]}]], 
         "]"}], ",", 
        RowBox[{"{", 
         RowBox[{"t", ",", "0", ",", "10000"}], "}"}], ",", 
        RowBox[{"PlotRange", "->", "All"}], ",", 
        RowBox[{"PlotStyle", "->", "Thin"}], ",", 
        RowBox[{"PlotLabel", "->", 
         RowBox[{
          RowBox[{
          "StringTemplate", 
           "[", "\"\<\!\(\*SubscriptBox[\(\[Tau]\), \(0\)]\) = ``, \[Tau] = \
``\>\"", "]"}], "[", 
          RowBox[{"1.", ",", 
           RowBox[{"0.1", " ", "i"}]}], "]"}]}]}], "]"}], ",", 
      RowBox[{"{", 
       RowBox[{"i", ",", "10"}], "}"}]}], "]"}], ",", 
    RowBox[{"{", "2", "}"}]}], "]"}]}]], "Input",
 CellLabel->"In[73]:=",
 CellID->113067017,ExpressionUUID->"7aa58031-66f3-f04b-963c-9c3d2ddc4744"],

