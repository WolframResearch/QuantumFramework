t_1)|^2 \\rangle  + |K_2|^2 \\langle |E(\\mathbf{r}_2, t_2)|^2 \\rangle \\\\\n\
& + 2 \\operatorname{Re} \\bigl[ K_1^* K_2 \\langle E^*(\\mathbf{r}_1, t_1) \
E(\\mathbf{r}_2, t_2) \\rangle \\bigr]\n\\end{aligned}", "state" -> "Boxes"|>,
  "TeXAssistantTemplate"]], "Input",
 CellID->930215168,ExpressionUUID->"d4be4df5-3966-8d43-a457-258b65220e91"],

Cell[TextData[{
 "the first two terms are related to intensities from each slit ",
 Cell[BoxData[
  FormBox[
   RowBox[{"(", 
    SubscriptBox["I", "1"]}], TraditionalForm]],ExpressionUUID->
  "c2a79b34-b8d4-1c40-b96e-1dfe1ec37570"],
 ", ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["I", "2"], TraditionalForm]],ExpressionUUID->
  "51e30d32-ce87-a749-956c-8e953bd415af"],
 "), and the last term is the interference term"
}], "Text",
 CellID->49057967,ExpressionUUID->"fb322757-8c41-dc4b-a91e-cd795317e409"],

Cell[TextData[{
 "Let ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox["x", "i"], "=", 
     SubscriptBox[
      StyleBox["r",
       FontWeight->"Bold"], "i"]}], ",", 
    SubscriptBox["t", "i"]}], TraditionalForm]],ExpressionUUID->
  "af73ddff-fabf-7f4e-980f-129864df5655"],
 ", the first order normalized coherence function can be defined as:"
}], "Text",
 CellID->197735460,ExpressionUUID->"7ff8e18f-ef68-5644-a0e6-cd0f7b5594bc"],

