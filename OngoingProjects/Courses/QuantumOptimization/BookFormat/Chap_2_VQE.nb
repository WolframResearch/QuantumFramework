Cell[CellGroupData[{

Cell["Gradient Vector Plot", "Subsubsection",
 CellChangeTimes->{{3.939737852437577*^9, 3.9397378546819735`*^9}, {
  3.93973791555846*^9, 3.9397379179018445`*^9}},
 CellID->439156400,ExpressionUUID->"78e15504-06bd-2341-b98e-719f89cb0621"],

Cell["\<\
The gradient flow shows how the optimizer finds the minimum. Flow lines \
converge toward optimal parameters, with the periodic landscape creating \
multiple equivalent minima\[LongDash]a generic feature of parametrized quantum \
circuits:\
\>", "Text",
 CellChangeTimes->{{3.9397379359023952`*^9, 3.939738004479134*^9}},
 CellID->269478319,ExpressionUUID->"ec85ba0e-c354-1741-b982-8f9e0e51ea80"],

Cell[BoxData[
 RowBox[{"StreamPlot", "[", 
  RowBox[{
   RowBox[{"Evaluate", "[", 
    RowBox[{"-", 
     RowBox[{"Grad", "[", 
      RowBox[{
       RowBox[{"\[ScriptCapitalL]", "[", 
        RowBox[{"\[Theta]1", ",", " ", "\[Theta]2"}], "]"}], ",", " ", 
       RowBox[{"{", 
        RowBox[{"\[Theta]1", ",", " ", "\[Theta]2"}], "}"}]}], "]"}]}], "]"}],
    ",", 
   InterpretationBox[
    DynamicModuleBox[{Typeset`open = False}, 
     TemplateBox[{"Expression", "SequenceIcon", 
