Cell[BoxData[
 RowBox[{
  RowBox[{"fib", "[", "n_", "]"}], ":=", 
  RowBox[{"If", "[", 
   RowBox[{
    RowBox[{
     RowBox[{"!", 
      RowBox[{"IntegerQ", "[", "n", "]"}]}], "||", 
     RowBox[{"n", "<", "1"}]}], ",", "\"\<Error\>\"", ",", 
    RowBox[{"If", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"n", "\[Equal]", "1"}], "||", 
       RowBox[{"n", "\[Equal]", "2"}]}], ",", "1", ",", 
      RowBox[{
       RowBox[{"fib", "[", 
        RowBox[{"n", "-", "1"}], "]"}], "+", 
       RowBox[{"fib", "[", 
        RowBox[{"n", "-", "2"}], "]"}]}]}], "]"}]}], "]"}]}]], "Input",
 CellLabel->"In[66]:=",ExpressionUUID->"f78c011b-3cd8-1e40-bd96-ed0695fe2567"]
}, Open  ]],

