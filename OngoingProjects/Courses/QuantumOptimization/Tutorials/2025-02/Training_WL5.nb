Cell[TextData[{
 "\[OpenCurlyDoubleQuote]There\[CloseCurlyQuote]s a function ",
 ButtonBox["DigitCount",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://reference.wolfram.com/language/ref/DigitCount.html"], None},
  ButtonNote->"https://reference.wolfram.com/language/ref/DigitCount.html"],
 " that counts the number of times different digits occur in an integer. \
Worse names for this function might be ",
 Cell[BoxData[
 "TotalDigits"], "InlineCode",ExpressionUUID->
  "5996ce5c-9f8f-0049-995e-696f8cd63692"],
 " (confusing with ",
 ButtonBox["IntegerLength",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://reference.wolfram.com/language/ref/IntegerLength.html"], 
    None},
  ButtonNote->"https://reference.wolfram.com/language/ref/IntegerLength.html"],
 "), ",
 Cell[BoxData[
 "IntegerTotals"], "InlineCode",ExpressionUUID->
  "1070659c-679e-a049-99aa-cd8224518a2e"],
 " (might be about adding up the integer somehow), ",
 Cell[BoxData[
 "PopulationCount"], "InlineCode",ExpressionUUID->
  "a7d7adac-f5c1-f74f-aa11-b1bc6a3d624a"],
 " (weird and whimsical), etc. \[OpenCurlyDoubleQuote]"
}], "Text",
 CellChangeTimes->{{3.9798163490134144`*^9, 
  3.979816380454914*^9}},ExpressionUUID->"bca8a4c8-6e64-3344-a73c-\
63bd309e488d"],

