Cell[BoxData[
 RowBox[{
  RowBox[{"Hchirped", " ", "=", 
   RowBox[{"QuantumOperator", "[", 
    RowBox[{
     RowBox[{
      FractionBox["1", "2"], "\[CapitalOmega]0", " ", 
      SuperscriptBox["\[ExponentialE]", 
       RowBox[{
        RowBox[{"-", 
         SuperscriptBox[
          RowBox[{"(", "t", ")"}], "2"]}], " ", "/", " ", 
        SuperscriptBox["\[Tau]", "2"]}]], 
      RowBox[{"(", 
       RowBox[{
        RowBox[{
         RowBox[{"Cos", "[", 
          RowBox[{"\[Kappa]", " ", 
           SuperscriptBox["t", "2"]}], "]"}], 
         RowBox[{"QuantumOperator", "[", "\"\<X\>\"", "]"}]}], "+", 
        RowBox[{
         RowBox[{"Sin", "[", 
          RowBox[{"\[Kappa]", " ", 
           SuperscriptBox["t", "2"]}], "]"}], 
         RowBox[{"QuantumOperator", "[", "\"\<Y\>\"", "]"}]}]}], ")"}]}], ",", 
     RowBox[{"\"\<Parameters\>\"", "->", 
      RowBox[{"{", 
       RowBox[{"\[CapitalOmega]0", ",", "\[Tau]", ",", "\[Kappa]"}], 
       "}"}]}]}], "]"}]}], ";"}]], "Input",
 CellChangeTimes->{{3.980612964222269*^9, 3.9806129785828953`*^9}, {
