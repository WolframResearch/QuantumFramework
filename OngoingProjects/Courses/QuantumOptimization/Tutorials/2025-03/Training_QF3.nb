  RowBox[{"{", 
   RowBox[{
    RowBox[{
     SqrtBox["_"], "->", "\[Lambda]"}], ",", 
    RowBox[{
     RowBox[{"1", "/", 
      SqrtBox["_"]}], "->", 
     RowBox[{"1", "/", " ", "\[Lambda]"}]}]}], "}"}]}]], "Input",
