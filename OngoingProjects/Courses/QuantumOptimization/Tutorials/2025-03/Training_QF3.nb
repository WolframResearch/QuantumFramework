        RowBox[{"t", " ", "\[Lambda]"}], "2"], "]"}], "+", 
      FractionBox[
       RowBox[{"\[ImaginaryI]", " ", 
        RowBox[{"Sinh", "[", 
         FractionBox[
          RowBox[{"t", " ", "\[Lambda]"}], "2"], "]"}], " ", 
        RowBox[{"(", 
         RowBox[{"\[Omega]", "-", 
          SubscriptBox["\[Omega]", "1"]}], ")"}]}], "\[Lambda]"]}], ")"}]}], ",", 
   RowBox[{
    SuperscriptBox["\[ExponentialE]", 
     FractionBox[
      RowBox[{"\[ImaginaryI]", " ", "t", " ", "\[Omega]"}], "2"]], " ", 
    RowBox[{"Sin", "[", 
     FractionBox["\[Alpha]", "2"], "]"}], " ", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"Cosh", "[", 
       FractionBox[
        RowBox[{"t", " ", "\[Lambda]"}], "2"], "]"}], "-", 
      FractionBox[
       RowBox[{"\[ImaginaryI]", " ", 
        RowBox[{"Sinh", "[", 
         FractionBox[
          RowBox[{"t", " ", "\[Lambda]"}], "2"], "]"}], " ", 
        RowBox[{"(", 
         RowBox[{"\[Omega]", "+", 
          SubscriptBox["\[Omega]", "1"]}], ")"}]}], "\[Lambda]"]}], ")"}]}]}],
   "}"}]], "Output",
