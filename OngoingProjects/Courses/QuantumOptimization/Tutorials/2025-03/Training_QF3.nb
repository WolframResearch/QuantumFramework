Cell[CellGroupData[{

Cell[TextData[StyleBox["Decoherencia de un qubit",
 IgnoreSpellCheck->True]], "Subsection",
 CellChangeTimes->{{3.9806177614270134`*^9, 3.9806177636839943`*^9}, {
  3.98061781383593*^9, 
  3.9806178157344265`*^9}},ExpressionUUID->"b8bef6fb-c96b-454f-851b-\
6cbe3a1cafc4"],

Cell[BoxData[
 RowBox[{
  RowBox[{"\[CapitalOmega]", "=", "50"}], ";", 
  RowBox[{"\[Gamma]", "=", "1"}], ";", 
  RowBox[{"n", "=", "3"}], ";"}]], "Input",
 CellLabel->
  "In[120]:=",ExpressionUUID->"edff08d4-b922-4346-89c7-156d89411278"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"\[Rho]0", "=", 
  RowBox[{"QuantumState", "[", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"Cos", "[", 
      RowBox[{"\[Pi]", "/", "8"}], "]"}], ",", 
     RowBox[{
      RowBox[{"Exp", "[", 
       RowBox[{"\[ImaginaryI]", " ", 
        RowBox[{"\[Pi]", "/", "4"}]}], "]"}], 
      RowBox[{"Sin", "[", 
       RowBox[{"\[Pi]", "/", "8"}], "]"}]}]}], "}"}], "]"}]}]], "Input",
 CellLabel->
  "In[121]:=",ExpressionUUID->"86b0af35-cd97-4140-9038-67a0c43ffe32"],

Cell[BoxData[
 FormBox[
  InterpretationBox[
   TooltipBox[
    StyleBox[
     RowBox[{
      RowBox[{
       RowBox[{"cos", "(", 
        FractionBox["\[Pi]", "8"], ")"}], 
       FormBox[
        InterpretationBox[
         StyleBox[
          TemplateBox[{
            RowBox[{
              FormBox["0", TraditionalForm]}]},
           "Ket"],
          FontWeight->"Plain"],
         Wolfram`QuantumFramework`QuditName[0, "Dual" -> False]],
        TraditionalForm]}], "+", 
      RowBox[{
       RowBox[{
        SuperscriptBox["\[ExponentialE]", 
         FractionBox[
          RowBox[{"\[ImaginaryI]", " ", "\[Pi]"}], "4"]], " ", 
        RowBox[{"sin", "(", 
         FractionBox["\[Pi]", "8"], ")"}]}], 
       FormBox[
        InterpretationBox[
         StyleBox[
          TemplateBox[{
            RowBox[{
              FormBox["1", TraditionalForm]}]},
           "Ket"],
          FontWeight->"Plain"],
