Cell[CellGroupData[{

Cell[TextData[StyleBox["Define un Hamiltoniano dependiente del tiempo y un \
estado inicial",
 IgnoreSpellCheck->True]], "Item",
 CellChangeTimes->{{3.9806146175359*^9, 3.980614652109787*^9}, {
  3.980614685633703*^9, 3.9806147247346478`*^9}, {3.9806166005947247`*^9, 
