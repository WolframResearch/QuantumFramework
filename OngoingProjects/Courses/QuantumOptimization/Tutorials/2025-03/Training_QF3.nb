ef9ebea24755"],

Cell[BoxData[
 RowBox[{
  RowBox[{"h", "=", 
   RowBox[{
    RowBox[{
     FractionBox[
      SubscriptBox["\[Omega]", "1"], "2"], 
     RowBox[{"Cos", "[", "\[Alpha]", "]"}], 
     RowBox[{"QuantumOperator", "[", "\"\<Z\>\"", "]"}]}], "+", 
    RowBox[{
     FractionBox[
      SubscriptBox["\[Omega]", "1"], "2"], 
     RowBox[{"Sin", "[", "\[Alpha]", "]"}], 
     RowBox[{"(", 
      RowBox[{
       RowBox[{
        RowBox[{"Cos", "[", 
         RowBox[{"\[Omega]", " ", "t"}], "]"}], 
        RowBox[{"QuantumOperator", "[", "\"\<X\>\"", "]"}]}], "+", 
       RowBox[{
        RowBox[{"Sin", "[", 
         RowBox[{"\[Omega]", " ", "t"}], "]"}], 
        RowBox[{"QuantumOperator", "[", "\"\<Y\>\"", "]"}]}]}], ")"}]}]}]}], 
  ";"}]], "Input",
 CellChangeTimes->{3.9806164207936096`*^9},
 CellLabel->"In[8]:=",ExpressionUUID->"29d7dc24-3d1d-8c44-809f-3d62d0dc9ddb"],

Cell[BoxData[
 RowBox[{
  RowBox[{"\[Psi]i", "=", 
   RowBox[{"QuantumState", "[", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"Cos", "[", 
       RowBox[{"\[Alpha]", "/", "2"}], "]"}], ",", 
      RowBox[{"Sin", "[", 
       RowBox[{"\[Alpha]", "/", "2"}], "]"}]}], "}"}], "]"}]}], 
  ";"}]], "Input",
