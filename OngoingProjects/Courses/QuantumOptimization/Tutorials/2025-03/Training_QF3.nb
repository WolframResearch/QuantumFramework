Cell[CellGroupData[{

Cell[TextData[{
 StyleBox["Evoluci\[OAcute]n",
  IgnoreSpellCheck->True],
 " de ",
 StyleBox["las",
  IgnoreSpellCheck->True],
 " ",
 StyleBox["componentes",
  IgnoreSpellCheck->True],
 " del vector de Bloch"
}], "Subsection",
 CellChangeTimes->{{3.9806162307899323`*^9, 
  3.9806162409444847`*^9}},ExpressionUUID->"65e02667-cd5b-0245-b29a-\
657851cebd1a"],

Cell[BoxData[
 RowBox[{
  RowBox[{"hamiltonian", "=", 
   RowBox[{
    RowBox[{"\[Omega]0", " ", 
     RowBox[{"QuantumOperator", "[", "\"\<JZ\>\"", "]"}]}], "+", " ", 
    RowBox[{"2", "\[Omega]p", " ", 
     RowBox[{"Cos", "[", 
      RowBox[{"\[Omega]0", " ", "t"}], "]"}], 
     RowBox[{"QuantumOperator", "[", "\"\<JX\>\"", "]"}]}]}]}], 
  ";"}]], "Input",
 CellProlog:>Needs["Wolfram`QuantumFramework`"],
 CellChangeTimes->{3.9806161635746746`*^9, 3.980616261136385*^9},
 CellLabel->"In[23]:=",
 CellID->432120951,ExpressionUUID->"14a2cda6-b2f0-9449-a9f7-aa0dc37cc986"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"\[Omega]0", "=", 
   RowBox[{"2", "\[Pi]"}]}], " ", ";", 
  RowBox[{"\[Omega]p", "=", 
   RowBox[{"\[Pi]", "/", "10"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"tf", "=", 
   RowBox[{"2", 
    RowBox[{"\[Pi]", "/", "\[Omega]p"}]}]}], ";"}]}], "Input",
 CellLabel->"In[24]:=",ExpressionUUID->"e82b454a-95b9-a94f-8cf1-344bdbf98189"],

Cell[BoxData[
 RowBox[{
  RowBox[{"r1", "=", 
   RowBox[{"QuantumEvolve", "[", 
    RowBox[{"hamiltonian", ",", 
     RowBox[{"{", 
      RowBox[{"t", ",", "0", ",", "tf"}], "}"}]}], "]"}]}], ";"}]], "Input",
 CellLabel->"In[26]:=",ExpressionUUID->"c5f3c146-6fa4-fc4b-a16c-c3875b242ee4"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Plot", "[", 
  RowBox[{
   RowBox[{"Evaluate", "@", 
    RowBox[{"Re", "@", 
     RowBox[{
      RowBox[{"r1", "[", "t", "]"}], "[", "\"\<BlochVector\>\"", "]"}]}]}], ",", 
   RowBox[{"{", 
    RowBox[{"t", ",", "0", ",", "tf"}], "}"}], ",", 
   RowBox[{"PlotRange", "->", "All"}], ",", 
   RowBox[{"PlotLegends", "->", 
    RowBox[{"{", 
     RowBox[{"\"\<\!\(\*SubscriptBox[\(r\), \(x\)]\)\>\"", 
      ",", "\"\<\!\(\*SubscriptBox[\(r\), \(y\)]\)\>\"", 
      ",", "\"\<\!\(\*SubscriptBox[\(r\), \(z\)]\)\>\""}], "}"}]}]}], 
  "]"}]], "Input",
 CellLabel->"In[27]:=",ExpressionUUID->"8a63f4cc-4f13-a94b-ab74-6e0a537259d2"],

