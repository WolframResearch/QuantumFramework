Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{
    SuperscriptBox["\[ExponentialE]", 
     RowBox[{
      RowBox[{"-", 
       FractionBox["1", "2"]}], " ", "\[ImaginaryI]", " ", "t", " ", 
      "\[Omega]"}]], " ", 
    RowBox[{"Cos", "[", 
     FractionBox["\[Alpha]", "2"], "]"}], " ", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"Cosh", "[", 
