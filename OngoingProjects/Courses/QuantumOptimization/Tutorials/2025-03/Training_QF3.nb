       RowBox[{
        RowBox[{"Cos", "[", 
         RowBox[{"\[Omega]", " ", "t"}], "]"}], 
        RowBox[{"QuantumOperator", "[", "\"\<X\>\"", "]"}]}], "+", 
       RowBox[{
        RowBox[{"Sin", "[", 
         RowBox[{"\[Omega]", " ", "t"}], "]"}], 
        RowBox[{"QuantumOperator", "[", "\"\<Y\>\"", "]"}]}]}], ")"}]}]}]}], 
  ";"}]], "Input",
