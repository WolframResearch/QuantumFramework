 ":"
}], "Text",ExpressionUUID->"6740ec67-939f-4369-b8d3-9d2815649eb0"],

Cell[BoxData[
 RowBox[{"AssociationThread", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"\"\<\\!\\(\\*SubscriptBox[\\(\[ScriptCapitalM]\\), \\(+\\)]\\)\>\
\"", ",", 
     " ", "\"\<\\!\\(\\*SubscriptBox[\\(\[ScriptCapitalM]\\), \
\\(-\\)]\\)\>\""}], "}"}], ",", " ", "\n", " ", 
   RowBox[{
    RowBox[{
     RowBox[{"MatrixForm", "[", 
      RowBox[{"FullSimplify", "@", 
       RowBox[{"MatrixPower", "[", 
        RowBox[{"#", ",", " ", 
         RowBox[{"1", "/", "2"}]}], "]"}]}], "]"}], " ", "&"}], " ", "/@", 
    " ", "\[ScriptCapitalE]"}]}], "]"}]], "Input",
 CellLabel->
  "In[218]:= ",ExpressionUUID->"6427f76c-3f9f-43d8-b148-0fc5b9e52f1f"],

Cell[TextData[{
 "Verify that ",
 Cell[BoxData[
  RowBox[{
   SubscriptBox["\[ScriptCapitalE]", "\[PlusMinus]"], "=", 
   SubsuperscriptBox["\[ScriptCapitalM]", "\[PlusMinus]", "\[Dagger]"], 
   SubscriptBox["\[ScriptCapitalM]", "\[PlusMinus]"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
