      StyleBox[")",
       SpanMaxSize->1]}]}], "=", 
    RowBox[{
     TemplateBox[{
       SubscriptBox[
        StyleBox["n", "TI"], "\[PlusMinus]"]},
      "Ket"], 
     TemplateBox[{
       SubscriptBox[
        StyleBox["n", "TI"], "\[PlusMinus]"]},
      "Bra"]}]}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "0820e110-c886-49b5-94ca-4e3d0dad410c"],
 "."
}], "Text",ExpressionUUID->"7facf141-016c-40cb-bef8-40c86fa79b64"],

