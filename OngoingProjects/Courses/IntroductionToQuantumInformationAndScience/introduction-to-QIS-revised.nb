    StyleBox[")",
     SpanMaxSize->1]}], ".", 
   OverscriptBox[
    StyleBox["\[Sigma]", "TI"], "\[RightVector]"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "afab8bb6-1154-4f17-b290-dc89ad478dd2"],
 ":"
}], "Text",ExpressionUUID->"8a3b1258-18f0-43f7-95d8-3a94d81e5e7f"],

Cell[BoxData[
 RowBox[{
  RowBox[{"With", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{"\[Sigma]", " ", "=", " ", 
       RowBox[{"Table", "[", 
        RowBox[{
         RowBox[{"PauliMatrix", "[", "j", "]"}], ",", " ", 
         RowBox[{"{", 
          RowBox[{"j", ",", " ", "3"}], "}"}]}], "]"}]}], ",", " ", "\n", 
      "   ", 
      RowBox[{"vec1", " ", "=", " ", 
       RowBox[{"Array", "[", 
        RowBox[{"\[FormalA]", ",", " ", "3"}], "]"}]}], ",", " ", "\n", "   ", 
      RowBox[{"vec2", " ", "=", " ", 
       RowBox[{"Array", "[", 
        RowBox[{"\[FormalB]", ",", " ", "\n", "     ", "3"}], "]"}]}]}], 
     "}"}], ",", " ", 
    RowBox[{
     RowBox[{
      RowBox[{"(", 
       RowBox[{"vec1", " ", ".", " ", "\[Sigma]"}], ")"}], " ", ".", " ", 
      RowBox[{"(", 
       RowBox[{"vec2", " ", ".", " ", "\[Sigma]"}], ")"}]}], " ", "==", " ", 
     RowBox[{
      RowBox[{
       RowBox[{"(", 
        RowBox[{"vec1", " ", ".", " ", "\n", "       ", "vec2"}], ")"}], " ", 
       
       RowBox[{"IdentityMatrix", "[", "2", "]"}]}], " ", "+", " ", "\n", 
      "    ", 
      RowBox[{"I", " ", 
       RowBox[{
        RowBox[{"Cross", "[", 
         RowBox[{"vec1", ",", " ", "vec2"}], "]"}], " ", ".", " ", 
        "\[Sigma]"}]}]}]}]}], "]"}], " ", "//", " ", 
  "FullSimplify"}]], "Input",
 CellLabel->
  "In[164]:= ",ExpressionUUID->"1f1b512e-bd18-4a0f-9cfb-680a751dc159"],

