Cell[990614, 16324, 198, 4, 70, "Input",ExpressionUUID->"05a08925-c384-45c5-b77c-7a27d3dfc810"],
Cell[990815, 16330, 282, 8, 70, "Text",ExpressionUUID->"8ea68493-0240-4b2f-aee8-8bb3d198b21d"],
