Cell[TextData[{
 "As we mentioned before, multiplying an eigenstate by an overall (nonzero) \
factor still gives an eigenstate with the same eigenvalue, so we can choose a \
convenient and conventional normalization and phase. For the operator ",
 Cell[BoxData[
  RowBox[{
   OverscriptBox[
    StyleBox["n", "TI"], "\[RightVector]"], ".", 
   OverscriptBox[
    StyleBox["\[Sigma]", "TI"], "\[RightVector]"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "627e26ba-c417-4e6a-b0a6-aec97317b52c"],
 ", a standard choice of eigenstates is ",
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     SubscriptBox[
      StyleBox["n", "TI"], "+"]},
    "Ket"], "=", "{", 
   StyleBox["C", "TI"], 
   StyleBox["o", "TI"], 
   StyleBox["s", "TI"], 
   StyleBox["[",
    SpanMaxSize->1], 
   StyleBox["\[Theta]", "TI"], "/", "2", 
   StyleBox["]",
    SpanMaxSize->1], ",", 
   SuperscriptBox[
    StyleBox["e", "TI"], 
    StyleBox[
     RowBox[{"i", "\[Phi]"}], "TI"]], 
   StyleBox["S", "TI"], 
   StyleBox["i", "TI"], 
   StyleBox["n", "TI"], 
   StyleBox["[",
    SpanMaxSize->1], 
   StyleBox["\[Theta]", "TI"], "/", "2", 
   StyleBox["]",
    SpanMaxSize->1], "}"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "ef47360a-e876-4c8b-9153-ce156e485f23"],
 " and ",
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     SubscriptBox[
      StyleBox["n", "TI"], "-"]},
    "Ket"], "=", "{", 
   StyleBox["S", "TI"], 
   StyleBox["i", "TI"], 
   StyleBox["n", "TI"], 
   StyleBox["[",
    SpanMaxSize->1], 
   StyleBox["\[Theta]", "TI"], "/", "2", 
   StyleBox["]",
    SpanMaxSize->1], ",", "-", 
   SuperscriptBox[
    StyleBox["e", "TI"], 
    StyleBox[
     RowBox[{"i", "\[Phi]"}], "TI"]], 
   StyleBox["C", "TI"], 
   StyleBox["o", "TI"], 
   StyleBox["s", "TI"], 
   StyleBox["[",
    SpanMaxSize->1], 
   StyleBox["\[Theta]", "TI"], "/", "2", 
   StyleBox["]",
    SpanMaxSize->1], "}"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "f379309f-71fa-44e5-ba70-50bc3dadff3e"]
}], "Text",ExpressionUUID->"3b3b34b9-c5f9-4dd2-b3e5-bc39975b7dbf"],

