Cell[BoxData[{
 RowBox[{"ClearAll", "[", 
  RowBox[{
  "\[Phi]", ",", " ", "\[Theta]", ",", " ", "r", ",", " ", "\[Phi]r", ",", 
   " ", "\[Theta]r"}], "]"}], "\n", 
 RowBox[{"Module", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
    "n", ",", " ", "blochvector", ",", " ", "\[Sigma]", ",", " ", "proj", ",",
      " ", "\[Rho]"}], "}"}], ",", "\n", " ", 
   RowBox[{"(*", 
    RowBox[{"define", " ", "Pauli", " ", "vector"}], "*)"}], "\n", " ", 
   RowBox[{
    RowBox[{"\[Sigma]", " ", "=", " ", 
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{"PauliMatrix", "[", "j", "]"}], ",", " ", 
       RowBox[{"{", 
        RowBox[{"j", ",", " ", "3"}], "}"}]}], "]"}]}], ";", "\n", " ", 
    RowBox[{"(*", 
     RowBox[{"define", " ", "a", " ", "Bloch", " ", "vector"}], "*)"}], "\n", 
    " ", 
    RowBox[{"blochvector", " ", "=", " ", "\n", "  ", 
     RowBox[{"r", " ", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{
         RowBox[{"Cos", "[", "\[Phi]r", "]"}], " ", 
         RowBox[{"Sin", "[", "\[Theta]r", "]"}]}], ",", " ", 
        RowBox[{
         RowBox[{"Sin", "[", "\[Phi]r", "]"}], " ", 
         RowBox[{"Sin", "[", "\[Theta]r", "]"}]}], ",", " ", "\n", "    ", 
        RowBox[{"Cos", "[", "\[Theta]r", "]"}]}], "}"}]}]}], ";", "\n", " ", 
    RowBox[{"(*", 
     RowBox[{"define", " ", "the", " ", "density", " ", "matrix"}], "*)"}], 
    "\n", " ", 
    RowBox[{"\[Rho]", " ", "=", " ", 
     RowBox[{"DensityMatrix", "[", "blochvector", "]"}]}], ";", "\n", " ", 
    RowBox[{"(*", 
     RowBox[{"define", " ", "a", " ", "unit", " ", "vector"}], "*)"}], "\n", 
    " ", 
    RowBox[{"n", " ", "=", " ", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{
        RowBox[{"Cos", "[", "\[Phi]", "]"}], " ", 
        RowBox[{"Sin", "[", "\[Theta]", "]"}]}], ",", " ", 
       RowBox[{
        RowBox[{"Sin", "[", "\[Phi]", "]"}], " ", 
        RowBox[{"Sin", "[", "\[Theta]", "]"}]}], ",", " ", "\n", "   ", 
       RowBox[{"Cos", "[", "\[Theta]", "]"}]}], "}"}]}], ";", "\n", " ", 
    RowBox[{"(*", 
     RowBox[{
     "define", " ", "the", " ", "projector", " ", "to", " ", "positive", " ", 
      "eigenstate"}], "*)"}], "\n", " ", 
    RowBox[{"proj", " ", "=", " ", 
     RowBox[{"DensityMatrix", "[", "n", "]"}]}], ";", "\n", " ", 
    RowBox[{"(*", 
     RowBox[{"confirm", " ", "identity"}], "*)"}], "\n", " ", 
    RowBox[{"FullSimplify", "[", "\n", "  ", 
     RowBox[{
      RowBox[{
       RowBox[{"Tr", "[", 
        RowBox[{"proj", " ", ".", " ", "\[Rho]"}], "]"}], " ", "==", " ", 
       "\n", "   ", 
       RowBox[{
        RowBox[{"1", "/", "2"}], " ", 
        RowBox[{"(", 
         RowBox[{"1", " ", "+", " ", "\n", "      ", 
          RowBox[{"n", " ", ".", " ", "blochvector"}]}], ")"}]}]}], ",", " ", 
      
      RowBox[{
       RowBox[{
        RowBox[{"(", 
         RowBox[{
         "r", " ", "|", " ", "\[Theta]r", " ", "|", " ", "\[Phi]r", " ", "|", 
          " ", "\[Theta]", " ", "|", " ", "\[Phi]"}], ")"}], " ", "\\\n"}], "\[Element]",
        " ", "Reals"}]}], "]"}]}]}], "]"}]}], "Input",
 CellLabel->
  "In[210]:= ",ExpressionUUID->"e1d6b14b-d1c7-4fd4-ac61-1268f7d4e00d"],

