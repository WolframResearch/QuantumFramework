Cell["From Algebra to Rotations", "Subsection",ExpressionUUID->"08a1e94b-ea94-44be-8115-4c9355682c39"],

Cell[TextData[{
 "From ",
 Cell[BoxData[
  RowBox[{
   RowBox[{
    StyleBox["(",
     SpanMaxSize->1], 
    RowBox[{
     OverscriptBox[
      StyleBox["a", "TI"], "\[RightVector]"], ".", 
     OverscriptBox[
      StyleBox["\[Sigma]", "TI"], "\[RightVector]"]}], 
    StyleBox[")",
     SpanMaxSize->1], 
    StyleBox["(",
     SpanMaxSize->1], 
    RowBox[{
     OverscriptBox[
      StyleBox["b", "TI"], "\[RightVector]"], ".", 
     OverscriptBox[
      StyleBox["\[Sigma]", "TI"], "\[RightVector]"]}], 
    StyleBox[")",
     SpanMaxSize->1], "=", 
    StyleBox["(",
     SpanMaxSize->1], 
    RowBox[{
     OverscriptBox[
      StyleBox["a", "TI"], "\[RightVector]"], ".", 
     OverscriptBox[
      StyleBox["b", "TI"], "\[RightVector]"]}], 
    StyleBox[")",
     SpanMaxSize->1], "\|01d540", "+", 
    StyleBox["i", "TI"], 
    StyleBox["(",
     SpanMaxSize->1], 
    RowBox[{
     OverscriptBox[
      StyleBox["a", "TI"], "\[RightVector]"], "\[Times]", 
     OverscriptBox[
      StyleBox["b", "TI"], "\[RightVector]"]}], 
    StyleBox[")",
     SpanMaxSize->1]}], ".", 
   OverscriptBox[
    StyleBox["\[Sigma]", "TI"], "\[RightVector]"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "e962e633-855e-4f9e-80df-1de7ae0dd671"],
 ", we get ",
 Cell[BoxData[
  RowBox[{
   SuperscriptBox[
    RowBox[{
     StyleBox["(",
      SpanMaxSize->1], 
     RowBox[{
      OverscriptBox[
       StyleBox["n", "TI"], "\[RightVector]"], ".", 
      OverscriptBox[
       StyleBox["\[Sigma]", "TI"], "\[RightVector]"]}], 
     StyleBox[")",
      SpanMaxSize->1]}], "2"], "=", 
   StyleBox["(",
    SpanMaxSize->1], 
   RowBox[{
    OverscriptBox[
     StyleBox["n", "TI"], "\[RightVector]"], ".", 
    OverscriptBox[
     StyleBox["n", "TI"], "\[RightVector]"]}], 
   StyleBox[")",
    SpanMaxSize->1], "\|01d540", "=", "\|01d540"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "9a6292b7-2e3b-4cf4-85cf-f49f87765def"],
 " where ",
 Cell[BoxData[
  OverscriptBox[
   StyleBox["n", "TI"], "\[RightVector]"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "e54e1835-df07-406c-b8d1-1b93acf37008"],
 " is a unit vector. This implies ",
 Cell[BoxData[
  RowBox[{
   SuperscriptBox[
    RowBox[{
     StyleBox["(",
      SpanMaxSize->1], 
     RowBox[{
      OverscriptBox[
       StyleBox["n", "TI"], "\[RightVector]"], ".", 
      OverscriptBox[
       StyleBox["\[Sigma]", "TI"], "\[RightVector]"]}], 
     StyleBox[")",
      SpanMaxSize->1]}], 
    RowBox[{"2", 
     StyleBox["m", "TI"]}]], "=", "\|01d540"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "16721b0e-15a5-4c7c-9c45-dd72f426a17f"],
 " and ",
 Cell[BoxData[
  RowBox[{
   RowBox[{
    SuperscriptBox[
     RowBox[{
      StyleBox["(",
       SpanMaxSize->1], 
      RowBox[{
       OverscriptBox[
        StyleBox["n", "TI"], "\[RightVector]"], ".", 
       OverscriptBox[
        StyleBox["\[Sigma]", "TI"], "\[RightVector]"]}], 
      StyleBox[")",
       SpanMaxSize->1]}], 
     RowBox[{"2", 
      StyleBox["m", "TI"], "+", "1"}]], "=", 
    OverscriptBox[
     StyleBox["n", "TI"], "\[RightVector]"]}], ".", 
   OverscriptBox[
    StyleBox["\[Sigma]", "TI"], "\[RightVector]"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "af0a3f88-2d17-439b-a477-bb8001b4ca85"],
 ". Using these relations in the power-series expansion of the exponential ",
 Cell[BoxData[
  SuperscriptBox[
   StyleBox["e", "TI"], 
   RowBox[{
    RowBox[{"-", 
     StyleBox["i", "TI"], " ", 
     StyleBox["\[Alpha]", "TI"], "/", "2", " ", 
     OverscriptBox[
      StyleBox["n", "TI"], "\[RightVector]"]}], ".", 
    OverscriptBox[
     StyleBox["\[Sigma]", "TI"], "\[RightVector]"]}]]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "f2baa8c3-2d82-43f7-94d3-25d69388436d"],
 ", we find: ",
 Cell[BoxData[
  RowBox[{
   RowBox[{
    SuperscriptBox[
     StyleBox["e", "TI"], 
     RowBox[{
      RowBox[{"-", 
       StyleBox["i", "TI"], " ", 
       StyleBox["\[Alpha]", "TI"], "/", "2", " ", 
       OverscriptBox[
        StyleBox["n", "TI"], "\[RightVector]"]}], ".", 
      OverscriptBox[
       StyleBox["\[Sigma]", "TI"], "\[RightVector]"]}]], "=", 
    StyleBox["C", "TI"], 
    StyleBox["o", "TI"], 
    StyleBox["s", "TI"], 
    StyleBox["[",
     SpanMaxSize->1], 
    RowBox[{
     StyleBox["\[Alpha]", "TI"], "/", "2"}], 
    StyleBox["]",
     SpanMaxSize->1], "\|01d540", "-", 
    StyleBox["i", "TI"], " ", 
    StyleBox["S", "TI"], 
    StyleBox["i", "TI"], 
    StyleBox["n", "TI"], 
    StyleBox["[",
     SpanMaxSize->1], 
    RowBox[{
     StyleBox["\[Alpha]", "TI"], "/", "2"}], 
    StyleBox["]",
     SpanMaxSize->1], 
    OverscriptBox[
     StyleBox["n", "TI"], "\[RightVector]"]}], ".", 
   OverscriptBox[
    StyleBox["\[Sigma]", "TI"], "\[RightVector]"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "cfed5a68-f2ce-4028-bd52-02d3e48b75a4"],
 "."
}], "Text",ExpressionUUID->"02b72557-3e91-4cfe-aa06-c15750496987"],

Cell[TextData[{
 "Verify that ",
 Cell[BoxData[
  RowBox[{
   RowBox[{
    SuperscriptBox[
     StyleBox["e", "TI"], 
     RowBox[{
      RowBox[{"-", 
       StyleBox["i", "TI"], " ", 
