                 RowBox[{"-", "5"}], ",", " ", 
                 RowBox[{"-", "0.75"}]}], "}"}]}], "}"}], ",", " ", "0.2"}], 
            "]"}], ",", " ", "\n", 
           RowBox[{"Opacity", "[", "0.5", "]"}]}], "}"}], ",", " ", "\n", 
         RowBox[{"RotationTransform", "[", 
          RowBox[{"\[Theta]", ",", " ", 
           RowBox[{
            RowBox[{"{", 
             RowBox[{"0", ",", " ", 
              RowBox[{"-", "5"}], ",", " ", 
              RowBox[{"-", "0.75"}]}], "}"}], " ", "-", " ", 
            RowBox[{"{", 
             RowBox[{"0", ",", " ", 
              RowBox[{"-", "4.5"}], ",", " ", 
              RowBox[{"-", "0.75"}]}], "}"}]}], ",", " ", 
           RowBox[{"{", 
            RowBox[{"0", ",", " ", 
             RowBox[{"\\\n", 
              RowBox[{"-", "4.5"}]}], ",", " ", 
             RowBox[{"-", "0.75"}]}], "}"}]}], "]"}]}], "]"}], ",", " ", 
       RowBox[{"{", "\n", 
        RowBox[{
         RowBox[{"Opacity", "[", "0.4", "]"}], ",", " ", "Blue", ",", " ", 
         "\n", 
         RowBox[{"Polygon", "[", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"{", 
             RowBox[{
              RowBox[{"-", "1"}], ",", " ", "1.1", ",", " ", 
              RowBox[{"-", "1.75"}]}], "}"}], ",", " ", 
            RowBox[{"{", 
             RowBox[{
              RowBox[{"-", "1"}], ",", " ", "1.1", ",", " ", "0.25"}], "}"}], 
            ",", " ", 
            RowBox[{"{", 
             RowBox[{"1", ",", " ", "1.1", ",", " ", "0.25"}], "}"}], ",", 
            " ", 
            RowBox[{"{", 
             RowBox[{"1", ",", " ", "\n", "       ", "1.1", ",", " ", 
              RowBox[{"-", "1.75"}]}], "}"}]}], "}"}], "]"}], ",", " ", 
         "Green", ",", " ", "\n", 
         RowBox[{"Polygon", "[", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"{", 
             RowBox[{
              RowBox[{"-", "1"}], ",", " ", 
              RowBox[{"-", "3.5"}], ",", " ", 
              RowBox[{"-", "0.6"}]}], "}"}], ",", " ", 
            RowBox[{"{", 
             RowBox[{
              RowBox[{"-", "1"}], ",", " ", 
              RowBox[{"-", "3.5"}], ",", " ", "0.25"}], "}"}], ",", " ", 
            RowBox[{"{", 
             RowBox[{"1", ",", " ", 
              RowBox[{"-", "3.5"}], ",", " ", "\n", "       ", "0.25"}], 
             "}"}], ",", " ", 
            RowBox[{"{", 
             RowBox[{"1", ",", " ", 
              RowBox[{"-", "3.5"}], ",", " ", 
              RowBox[{"-", "0.6"}]}], "}"}]}], "}"}], "]"}], ",", " ", "\n", 
         RowBox[{"Polygon", "[", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"{", 
             RowBox[{
              RowBox[{"-", "1"}], ",", " ", 
              RowBox[{"-", "4"}], ",", " ", 
              RowBox[{"-", "1.75"}]}], "}"}], ",", " ", 
            RowBox[{"{", 
             RowBox[{
              RowBox[{"-", "1"}], ",", " ", 
              RowBox[{"-", "4"}], ",", " ", 
              RowBox[{"-", "0.9"}]}], "}"}], ",", " ", 
            RowBox[{"{", 
             RowBox[{"1", ",", " ", 
              RowBox[{"-", "4"}], ",", " ", 
              RowBox[{"-", "0.9"}]}], "}"}], ",", " ", 
            RowBox[{"{", 
             RowBox[{"1", ",", " ", 
              RowBox[{"-", "4"}], ",", " ", 
              RowBox[{"\\\n", 
               RowBox[{"-", "1.75"}]}]}], "}"}]}], "}"}], "]"}], ",", " ", 
         "\n", 
         RowBox[{"Polygon", "[", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"{", 
             RowBox[{
              RowBox[{"-", "1"}], ",", " ", 
              RowBox[{"-", "3.5"}], ",", " ", 
              RowBox[{"-", "1.75"}]}], "}"}], ",", " ", 
            RowBox[{"{", 
             RowBox[{
              RowBox[{"-", "1"}], ",", " ", 
              RowBox[{"-", "3.5"}], ",", " ", 
              RowBox[{"-", "0.9"}]}], "}"}], ",", " ", 
            RowBox[{"{", 
             RowBox[{"1", ",", " ", 
              RowBox[{"-", "3.5"}], ",", " ", 
              RowBox[{"-", "0.9"}]}], "}"}], ",", " ", 
            RowBox[{"{", 
             RowBox[{"1", ",", " ", 
              RowBox[{"\\\n", 
               RowBox[{"-", "3.5"}]}], ",", " ", 
              RowBox[{"-", "1.75"}]}], "}"}]}], "}"}], "]"}], ",", " ", "\n", 
         
         RowBox[{"Polygon", "[", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"{", 
             RowBox[{
              RowBox[{"-", "1"}], ",", " ", 
              RowBox[{"-", "4"}], ",", " ", 
              RowBox[{"-", "0.6"}]}], "}"}], ",", " ", 
            RowBox[{"{", 
             RowBox[{
              RowBox[{"-", "1"}], ",", " ", 
              RowBox[{"-", "4"}], ",", " ", "0.25"}], "}"}], ",", " ", 
            RowBox[{"{", 
             RowBox[{"1", ",", " ", 
              RowBox[{"-", "4"}], ",", " ", "\n", "       ", "0.25"}], "}"}], 
            ",", " ", 
            RowBox[{"{", 
             RowBox[{"1", ",", " ", 
              RowBox[{"-", "4"}], ",", " ", 
              RowBox[{"-", "0.6"}]}], "}"}]}], "}"}], "]"}]}], "}"}], ",", 
       " ", 
       RowBox[{"{", "\n", 
        RowBox[{
         RowBox[{"Text", "[", 
          RowBox[{"\"\<Source\>\"", ",", " ", 
           RowBox[{"{", 
            RowBox[{"0", ",", " ", 
             RowBox[{"-", "5"}], ",", " ", "0"}], "}"}]}], "]"}], ",", " ", 
         "\n", 
         RowBox[{"Text", "[", 
          RowBox[{"\"\<Collimators\>\"", ",", " ", 
           RowBox[{"{", 
            RowBox[{"0", ",", " ", 
             RowBox[{"-", "4"}], ",", " ", "1"}], "}"}]}], "]"}], ",", " ", 
         "\n", 
         RowBox[{"Text", "[", 
          RowBox[{"\"\<Detector\>\"", ",", " ", 
           RowBox[{"{", 
            RowBox[{"0", ",", " ", "1", ",", " ", "1"}], "}"}]}], "]"}], ",", 
         " ", "\n", 
         RowBox[{"Text", "[", 
          RowBox[{"\"\<External magnetic field\>\"", ",", " ", 
           RowBox[{"{", 
            RowBox[{"0", ",", " ", 
             RowBox[{"-", "2"}], ",", " ", "2"}], "}"}]}], "]"}]}], "}"}]}], 
      "}"}], ",", " ", 
     RowBox[{"Boxed", " ", "->", " ", "False"}], ",", " ", "\n", "  ", 
     RowBox[{"ViewPoint", " ", "->", " ", 
      RowBox[{"{", 
       RowBox[{"3", ",", " ", 
        RowBox[{"-", "1.5"}], ",", " ", "1"}], "}"}]}], ",", " ", "\n", 
     "    ", 
     RowBox[{"ImageSize", " ", "->", " ", "300"}]}], "]"}], ",", " ", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"t", ",", " ", ".35", ",", " ", "\"\<Number of particles\>\""}],
       "}"}], ",", " ", "0", ",", " ", "\n", "  ", "1"}], "}"}], ",", " ", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
      "\[Theta]", ",", " ", "0", ",", 
       " ", "\"\<Angle of external field gradient\>\""}], "}"}], ",", " ", 
     "0", ",", " ", 
     RowBox[{"2", " ", "\[Pi]"}]}], "}"}], ",", "\n", "  ", 
   RowBox[{"SaveDefinitions", " ", "->", " ", "True"}]}], "]"}]], "Input",
 CellLabel->
  "In[83]:= ",ExpressionUUID->"492741c0-ef22-4554-b1ee-0bbba9379095"],

Cell[TextData[{
 "The demonstration above is modified from ",
 ButtonBox["an example",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://demonstrations.wolfram.com/SternGerlachExperiment/"], 
    None}],
 " in the Wolfram Demonstration Project."
}], "Text",ExpressionUUID->"6eae0806-c2b7-4748-b8f5-a1a375492322"],

Cell[TextData[{
 "The beam of atoms coming out of the source (a hot oven) is an unpolarized \
beam (i.e., with no preferred spin direction). Therefore, the probabilities \
of obtaining spin up and spin down are 1/2 and 1/2 along any measurement \
direction (specified by ",
 Cell[BoxData[
  OverscriptBox[
   StyleBox["n", "TI"], "\[RightVector]"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "c91e874f-d911-48a9-a0ee-39d1df8b414d"],
 "); the measurement outcomes are equiprobable. In this experiment, state \
vector cannot fully describe the system. Instead, we use a density matrix (or \
density operator). The unique qubit state that gives 1/2\[Dash]1/2 \
probabilities for every axis is ",
 Cell[BoxData[
  RowBox[{
   StyleBox["\[Rho]", "TI"], " ", "=", "\|01d540", " ", "/", "2"}]], 
  "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "03047a0e-a4fb-4521-89fc-f68a7bf91ab8"],
 " (the maximally mixed state with \|01d540 the 2\[Times]2 identity matrix). \
No pure state can do that."
}], "Text",ExpressionUUID->"41d01694-0f4a-48e6-b038-362599eccfe2"],

Cell["No Pure State Can Be Unpolarized in Every Basis", "Subsection",ExpressionUUID->"73c582c0-2c9d-4d4b-a99f-c20ab0b75079"],

Cell[TextData[{
 "Let\[CloseCurlyQuote]s explore why a state vector description fails for the \
Stern-Gerlach experiment above. Let\[CloseCurlyQuote]s assume that there is a \
state vector ",
 Cell[BoxData[
  RowBox[{
   RowBox[{"{", 
    StyleBox["C", "TI"], 
    StyleBox["o", "TI"], 
    StyleBox["s", "TI"], 
    StyleBox["[",
     SpanMaxSize->1], 
    RowBox[{
     StyleBox["\[Theta]", "TI"], "/", "2"}], 
    StyleBox["]",
     SpanMaxSize->1]}], ",", 
   RowBox[{
    SuperscriptBox[
     StyleBox["e", "TI"], 
     RowBox[{
      StyleBox["i", "TI"], " ", 
      StyleBox["\[Phi]", "TI"]}]], 
    StyleBox["S", "TI"], 
    StyleBox["i", "TI"], 
    StyleBox["n", "TI"], 
    StyleBox["[",
     SpanMaxSize->1], 
    RowBox[{
     StyleBox["\[Theta]", "TI"], "/", "2"}], 
    StyleBox["]",
     SpanMaxSize->1], "}"}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "c47758da-600a-4a4e-9f0a-c091c60fbb29"],
 " that can generate probabilities ",
 Cell[BoxData[
  RowBox[{
   RowBox[{"{", "1", "/", "2"}], ",", 
   RowBox[{"1", "/", "2", "}"}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "20b0534b-2078-4f2f-b87e-2dace6cbd4f3"],
 " for any measurement in any basis. Note that our state vector is the most \
generic pure state of a qubit. We will consider three cases: measurement \
along the z-direction (measuring Pauli-Z), along the x-direction (measuring \
Pauli-X), and along the y-direction (measuring Pauli-Y)."
}], "Text",ExpressionUUID->"7bba02bc-2f62-4ef9-b147-24df0fa7253d"],

Cell["\<\
Compute the measurement probabilities when Pauli-Z is measured:\
\>", "Text",ExpressionUUID->"b79499f0-0966-47f6-a384-38eeaba2c30d"],

Cell[BoxData[
 RowBox[{"FullSimplify", "[", "\n", " ", 
  RowBox[{
   RowBox[{
    RowBox[{"Abs", "[", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"Cos", "[", 
        RowBox[{"\[Theta]", "/", "2"}], "]"}], ",", " ", "\n", "    ", 
       RowBox[{
        RowBox[{"E", "^", 
         RowBox[{"(", 
          RowBox[{"I", " ", "\[Phi]"}], ")"}]}], " ", 
        RowBox[{"Sin", "[", 
         RowBox[{"\[Theta]", "/", "2"}], "]"}]}]}], "}"}], "]"}], "^", "2"}], 
   ",", " ", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{"\[Theta]", " ", "|", " ", "\[Phi]"}], ")"}], " ", "\[Element]", 
    " ", "\n", "  ", "Reals"}]}], "]"}]], "Input",
 CellLabel->
  "In[84]:= ",ExpressionUUID->"469110f8-e656-47ad-a9fc-50a330c225dd"],

Cell[TextData[{
 "Imposing the condition that ",
 Cell[BoxData[
  RowBox[{
   StyleBox["C", "TI"], 
   StyleBox["o", "TI"], 
   StyleBox["s", "TI"], 
   SuperscriptBox[
    RowBox[{
     StyleBox["[",
      SpanMaxSize->1], 
     RowBox[{
      StyleBox["\[Theta]", "TI"], "/", "2"}], 
     StyleBox["]",
      SpanMaxSize->1]}], "2"], "=", 
   StyleBox["S", "TI"], 
   StyleBox["i", "TI"], 
   StyleBox["n", "TI"], 
   SuperscriptBox[
    RowBox[{
     StyleBox["[",
      SpanMaxSize->1], 
     RowBox[{
      StyleBox["\[Theta]", "TI"], "/", "2"}], 
     StyleBox["]",
      SpanMaxSize->1]}], "2"], "=", "1", "/", "2"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "0d7df66f-91d6-4ef4-93f2-48d344be5469"],
 " implies that \[Theta] can be ",
 Cell[BoxData[
  RowBox[{"\[Pi]", "/", "2"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "3b73739a-faf2-4547-8cc8-0b7ef6d0333b"],
 "."
}], "Text",ExpressionUUID->"10df9c3f-cc15-4866-956a-7cfd71fe7d14"],

Cell[BoxData[
 RowBox[{
  RowBox[{"Solve", "[", 
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{"Cos", "[", 
        RowBox[{"\[Theta]", "/", "2"}], "]"}], "^", "2"}], " ", "==", " ", 
      RowBox[{"1", "/", "2"}]}], " ", "&&", " ", 
     RowBox[{
      RowBox[{
       RowBox[{"Sin", "[", 
        RowBox[{"\[Theta]", "/", "2"}], "]"}], "^", "2"}], " ", "==", " ", 
      RowBox[{"1", "/", "2"}]}], " ", "&&", " ", "\n", "   ", 
     RowBox[{"0", " ", "<=", " ", "\[Theta]", " ", "<=", " ", "\[Pi]"}]}], ",",
     " ", "\[Theta]"}], "]"}], " ", "//", " ", "FullSimplify"}]], "Input",
 CellLabel->
  "In[85]:= ",ExpressionUUID->"af3f79d8-0740-4d24-b747-bb81dc4e46da"],

Cell["\<\
Using this result, let us compute the measurement probabilities in the \
Pauli-X basis. We will first transform the state into the eigenbasis of \
Pauli-X and then calculate the corresponding probabilities.\
\>", "Text",ExpressionUUID->"4a947b6c-215a-449f-abe0-c0e63eefb227"],

Cell["Compute the state in the eigenbasis of Pauli-X:", "Text",ExpressionUUID->"31af35ad-3c86-470e-b69e-02fd42960524"],

Cell[BoxData[
 RowBox[{"stateVectorPauliX", " ", "=", " ", "\n", " ", 
  RowBox[{
   RowBox[{"Conjugate", "[", 
    RowBox[{"{", 
     RowBox[{"plus", ",", " ", "minus"}], "}"}], "]"}], " ", ".", " ", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"Cos", "[", 
      RowBox[{"\[Theta]", "/", "2"}], "]"}], ",", " ", "\n", "   ", 
     RowBox[{
      RowBox[{"E", "^", 
       RowBox[{"(", 
        RowBox[{"I", " ", "\[Phi]"}], ")"}]}], " ", 
      RowBox[{"Sin", "[", 
       RowBox[{"\[Theta]", "/", "2"}], "]"}]}]}], "}"}]}]}]], "Input",
 CellLabel->
  "In[86]:= ",ExpressionUUID->"c522897c-f7d3-4f6a-b50c-c92e4b528802"],

Cell["Impose the condition on \[Theta] and calculate probabilities:", "Text",ExpressionUUID->"46bd1529-e1bd-4122-acac-caa4711f8339"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"Abs", "[", "stateVectorPauliX", "]"}], "^", "2"}], " ", "/.", 
   " ", 
   RowBox[{"{", 
    RowBox[{"\[Theta]", " ", "->", " ", 
     RowBox[{"\[Pi]", "/", "2"}]}], "}"}]}], " ", "//", " ", 
  "FullSimplify"}]], "Input",
 CellLabel->
  "In[87]:= ",ExpressionUUID->"92203736-5df3-43c1-9684-ce3359093c30"],

Cell[TextData[{
 "Imposing the condition that ",
 Cell[BoxData[
  RowBox[{
   StyleBox["C", "TI"], 
   StyleBox["o", "TI"], 
   StyleBox["s", "TI"], 
   SuperscriptBox[
    RowBox[{
     StyleBox["[",
      SpanMaxSize->1], 
     RowBox[{
      StyleBox["\[Phi]", "TI"], "/", "2"}], 
     StyleBox["]",
      SpanMaxSize->1]}], "2"], "=", 
   StyleBox["S", "TI"], 
   StyleBox["i", "TI"], 
   StyleBox["n", "TI"], 
   SuperscriptBox[
    RowBox[{
     StyleBox["[",
      SpanMaxSize->1], 
     RowBox[{
      StyleBox["\[Phi]", "TI"], "/", "2"}], 
     StyleBox["]",
      SpanMaxSize->1]}], "2"], "=", "1", "/", "2"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "4494d421-8d5b-4493-92ee-77786ede2895"],
 " implies that \[Phi] can be ",
 Cell[BoxData[
  RowBox[{
   RowBox[{"\[Pi]", "/", "2"}], ",", 
   RowBox[{"3", "\[Pi]", "/", "2"}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "7554c498-2c56-423a-8962-80a8e218c58c"],
 "."
}], "Text",ExpressionUUID->"741f92c1-96ff-41cf-baa6-8fb90eb00d9f"],

Cell[BoxData[
 RowBox[{
  RowBox[{"Solve", "[", 
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{"Cos", "[", 
        RowBox[{"\[Phi]", "/", "2"}], "]"}], "^", "2"}], " ", "==", " ", 
      RowBox[{"1", "/", "2"}]}], " ", "&&", " ", 
     RowBox[{
      RowBox[{
       RowBox[{"Sin", "[", 
        RowBox[{"\[Phi]", "/", "2"}], "]"}], "^", "2"}], " ", "==", " ", 
      RowBox[{"1", "/", "2"}]}], " ", "&&", " ", "\n", "   ", 
     RowBox[{"0", " ", "<=", " ", "\[Phi]", " ", "<=", " ", 
      RowBox[{"2", " ", "\[Pi]"}]}]}], ",", " ", "\[Phi]"}], "]"}], " ", "//",
   " ", "FullSimplify"}]], "Input",
 CellLabel->
  "In[88]:= ",ExpressionUUID->"0ef7f9b0-3c03-4aeb-abe4-cf4b397d751f"],

Cell["\<\
So far, we have found pure states that give probability 1/2 for each outcome \
in measurements of both Pauli-X and Pauli-Z. Now we turn our attention to \
measurements of Pauli-Y.\
\>", "Text",ExpressionUUID->"78604ced-820b-4a0a-ac45-1e054e1ed02b"],

Cell["\<\
If we impose the previous conditions into the measurement probabilities in \
the Pauli-Y basis, one finds the measurement probabilities can be only 0 or \
1, which contradicts the experimental result. Let\[CloseCurlyQuote]s show \
this explicitly.\
\>", "Text",ExpressionUUID->"220c2475-29f9-40a1-aedb-5946ea7da52f"],

Cell["Compute the state in the eigenbasis of Pauli-Y:", "Text",ExpressionUUID->"d355aafb-4d80-4553-a583-4394df209291"],

Cell[BoxData[
 RowBox[{"stateVectorPauliY", " ", "=", " ", "\n", " ", 
  RowBox[{
   RowBox[{"Conjugate", "[", 
    RowBox[{"{", 
     RowBox[{"right", ",", " ", "left"}], "}"}], "]"}], " ", ".", " ", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"Cos", "[", 
      RowBox[{"\[Theta]", "/", "2"}], "]"}], ",", " ", "\n", "   ", 
     RowBox[{
      RowBox[{"E", "^", 
       RowBox[{"(", 
        RowBox[{"I", " ", "\[Phi]"}], ")"}]}], " ", 
      RowBox[{"Sin", "[", 
       RowBox[{"\[Theta]", "/", "2"}], "]"}]}]}], "}"}]}]}]], "Input",
 CellLabel->
  "In[89]:= ",ExpressionUUID->"c4bc484b-0501-4c54-81c0-c3a40af0381e"],

Cell["Find probabilities after imposing conditions for \[Theta] and \[Phi]:", \
"Text",ExpressionUUID->"543dda2e-14ea-4d94-a03b-09ca6b9acea9"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"Abs", "[", "stateVectorPauliY", "]"}], "^", "2"}], " ", "/.", 
   " ", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"\[Theta]", " ", "->", " ", 
      RowBox[{"\[Pi]", "/", "2"}]}], ",", " ", 
     RowBox[{"\[Phi]", " ", "->", " ", 
      RowBox[{"\[Pi]", "/", "\n", "    ", "2"}]}]}], "}"}]}], " ", "//", " ", 
  "FullSimplify"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"Abs", "[", "stateVectorPauliY", "]"}], "^", "2"}], " ", "/.", 
   " ", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"\[Theta]", " ", "->", " ", 
      RowBox[{"\[Pi]", "/", "2"}]}], ",", " ", 
     RowBox[{"\[Phi]", " ", "->", " ", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{"3", " ", "\[Pi]"}], ")"}], "/", "\n", "    ", "2"}]}]}], 
    "}"}]}], " ", "//", " ", "FullSimplify"}]}], "Input",
 CellLabel->
  "In[90]:= ",ExpressionUUID->"cfff2ea7-3e67-4822-93b1-e5b7b3da61cc"],

Cell["\<\
The result shows that the pure state cannot yield 1/2 measurement \
probabilities in every basis. This motivates a more general description of \
quantum states using a density matrix. First, we will focus on the density \
matrix description of pure states and then we will introduce another class of \
states called the mixed states that can fully describe Stern-Gerlach \
experimental results.\
\>", "Text",ExpressionUUID->"df64423d-5b23-46a5-a51d-c43ffbbd905e"],

Cell["\<\
Density Matrices: What They Are and How to Read Their Entries\
\>", "Subsection",ExpressionUUID->"9e701764-7fff-489e-8156-8a8784bd6f92"],

Cell[TextData[{
 "The density matrix description of a qubit is given by a ",
 Cell[BoxData[
  RowBox[{"2", "\[Times]", "2"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "c1322f44-2829-4860-bd2b-7d152ecf422f"],
 " matrix, usually denoted by \[Rho], that is Hermitian and positive \
semidefinite. We will discuss these properties in detail later. First, a \
brief comment on matrix notation: the elements of a matrix \[Rho] are usually \
written as ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["\[Rho]", "TI"], 
   RowBox[{
    StyleBox["i", "TI"], ",", 
    StyleBox["j", "TI"]}]]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "24714021-27c2-4319-8874-f5f992b9bdca"],
 " (or ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["\[Rho]", "TI"], 
   StyleBox[
    RowBox[{"i", "j"}], "TI"]]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "fb0e71d6-6867-428e-b301-89a1ba463cc6"],
 "), where ",
 Cell[BoxData[
  StyleBox["i", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "92ceb047-13f9-4264-8f84-0687dac620cc"],
 " labels the row and ",
 Cell[BoxData[
  StyleBox["j", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "21a5487b-e92a-4a3f-aa80-c31301922ad7"],
 " labels the column."
}], "Text",ExpressionUUID->"86b9f231-771d-4606-82a8-eff88760ff4b"],

Cell["Show the matrix form of a 2x2 density matrix:", "Text",ExpressionUUID->"ff63500a-02d1-4515-9571-4abda3456d96"],

Cell[BoxData[
 RowBox[{
  RowBox[{"Array", "[", 
   RowBox[{
    RowBox[{
     RowBox[{"Subscript", "[", 
      RowBox[{"\[Rho]", ",", " ", "##"}], "]"}], " ", "&"}], ",", " ", 
    RowBox[{"{", 
     RowBox[{"2", ",", " ", "2"}], "}"}]}], "]"}], " ", "//", " ", 
  "MatrixForm"}]], "Input",
 CellLabel->
  "In[91]:= ",ExpressionUUID->"ed532c3b-fc95-4592-9ddf-61d4a55784f8"],

Cell[TextData[{
 "There is another common notation that refers directly to the ",
 Cell[BoxData[
  TemplateBox[{"0"},
   "Ket"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "6cc04353-f1f1-44e6-be47-9727ecd239a4"],
 " and ",
 Cell[BoxData[
  TemplateBox[{"1"},
   "Ket"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "7377e03e-83f6-40a4-840c-d0e2892c5206"],
 " states. In this notation, the matrix elements are written as ",
 Cell[BoxData[
  RowBox[{
   SubscriptBox[
    StyleBox["\[Rho]", "TI"], 
    StyleBox[
     RowBox[{"i", "j"}], "TI"]], "=", 
   RowBox[{
    TemplateBox[{
      StyleBox["i", "TI"]},
     "Bra"], 
    StyleBox["\[Rho]", "TI"], 
    TemplateBox[{
      StyleBox["j", "TI"]},
     "Ket"]}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "c59df70f-2af4-4a5c-ae8f-6793ea9eeb47"],
 " with ",
 Cell[BoxData[
  RowBox[{
   StyleBox["i", "TI"], ",", " ", 
   RowBox[{
    StyleBox["j", "TI"], " ", "\[Element]", " ", 
    RowBox[{"{", 
     RowBox[{"0", ",", " ", "1"}], "}"}]}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "b538544c-730b-4eeb-bcf2-892d1a4825b0"],
 ", so that, for example, ",
 Cell[BoxData[
  RowBox[{
   SubscriptBox[
    StyleBox["\[Rho]", "TI"], "01"], "=", 
   RowBox[{
    TemplateBox[{"0"},
     "Bra"], 
    StyleBox["\[Rho]", "TI"], 
    TemplateBox[{"1"},
     "Ket"]}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "f9fd7d5a-e6bf-4a61-8638-20b21566dc6c"],
 " or ",
 Cell[BoxData[
  RowBox[{
   SubscriptBox[
    StyleBox["\[Rho]", "TI"], "11"], "=", 
   RowBox[{
    TemplateBox[{"1"},
     "Bra"], 
    StyleBox["\[Rho]", "TI"], 
    TemplateBox[{"1"},
     "Ket"]}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "484c2700-3646-4228-a682-64d3df87e558"],
 " . We will discuss this notation in details later."
}], "Text",ExpressionUUID->"cbbf123c-1295-482e-a4b0-8aefa1c6ee99"],

Cell["Define the computational basis:", "Text",ExpressionUUID->"ae1f268b-a235-4f82-a1f2-9476ab764f74"],

Cell[BoxData[
 RowBox[{
  RowBox[{"{", 
   RowBox[{"zero", ",", " ", "one"}], "}"}], " ", "=", " ", 
  RowBox[{"IdentityMatrix", "[", "2", "]"}]}]], "Input",
 CellLabel->
  "In[92]:= ",ExpressionUUID->"9e174241-b4fe-4391-8d51-1edd8761a22d"],

Cell["Define a 2x2 density matrix:", "Text",ExpressionUUID->"05f476c4-ed7d-431b-8853-0d1f65b49804"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"r", " ", "=", " ", 
   RowBox[{"Array", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"Subscript", "[", 
       RowBox[{"\[Rho]", ",", " ", "##"}], "]"}], " ", "&"}], ",", " ", 
     RowBox[{"{", 
      RowBox[{"2", ",", " ", "2"}], "}"}]}], "]"}]}], ";"}], "\n", 
 RowBox[{"r", " ", "//", " ", "MatrixForm"}]}], "Input",
 CellLabel->
  "In[93]:= ",ExpressionUUID->"38b3fd34-2cd1-4869-9e0a-b50a671770fa"],

Cell[TextData[{
 "Compute ",
 Cell[BoxData[
  RowBox[{
   SubscriptBox[
    StyleBox["\[Rho]", "TI"], "00"], "=", 
   RowBox[{
    TemplateBox[{"0"},
     "Bra"], 
    StyleBox["\[Rho]", "TI"], 
    TemplateBox[{"0"},
     "Ket"]}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "31f6b3c5-b4db-4f9d-b516-b9cddfc083f5"],
 ":"
}], "Text",ExpressionUUID->"1d9199ca-a434-4cb0-8c2d-847de41c0729"],

Cell[BoxData[
 RowBox[{
  RowBox[{"Conjugate", "[", "zero", "]"}], " ", ".", " ", "r", " ", ".", " ", 
  "zero"}]], "Input",
 CellLabel->
  "In[94]:= ",ExpressionUUID->"fe2aa542-649a-41d6-b51b-56a3b9c353fc"],

Cell[TextData[{
 "Compute ",
 Cell[BoxData[
  RowBox[{
   SubscriptBox[
    StyleBox["\[Rho]", "TI"], "01"], "=", 
   RowBox[{
    TemplateBox[{"0"},
     "Bra"], 
    StyleBox["\[Rho]", "TI"], 
    TemplateBox[{"1"},
     "Ket"]}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "d2962a08-1dd8-4c5d-8007-4529e518b5a5"],
 ":"
}], "Text",ExpressionUUID->"8fa9285b-6892-4585-bd2a-184643595c24"],

Cell[BoxData[
 RowBox[{
  RowBox[{"Conjugate", "[", "zero", "]"}], " ", ".", " ", "r", " ", ".", " ", 
  "one"}]], "Input",
 CellLabel->
  "In[95]:= ",ExpressionUUID->"23894c81-04be-4d83-a617-278b336bc091"],

Cell[TextData[{
 "Compute ",
 Cell[BoxData[
  RowBox[{
   SubscriptBox[
    StyleBox["\[Rho]", "TI"], "10"], "=", 
   RowBox[{
    TemplateBox[{"1"},
     "Bra"], 
    StyleBox["\[Rho]", "TI"], 
    TemplateBox[{"0"},
     "Ket"]}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "ec679558-fd7d-40b6-9452-2a10c8099255"],
 ":"
}], "Text",ExpressionUUID->"80fead8f-9634-465f-bf17-e7b832ed1980"],

Cell[BoxData[
 RowBox[{
  RowBox[{"Conjugate", "[", "one", "]"}], " ", ".", " ", "r", " ", ".", " ", 
  "zero"}]], "Input",
 CellLabel->
  "In[96]:= ",ExpressionUUID->"5591422f-2153-44da-8696-04592455d3d7"],

Cell[TextData[{
 "Compute ",
 Cell[BoxData[
  RowBox[{
   SubscriptBox[
    StyleBox["\[Rho]", "TI"], "11"], "=", 
   RowBox[{
    TemplateBox[{"1"},
     "Bra"], 
    StyleBox["\[Rho]", "TI"], 
    TemplateBox[{"1"},
     "Ket"]}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "927fb538-b3b0-4ba4-a49b-08e00e86c85e"],
 ":"
}], "Text",ExpressionUUID->"25b2c160-598b-449d-892c-6a17c72d7508"],

Cell[BoxData[
 RowBox[{
  RowBox[{"Conjugate", "[", "one", "]"}], " ", ".", " ", "r", " ", ".", " ", 
  "one"}]], "Input",
 CellLabel->
  "In[97]:= ",ExpressionUUID->"4a1affaf-594b-4d0d-88f1-101d1d365acf"],

Cell["\<\
Basis-Dependence Returns: Density Matrices in Different Bases\
\>", "Subsection",ExpressionUUID->"1d8b2e5a-a56b-4626-ab3d-5cee381b05b4"],

Cell[TextData[{
 "Let\[CloseCurlyQuote]s express the same density matrix in a different \
perspective: the Pauli-X basis ",
 Cell[BoxData[
  RowBox[{"{", 
   RowBox[{
    TemplateBox[{
      SubscriptBox[
       StyleBox["x", "TI"], "+"]},
     "Ket"], ",", 
    TemplateBox[{
      SubscriptBox[
       StyleBox["x", "TI"], "-"]},
     "Ket"]}], "}"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "14ce5e81-37f6-4aeb-96e9-801ab5ed37cd"],
 "."
}], "Text",ExpressionUUID->"6ca36d1c-462e-4c3d-b78b-04079ee9dac9"],

Cell[TextData[{
 "Compute ",
 Cell[BoxData[
  RowBox[{
   SubscriptBox[
    StyleBox["\[Rho]", "TI"], 
    RowBox[{"+", "+"}]], "=", 
   StyleBox["\[LeftAngleBracket]",
    SpanMaxSize->1], 
   RowBox[{
    RowBox[{"+", "\[LeftBracketingBar]", 
     StyleBox["\[Rho]", "TI"], "\[VeryThinSpace]", "\[RightBracketingBar]"}], 
    "+"}], 
   StyleBox["\[RightAngleBracket]",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "5b07208b-e16d-44b1-b543-f81289d0602c"],
 ":"
}], "Text",ExpressionUUID->"b1684b89-6413-45d3-b4df-d999ac940585"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"Conjugate", "[", "plus", "]"}], " ", ".", " ", "r", " ", ".", " ",
    "plus"}], " ", "//", " ", "FullSimplify"}]], "Input",
 CellLabel->
  "In[98]:= ",ExpressionUUID->"4c688e01-c071-4fa9-a975-b69f9af20cd2"],

Cell[TextData[{
 "Compute ",
 Cell[BoxData[
  RowBox[{
   SubscriptBox[
    StyleBox["\[Rho]", "TI"], 
    RowBox[{"+", "-"}]], "=", 
   StyleBox["\[LeftAngleBracket]",
    SpanMaxSize->1], 
   RowBox[{
    RowBox[{"+", "\[LeftBracketingBar]", 
     StyleBox["\[Rho]", "TI"], "\[VeryThinSpace]", "\[RightBracketingBar]"}], 
    "-"}], 
   StyleBox["\[RightAngleBracket]",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "da8f8b5d-fde1-4d9d-a44f-4fc18e84788d"],
 ":"
}], "Text",ExpressionUUID->"ac668753-6c51-4cac-9142-bfc94ad6a9d0"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"Conjugate", "[", "plus", "]"}], " ", ".", " ", "r", " ", ".", " ",
    "minus"}], " ", "//", " ", "FullSimplify"}]], "Input",
 CellLabel->
  "In[99]:= ",ExpressionUUID->"5dfd7206-7d22-4309-92d6-318fa9f3ff5a"],

Cell[TextData[{
 "Compute ",
 Cell[BoxData[
  RowBox[{
   SubscriptBox[
    StyleBox["\[Rho]", "TI"], 
    RowBox[{"-", "+"}]], "=", 
   StyleBox["\[LeftAngleBracket]",
    SpanMaxSize->1], 
   RowBox[{
    RowBox[{"-", "\[LeftBracketingBar]", 
     StyleBox["\[Rho]", "TI"], "\[VeryThinSpace]", "\[RightBracketingBar]"}], 
    "+"}], 
   StyleBox["\[RightAngleBracket]",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "1a9b5cc8-cff3-40c2-835a-fda8ea7f2f85"],
 ":"
}], "Text",ExpressionUUID->"475a1b22-bf95-4432-8040-143fbc891b36"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"Conjugate", "[", "minus", "]"}], " ", ".", " ", "r", " ", ".", 
   " ", "plus"}], " ", "//", " ", "FullSimplify"}]], "Input",
 CellLabel->
  "In[100]:= ",ExpressionUUID->"b778d7a8-2b81-45f6-bbf3-b2a9760d3c1d"],

Cell[TextData[{
 "Compute ",
 Cell[BoxData[
  RowBox[{
   SubscriptBox[
    StyleBox["\[Rho]", "TI"], 
    RowBox[{"-", "-"}]], "=", 
   StyleBox["\[LeftAngleBracket]",
    SpanMaxSize->1], 
   RowBox[{
    RowBox[{"-", "\[LeftBracketingBar]", 
     StyleBox["\[Rho]", "TI"], "\[VeryThinSpace]", "\[RightBracketingBar]"}], 
    "-"}], 
   StyleBox["\[RightAngleBracket]",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "6b548a95-896c-4749-897f-47139876e0d6"],
 ":"
}], "Text",ExpressionUUID->"92e8a41b-051e-455f-9160-63fc5bc1ef11"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"Conjugate", "[", "minus", "]"}], " ", ".", " ", "r", " ", ".", 
   " ", "minus"}], " ", "//", " ", "FullSimplify"}]], "Input",
 CellLabel->
  "In[101]:= ",ExpressionUUID->"f027d4d5-1f78-42d7-b588-95945c530e12"],

Cell["\<\
As one can see, much like the state vector, the density-matrix representation \
also depends on the chosen basis. In a different basis, it takes a different \
matrix form, even though it describes the same physical state. Let\
\[CloseCurlyQuote]s remind ourselves of this feature by doing some \
computations for the state vector first, and then we will extend the same \
idea to the density matrix.\
\>", "Text",ExpressionUUID->"52ded9be-7c4a-45f0-aab1-636a7c9bf90c"],

Cell["Consider a symbolic state vector in the computational basis:", "Text",ExpressionUUID->"7d151f6b-79f0-414c-ad40-9c6c4bae461d"],

Cell[BoxData[{
 RowBox[{"ClearAll", "[", 
  RowBox[{"c0", ",", " ", "c1", ",", " ", "cR", ",", " ", "cL"}], "]"}], "\n", 
 RowBox[{
  RowBox[{"\[Psi]", " ", "=", " ", 
   RowBox[{"{", 
    RowBox[{"c0", ",", " ", "c1"}], "}"}]}], ";"}]}], "Input",
 CellLabel->
  "In[102]:= ",ExpressionUUID->"51493601-c9fe-4437-aeb0-0fd26b4a1795"],

Cell["Calculate its presentation in the Pauli-Y basis:", "Text",ExpressionUUID->"765c986d-f7c6-440b-b8c2-fdb7ed7eb57d"],

Cell[BoxData[
 RowBox[{
  RowBox[{"{", 
   RowBox[{"cR", ",", " ", "cL"}], "}"}], " ", "=", " ", 
  RowBox[{
   RowBox[{"Conjugate", "[", 
    RowBox[{"{", 
     RowBox[{"right", ",", " ", "left"}], "}"}], "]"}], " ", ".", " ", 
   "\[Psi]"}]}]], "Input",
 CellLabel->
  "In[103]:= ",ExpressionUUID->"6423b878-0e36-4d65-a5f7-1c3fabd06a99"],

Cell[TextData[{
 "Confirm that the linear combination ",
 Cell[BoxData[
  RowBox[{
   RowBox[{
    SubscriptBox[
     StyleBox["c", "TI"], "0"], 
    TemplateBox[{"0"},
     "Ket"]}], "+", 
   RowBox[{
    SubscriptBox[
     StyleBox["c", "TI"], "1"], 
    TemplateBox[{"1"},
     "Ket"]}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "be774a50-ea33-4780-8e0c-961d65562da9"],
 " describes the same state as ",
 Cell[BoxData[
  RowBox[{
   RowBox[{
    SubscriptBox[
     StyleBox["c", "TI"], 
     StyleBox["R", "TI"]], 
    TemplateBox[{
      StyleBox["R", "TI"]},
     "Ket"]}], "+", 
   RowBox[{
    SubscriptBox[
     StyleBox["c", "TI"], 
     StyleBox["L", "TI"]], 
    TemplateBox[{
      StyleBox["L", "TI"]},
     "Ket"]}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "d62c4de0-c808-4849-9ba6-6ac14ba27605"],
 ":"
}], "Text",ExpressionUUID->"4065b5ca-0a44-4249-8d23-b8d09eb3d0d4"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"{", 
     RowBox[{"cR", ",", " ", "cL"}], "}"}], " ", ".", " ", 
    RowBox[{"{", 
     RowBox[{"right", ",", " ", "left"}], "}"}]}], " ", "==", " ", 
   RowBox[{"{", 
    RowBox[{"c0", ",", " ", "c1"}], "}"}]}], " ", "//", " ", 
  "FullSimplify"}]], "Input",
 CellLabel->
  "In[104]:= ",ExpressionUUID->"9ce3cee8-1e20-461c-a3ac-051f882a0240"],

Cell[TextData[{
 "As one can see, a state vector written in a given basis is a linear \
combination of that basis\[CloseCurlyQuote]s elements, with complex \
amplitudes as coefficients. An important question, then, is: what is the \
corresponding representation for the density matrix? How do we represent a \
density operator in different bases? We have already shown how to compute \
matrix elements such as ",
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     SubscriptBox[
      StyleBox["v", "TI"], 
      StyleBox["i", "TI"]]},
    "Bra"], 
   StyleBox["\[Rho]", "TI"], 
   TemplateBox[{
     SubscriptBox[
      StyleBox["v", "TI"], 
      StyleBox["j", "TI"]]},
    "Ket"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "c6053379-d826-4058-94e1-0e0537e2d3cd"],
 ". But how do we represent the density matrix as a whole in a chosen basis, \
and how does that representation transform when we change the basis?"
}], "Text",ExpressionUUID->"fee0e873-a346-4e49-86d2-65057cb8430b"],

Cell["Outer Products and Projectors", "Subsection",ExpressionUUID->"3d4aff30-6bfe-4c85-b316-bf6b5f8436fe"],

Cell[TextData[{
 "The answer is that, once a basis ",
 Cell[BoxData[
  RowBox[{"{", 
   TemplateBox[{
     SubscriptBox[
      StyleBox["v", "TI"], 
      StyleBox["j", "TI"]]},
    "Ket"], "}"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "54daa8d6-95f2-418a-950f-192f0da425ee"],
 " is chosen, the density operator \[Rho] is represented by its matrix of \
elements ",
 Cell[BoxData[
  RowBox[{
   SubscriptBox[
    StyleBox["\[Rho]", "TI"], 
    StyleBox[
     RowBox[{"i", "j"}], "TI"]], "=", 
   RowBox[{
    TemplateBox[{
      SubscriptBox[
       StyleBox["v", "TI"], 
       StyleBox["i", "TI"]]},
     "Bra"], 
    StyleBox["\[Rho]", "TI"], 
    TemplateBox[{
      SubscriptBox[
       StyleBox["v", "TI"], 
       StyleBox["j", "TI"]]},
     "Ket"]}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "4d62eac6-0505-4407-b13d-feba43f28294"],
 ", and we can reconstruct the full operator from these numbers as ",
 Cell[BoxData[
  RowBox[{
   StyleBox["\[Rho]", "TI"], "=", 
   RowBox[{
    UnderscriptBox["\[Sum]", 
     RowBox[{
      StyleBox["i", "TI"], ",", 
      StyleBox["j", "TI"]}],
     LimitsPositioning->False], 
    RowBox[{
     SubscriptBox[
      StyleBox["\[Rho]", "TI"], 
      StyleBox[
       RowBox[{"i", "j"}], "TI"]], 
     TemplateBox[{
       SubscriptBox[
        StyleBox["v", "TI"], 
        StyleBox["i", "TI"]]},
      "Ket"], 
     TemplateBox[{
       SubscriptBox[
        StyleBox["v", "TI"], 
        StyleBox["j", "TI"]]},
      "Bra"]}]}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "f62c9cd4-5618-47d5-b167-9605901316a4"],
 ". Here ",
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     SubscriptBox[
      StyleBox["v", "TI"], 
      StyleBox["i", "TI"]]},
    "Ket"], 
   TemplateBox[{
     SubscriptBox[
      StyleBox["v", "TI"], 
      StyleBox["j", "TI"]]},
    "Bra"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "0ca7746f-0720-44fd-9bb6-d3f632967f40"],
 " is an outer product: a ket times a bra, which produces an operator (a \
matrix). In coordinates, if ",
 Cell[BoxData[
  TemplateBox[{
    SubscriptBox[
     StyleBox["v", "TI"], 
     StyleBox["i", "TI"]]},
   "Ket"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "b26ffc10-c9dd-4889-8881-2481f29ed6a2"],
 " is represented by an ",
 Cell[BoxData[
  StyleBox["n", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "49e365b0-f27e-424e-ba1d-9a3c250010d1"],
 "-component vector, then the outer product ",
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     SubscriptBox[
      StyleBox["v", "TI"], 
      StyleBox["i", "TI"]]},
    "Ket"], 
   TemplateBox[{
     SubscriptBox[
      StyleBox["v", "TI"], 
      StyleBox["j", "TI"]]},
    "Bra"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "04931800-1322-4ccd-ba80-ee8f200abeae"],
 " is an ",
 Cell[BoxData[
  RowBox[{
   StyleBox["n", "TI"], "\[Times]", 
   StyleBox["n", "TI"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "ea8fa891-7efd-4d87-93ab-a49f8d4b1500"],
 " matrix, exactly what is implemented as (vector) \[CircleTimes] (conjugate \
vector)."
}], "Text",ExpressionUUID->"b435ffbf-0401-4b22-a4e1-b9c16077fdca"],

Cell[TextData[{
 "Compute ",
 Cell[BoxData[
  RowBox[{
   TemplateBox[{"0"},
    "Ket"], 
   TemplateBox[{"0"},
    "Bra"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "40c44ad6-205f-4ce9-9085-13c871bbc597"],
 ":"
}], "Text",ExpressionUUID->"6d733d3b-79aa-4e78-997e-0105b29af0ec"],

Cell[BoxData[
 RowBox[{"MatrixForm", "@", 
  RowBox[{"TensorProduct", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"1", ",", " ", "0"}], "}"}], ",", " ", 
    RowBox[{"Conjugate", "@", 
     RowBox[{"{", 
      RowBox[{"1", ",", " ", "0"}], "}"}]}]}], "]"}]}]], "Input",
 CellLabel->
  "In[105]:= ",ExpressionUUID->"f08c206b-14f1-4738-a5a5-0ab9382bc7ae"],

Cell[TextData[{
 "Compute ",
 Cell[BoxData[
  RowBox[{
   TemplateBox[{"0"},
    "Ket"], 
   TemplateBox[{"1"},
    "Bra"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "47353c28-491e-47b4-a1c3-4686dbbff1c2"],
 ":"
}], "Text",ExpressionUUID->"e5ec29de-2ce7-46dc-9aa7-e769b41c7f91"],

Cell[BoxData[
 RowBox[{"MatrixForm", "@", 
  RowBox[{"TensorProduct", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"1", ",", " ", "0"}], "}"}], ",", " ", 
    RowBox[{"Conjugate", "@", 
     RowBox[{"{", 
      RowBox[{"0", ",", " ", "1"}], "}"}]}]}], "]"}]}]], "Input",
 CellLabel->
  "In[106]:= ",ExpressionUUID->"0cfdaaec-b9a2-4b36-8782-2162b07dd2b2"],

Cell[TextData[{
 "Compute ",
 Cell[BoxData[
  RowBox[{
   TemplateBox[{"1"},
    "Ket"], 
   TemplateBox[{"0"},
    "Bra"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "d79ecfd3-c128-468c-aced-ee1e2b7cb716"],
 ":"
}], "Text",ExpressionUUID->"95289c42-9172-4a22-979f-0df98a58d9b9"],

Cell[BoxData[
 RowBox[{"MatrixForm", "@", 
  RowBox[{"TensorProduct", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"0", ",", " ", "1"}], "}"}], ",", " ", 
    RowBox[{"Conjugate", "@", 
     RowBox[{"{", 
      RowBox[{"1", ",", " ", "0"}], "}"}]}]}], "]"}]}]], "Input",
 CellLabel->
  "In[107]:= ",ExpressionUUID->"169916fa-bc93-4020-85a7-3948981f2102"],

Cell[TextData[{
 "Compute ",
 Cell[BoxData[
  RowBox[{
   TemplateBox[{"1"},
    "Ket"], 
   TemplateBox[{"1"},
    "Bra"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "39e57a8f-6503-4dc3-8080-898c59c1bbd1"],
 ":"
}], "Text",ExpressionUUID->"61292175-edb4-40f3-b7cd-cea02c3b7cda"],

Cell[BoxData[
 RowBox[{"MatrixForm", "@", 
  RowBox[{"TensorProduct", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"0", ",", " ", "1"}], "}"}], ",", " ", 
    RowBox[{"Conjugate", "@", 
     RowBox[{"{", 
      RowBox[{"0", ",", " ", "1"}], "}"}]}]}], "]"}]}]], "Input",
 CellLabel->
  "In[108]:= ",ExpressionUUID->"d33d9a98-2bb5-4822-96f7-ebd646bfd453"],

Cell[TextData[{
 "For ",
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     SubscriptBox[
      StyleBox["v", "TI"], "1"]},
    "Ket"], "=", "{", 
   SubscriptBox[
    StyleBox["\[Alpha]", "TI"], "1"], ",", 
   SubscriptBox[
    StyleBox["\[Beta]", "TI"], "1"], "}"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "bf3d1b76-2c07-49db-8dc4-8af269f3814c"],
 " and ",
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     SubscriptBox[
      StyleBox["v", "TI"], "2"]},
    "Ket"], "=", "{", 
   SubscriptBox[
    StyleBox["\[Alpha]", "TI"], "2"], ",", 
   SubscriptBox[
    StyleBox["\[Beta]", "TI"], "2"], "}"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "82ae7c5f-78dd-4f1d-9770-cc7bb86bb524"],
 ", compute ",
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     SubscriptBox[
      StyleBox["v", "TI"], "1"]},
    "Ket"], 
   TemplateBox[{
     SubscriptBox[
      StyleBox["v", "TI"], "2"]},
    "Bra"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "20fbdcfe-388b-44a6-9bac-09d8ba88e03b"],
 ":"
}], "Text",ExpressionUUID->"b642b26e-f161-4ddc-bf5f-5815328d1b55"],

Cell[BoxData[
 RowBox[{
  RowBox[{"TensorProduct", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"\[Alpha]1", ",", " ", "\[Beta]1"}], "}"}], ",", " ", "\n", "  ", 
    RowBox[{"Conjugate", "@", 
     RowBox[{"{", 
      RowBox[{"\[Alpha]2", ",", " ", "\[Beta]2"}], "}"}]}]}], "]"}], " ", "//",
   " ", "TraditionalForm"}]], "Input",
 CellLabel->
  "In[109]:= ",ExpressionUUID->"904d6f72-a2b8-4b74-b3ab-cb533dfdff15"],

Cell[TextData[{
 "Since ",
 Cell[BoxData[
  RowBox[{"{", 
   TemplateBox[{
     SubscriptBox[
      StyleBox["v", "TI"], 
      StyleBox["j", "TI"]]},
    "Ket"], "}"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "a795161f-03ef-4a11-b30f-d42c59277fa2"],
 " are vectors, it would be same to use TensorProduct or KroneckerProduct, in \
Mathematica. Let\[CloseCurlyQuote]s verify that:"
}], "Text",ExpressionUUID->"e0c8fc50-b4a1-4877-b993-9d5c6258ad7d"],

Cell[BoxData[
 RowBox[{
  RowBox[{"KroneckerProduct", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"\[Alpha]1", ",", " ", "\[Beta]1"}], "}"}], ",", " ", "\n", "  ", 
    RowBox[{"Conjugate", "@", 
     RowBox[{"{", 
      RowBox[{"\[Alpha]2", ",", " ", "\[Beta]2"}], "}"}]}]}], "]"}], " ", "==",
   " ", "\n", " ", 
  RowBox[{"TensorProduct", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"\[Alpha]1", ",", " ", "\[Beta]1"}], "}"}], ",", " ", 
    RowBox[{"Conjugate", "@", 
     RowBox[{"{", 
      RowBox[{"\[Alpha]2", ",", " ", "\[Beta]2"}], "}"}]}]}], 
   "]"}]}]], "Input",
 CellLabel->
  "In[110]:= ",ExpressionUUID->"88e40f0c-2ee8-4bf6-8470-c52368f06cbe"],

Cell[TextData[{
 "Therefore, for a pure state ",
 Cell[BoxData[
  TemplateBox[{
    StyleBox["\[Psi]", "TI"]},
   "Ket"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "e99ca83e-c566-4af8-b0e4-c030dfe4294f"],
 ", one can compute the corresponding density operator as the projector onto \
that state as ",
 Cell[BoxData[
  RowBox[{
   StyleBox["\[Rho]", "TI"], "=", 
   RowBox[{
    TemplateBox[{
      StyleBox["\[Psi]", "TI"]},
     "Ket"], 
    TemplateBox[{
      StyleBox["\[Psi]", "TI"]},
     "Bra"]}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "1b2200ca-164b-44ea-bf98-067cc30509e8"],
 "."
}], "Text",ExpressionUUID->"a63a9a20-e65c-4ae0-be3c-12e22fb9b3ce"],

Cell[TextData[{
 "Compute the density matrix (projector) for ",
 Cell[BoxData[
  TemplateBox[{
    SubscriptBox[
     StyleBox["x", "TI"], "+"]},
   "Ket"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "7c7f8242-5c57-4e81-8174-4c0ff910d00d"],
 ":"
}], "Text",ExpressionUUID->"b655b838-b7c1-4034-8c30-fca32b821efb"],

Cell[BoxData[
 RowBox[{
  RowBox[{"TensorProduct", "[", 
   RowBox[{"plus", ",", " ", 
    RowBox[{"Conjugate", "@", "plus"}]}], "]"}], " ", "//", " ", 
  "MatrixForm"}]], "Input",
 CellLabel->
  "In[111]:= ",ExpressionUUID->"66220308-9f47-4dff-b443-0b10d114cf57"],

Cell[TextData[{
 "Compute the density matrix (projector) for ",
 Cell[BoxData[
  TemplateBox[{
    SubscriptBox[
     StyleBox["x", "TI"], "-"]},
   "Ket"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "18da53e7-cefb-4226-95bb-e66c24544fa9"],
 ":"
}], "Text",ExpressionUUID->"0be13f45-5b58-47ac-8fd8-aa968e615288"],

Cell[BoxData[
 RowBox[{
  RowBox[{"TensorProduct", "[", 
   RowBox[{"minus", ",", " ", 
    RowBox[{"Conjugate", "@", "minus"}]}], "]"}], " ", "//", " ", 
  "MatrixForm"}]], "Input",
 CellLabel->
  "In[112]:= ",ExpressionUUID->"99877a70-d1ec-44a6-ba87-099f8cde5062"],

Cell[TextData[{
 "Compute the density matrix (projector) for ",
 Cell[BoxData[
  TemplateBox[{
    SubscriptBox[
     StyleBox["y", "TI"], "+"]},
   "Ket"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "9c1da7f0-7f3d-4582-808f-2a2eb35874b8"],
 ":"
}], "Text",ExpressionUUID->"2aac622f-b106-4d96-8b93-158692142469"],

Cell[BoxData[
 RowBox[{
  RowBox[{"TensorProduct", "[", 
   RowBox[{"right", ",", " ", 
    RowBox[{"Conjugate", "@", "right"}]}], "]"}], " ", "//", " ", 
  "MatrixForm"}]], "Input",
 CellLabel->
  "In[113]:= ",ExpressionUUID->"d146ce67-9e0e-4b59-8840-2b66913c35c3"],

Cell[TextData[{
 "Compute the density matrix (projector) for ",
 Cell[BoxData[
  TemplateBox[{
    SubscriptBox[
     StyleBox["y", "TI"], "-"]},
   "Ket"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "93d967e1-0630-4a84-b834-82e9f3b59e5a"],
 ":"
}], "Text",ExpressionUUID->"e36cf961-1ee9-4163-ae5d-f01d5b5cb255"],

Cell[BoxData[
 RowBox[{
  RowBox[{"TensorProduct", "[", 
   RowBox[{"left", ",", " ", 
    RowBox[{"Conjugate", "@", "left"}]}], "]"}], " ", "//", " ", 
  "MatrixForm"}]], "Input",
 CellLabel->
  "In[114]:= ",ExpressionUUID->"7aec21c9-f6bc-42c2-964b-29bce52000bd"],

Cell[TextData[{
 "Note that all above projectors are defined in the computational basis. for \
example, the projector ",
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     SubscriptBox[
      StyleBox["y", "TI"], "+"]},
    "Ket"], 
   TemplateBox[{
     SubscriptBox[
      StyleBox["y", "TI"], "+"]},
    "Bra"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "5367d16a-a429-4c29-ac0b-7c6e4d8274c1"],
 "is given as ",
 Cell[BoxData[
  RowBox[{"(", GridBox[{
     {"1", "0"},
     {"0", "0"}
    }], ")"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "c28c330f-aa1e-43dc-ad00-7b93f3a67e2a"],
 " in the eigenbasis of Pauli-Y."
}], "Text",ExpressionUUID->"e80c9021-a1de-46b2-b1ce-c50cc0c45e93"],

Cell[TextData[{
 "Compute the density matrix for the generic pure state ",
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     StyleBox["\[Psi]", "TI"]},
    "Ket"], "=", "{", 
   StyleBox["C", "TI"], 
   StyleBox["o", "TI"], 
   StyleBox["s", "TI"], 
   StyleBox["[",
    SpanMaxSize->1], 
   StyleBox["\[Theta]", "TI"], "/", "2", 
   StyleBox["]",
    SpanMaxSize->1], ",", 
   SuperscriptBox[
    StyleBox["e", "TI"], 
    RowBox[{
     StyleBox["i", "TI"], " ", 
     StyleBox["\[Phi]", "TI"]}]], 
   StyleBox["S", "TI"], 
   StyleBox["i", "TI"], 
   StyleBox["n", "TI"], 
   StyleBox["[",
    SpanMaxSize->1], 
   StyleBox["\[Theta]", "TI"], "/", "2", 
   StyleBox["]",
    SpanMaxSize->1], "}"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "11f52678-6f4b-4c20-98e9-ab5ce7860cea"],
 ":"
}], "Text",ExpressionUUID->"df01ffc6-5f53-43bb-8c74-59eef71b6557"],

Cell[BoxData[
 RowBox[{
  RowBox[{"With", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"\[Psi]", " ", "=", " ", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"Cos", "[", 
         RowBox[{"\[Theta]", "/", "2"}], "]"}], ",", " ", 
        RowBox[{
         RowBox[{"E", "^", 
          RowBox[{"(", 
           RowBox[{"I", " ", "\[Phi]"}], ")"}]}], " ", 
         RowBox[{"Sin", "[", 
          RowBox[{"\[Theta]", "/", "2"}], "]"}]}]}], "}"}]}], "}"}], ",", " ",
     "\n", "  ", 
    RowBox[{"FullSimplify", "[", "\n", "   ", 
     RowBox[{
      RowBox[{"TensorProduct", "[", 
       RowBox[{"\[Psi]", ",", " ", "\n", "    ", 
        RowBox[{"Conjugate", "@", "\[Psi]"}]}], "]"}], ",", " ", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{"\[Theta]", " ", "|", " ", "\[Phi]"}], ")"}], " ", "\[Element]",
        " ", "\n", "    ", "Reals"}]}], "]"}]}], "]"}], " ", "//", " ", 
  "MatrixForm"}]], "Input",
 CellLabel->
  "In[115]:= ",ExpressionUUID->"07b58552-cc8b-4cd1-906d-a252acf15130"],

Cell[TextData[{
 "Note that in all previous examples, the pure state was normalized (",
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     StyleBox["\[Psi]", "TI"], 
     StyleBox["\[Psi]", "TI"]},
    "BraKet"], "=", "1"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "ceffe52f-942a-4282-94d5-7a43cdbb3f52"],
 "). This normalization is reflected in the density matrix by the fact that \
its trace is one: ",
 Cell[BoxData[
  RowBox[{
   StyleBox["T", "TI"], 
   StyleBox["r", "TI"], 
   StyleBox["[",
    SpanMaxSize->1], 
   StyleBox["\[Rho]", "TI"], 
   StyleBox["]",
    SpanMaxSize->1], "=", "1"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "f22c7601-cace-4604-a468-dfc3139c69e6"],
 ". The trace of a matrix is defined as the sum of its diagonal elements."
}], "Text",ExpressionUUID->"71c2bd9c-9dee-40c0-87a0-07fbe03f3dca"],

Cell[TextData[{
 "For a generic ",
 Cell[BoxData[
  RowBox[{"2", "\[Times]", "2"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "5ba8dc38-c031-468d-b329-d4cf20b13d7c"],
 " matrix, compute its trace:"
}], "Text",ExpressionUUID->"2241055b-d49c-4a15-8f97-8d85d54e065c"],

Cell[BoxData[
 RowBox[{"Tr", "[", 
  RowBox[{"Array", "[", 
   RowBox[{
    RowBox[{
     RowBox[{"Subscript", "[", 
      RowBox[{"\[Rho]", ",", " ", "##"}], "]"}], " ", "&"}], ",", " ", 
    RowBox[{"{", 
     RowBox[{"2", ",", " ", "2"}], "}"}]}], "]"}], "]"}]], "Input",
 CellLabel->
  "In[116]:= ",ExpressionUUID->"d180a6d7-fe74-48f4-b53a-015eb3cea7dd"],

Cell["Expectation Values via Trace", "Subsection",ExpressionUUID->"82dc3b3a-dced-4b55-881a-84bbb7100752"],

Cell[TextData[{
 "Now let\[CloseCurlyQuote]s focus on what it means for a density matrix to \
be Hermitian and positive semidefinite. Hermiticity means that \[Rho] equals \
its own conjugate transpose, ",
 Cell[BoxData[
  RowBox[{
   StyleBox["\[Rho]", "TI"], "=", 
   SuperscriptBox[
    StyleBox["\[Rho]", "TI"], "\[Dagger]"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "12ae428f-6df8-45f0-92b1-ff77b86060d7"],
 ". This guarantees that the expectation value ",
 Cell[BoxData[
  RowBox[{
   StyleBox["\[LeftAngleBracket]",
    SpanMaxSize->1], 
   StyleBox["A", "TI"], "\[VeryThinSpace]", 
   StyleBox["\[RightAngleBracket]",
    SpanMaxSize->1], "=", 
   StyleBox["T", "TI"], 
   StyleBox["r", "TI"], 
   StyleBox["[",
    SpanMaxSize->1], 
   RowBox[{
    StyleBox["\[Rho]", "TI"], ".", 
    StyleBox["A", "TI"]}], 
   StyleBox["]",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "6e29dc14-43c0-4746-a717-80e7be0a8cc3"],
 " is real for every Hermitian observable ",
 Cell[BoxData[
  StyleBox["A", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "13e7c44c-e8c1-4969-ae61-462d34ae6fde"],
 "."
}], "Text",ExpressionUUID->"46360d31-beda-40fd-9068-4ef4c068d25c"],

Cell[TextData[{
 "Compute the expectation value of Pauli-X for the generic pure state ",
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     StyleBox["\[Psi]", "TI"]},
    "Ket"], "=", "{", 
   StyleBox["C", "TI"], 
   StyleBox["o", "TI"], 
   StyleBox["s", "TI"], 
   StyleBox["[",
    SpanMaxSize->1], 
   StyleBox["\[Theta]", "TI"], "/", "2", 
   StyleBox["]",
    SpanMaxSize->1], ",", 
   SuperscriptBox[
    StyleBox["e", "TI"], 
    RowBox[{
     StyleBox["i", "TI"], " ", 
     StyleBox["\[Phi]", "TI"]}]], 
   StyleBox["S", "TI"], 
   StyleBox["i", "TI"], 
   StyleBox["n", "TI"], 
   StyleBox["[",
    SpanMaxSize->1], 
   StyleBox["\[Theta]", "TI"], "/", "2", 
   StyleBox["]",
    SpanMaxSize->1], "}"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "4073e28d-ceb5-4e5f-8019-1d94c352164f"],
 " as ",
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     StyleBox["\[Psi]", "TI"]},
    "Bra"], 
   SubscriptBox[
    StyleBox["\[Sigma]", "TI"], 
    StyleBox["x", "TI"]], 
   TemplateBox[{
     StyleBox["\[Psi]", "TI"]},
    "Ket"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "294fc88d-020f-4bf4-bc9d-9646d0cffc24"],
 ":"
}], "Text",ExpressionUUID->"e0f61c35-c112-4c35-a8d0-6afa6ddba4db"],

Cell[BoxData[
 RowBox[{"With", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"\[Psi]", " ", "=", " ", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"Cos", "[", 
        RowBox[{"\[Theta]", "/", "2"}], "]"}], ",", " ", 
       RowBox[{
        RowBox[{"E", "^", 
         RowBox[{"(", 
          RowBox[{"I", " ", "\[Phi]"}], ")"}]}], " ", 
        RowBox[{"Sin", "[", 
         RowBox[{"\[Theta]", "/", "2"}], "]"}]}]}], "}"}]}], "}"}], ",", " ", 
   "\n", " ", 
   RowBox[{"FullSimplify", "[", "\n", "  ", 
    RowBox[{
     RowBox[{
      RowBox[{"Conjugate", "[", "\[Psi]", "]"}], " ", ".", " ", "\n", "   ", 
      RowBox[{"PauliMatrix", "[", "1", "]"}], " ", ".", " ", "\[Psi]"}], ",", 
     " ", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{"\[Theta]", " ", "|", " ", "\[Phi]"}], ")"}], " ", "\[Element]",
       " ", "Reals"}]}], "]"}]}], "]"}]], "Input",
 CellLabel->
  "In[117]:= ",ExpressionUUID->"3fd4bba7-14bc-433a-ab1d-7ef1b0c419fa"],

Cell[TextData[{
 "Compute the expectation value of Pauli-X for the generic pure state ",
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     StyleBox["\[Psi]", "TI"]},
    "Ket"], "=", "{", 
   StyleBox["C", "TI"], 
   StyleBox["o", "TI"], 
   StyleBox["s", "TI"], 
   StyleBox["[",
    SpanMaxSize->1], 
   StyleBox["\[Theta]", "TI"], "/", "2", 
   StyleBox["]",
    SpanMaxSize->1], ",", 
   SuperscriptBox[
    StyleBox["e", "TI"], 
    RowBox[{
     StyleBox["i", "TI"], " ", 
     StyleBox["\[Phi]", "TI"]}]], 
   StyleBox["S", "TI"], 
   StyleBox["i", "TI"], 
   StyleBox["n", "TI"], 
   StyleBox["[",
    SpanMaxSize->1], 
   StyleBox["\[Theta]", "TI"], "/", "2", 
   StyleBox["]",
    SpanMaxSize->1], "}"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "78e6c584-9cdb-4234-8b5a-7bd9b1eae215"],
 " as ",
 Cell[BoxData[
  RowBox[{
   StyleBox["Tr",
    FontSlant->"Plain"], 
   StyleBox["[",
    SpanMaxSize->1], 
   RowBox[{
    StyleBox["\[Rho]", "TI"], ".", 
    SubscriptBox[
     StyleBox["\[Sigma]", "TI"], 
     StyleBox["x", "TI"]]}], 
   StyleBox["]",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "cc90fca6-503f-423d-921d-2c0b80f8ff21"],
 ":"
}], "Text",ExpressionUUID->"24ddd7fe-aec2-4e15-a73c-b59b599b6c4a"],

Cell[BoxData[
 RowBox[{"With", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"\[Psi]", " ", "=", " ", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"Cos", "[", 
        RowBox[{"\[Theta]", "/", "2"}], "]"}], ",", " ", "\n", "    ", 
       RowBox[{
        RowBox[{"E", "^", 
         RowBox[{"(", 
          RowBox[{"I", " ", "\[Phi]"}], ")"}]}], " ", 
        RowBox[{"Sin", "[", 
         RowBox[{"\[Theta]", "/", "2"}], "]"}]}]}], "}"}]}], "}"}], ",", " ", 
   
   RowBox[{"{", 
    RowBox[{"\[Rho]", " ", "=", " ", "\n", "   ", 
     RowBox[{"TensorProduct", "[", 
      RowBox[{"\[Psi]", ",", " ", 
       RowBox[{"Conjugate", "@", "\[Psi]"}]}], "]"}]}], "}"}], ",", " ", "\n",
    " ", 
   RowBox[{"FullSimplify", "[", "\n", "  ", 
    RowBox[{
     RowBox[{"Tr", "[", 
      RowBox[{
       RowBox[{"PauliMatrix", "[", "1", "]"}], " ", ".", " ", "\[Rho]"}], 
      "]"}], ",", " ", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{"\[Theta]", " ", "|", " ", "\[Phi]"}], ")"}], " ", "\[Element]",
       " ", "Reals"}]}], "]"}]}], "]"}]], "Input",
 CellLabel->
  "In[118]:= ",ExpressionUUID->"077e5ecc-50cd-43a7-84fc-626a684385b8"],

Cell[TextData[{
 "Compute the expectation value of Pauli-Y for the generic pure state ",
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     StyleBox["\[Psi]", "TI"]},
    "Ket"], "=", "{", 
   StyleBox["C", "TI"], 
   StyleBox["o", "TI"], 
   StyleBox["s", "TI"], 
   StyleBox["[",
    SpanMaxSize->1], 
   StyleBox["\[Theta]", "TI"], "/", "2", 
   StyleBox["]",
    SpanMaxSize->1], ",", 
   SuperscriptBox[
    StyleBox["e", "TI"], 
    RowBox[{
     StyleBox["i", "TI"], " ", 
     StyleBox["\[Phi]", "TI"]}]], 
   StyleBox["S", "TI"], 
   StyleBox["i", "TI"], 
   StyleBox["n", "TI"], 
   StyleBox["[",
    SpanMaxSize->1], 
   StyleBox["\[Theta]", "TI"], "/", "2", 
   StyleBox["]",
    SpanMaxSize->1], "}"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "8e15317c-fb7a-42be-992e-194478563fbd"],
 " as ",
 Cell[BoxData[
  RowBox[{
   StyleBox["Tr",
    FontSlant->"Plain"], 
   StyleBox["[",
    SpanMaxSize->1], 
   RowBox[{
    StyleBox["\[Rho]", "TI"], ".", 
    SubscriptBox[
     StyleBox["\[Sigma]", "TI"], 
     StyleBox["y", "TI"]]}], 
   StyleBox["]",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "609a751c-34d5-41c3-bbeb-1e45840329ba"],
 ":"
}], "Text",ExpressionUUID->"a245b72c-5565-4218-b6c9-92b91136dd0f"],

Cell[BoxData[
 RowBox[{"With", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"\[Psi]", " ", "=", " ", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"Cos", "[", 
        RowBox[{"\[Theta]", "/", "2"}], "]"}], ",", " ", "\n", "    ", 
       RowBox[{
        RowBox[{"E", "^", 
         RowBox[{"(", 
          RowBox[{"I", " ", "\[Phi]"}], ")"}]}], " ", 
        RowBox[{"Sin", "[", 
         RowBox[{"\[Theta]", "/", "2"}], "]"}]}]}], "}"}]}], "}"}], ",", " ", 
   
   RowBox[{"{", 
    RowBox[{"\[Rho]", " ", "=", " ", "\n", "   ", 
     RowBox[{"TensorProduct", "[", 
      RowBox[{"\[Psi]", ",", " ", 
       RowBox[{"Conjugate", "@", "\[Psi]"}]}], "]"}]}], "}"}], ",", " ", "\n",
    " ", 
   RowBox[{"FullSimplify", "[", "\n", "  ", 
    RowBox[{
     RowBox[{"Tr", "[", 
      RowBox[{
       RowBox[{"PauliMatrix", "[", "2", "]"}], " ", ".", " ", "\[Rho]"}], 
      "]"}], ",", " ", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{"\[Theta]", " ", "|", " ", "\[Phi]"}], ")"}], " ", "\[Element]",
       " ", "Reals"}]}], "]"}]}], "]"}]], "Input",
 CellLabel->
  "In[119]:= ",ExpressionUUID->"f1127a08-c0e7-4a78-a034-3a34672080ed"],

Cell[TextData[{
 "Compute the expectation value of Pauli-Z for the generic pure state ",
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     StyleBox["\[Psi]", "TI"]},
    "Ket"], "=", "{", 
   StyleBox["C", "TI"], 
   StyleBox["o", "TI"], 
   StyleBox["s", "TI"], 
   StyleBox["[",
    SpanMaxSize->1], 
   StyleBox["\[Theta]", "TI"], "/", "2", 
   StyleBox["]",
    SpanMaxSize->1], ",", 
   SuperscriptBox[
    StyleBox["e", "TI"], 
    RowBox[{
     StyleBox["i", "TI"], " ", 
     StyleBox["\[Phi]", "TI"]}]], 
   StyleBox["S", "TI"], 
   StyleBox["i", "TI"], 
   StyleBox["n", "TI"], 
   StyleBox["[",
    SpanMaxSize->1], 
   StyleBox["\[Theta]", "TI"], "/", "2", 
   StyleBox["]",
    SpanMaxSize->1], "}"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "f52eb622-f5c6-4606-8cff-ee0a3482bb69"],
 " as ",
 Cell[BoxData[
  RowBox[{
   StyleBox["Tr",
    FontSlant->"Plain"], 
   StyleBox["[",
    SpanMaxSize->1], 
   RowBox[{
    StyleBox["\[Rho]", "TI"], ".", 
    SubscriptBox[
     StyleBox["\[Sigma]", "TI"], 
     StyleBox["z", "TI"]]}], 
   StyleBox["]",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "640191ae-ca51-4aff-b63b-619c1c231493"],
 ":"
}], "Text",ExpressionUUID->"f2a04b08-d936-430d-a222-28adb24e4ebb"],

Cell[BoxData[
 RowBox[{"With", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"\[Psi]", " ", "=", " ", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"Cos", "[", 
        RowBox[{"\[Theta]", "/", "2"}], "]"}], ",", " ", "\n", "    ", 
       RowBox[{
        RowBox[{"E", "^", 
         RowBox[{"(", 
          RowBox[{"I", " ", "\[Phi]"}], ")"}]}], " ", 
        RowBox[{"Sin", "[", 
         RowBox[{"\[Theta]", "/", "2"}], "]"}]}]}], "}"}]}], "}"}], ",", " ", 
   
   RowBox[{"{", 
    RowBox[{"\[Rho]", " ", "=", " ", "\n", "   ", 
     RowBox[{"TensorProduct", "[", 
      RowBox[{"\[Psi]", ",", " ", 
       RowBox[{"Conjugate", "@", "\[Psi]"}]}], "]"}]}], "}"}], ",", " ", "\n",
    " ", 
   RowBox[{"FullSimplify", "[", "\n", "  ", 
    RowBox[{
     RowBox[{"Tr", "[", 
      RowBox[{
       RowBox[{"PauliMatrix", "[", "3", "]"}], " ", ".", " ", "\[Rho]"}], 
      "]"}], ",", " ", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{"\[Theta]", " ", "|", " ", "\[Phi]"}], ")"}], " ", "\[Element]",
       " ", "Reals"}]}], "]"}]}], "]"}]], "Input",
 CellLabel->
  "In[120]:= ",ExpressionUUID->"a75108b2-c3af-44d9-b8f3-714b0e8706c5"],

Cell[TextData[{
 "Have you noticed something interesting about the expectation values of the \
Pauli operators we calculated above? Let\[CloseCurlyQuote]s recall an \
important feature: for the pure qubit state ",
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     StyleBox["\[Psi]", "TI"]},
    "Ket"], "=", "{", 
   StyleBox["C", "TI"], 
   StyleBox["o", "TI"], 
   StyleBox["s", "TI"], 
   StyleBox["[",
    SpanMaxSize->1], 
   StyleBox["\[Theta]", "TI"], "/", "2", 
   StyleBox["]",
    SpanMaxSize->1], ",", 
   SuperscriptBox[
    StyleBox["e", "TI"], 
    RowBox[{
     StyleBox["i", "TI"], " ", 
     StyleBox["\[Phi]", "TI"]}]], 
   StyleBox["S", "TI"], 
   StyleBox["i", "TI"], 
   StyleBox["n", "TI"], 
   StyleBox["[",
    SpanMaxSize->1], 
   StyleBox["\[Theta]", "TI"], "/", "2", 
   StyleBox["]",
    SpanMaxSize->1], "}"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "ab769afa-68bc-4875-8d9d-6eb14ae99230"],
 ", the corresponding Bloch vector is the unit vector ",
 Cell[BoxData[
  RowBox[{
   RowBox[{
    OverscriptBox[
     StyleBox["n", "TI"], "\[RightVector]"], "=", "{", 
    StyleBox["C", "TI"], 
    StyleBox["o", "TI"], 
    StyleBox["s", "TI"], 
    StyleBox["[",
     SpanMaxSize->1], 
    StyleBox["\[Phi]", "TI"], 
    StyleBox["]",
     SpanMaxSize->1], 
    StyleBox["S", "TI"], 
    StyleBox["i", "TI"], 
    StyleBox["n", "TI"], 
    StyleBox["[",
     SpanMaxSize->1], 
    StyleBox["\[Theta]", "TI"], 
    StyleBox["]",
     SpanMaxSize->1]}], ",", 
   RowBox[{
    StyleBox["S", "TI"], 
    StyleBox["i", "TI"], 
    StyleBox["n", "TI"], 
    StyleBox["[",
     SpanMaxSize->1], 
    StyleBox["\[Phi]", "TI"], 
    StyleBox["]",
     SpanMaxSize->1], 
    StyleBox["S", "TI"], 
    StyleBox["i", "TI"], 
    StyleBox["n", "TI"], 
    StyleBox["[",
     SpanMaxSize->1], 
    StyleBox["\[Theta]", "TI"], 
    StyleBox["]",
     SpanMaxSize->1]}], ",", 
   RowBox[{
    StyleBox["C", "TI"], 
    StyleBox["o", "TI"], 
    StyleBox["s", "TI"], 
    StyleBox["[",
     SpanMaxSize->1], 
    StyleBox["\[Theta]", "TI"], 
    StyleBox["]",
     SpanMaxSize->1], "}"}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "c0364e54-919d-4044-9734-c402c827c11c"],
 ". As you may have noticed, the expectation values of the Pauli operators \
match the components of this Bloch vector: ",
 Cell[BoxData[
  RowBox[{
   RowBox[{
    OverscriptBox[
     StyleBox["n", "TI"], "\[RightVector]"], "=", "{", 
    StyleBox["\[LeftAngleBracket]",
     SpanMaxSize->1], 
    SubscriptBox[
     StyleBox["\[Sigma]", "TI"], 
     StyleBox["x", "TI"]], 
    StyleBox["\[RightAngleBracket]",
     SpanMaxSize->1]}], ",", 
   RowBox[{
    StyleBox["\[LeftAngleBracket]",
     SpanMaxSize->1], 
    SubscriptBox[
     StyleBox["\[Sigma]", "TI"], 
     StyleBox["y", "TI"]], 
    StyleBox["\[RightAngleBracket]",
     SpanMaxSize->1]}], ",", 
   RowBox[{
    StyleBox["\[LeftAngleBracket]",
     SpanMaxSize->1], 
    SubscriptBox[
     StyleBox["\[Sigma]", "TI"], 
     StyleBox["z", "TI"]], 
    StyleBox["\[RightAngleBracket]",
     SpanMaxSize->1], "}"}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "783133c1-1231-4144-9ef9-d63e157ccea5"],
 "."
}], "Text",ExpressionUUID->"5853cdb9-2a28-4dd8-a4d3-a1edd80c212e"],

Cell["Hermiticity Condition on Density Matrices", "Subsection",ExpressionUUID->"5b7fa1e7-3e0a-4713-87e8-73ce373b0cdd"],

Cell[TextData[{
 "Pauli operators together with the identity form a complete basis for the \
space of linear operators on a two-dimensional Hilbert space. In other words, \
",
 Cell[BoxData[
  RowBox[{
   RowBox[{"{", "\|01d540"}], ",", 
   SubscriptBox[
    StyleBox["\[Sigma]", "TI"], 
    StyleBox["x", "TI"]], ",", 
   SubscriptBox[
    StyleBox["\[Sigma]", "TI"], 
    StyleBox["y", "TI"]], ",", 
   RowBox[{
    SubscriptBox[
     StyleBox["\[Sigma]", "TI"], 
     StyleBox["z", "TI"]], "}"}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "d1d17de7-d2af-4260-bc55-42aae06c0509"],
 " is a complete basis. This means any operator can be written as a linear \
superposition of these basis operators. In particular, one can write the \
density matrix as ",
 Cell[BoxData[
  RowBox[{
   StyleBox["\[Rho]", "TI"], "=", 
   SubscriptBox[
    StyleBox["c", "TI"], "0"], "\|01d540", "+", 
   SubscriptBox[
    StyleBox["c", "TI"], "1"], 
   SubscriptBox[
    StyleBox["\[Sigma]", "TI"], 
    StyleBox["x", "TI"]], "+", 
   SubscriptBox[
    StyleBox["c", "TI"], "2"], 
   SubscriptBox[
    StyleBox["\[Sigma]", "TI"], 
    StyleBox["y", "TI"]], "+", 
   SubscriptBox[
    StyleBox["c", "TI"], "3"], 
   SubscriptBox[
    StyleBox["\[Sigma]", "TI"], 
    StyleBox["z", "TI"]]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "0df306d0-a81e-4027-8868-07c451bf412c"],
 ". Let\[CloseCurlyQuote]s explore these coefficients in more detail."
}], "Text",ExpressionUUID->"fbfe54b1-4955-48cf-a886-bc6aa23ca6eb"],

Cell[TextData[{
 "Show ",
 Cell[BoxData[
  RowBox[{
   StyleBox["\[Rho]", "TI"], "=", 
   SubscriptBox[
    StyleBox["c", "TI"], "0"], "\|01d540", "+", 
   SubscriptBox[
    StyleBox["c", "TI"], "1"], 
   SubscriptBox[
    StyleBox["\[Sigma]", "TI"], 
    StyleBox["x", "TI"]], "+", 
   SubscriptBox[
    StyleBox["c", "TI"], "2"], 
   SubscriptBox[
    StyleBox["\[Sigma]", "TI"], 
    StyleBox["y", "TI"]], "+", 
   SubscriptBox[
    StyleBox["c", "TI"], "3"], 
   SubscriptBox[
    StyleBox["\[Sigma]", "TI"], 
    StyleBox["z", "TI"]]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "80ba6217-0597-4f86-8e93-76a743f94100"],
 " in the matrix form:"
}], "Text",ExpressionUUID->"43f4e13c-9840-49bf-971b-c62dc6d5acaa"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"Array", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"Subscript", "[", 
       RowBox[{"c", ",", " ", "#"}], "]"}], " ", "&"}], ",", " ", "4", ",", 
     " ", "0"}], "]"}], " ", ".", " ", "\n", "  ", 
   RowBox[{"Table", "[", 
    RowBox[{
     RowBox[{"PauliMatrix", "[", "j", "]"}], ",", " ", 
     RowBox[{"{", 
      RowBox[{"j", ",", " ", "0", ",", " ", "3"}], "}"}]}], "]"}]}], " ", "//",
   " ", "MatrixForm"}]], "Input",
 CellLabel->
  "In[121]:= ",ExpressionUUID->"3e4d6d91-e261-4b5c-b4b3-c73c836e3730"],

Cell["\<\
Pauli operators are traceless matrices, meaning their trace is zero.\
\>", "Text",ExpressionUUID->"54d0a5dc-f34b-4828-9050-7e773cc27d32"],

Cell["Verify that Pauli operators are traceless:", "Text",ExpressionUUID->"58f10f76-2fd9-4009-8822-558ee3426adc"],

Cell[BoxData[
 RowBox[{"Tr", " ", "/@", " ", 
  RowBox[{"Table", "[", 
   RowBox[{
    RowBox[{"PauliMatrix", "[", "j", "]"}], ",", " ", 
    RowBox[{"{", 
     RowBox[{"j", ",", " ", "3"}], "}"}]}], "]"}]}]], "Input",
 CellLabel->
  "In[122]:= ",ExpressionUUID->"d04848f7-767f-45fd-be65-6098639e4944"],

Cell[TextData[{
 "Therefore, one finds: ",
 Cell[BoxData[
  RowBox[{
   StyleBox["T", "TI"], 
   StyleBox["r", "TI"], 
   StyleBox["[",
    SpanMaxSize->1], 
   StyleBox["\[Rho]", "TI"], 
   StyleBox["]",
    SpanMaxSize->1], "=", 
   SubscriptBox[
    StyleBox["c", "TI"], "0"], 
   StyleBox["T", "TI"], 
   StyleBox["r", "TI"], 
   StyleBox["[",
    SpanMaxSize->1], "\|01d540", 
   StyleBox["]",
    SpanMaxSize->1], "=", "2", 
   SubscriptBox[
    StyleBox["c", "TI"], "0"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "2efa77a6-494e-4a7d-9edf-c4fcf5fba8ab"],
 "."
}], "Text",ExpressionUUID->"91e0748b-0c35-4967-b372-23d939af5df1"],

Cell[TextData[{
 "Verify that ",
 Cell[BoxData[
  RowBox[{
   StyleBox["T", "TI"], 
   StyleBox["r", "TI"], 
   StyleBox["[",
    SpanMaxSize->1], 
   StyleBox["\[Rho]", "TI"], 
   StyleBox["]",
    SpanMaxSize->1], "=", "2", 
   SubscriptBox[
    StyleBox["c", "TI"], "0"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "8eb03dfe-3ac8-4413-a679-16cfc8471b1c"],
 " with ",
 Cell[BoxData[
  RowBox[{
   StyleBox["\[Rho]", "TI"], "=", 
   SubscriptBox[
    StyleBox["c", "TI"], "0"], "\|01d540", "+", 
   SubscriptBox[
    StyleBox["c", "TI"], "1"], 
   SubscriptBox[
    StyleBox["\[Sigma]", "TI"], 
    StyleBox["x", "TI"]], "+", 
   SubscriptBox[
    StyleBox["c", "TI"], "2"], 
   SubscriptBox[
    StyleBox["\[Sigma]", "TI"], 
    StyleBox["y", "TI"]], "+", 
   SubscriptBox[
    StyleBox["c", "TI"], "3"], 
   SubscriptBox[
    StyleBox["\[Sigma]", "TI"], 
    StyleBox["z", "TI"]]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "83e327a5-2bf1-469c-a343-c8b984c6d762"],
 ":"
}], "Text",ExpressionUUID->"7896e357-8278-4619-828d-153bb4b3bcaa"],

Cell[BoxData[
 RowBox[{"Tr", "[", 
  RowBox[{
   RowBox[{"Array", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"Subscript", "[", 
       RowBox[{"c", ",", " ", "#"}], "]"}], " ", "&"}], ",", " ", "4", ",", 
     " ", "0"}], "]"}], " ", ".", " ", 
   RowBox[{"Table", "[", 
    RowBox[{
     RowBox[{"PauliMatrix", "[", "j", "]"}], ",", " ", 
     RowBox[{"{", 
      RowBox[{"j", ",", " ", "0", ",", " ", "3"}], "}"}]}], "]"}]}], 
  "]"}]], "Input",
 CellLabel->
  "In[123]:= ",ExpressionUUID->"57111a3d-6b8c-485f-a3e7-1aef4183a4c0"],

Cell[TextData[{
 "Assuming that the density matrix is normalized, this implies that ",
 Cell[BoxData[
  RowBox[{
   SubscriptBox[
    StyleBox["c", "TI"], "0"], "=", "1", "/", "2"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "ad403d8f-5756-44cc-88eb-bd78b6a4c932"],
 ". Therefore, we can rescale the coefficients ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["c", "TI"], 
   StyleBox["\[Mu]", "TI"]]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "fe0d8d3a-c434-495a-a52b-27ae9150d2b0"],
 " by a factor 2, and write: ",
 Cell[BoxData[
  RowBox[{
   StyleBox["\[Rho]", "TI"], "=", "1", "/", "2", 
   StyleBox["(",
    SpanMaxSize->1], 
   RowBox[{"\|01d540", "+", 
    SubscriptBox[
     StyleBox["r", "TI"], 
     StyleBox["x", "TI"]], 
    SubscriptBox[
     StyleBox["\[Sigma]", "TI"], 
     StyleBox["x", "TI"]], "+", 
    SubscriptBox[
     StyleBox["r", "TI"], 
     StyleBox["y", "TI"]], 
    SubscriptBox[
     StyleBox["\[Sigma]", "TI"], 
     StyleBox["y", "TI"]], "+", 
    SubscriptBox[
     StyleBox["r", "TI"], 
     StyleBox["z", "TI"]], 
    SubscriptBox[
     StyleBox["\[Sigma]", "TI"], 
     StyleBox["z", "TI"]]}], 
   StyleBox[")",
    SpanMaxSize->1], "=", "1", "/", "2", 
   StyleBox["(",
    SpanMaxSize->1], 
   RowBox[{
    RowBox[{"\|01d540", "+", 
     OverscriptBox[
      StyleBox["r", "TI"], "\[RightVector]"]}], ".", 
    OverscriptBox[
     StyleBox["\[Sigma]", "TI"], "\[RightVector]"]}], 
   StyleBox[")",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "b2cfdaf3-0358-4034-9234-df442648f776"],
 " with ",
 Cell[BoxData[
  RowBox[{
   RowBox[{
    OverscriptBox[
     StyleBox["r", "TI"], "\[RightVector]"], "=", "{", 
    SubscriptBox[
     StyleBox["r", "TI"], 
     StyleBox["x", "TI"]]}], ",", 
   SubscriptBox[
    StyleBox["r", "TI"], 
    StyleBox["y", "TI"]], ",", 
   RowBox[{
    SubscriptBox[
     StyleBox["r", "TI"], 
     StyleBox["z", "TI"]], "}"}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "df225746-7578-4da5-a798-77ddc585248d"],
 " the Bloch vector and ",
 Cell[BoxData[
  RowBox[{
   RowBox[{
    OverscriptBox[
     StyleBox["\[Sigma]", "TI"], "\[RightVector]"], "=", "{", 
    SubscriptBox[
     StyleBox["\[Sigma]", "TI"], 
     StyleBox["x", "TI"]]}], ",", 
   SubscriptBox[
    StyleBox["\[Sigma]", "TI"], 
    StyleBox["y", "TI"]], ",", 
   RowBox[{
    SubscriptBox[
     StyleBox["\[Sigma]", "TI"], 
     StyleBox["z", "TI"]], "}"}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "95cab5e6-3168-4ff9-a602-b49a2ab76dac"],
 ". This representation automatically implies unit trace."
}], "Text",ExpressionUUID->"9005d8db-89f3-4446-b69b-3d45c6c255e5"],

Cell[TextData[{
 "Define a function that takes a Bloch vector in Cartesian form (",
 Cell[BoxData[
  RowBox[{
   RowBox[{"{", 
    SubscriptBox[
     StyleBox["r", "TI"], 
     StyleBox["x", "TI"]]}], ",", 
   SubscriptBox[
    StyleBox["r", "TI"], 
    StyleBox["y", "TI"]], ",", 
   RowBox[{
    SubscriptBox[
     StyleBox["r", "TI"], 
     StyleBox["z", "TI"]], "}"}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "367d7408-6b64-4e2f-862d-c8ba81424c4a"],
 ") and returns the corresponding qubit density matrix:"
}], "Text",ExpressionUUID->"d2d77000-fddc-4c40-9236-5a38d4dc890d"],

Cell[BoxData[
 RowBox[{
  RowBox[{"DensityMatrix", "[", 
   RowBox[{"{", 
    RowBox[{"rx_", ",", " ", "ry_", ",", " ", "rz_"}], "}"}], "]"}], " ", ":=",
   " ", "\n", " ", 
  RowBox[{
   RowBox[{"1", "/", "2"}], " ", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"1", ",", " ", "rx", ",", " ", "ry", ",", " ", "rz"}], "}"}], 
    " ", ".", " ", 
    RowBox[{"Table", "[", 
     RowBox[{
      RowBox[{"PauliMatrix", "[", "j", "]"}], ",", " ", 
      RowBox[{"{", 
       RowBox[{"j", ",", " ", "0", ",", " ", "3"}], "}"}]}], 
     "]"}]}]}]}]], "Input",
 CellLabel->
  "In[124]:= ",ExpressionUUID->"f9c16dfe-8fc2-4759-b96f-3c3cdca73a64"],

Cell[TextData[{
 "Calculate trace of \[Rho] with ",
 Cell[BoxData[
  RowBox[{
   StyleBox["\[Rho]", "TI"], "=", "1", "/", "2", 
   StyleBox["(",
    SpanMaxSize->1], 
   RowBox[{
    RowBox[{"\|01d540", "+", 
     OverscriptBox[
      StyleBox["r", "TI"], "\[RightVector]"]}], ".", 
    OverscriptBox[
     StyleBox["\[Sigma]", "TI"], "\[RightVector]"]}], 
   StyleBox[")",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "633aecba-f0f0-4361-bf92-a3782d9c1528"],
 ":"
}], "Text",ExpressionUUID->"db589e43-19e5-4c6b-b8d1-c3b279ef9224"],

Cell[BoxData[{
 RowBox[{"ClearAll", "[", 
  RowBox[{"rx", ",", " ", "ry", ",", " ", "rz"}], "]"}], "\n", 
 RowBox[{
  RowBox[{"Tr", "[", 
   RowBox[{"DensityMatrix", "[", 
    RowBox[{"{", 
     RowBox[{"rx", ",", " ", "ry", ",", " ", "rz"}], "}"}], "]"}], "]"}], " ",
   "//", " ", "FullSimplify"}]}], "Input",
 CellLabel->
  "In[125]:= ",ExpressionUUID->"69b7d635-382c-4ad7-8b30-710b8cc7d38f"],

Cell[TextData[{
 "Given ",
 Cell[BoxData[
  RowBox[{
   StyleBox["\[Rho]", "TI"], "=", "1", "/", "2", 
   StyleBox["(",
    SpanMaxSize->1], 
   RowBox[{
    RowBox[{"\|01d540", "+", 
     OverscriptBox[
      StyleBox["r", "TI"], "\[RightVector]"]}], ".", 
    OverscriptBox[
     StyleBox["\[Sigma]", "TI"], "\[RightVector]"]}], 
   StyleBox[")",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "20e862fa-baa9-4417-9594-6ffc0229581d"],
 ", verify that ",
 Cell[BoxData[
  RowBox[{
   StyleBox["d", "TI"], 
   StyleBox["e", "TI"], 
   StyleBox["t", "TI"], 
   StyleBox["[",
    SpanMaxSize->1], 
   StyleBox["\[Rho]", "TI"], 
   StyleBox["]",
    SpanMaxSize->1], "=", "1", "/", "4", 
   StyleBox["(",
    SpanMaxSize->1], 
   RowBox[{"1", "-", 
    SuperscriptBox[
     StyleBox["r", "TI"], "2"]}], 
   StyleBox[")",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "55dcddd5-be85-42fa-8053-0cde656355b8"],
 ":"
}], "Text",ExpressionUUID->"889da66f-cdca-49d4-b052-feb5ca81d0bf"],

Cell[BoxData[
 RowBox[{
  RowBox[{"Det", "[", 
   RowBox[{"DensityMatrix", "[", 
    RowBox[{"{", 
     RowBox[{"rx", ",", " ", "ry", ",", " ", "rz"}], "}"}], "]"}], "]"}], " ",
   "//", " ", "FullSimplify"}]], "Input",
 CellLabel->
  "In[126]:= ",ExpressionUUID->"47155a2c-5a9a-4490-9090-7001af682bc2"],

Cell[TextData[{
 "Now let\[CloseCurlyQuote]s impose Hermiticity on the density matrix. Since \
the density matrix ",
 Cell[BoxData[
  RowBox[{
   StyleBox["\[Rho]", "TI"], "=", "1", "/", "2", 
   StyleBox["(",
    SpanMaxSize->1], 
   RowBox[{
    RowBox[{"\|01d540", "+", 
     OverscriptBox[
      StyleBox["r", "TI"], "\[RightVector]"]}], ".", 
    OverscriptBox[
     StyleBox["\[Sigma]", "TI"], "\[RightVector]"]}], 
   StyleBox[")",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "15129623-c598-45f6-a4bb-ab46306f1719"],
 " must satisfy ",
 Cell[BoxData[
  RowBox[{
   StyleBox["\[Rho]", "TI"], "=", 
   SuperscriptBox[
    StyleBox["\[Rho]", "TI"], "\[Dagger]"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "2422cc74-5b89-46ec-83b9-15cfe33d21ab"],
 ", and Pauli matrices are Hermitian, the immediate consequence is that the \
coefficients ",
 Cell[BoxData[
  RowBox[{
   RowBox[{"{", 
    SubscriptBox[
     StyleBox["r", "TI"], 
     StyleBox["x", "TI"]]}], ",", 
   SubscriptBox[
    StyleBox["r", "TI"], 
    StyleBox["y", "TI"]], ",", 
   RowBox[{
    SubscriptBox[
     StyleBox["r", "TI"], 
     StyleBox["z", "TI"]], "}"}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "048c5674-7db3-49ee-998b-2e98d4e3846b"],
 " must be real numbers. In other words, ",
 Cell[BoxData[
  OverscriptBox[
   StyleBox["r", "TI"], "\[RightVector]"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "6ee76fee-ea12-49df-8cba-df72ecbb84df"],
 " must be a real vector."
}], "Text",ExpressionUUID->"9dfa380e-aa3b-4a75-b06b-59b86c7e204a"],

Cell[TextData[{
 "Impose Hermiticity of ",
 Cell[BoxData[
  RowBox[{
   StyleBox["\[Rho]", "TI"], "=", "1", "/", "2", 
   StyleBox["(",
    SpanMaxSize->1], 
   RowBox[{
    RowBox[{"\|01d540", "+", 
     OverscriptBox[
      StyleBox["r", "TI"], "\[RightVector]"]}], ".", 
    OverscriptBox[
     StyleBox["\[Sigma]", "TI"], "\[RightVector]"]}], 
   StyleBox[")",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "f08a0151-846d-4cb0-95fe-eda850f580a0"],
 ":"
}], "Text",ExpressionUUID->"df9a7889-7c28-40a6-b9eb-5c316f8d69e6"],

Cell[BoxData[
 RowBox[{"With", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"\[Rho]", " ", "=", " ", 
     RowBox[{"DensityMatrix", "[", 
      RowBox[{"{", 
       RowBox[{"rx", ",", " ", "ry", ",", " ", "rz"}], "}"}], "]"}]}], "}"}], 
   ",", " ", "\n", " ", 
   RowBox[{"Reduce", "[", 
    RowBox[{"\[Rho]", " ", "==", " ", 
     RowBox[{"ConjugateTranspose", "[", "\[Rho]", "]"}]}], "]"}]}], 
  "]"}]], "Input",
 CellLabel->
  "In[127]:= ",ExpressionUUID->"dfcb6817-f63d-418a-aa7a-e795aff77ae6"],

Cell[TextData[{
 "As one can see, Hermiticity of \[Rho] implies that ",
 Cell[BoxData[
  RowBox[{
   RowBox[{"{", 
    SubscriptBox[
     StyleBox["r", "TI"], 
     StyleBox["x", "TI"]]}], ",", 
   SubscriptBox[
    StyleBox["r", "TI"], 
    StyleBox["y", "TI"]], ",", 
   RowBox[{
    SubscriptBox[
     StyleBox["r", "TI"], 
     StyleBox["z", "TI"]], "}", "\[Element]", "\:211d"}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "b26c1808-ec80-4bbc-b952-afe1100857c7"],
 "."
}], "Text",ExpressionUUID->"03c91b54-d253-411a-8a6a-79db6f224693"],

Cell["\<\
Positivity, Eigenvalues, and the Meaning of Bloch Vector\[CloseCurlyQuote]s \
Lenght\
\>", "Subsection",ExpressionUUID->"b60ed667-5d20-4006-9ffa-4d88b0e7557f"],

Cell["\<\
The density matrix must be positive semidefinite, which is the mathematical \
way of saying that all predicted probabilities are nonnegative. This implies \
that all eigenvalues of the density matrix must be nonnegative. To explore \
this, first let\[CloseCurlyQuote]s calculate the eigenvalues of the density \
matrix.\
\>", "Text",ExpressionUUID->"af63db72-ede3-4984-aa2a-e50496ba31ad"],

Cell[TextData[{
 "Compute eigenvalues of the density matrix ",
 Cell[BoxData[
  RowBox[{
   StyleBox["\[Rho]", "TI"], "=", "1", "/", "2", 
   StyleBox["(",
    SpanMaxSize->1], 
   RowBox[{
    RowBox[{"\|01d540", "+", 
     OverscriptBox[
      StyleBox["r", "TI"], "\[RightVector]"]}], ".", 
    OverscriptBox[
     StyleBox["\[Sigma]", "TI"], "\[RightVector]"]}], 
   StyleBox[")",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "d831af69-368b-4f65-867f-1290fe1aa9dc"],
 ":"
}], "Text",ExpressionUUID->"13869726-9096-4a2c-84f7-7c93e4e3c4b3"],

Cell[BoxData[
 RowBox[{
  RowBox[{"Eigenvalues", "[", 
   RowBox[{"DensityMatrix", "[", 
    RowBox[{"{", 
     RowBox[{"rx", ",", " ", "ry", ",", " ", "rz"}], "}"}], "]"}], "]"}], " ",
   "//", " ", "FullSimplify"}]], "Input",
 CellLabel->
  "In[128]:= ",ExpressionUUID->"150e84b5-eb18-4ea8-9219-1420ae6b1f6d"],

Cell[TextData[{
 "Since ",
 Cell[BoxData[
  RowBox[{
   RowBox[{
    OverscriptBox[
     StyleBox["r", "TI"], "\[RightVector]"], "=", "{", 
    SubscriptBox[
     StyleBox["r", "TI"], 
     StyleBox["x", "TI"]]}], ",", 
   SubscriptBox[
    StyleBox["r", "TI"], 
    StyleBox["y", "TI"]], ",", 
   RowBox[{
    SubscriptBox[
     StyleBox["r", "TI"], 
     StyleBox["z", "TI"]], "}", "\[Element]", "\:211d"}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "73205491-4277-4e60-8e95-e5cfd3191d4c"],
 ", then the second eigenvalue would be automatically nonnegative; so \
positivity reduces to requiring that the first eigenvalue should be \
nonnegative which means ",
 Cell[BoxData[
  RowBox[{
   StyleBox["r", "TI"], "\[LessEqual]", "1"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "d3ee09c2-e3cf-425d-bb54-807460ffdc8a"],
 " with ",
 Cell[BoxData[
  RowBox[{
   StyleBox["r", "TI"], "=", 
   SqrtBox[
    RowBox[{
     SubsuperscriptBox[
      StyleBox["r", "TI"], 
      StyleBox["x", "TI"], "2"], "+", 
     SubsuperscriptBox[
      StyleBox["r", "TI"], 
      StyleBox["y", "TI"], "2"], "+", 
     SubsuperscriptBox[
      StyleBox["r", "TI"], 
      StyleBox["z", "TI"], "2"]}]]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "5144d66c-3dd7-4e1f-b573-13f202f0f252"],
 ". Geometrically, this is exactly the condition that ",
 Cell[BoxData[
  RowBox[{
   RowBox[{"{", 
    SubscriptBox[
     StyleBox["r", "TI"], 
     StyleBox["x", "TI"]]}], ",", 
   SubscriptBox[
    StyleBox["r", "TI"], 
    StyleBox["y", "TI"]], ",", 
   RowBox[{
    SubscriptBox[
     StyleBox["r", "TI"], 
     StyleBox["z", "TI"]], "}"}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "48daf3e9-1233-406d-a151-4dfb5f49cf2a"],
 " lies inside the unit ball (the Bloch ball). Points on the surface satisfy ",
 Cell[BoxData[
  RowBox[{
   StyleBox["r", "TI"], "=", "1"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "6497e837-5979-4720-a676-65fe33f24886"],
 " and correspond to pure states. Points strictly inside satisfy ",
 Cell[BoxData[
  RowBox[{
   StyleBox["r", "TI"], "<", "1"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "2dca2926-b00f-487e-b650-1dc5beef36e1"],
 " and correspond to mixed states."
}], "Text",ExpressionUUID->"4774d005-2d31-45ec-931c-e6aae29c9058"],

Cell[TextData[{
 "Recall that the Bloch vector can be represented either in Cartesian \
coordinates ",
 Cell[BoxData[
  RowBox[{
   RowBox[{"{", 
    SubscriptBox[
     StyleBox["r", "TI"], 
     StyleBox["x", "TI"]]}], ",", 
   SubscriptBox[
    StyleBox["r", "TI"], 
    StyleBox["y", "TI"]], ",", 
   RowBox[{
    SubscriptBox[
     StyleBox["r", "TI"], 
     StyleBox["z", "TI"]], "}"}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "5c23d916-3b9a-49e9-bf72-ba8653bc2b26"],
 " or in spherical coordinates ",
 Cell[BoxData[
  RowBox[{
   RowBox[{"{", 
    StyleBox["r", "TI"]}], ",", 
   StyleBox["\[Theta]", "TI"], ",", 
   RowBox[{
    StyleBox["\[Phi]", "TI"], "}"}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "be429117-d97b-408e-8008-833acd8a7b92"],
 ", which are related by ",
 Cell[BoxData[
  RowBox[{
   SubscriptBox[
    StyleBox["r", "TI"], 
    StyleBox["x", "TI"]], "=", 
   StyleBox["r", "TI"], " ", 
   StyleBox["C", "TI"], 
   StyleBox["o", "TI"], 
   StyleBox["s", "TI"], 
   StyleBox["[",
    SpanMaxSize->1], 
   StyleBox["\[Phi]", "TI"], 
   StyleBox["]",
    SpanMaxSize->1], " ", 
   StyleBox["S", "TI"], 
   StyleBox["i", "TI"], 
   StyleBox["n", "TI"], 
   StyleBox["[",
    SpanMaxSize->1], 
   StyleBox["\[Theta]", "TI"], 
   StyleBox["]",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "7097d1f2-9f04-4409-854f-29caf8968681"],
 ", ",
 Cell[BoxData[
  RowBox[{
   SubscriptBox[
    StyleBox["r", "TI"], 
    StyleBox["y", "TI"]], "=", 
   StyleBox["r", "TI"], " ", 
   StyleBox["S", "TI"], 
   StyleBox["i", "TI"], 
   StyleBox["n", "TI"], 
   StyleBox["[",
    SpanMaxSize->1], 
   StyleBox["\[Phi]", "TI"], 
   StyleBox["]",
    SpanMaxSize->1], " ", 
   StyleBox["S", "TI"], 
   StyleBox["i", "TI"], 
   StyleBox["n", "TI"], 
   StyleBox["[",
    SpanMaxSize->1], 
   StyleBox["\[Theta]", "TI"], 
   StyleBox["]",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "a4776010-1760-450a-aca1-6cae2081e92d"],
 ", and ",
 Cell[BoxData[
  RowBox[{
   SubscriptBox[
    StyleBox["r", "TI"], 
    StyleBox["z", "TI"]], "=", 
   StyleBox["r", "TI"], " ", 
   StyleBox["C", "TI"], 
   StyleBox["o", "TI"], 
   StyleBox["s", "TI"], 
   StyleBox["[",
    SpanMaxSize->1], 
   StyleBox["\[Theta]", "TI"], 
   StyleBox["]",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "c9ac92e2-82a6-41e4-be14-6f90ce3fd19e"],
 " with ",
 Cell[BoxData[
  RowBox[{"0", "\[LessEqual]", 
   StyleBox["r", "TI"], "\[LessEqual]", "1"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "177c5e80-7a90-4332-bc01-1e39947b41b9"],
 ", ",
 Cell[BoxData[
  RowBox[{"0", "\[LessEqual]", 
   StyleBox["\[Theta]", "TI"], "\[LessEqual]", "\[Pi]"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "cb1a4b9c-ce55-42c6-80a8-8710c99764ef"],
 " and ",
 Cell[BoxData[
  RowBox[{"0", "\[LessEqual]", 
   StyleBox["\[Phi]", "TI"], "\[LessEqual]", "2", "\[Pi]"}]], "InlineFormula",
  
  FontSize->0.9 Inherited,ExpressionUUID->
  "092dff4c-7ed6-4cbf-bce3-12f36c3d0e30"],
 "."
}], "Text",ExpressionUUID->"7d36eef9-33d8-44a2-ab71-f55c3fc09eee"],

Cell["\<\
Transform the Bloch vector from Cartesian coordinate to spherical one:\
\>", "Text",ExpressionUUID->"18eb2506-c42e-4ac6-9d59-c585eb702b77"],

Cell[BoxData[{
 RowBox[{"ClearAll", "[", 
  RowBox[{"rx", ",", " ", "ry", ",", " ", "rz"}], "]"}], "\n", 
 RowBox[{"ToSphericalCoordinates", "[", 
  RowBox[{"{", 
   RowBox[{"rx", ",", " ", "ry", ",", " ", "rz"}], "}"}], "]"}]}], "Input",
 CellLabel->
  "In[129]:= ",ExpressionUUID->"31e12ff0-2d3f-44d2-8266-df2d0a49fcf8"],

Cell["\<\
Transforming the Bloch vector from spherical coordinate to Cartesian one:\
\>", "Text",ExpressionUUID->"c5991630-1852-471f-8086-330cf3134580"],

Cell[BoxData[{
 RowBox[{"ClearAll", "[", 
  RowBox[{"r", ",", " ", "\[Theta]", ",", " ", "\[Phi]"}], "]"}], "\n", 
 RowBox[{"FromSphericalCoordinates", "[", 
  RowBox[{"{", 
   RowBox[{"r", ",", " ", "\[Theta]", ",", " ", "\[Phi]"}], "}"}], 
  "]"}]}], "Input",
 CellLabel->
  "In[130]:= ",ExpressionUUID->"c9498598-fd78-4fdb-8b90-6229a67a06b2"],

Cell["Purity and von Neumann Entropy: Quantifying Mixedness", "Subsection",ExpressionUUID->"034edbbb-8572-468f-96f5-201324246f2e"],

Cell[TextData[{
 "One can quantify if a state in pure or mixed. One measure is purity which \
is defined as ",
 Cell[BoxData[
  RowBox[{
   StyleBox["T", "TI"], 
   StyleBox["r", "TI"], 
   StyleBox["[",
    SpanMaxSize->1], 
   SuperscriptBox[
    StyleBox["\[Rho]", "TI"], "2"], 
   StyleBox["]",
    SpanMaxSize->1], "=", "1", "/", "2", 
   StyleBox["(",
    SpanMaxSize->1], 
   RowBox[{"1", "+", 
    SuperscriptBox[
     StyleBox["r", "TI"], "2"]}], 
   StyleBox[")",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "943fb070-49b4-4406-8b32-5099cac863f1"],
 ". For a pure state (",
 Cell[BoxData[
  RowBox[{
   StyleBox["r", "TI"], "=", "1"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "25884640-2ce3-45e2-86b9-c170f010375f"],
 "), purity will be 1, while mixed states (",
 Cell[BoxData[
  RowBox[{
   StyleBox["r", "TI"], "<", "1"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "8cce59f8-bd28-4bd5-b7ec-9f15c25fe3bb"],
 ") have ",
 Cell[BoxData[
  RowBox[{
   StyleBox["T", "TI"], 
   StyleBox["r", "TI"], 
   StyleBox["[",
    SpanMaxSize->1], 
   SuperscriptBox[
    StyleBox["\[Rho]", "TI"], "2"], 
   StyleBox["]",
    SpanMaxSize->1], "<", "1"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "aa45f9f4-b036-4e5a-ad0c-aba64d6f01f6"],
 "."
}], "Text",ExpressionUUID->"a5079531-3288-44d1-aa2a-5bd848635331"],

Cell[TextData[{
 "Verify that ",
 Cell[BoxData[
  RowBox[{
   StyleBox["T", "TI"], 
   StyleBox["r", "TI"], 
   StyleBox["[",
    SpanMaxSize->1], 
   SuperscriptBox[
    StyleBox["\[Rho]", "TI"], "2"], 
   StyleBox["]",
    SpanMaxSize->1], "=", "1", "/", "2", 
   StyleBox["(",
    SpanMaxSize->1], 
   RowBox[{"1", "+", 
    SuperscriptBox[
     StyleBox["r", "TI"], "2"]}], 
   StyleBox[")",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "e60e3a49-2e8a-4ac2-8ccc-7d6b4bb05001"],
 ":"
}], "Text",ExpressionUUID->"e9dc8ac7-face-476a-b0b5-010547027843"],

Cell[BoxData[
 RowBox[{
  RowBox[{"With", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"\[Rho]", " ", "=", " ", 
      RowBox[{"DensityMatrix", "[", 
       RowBox[{"{", 
        RowBox[{"rx", ",", " ", "ry", ",", " ", "rz"}], "}"}], "]"}]}], "}"}],
     ",", " ", "\n", "  ", 
    RowBox[{"Tr", "[", 
     RowBox[{"\[Rho]", " ", ".", " ", "\[Rho]"}], "]"}]}], "]"}], " ", "//", 
  " ", "FullSimplify"}]], "Input",
 CellLabel->
  "In[131]:= ",ExpressionUUID->"d307baec-52f5-4c90-ab69-0096113d59cb"],

Cell[TextData[{
 "An example of a mixed state is a classical ensemble. For example, consider \
an ensemble prepared in ",
 Cell[BoxData[
  TemplateBox[{"0"},
   "Ket"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "055fd815-4d41-47ac-848d-52a22cfbd713"],
 " with probability 0.4 and in ",
 Cell[BoxData[
  TemplateBox[{"1"},
   "Ket"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "c820176f-57f8-4ba2-b78b-f9250815b9cc"],
 " with probability 0.6. This correspond to a dephased (classical) mixture in \
the computational basis. The dephased (classical) mixture in the \
computational basis has the general form of ",
 Cell[BoxData[
  RowBox[{
   RowBox[{
    StyleBox["p", "TI"], 
    TemplateBox[{"0"},
     "Ket"], 
    TemplateBox[{"0"},
     "Bra"]}], "+", 
   RowBox[{
    RowBox[{
     StyleBox["(",
      SpanMaxSize->1], 
     RowBox[{"1", "-", 
      StyleBox["p", "TI"]}], 
     StyleBox[")",
      SpanMaxSize->1]}], 
    TemplateBox[{"1"},
     "Ket"], 
    TemplateBox[{"1"},
     "Bra"]}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "d7e0b089-605b-4608-8593-5d7ee3823db1"],
 "."
}], "Text",ExpressionUUID->"c84cf6af-f3f9-4921-b7ea-5694f6ae3b18"],

Cell["Calculate the density matrix of above example:", "Text",ExpressionUUID->"0b159a49-d8b5-40d8-be30-3144138bd0b2"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"0.4", " ", 
    RowBox[{"TensorProduct", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"1", ",", " ", "0"}], "}"}], ",", " ", 
      RowBox[{"{", 
       RowBox[{"1", ",", " ", "0"}], "}"}]}], "]"}]}], " ", "+", " ", "\n", 
   "  ", 
   RowBox[{"0.6", " ", 
    RowBox[{"TensorProduct", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"0", ",", " ", "1"}], "}"}], ",", " ", 
      RowBox[{"{", 
       RowBox[{"0", ",", " ", "1"}], "}"}]}], "]"}]}]}], " ", "//", " ", 
  "MatrixForm"}]], "Input",
 CellLabel->
  "In[132]:= ",ExpressionUUID->"bfd07db8-30ac-40ce-98f5-13d810746572"],

Cell["\<\
Verify that the above state is mixed by calculating its purity:\
\>", "Text",ExpressionUUID->"df755b20-7d43-4296-b735-cee976aff56c"],

Cell[BoxData[
 RowBox[{"With", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"\[Rho]", " ", "=", " ", "\n", "   ", 
     RowBox[{
      RowBox[{"0.4", " ", 
       RowBox[{"TensorProduct", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"1", ",", " ", "0"}], "}"}], ",", " ", 
         RowBox[{"{", 
          RowBox[{"1", ",", " ", "0"}], "}"}]}], "]"}]}], " ", "+", " ", "\n",
       "    ", 
      RowBox[{"0.6", " ", 
       RowBox[{"TensorProduct", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"0", ",", " ", "1"}], "}"}], ",", " ", 
         RowBox[{"{", 
          RowBox[{"0", ",", " ", "1"}], "}"}]}], "]"}]}]}]}], "}"}], ",", " ", 
   RowBox[{"Tr", "[", 
    RowBox[{"\[Rho]", " ", ".", " ", "\[Rho]"}], "]"}]}], "]"}]], "Input",
 CellLabel->
  "In[133]:= ",ExpressionUUID->"05f583bf-881f-4ca9-b9bf-3b2fba06255e"],

Cell["which is less than one, thus the state is a mixed state.", "Text",ExpressionUUID->"66da3228-3574-44c6-bdb1-088ba4425be5"],

Cell["\<\
Let\[CloseCurlyQuote]s generalize the function BlochVector we introduced \
before so that it also accepts density matrices and returns the corresponding \
Bloch vector.\
\>", "Text",ExpressionUUID->"6a6e3db4-0cfa-492a-8c43-8ec11884288b"],

Cell[BoxData[{
 RowBox[{"ClearAll", "[", "BlochVector", "]"}], "\n", 
 RowBox[{
  RowBox[{"BlochVector", "[", 
   RowBox[{"v_", "?", "VectorQ"}], "]"}], " ", ":=", " ", "\n", " ", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"\[Alpha]", ",", " ", "\[Beta]"}], "}"}], ",", " ", 
    RowBox[{
     RowBox[{
      RowBox[{"{", 
       RowBox[{"\[Alpha]", ",", " ", "\[Beta]"}], "}"}], " ", "=", " ", "\n", 
      "   ", "v"}], ";", " ", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"2", " ", 
        RowBox[{"Re", "[", 
         RowBox[{"\[Beta]", " ", 
          RowBox[{"Conjugate", "@", "\[Alpha]"}]}], "]"}]}], ",", " ", "\n", 
       "   ", 
       RowBox[{"2", " ", 
        RowBox[{"Im", "[", 
         RowBox[{"\[Beta]", " ", 
          RowBox[{"Conjugate", "@", "\[Alpha]"}]}], "]"}]}], ",", " ", 
       RowBox[{
        RowBox[{
         RowBox[{"Abs", "[", "\[Alpha]", "]"}], "^", "2"}], " ", "-", " ", 
        RowBox[{
         RowBox[{"Abs", "[", "\[Beta]", "]"}], "^", "2"}]}]}], "}"}]}]}], 
   "]"}]}], "\n", 
 RowBox[{
  RowBox[{"BlochVector", "[", 
   RowBox[{"\[Rho]_", "?", "MatrixQ"}], "]"}], " ", ":=", " ", "\n", " ", 
  RowBox[{"Table", "[", 
   RowBox[{
    RowBox[{"Tr", "[", 
     RowBox[{"\[Rho]", " ", ".", " ", 
      RowBox[{"PauliMatrix", "[", "j", "]"}]}], "]"}], ",", " ", 
    RowBox[{"{", 
     RowBox[{"j", ",", " ", "3"}], "}"}]}], "]"}]}]}], "Input",
 CellLabel->
  "In[134]:= ",ExpressionUUID->"59240067-fac8-435d-ad01-d28f46d0b5e7"],

Cell["\<\
Compute the Bloch vector (in Cartesian coordinates) for the mixed state \
defined above:\
\>", "Text",ExpressionUUID->"677e3234-02fa-4f97-8d8b-1065a6a0264b"],

Cell[BoxData[
 RowBox[{"With", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"\[Rho]", " ", "=", " ", "\n", "   ", 
     RowBox[{
      RowBox[{"0.4", " ", 
       RowBox[{"TensorProduct", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"1", ",", " ", "0"}], "}"}], ",", " ", 
         RowBox[{"{", 
          RowBox[{"1", ",", " ", "0"}], "}"}]}], "]"}]}], " ", "+", " ", "\n",
       "    ", 
      RowBox[{"0.6", " ", 
       RowBox[{"TensorProduct", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"0", ",", " ", "1"}], "}"}], ",", " ", 
         RowBox[{"{", 
          RowBox[{"0", ",", " ", "1"}], "}"}]}], "]"}]}]}]}], "}"}], ",", " ", 
   RowBox[{"BlochVector", "[", "\[Rho]", "]"}]}], "]"}]], "Input",
 CellLabel->
  "In[135]:= ",ExpressionUUID->"cf8c7c89-d94b-43ee-a6b7-2f6e5f7498e2"],

Cell[TextData[{
 "Compute the Bloch vector for a dephased classical mixture ",
 Cell[BoxData[
  RowBox[{
   RowBox[{
    StyleBox["p", "TI"], 
    TemplateBox[{"0"},
     "Ket"], 
    TemplateBox[{"0"},
     "Bra"]}], "+", 
   RowBox[{
    RowBox[{
     StyleBox["(",
      SpanMaxSize->1], 
     RowBox[{"1", "-", 
      StyleBox["p", "TI"]}], 
     StyleBox[")",
      SpanMaxSize->1]}], 
    TemplateBox[{"1"},
     "Ket"], 
    TemplateBox[{"1"},
     "Bra"]}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "dbcc54dd-b768-432a-a6e2-b3472b185f32"],
 ":"
}], "Text",ExpressionUUID->"f55995c0-f5b2-4fbb-aa70-529022350fc0"],

Cell[BoxData[{
 RowBox[{"ClearAll", "[", "p", "]"}], "\n", 
 RowBox[{"With", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"\[Rho]", " ", "=", " ", "\n", "   ", 
     RowBox[{
      RowBox[{"p", " ", 
       RowBox[{"TensorProduct", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"1", ",", " ", "0"}], "}"}], ",", " ", 
         RowBox[{"{", 
          RowBox[{"1", ",", " ", "0"}], "}"}]}], "]"}]}], " ", "+", " ", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{"1", " ", "-", " ", "p"}], ")"}], " ", 
       RowBox[{"TensorProduct", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"0", ",", " ", "\n", "       ", "1"}], "}"}], ",", " ", 
         RowBox[{"{", 
          RowBox[{"0", ",", " ", "1"}], "}"}]}], "]"}]}]}]}], "}"}], ",", " ", 
   RowBox[{"FullSimplify", "[", 
    RowBox[{
     RowBox[{"BlochVector", "[", "\[Rho]", "]"}], ",", " ", 
     RowBox[{"0", " ", "<=", " ", "p", " ", "<=", " ", "1"}]}], "]"}]}], 
  "]"}]}], "Input",
 CellLabel->
  "In[136]:= ",ExpressionUUID->"59aa7795-8dda-4aff-925d-d0a0c03aa314"],

Cell[TextData[{
 "Another useful way to quantify \[OpenCurlyDoubleQuote]mixedness\
\[CloseCurlyDoubleQuote] is the von Neumann entropy, which gives an \
information-theoretic meaning to how uncertain (or mixed) a quantum state is. \
It is defined as ",
 Cell[BoxData[
  RowBox[{"\|01d4ae", "=", "-", 
   StyleBox["T", "TI"], 
   StyleBox["r", "TI"], 
   StyleBox["[",
    SpanMaxSize->1], 
   RowBox[{
    StyleBox["\[Rho]", "TI"], ".", 
    RowBox[{
     StyleBox["L", "TI"], 
     StyleBox["o", "TI"], 
     StyleBox["g", "TI"], "2", 
     StyleBox["[",
      SpanMaxSize->1], 
     StyleBox["\[Rho]", "TI"], 
     StyleBox["]",
      SpanMaxSize->1]}]}], 
   StyleBox["]",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "2f09fb4a-e744-4def-917a-2f3a4e5c8ecb"],
 " where the logarithm is taken in base 2 (giving entropy in bits)."
}], "Text",ExpressionUUID->"1a7e84dc-5392-4e04-8697-f7ff10ed5b9a"],

Cell[TextData[{
 "Compute the von Neumann entropy for the density matrix ",
 Cell[BoxData[
  RowBox[{
   StyleBox["\[Rho]", "TI"], "=", "1", "/", "2", 
   StyleBox["(",
    SpanMaxSize->1], 
   RowBox[{
    RowBox[{"\|01d540", "+", 
     OverscriptBox[
      StyleBox["r", "TI"], "\[RightVector]"]}], ".", 
    OverscriptBox[
     StyleBox["\[Sigma]", "TI"], "\[RightVector]"]}], 
   StyleBox[")",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "9aad95d6-a586-4a70-9430-06693be4fd25"],
 ":"
}], "Text",ExpressionUUID->"cfae33f6-44da-46b0-96c9-28f008e78b51"],

Cell[BoxData[
 RowBox[{
  RowBox[{"With", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"\[Rho]", " ", "=", " ", "\n", "    ", 
      RowBox[{"DensityMatrix", "[", 
       RowBox[{"{", 
        RowBox[{"rx", ",", " ", "ry", ",", " ", "rz"}], "}"}], "]"}]}], "}"}],
     ",", " ", 
    RowBox[{
     RowBox[{"-", 
      RowBox[{"Tr", "[", 
       RowBox[{"\[Rho]", " ", ".", " ", 
        RowBox[{"MatrixLog", "[", "\[Rho]", "]"}]}], "]"}]}], "/", "\n", 
     "   ", 
     RowBox[{"Log", "[", "2", "]"}]}]}], "]"}], " ", "//", " ", 
  "FullSimplify"}]], "Input",
 CellLabel->
  "In[137]:= ",ExpressionUUID->"d07c7345-d538-4c5a-9089-bd269b75c689"],

Cell[TextData[{
 "As one can see, the von Neumann entropy for ",
 Cell[BoxData[
  RowBox[{
   StyleBox["\[Rho]", "TI"], "=", "1", "/", "2", 
   StyleBox["(",
    SpanMaxSize->1], 
   RowBox[{
    RowBox[{"\|01d540", "+", 
     OverscriptBox[
      StyleBox["r", "TI"], "\[RightVector]"]}], ".", 
    OverscriptBox[
     StyleBox["\[Sigma]", "TI"], "\[RightVector]"]}], 
   StyleBox[")",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "ad60fad2-545e-4c6e-8088-388c492c946f"],
 " depends only on ",
 Cell[BoxData[
  StyleBox["r", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "ca3611b0-4a31-44eb-93d7-f62d26e0cdd2"],
 "."
}], "Text",ExpressionUUID->"5ff6f1a3-8708-4eae-b7b4-c6cd5bd46d13"],

Cell[TextData[{
 "Plot the von Neumann entropy for the density matrix ",
 Cell[BoxData[
  RowBox[{
   StyleBox["\[Rho]", "TI"], "=", "1", "/", "2", 
   StyleBox["(",
    SpanMaxSize->1], 
   RowBox[{
    RowBox[{"\|01d540", "+", 
     OverscriptBox[
      StyleBox["r", "TI"], "\[RightVector]"]}], ".", 
    OverscriptBox[
     StyleBox["\[Sigma]", "TI"], "\[RightVector]"]}], 
   StyleBox[")",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "8d293569-df42-41b8-ba55-1f9c42508eb3"],
 " as a function of ",
 Cell[BoxData[
  StyleBox["r", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "e21eaf37-36d9-4e76-ae55-7cd325a1e356"],
 "."
}], "Text",ExpressionUUID->"a5643cc4-ca2d-424c-ac00-09235adedf61"],

Cell[BoxData[
 RowBox[{"Plot", "[", 
  RowBox[{
   RowBox[{"-", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{
        RowBox[{"2", " ", "r", " ", 
         RowBox[{"ArcTanh", "[", "r", "]"}]}], " ", "+", " ", 
        RowBox[{"Log", "[", 
         RowBox[{
          RowBox[{"1", "/", "4"}], " ", "-", " ", 
          RowBox[{
           RowBox[{"1", "/", "4"}], " ", "r"}]}], "]"}], " ", "+", " ", 
        RowBox[{"Log", "[", 
         RowBox[{"1", " ", "+", " ", "r"}], "]"}]}], ")"}], "/", 
      RowBox[{"Log", "[", "4", "]"}]}], ")"}]}], ",", " ", 
   RowBox[{"{", 
    RowBox[{"r", ",", " ", "\n", "  ", "0", ",", " ", "1"}], "}"}], ",", " ", 
   
   RowBox[{"Sequence", "[", "\n", " ", 
    RowBox[{
     RowBox[{"PlotRange", " ", "->", " ", "All"}], ",", " ", 
     RowBox[{"AspectRatio", " ", "->", " ", 
      RowBox[{"1", "/", "2"}]}], ",", " ", 
     RowBox[{"Filling", " ", "->", " ", "0"}], ",", " ", "\n", "  ", 
     RowBox[{"FrameLabel", " ", "->", " ", 
      RowBox[{"{", 
       RowBox[{"\"\<r\>\"", ",", " ", "\"\<\[ScriptCapitalS]\>\""}], "}"}]}], 
     ",", " ", 
     RowBox[{"GridLines", " ", "->", " ", "Automatic"}], ",", " ", "\n", "  ", 
     RowBox[{"Frame", " ", "->", " ", "True"}], ",", " ", "\n", "  ", 
     RowBox[{
     "PlotLabel", " ", "->", 
      " ", "\"\<Entropy \\!\\(TraditionalForm\\`\[ScriptCapitalS] = \\(-Tr[\
\[Rho] . Log2[\[Rho]]]\\)\\) vs r with \\!\\(TraditionalForm\\`\[Rho] = \
\\*FractionBox[\\(1\\), \\(2\\)] \\((\[DoubleStruckCapitalI] + \
\\*OverscriptBox[\\(r\\), \\(\[RightVector]\\)] . \
\\*OverscriptBox[\\(\[Sigma]\\), \\(\[RightVector]\\)])\\)\\)\>\""}]}], 
    "]"}]}], "]"}]], "Input",
 CellLabel->
  "In[138]:= ",ExpressionUUID->"0cd858a7-3aed-4fc2-a728-7a05dc44a007"],

Cell["\<\
Hilbert\[Dash]Schmidt Operator Basis: Why the Pauli Expansion Always Works\
\>", "Subsection",ExpressionUUID->"7dca582a-9c32-4bae-b1d4-70837c1eccfc"],

Cell[TextData[{
 "Let\[CloseCurlyQuote]s focus again on the operator basis in a \
two-dimensional Hilbert space. Earlier, we wrote the density matrix in the \
form ",
 Cell[BoxData[
  RowBox[{
   StyleBox["\[Rho]", "TI"], "=", 
   SubscriptBox[
    StyleBox["c", "TI"], "0"], "\|01d540", "+", 
   SubscriptBox[
    StyleBox["c", "TI"], "1"], 
   SubscriptBox[
    StyleBox["\[Sigma]", "TI"], 
    StyleBox["x", "TI"]], "+", 
   SubscriptBox[
    StyleBox["c", "TI"], "2"], 
   SubscriptBox[
    StyleBox["\[Sigma]", "TI"], 
    StyleBox["y", "TI"]], "+", 
   SubscriptBox[
    StyleBox["c", "TI"], "3"], 
   SubscriptBox[
    StyleBox["\[Sigma]", "TI"], 
    StyleBox["z", "TI"]]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "c3952c91-562c-4d70-bab1-051d450612e0"],
 ", but we did not explain why this decomposition is always possible for any \
density matrix. Now let\[CloseCurlyQuote]s explore in detail why any ",
 Cell[BoxData[
  RowBox[{"2", "\[Times]", "2"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "ea64b85b-ec97-4ea2-ab62-b3484764eb07"],
 " density operator can indeed be expanded in this Pauli\[Dash]identity basis \
",
 Cell[BoxData[
  RowBox[{
   RowBox[{"{", "\|01d540"}], ",", 
   SubscriptBox[
    StyleBox["\[Sigma]", "TI"], 
    StyleBox["x", "TI"]], ",", 
   SubscriptBox[
    StyleBox["\[Sigma]", "TI"], 
    StyleBox["y", "TI"]], ",", 
   RowBox[{
    SubscriptBox[
     StyleBox["\[Sigma]", "TI"], 
     StyleBox["z", "TI"]], "}"}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "259a2b49-5515-4cc6-aaf1-fa3948f23705"],
 ". For Pauli-identity basis, let\[CloseCurlyQuote]s use the notation ",
 Cell[BoxData[
  RowBox[{
   RowBox[{"{", 
    SubscriptBox[
     StyleBox["\[Sigma]", "TI"], "0"]}], ",", 
   SubscriptBox[
    StyleBox["\[Sigma]", "TI"], "1"], ",", 
   SubscriptBox[
    StyleBox["\[Sigma]", "TI"], "2"], ",", 
   RowBox[{
    SubscriptBox[
     StyleBox["\[Sigma]", "TI"], "3"], "}", "=", "{", 
    SubscriptBox[
     StyleBox["\[Sigma]", "TI"], 
     StyleBox["\[Mu]", "TI"]], "}"}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "f267906f-47ff-442e-ba81-d088eb86b721"],
 " (with ",
 Cell[BoxData[
  RowBox[{
   RowBox[{
    StyleBox["\[Mu]", "TI"], "=", "0"}], ",", 
   RowBox[{"1", ",", "2", ",", "3"}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "89fd6cc1-260c-456f-a3aa-9b675e07449c"],
 ") which is more convenient for what we want to explore next. We will show \
that this basis is Hilbert-Schmidt orthogonal, i.e. ",
 Cell[BoxData[
  RowBox[{
   StyleBox["T", "TI"], 
   StyleBox["r", "TI"], 
   StyleBox["[",
    SpanMaxSize->1], 
   RowBox[{
    SubsuperscriptBox[
     StyleBox["\[Sigma]", "TI"], 
     StyleBox["\[Mu]", "TI"], "\[Dagger]"], ".", 
    SubscriptBox[
     StyleBox["\[Sigma]", "TI"], 
     StyleBox["\[Nu]", "TI"]]}], 
   StyleBox["]",
    SpanMaxSize->1], "\[Proportional]", 
   SubscriptBox[
    StyleBox["\[Delta]", "TI"], 
    StyleBox[
     RowBox[{"\[Mu]", "\[Nu]"}], "TI"]]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "cb814d06-5445-411e-a88b-6eed79859869"],
 ". If ",
 Cell[BoxData[
  RowBox[{
   StyleBox["T", "TI"], 
   StyleBox["r", "TI"], 
   StyleBox["[",
    SpanMaxSize->1], 
   RowBox[{
    SubsuperscriptBox[
     StyleBox["\[Sigma]", "TI"], 
     StyleBox["\[Mu]", "TI"], "\[Dagger]"], ".", 
    SubscriptBox[
     StyleBox["\[Sigma]", "TI"], 
     StyleBox["\[Nu]", "TI"]]}], 
   StyleBox["]",
    SpanMaxSize->1], "=", 
   SubscriptBox[
    StyleBox["\[Delta]", "TI"], 
    StyleBox[
     RowBox[{"\[Mu]", "\[Nu]"}], "TI"]]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "f63e9e78-59e0-4687-b759-62ea2dca3c1d"],
 ", then the basis is called Hilbert-Schmidt orthonormal."
}], "Text",ExpressionUUID->"d7969c54-3dfd-4a36-9e6a-1c82051b8f0b"],

Cell[TextData[{
 "Verify that the basis ",
 Cell[BoxData[
  RowBox[{
   RowBox[{"{", 
    SubscriptBox[
     StyleBox["\[Sigma]", "TI"], "0"]}], ",", 
   SubscriptBox[
    StyleBox["\[Sigma]", "TI"], "1"], ",", 
   SubscriptBox[
    StyleBox["\[Sigma]", "TI"], "2"], ",", 
   RowBox[{
    SubscriptBox[
     StyleBox["\[Sigma]", "TI"], "3"], "}"}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "51dcf133-931e-4aac-b6ec-930a88bf22ac"],
 " is Hilbert\[Dash]Schmidt orthogonal:"
}], "Text",ExpressionUUID->"21ec2bc6-640c-4a8b-83c5-d8163186377c"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"gram", " ", "=", " ", 
   RowBox[{"With", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"basis", " ", "=", " ", 
       RowBox[{"Table", "[", 
        RowBox[{
         RowBox[{"PauliMatrix", "[", "j", "]"}], ",", " ", 
         RowBox[{"{", 
          RowBox[{"j", ",", " ", "0", ",", " ", "3"}], "}"}]}], "]"}]}], 
      "}"}], ",", " ", "\n", "   ", 
     RowBox[{"Outer", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"Tr", "[", 
         RowBox[{
          RowBox[{"ConjugateTranspose", "[", "#1", "]"}], " ", ".", " ", 
          "#2"}], "]"}], " ", "&"}], ",", " ", "basis", ",", " ", "basis", ",",
        " ", "1"}], "]"}]}], "]"}]}], ";"}], "\n", 
 RowBox[{"gram", " ", "//", " ", "MatrixForm"}]}], "Input",
 CellLabel->
  "In[139]:= ",ExpressionUUID->"435ba8ba-8cc2-4c33-8688-fd129589c9c7"],

Cell[TextData[{
 "The above matrix is called the Gram matrix \|01d4a2. Since ",
 Cell[BoxData[
  RowBox[{
   StyleBox["d", "TI"], 
   StyleBox["e", "TI"], 
   StyleBox["t", "TI"], 
   StyleBox["[",
    SpanMaxSize->1], "\|01d4a2", 
   StyleBox["]",
    SpanMaxSize->1], "\[NotEqual]", "0"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "b34df0d9-09d7-4e41-bcd7-6914fb6761e6"],
 " (which means \|01d4a2 is invertible), then the basis set ",
 Cell[BoxData[
  RowBox[{"{", 
   SubscriptBox[
    StyleBox["\[Sigma]", "TI"], 
    StyleBox["\[Mu]", "TI"]], "}"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "e2b00bfe-a9fa-4d16-9cd2-7dab036dddaa"],
 " is linearly independent. We have 4 elements in the basis set ",
 Cell[BoxData[
  RowBox[{"{", 
   SubscriptBox[
    StyleBox["\[Sigma]", "TI"], 
    StyleBox["\[Mu]", "TI"]], "}"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "f8aabef0-7562-4047-b293-c51a00e482a1"],
 " and they are linearly independent; thus it means the set is a complete \
basis. In general, a complete basis for the space of operators on an ",
 Cell[BoxData[
  StyleBox["n", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "33439d2f-1d40-414d-9d6d-17f32c21310e"],
 "-dimensional Hilbert space has ",
 Cell[BoxData[
  SuperscriptBox[
   StyleBox["n", "TI"], "2"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "12e68be2-bf95-4e12-8035-34e68fcac57e"],
 " elements and its Gram matrix is invertible (",
 Cell[BoxData[
  RowBox[{
   StyleBox["d", "TI"], 
   StyleBox["e", "TI"], 
   StyleBox["t", "TI"], 
   StyleBox["[",
    SpanMaxSize->1], "\|01d4a2", 
   StyleBox["]",
    SpanMaxSize->1], "\[NotEqual]", "0"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "d4dd8f1a-67b2-439f-a9cf-739d2ffa9bb9"],
 ")."
}], "Text",ExpressionUUID->"a6c19a50-6139-45aa-98ea-d245343f4dcf"],

Cell["Calculate the determinant of the Gram matrix:", "Text",ExpressionUUID->"dd5dc00c-7ef9-450e-88a0-e9c11ce94b5b"],

Cell[BoxData[
 RowBox[{"Det", "[", "gram", "]"}]], "Input",
 CellLabel->
  "In[140]:= ",ExpressionUUID->"83d3dd6f-3981-47d5-90fe-831db5d7df45"],

Cell[TextData[{
 "Note that the above Gram matrix is proportional to the identity, i.e. ",
 Cell[BoxData[
  RowBox[{"\|01d4a2", "=", "2", "\|01d540"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "7de93851-1dda-4974-beb3-d4efb1fa6842"],
 ". Recall that the identity matrix has elements ",
 Cell[BoxData[
  RowBox[{
   SubscriptBox["\|01d540", 
    StyleBox[
     RowBox[{"i", "j"}], "TI"]], "=", 
   SubscriptBox[
    StyleBox["\[Delta]", "TI"], 
    StyleBox[
     RowBox[{"i", "j"}], "TI"]]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "72100bd8-5ebc-4810-bad0-e4efe6b8d914"],
 ". So the set ",
 Cell[BoxData[
  RowBox[{
   RowBox[{"{", 
    SubscriptBox[
     StyleBox["\[Sigma]", "TI"], "0"]}], ",", 
   SubscriptBox[
    StyleBox["\[Sigma]", "TI"], "1"], ",", 
   SubscriptBox[
    StyleBox["\[Sigma]", "TI"], "2"], ",", 
   RowBox[{
    SubscriptBox[
     StyleBox["\[Sigma]", "TI"], "3"], "}"}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "ee00d8e6-3b0a-4e45-bea6-c1105bb1a052"],
 " is Hilbert-Schmidt orthogonal, i.e. ",
 Cell[BoxData[
  RowBox[{
   SubscriptBox["\|01d4a2", 
    StyleBox[
     RowBox[{"\[Mu]", "\[Nu]"}], "TI"]], "\[Proportional]", 
   SubscriptBox[
    StyleBox["\[Delta]", "TI"], 
    StyleBox[
     RowBox[{"\[Mu]", "\[Nu]"}], "TI"]]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "05818aad-e69a-432f-ae76-83efd835bf77"],
 ". Note that ",
 Cell[BoxData[
  RowBox[{
   StyleBox["Tr",
    FontSlant->"Plain"], 
   StyleBox["[",
    SpanMaxSize->1], 
   RowBox[{
    SuperscriptBox[
     StyleBox["A", "TI"], "\[Dagger]"], 
    StyleBox["B", "TI"]}], 
   StyleBox["]",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "4b5405d0-df94-4c48-a887-5f105821ce7a"],
 " is called the Hilbert\[Dash]Schmidt inner product (also denoted as ",
 Cell[BoxData[
  RowBox[{
   StyleBox["\[LeftAngleBracket]",
    SpanMaxSize->1], 
   RowBox[{
    StyleBox["A", "TI"], ",", 
    StyleBox["B", "TI"]}], "\[VeryThinSpace]", 
   StyleBox["\[RightAngleBracket]",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "dc76e5fe-dab1-4b0f-8129-15a9efb79149"],
 "). Since all Pauli matrices and identify matrix are Hermitian (",
 Cell[BoxData[
  RowBox[{
   SubsuperscriptBox[
    StyleBox["\[Sigma]", "TI"], 
    StyleBox["\[Mu]", "TI"], "\[Dagger]"], "=", 
   SubscriptBox[
    StyleBox["\[Sigma]", "TI"], 
    StyleBox["\[Mu]", "TI"]]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "a02c83ae-4883-49fb-8fb7-edfe8a01eabc"],
 "), Hilbert-Schmidt orthogonal for them can be also written as ",
 Cell[BoxData[
  RowBox[{
   StyleBox["T", "TI"], 
   StyleBox["r", "TI"], 
   StyleBox["[",
    SpanMaxSize->1], 
   RowBox[{
    SubscriptBox[
     StyleBox["\[Sigma]", "TI"], 
     StyleBox["\[Mu]", "TI"]], ".", 
    SubscriptBox[
     StyleBox["\[Sigma]", "TI"], 
     StyleBox["\[Nu]", "TI"]]}], 
   StyleBox["]",
    SpanMaxSize->1], "=", 
   SubscriptBox["\|01d4a2", 
    StyleBox[
     RowBox[{"\[Mu]", "\[Nu]"}], "TI"]], "=", "2", 
   SubscriptBox[
    StyleBox["\[Delta]", "TI"], 
    StyleBox[
     RowBox[{"\[Mu]", "\[Nu]"}], "TI"]]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "e82333fd-6096-49ae-b5b6-f99e9b10d83a"],
 "."
}], "Text",ExpressionUUID->"32314afa-f2c7-4d9c-99d8-b814f5c80a4e"],

Cell["How Density Matrices Transform Under Basis Change", "Subsection",ExpressionUUID->"f0ba2487-e89f-4025-8e98-47dfc5926566"],

Cell[TextData[{
 "Now let\[CloseCurlyQuote]s see how we can transform a density matrix from \
one basis to another. We will assume both bases are orthonormal. Denote the \
first basis by ",
 Cell[BoxData[
  RowBox[{"{", 
   TemplateBox[{
     SubscriptBox[
      StyleBox["\[Zeta]", "TI"], 
      StyleBox["j", "TI"]]},
    "Ket"], "}"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "814afce0-9f7b-4e6e-a922-e38713719be3"],
 " and the second by ",
 Cell[BoxData[
  RowBox[{"{", 
   TemplateBox[{
     SubscriptBox[
      StyleBox["\[Omega]", "TI"], 
      StyleBox["j", "TI"]]},
    "Ket"], "}"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "99c8083c-bdc9-48a0-aa0d-ee1f075b6065"],
 ". Define the change-of-basis (unitary) matrix by its elements ",
 Cell[BoxData[
  RowBox[{
   SubscriptBox[
    StyleBox["U", "TI"], 
    StyleBox[
     RowBox[{"i", "j"}], "TI"]], "=", 
   TemplateBox[{
     SubscriptBox[
      StyleBox["\[Omega]", "TI"], 
      StyleBox["i", "TI"]], 
     SubscriptBox[
      StyleBox["\[Xi]", "TI"], 
      StyleBox["j", "TI"]]},
    "BraKet"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "4f4a4bb9-5014-44a7-84b2-6f306203bc10"],
 ". With this convention, if a state ",
 Cell[BoxData[
  TemplateBox[{
    SubscriptBox[
     StyleBox["\[Psi]", "TI"], 
     StyleBox["\[Xi]", "TI"]]},
   "Ket"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "874baafb-368c-458d-817e-6d37508069b8"],
 " is in the ",
 Cell[BoxData[
  StyleBox["\[Xi]", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "49217a78-1a21-4eed-b8c2-8bd8bc8f4281"],
 "-basis and ",
 Cell[BoxData[
  TemplateBox[{
    SubscriptBox[
     StyleBox["\[Psi]", "TI"], 
     StyleBox["\[Omega]", "TI"]]},
   "Ket"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "c368fb66-a34b-4163-b5b3-c2f6dd3e83be"],
 " in the ",
 Cell[BoxData[
  StyleBox["\[Omega]", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "e536c5bf-bda8-40cc-be41-113fde7af80a"],
 "-basis, then the coordinates transform as ",
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     SubscriptBox[
      StyleBox["\[Psi]", "TI"], 
      StyleBox["\[Omega]", "TI"]]},
    "Ket"], "=", 
   RowBox[{
    StyleBox["U", "TI"], 
    TemplateBox[{
      SubscriptBox[
       StyleBox["\[Psi]", "TI"], 
       StyleBox["\[Xi]", "TI"]]},
     "Ket"]}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "586f97ba-1581-4f03-9825-d4e34a9030fa"],
 "; so ",
 Cell[BoxData[
  StyleBox["U", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "b3a160d5-5caf-48fc-a3f1-f54c554a59f7"],
 " maps coordinate vectors in basis \[Xi] to coordinate vectors in basis \
\[Omega]. Note that the state in Hilbert space doesn\[CloseCurlyQuote]t \
change; only its coordinates do. Additionally, the density matrix transforms \
as ",
 Cell[BoxData[
  RowBox[{
   SubscriptBox[
    StyleBox["\[Rho]", "TI"], 
    StyleBox["u", "TI"]], "=", 
   StyleBox["U", "TI"], " ", 
   SubscriptBox[
    StyleBox["\[Rho]", "TI"], 
    StyleBox["v", "TI"]], " ", 
   SuperscriptBox[
    StyleBox["U", "TI"], "\[Dagger]"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "7df9fe41-f846-4ad1-aea4-f1da1243247c"],
 ". Let\[CloseCurlyQuote]s do these calculations for some examples."
}], "Text",ExpressionUUID->"0e41d93c-18bd-4507-9131-eaddc05b1fe4"],

Cell["\<\
Find the change-of-basis (unitary) matrix that transforms state coordinates \
from the Pauli-Y to the Pauli-X basis:\
\>", "Text",ExpressionUUID->"1b4cfe38-10bd-4462-971e-7c91cd24dc0c"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"uYtoX", " ", "=", " ", 
   RowBox[{"Outer", "[", 
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{"Conjugate", "[", "#1", "]"}], " ", ".", " ", "#2"}], " ", 
      "&"}], ",", " ", 
     RowBox[{
      RowBox[{"1", "/", 
       RowBox[{"Sqrt", "[", "2", "]"}]}], " ", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"1", ",", " ", "1"}], "}"}], ",", " ", 
        RowBox[{"{", 
         RowBox[{"1", ",", " ", 
          RowBox[{"-", "1"}]}], "}"}]}], "}"}]}], ",", " ", "\n", "   ", 
     RowBox[{
      RowBox[{"1", "/", 
       RowBox[{"Sqrt", "[", "2", "]"}]}], " ", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"1", ",", " ", "I"}], "}"}], ",", " ", 
        RowBox[{"{", 
         RowBox[{"1", ",", " ", 
          RowBox[{"-", "I"}]}], "}"}]}], "}"}]}], ",", " ", "1"}], "]"}]}], 
  ";"}], "\n", 
 RowBox[{"uYtoX", " ", "//", " ", "MatrixForm"}]}], "Input",
 CellLabel->
  "In[141]:= ",ExpressionUUID->"efd54154-e319-4b1b-b930-762c1da8a37c"],

Cell[TextData[{
 "Transform ",
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     SubscriptBox[
      StyleBox["\[Psi]", "TI"], 
      StyleBox["y", "TI"]]},
    "Ket"], "=", 
   RowBox[{
    RowBox[{
     SubscriptBox[
      StyleBox["c", "TI"], 
      StyleBox["R", "TI"]], 
     TemplateBox[{
       StyleBox["R", "TI"]},
      "Ket"]}], "+", 
    RowBox[{
     SubscriptBox[
      StyleBox["c", "TI"], 
      StyleBox["L", "TI"]], 
     TemplateBox[{
       StyleBox["L", "TI"]},
      "Ket"]}]}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "08d0d2f9-19cb-4291-b7fc-47f69647143b"],
 " to Pauli-X basis:"
}], "Text",ExpressionUUID->"e4061958-a481-42ab-8b7b-6dffdcec4c75"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"ClearAll", "[", "c", "]"}], ";"}], "\n", 
 RowBox[{"uYtoX", " ", ".", " ", 
  RowBox[{"{", 
   RowBox[{
    RowBox[{"Subscript", "[", 
     RowBox[{"c", ",", " ", "R"}], "]"}], ",", " ", 
    RowBox[{"Subscript", "[", 
     RowBox[{"c", ",", " ", "L"}], "]"}]}], "}"}]}]}], "Input",
 CellLabel->
  "In[142]:= ",ExpressionUUID->"fa9ae2f3-32fb-42ba-8ddc-001dfd622a17"],

Cell[TextData[{
 "Compute ",
 Cell[BoxData[
  TemplateBox[{
    SubscriptBox[
     StyleBox["x", "TI"], "\[PlusMinus]"], 
    SubscriptBox[
     StyleBox["\[Psi]", "TI"], 
     StyleBox["y", "TI"]]},
   "BraKet"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "c42b2049-0322-41ce-bc74-08e94d2d9f98"],
 " explicitly and verify it is the same as above result:"
}], "Text",ExpressionUUID->"80190a88-64a2-426c-99cd-553aa4190002"],

Cell[BoxData[
 RowBox[{"With", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"\[Psi]Y", " ", "=", " ", "\n", "   ", 
     RowBox[{
      RowBox[{
       RowBox[{"Subscript", "[", 
        RowBox[{"c", ",", " ", "R"}], "]"}], " ", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"1", ",", " ", "I"}], "}"}], "/", 
        RowBox[{"Sqrt", "[", "2", "]"}]}]}], " ", "+", " ", "\n", "    ", 
      RowBox[{
       RowBox[{"Subscript", "[", 
        RowBox[{"c", ",", " ", "L"}], "]"}], " ", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"1", ",", " ", 
          RowBox[{"-", "I"}]}], "}"}], "/", 
        RowBox[{"Sqrt", "[", "\n", "     ", "2", "]"}]}]}]}]}], "}"}], ",", 
   " ", 
   RowBox[{
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{
        RowBox[{"Conjugate", "[", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{"1", ",", " ", "1"}], "}"}], "/", 
          RowBox[{"Sqrt", "[", "2", "]"}]}], "]"}], " ", ".", " ", 
        "\[Psi]Y"}], ",", " ", "\n", "    ", 
       RowBox[{
        RowBox[{"Conjugate", "[", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{"1", ",", " ", 
            RowBox[{"-", "1"}]}], "}"}], "/", 
          RowBox[{"Sqrt", "[", "2", "]"}]}], "]"}], " ", ".", " ", 
        "\[Psi]Y"}]}], "}"}], " ", "==", " ", "\n", "   ", 
     RowBox[{"uYtoX", " ", ".", " ", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"Subscript", "[", 
         RowBox[{"c", ",", " ", "R"}], "]"}], ",", " ", 
        RowBox[{"Subscript", "[", 
         RowBox[{"c", ",", " ", "L"}], "]"}]}], "}"}]}]}], " ", "//", " ", 
    "FullSimplify"}]}], "]"}]], "Input",
 CellLabel->
  "In[143]:= ",ExpressionUUID->"623404c2-1673-40b9-afb5-428a26ff47b4"],

Cell[TextData[{
 "Compute the density matrix of the state ",
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     SubscriptBox[
      StyleBox["\[Psi]", "TI"], 
      StyleBox["y", "TI"]]},
    "Ket"], "=", 
   RowBox[{
    RowBox[{
     SubscriptBox[
      StyleBox["c", "TI"], 
      StyleBox["R", "TI"]], 
     TemplateBox[{
       StyleBox["R", "TI"]},
      "Ket"]}], "+", 
    RowBox[{
     SubscriptBox[
      StyleBox["c", "TI"], 
      StyleBox["L", "TI"]], 
     TemplateBox[{
       StyleBox["L", "TI"]},
      "Ket"]}]}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "61b539e4-0849-418d-972c-5ac3600376f5"],
 " in the Pauli Y basis:"
}], "Text",ExpressionUUID->"7ed0eb1d-dec3-456c-89eb-e0e0f57d929d"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"\[Rho]Y", " ", "=", " ", "\n", "  ", 
   RowBox[{"TensorProduct", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"Subscript", "[", 
        RowBox[{"c", ",", " ", "R"}], "]"}], ",", " ", 
       RowBox[{"Subscript", "[", 
        RowBox[{"c", ",", " ", "L"}], "]"}]}], "}"}], ",", " ", "\n", "   ", 
     RowBox[{"Conjugate", "[", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"Subscript", "[", 
         RowBox[{"c", ",", " ", "R"}], "]"}], ",", " ", 
        RowBox[{"Subscript", "[", 
         RowBox[{"c", ",", " ", "L"}], "]"}]}], "}"}], "]"}]}], "]"}]}], 
  ";"}], "\n", 
 RowBox[{"\[Rho]Y", " ", "//", " ", "TraditionalForm"}]}], "Input",
 CellLabel->
  "In[144]:= ",ExpressionUUID->"220def6e-5eca-4135-ac0c-b8f74eab6258"],

Cell["\<\
Note that the density matrix is in the Pauli Y basis. Now transform it into \
Pauli-X basis:\
\>", "Text",ExpressionUUID->"09a3b0a4-9860-4dfe-a23a-bd8a99c9a744"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"uYtoX", " ", ".", " ", "\[Rho]Y", " ", ".", " ", 
    RowBox[{"ConjugateTranspose", "[", "uYtoX", "]"}]}], " ", "//", " ", "\n",
    "  ", "Simplify"}], " ", "//", " ", "TraditionalForm"}]], "Input",
 CellLabel->
  "In[145]:= ",ExpressionUUID->"1ee8a799-84b1-40ba-8891-f4315e209d3c"],

Cell["\<\
Confirm the result is the same as the state vector transformation in the \
previous step:\
\>", "Text",ExpressionUUID->"15d3ea93-f131-4024-a5d8-153802fd889e"],

Cell[BoxData[
 RowBox[{
  RowBox[{"With", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"vec", " ", "=", " ", 
      RowBox[{"uYtoX", " ", ".", " ", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"Subscript", "[", 
          RowBox[{"c", ",", " ", "R"}], "]"}], ",", " ", 
         RowBox[{"Subscript", "[", 
          RowBox[{"c", ",", " ", "L"}], "]"}]}], "}"}]}]}], "}"}], ",", " ", 
    "\n", "  ", 
    RowBox[{
     RowBox[{"TensorProduct", "[", 
      RowBox[{"vec", ",", " ", 
       RowBox[{"Conjugate", "[", "vec", "]"}]}], "]"}], " ", "==", " ", "\n", 
     "   ", 
     RowBox[{"uYtoX", " ", ".", " ", "\[Rho]Y", " ", ".", " ", 
      RowBox[{"ConjugateTranspose", "[", "uYtoX", "]"}]}]}]}], "]"}], " ", "//",
   " ", "FullSimplify"}]], "Input",
 CellLabel->
  "In[146]:= ",ExpressionUUID->"58e67942-2603-4ca8-a97b-603ade935c79"],

Cell[TextData[{
 "For a single qubit, the most famous mixed state is the maximally mixed \
state: ",
 Cell[BoxData[
  RowBox[{
   StyleBox["\[Rho]", "TI"], "=", "\|01d540", "/", "2"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "fea51828-078d-44a9-bc5f-dbd2d8693dd6"],
 ". One can show that its representation is the same in any basis, because \
the transformation is described as ",
 Cell[BoxData[
  RowBox[{
   StyleBox["U", "TI"], ".", 
   StyleBox["\[Rho]", "TI"], ".", 
   RowBox[{
    SuperscriptBox[
     StyleBox["U", "TI"], "\[Dagger]"], "=", 
    StyleBox["U", "TI"]}], ".", "\|01d540", ".", 
   RowBox[{
    SuperscriptBox[
     StyleBox["U", "TI"], "\[Dagger]"], "/", "2", "=", 
    StyleBox["U", "TI"]}], ".", 
   RowBox[{
    SuperscriptBox[
     StyleBox["U", "TI"], "\[Dagger]"], "/", "2", "=", "\|01d540", "/", 
    "2"}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "813841a5-31b0-4f0e-a877-741082af6339"],
 "."
}], "Text",ExpressionUUID->"c064b49f-046a-452d-be79-f46f065359f3"],

Cell["\<\
Now that we can represent states geometrically, let\[CloseCurlyQuote]s focus \
on their movement: what operations move us around the Bloch sphere, and how \
does the algebra of those operations encode 3D rotations?\
\>", "Text",ExpressionUUID->"9a261cbe-3a06-4d63-9d99-f4fce05ca922"],

Cell["Part II: Operators, SU(2), and Rotations", "Section",ExpressionUUID->"0d5b9db4-aee2-48d5-895a-ed12568848e5"],

Cell["Unitaries and SU(2): The Home of Single-Qubit Dynamics", "Subsection",ExpressionUUID->"f413beeb-fb30-4e05-887e-043244c4a1ae"],

Cell[TextData[{
 "Let\[CloseCurlyQuote]s focus more on unitary operators for qubits. SU(2) is \
the mathematical home of all physically distinct single-qubit unitary \
operations. For all ",
 Cell[BoxData[
  RowBox[{"2", "\[Times]", "2"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "6e8fb3d7-bc69-4bcf-83c5-ff7f1c8c39df"],
 " unitaries we have ",
 Cell[BoxData[
  RowBox[{
   RowBox[{
    StyleBox["U", "TI"], 
    StyleBox["(",
     SpanMaxSize->1], "2", 
    StyleBox[")",
     SpanMaxSize->1], "=", "{", 
    StyleBox["U", "TI"], "\[Element]", 
    SuperscriptBox["\:2102", 
     RowBox[{"2", "\[Times]", "2"}]]}], 
   StyleBox["|",
    SpanMaxSize->1], 
   RowBox[{
    SuperscriptBox[
     StyleBox["U", "TI"], "\[Dagger]"], " ", 
    StyleBox["U", "TI"], "=", "\|01d540", "}"}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "80e4392a-2c3f-4ab9-ba78-816f217fd09c"],
 ". SU(2) group has unitaries with determinant 1: ",
 Cell[BoxData[
  RowBox[{
   RowBox[{
    StyleBox["S", "TI"], 
    StyleBox["U", "TI"], 
    StyleBox["(",
     SpanMaxSize->1], "2", 
    StyleBox[")",
     SpanMaxSize->1], "=", "{", 
    StyleBox["U", "TI"], "\[Element]", 
    StyleBox["U", "TI"], 
    StyleBox["(",
     SpanMaxSize->1], "2", 
    StyleBox[")",
     SpanMaxSize->1]}], 
   StyleBox["|",
    SpanMaxSize->1], 
   RowBox[{
    StyleBox["d", "TI"], 
    StyleBox["e", "TI"], 
    StyleBox["t", "TI"], 
    StyleBox["(",
     SpanMaxSize->1], 
    StyleBox["U", "TI"], 
    StyleBox[")",
     SpanMaxSize->1], "=", "1", "}"}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "003ecf8b-dbfe-4380-b3e4-8fc49543381f"],
 ". For any element in SU(2), a very handy characterization is: ",
 Cell[BoxData[
  RowBox[{
   StyleBox["U", "TI"], "=", "(", GridBox[{
     {
      StyleBox["a", "TI"], 
      StyleBox["b", "TI"]},
     {
      RowBox[{"-", 
       SuperscriptBox[
        StyleBox["b", "TI"], "*"]}], 
      SuperscriptBox[
       StyleBox["a", "TI"], "*"]}
    }], ")"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "d28f7a42-ab69-4e3c-a32a-ba980a538107"],
 " with ",
 Cell[BoxData[
  RowBox[{
   RowBox[{
    SuperscriptBox[
     TemplateBox[{
       RowBox[{
         StyleBox["a", "TI"], "\[VeryThinSpace]"}]},
      "Abs"], "2"], "+", 
    SuperscriptBox[
     TemplateBox[{
       RowBox[{
         StyleBox["b", "TI"], "\[VeryThinSpace]"}]},
      "Abs"], "2"]}], "=", "1"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "0ebc2504-d12b-4225-8963-ec060c731d12"],
 ". This shows SU(2) has 3 real degrees of freedom (like a 3D rotation). \
SU(2) describes all \[OpenCurlyDoubleQuote]qubit rotations\
\[CloseCurlyDoubleQuote] (up to an overall phase)."
}], "Text",ExpressionUUID->"df771fd5-dc34-4b34-bbb0-31459c831d5e"],

Cell["\<\
Define a function that generates random special unitary matrices (elements of \
SU(2)) sampled from the Haar measure:\
\>", "Text",ExpressionUUID->"b5ed54aa-c120-416d-80bc-3f8942f53a93"],

Cell[BoxData[
 RowBox[{
  RowBox[{"RandomSU2", "[", "]"}], " ", ":=", " ", "\n", " ", 
  RowBox[{"With", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"u", " ", "=", " ", 
      RowBox[{"RandomVariate", "@", 
       RowBox[{"CircularUnitaryMatrixDistribution", "[", "2", "]"}]}]}], 
     "}"}], ",", " ", "\n", "  ", 
    RowBox[{
     RowBox[{"u", "/", 
      RowBox[{"Sqrt", "[", 
       RowBox[{"Det", "[", "u", "]"}], "]"}]}], " ", "//", " ", "Chop"}]}], 
   "]"}]}]], "Input",
 CellLabel->
  "In[147]:= ",ExpressionUUID->"2c7c69c5-c10b-42d7-ae6e-0ac45d71e42e"],

Cell[TextData[{
 "For a random SU(2) element, verify that it has the form ",
 Cell[BoxData[
  RowBox[{
   StyleBox["U", "TI"], "=", "(", GridBox[{
     {
      StyleBox["a", "TI"], 
      StyleBox["b", "TI"]},
     {
      RowBox[{"-", 
       SuperscriptBox[
        StyleBox["b", "TI"], "*"]}], 
      SuperscriptBox[
       StyleBox["a", "TI"], "*"]}
    }], ")"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "8ca0dfe9-2a60-4b8f-9aaf-0e3790f04698"],
 ":"
}], "Text",ExpressionUUID->"635f064b-616e-4282-88b3-57904fa49c6e"],

Cell[BoxData[
 RowBox[{"With", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"u", " ", "=", " ", 
     RowBox[{"RandomSU2", "[", "]"}]}], "}"}], ",", " ", "\n", " ", 
   RowBox[{
    RowBox[{
     RowBox[{"u", "[", 
      RowBox[{"[", 
       RowBox[{"1", ",", " ", "1"}], "]"}], "]"}], " ", "==", " ", 
     RowBox[{"Conjugate", "[", 
      RowBox[{"u", "[", 
       RowBox[{"[", 
        RowBox[{"2", ",", " ", "2"}], "]"}], "]"}], "]"}]}], " ", "&&", " ", 
    RowBox[{
     RowBox[{"u", "[", 
      RowBox[{"[", 
       RowBox[{"1", ",", " ", "2"}], "]"}], "]"}], " ", "==", " ", 
     RowBox[{"-", 
      RowBox[{"Conjugate", "[", 
       RowBox[{"u", "[", 
        RowBox[{"[", 
         RowBox[{"2", ",", " ", "1"}], "]"}], "]"}], "]"}]}]}]}]}], 
  "]"}]], "Input",
 CellLabel->
  "In[148]:= ",ExpressionUUID->"6cba44f5-e96a-41ba-833f-90d8d768acf0"],

Cell["\<\
Lie Groups and Lie Algebras: Generators, Exponentials, and Conventions\
\>", "Subsection",ExpressionUUID->"8bdcc17b-18c5-4714-b9d0-9d197133ba83"],

Cell["\<\
You may have noticed we used the term \[OpenCurlyDoubleQuote]group\
\[CloseCurlyDoubleQuote] when referring to SU(2). What is a group in this \
context? A group is a set of objects that you can compose (or \
\[OpenCurlyDoubleQuote]multiply\[CloseCurlyDoubleQuote]) in a way that \
behaves nicely: (i) combining two objects keeps you inside the set (closure), \
(ii) there is an identity element that does nothing, and (iii) every element \
has an inverse that undoes it. In our setting, the objects are matrices and \
the \[OpenCurlyDoubleQuote]multiplication\[CloseCurlyDoubleQuote] is ordinary \
matrix multiplication. So SU(2) is a matrix group: multiply two SU(2) \
matrices and you get another SU(2) matrix.\
\>", "Text",ExpressionUUID->"7f27f4de-564a-48bf-aef5-ad940fb1e1c8"],

Cell["\<\
What makes SU(2) especially important in quantum mechanics is that it\
\[CloseCurlyQuote]s also continuous: its elements vary smoothly with real \
parameters, and you can move from one element to a nearby one by making an \
arbitrarily small change. A group equipped with this kind of smooth structure \
is called a Lie group.\
\>", "Text",ExpressionUUID->"e1144718-9455-481f-a5e5-4d96d778fa12"],

Cell["\<\
Once we know the group is smooth, it makes sense to study it \
\[OpenCurlyDoubleQuote]from the inside out\[CloseCurlyDoubleQuote]: start at \
the identity (the \[OpenCurlyDoubleQuote]do nothing\[CloseCurlyDoubleQuote] \
transformation) and ask what infinitesimal transformations are possible. The \
collection of these infinitesimal directions is the Lie algebra. The Lie \
group describes finite transformations, while the Lie algebra describes the \
infinitesimal generators that, when exponentiated, produce finite \
transformations.\
\>", "Text",ExpressionUUID->"649fe314-81cf-4e5d-846a-4749dd503535"],

Cell[TextData[{
 "Pauli operators (the Pauli matrices) are \[OpenCurlyDoubleQuote]generators \
of SU(2)\[CloseCurlyDoubleQuote] because, up to a constant factor, they form \
a basis for the Lie algebra of SU(2), and exponentiating elements of that Lie \
algebra produces every SU(2) matrix. The generators of a Lie group are \
elements of its Lie algebra. For SU(2), the Lie algebra is: ",
 Cell[BoxData[
  RowBox[{
   RowBox[{"\|01d530", "\|01d532", 
    StyleBox["(",
     SpanMaxSize->1], "2", 
    StyleBox[")",
     SpanMaxSize->1], "=", "{", 
    StyleBox["X", "TI"], "\[Element]", 
    SuperscriptBox["\:2102", 
     RowBox[{"2", "\[Times]", "2"}]]}], ":", 
   RowBox[{
    SuperscriptBox[
     StyleBox["X", "TI"], "\[Dagger]"], "=", "-", 
    StyleBox["X", "TI"]}], ",", 
   RowBox[{
    StyleBox["T", "TI"], 
    StyleBox["r", "TI"], 
    StyleBox["[",
     SpanMaxSize->1], 
    StyleBox["X", "TI"], 
    StyleBox["]",
     SpanMaxSize->1], "=", "0", "}"}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "9c9aae0a-97af-481b-ae77-b2f7852c0898"],
 ", i.e. traceless anti-Hermitian matrices. So this implies that ",
 Cell[BoxData[
  RowBox[{
   RowBox[{"{", 
    StyleBox["i", "TI"], 
    SubscriptBox[
     StyleBox["\[Sigma]", "TI"], 
     StyleBox["x", "TI"]]}], ",", 
   RowBox[{
    StyleBox["i", "TI"], 
    SubscriptBox[
     StyleBox["\[Sigma]", "TI"], 
     StyleBox["y", "TI"]]}], ",", 
   RowBox[{
    StyleBox["i", "TI"], 
    SubscriptBox[
     StyleBox["\[Sigma]", "TI"], 
     StyleBox["z", "TI"]], "}", "\[Element]", "\|01d530", "\|01d532", 
    StyleBox["(",
     SpanMaxSize->1], "2", 
    StyleBox[")",
     SpanMaxSize->1]}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "92753c4d-472c-480d-913a-7e8c9e430388"],
 ". Equivalently, one may use ",
 Cell[BoxData[
  RowBox[{
   RowBox[{"{", "-", 
    StyleBox["i", "TI"], 
    SubscriptBox[
     StyleBox["\[Sigma]", "TI"], 
     StyleBox["x", "TI"]]}], ",", 
   RowBox[{"-", 
    StyleBox["i", "TI"], 
    SubscriptBox[
     StyleBox["\[Sigma]", "TI"], 
     StyleBox["y", "TI"]]}], ",", 
   RowBox[{"-", 
    StyleBox["i", "TI"], 
    SubscriptBox[
     StyleBox["\[Sigma]", "TI"], 
     StyleBox["z", "TI"]], "}", "\[Element]", "\|01d530", "\|01d532", 
    StyleBox["(",
     SpanMaxSize->1], "2", 
    StyleBox[")",
     SpanMaxSize->1]}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "4d2ce1fe-9431-4001-8f79-552bc9291540"],
 "."
}], "Text",ExpressionUUID->"5fd1299b-d73e-4175-b770-9114184d0cb0"],

Cell[TextData[{
 "Verify that multiplying Pauli operators by i or ",
 Cell[BoxData[
  RowBox[{"-", 
   StyleBox["i", "TI"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "8aebacc5-9709-4560-af46-620f9dec3d4f"],
 " makes them anti-Hermitian:"
}], "Text",ExpressionUUID->"1d8b3b4d-d6d7-496b-9af4-680b21e10ff3"],

Cell[BoxData[
 RowBox[{"Table", "[", 
  RowBox[{
   RowBox[{"With", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"x", " ", "=", " ", 
        RowBox[{"I", " ", 
         RowBox[{"PauliMatrix", "[", "j", "]"}]}]}], ",", " ", 
       RowBox[{"y", " ", "=", " ", 
        RowBox[{
         RowBox[{"-", "I"}], " ", 
         RowBox[{"PauliMatrix", "[", "j", "]"}]}]}]}], "}"}], ",", " ", "\n", 
     "  ", 
     RowBox[{
      RowBox[{
       RowBox[{"ConjugateTranspose", "[", "x", "]"}], " ", "==", " ", 
       RowBox[{"-", "x"}]}], " ", "&&", " ", 
      RowBox[{
       RowBox[{"ConjugateTranspose", "[", "y", "]"}], " ", "==", " ", 
       RowBox[{"-", "y"}]}]}]}], "]"}], ",", " ", 
   RowBox[{"{", 
    RowBox[{"j", ",", " ", "3"}], "}"}]}], "]"}]], "Input",
 CellLabel->
  "In[149]:= ",ExpressionUUID->"9b91b410-c3f9-48cb-91b6-8354407e86d3"],

Cell["Verify that Pauli operators are also traceless:", "Text",ExpressionUUID->"5fea40a4-f2a1-40d7-b62b-544269aac4f4"],

Cell[BoxData[
 RowBox[{"Table", "[", 
  RowBox[{
   RowBox[{"With", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"x", " ", "=", " ", 
       RowBox[{"I", " ", 
        RowBox[{"PauliMatrix", "[", "j", "]"}]}]}], "}"}], ",", " ", 
     RowBox[{
      RowBox[{"Tr", "[", "x", "]"}], " ", "==", " ", "0"}]}], "]"}], ",", " ", 
   RowBox[{"{", 
    RowBox[{"j", ",", " ", "3"}], "}"}]}], "]"}]], "Input",
 CellLabel->
  "In[150]:= ",ExpressionUUID->"a6f480c3-a9e3-4c0d-8d68-2b92fc6a1856"],

Cell["Commutators, Levi\[Dash]Civita, and the Pauli Product Identity", \
"Subsection",ExpressionUUID->"6985a1b6-513a-4ca5-84e2-11c0011634be"],

Cell[TextData[{
 "A hallmark of \[OpenCurlyDoubleQuote]being the generators\
\[CloseCurlyDoubleQuote] is satisfying the right Lie bracket relations (the \
commutation relations). The Lie bracket relation of ",
 Cell[BoxData[
  StyleBox["A", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "387470f3-d2c9-4cfb-87ae-bcdc763d61e9"],
 " and ",
 Cell[BoxData[
  StyleBox["B", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "0d301e42-ff20-46df-a3e3-c77e585588c0"],
 " is defined as ",
 Cell[BoxData[
  RowBox[{
   RowBox[{
    StyleBox["[",
     SpanMaxSize->1], 
    RowBox[{
     StyleBox["A", "TI"], ",", 
     StyleBox["B", "TI"]}], 
    StyleBox["]",
     SpanMaxSize->1], "=", 
    StyleBox["A", "TI"]}], ".", 
   RowBox[{
    StyleBox["B", "TI"], "-", 
    StyleBox["B", "TI"]}], ".", 
   StyleBox["A", "TI"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "2f816a9e-857a-4bd3-910f-90a114331fb7"],
 ". Denoting \|01d530\|01d532(2) generators as ",
 Cell[BoxData[
  RowBox[{"{", 
   SubscriptBox[
    StyleBox["J", "TI"], 
    StyleBox["i", "TI"]], "}"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "ca7b83a9-acad-4a0c-8ce7-2e90932f50b4"],
 ", their canonical commutation relation is ",
 Cell[BoxData[
  RowBox[{
   StyleBox["[",
    SpanMaxSize->1], 
   RowBox[{
    SubscriptBox[
     StyleBox["J", "TI"], 
     StyleBox["i", "TI"]], ",", 
    SubscriptBox[
     StyleBox["J", "TI"], 
     StyleBox["j", "TI"]]}], 
   StyleBox["]",
    SpanMaxSize->1], "=", 
   StyleBox["i", "TI"], " ", 
   UnderscriptBox["\[Sum]", 
    StyleBox["k", "TI"],
    LimitsPositioning->False], 
   SubscriptBox["\[Epsilon]", 
    StyleBox[
     RowBox[{"i", "j", "k"}], "TI"]], 
   SubscriptBox[
    StyleBox["J", "TI"], 
    StyleBox["k", "TI"]]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "ba804484-bff3-4ff1-a514-396527a37dc3"],
 " where ",
 Cell[BoxData[
  SubscriptBox["\[Epsilon]", 
   StyleBox[
    RowBox[{"i", "j", "k"}], "TI"]]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "ca47f061-46b5-4d76-b1cf-8ce4ac35a73c"],
 " is the 3-dimensional Levi-Civita totally antisymmetric tensor. Note that \
the relation ",
 Cell[BoxData[
  RowBox[{
   StyleBox["[",
    SpanMaxSize->1], 
   RowBox[{
    SubscriptBox[
     StyleBox["J", "TI"], 
     StyleBox["i", "TI"]], ",", 
    SubscriptBox[
     StyleBox["J", "TI"], 
     StyleBox["j", "TI"]]}], 
   StyleBox["]",
    SpanMaxSize->1], "=", 
   StyleBox["i", "TI"], " ", 
   UnderscriptBox["\[Sum]", 
    StyleBox["k", "TI"],
    LimitsPositioning->False], 
   SubscriptBox["\[Epsilon]", 
    StyleBox[
     RowBox[{"i", "j", "k"}], "TI"]], 
   SubscriptBox[
    StyleBox["J", "TI"], 
    StyleBox["k", "TI"]]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "b7edd540-5b33-46bd-ad38-6b64228a9d58"],
 " is often written in the shorthand form ",
 Cell[BoxData[
  RowBox[{
   StyleBox["[",
    SpanMaxSize->1], 
   RowBox[{
    SubscriptBox[
     StyleBox["J", "TI"], 
     StyleBox["i", "TI"]], ",", 
    SubscriptBox[
     StyleBox["J", "TI"], 
     StyleBox["j", "TI"]]}], 
   StyleBox["]",
    SpanMaxSize->1], "=", 
   StyleBox["i", "TI"], " ", 
   SubscriptBox["\[Epsilon]", 
    StyleBox[
     RowBox[{"i", "j", "k"}], "TI"]], 
   SubscriptBox[
    StyleBox["J", "TI"], 
    StyleBox["k", "TI"]]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "d4902c18-3923-42a2-9d3c-ce3f94c2f669"],
 " where the repeated index (here ",
 Cell[BoxData[
  StyleBox["k", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "6a3382f1-374d-4c4b-aa5b-8e0f10f4927a"],
 ") is understood to be summed over (",
 ButtonBox["Einstein summation",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://mathworld.wolfram.com/EinsteinSummation.html"], None}],
 " convention)."
}], "Text",ExpressionUUID->"15914cc6-9272-4fbf-9fb7-944b7e28a894"],

Cell["Dimensions of 3D Levi-Civita tensor:", "Text",ExpressionUUID->"967895f5-12d0-4195-942c-c616f1810af9"],

Cell[BoxData[
 RowBox[{
  RowBox[{"LeviCivitaTensor", "[", "3", "]"}], " ", "//", " ", 
  "TensorDimensions"}]], "Input",
 CellLabel->
  "In[151]:= ",ExpressionUUID->"154b7e06-3f21-4582-9bf7-f6542a8a37c0"],

Cell["Visualize 3D Levi-Civita tensor:", "Text",ExpressionUUID->"ce94f6f1-2b75-4c45-a787-f95b70fab495"],

Cell[BoxData[
 RowBox[{"ArrayPlot3D", "[", 
  RowBox[{
   RowBox[{"LeviCivitaTensor", "[", "3", "]"}], ",", " ", 
   RowBox[{"Axes", " ", "->", " ", "True"}], ",", " ", 
   RowBox[{"AxesStyle", " ", "->", " ", 
    RowBox[{"Opacity", "[", "0", "]"}]}], ",", "\n", "  ", 
   RowBox[{"TicksStyle", " ", "->", " ", 
    RowBox[{"Opacity", "[", "1", "]"}]}], ",", " ", 
   RowBox[{"Mesh", " ", "->", " ", "All"}], ",", " ", "\n", " ", 
   RowBox[{"ColorRules", " ", "->", " ", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"1", " ", "->", " ", "Yellow"}], ",", " ", 
      RowBox[{
       RowBox[{"-", "1"}], " ", "->", " ", "Orange"}]}], "}"}]}], ",", " ", 
   RowBox[{"Boxed", " ", "->", " ", "False"}], ",", " ", "\n", " ", 
   RowBox[{"PlotLegends", " ", "->", " ", "Automatic"}], ",", " ", "\n", " ", 
   
   RowBox[{
   "PlotLabel", " ", "->", " ", "\n", 
    "  ", "\"\<Levi-Civita tensor \\!\\(\\*SubscriptBox[\\(\[Epsilon]\\), \
\\(ijk\\)]\\)\>\""}], ",", " ", "\n", " ", 
   RowBox[{"ImageSize", " ", "->", " ", "Small"}], ",", " ", "\n", " ", 
   RowBox[{"AxesLabel", " ", "->", " ", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{
       RowBox[{"Style", "[", 
        RowBox[{"#", ",", " ", "14", ",", " ", "Black", ",", " ", 
         RowBox[{"Opacity", "[", "1", "]"}]}], "]"}], " ", "&"}], " ", "/@", 
      " ", 
      RowBox[{"{", 
       RowBox[{"\"\<k\>\"", ",", " ", "\"\<j\>\"", ",", " ", "\"\<i\>\""}], 
       "}"}]}], ")"}]}]}], "]"}]], "Input",
 CellLabel->
  "In[152]:= ",ExpressionUUID->"238c48c0-fa69-435b-82cb-2244f56f0e54"],

Cell[TextData[{
 "Note that the above ",
 Cell[BoxData[
  RowBox[{"3", "\[Times]", "3", "\[Times]", "3"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "c0e61e93-a610-4cfa-9b2b-fea5383579a7"],
 " cube has only 6 nonzero cells. In 3D, the Levi\[Dash]Civita symbol ",
 Cell[BoxData[
  SubscriptBox["\[Epsilon]", 
   StyleBox[
    RowBox[{"i", "j", "k"}], "TI"]]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "378e51df-7c0d-470e-a4cb-1d134a300aea"],
 " is best understood as \[OpenCurlyDoubleQuote]orientation (right-hand rule) \
packaged into indices.\[CloseCurlyDoubleQuote] Using the cyclic order 1\
\[RightArrow]2\[RightArrow]3\[RightArrow]1: if (i, j, k) follows this cycle \
(e.g., ",
 Cell[BoxData[
  SubscriptBox["\[Epsilon]", "231"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "a05e3cef-f026-40db-9d53-3fefdc9ebc87"],
 "), then ",
 Cell[BoxData[
  RowBox[{
   SubscriptBox["\[Epsilon]", 
    StyleBox[
     RowBox[{"i", "j", "k"}], "TI"]], "=", "1"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "4ccaa3c7-04be-466f-a329-5d4703688a9f"],
 "; if it runs against the cycle (e.g., ",
 Cell[BoxData[
  SubscriptBox["\[Epsilon]", "132"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "949f56d6-3fbd-46ca-9769-9d6a9fdc279d"],
 "), then ",
 Cell[BoxData[
  RowBox[{
   SubscriptBox["\[Epsilon]", 
    StyleBox[
     RowBox[{"i", "j", "k"}], "TI"]], "=", "-", "1"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "894aa28e-19bb-4686-9747-40901e86c618"],
 "; and if any index is repeated, then ",
 Cell[BoxData[
  RowBox[{
   SubscriptBox["\[Epsilon]", 
    StyleBox[
     RowBox[{"i", "j", "k"}], "TI"]], "=", "0"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "4066dfb5-899b-4854-8517-664852c60c29"],
 ". One of the important use of ",
 Cell[BoxData[
  SubscriptBox["\[Epsilon]", 
   StyleBox[
    RowBox[{"i", "j", "k"}], "TI"]]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "d835cc05-738c-48c9-ac4b-f70d8260be91"],
 " is in the cross product\[CloseCurlyQuote]s multiplication table: ",
 Cell[BoxData[
  RowBox[{
   SubscriptBox[
    RowBox[{
     StyleBox["(",
      SpanMaxSize->1], 
     RowBox[{
      OverscriptBox[
       StyleBox["a", "TI"], "\[RightVector]"], "\[Times]", 
      OverscriptBox[
       StyleBox["b", "TI"], "\[RightVector]"]}], 
     StyleBox[")",
      SpanMaxSize->1]}], 
    StyleBox["i", "TI"]], "=", 
   UnderscriptBox["\[Sum]", 
    RowBox[{
     StyleBox["j", "TI"], ",", 
     StyleBox["k", "TI"]}],
    LimitsPositioning->False], 
   SubscriptBox["\[Epsilon]", 
    StyleBox[
     RowBox[{"i", "j", "k"}], "TI"]], 
   SubscriptBox[
    StyleBox["a", "TI"], 
    StyleBox["j", "TI"]], 
   SubscriptBox[
    StyleBox["b", "TI"], 
    StyleBox["k", "TI"]]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "80b607c3-4de3-4b3e-ad35-6be363066e1a"],
 "."
}], "Text",ExpressionUUID->"ed302000-fe72-45a9-95ac-492d4e54a29e"],

Cell[TextData[{
 "Verify that ",
 Cell[BoxData[
  RowBox[{
   SubscriptBox[
    RowBox[{
     StyleBox["(",
      SpanMaxSize->1], 
     RowBox[{
      OverscriptBox[
       StyleBox["a", "TI"], "\[RightVector]"], "\[Times]", 
      OverscriptBox[
       StyleBox["b", "TI"], "\[RightVector]"]}], 
     StyleBox[")",
      SpanMaxSize->1]}], 
    StyleBox["i", "TI"]], "=", 
   UnderscriptBox["\[Sum]", 
    RowBox[{
     StyleBox["j", "TI"], ",", 
     StyleBox["k", "TI"]}],
    LimitsPositioning->False], 
   SubscriptBox["\[Epsilon]", 
    StyleBox[
     RowBox[{"i", "j", "k"}], "TI"]], 
   SubscriptBox[
    StyleBox["a", "TI"], 
    StyleBox["j", "TI"]], 
   SubscriptBox[
    StyleBox["b", "TI"], 
    StyleBox["k", "TI"]]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "12e29de4-dcdc-4d8d-8d1a-55ff06ccb33b"],
 ":"
}], "Text",ExpressionUUID->"59abffa2-4465-4e95-89ea-c944afc85685"],

Cell[BoxData[
 RowBox[{"With", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{"v1", " ", "=", " ", 
      RowBox[{"Array", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"Subscript", "[", 
          RowBox[{"\[FormalA]", ",", " ", "##"}], "]"}], " ", "&"}], ",", " ",
         "3"}], "]"}]}], ",", " ", "\n", "  ", 
     RowBox[{"v2", " ", "=", " ", 
      RowBox[{"Array", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"Subscript", "[", 
          RowBox[{"\[FormalB]", ",", " ", "##"}], "]"}], " ", "&"}], ",", " ",
         "3"}], "]"}]}]}], "}"}], ",", " ", "\n", " ", 
   RowBox[{
    RowBox[{"Cross", "[", 
     RowBox[{"v1", ",", " ", "v2"}], "]"}], " ", "==", " ", "\n", "  ", 
    RowBox[{"TensorContract", "[", "\n", "   ", 
     RowBox[{
      RowBox[{"TensorProduct", "[", 
       RowBox[{
        RowBox[{"LeviCivitaTensor", "[", "3", "]"}], ",", " ", "v1", ",", " ",
         "v2"}], "]"}], ",", " ", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"2", ",", " ", "4"}], "}"}], ",", " ", 
        RowBox[{"{", 
         RowBox[{"3", ",", " ", "5"}], "}"}]}], "}"}]}], "]"}]}]}], 
  "]"}]], "Input",
 CellLabel->
  "In[153]:= ",ExpressionUUID->"63021ebc-4231-4038-875d-92ce91a125d6"],

Cell[TextData[{
 "Note that the equation ",
 Cell[BoxData[
  RowBox[{
   SubscriptBox[
    RowBox[{
     StyleBox["(",
      SpanMaxSize->1], 
     RowBox[{
      OverscriptBox[
       StyleBox["a", "TI"], "\[RightVector]"], "\[Times]", 
      OverscriptBox[
       StyleBox["b", "TI"], "\[RightVector]"]}], 
     StyleBox[")",
      SpanMaxSize->1]}], 
    StyleBox["i", "TI"]], "=", 
   UnderscriptBox["\[Sum]", 
    RowBox[{
     StyleBox["j", "TI"], ",", 
     StyleBox["k", "TI"]}],
    LimitsPositioning->False], 
   SubscriptBox["\[Epsilon]", 
    StyleBox[
     RowBox[{"i", "j", "k"}], "TI"]], 
   SubscriptBox[
    StyleBox["a", "TI"], 
    StyleBox["j", "TI"]], 
   SubscriptBox[
    StyleBox["b", "TI"], 
    StyleBox["k", "TI"]]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "078b273c-2071-4fa8-8ac2-c810c5d5ec59"],
 " is written only for ",
 Cell[BoxData[
  StyleBox["i", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "a113e23e-2937-43c1-a4b5-aa1ef8ceb55b"],
 "-th element of 3-component vector ",
 Cell[BoxData[
  RowBox[{
   OverscriptBox[
    StyleBox["a", "TI"], "\[RightVector]"], "\[Times]", 
   OverscriptBox[
    StyleBox["b", "TI"], "\[RightVector]"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "de2b543a-2a69-4f69-a346-e397bd8c2a90"],
 ". n the code above, the left-hand side is represented as ",
 Cell[BoxData[
  RowBox[{
   StyleBox["Cross",
    FontSlant->"Plain"], 
   StyleBox["[",
    SpanMaxSize->1], 
   RowBox[{
    RowBox[{
     StyleBox["v", "TI"], "1"}], ",", 
    RowBox[{
     StyleBox["v", "TI"], "2"}]}], 
   StyleBox["]",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "d8ae73ed-ee79-4062-be2a-335ec14f22c5"],
 ". On the right-hand side, we first form the tensor product of the Levi\
\[Dash]Civita symbol ",
 Cell[BoxData[
  SubscriptBox["\[Epsilon]", 
   StyleBox[
    RowBox[{"i", "j", "k"}], "TI"]]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "27e4a4cc-7845-4164-84f5-2c11d7c04638"],
 ", ",
 Cell[BoxData[
  OverscriptBox[
   StyleBox["a", "TI"], "\[RightVector]"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "32a7c333-96fe-4a06-9ff7-947f9e5b0001"],
 ", and ",
 Cell[BoxData[
  OverscriptBox[
   StyleBox["b", "TI"], "\[RightVector]"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "b2b341aa-4c91-4f77-95c3-c6347a7ddd57"],
 " by ",
 Cell[BoxData[
  RowBox[{
   StyleBox["TensorProduct",
    FontSlant->"Plain"], 
   StyleBox["[",
    SpanMaxSize->1], 
   RowBox[{
    RowBox[{
     StyleBox["L", "TI"], 
     StyleBox["e", "TI"], 
     StyleBox["v", "TI"], 
     StyleBox["i", "TI"], 
     StyleBox["C", "TI"], 
     StyleBox["i", "TI"], 
     StyleBox["v", "TI"], 
     StyleBox["i", "TI"], 
     StyleBox["t", "TI"], 
     StyleBox["a", "TI"], 
     StyleBox["T", "TI"], 
     StyleBox["e", "TI"], 
     StyleBox["n", "TI"], 
     StyleBox["s", "TI"], 
     StyleBox["o", "TI"], 
     StyleBox["r", "TI"], 
     StyleBox["[",
      SpanMaxSize->1], "3", 
     StyleBox["]",
      SpanMaxSize->1]}], ",", 
    RowBox[{
     StyleBox["v", "TI"], "1"}], ",", 
    RowBox[{
     StyleBox["v", "TI"], "2"}]}], 
   StyleBox["]",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "7d93d4b7-9b7e-4ab2-b433-98b07c8b84ce"],
 ". This produces a tensor with five indices: the first three indices \
correspond to ",
 Cell[BoxData[
  SubscriptBox["\[Epsilon]", 
   StyleBox[
    RowBox[{"i", "j", "k"}], "TI"]]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "b9e01a9d-7841-4e93-b506-c63fb2cabe77"],
 ", the fourth index corresponds to the components of ",
 Cell[BoxData[
  OverscriptBox[
   StyleBox["a", "TI"], "\[RightVector]"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "68cc5f6b-8113-44f1-a35a-2ec61aa257b8"],
 ", and the fifth index corresponds to the components of ",
 Cell[BoxData[
  OverscriptBox[
   StyleBox["b", "TI"], "\[RightVector]"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "8c57587b-c82c-4241-85b4-b7cc51fac561"],
 ". The summation over ",
 Cell[BoxData[
  StyleBox["j", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "0c0e8191-4887-43c4-af3a-c9f9ca886b16"],
 " is then implemented by contracting the second and fourth indices, and the \
summation over ",
 Cell[BoxData[
  StyleBox["k", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "3abbe4b9-2677-4768-a9e2-866c85ad04e8"],
 " is implemented by contracting the third and fifth indices."
}], "Text",ExpressionUUID->"2aa53ebc-9dd8-48d6-bed2-437278c1e0a3"],

Cell[TextData[{
 "The triple product is where the geometry application of ",
 Cell[BoxData[
  SubscriptBox["\[Epsilon]", 
   StyleBox[
    RowBox[{"i", "j", "k"}], "TI"]]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "66ec5611-47d2-48fa-81ed-0e004586346d"],
 " becomes obvious: ",
 Cell[BoxData[
  RowBox[{
   OverscriptBox[
    StyleBox["a", "TI"], "\[RightVector]"], ".", 
   RowBox[{
    StyleBox["(",
     SpanMaxSize->1], 
    RowBox[{
     OverscriptBox[
      StyleBox["b", "TI"], "\[RightVector]"], "\[Times]", 
     OverscriptBox[
      StyleBox["c", "TI"], "\[RightVector]"]}], 
    StyleBox[")",
     SpanMaxSize->1], "=", 
    UnderscriptBox["\[Sum]", 
     RowBox[{
      StyleBox["i", "TI"], ",", 
      StyleBox["j", "TI"], ",", 
      StyleBox["k", "TI"]}],
     LimitsPositioning->False], 
    SubscriptBox["\[Epsilon]", 
     StyleBox[
      RowBox[{"i", "j", "k"}], "TI"]], 
    SubscriptBox[
     StyleBox["a", "TI"], 
     StyleBox["i", "TI"]], 
    SubscriptBox[
     StyleBox["b", "TI"], 
     StyleBox["j", "TI"]], 
    SubscriptBox[
     StyleBox["c", "TI"], 
     StyleBox["k", "TI"]]}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "d11dbc23-8dcc-44ea-a053-b65831e8bcab"],
 ". This equals the signed volume of the parallelepiped formed by ",
 Cell[BoxData[
  RowBox[{
   RowBox[{"{", 
    OverscriptBox[
     StyleBox["a", "TI"], "\[RightVector]"]}], ",", 
   OverscriptBox[
    StyleBox["b", "TI"], "\[RightVector]"], ",", 
   RowBox[{
    OverscriptBox[
     StyleBox["c", "TI"], "\[RightVector]"], "}"}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "edde4d43-6f7d-4f83-9b06-21db42d19d65"],
 ". The signed volume is positive if ",
 Cell[BoxData[
  RowBox[{
   RowBox[{"{", 
    OverscriptBox[
     StyleBox["a", "TI"], "\[RightVector]"]}], ",", 
   OverscriptBox[
    StyleBox["b", "TI"], "\[RightVector]"], ",", 
   RowBox[{
    OverscriptBox[
     StyleBox["c", "TI"], "\[RightVector]"], "}"}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "5137a642-6dd5-4bc6-83a9-79b598c393a7"],
 " is right-handed, it is negative if left-handed, and zero if they\
\[CloseCurlyQuote]re coplanar."
}], "Text",ExpressionUUID->"a0423197-588a-4f72-a70b-b55e67f58158"],

Cell[TextData[{
 "Visualize the parallelepiped and signed volume for three sets of ",
 Cell[BoxData[
  RowBox[{
   RowBox[{"{", 
    OverscriptBox[
     StyleBox["a", "TI"], "\[RightVector]"]}], ",", 
   OverscriptBox[
    StyleBox["b", "TI"], "\[RightVector]"], ",", 
   RowBox[{
    OverscriptBox[
     StyleBox["c", "TI"], "\[RightVector]"], "}"}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "6a69d8ab-cabd-4050-864c-9e6938f9b1f6"],
 " that are right-handed, left-handed, and coplanar respectively:"
}], "Text",ExpressionUUID->"cea88b71-3e65-42e0-bb7d-453f8a4d78c4"],

Cell[BoxData[
 RowBox[{"Row", "[", 
  RowBox[{
   RowBox[{
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
       "v1", ",", " ", "v2", ",", " ", "v3", ",", " ", "signedVolume"}], 
       "}"}], ",", "\n", "    ", 
      RowBox[{
       RowBox[{
        RowBox[{"{", 
         RowBox[{"v1", ",", " ", "v2", ",", " ", "v3"}], "}"}], " ", "=", " ",
         "#"}], ";", "\n", "    ", 
       RowBox[{"signedVolume", " ", "=", " ", 
        RowBox[{"Det", "[", 
         RowBox[{"Transpose", "@", 
          RowBox[{"{", 
           RowBox[{"v1", ",", " ", "v2", ",", " ", "v3"}], "}"}]}], "]"}]}], ";",
        "\n", "    ", 
       RowBox[{"Graphics3D", "[", 
        RowBox[{
         RowBox[{"{", "\n", "      ", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{
             RowBox[{"Opacity", "[", "0.2", "]"}], ",", " ", 
             RowBox[{"Parallelepiped", "[", 
              RowBox[{
               RowBox[{"{", 
                RowBox[{"0", ",", " ", "0", ",", " ", "0"}], "}"}], ",", " ", 
               
               RowBox[{"{", 
                RowBox[{"v1", ",", " ", "v2", ",", " ", "v3"}], "}"}]}], 
              "]"}]}], "}"}], ",", "\n", "      ", 
           RowBox[{"{", 
            RowBox[{"Black", ",", " ", "Thick", ",", " ", 
             RowBox[{
              RowBox[{
               RowBox[{"Arrow", "[", 
                RowBox[{"{", 
                 RowBox[{
                  RowBox[{"{", 
                   RowBox[{"0", ",", " ", "0", ",", " ", "0"}], "}"}], ",", 
                  " ", "#"}], "}"}], "]"}], " ", "&"}], " ", "/@", " ", 
              RowBox[{"{", 
               RowBox[{"v1", ",", " ", "v2", ",", " ", "v3"}], "}"}]}]}], 
            "}"}], ",", "\n", "      ", 
           RowBox[{"{", 
            RowBox[{
             RowBox[{"Text", "[", "\n", "        ", 
              
              RowBox[{"\"\<\\!\\(\\*SubscriptBox[OverscriptBox[\\(v\\), \\(\
\[RightVector]\\)], \\(1\\)]\\)\>\"", ",", " ", 
               RowBox[{"1.1", " ", "v1"}]}], "]"}], ",", " ", "\n", "       ", 
             RowBox[{"Text", "[", 
              
              RowBox[{"\"\<\\!\\(\\*SubscriptBox[OverscriptBox[\\(v\\), \\(\
\[RightVector]\\)], \\(2\\)]\\)\>\"", ",", " ", 
               RowBox[{"1.1", " ", "v2"}]}], "]"}], ",", " ", "\n", "       ", 
             RowBox[{"Text", "[", 
              
              RowBox[{"\"\<\\!\\(\\*SubscriptBox[OverscriptBox[\\(v\\), \\(\
\[RightVector]\\)], \\(3\\)]\\)\>\"", ",", " ", 
               RowBox[{"1.1", " ", "v3"}]}], "]"}]}], "}"}]}], "\n", "      ",
           "}"}], ",", " ", 
         RowBox[{"Boxed", " ", "->", " ", "False"}], ",", " ", "\n", "     ", 
         
         RowBox[{"PlotLabel", " ", "->", " ", "\n", "      ", 
          RowBox[{"\"\<Signed volume is \>\"", " ", "<>", " ", 
           RowBox[{"ToString", "[", 
            RowBox[{"Round", "[", 
             RowBox[{"signedVolume", ",", " ", ".01"}], "]"}], "]"}]}]}], ",",
          " ", "\n", "     ", 
         RowBox[{"ImageSize", " ", "->", " ", "Small"}]}], "]"}]}]}], "]"}], 
    " ", "&"}], " ", "/@", " ", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"1", ",", " ", "0", ",", " ", "0"}], "}"}], ",", " ", 
       RowBox[{"{", 
        RowBox[{"0", ",", " ", "2", ",", " ", "0"}], "}"}], ",", " ", 
       RowBox[{"{", 
        RowBox[{"0", ",", " ", "\n", "     ", "1", ",", " ", ".5"}], "}"}]}], 
      "}"}], ",", " ", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"0", ",", " ", "1", ",", " ", "0"}], "}"}], ",", " ", 
       RowBox[{"{", 
        RowBox[{"1.5", ",", " ", ".5", ",", " ", "0"}], "}"}], ",", " ", 
       RowBox[{"{", 
        RowBox[{"0", ",", " ", ".5", ",", " ", "1"}], "}"}]}], "}"}], ",", 
     " ", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"0", ",", " ", "1", ",", " ", "\n", "     ", "0"}], "}"}], ",",
        " ", 
       RowBox[{"{", 
        RowBox[{"1.5", ",", " ", ".5", ",", " ", "0"}], "}"}], ",", " ", 
       RowBox[{"{", 
        RowBox[{"1", ",", " ", ".7", ",", " ", "0"}], "}"}]}], "}"}]}], 
    "}"}]}], "]"}]], "Input",
 CellLabel->
  "In[154]:= ",ExpressionUUID->"43437c8f-9847-4c81-a075-81a9376b3976"],

