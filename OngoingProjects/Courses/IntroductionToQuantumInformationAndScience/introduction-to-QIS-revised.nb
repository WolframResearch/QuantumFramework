Cell[TextData[{
 "Given a density matrix ",
 Cell[BoxData[
  RowBox[{
   StyleBox["\[Rho]", "TI"], "=", "1", "/", "2", 
   StyleBox["(",
    SpanMaxSize->1], 
   RowBox[{
    RowBox[{"\|01d540", "+", 
     OverscriptBox[
      StyleBox["r", "TI"], "\[RightVector]"]}], ".", 
    OverscriptBox[
     StyleBox["\[Sigma]", "TI"], "\[RightVector]"]}], 
   StyleBox[")",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "f248722e-1282-4e57-925e-5fc83ab8e437"],
 ", the probability of obtaining outcome 0 in the computational-basis \
measurement is ",
 Cell[BoxData[
  RowBox[{
   RowBox[{
    StyleBox["p", "TI"], 
    RowBox[{
     StyleBox["(",
      SpanMaxSize->1], "0", 
     StyleBox[")",
      SpanMaxSize->1]}]}], "=", 
   RowBox[{
    TemplateBox[{"0"},
     "Bra"], 
    StyleBox["\[Rho]", "TI"], 
    TemplateBox[{"0"},
     "Ket"]}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "9effe764-a182-48ca-a665-da92d8cf7d19"],
 " which is equivalently written using the projector ",
 Cell[BoxData[
  SubscriptBox["\|01d4ab", "0"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "32f796f9-ddcd-4478-9e6a-216578fde88b"],
 " as ",
 Cell[BoxData[
  RowBox[{
   StyleBox["p", "TI"], 
   StyleBox["(",
    SpanMaxSize->1], "0", 
   StyleBox[")",
    SpanMaxSize->1], "=", 
   StyleBox["T", "TI"], 
   StyleBox["r", "TI"], 
   StyleBox["[",
    SpanMaxSize->1], 
   RowBox[{
    SubscriptBox["\|01d4ab", "0"], 
    StyleBox["\[Rho]", "TI"]}], 
   StyleBox["]",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "0d0d8c6d-c550-40d9-991c-8ce60d29890d"],
 ".Likewise, the probability of obtaining outcome 1 is ",
 Cell[BoxData[
  RowBox[{
   RowBox[{
    StyleBox["p", "TI"], 
    RowBox[{
     StyleBox["(",
      SpanMaxSize->1], "1", 
     StyleBox[")",
      SpanMaxSize->1]}]}], "=", 
   RowBox[{
    RowBox[{
     TemplateBox[{"1"},
      "Bra"], 
     StyleBox["\[Rho]", "TI"], 
     TemplateBox[{"1"},
      "Ket"]}], "=", 
    RowBox[{
     StyleBox["T", "TI"], 
     RowBox[{
      StyleBox["r", "TI"], 
      StyleBox["[",
       SpanMaxSize->1], 
      RowBox[{
       SubscriptBox["\|01d4ab", "1"], 
       StyleBox["\[Rho]", "TI"]}], 
      StyleBox["]",
       SpanMaxSize->1]}]}]}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "b9d5350d-b602-445e-ac5f-778cfd5434fc"],
 ". Geometrically, applying ",
 Cell[BoxData[
  SubscriptBox["\|01d4ab", "0"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "29fb24a4-0b02-42c1-a534-1d764d5e55ee"],
 " keeps only the ",
 Cell[BoxData[
  TemplateBox[{"0"},
   "Ket"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "6665a4a2-996c-419f-b036-3aaa7f367ccf"],
 " component of a state, while applying ",
 Cell[BoxData[
  SubscriptBox["\|01d4ab", "1"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "be2ce062-224c-4943-935b-a32e9a748bde"],
 " keeps only the ",
 Cell[BoxData[
  TemplateBox[{"1"},
   "Ket"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "932e75c2-378e-42af-87fb-b0447cab258b"],
 " component. In other words, each projector \[OpenCurlyDoubleQuote]filters\
\[CloseCurlyDoubleQuote] the state down to the part that lies in the \
corresponding measurement subspace."
}], "Text",ExpressionUUID->"a2fffb77-5596-439d-b375-308503c8c791"],

