 ":"
}], "Text",ExpressionUUID->"70eb85d6-4a3d-4066-a0f7-1609e9e78e62"],

Cell[BoxData[
 RowBox[{
  RowBox[{"With", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{"v1", " ", "=", " ", 
       RowBox[{"Array", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"Subscript", "[", 
           RowBox[{"\[FormalA]", ",", " ", "##"}], "]"}], " ", "&"}], ",", 
         " ", "3"}], "]"}]}], ",", " ", "\n", "   ", 
      RowBox[{"v2", " ", "=", " ", 
       RowBox[{"Array", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"Subscript", "[", 
           RowBox[{"\[FormalB]", ",", " ", "##"}], "]"}], " ", "&"}], ",", 
         " ", "3"}], "]"}]}], ",", " ", "\n", "   ", 
      RowBox[{"v3", " ", "=", " ", 
       RowBox[{"Array", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"Subscript", "[", 
           RowBox[{"\[FormalC]", ",", " ", "##"}], "]"}], " ", "&"}], ",", 
         " ", "3"}], "]"}]}]}], "}"}], ",", " ", "\n", "  ", 
    RowBox[{
     RowBox[{"v1", " ", ".", " ", 
      RowBox[{"Cross", "[", 
       RowBox[{"v2", ",", " ", "v3"}], "]"}]}], " ", "==", " ", 
     RowBox[{"Det", "[", 
      RowBox[{"Transpose", "[", 
       RowBox[{"{", 
        RowBox[{"v1", ",", " ", "v2", ",", " ", "v3"}], "}"}], "]"}], 
      "]"}]}]}], "]"}], " ", "//", " ", "FullSimplify"}]], "Input",
 CellLabel->
  "In[156]:= ",ExpressionUUID->"a3f9ca52-fabf-4a24-a641-e8dd232e0cc9"],

Cell[TextData[{
 "Additionally, the 3D Levi\[Dash]Civita symbol obeys the contraction \
identity: ",
 Cell[BoxData[
  RowBox[{
   UnderscriptBox["\[Sum]", 
    StyleBox["i", "TI"],
    LimitsPositioning->False], 
   SubscriptBox["\[Epsilon]", 
    StyleBox[
     RowBox[{"i", "j", "k"}], "TI"]], 
   SubscriptBox["\[Epsilon]", 
    StyleBox[
     RowBox[{"i", "m", "n"}], "TI"]], "=", 
   SubscriptBox[
    StyleBox["\[Delta]", "TI"], 
    StyleBox[
     RowBox[{"j", "m"}], "TI"]], 
   SubscriptBox[
    StyleBox["\[Delta]", "TI"], 
    StyleBox[
     RowBox[{"k", "n"}], "TI"]], "-", 
   SubscriptBox[
    StyleBox["\[Delta]", "TI"], 
    StyleBox[
     RowBox[{"j", "n"}], "TI"]], 
   SubscriptBox[
    StyleBox["\[Delta]", "TI"], 
    StyleBox[
     RowBox[{"k", "m"}], "TI"]]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "138c05c5-0f54-4af4-be10-075f2cc22099"],
 "."
}], "Text",ExpressionUUID->"3bc258e7-68ce-4ab4-91cd-5a3ba8e8b2ee"],

Cell[TextData[{
 "Verify that ",
 Cell[BoxData[
  RowBox[{
   UnderscriptBox["\[Sum]", 
    StyleBox["i", "TI"],
    LimitsPositioning->False], 
   SubscriptBox["\[Epsilon]", 
    StyleBox[
     RowBox[{"i", "j", "k"}], "TI"]], 
   SubscriptBox["\[Epsilon]", 
    StyleBox[
     RowBox[{"i", "m", "n"}], "TI"]], "=", 
   SubscriptBox[
    StyleBox["\[Delta]", "TI"], 
    StyleBox[
     RowBox[{"j", "m"}], "TI"]], 
   SubscriptBox[
    StyleBox["\[Delta]", "TI"], 
    StyleBox[
     RowBox[{"k", "n"}], "TI"]], "-", 
   SubscriptBox[
    StyleBox["\[Delta]", "TI"], 
    StyleBox[
     RowBox[{"j", "n"}], "TI"]], 
   SubscriptBox[
    StyleBox["\[Delta]", "TI"], 
    StyleBox[
     RowBox[{"k", "m"}], "TI"]]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "a2427aa0-227d-48b9-8334-ffa8f32ecf0a"],
 ":"
}], "Text",ExpressionUUID->"e914af41-d925-47cd-a91c-b30133435646"],

Cell[BoxData[
 RowBox[{
  RowBox[{"TensorContract", "[", "\n", "  ", 
   RowBox[{
    RowBox[{"TensorProduct", "[", 
     RowBox[{
      RowBox[{"LeviCivitaTensor", "[", "3", "]"}], ",", " ", 
      RowBox[{"LeviCivitaTensor", "[", "3", "]"}]}], "]"}], ",", " ", 
    RowBox[{"{", 
     RowBox[{"{", 
      RowBox[{"1", ",", " ", "4"}], "}"}], "}"}]}], "]"}], " ", "==", "\n", 
  " ", 
  RowBox[{"With", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"t", " ", "=", " ", 
      RowBox[{"TensorProduct", "[", 
       RowBox[{
        RowBox[{"IdentityMatrix", "[", "3", "]"}], ",", " ", 
        RowBox[{"IdentityMatrix", "[", "3", "]"}]}], "]"}]}], "}"}], ",", " ",
     "\n", "  ", 
    RowBox[{
     RowBox[{"TensorTranspose", "[", 
      RowBox[{"t", ",", " ", 
       RowBox[{"{", 
        RowBox[{"1", ",", " ", "3", ",", " ", "2", ",", " ", "4"}], "}"}]}], 
      "]"}], " ", "-", " ", 
     RowBox[{"TensorTranspose", "[", 
      RowBox[{"t", ",", " ", 
       RowBox[{"{", 
        RowBox[{"1", ",", " ", "4", ",", " ", "3", ",", " ", "2"}], "}"}]}], 
      "]"}]}]}], "]"}]}]], "Input",
 CellLabel->
  "In[157]:= ",ExpressionUUID->"44fe8889-df91-427e-b1f6-870b764bf697"],

Cell[TextData[{
 "Note that in the above code, the right-hand side of the identity ",
 Cell[BoxData[
  RowBox[{
   UnderscriptBox["\[Sum]", 
    StyleBox["i", "TI"],
    LimitsPositioning->False], 
   SubscriptBox["\[Epsilon]", 
    StyleBox[
     RowBox[{"i", "j", "k"}], "TI"]], 
   SubscriptBox["\[Epsilon]", 
    StyleBox[
     RowBox[{"i", "m", "n"}], "TI"]], "=", 
   SubscriptBox[
    StyleBox["\[Delta]", "TI"], 
    StyleBox[
     RowBox[{"j", "m"}], "TI"]], 
   SubscriptBox[
    StyleBox["\[Delta]", "TI"], 
    StyleBox[
     RowBox[{"k", "n"}], "TI"]], "-", 
   SubscriptBox[
    StyleBox["\[Delta]", "TI"], 
    StyleBox[
     RowBox[{"j", "n"}], "TI"]], 
   SubscriptBox[
    StyleBox["\[Delta]", "TI"], 
    StyleBox[
     RowBox[{"k", "m"}], "TI"]]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "89fa287b-0c76-44f0-bbd2-78fa46f32d39"],
 " is implemented as follows. First, we form the tensor product of two Levi\
\[Dash]Civita tensors and then contract over the appropriate pair of indices \
to mimic the summation over ",
 Cell[BoxData[
  StyleBox["i", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "c929328f-97ba-4e6c-9afe-d047ec230dd8"],
 " (namely the first index of ",
 Cell[BoxData[
  SubscriptBox["\[Epsilon]", 
   StyleBox[
    RowBox[{"i", "j", "k"}], "TI"]]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "9cfab27c-aeab-4b04-baa7-d971d3f64a3a"],
 " with the first index of ",
 Cell[BoxData[
  SubscriptBox["\[Epsilon]", 
   StyleBox[
    RowBox[{"i", "m", "n"}], "TI"]]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "a9f2fcef-1c58-4b0f-af55-e454e8fc4dcb"],
 "). On the right-hand side, products of Kronecker deltas can be implemented \
as tensor products of two 3\[Times]3 identity matrices (since each index runs \
from 1 to 3), but one must pay close attention to the index order. If we take \
the index order on the left-hand side to be ",
 Cell[BoxData[
  RowBox[{
   StyleBox["(",
    SpanMaxSize->1], 
   RowBox[{
    StyleBox["j", "TI"], ",", 
    StyleBox["k", "TI"], ",", 
    StyleBox["m", "TI"], ",", 
    StyleBox["n", "TI"]}], 
   StyleBox[")",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "5e407b78-f8dd-4e30-b9f3-e7a23b5155ce"],
 ", then the first term corresponds to the ordering ",
 Cell[BoxData[
  RowBox[{
   StyleBox["(",
    SpanMaxSize->1], 
   RowBox[{
    StyleBox["j", "TI"], ",", 
    StyleBox["m", "TI"], ",", 
    StyleBox["k", "TI"], ",", 
    StyleBox["n", "TI"]}], 
   StyleBox[")",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "d971e869-517b-4335-9820-a5f4b6c10f33"],
 ", while the second term corresponds to ",
 Cell[BoxData[
  RowBox[{
   StyleBox["(",
    SpanMaxSize->1], 
   RowBox[{
    StyleBox["j", "TI"], ",", 
    StyleBox["n", "TI"], ",", 
    StyleBox["k", "TI"], ",", 
    StyleBox["m", "TI"]}], 
   StyleBox[")",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "1187bed6-ca65-4dcb-872a-a2ee12a7f8f0"],
 ". Therefore, a suitable transposition (i.e., a permutation of tensor \
indices) is needed to match the desired ordering before combining the two \
terms."
}], "Text",ExpressionUUID->"ed400dab-710d-4c7c-81d7-a1334a8fbe8a"],

Cell[TextData[{
 "Now let\[CloseCurlyQuote]s focus on how the Levi\[Dash]Civita symbol \
appears in the commutation relations of the Pauli operators. This is \
something we will use soon when we connect Pauli matrices to the Lie algebra \
\|01d530\|01d532(2). But first, a few comments on matrix multiplication.  In \
general, matrix multiplication is not commutative: ",
 Cell[BoxData[
  RowBox[{
   StyleBox["A", "TI"], ".", 
   RowBox[{
    StyleBox["B", "TI"], "\[NotEqual]", 
    StyleBox["B", "TI"]}], ".", 
   StyleBox["A", "TI"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "0a518554-dbff-4f56-8585-d9cb47af21bd"],
 ". That said, some pairs of matrices do commute. For example, the identity \
matrix commutes with every matrix: ",
 Cell[BoxData[
  RowBox[{
   StyleBox["[",
    SpanMaxSize->1], 
   RowBox[{"\|01d540", ",", 
    StyleBox["A", "TI"]}], 
   StyleBox["]",
    SpanMaxSize->1], "=", "0"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "d5dd8d0d-5eb9-4857-afa4-aaa89de99a4c"],
 ". Also, any matrix commutes with itself: ",
 Cell[BoxData[
  RowBox[{
   StyleBox["[",
    SpanMaxSize->1], 
   RowBox[{
    StyleBox["A", "TI"], ",", 
    StyleBox["A", "TI"]}], 
   StyleBox["]",
    SpanMaxSize->1], "=", "0"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "f637bbd1-b166-4842-a6e9-c436312f5dfe"],
 ". This implies, a matrix commutes with any function of itself (when \
defined): ",
 Cell[BoxData[
  RowBox[{
   StyleBox["[",
    SpanMaxSize->1], 
   RowBox[{
    StyleBox["A", "TI"], ",", 
    RowBox[{
     StyleBox["f", "TI"], 
     StyleBox["(",
      SpanMaxSize->1], 
     StyleBox["A", "TI"], 
     StyleBox[")",
      SpanMaxSize->1]}]}], 
   StyleBox["]",
    SpanMaxSize->1], "=", "0"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "119be241-dd07-4c5d-92d1-4455437ce658"],
 "."
}], "Text",ExpressionUUID->"e2433c0a-332e-4011-8a5f-eaa295367cc8"],

Cell[TextData[{
 "Verify that ",
 Cell[BoxData[
  RowBox[{
   StyleBox["[",
    SpanMaxSize->1], 
   RowBox[{
    SqrtBox[
     SubscriptBox[
      StyleBox["\[Sigma]", "TI"], 
      StyleBox["j", "TI"]]], ",", 
    SubscriptBox[
     StyleBox["\[Sigma]", "TI"], 
     StyleBox["j", "TI"]]}], 
   StyleBox["]",
    SpanMaxSize->1], "=", "0"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "d7a187b0-f248-40aa-94bf-1b6897bdd329"],
 ":"
}], "Text",ExpressionUUID->"a6242276-1117-43b1-a4e6-fb99345f3435"],

Cell[BoxData[
 RowBox[{"Table", "[", 
  RowBox[{
   RowBox[{"With", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"v", " ", "=", " ", 
       RowBox[{"MatrixPower", "[", 
        RowBox[{
         RowBox[{"PauliMatrix", "[", "j", "]"}], ",", " ", 
         RowBox[{"1", "/", "2"}]}], "]"}]}], "}"}], ",", " ", "\n", "  ", 
     RowBox[{
      RowBox[{"Commutator", "[", 
       RowBox[{"v", ",", " ", 
        RowBox[{"PauliMatrix", "[", "j", "]"}], ",", " ", "Dot"}], "]"}], " ",
       "==", " ", 
      RowBox[{"DiagonalMatrix", "[", 
       RowBox[{"{", 
        RowBox[{"0", ",", " ", "0"}], "}"}], "]"}]}]}], "]"}], ",", " ", 
   RowBox[{"{", 
    RowBox[{"j", ",", " ", "\n", "  ", "3"}], "}"}]}], "]"}]], "Input",
 CellLabel->
  "In[158]:= ",ExpressionUUID->"7a57d780-d6de-4af4-8750-f25dd2532028"],

Cell[TextData[{
 "Verify that ",
 Cell[BoxData[
  RowBox[{
   StyleBox["[",
    SpanMaxSize->1], 
   RowBox[{
    SuperscriptBox[
     StyleBox["e", "TI"], 
     SubscriptBox[
      StyleBox["\[Sigma]", "TI"], 
      StyleBox["j", "TI"]]], ",", 
    SubscriptBox[
     StyleBox["\[Sigma]", "TI"], 
     StyleBox["j", "TI"]]}], 
   StyleBox["]",
    SpanMaxSize->1], "=", "0"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "ed1de1b6-7c49-43b6-b124-a519a3648e86"],
 ":"
}], "Text",ExpressionUUID->"43cdb76d-3435-4752-b073-f752e7002cca"],

Cell[BoxData[
 RowBox[{"Table", "[", 
  RowBox[{
   RowBox[{"With", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"v", " ", "=", " ", 
       RowBox[{"MatrixExp", "[", 
        RowBox[{"PauliMatrix", "[", "j", "]"}], "]"}]}], "}"}], ",", " ", 
     "\n", "  ", 
     RowBox[{
      RowBox[{"Commutator", "[", 
       RowBox[{"v", ",", " ", 
        RowBox[{"PauliMatrix", "[", "j", "]"}], ",", " ", "Dot"}], "]"}], " ",
       "==", " ", 
      RowBox[{"DiagonalMatrix", "[", 
       RowBox[{"{", 
        RowBox[{"0", ",", " ", "0"}], "}"}], "]"}]}]}], "]"}], ",", " ", 
   RowBox[{"{", 
    RowBox[{"j", ",", " ", "\n", "  ", "3"}], "}"}]}], "]"}]], "Input",
 CellLabel->
  "In[159]:= ",ExpressionUUID->"66a7643f-2463-45c0-a087-018806638441"],

Cell[TextData[{
 "The Pauli matrices satisfy the fundamental product rule: ",
 Cell[BoxData[
  RowBox[{
   SubscriptBox[
    StyleBox["\[Sigma]", "TI"], 
    StyleBox["i", "TI"]], 
   SubscriptBox[
    StyleBox["\[Sigma]", "TI"], 
    StyleBox["j", "TI"]], "=", 
   SubscriptBox[
    StyleBox["\[Delta]", "TI"], 
    StyleBox[
     RowBox[{"i", "j"}], "TI"]], "\|01d540", "+", 
   StyleBox["i", "TI"], 
   UnderscriptBox["\[Sum]", 
    StyleBox["k", "TI"],
    LimitsPositioning->False], 
   SubscriptBox["\[Epsilon]", 
    StyleBox[
     RowBox[{"i", "j", "k"}], "TI"]], 
   SubscriptBox[
    StyleBox["\[Sigma]", "TI"], 
    StyleBox["k", "TI"]]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "19c28598-eb2e-4f1d-a508-02fbe3576956"],
 "."
}], "Text",ExpressionUUID->"3db68630-6742-4f58-a878-4c31b1d3bb7d"],

Cell[TextData[{
 "Verify that ",
 Cell[BoxData[
  RowBox[{
   SubscriptBox[
    StyleBox["\[Sigma]", "TI"], 
    StyleBox["i", "TI"]], 
   SubscriptBox[
    StyleBox["\[Sigma]", "TI"], 
    StyleBox["j", "TI"]], "=", 
   SubscriptBox[
    StyleBox["\[Delta]", "TI"], 
    StyleBox[
     RowBox[{"i", "j"}], "TI"]], "\|01d540", "+", 
   StyleBox["i", "TI"], 
   UnderscriptBox["\[Sum]", 
    StyleBox["k", "TI"],
    LimitsPositioning->False], 
   SubscriptBox["\[Epsilon]", 
    StyleBox[
     RowBox[{"i", "j", "k"}], "TI"]], 
   SubscriptBox[
    StyleBox["\[Sigma]", "TI"], 
    StyleBox["k", "TI"]]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "6d96b274-2da2-494e-b9ef-cd20498db683"],
 ":"
}], "Text",ExpressionUUID->"a6dc102d-d917-407e-bf80-1e98fb30878e"],

Cell[BoxData[
 RowBox[{"With", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"\[Sigma]", " ", "=", " ", 
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{"PauliMatrix", "[", "j", "]"}], ",", " ", 
       RowBox[{"{", 
        RowBox[{"j", ",", " ", "3"}], "}"}]}], "]"}]}], "}"}], ",", " ", "\n",
    " ", 
   RowBox[{
    RowBox[{"Outer", "[", 
     RowBox[{
     "Dot", ",", " ", "\[Sigma]", ",", " ", "\[Sigma]", ",", " ", "1"}], 
     "]"}], " ", "==", " ", "\n", "  ", 
    RowBox[{
     RowBox[{"TensorProduct", "[", 
      RowBox[{
       RowBox[{"IdentityMatrix", "[", "3", "]"}], ",", " ", 
       RowBox[{"IdentityMatrix", "[", "2", "]"}]}], "]"}], " ", "+", " ", 
     "\n", "   ", 
     RowBox[{"I", " ", 
      RowBox[{"TensorContract", "[", "\n", "     ", 
       RowBox[{
        RowBox[{"TensorProduct", "[", 
         RowBox[{
          RowBox[{"LeviCivitaTensor", "[", "3", "]"}], ",", " ", "\[Sigma]"}],
          "]"}], ",", " ", 
        RowBox[{"{", 
         RowBox[{"{", 
          RowBox[{"3", ",", " ", "4"}], "}"}], "}"}]}], "]"}]}]}]}]}], 
  "]"}]], "Input",
 CellLabel->
  "In[160]:= ",ExpressionUUID->"3afa2b77-82f9-4bdf-922b-e4f8ab5de5f2"],

Cell[TextData[{
 "The above relation gives you both the commutator and anticommutator \
immediately. For commutator, Pauli operators obey ",
 Cell[BoxData[
  RowBox[{
   StyleBox["[",
    SpanMaxSize->1], 
   RowBox[{
    SubscriptBox[
     StyleBox["\[Sigma]", "TI"], 
     StyleBox["i", "TI"]], ",", 
    SubscriptBox[
     StyleBox["\[Sigma]", "TI"], 
     StyleBox["j", "TI"]]}], 
   StyleBox["]",
    SpanMaxSize->1], "=", "2", 
   StyleBox["i", "TI"], 
   UnderscriptBox["\[Sum]", 
    StyleBox["k", "TI"],
    LimitsPositioning->False], 
   SubscriptBox["\[Epsilon]", 
    StyleBox[
     RowBox[{"i", "j", "k"}], "TI"]], 
   SubscriptBox[
    StyleBox["\[Sigma]", "TI"], 
    StyleBox["k", "TI"]]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "336a7860-8b58-4296-a132-059a7598b164"],
 "."
}], "Text",ExpressionUUID->"1c402233-00aa-46f0-92b7-cdc63b0d8dc5"],

Cell[TextData[{
 "Verify that ",
 Cell[BoxData[
  RowBox[{
   StyleBox["[",
    SpanMaxSize->1], 
   RowBox[{
    SubscriptBox[
     StyleBox["\[Sigma]", "TI"], 
     StyleBox["i", "TI"]], ",", 
    SubscriptBox[
     StyleBox["\[Sigma]", "TI"], 
     StyleBox["j", "TI"]]}], 
   StyleBox["]",
    SpanMaxSize->1], "=", "2", 
   StyleBox["i", "TI"], 
   UnderscriptBox["\[Sum]", 
    StyleBox["k", "TI"],
    LimitsPositioning->False], 
   SubscriptBox["\[Epsilon]", 
    StyleBox[
     RowBox[{"i", "j", "k"}], "TI"]], 
   SubscriptBox[
    StyleBox["\[Sigma]", "TI"], 
    StyleBox["k", "TI"]]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "deb92ebd-ebf3-4842-9d29-f0d504147a10"],
 ":"
}], "Text",ExpressionUUID->"40ca8abc-7fba-4a32-9a5d-6d0a31e0fd8c"],

Cell[BoxData[
 RowBox[{"With", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"\[Sigma]", " ", "=", " ", 
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{"PauliMatrix", "[", "j", "]"}], ",", " ", 
       RowBox[{"{", 
        RowBox[{"j", ",", " ", "3"}], "}"}]}], "]"}]}], "}"}], ",", " ", "\n",
    " ", 
   RowBox[{
    RowBox[{"Outer", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"Commutator", "[", 
        RowBox[{"#1", ",", " ", "#2", ",", " ", "Dot"}], "]"}], " ", "&"}], ",",
       " ", "\[Sigma]", ",", " ", "\[Sigma]", ",", " ", "1"}], "]"}], " ", "==",
     " ", "\n", "  ", 
    RowBox[{"2", " ", "I", " ", 
     RowBox[{"TensorContract", "[", "\n", "    ", 
      RowBox[{
       RowBox[{"TensorProduct", "[", 
        RowBox[{
         RowBox[{"LeviCivitaTensor", "[", "3", "]"}], ",", " ", "\[Sigma]"}], 
        "]"}], ",", " ", 
       RowBox[{"{", 
        RowBox[{"{", 
         RowBox[{"3", ",", " ", "4"}], "}"}], "}"}]}], "]"}]}]}]}], 
  "]"}]], "Input",
 CellLabel->
  "In[161]:= ",ExpressionUUID->"79b34b75-8eca-4497-992d-fc3b546af126"],

Cell[TextData[{
 "For anticommutator, one gets: ",
 Cell[BoxData[
  RowBox[{
   RowBox[{"{", 
    SubscriptBox[
     StyleBox["\[Sigma]", "TI"], 
     StyleBox["i", "TI"]]}], ",", 
   RowBox[{
    SubscriptBox[
     StyleBox["\[Sigma]", "TI"], 
     StyleBox["j", "TI"]], "}", "=", "2", 
    SubscriptBox[
     StyleBox["\[Delta]", "TI"], 
     StyleBox[
      RowBox[{"i", "j"}], "TI"]], "\|01d540"}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "30d95e06-0e4e-47a6-9387-31fe1d5d3940"],
 "."
}], "Text",ExpressionUUID->"cbcd7186-7957-425e-99c9-2c6f10b7691e"],

Cell[TextData[{
 "Verify that ",
 Cell[BoxData[
  RowBox[{
   RowBox[{"{", 
    SubscriptBox[
     StyleBox["\[Sigma]", "TI"], 
     StyleBox["i", "TI"]]}], ",", 
   RowBox[{
    SubscriptBox[
     StyleBox["\[Sigma]", "TI"], 
     StyleBox["j", "TI"]], "}", "=", "2", 
    SubscriptBox[
     StyleBox["\[Delta]", "TI"], 
     StyleBox[
      RowBox[{"i", "j"}], "TI"]], "\|01d540"}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "cf925c5f-0006-4df2-b256-c08662a8f598"],
 ":"
}], "Text",ExpressionUUID->"20e2f77e-b087-4e28-bbf0-35259f84c228"],

Cell[BoxData[
 RowBox[{"With", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"\[Sigma]", " ", "=", " ", 
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{"PauliMatrix", "[", "j", "]"}], ",", " ", 
       RowBox[{"{", 
        RowBox[{"j", ",", " ", "3"}], "}"}]}], "]"}]}], "}"}], ",", " ", "\n",
    " ", 
   RowBox[{
    RowBox[{"Outer", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"Anticommutator", "[", 
        RowBox[{"#1", ",", " ", "#2", ",", " ", "Dot"}], "]"}], " ", "&"}], ",",
       " ", "\[Sigma]", ",", " ", "\[Sigma]", ",", " ", "1"}], "]"}], " ", "==",
     " ", "\n", "  ", 
    RowBox[{"2", " ", 
     RowBox[{"TensorProduct", "[", 
      RowBox[{
       RowBox[{"IdentityMatrix", "[", "3", "]"}], ",", " ", 
       RowBox[{"IdentityMatrix", "[", "2", "]"}]}], "]"}]}]}]}], 
  "]"}]], "Input",
 CellLabel->
  "In[162]:= ",ExpressionUUID->"129a2360-966a-4781-a7d0-05461c546707"],

Cell[TextData[{
 "An important fact is that any ",
 Cell[BoxData[
  RowBox[{"2", "\[Times]", "2"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "564db133-51f9-4472-b4c7-8590c5e07300"],
 " Hermitian traceless matrix can be written as a real linear combination of \
the Pauli matrices: ",
 Cell[BoxData[
  RowBox[{
   RowBox[{
    StyleBox["H", "TI"], "=", 
    OverscriptBox[
     StyleBox["a", "TI"], "\[RightVector]"]}], ".", 
   RowBox[{
    OverscriptBox[
     StyleBox["\[Sigma]", "TI"], "\[RightVector]"], "=", 
    SubscriptBox[
     StyleBox["a", "TI"], 
     StyleBox["x", "TI"]], 
    SubscriptBox[
     StyleBox["\[Sigma]", "TI"], 
     StyleBox["x", "TI"]], "+", 
    SubscriptBox[
     StyleBox["a", "TI"], 
     StyleBox["y", "TI"]], 
    SubscriptBox[
     StyleBox["\[Sigma]", "TI"], 
     StyleBox["y", "TI"]], "+", 
    SubscriptBox[
     StyleBox["a", "TI"], 
     StyleBox["z", "TI"]], 
    SubscriptBox[
     StyleBox["\[Sigma]", "TI"], 
     StyleBox["z", "TI"]]}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "52456fde-137d-49f7-8288-d1b719c2c337"],
 " with ",
 Cell[BoxData[
  RowBox[{
   RowBox[{"{", 
    SubscriptBox[
     StyleBox["a", "TI"], 
     StyleBox["x", "TI"]]}], ",", 
   SubscriptBox[
    StyleBox["a", "TI"], 
    StyleBox["y", "TI"]], ",", 
   RowBox[{
    SubscriptBox[
     StyleBox["a", "TI"], 
     StyleBox["z", "TI"]], "}", "\[Element]", "\:211d"}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "544b1eef-324e-44bd-a5ae-5c6279eedb65"],
 ". So from this point on, whenever you see a formula as ",
 Cell[BoxData[
  RowBox[{
   OverscriptBox[
    StyleBox["a", "TI"], "\[RightVector]"], ".", 
   OverscriptBox[
    StyleBox["\[Sigma]", "TI"], "\[RightVector]"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "cf16502f-8d2b-4521-b499-00ddc80223d2"],
 ", think of it as a Hermitian traceless matrix. Notice that there is no \
identity term here, precisely because ",
 Cell[BoxData[
  StyleBox["H", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "fa8f777f-4495-4a4f-8b35-2ef145b78001"],
 " is traceless. Physically, an identity contribution in a generator only \
produces an overall global phase under exponentiation, and that global phase \
does not affect a qubit state. With these facts in mind, we will now explore \
useful relations and identities among Hermitian traceless matrices of the \
form ",
 Cell[BoxData[
  RowBox[{
   OverscriptBox[
    StyleBox["a", "TI"], "\[RightVector]"], ".", 
   OverscriptBox[
    StyleBox["\[Sigma]", "TI"], "\[RightVector]"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "61d5de78-f9d3-403e-b60e-652c87051cd9"],
 "."
}], "Text",ExpressionUUID->"b659af64-9795-4877-9103-8458ea55ef9a"],

Cell[TextData[{
 "For ",
 Cell[BoxData[
  RowBox[{
   StyleBox["H", "TI"], "=", 
   SubscriptBox[
    StyleBox["a", "TI"], 
    StyleBox["x", "TI"]], 
   SubscriptBox[
    StyleBox["\[Sigma]", "TI"], 
    StyleBox["x", "TI"]], "+", 
   SubscriptBox[
    StyleBox["a", "TI"], 
    StyleBox["y", "TI"]], 
   SubscriptBox[
    StyleBox["\[Sigma]", "TI"], 
    StyleBox["y", "TI"]], "+", 
   SubscriptBox[
    StyleBox["a", "TI"], 
    StyleBox["z", "TI"]], 
   SubscriptBox[
    StyleBox["\[Sigma]", "TI"], 
    StyleBox["z", "TI"]]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "ee13db21-323d-47ca-b93a-b7aa8601b3a3"],
 " with ",
 Cell[BoxData[
  RowBox[{
   RowBox[{"{", 
    SubscriptBox[
     StyleBox["a", "TI"], 
     StyleBox["x", "TI"]]}], ",", 
   SubscriptBox[
    StyleBox["a", "TI"], 
    StyleBox["y", "TI"]], ",", 
   RowBox[{
    SubscriptBox[
     StyleBox["a", "TI"], 
     StyleBox["z", "TI"]], "}", "\[Element]", "\:211d"}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "ddb733ea-ebbe-40b0-93d3-64ec848fd935"],
 ", verify that ",
 Cell[BoxData[
  StyleBox["H", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "76abc887-00a6-4a93-868f-803bcbced4a3"],
 " is Hermitian and also traceless:"
}], "Text",ExpressionUUID->"bf5af017-3396-4dd2-afe0-f38fddae123d"],

Cell[BoxData[
 RowBox[{"With", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"h", " ", "=", " ", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"c1", ",", " ", "c2", ",", " ", "c3"}], "}"}], " ", ".", " ", 
      RowBox[{"Table", "[", 
       RowBox[{
        RowBox[{"PauliMatrix", "[", "j", "]"}], ",", " ", 
        RowBox[{"{", 
         RowBox[{"j", ",", " ", "3"}], "}"}]}], "]"}]}]}], "}"}], ",", " ", 
   "\n", " ", 
   RowBox[{
    RowBox[{
     RowBox[{"Tr", "[", "h", "]"}], " ", "==", " ", "0"}], " ", "&&", " ", 
    "\n", "  ", 
    RowBox[{"FullSimplify", "[", "\n", "   ", 
     RowBox[{
      RowBox[{"h", " ", "==", " ", 
       RowBox[{"ConjugateTranspose", "[", "h", "]"}]}], ",", " ", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{"c1", " ", "|", " ", "c2", " ", "|", " ", "c3"}], ")"}], " ", 
       "\[Element]", " ", "Reals"}]}], "]"}]}]}], "]"}]], "Input",
 CellLabel->
  "In[163]:= ",ExpressionUUID->"5638e5ae-40e8-46bd-8e3b-6dc7f380747c"],

Cell[TextData[{
 "Given a Hermitian traceless operator ",
 Cell[BoxData[
  RowBox[{
   RowBox[{
    StyleBox["H", "TI"], "=", 
    OverscriptBox[
     StyleBox["a", "TI"], "\[RightVector]"]}], ".", 
   RowBox[{
    OverscriptBox[
     StyleBox["\[Sigma]", "TI"], "\[RightVector]"], "=", 
    UnderoverscriptBox["\[Sum]", 
     RowBox[{
      StyleBox["j", "TI"], "=", "1"}], "3",
     LimitsPositioning->False], 
    SubscriptBox[
     StyleBox["a", "TI"], 
     StyleBox["j", "TI"]], 
    SubscriptBox[
     StyleBox["\[Sigma]", "TI"], 
     StyleBox["j", "TI"]]}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "0fbb8386-0132-4fef-9600-45d807ef9ba1"],
 ", one finds ",
 Cell[BoxData[
  RowBox[{
   SubscriptBox[
    StyleBox["a", "TI"], 
    StyleBox["j", "TI"]], "=", 
   StyleBox["T", "TI"], 
   StyleBox["r", "TI"], 
   StyleBox["[",
    SpanMaxSize->1], 
   RowBox[{
    StyleBox["H", "TI"], ".", 
    SubscriptBox[
     StyleBox["\[Sigma]", "TI"], 
     StyleBox["j", "TI"]]}], 
   StyleBox["]",
    SpanMaxSize->1], "/", "2"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "fe294079-ed9b-4eb5-8d2e-af34164dd167"],
 "."
}], "Text",ExpressionUUID->"2ed35e03-4be9-42cc-a2a1-77ec2271de14"],

Cell[TextData[{
 "The above algebraic relations have some important consequences: they tell \
us exactly how dot products and cross products of ordinary 3D vectors get \
\[OpenCurlyDoubleQuote]translated\[CloseCurlyDoubleQuote] into products of \
qubit operators built from Pauli matrices: ",
 Cell[BoxData[
  RowBox[{
   RowBox[{
    StyleBox["(",
     SpanMaxSize->1], 
    RowBox[{
     OverscriptBox[
      StyleBox["a", "TI"], "\[RightVector]"], ".", 
     OverscriptBox[
      StyleBox["\[Sigma]", "TI"], "\[RightVector]"]}], 
    StyleBox[")",
     SpanMaxSize->1], 
    StyleBox["(",
     SpanMaxSize->1], 
    RowBox[{
     OverscriptBox[
      StyleBox["b", "TI"], "\[RightVector]"], ".", 
     OverscriptBox[
      StyleBox["\[Sigma]", "TI"], "\[RightVector]"]}], 
    StyleBox[")",
     SpanMaxSize->1], "=", 
    StyleBox["(",
     SpanMaxSize->1], 
    RowBox[{
     OverscriptBox[
      StyleBox["a", "TI"], "\[RightVector]"], ".", 
     OverscriptBox[
      StyleBox["b", "TI"], "\[RightVector]"]}], 
    StyleBox[")",
     SpanMaxSize->1], "\|01d540", "+", 
    StyleBox["i", "TI"], 
    StyleBox["(",
     SpanMaxSize->1], 
    RowBox[{
     OverscriptBox[
      StyleBox["a", "TI"], "\[RightVector]"], "\[Times]", 
     OverscriptBox[
      StyleBox["b", "TI"], "\[RightVector]"]}], 
    StyleBox[")",
     SpanMaxSize->1]}], ".", 
   OverscriptBox[
    StyleBox["\[Sigma]", "TI"], "\[RightVector]"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "0c2c674c-c7a2-457c-895c-6ef4b0810c8b"],
 "  From this single formula, the commutator and anticommutator follow \
immediately and reveal two complementary pieces of physics: the commutator \
captures the \[OpenCurlyDoubleQuote]non-commuting rotation\
\[CloseCurlyDoubleQuote] structure, while the anticommutator captures the \
symmetric overlap: ",
 Cell[BoxData[
  RowBox[{
   RowBox[{
    StyleBox["[",
     SpanMaxSize->1], 
    RowBox[{
     OverscriptBox[
      StyleBox["a", "TI"], "\[RightVector]"], ".", 
     OverscriptBox[
      StyleBox["\[Sigma]", "TI"], "\[RightVector]"], ",", 
     OverscriptBox[
      StyleBox["b", "TI"], "\[RightVector]"], ".", 
     OverscriptBox[
      StyleBox["\[Sigma]", "TI"], "\[RightVector]"]}], 
    StyleBox["]",
     SpanMaxSize->1], "=", "2", 
    StyleBox["i", "TI"], 
    StyleBox["(",
     SpanMaxSize->1], 
    RowBox[{
     OverscriptBox[
      StyleBox["a", "TI"], "\[RightVector]"], "\[Times]", 
     OverscriptBox[
      StyleBox["b", "TI"], "\[RightVector]"]}], 
    StyleBox[")",
     SpanMaxSize->1]}], ".", 
   OverscriptBox[
    StyleBox["\[Sigma]", "TI"], "\[RightVector]"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "f247ce42-bc7a-4d8d-adb9-447d1cbce554"],
 " ",
 Cell[BoxData[
  RowBox[{
   RowBox[{"{", 
    OverscriptBox[
     StyleBox["a", "TI"], "\[RightVector]"]}], ".", 
   OverscriptBox[
    StyleBox["\[Sigma]", "TI"], "\[RightVector]"], ",", 
   OverscriptBox[
    StyleBox["b", "TI"], "\[RightVector]"], ".", 
   RowBox[{
    OverscriptBox[
     StyleBox["\[Sigma]", "TI"], "\[RightVector]"], "}", "=", "2", 
    StyleBox["(",
     SpanMaxSize->1], 
    RowBox[{
     OverscriptBox[
      StyleBox["a", "TI"], "\[RightVector]"], ".", 
     OverscriptBox[
      StyleBox["b", "TI"], "\[RightVector]"]}], 
    StyleBox[")",
     SpanMaxSize->1], "\|01d540"}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "696060e2-9921-4be5-b546-ac287b357b1b"],
 " We will soon discuss the implications and applications of these relations \
for describing generic rotations of a qubit state."
}], "Text",ExpressionUUID->"46da25e1-ed7e-42b0-a434-50fe03181c20"],

Cell[TextData[{
 "Verify that ",
 Cell[BoxData[
  RowBox[{
   RowBox[{
    StyleBox["(",
