Cell[BoxData[
 RowBox[{"Manipulate", "[", 
  RowBox[{
   RowBox[{"Legended", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"ResourceFunction", "[", "\"\<BlochSpherePlot\>\"", "]"}], "[", 
      
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"0", ",", " ", "0", ",", " ", "1"}], "}"}], ",", " ", "\n", 
         "    ", 
         RowBox[{"pulse", " ", ".", " ", 
          RowBox[{"{", 
           RowBox[{"0", ",", " ", "0", ",", " ", "1"}], "}"}]}]}], "}"}], ",",
        " ", 
       RowBox[{"ImageSize", " ", "->", " ", "150"}]}], "]"}], ",", " ", "\n", 
     "  ", 
     RowBox[{"SwatchLegend", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{
          RowBox[{"ColorData", "[", "97", "]"}], "[", "1", "]"}], ",", " ", 
         "\n", "    ", 
         RowBox[{
          RowBox[{"ColorData", "[", "97", "]"}], "[", "2", "]"}]}], "}"}], ",",
        " ", 
       RowBox[{"{", 
        RowBox[{"\"\<\\!\\(\\*TemplateBox[{\\\"0\\\"},\n\\\"Ket\\\"]\\)\>\"", 
         ",", " ", "\n", 
         "    ", "\"\<Pulse\\!\\(\\*TemplateBox[{\\\"0\\\"},\n\\\"Ket\\\"]\\)\
\>\""}], "}"}]}], "]"}]}], "]"}], ",", " ", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"pulse", ",", " ", "\n", "   ", 
       RowBox[{"RotationMatrix", "[", 
        RowBox[{
         RowBox[{"\[Pi]", "/", "2"}], ",", " ", 
         RowBox[{"{", 
          RowBox[{"1", ",", " ", "0", ",", " ", "0"}], "}"}]}], "]"}], ",", 
       " ", "\n", "   ", "\"\<Pulse\>\""}], "}"}], ",", " ", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{
        RowBox[{"RotationMatrix", "[", 
         RowBox[{
          RowBox[{"\[Pi]", "/", "2"}], ",", " ", 
          RowBox[{"{", 
           RowBox[{"1", ",", " ", "0", ",", " ", "0"}], "}"}]}], "]"}], " ", "->",
         " ", "\n", 
        "    ", "\"\<\\!\\(\\*SubscriptBox[\\(X\\), \\(\[Pi]/2\\)]\\)\>\""}], 
       ",", " ", "\n", "   ", 
       RowBox[{
        RowBox[{"RotationMatrix", "[", 
         RowBox[{"\[Pi]", ",", " ", 
          RowBox[{"{", 
           RowBox[{"1", ",", " ", "0", ",", " ", "0"}], "}"}]}], "]"}], " ", "->",
         " ", "\n", 
        "    ", "\"\<\\!\\(\\*SubscriptBox[\\(X\\), \\(\[Pi]\\)]\\)\>\""}], ",",
        " ", "\n", "   ", 
       RowBox[{
        RowBox[{"RotationMatrix", "[", 
         RowBox[{
          RowBox[{"\[Pi]", "/", "2"}], ",", " ", 
          RowBox[{"{", 
           RowBox[{"0", ",", " ", "1", ",", " ", "0"}], "}"}]}], "]"}], " ", "->",
         " ", "\n", 
        "    ", "\"\<\\!\\(\\*SubscriptBox[\\(Y\\), \\(\[Pi]/2\\)]\\)\>\""}], 
       ",", " ", "\n", "   ", 
       RowBox[{
        RowBox[{"RotationMatrix", "[", 
         RowBox[{"\[Pi]", ",", " ", 
          RowBox[{"{", 
           RowBox[{"0", ",", " ", "1", ",", " ", "0"}], "}"}]}], "]"}], " ", "->",
         " ", "\n", 
        "    ", "\"\<\\!\\(\\*SubscriptBox[\\(Y\\), \\(\[Pi]\\)]\\)\>\""}]}], 
      "}"}]}], "}"}]}], "]"}]], "Input",
 CellLabel->
  "In[184]:= ",ExpressionUUID->"707ec89b-5d8b-4cca-be8c-23e80cc574f8"],

Cell[TextData[{
