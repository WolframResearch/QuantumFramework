Cell[BoxData[{
 RowBox[{"ClearAll", "[", 
  RowBox[{"\[Phi]", ",", " ", "\[Theta]"}], "]"}], "\n", 
 RowBox[{"With", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{"n", " ", "=", " ", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{
         RowBox[{"Cos", "[", "\[Phi]", "]"}], " ", 
         RowBox[{"Sin", "[", "\[Theta]", "]"}]}], ",", " ", 
        RowBox[{
         RowBox[{"Sin", "[", "\[Phi]", "]"}], " ", 
         RowBox[{"Sin", "[", "\[Theta]", "]"}]}], ",", " ", "\n", "    ", 
        RowBox[{"Cos", "[", "\[Theta]", "]"}]}], "}"}]}], ",", " ", 
     RowBox[{"\[Sigma]", " ", "=", " ", 
      RowBox[{"Table", "[", 
       RowBox[{
        RowBox[{"PauliMatrix", "[", "j", "]"}], ",", " ", 
        RowBox[{"{", 
         RowBox[{"j", ",", " ", "3"}], "}"}]}], "]"}]}]}], "}"}], ",", " ", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"P1", " ", "=", " ", "\n", "   ", 
      RowBox[{
       RowBox[{"1", "/", "2"}], " ", 
       RowBox[{"(", 
        RowBox[{
         RowBox[{"IdentityMatrix", "[", "2", "]"}], " ", "+", " ", 
         RowBox[{"n", " ", ".", " ", "\[Sigma]"}]}], ")"}]}]}], ",", " ", 
     "\n", "  ", 
     RowBox[{"P2", " ", "=", " ", 
      RowBox[{
       RowBox[{"1", "/", "2"}], " ", 
       RowBox[{"(", 
        RowBox[{
         RowBox[{"IdentityMatrix", "[", "2", "]"}], " ", "-", " ", 
         RowBox[{"n", " ", ".", " ", "\[Sigma]"}]}], ")"}]}]}]}], "}"}], ",", 
   " ", "\n", " ", 
   RowBox[{"FullSimplify", "[", "\n", "  ", 
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{"P1", " ", ".", " ", "P1"}], " ", "==", " ", "P1"}], " ", "&&",
       " ", 
      RowBox[{"P1", " ", "==", " ", 
       RowBox[{"ConjugateTranspose", "[", "P1", "]"}]}], " ", "&&", " ", 
      RowBox[{
       RowBox[{"P2", " ", ".", " ", "P2"}], " ", "==", " ", "P2"}], " ", "&&",
       " ", "\n", "   ", 
      RowBox[{"P2", " ", "==", " ", 
       RowBox[{"ConjugateTranspose", "[", "P2", "]"}]}], " ", "&&", " ", "\n",
       "   ", 
      RowBox[{
       RowBox[{"P1", " ", "+", " ", "P2"}], " ", "==", " ", 
