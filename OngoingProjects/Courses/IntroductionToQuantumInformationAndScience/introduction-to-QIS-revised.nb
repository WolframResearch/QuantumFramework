     StyleBox["n", "TI"], "\[PlusMinus]"]], "=", 
   RowBox[{
    RowBox[{
     RowBox[{"1", "/", "2"}], 
     RowBox[{
      StyleBox["(",
       SpanMaxSize->1], 
      RowBox[{"\|01d540", "\[PlusMinus]", 
       RowBox[{
