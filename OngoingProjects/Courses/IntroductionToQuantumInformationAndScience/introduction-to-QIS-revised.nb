 ":"
}], "Text",ExpressionUUID->"4dbffa58-d965-422a-bfd0-53c7eaaf9228"],

Cell[BoxData[
 RowBox[{"With", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"m", " ", "=", " ", 
     RowBox[{
      RowBox[{
       RowBox[{"MatrixPower", "[", 
        RowBox[{"#", ",", " ", 
         RowBox[{"1", "/", "2"}]}], "]"}], " ", "&"}], " ", "/@", " ", 
      "\[ScriptCapitalE]"}]}], "}"}], ",", " ", "\n", " ", 
   RowBox[{"FullSimplify", "[", 
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{"ConjugateTranspose", "[", "#", "]"}], " ", ".", " ", "#"}], 
        " ", "&"}], " ", "/@", " ", "m"}], " ", "==", " ", 
      "\[ScriptCapitalE]"}], ",", " ", "\n", "  ", 
     RowBox[{"0", " ", "<=", " ", "\[Eta]", " ", "<=", " ", "1"}]}], "]"}]}], 
  "]"}]], "Input",
 CellLabel->
  "In[219]:= ",ExpressionUUID->"2d3747e6-f1be-4fbb-a663-97f0ff1e0232"],

Cell[TextData[{
 "Calculation post-measurement states ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["\[Rho]", "TI"], "\[PlusMinus]"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "16b14ae7-6388-4658-a225-fb2c2a2b2aa7"],
 ":"
}], "Text",ExpressionUUID->"b4730fcc-35e5-4126-bca9-6e764e1f26ce"],

Cell[BoxData[{
 RowBox[{"ClearAll", "[", 
  RowBox[{"rx", ",", " ", "ry", ",", " ", "rz"}], "]"}], "\n", 
 RowBox[{"AssociationThread", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"\"\<\\!\\(\\*SubscriptBox[\\(\[Rho]\\), \\(+\\)]\\)\>\"", ",", 
     " ", "\n", 
     "  ", "\"\<\\!\\(\\*SubscriptBox[\\(\[Rho]\\), \\(-\\)]\\)\>\""}], "}"}],
    ",", " ", "\n", " ", 
   RowBox[{"With", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"m", " ", "=", " ", 
        RowBox[{
         RowBox[{
          RowBox[{"MatrixPower", "[", 
           RowBox[{"#", ",", " ", 
            RowBox[{"1", "/", "2"}]}], "]"}], " ", "&"}], " ", "/@", " ", 
         "\[ScriptCapitalE]"}]}], ",", " ", "\n", "   ", 
       RowBox[{"r", " ", "=", " ", 
        RowBox[{"{", 
         RowBox[{"rx", ",", " ", "ry", ",", " ", "rz"}], "}"}]}]}], "}"}], ",",
      " ", 
     RowBox[{"{", 
      RowBox[{"\[Rho]", " ", "=", " ", 
       RowBox[{"DensityMatrix", "[", "r", "]"}]}], "}"}], ",", " ", "\n", 
     "  ", 
     RowBox[{
      RowBox[{
       RowBox[{"MatrixForm", "[", "\n", "     ", 
        RowBox[{"FullSimplify", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"#", " ", ".", " ", "\[Rho]", " ", ".", " ", 
            RowBox[{"ConjugateTranspose", "[", "#", "]"}]}], "/", "\n", 
           "      ", 
           RowBox[{"Tr", "[", 
            RowBox[{"#", " ", ".", " ", "\[Rho]", " ", ".", " ", 
             RowBox[{"ConjugateTranspose", "[", "#", "]"}]}], "]"}]}], ",", 
          " ", 
          RowBox[{"0", " ", "<=", " ", "\[Eta]", " ", "<=", " ", "1"}]}], 
         "]"}], "]"}], " ", "&"}], " ", "/@", " ", "\n", "   ", "m"}]}], 
    "]"}]}], "]"}]}], "Input",
 CellLabel->
  "In[220]:= ",ExpressionUUID->"510b61b7-760a-445b-aa61-3e106703ccef"],

Cell[TextData[{
 "Calculation Bloch vectors corresponding to post-measurement states ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["\[Rho]", "TI"], "\[PlusMinus]"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "431e80cf-17d2-4c42-9f47-ae64da5f2135"],
 ":"
}], "Text",ExpressionUUID->"9b7915ec-106e-452a-badb-484a10f271e9"],

Cell[BoxData[{
 RowBox[{"ClearAll", "[", 
  RowBox[{"rx", ",", " ", "ry", ",", " ", "rz"}], "]"}], "\n", 
 RowBox[{"AssociationThread", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"\"\<\\!\\(\\*SubscriptBox[\\(r\\), \\(+\\)]\\)\>\"", ",", " ", 
     "\n", "  ", "\"\<\\!\\(\\*SubscriptBox[\\(r\\), \\(-\\)]\\)\>\""}], 
    "}"}], ",", " ", "\n", " ", 
   RowBox[{"With", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"m", " ", "=", " ", 
        RowBox[{
         RowBox[{
          RowBox[{"MatrixPower", "[", 
           RowBox[{"#", ",", " ", 
            RowBox[{"1", "/", "2"}]}], "]"}], " ", "&"}], " ", "/@", " ", 
         "\[ScriptCapitalE]"}]}], ",", " ", "\n", "   ", 
       RowBox[{"r", " ", "=", " ", 
        RowBox[{"{", 
         RowBox[{"rx", ",", " ", "ry", ",", " ", "rz"}], "}"}]}]}], "}"}], ",",
      " ", 
     RowBox[{"{", 
      RowBox[{"\[Rho]", " ", "=", " ", 
       RowBox[{"DensityMatrix", "[", "r", "]"}]}], "}"}], ",", " ", "\n", 
     "  ", 
     RowBox[{
      RowBox[{
       RowBox[{"FullSimplify", "[", "\n", "     ", 
        RowBox[{
         RowBox[{"BlochVector", "[", 
          RowBox[{
           RowBox[{"#", " ", ".", " ", "\[Rho]", " ", ".", " ", 
            RowBox[{"ConjugateTranspose", "[", "#", "]"}]}], "/", "\n", 
           "      ", 
           RowBox[{"Tr", "[", 
            RowBox[{"#", " ", ".", " ", "\[Rho]", " ", ".", " ", 
             RowBox[{"ConjugateTranspose", "[", "#", "]"}]}], "]"}]}], "]"}], 
         ",", " ", "\n", "     ", 
         RowBox[{
          RowBox[{"0", " ", "<=", " ", "\[Eta]", " ", "<=", " ", "1"}], " ", "&&",
           " ", 
          RowBox[{
           RowBox[{"(", 
            RowBox[{"rx", " ", "|", " ", "ry", " ", "|", " ", "rz"}], ")"}], 
           " ", "\[Element]", " ", "Reals"}]}]}], "]"}], " ", "&"}], " ", "/@",
       " ", "m"}]}], "]"}]}], "]"}]}], "Input",
 CellLabel->
  "In[221]:= ",ExpressionUUID->"6a1c6f17-59ce-4e0f-9efd-adf29ab35e3e"],

Cell["POVMs and Quantum Channels", "Subsection",ExpressionUUID->"d9479c46-1749-4338-86d0-1e7df4219f9b"],

Cell[TextData[{
 "Now consider the case that you perform a measurement but then you ignore \
(or don\[CloseCurlyQuote]t record) which outcome happened. This non-selective \
state is the average over outcomes: ",
 Cell[BoxData[
  RowBox[{
   UnderscriptBox["\[Sum]", 
    StyleBox["J", "TI"],
    LimitsPositioning->False], 
   StyleBox["p", "TI"], 
   StyleBox["(",
    SpanMaxSize->1], 
   StyleBox["j", "TI"], 
   StyleBox[")",
    SpanMaxSize->1], " ", 
   SubscriptBox[
    StyleBox["\[Rho]", "TI"], 
    StyleBox["j", "TI"]], "=", 
   UnderscriptBox["\[Sum]", 
    StyleBox["j", "TI"],
    LimitsPositioning->False], 
   SubscriptBox["\[ScriptCapitalM]", 
    StyleBox["j", "TI"]], 
   StyleBox["\[Rho]", "TI"], " ", 
   SubsuperscriptBox["\[ScriptCapitalM]", 
    StyleBox["j", "TI"], "\[Dagger]"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "39ecaeec-fd3a-4b28-88fc-174eb3797ddf"],
 ". This is the unconditional (non-selective) post-measurement density \
matrix. It represents the state of the system after the measurement \
interaction has happened, when you haven\[CloseCurlyQuote]t conditioned on a \
specific outcome. The form of the transformation ",
 Cell[BoxData[
  RowBox[{
   UnderscriptBox["\[Sum]", 
    StyleBox["j", "TI"],
    LimitsPositioning->False], 
   SubscriptBox["\[ScriptCapitalM]", 
    StyleBox["j", "TI"]], 
   StyleBox["\[Rho]", "TI"], " ", 
   SubsuperscriptBox["\[ScriptCapitalM]", 
    StyleBox["j", "TI"], "\[Dagger]"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "7838567c-5abe-4a51-9d2e-76cbc15e5cbf"],
 " is usually called Kraus form. Any transformation that can be written in \
the Kraus form as ",
 Cell[BoxData[
  RowBox[{
   StyleBox["\[Rho]", "TI"], "\[Rule]", 
   UnderscriptBox["\[Sum]", 
    StyleBox["j", "TI"],
    LimitsPositioning->False], 
   SubscriptBox["\[ScriptCapitalM]", 
    StyleBox["j", "TI"]], 
   StyleBox["\[Rho]", "TI"], " ", 
   SubsuperscriptBox["\[ScriptCapitalM]", 
    StyleBox["j", "TI"], "\[Dagger]"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "eabfee41-80b4-4de2-a0e0-6afc0ec5bbe4"],
 " with ",
 Cell[BoxData[
  RowBox[{
   UnderscriptBox["\[Sum]", 
    StyleBox["j", "TI"],
    LimitsPositioning->False], 
   SubsuperscriptBox["\[ScriptCapitalM]", 
    StyleBox["j", "TI"], "\[Dagger]"], 
   SubscriptBox["\[ScriptCapitalM]", 
    StyleBox["j", "TI"]], "=", "\|01d540"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "7fe804f4-3ff4-4169-8357-667a8f762966"],
 " is a linear map that is called a quantum channel, and it is completely \
positive and trace preserving (CPTP)."
}], "Text",ExpressionUUID->"cc8ca3fc-9723-4d14-9f17-1a8572228c99"],

Cell[TextData[{
 "Calculate ",
 Cell[BoxData[
  RowBox[{
   SubscriptBox["\[ScriptCapitalM]", "+"], 
   StyleBox["\[Rho]", "TI"], " ", 
   SubsuperscriptBox["\[ScriptCapitalM]", "+", "\[Dagger]"], "+", 
   SubscriptBox["\[ScriptCapitalM]", "-"], 
   StyleBox["\[Rho]", "TI"], " ", 
   SubsuperscriptBox["\[ScriptCapitalM]", "-", "\[Dagger]"]}]], 
  "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "1a88207b-b705-4f1a-baa8-616cc51fd2c3"],
 ":"
}], "Text",ExpressionUUID->"c6ac1cdb-25df-4cd8-9c22-f7387ef1e21e"],

Cell[BoxData[
 RowBox[{
  RowBox[{"With", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{"m", " ", "=", " ", 
       RowBox[{
        RowBox[{
         RowBox[{"MatrixPower", "[", 
          RowBox[{"#", ",", " ", 
           RowBox[{"1", "/", "2"}]}], "]"}], " ", "&"}], " ", "/@", " ", 
        "\[ScriptCapitalE]"}]}], ",", " ", "\n", "   ", 
      RowBox[{"r", " ", "=", " ", 
       RowBox[{"{", 
        RowBox[{"rx", ",", " ", "ry", ",", " ", "rz"}], "}"}]}], ",", " ", 
      RowBox[{"\[Sigma]", " ", "=", " ", "\n", "    ", 
       RowBox[{"Table", "[", 
        RowBox[{
         RowBox[{"PauliMatrix", "[", "j", "]"}], ",", " ", 
         RowBox[{"{", 
          RowBox[{"j", ",", " ", "3"}], "}"}]}], "]"}]}]}], "}"}], ",", " ", 
    RowBox[{"{", 
     RowBox[{"\[Rho]", " ", "=", " ", 
      RowBox[{"DensityMatrix", "[", "r", "]"}]}], "}"}], ",", " ", "\n", "  ", 
    RowBox[{"FullSimplify", "[", "\n", "   ", 
     RowBox[{
      RowBox[{"Sum", "[", 
       RowBox[{
        RowBox[{
        "\[ScriptCapitalK]", " ", ".", " ", "\[Rho]", " ", ".", " ", "\n", 
         "     ", 
         RowBox[{"ConjugateTranspose", "[", "\[ScriptCapitalK]", "]"}]}], ",",
         " ", 
        RowBox[{"{", 
         RowBox[{"\[ScriptCapitalK]", ",", " ", "m"}], "}"}]}], "]"}], ",", 
      " ", "\n", "   ", 
      RowBox[{
       RowBox[{"0", " ", "<=", " ", "\[Eta]", " ", "<=", " ", "1"}], " ", "&&",
        " ", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{"rx", " ", "|", " ", "ry", " ", "|", " ", "rz"}], ")"}], " ",
         "\[Element]", " ", "Reals"}]}]}], "]"}]}], "]"}], " ", "//", " ", 
  "MatrixForm"}]], "Input",
 CellLabel->
  "In[222]:= ",ExpressionUUID->"8bc60b50-bbd6-4504-bad5-c0e1ea1111c7"],

Cell[TextData[{
 "Calculate the Bloch vector for the transformation ",
 Cell[BoxData[
  RowBox[{
   SubscriptBox["\[ScriptCapitalM]", "+"], 
   StyleBox["\[Rho]", "TI"], " ", 
   SubsuperscriptBox["\[ScriptCapitalM]", "+", "\[Dagger]"], "+", 
   SubscriptBox["\[ScriptCapitalM]", "-"], 
   StyleBox["\[Rho]", "TI"], " ", 
   SubsuperscriptBox["\[ScriptCapitalM]", "-", "\[Dagger]"]}]], 
  "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "101cd7da-8fc6-43e7-8139-25e9f34d727d"],
 ":"
}], "Text",ExpressionUUID->"406ec606-ce37-4749-a1ea-07b36db5d404"],

Cell[BoxData[
 RowBox[{"With", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{"m", " ", "=", " ", 
      RowBox[{
       RowBox[{
        RowBox[{"MatrixPower", "[", 
         RowBox[{"#", ",", " ", 
          RowBox[{"1", "/", "2"}]}], "]"}], " ", "&"}], " ", "/@", " ", 
       "\[ScriptCapitalE]"}]}], ",", " ", "\n", "  ", 
     RowBox[{"r", " ", "=", " ", 
      RowBox[{"{", 
       RowBox[{"rx", ",", " ", "ry", ",", " ", "rz"}], "}"}]}], ",", " ", 
     RowBox[{"\[Sigma]", " ", "=", " ", "\n", "   ", 
      RowBox[{"Table", "[", 
       RowBox[{
        RowBox[{"PauliMatrix", "[", "j", "]"}], ",", " ", 
        RowBox[{"{", 
         RowBox[{"j", ",", " ", "3"}], "}"}]}], "]"}]}]}], "}"}], ",", " ", 
   RowBox[{"{", 
    RowBox[{"\[Rho]", " ", "=", " ", 
     RowBox[{"DensityMatrix", "[", "r", "]"}]}], "}"}], ",", " ", "\n", " ", 
   RowBox[{"FullSimplify", "[", "\n", "  ", 
    RowBox[{
     RowBox[{"BlochVector", "@", "\n", "   ", 
      RowBox[{"Sum", "[", 
       RowBox[{
        RowBox[{
        "\[ScriptCapitalK]", " ", ".", " ", "\[Rho]", " ", ".", " ", "\n", 
         "     ", 
         RowBox[{"ConjugateTranspose", "[", "\[ScriptCapitalK]", "]"}]}], ",",
         " ", 
        RowBox[{"{", 
         RowBox[{"\[ScriptCapitalK]", ",", " ", "m"}], "}"}]}], "]"}]}], ",", 
     " ", "\n", "  ", 
     RowBox[{
      RowBox[{"0", " ", "<=", " ", "\[Eta]", " ", "<=", " ", "1"}], " ", "&&",
       " ", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{"rx", " ", "|", " ", "ry", " ", "|", " ", "rz"}], ")"}], " ", 
       "\[Element]", " ", "Reals"}]}]}], "]"}]}], "]"}]], "Input",
 CellLabel->
  "In[223]:= ",ExpressionUUID->"16eed1e4-b127-401f-808d-123d284dbf48"],

Cell[TextData[{
 "So the unsharp X-measurement preserves the measured component ",
 Cell[BoxData[
  RowBox[{"(", 
   SubscriptBox[
    StyleBox["r", "TI"], 
    StyleBox["x", "TI"]]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "8dd02cfd-fe01-4364-acb6-37f226b667ea"],
 ") but shrinks the perpendicular components ",
 Cell[BoxData[
  RowBox[{"(", 
   SubscriptBox[
    StyleBox["r", "TI"], 
    RowBox[{
     StyleBox["y", "TI"], ",", 
     StyleBox["z", "TI"]}]]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "c3f5ad96-5cc6-49d5-9fa6-1cbf87c58166"],
 "), which is exactly \[OpenCurlyDoubleQuote]measurement-induced decoherence\
\[CloseCurlyDoubleQuote] in the measurement eigenbasis."
}], "Text",ExpressionUUID->"bede460d-3f1a-4573-8d90-ba447d468314"],

Cell["\<\
Visualize the change in the available space in the Bloch sphere due to \
unsharp X-measurement:\
\>", "Text",ExpressionUUID->"32a74684-4730-48b3-a8a2-4fcf7393cfc7"],

Cell[BoxData[
 RowBox[{"With", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"\[Eta]", " ", "=", " ", ".75"}], "}"}], ",", " ", 
   RowBox[{"Show", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"ResourceFunction", "[", "\"\<BlochSpherePlot\>\"", "]"}], "[", 
      
      RowBox[{"ImageSize", " ", "->", " ", "250"}], "]"}], ",", "\n", "   ", 
     RowBox[{"ParametricPlot3D", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{
          RowBox[{"Cos", "[", "\[Phi]", "]"}], " ", 
          RowBox[{"Sin", "[", "\[Theta]", "]"}]}], ",", " ", "\n", "    ", 
         RowBox[{
          RowBox[{"Sin", "[", "\[Phi]", "]"}], " ", 
          RowBox[{"Sin", "[", "\[Theta]", "]"}], " ", 
          RowBox[{"Sqrt", "[", 
           RowBox[{"1", " ", "-", " ", 
            RowBox[{"\[Eta]", "^", "2"}]}], "]"}]}], ",", " ", "\n", "    ", 
         RowBox[{
          RowBox[{"Cos", "[", "\[Theta]", "]"}], " ", 
          RowBox[{"Sqrt", "[", 
           RowBox[{"1", " ", "-", " ", 
            RowBox[{"\[Eta]", "^", "2"}]}], "]"}]}]}], "}"}], ",", " ", 
       RowBox[{"{", 
        RowBox[{"\[Theta]", ",", " ", "0", ",", " ", "\[Pi]"}], "}"}], ",", 
       " ", 
       RowBox[{"{", 
        RowBox[{"\[Phi]", ",", " ", "\n", "    ", "0", ",", " ", 
         RowBox[{"2", " ", "\[Pi]"}]}], "}"}], ",", " ", 
       RowBox[{"Boxed", " ", "->", " ", "False"}], ",", " ", 
       RowBox[{"Axes", " ", "->", " ", "False"}], ",", " ", 
       RowBox[{"PlotPoints", " ", "->", " ", "25"}], ",", " ", "\n", "   ", 
       RowBox[{"PlotStyle", " ", "->", " ", 
        RowBox[{"Opacity", "[", ".5", "]"}]}]}], "]"}], ",", " ", "\n", "  ", 
     
     RowBox[{
     "PlotLabel", " ", "->", " ", "\n", 
      "   ", "\"\<Transformed space of states due to\n unsharpe/weak Pauli-X \
measurement\n with the sharpness/strength \[Eta]=0.75\>\""}]}], "]"}]}], 
  "]"}]], "Input",
 CellLabel->
  "In[224]:= ",ExpressionUUID->"94b55f74-0f41-438a-9626-ec0d604bed0e"],

Cell["POVMs: Same Statistics, Different Measurements", "Subsection",ExpressionUUID->"bb4ee3b2-83ba-455e-b7a1-bdd2321fcd6a"],

Cell[TextData[{
 "However, fixing the effects ",
 Cell[BoxData[
  SubscriptBox["\[ScriptCapitalE]", 
   StyleBox["j", "TI"]]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "8d9a31de-31c5-4d73-aa27-beb87993d483"],
 " pins down only the statistics of a measurement: for every input state, it \
tells you the probabilities as ",
 Cell[BoxData[
  RowBox[{
   SubscriptBox[
    StyleBox["p", "TI"], 
    StyleBox["j", "TI"]], "=", 
   StyleBox["T", "TI"], 
   StyleBox["r", "TI"], 
   StyleBox["[",
    SpanMaxSize->1], 
   RowBox[{
    SubscriptBox["\[ScriptCapitalE]", 
     StyleBox["j", "TI"]], 
    StyleBox["\[Rho]", "TI"]}], 
   StyleBox["]",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "7d6bee83-0e2c-421c-b008-d1bfaf771635"],
 ". But it does not uniquely determine what the measurement does to the \
system when an outcome occurs. That \[OpenCurlyDoubleQuote]what it does\
\[CloseCurlyDoubleQuote] is encoded in the measurement operators (Kraus \
operators) ",
 Cell[BoxData[
  SubscriptBox["\[ScriptCapitalM]", 
   StyleBox["j", "TI"]]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "2b83087b-5a9a-4480-86b1-99c69cfc0833"],
 " that realize the same effects through ",
 Cell[BoxData[
  SubscriptBox["\[ScriptCapitalE]", 
   StyleBox["j", "TI"]]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "458fe1e7-007a-4dde-9ba6-242d3a17e8b9"],
 ". Many different physical procedures (e.g., different hidden detector \
dynamics, different classical randomizations) can produce exactly the same \
classical outcome frequencies while disturbing the quantum state in different \
ways. In other words, a POVM is like specifying the distribution of readouts; \
specifying a particular set of \[ScriptCapitalM]\[CloseCurlyQuote]s is \
specifying the measurement device\[CloseCurlyQuote]s internal mechanism and \
therefore the back-action."
}], "Text",ExpressionUUID->"7b21fad7-e8b5-4ac4-875a-052e2f5c90d7"],

Cell[TextData[{
 "For example, take ",
 Cell[BoxData[
  SubscriptBox["\[ScriptCapitalM]", "\[PlusMinus]"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "d6aa29e9-6c5d-4cfe-b73b-44eff05e9cd6"],
 " we defined above. Now define a new implementation as ",
 Cell[BoxData[
  RowBox[{
   SubscriptBox[
    StyleBox["U", "TI"], "\[PlusMinus]"], 
   SubscriptBox["\[ScriptCapitalM]", "\[PlusMinus]"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "5a3c755f-4e35-488a-9e69-3aa42829f806"],
 " where ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["U", "TI"], 
   RowBox[{"+", "\[PlusMinus]"}]]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "e7f404ea-013d-4c9a-a748-bc090a45b423"],
 " are any unitaries. Then, one can show that ",
 Cell[BoxData[
  RowBox[{
   SuperscriptBox[
    RowBox[{
     StyleBox["(",
      SpanMaxSize->1], 
     RowBox[{
      SubscriptBox[
       StyleBox["U", "TI"], "\[PlusMinus]"], 
      SubscriptBox["\[ScriptCapitalM]", "\[PlusMinus]"]}], 
     StyleBox[")",
      SpanMaxSize->1]}], "\[Dagger]"], 
   SubscriptBox[
    StyleBox["U", "TI"], "\[PlusMinus]"], 
   SubscriptBox["\[ScriptCapitalM]", "\[PlusMinus]"], "=", 
   SubsuperscriptBox["\[ScriptCapitalM]", "\[PlusMinus]", "\[Dagger]"], 
   SubsuperscriptBox[
    StyleBox["U", "TI"], "\[PlusMinus]", "\[Dagger]"], 
   SubscriptBox[
    StyleBox["U", "TI"], "\[PlusMinus]"], 
   SubscriptBox["\[ScriptCapitalM]", "\[PlusMinus]"], "=", 
   SubsuperscriptBox["\[ScriptCapitalM]", "\[PlusMinus]", "\[Dagger]"], 
   SubscriptBox["\[ScriptCapitalM]", "\[PlusMinus]"], "=", 
   SubscriptBox["\[ScriptCapitalE]", "\[PlusMinus]"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "b2475fa4-6f8f-4e85-bf7d-c99f6cab49b2"],
 " which means POVM (and therefore the probabilities) are exactly unchanged. \
The new measurement (Kraus operators) can be interpreted like this: you \
perform the same measurement you always did, but your apparatus is wired so \
that after it flashes \[OpenCurlyDoubleQuote]+\[CloseCurlyDoubleQuote] it \
secretly rotates the qubit by ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["U", "TI"], "+"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "16c988d0-8349-4ad1-b563-33ee7433cc97"],
 ", and after it flashes \[OpenCurlyDoubleQuote]\[Minus]\
\[CloseCurlyDoubleQuote] it rotates it by ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["U", "TI"], "-"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "5ad0c9cb-46a7-476c-a346-c98d602b061d"],
 ". The readout statistics don\[CloseCurlyQuote]t notice this extra step; the \
post-measurement state does."
}], "Text",ExpressionUUID->"085e0a7e-6453-4e6c-8018-d04af7fdb39d"],

Cell[TextData[{
 "For ",
 Cell[BoxData[
  RowBox[{
   SubscriptBox[
    StyleBox["U", "TI"], "+"], "=", 
   SuperscriptBox[
    StyleBox["e", "TI"], 
    RowBox[{"-", 
     StyleBox["i", "TI"], " ", "\[Pi]", " ", 
     SubscriptBox[
      StyleBox["\[Sigma]", "TI"], 
      StyleBox["z", "TI"]], "/", "4"}]]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "12a7eb5c-6a83-461f-aa11-42d05f85add0"],
 " and ",
 Cell[BoxData[
  RowBox[{
   SubscriptBox[
    StyleBox["U", "TI"], "-"], "=", "\|01d540"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "6e3e6b3f-0046-4c86-be08-9573a5afa7dd"],
 ", verify that ",
 Cell[BoxData[
  SubscriptBox["\[ScriptCapitalE]", "\[PlusMinus]"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "f25e881a-d95f-4089-8722-5140e81598f0"],
 " remain unchanged:"
}], "Text",ExpressionUUID->"577a5be3-e0c4-4ca9-971b-bc4fdb0b37a2"],

Cell[BoxData[
 RowBox[{"With", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"m", " ", "=", " ", "\n", "   ", 
     RowBox[{"MapThread", "[", "\n", "    ", 
      RowBox[{"Dot", ",", " ", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{
           RowBox[{"IdentityMatrix", "[", "2", "]"}], ",", " ", 
           RowBox[{"PauliMatrix", "[", "3", "]"}]}], "}"}], ",", " ", "\n", 
         "     ", 
         RowBox[{
          RowBox[{
           RowBox[{"MatrixPower", "[", 
            RowBox[{"#", ",", " ", 
             RowBox[{"1", "/", "2"}]}], "]"}], " ", "&"}], " ", "/@", " ", 
          "\[ScriptCapitalE]"}]}], "}"}]}], "]"}]}], "}"}], ",", " ", "\n", 
   " ", 
   RowBox[{"FullSimplify", "[", 
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{"ConjugateTranspose", "[", "#", "]"}], " ", ".", " ", "#"}], 
        " ", "&"}], " ", "/@", " ", "m"}], " ", "==", " ", 
      "\[ScriptCapitalE]"}], ",", " ", "\n", "  ", 
     RowBox[{
      RowBox[{"0", " ", "<=", " ", "\[Eta]", " ", "<=", " ", "1"}], " ", "&&",
       " ", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{"rx", " ", "|", " ", "ry", " ", "|", " ", "rz"}], ")"}], " ", 
       "\[Element]", " ", "Reals"}]}]}], "]"}]}], "]"}]], "Input",
 CellLabel->
  "In[225]:= ",ExpressionUUID->"54bdebef-9566-4ec8-96c0-e93b0f42ea16"],

Cell[TextData[{
 "With new Kraus operators ",
 Cell[BoxData[
  RowBox[{
   RowBox[{"{", 
    SuperscriptBox[
     StyleBox["e", "TI"], 
     RowBox[{"-", 
      StyleBox["i", "TI"], " ", "\[Pi]", " ", 
      SubscriptBox[
       StyleBox["\[Sigma]", "TI"], 
       StyleBox["z", "TI"]], "/", "4"}]], 
    SubscriptBox["\[ScriptCapitalM]", "+"]}], ",", 
   RowBox[{
    SubscriptBox["\[ScriptCapitalM]", "-"], "}"}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "65c2e0d5-adc2-4be1-add2-247e4721bfd1"],
 ", calculate the post-measurement states for each outcome:"
}], "Text",ExpressionUUID->"7555f5ab-e373-4628-95ba-c3848571fb34"],

Cell[BoxData[{
 RowBox[{"ClearAll", "[", 
  RowBox[{"rx", ",", " ", "ry", ",", " ", "rz"}], "]"}], "\n", 
 RowBox[{"AssociationThread", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"\"\<\\!\\(\\*SubscriptBox[\\(\[Rho]\\), \\(+\\)]\\)\>\"", ",", 
     " ", "\n", 
     "  ", "\"\<\\!\\(\\*SubscriptBox[\\(\[Rho]\\), \\(-\\)]\\)\>\""}], "}"}],
    ",", " ", "\n", " ", 
   RowBox[{"With", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"m", " ", "=", " ", "\n", "    ", 
        RowBox[{"MapThread", "[", "\n", "     ", 
         RowBox[{"Dot", ",", " ", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"{", 
             RowBox[{
              RowBox[{"IdentityMatrix", "[", "2", "]"}], ",", " ", 
              RowBox[{"PauliMatrix", "[", "3", "]"}]}], "}"}], ",", " ", "\n",
             "      ", 
            RowBox[{
             RowBox[{
              RowBox[{"MatrixPower", "[", 
               RowBox[{"#", ",", " ", 
                RowBox[{"1", "/", "2"}]}], "]"}], " ", "&"}], " ", "/@", " ", 
             "\[ScriptCapitalE]"}]}], "}"}]}], "]"}]}], ",", " ", "\n", "   ", 
       RowBox[{"r", " ", "=", " ", 
        RowBox[{"{", 
         RowBox[{"rx", ",", " ", "ry", ",", " ", "rz"}], "}"}]}]}], "}"}], ",",
      " ", 
     RowBox[{"{", 
      RowBox[{"\[Rho]", " ", "=", " ", 
       RowBox[{"DensityMatrix", "[", "r", "]"}]}], "}"}], ",", " ", "\n", 
     "  ", 
     RowBox[{
      RowBox[{
       RowBox[{"MatrixForm", "[", "\n", "     ", 
        RowBox[{"FullSimplify", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"#", " ", ".", " ", "\[Rho]", " ", ".", " ", 
            RowBox[{"ConjugateTranspose", "[", "#", "]"}]}], "/", "\n", 
           "      ", 
           RowBox[{"Tr", "[", 
            RowBox[{"#", " ", ".", " ", "\[Rho]", " ", ".", " ", 
             RowBox[{"ConjugateTranspose", "[", "#", "]"}]}], "]"}]}], ",", 
          " ", 
          RowBox[{"0", " ", "<=", " ", "\[Eta]", " ", "<=", " ", "1"}]}], 
         "]"}], "]"}], " ", "&"}], " ", "/@", " ", "\n", "   ", "m"}]}], 
    "]"}]}], "]"}]}], "Input",
 CellLabel->
  "In[226]:= ",ExpressionUUID->"14c7c9f0-47f9-4406-94f8-36046896fb63"],

Cell[TextData[{
 "Calculate the Bloch vector of the non-selective post-measurement state \
using new Kraus operators ",
 Cell[BoxData[
  RowBox[{
   RowBox[{"{", 
    SuperscriptBox[
     StyleBox["e", "TI"], 
     RowBox[{"-", 
      StyleBox["i", "TI"], " ", "\[Pi]", " ", 
      SubscriptBox[
       StyleBox["\[Sigma]", "TI"], 
       StyleBox["z", "TI"]], "/", "4"}]], 
    SubscriptBox["\[ScriptCapitalM]", "+"]}], ",", 
   RowBox[{
    SubscriptBox["\[ScriptCapitalM]", "-"], "}"}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "46472cce-232a-4f77-961a-f0a8821edf2d"],
 ":"
}], "Text",ExpressionUUID->"dc0180d4-5c1b-446c-920c-eeb1929c2380"],

Cell[BoxData[
 RowBox[{"With", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{"m", " ", "=", " ", "\n", "   ", 
      RowBox[{"MapThread", "[", "\n", "    ", 
       RowBox[{"Dot", ",", " ", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{
            RowBox[{"MatrixExp", "[", 
             RowBox[{
              RowBox[{"-", "I"}], " ", 
              RowBox[{"\[Pi]", "/", "4"}], " ", 
              RowBox[{"PauliMatrix", "[", "3", "]"}]}], "]"}], ",", " ", 
            RowBox[{"IdentityMatrix", "[", "2", "]"}]}], "}"}], ",", " ", 
          "\n", "     ", 
          RowBox[{
           RowBox[{
            RowBox[{"MatrixPower", "[", 
             RowBox[{"#", ",", " ", 
              RowBox[{"1", "/", "2"}]}], "]"}], " ", "&"}], " ", "/@", " ", 
           "\[ScriptCapitalE]"}]}], "}"}]}], "]"}]}], ",", " ", "\n", "  ", 
     RowBox[{"r", " ", "=", " ", 
      RowBox[{"{", 
       RowBox[{"rx", ",", " ", "ry", ",", " ", "rz"}], "}"}]}]}], "}"}], ",", 
   " ", 
   RowBox[{"{", 
    RowBox[{"\[Rho]", " ", "=", " ", 
     RowBox[{"DensityMatrix", "[", "r", "]"}]}], "}"}], ",", " ", "\n", " ", 
   RowBox[{"FullSimplify", "[", "\n", "  ", 
    RowBox[{
     RowBox[{"BlochVector", "@", "\n", "   ", 
      RowBox[{"Sum", "[", 
       RowBox[{
        RowBox[{
        "\[ScriptCapitalK]", " ", ".", " ", "\[Rho]", " ", ".", " ", "\n", 
         "     ", 
         RowBox[{"ConjugateTranspose", "[", "\[ScriptCapitalK]", "]"}]}], ",",
         " ", 
        RowBox[{"{", 
         RowBox[{"\[ScriptCapitalK]", ",", " ", "m"}], "}"}]}], "]"}]}], ",", 
     " ", "\n", "  ", 
     RowBox[{
      RowBox[{"0", " ", "<=", " ", "\[Eta]", " ", "<=", " ", "1"}], " ", "&&",
       " ", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{"rx", " ", "|", " ", "ry", " ", "|", " ", "rz"}], ")"}], " ", 
       "\[Element]", " ", "Reals"}]}]}], "]"}]}], "]"}]], "Input",
 CellLabel->
  "In[227]:= ",ExpressionUUID->"3cd9b401-2c98-4f1a-99d2-4b94a2751975"],

Cell["\<\
Visualize the change in the available space in the Bloch sphere due to \
unsharp X-measurement:\
\>", "Text",ExpressionUUID->"72691dca-aac3-4ddb-98da-9132909a7f0e"],

Cell[BoxData[
 RowBox[{"Legended", "[", 
  RowBox[{
   RowBox[{"With", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"\[Eta]", " ", "=", " ", ".75"}], "}"}], ",", " ", 
     RowBox[{"Show", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"ResourceFunction", "[", "\"\<BlochSpherePlot\>\"", "]"}], "[", 
        RowBox[{"ImageSize", " ", "->", " ", "250"}], "]"}], ",", "\n", "   ", 
       RowBox[{"ParametricPlot3D", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{
           RowBox[{
            RowBox[{"Cos", "[", "\[Phi]", "]"}], " ", 
            RowBox[{"Sin", "[", "\[Theta]", "]"}]}], ",", " ", "\n", "     ", 
           
           RowBox[{
            RowBox[{"Sin", "[", "\[Phi]", "]"}], " ", 
            RowBox[{"Sin", "[", "\[Theta]", "]"}], " ", 
            RowBox[{"Sqrt", "[", 
             RowBox[{"1", " ", "-", " ", 
              RowBox[{"\[Eta]", "^", "2"}]}], "]"}]}], ",", " ", "\n", 
           "     ", 
           RowBox[{
            RowBox[{"Cos", "[", "\[Theta]", "]"}], " ", 
            RowBox[{"Sqrt", "[", 
             RowBox[{"1", " ", "-", " ", 
              RowBox[{"\[Eta]", "^", "2"}]}], "]"}]}]}], "}"}], ",", " ", 
         RowBox[{"{", 
          RowBox[{"\[Theta]", ",", " ", "0", ",", " ", "\[Pi]"}], "}"}], ",", 
         " ", 
         RowBox[{"{", 
          RowBox[{"\[Phi]", ",", "\n", "      ", "0", ",", " ", 
           RowBox[{"2", " ", "\[Pi]"}]}], "}"}], ",", " ", 
         RowBox[{"Boxed", " ", "->", " ", "False"}], ",", " ", 
         RowBox[{"Axes", " ", "->", " ", "False"}], ",", " ", 
         RowBox[{"PlotPoints", " ", "->", " ", "25"}], ",", " ", "\n", "    ", 
         RowBox[{"PlotStyle", " ", "->", " ", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{
             RowBox[{"ColorData", "[", "97", "]"}], "[", "1", "]"}], ",", " ", 
            RowBox[{"Opacity", "[", ".5", "]"}]}], "}"}]}]}], "]"}], ",", " ",
        "\n", "   ", 
       RowBox[{"ParametricPlot3D", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{
           RowBox[{
            RowBox[{"1", "/", "\n", "      ", "2"}], " ", 
            RowBox[{"(", 
             RowBox[{
              RowBox[{"-", "\[Eta]"}], " ", "+", " ", 
              RowBox[{
               RowBox[{"Cos", "[", "\[Phi]", "]"}], " ", 
               RowBox[{"Sin", "[", "\[Theta]", "]"}]}], " ", "-", " ", "\n", 
              "        ", 
              RowBox[{
               RowBox[{"Sqrt", "[", 
                RowBox[{"1", " ", "-", " ", 
                 RowBox[{"\[Eta]", "^", "2"}]}], "]"}], " ", 
               RowBox[{"Sin", "[", "\[Theta]", "]"}], " ", 
               RowBox[{"Sin", "[", "\[Phi]", "]"}]}]}], ")"}]}], ",", " ", 
           "\n", "     ", 
           RowBox[{
            RowBox[{"1", "/", "2"}], " ", 
            RowBox[{"(", 
             RowBox[{"\[Eta]", " ", "+", " ", 
              RowBox[{
               RowBox[{"Cos", "[", "\[Phi]", "]"}], " ", 
               RowBox[{"Sin", "[", "\[Theta]", "]"}]}], " ", "+", " ", "\n", 
              "        ", 
              RowBox[{
               RowBox[{"Sqrt", "[", 
                RowBox[{"1", " ", "-", " ", 
                 RowBox[{"\[Eta]", "^", "2"}]}], "]"}], " ", 
               RowBox[{"Sin", "[", "\[Theta]", "]"}], " ", 
               RowBox[{"Sin", "[", "\[Phi]", "]"}]}]}], ")"}]}], ",", " ", 
           "\n", "     ", 
           RowBox[{
            RowBox[{"Sqrt", "[", 
             RowBox[{"1", " ", "-", " ", 
              RowBox[{"\[Eta]", "^", "2"}]}], "]"}], " ", 
            RowBox[{"Cos", "[", "\[Theta]", "]"}]}]}], "}"}], ",", " ", 
         RowBox[{"{", 
          RowBox[{"\[Theta]", ",", " ", "0", ",", " ", "\[Pi]"}], "}"}], ",", 
         " ", 
         RowBox[{"{", 
          RowBox[{"\[Phi]", ",", "\n", "      ", "0", ",", " ", 
           RowBox[{"2", " ", "\[Pi]"}]}], "}"}], ",", " ", 
         RowBox[{"Boxed", " ", "->", " ", "False"}], ",", " ", 
         RowBox[{"Axes", " ", "->", " ", "False"}], ",", " ", 
         RowBox[{"PlotPoints", " ", "->", " ", "25"}], ",", " ", "\n", "    ", 
         RowBox[{"PlotStyle", " ", "->", " ", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{
             RowBox[{"ColorData", "[", "97", "]"}], "[", "2", "]"}], ",", " ", 
            RowBox[{"Opacity", "[", ".5", "]"}]}], "}"}]}]}], "]"}], ",", " ",
        "\n", "   ", 
       RowBox[{
       "PlotLabel", " ", "->", " ", "\n", 
        "    ", "\"\<Transformed space of states due to\n unsharpe/weak \
Pauli-X measurement\n with the sharpness/strength \[Eta]=0.75\>\""}]}], 
      "]"}]}], "]"}], ",", " ", "\n", " ", 
   RowBox[{"SwatchLegend", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{
        RowBox[{"ColorData", "[", "97", "]"}], "[", "1", "]"}], ",", " ", 
       "\n", "   ", 
       RowBox[{
        RowBox[{"ColorData", "[", "97", "]"}], "[", "\n", "    ", "2", 
        "]"}]}], "}"}], ",", " ", 
     RowBox[{"{", 
      RowBox[{"\"\<\\!\\(\\*SubscriptBox[\\(\[ScriptCapitalM]\\), \\(\
\[PlusMinus]\\)]\\)=\\!\\(\\*SqrtBox[SubscriptBox[\\(\[ScriptCapitalE]\\), \
\\(\[PlusMinus]\\)]]\\)\>\"", ",", " ", "\n", 
       "   ", "\"\<\\!\\(\\*SubscriptBox[\\(\[ScriptCapitalM]\\), \
\\(+\\)]\\)=\\!\\(\\*SuperscriptBox[\\(\[ExponentialE]\\), \
\\(-\\*FractionBox[\\(\[ImaginaryI]\\\\ \[Pi]\\\\ \\*SubscriptBox[\\(\[Sigma]\
\\), \\(z\\)]\\), \\(4\\)]\\)]\\)\\!\\(\\*SqrtBox[SubscriptBox[\\(\
\[ScriptCapitalE]\\), \\(+\\)]]\\), \
\\!\\(\\*SubscriptBox[\\(\[ScriptCapitalM]\\), \
\\(-\\)]\\)=\\!\\(\\*SqrtBox[SubscriptBox[\\(\[ScriptCapitalE]\\), \
\\(+\\)]]\\)\>\""}], "}"}]}], "]"}]}], "]"}]], "Input",
 CellLabel->
  "In[228]:= ",ExpressionUUID->"79af7ea4-9c44-4c61-b9f1-f6235f59430d"],

Cell["\<\
When you \[OpenCurlyDoubleQuote]add a unitary\[CloseCurlyDoubleQuote] to a \
Kraus operator, you are not changing the measurement\[CloseCurlyQuote]s \
readout statistics, you are changing what happens to the quantum state after \
the measurement reports an outcome. Think of it as wiring an extra control \
box after the detector: first the detector produces an outcome label (like \
\[OpenCurlyDoubleQuote]+\[CloseCurlyDoubleQuote] or \[OpenCurlyDoubleQuote]\
\[Minus]\[CloseCurlyDoubleQuote]), and then, depending on which label \
appeared, the control box applies a rotation to the qubit.  The crucial point \
is that the POVM effects determine only how often each label appears, not \
what the device does to the state. So you can keep the same effects (and \
therefore the same outcome probabilities for every input state) while \
modifying the back-action by appending an outcome-dependent unitary. In \
practice, this models real experiments where you do feedback, actively \
correct errors, or simply have hardware that naturally applies a conditional \
phase or rotation as part of the readout process.  What changes, then, are \
the post-measurement states. If you look at the state conditioned on a \
particular outcome, it will generally be a rotated version of the state you \
would have gotten without that extra unitary. That means if you repeat the \
measurement, or if you use the post-measurement state as the input to later \
gates, the subsequent behavior can be very different\[LongDash]even though \
the measurement\[CloseCurlyQuote]s raw outcome frequencies are identical. In \
other words, you can make two devices that \[OpenCurlyDoubleQuote]report the \
same results with the same probabilities,\[CloseCurlyDoubleQuote] but one of \
them leaves the system gently nudged toward an eigenstate, while the other \
one nudges it and then also kicks it (rotates it) in a way that depends on \
the outcome.\
\>", "Text",ExpressionUUID->"c1803f5b-3fc4-441a-8aaf-6405301d8d8b"],

Cell["Time Evolution: Schrodinger Equation", "Subsection",ExpressionUUID->"e7cfb3a9-04ed-4865-bb18-71888f5f6ae7"],

Cell[TextData[{
 "In quantum mechanics, a pure state is represented by a ket ",
 Cell[BoxData[
  TemplateBox[{
    StyleBox["\[Psi]", "TI"]},
   "Ket"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "91c8facd-d234-43bb-a122-72cadb73712b"],
 ", and measurement probabilities are determined by inner products, e.g. ",
 Cell[BoxData[
  SuperscriptBox[
   RowBox[{
    StyleBox["\[LeftBracketingBar]",
     SpanMinSize->1.9], 
    TemplateBox[{
      StyleBox["\[Phi]", "TI"], 
      StyleBox["\[Psi]", "TI"]},
     "BraKet"], 
    StyleBox["\[RightBracketingBar]",
     SpanMinSize->1.9]}], "2"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "3ffa075a-6242-441c-bf66-e01ad6014a4a"],
 ". For a closed system (no information leaking to an environment), merely \
letting time pass should not change total probability or alter overlaps \
between states, otherwise measurement statistics would not be consistent. We \
therefore require time evolution to preserve norms and inner products: ",
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     RowBox[{
       StyleBox["\[Psi]", "TI"], 
       StyleBox["(", SpanMaxSize -> 1], 
       StyleBox["t", "TI"], 
       StyleBox[")", SpanMaxSize -> 1]}], 
     RowBox[{
       StyleBox["\[Psi]", "TI"], 
       StyleBox["(", SpanMaxSize -> 1], 
       StyleBox["t", "TI"], 
       StyleBox[")", SpanMaxSize -> 1]}]},
    "BraKet"], "=", 
   TemplateBox[{
     RowBox[{
       StyleBox["\[Psi]", "TI"], 
       StyleBox["(", SpanMaxSize -> 1], "0", 
       StyleBox[")", SpanMaxSize -> 1]}], 
     RowBox[{
       StyleBox["\[Psi]", "TI"], 
       StyleBox["(", SpanMaxSize -> 1], "0", 
       StyleBox[")", SpanMaxSize -> 1]}]},
    "BraKet"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "ed76f02d-9fdc-4486-a0d8-00249f3e0ee5"],
 " and ",
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     RowBox[{
       StyleBox["\[Phi]", "TI"], 
       StyleBox["(", SpanMaxSize -> 1], 
       StyleBox["t", "TI"], 
       StyleBox[")", SpanMaxSize -> 1]}], 
     RowBox[{
       StyleBox["\[Psi]", "TI"], 
       StyleBox["(", SpanMaxSize -> 1], 
       StyleBox["t", "TI"], 
       StyleBox[")", SpanMaxSize -> 1]}]},
    "BraKet"], "=", 
   TemplateBox[{
     RowBox[{
       StyleBox["\[Phi]", "TI"], 
       StyleBox["(", SpanMaxSize -> 1], "0", 
       StyleBox[")", SpanMaxSize -> 1]}], 
     RowBox[{
       StyleBox["\[Psi]", "TI"], 
       StyleBox["(", SpanMaxSize -> 1], "0", 
       StyleBox[")", SpanMaxSize -> 1]}]},
    "BraKet"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "f5a685e1-1568-4fea-aa79-68cea3ab69cf"],
 ". The linear maps that preserve inner products are unitary, so the state \
must evolve as ",
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     RowBox[{
       StyleBox["\[Psi]", "TI"], 
       StyleBox["(", SpanMaxSize -> 1], 
       StyleBox["t", "TI"], 
       StyleBox[")", SpanMaxSize -> 1]}]},
    "Ket"], "=", 
   RowBox[{
    StyleBox["U", "TI"], 
    RowBox[{
     StyleBox["(",
      SpanMaxSize->1], 
     StyleBox["t", "TI"], 
     StyleBox[")",
      SpanMaxSize->1]}], 
    TemplateBox[{
      RowBox[{
        StyleBox["\[Psi]", "TI"], 
        StyleBox["(", SpanMaxSize -> 1], "0", 
        StyleBox[")", SpanMaxSize -> 1]}]},
     "Ket"]}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "fb373563-358e-47cd-8962-48fa76b97a2d"],
 " with ",
 Cell[BoxData[
  RowBox[{
   StyleBox["U", "TI"], 
   SuperscriptBox[
    RowBox[{
     StyleBox["(",
      SpanMaxSize->1], 
     StyleBox["t", "TI"], 
     StyleBox[")",
      SpanMaxSize->1]}], "\[Dagger]"], 
   StyleBox["U", "TI"], 
   StyleBox["(",
    SpanMaxSize->1], 
   StyleBox["t", "TI"], 
   StyleBox[")",
    SpanMaxSize->1], "=", "\|01d540"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "ca4e4e6b-926f-41c3-b6ba-74352da81b50"],
 ". This is the first key result: time evolution in an isolated quantum \
system is unitary (we will briefly comment on open systems later)."
}], "Text",ExpressionUUID->"936a830f-441d-4e81-8ca0-51e5aa413f27"],

Cell[TextData[{
 "Next, we assume time evolution is continuous: over a very small time step (",
 Cell[BoxData[
  StyleBox[
   RowBox[{"d", "t"}], "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "ef0257d1-27d9-46b3-a62d-77f02c28ab21"],
 "), the state changes only slightly, so ",
 Cell[BoxData[
  RowBox[{
   StyleBox["U", "TI"], 
   StyleBox["(",
    SpanMaxSize->1], 
   StyleBox[
    RowBox[{"d", "t"}], "TI"], 
   StyleBox[")",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "46ec6545-e576-43b0-9192-3a8ed5daa818"],
 " must be close to the identity. Using the Lie-algebra intuition (as with \
SU(2) and \|01d530\|01d532(2)), the most general form consistent with \
unitarity is ",
 Cell[BoxData[
  RowBox[{
   StyleBox["U", "TI"], 
   StyleBox["(",
    SpanMaxSize->1], 
   StyleBox[
    RowBox[{"d", "t"}], "TI"], 
   StyleBox[")",
    SpanMaxSize->1], "\[TildeTilde]", "\|01d540", "-", 
   StyleBox["i", "TI"], " ", 
   StyleBox["H", "TI"], " ", 
   StyleBox["d", "TI"], 
   StyleBox["t", "TI"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "d70d4d60-79ff-48d8-88cf-6b09e2167cbb"],
 " where ",
 Cell[BoxData[
  StyleBox["H", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "0a7b02b2-fbc5-4e86-ac02-da31c1b82267"],
 " is a Hermitian operator, the infinitesimal generator of unitary evolution. \
Intuitively, ",
 Cell[BoxData[
  StyleBox["H", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "eaf5e0ee-ca31-4c2e-8fa9-f71efbe0bdff"],
 " sets how the state \[OpenCurlyDoubleQuote]turns\[CloseCurlyDoubleQuote] in \
Hilbert space as time flows. It is usually called the Hamiltonian operator, \
which determines the energy of a system."
}], "Text",ExpressionUUID->"dba9aa91-4faf-4a6d-8b05-783b7f554053"],

Cell[TextData[{
 "Finally, we impose the composition law: evolving for time ",
 Cell[BoxData[
  StyleBox["t", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "09ab5b44-aa75-4ff7-a0f0-b77e224ffeb4"],
 " and then for time ",
 Cell[BoxData[
  StyleBox["s", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "47db8fdb-b8d0-4d8d-99eb-94b258ecdda9"],
 " is the same as evolving for time ",
 Cell[BoxData[
  RowBox[{
   StyleBox["t", "TI"], "+", 
   StyleBox["s", "TI"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "7e638046-7c62-4fb0-bfea-e0d0bd0c4e34"],
 ": ",
 Cell[BoxData[
  RowBox[{
   StyleBox["U", "TI"], 
   StyleBox["(",
    SpanMaxSize->1], 
   RowBox[{
    StyleBox["t", "TI"], "+", 
    StyleBox["s", "TI"]}], 
   StyleBox[")",
    SpanMaxSize->1], "=", 
   StyleBox["U", "TI"], 
   StyleBox["(",
    SpanMaxSize->1], 
   StyleBox["t", "TI"], 
   StyleBox[")",
    SpanMaxSize->1], 
   StyleBox["U", "TI"], 
   StyleBox["(",
    SpanMaxSize->1], 
   StyleBox["s", "TI"], 
   StyleBox[")",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "dad71bc2-399f-405b-8019-d223c9e58b5d"],
 ". Applying this with (",
 Cell[BoxData[
  RowBox[{
   StyleBox["s", "TI"], "=", " ", 
   StyleBox["d", "TI"], 
   StyleBox["t", "TI"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "c262e2b8-26be-4970-a806-825416c3bafc"],
 ") gives ",
 Cell[BoxData[
  RowBox[{
   StyleBox["U", "TI"], 
   StyleBox["(",
    SpanMaxSize->1], 
   RowBox[{
    StyleBox["t", "TI"], "+", 
    StyleBox["d", "TI"], 
    StyleBox["t", "TI"]}], 
   StyleBox[")",
    SpanMaxSize->1], "\[TildeTilde]", 
   StyleBox["(",
    SpanMaxSize->1], 
   RowBox[{"\|01d540", "-", 
    StyleBox["i", "TI"], " ", 
    StyleBox["H", "TI"], " ", 
    StyleBox["d", "TI"], 
    StyleBox["t", "TI"]}], 
   StyleBox[")",
    SpanMaxSize->1], 
   StyleBox["U", "TI"], 
   StyleBox["(",
    SpanMaxSize->1], 
   StyleBox["t", "TI"], 
   StyleBox[")",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "062782d3-6918-447d-958a-df314863e4d8"],
 ". Rearranging and taking the limit ",
 Cell[BoxData[
  RowBox[{
   StyleBox["d", "TI"], 
   StyleBox["t", "TI"], "\[Rule]", "0"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "9f4f214d-ab6b-4974-95a8-903c1b748d5c"],
 " yields the differential equation for the propagator, ",
 Cell[BoxData[
  RowBox[{
   StyleBox["d", "TI"], 
   StyleBox["U", "TI"], 
   StyleBox["(",
    SpanMaxSize->1], 
   StyleBox["t", "TI"], 
   StyleBox[")",
    SpanMaxSize->1], "/", 
   StyleBox["d", "TI"], 
   StyleBox["t", "TI"], "=", "-", 
   StyleBox["i", "TI"], " ", 
   StyleBox["H", "TI"], 
   StyleBox["(",
    SpanMaxSize->1], 
   StyleBox["t", "TI"], 
   StyleBox[")",
    SpanMaxSize->1], " ", 
   StyleBox["U", "TI"], 
   StyleBox["(",
    SpanMaxSize->1], 
   StyleBox["t", "TI"], 
   StyleBox[")",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "f62a5d5b-1029-43b6-a12e-25efeefb2c60"],
 ". Note that most of the time, we do not show explicitly the dependency on \
time, and write only a shorter version as ",
 Cell[BoxData[
  RowBox[{
   StyleBox["d", "TI"], 
   StyleBox["U", "TI"], "/", 
   StyleBox["d", "TI"], 
   StyleBox["t", "TI"], "=", "-", 
   StyleBox["i", "TI"], " ", 
   StyleBox["H", "TI"], " ", 
   StyleBox["U", "TI"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "1337a13f-e7d2-40e5-8c68-4bc8cfc1fc19"],
 ". If ",
 Cell[BoxData[
  StyleBox["H", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "baafbec1-6106-4770-86ee-18ce8c372e1d"],
 " is time-independent, the solution is ",
 Cell[BoxData[
  RowBox[{
   StyleBox["U", "TI"], 
   StyleBox["(",
    SpanMaxSize->1], 
   StyleBox["t", "TI"], 
   StyleBox[")",
    SpanMaxSize->1], "=", 
   SuperscriptBox[
    StyleBox["e", "TI"], 
    RowBox[{"-", 
     StyleBox["i", "TI"], " ", 
     StyleBox["H", "TI"], " ", 
     StyleBox["t", "TI"]}]]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "dbcd3134-d9b9-495a-8f44-1cfb338f3202"],
 ". Since ",
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     RowBox[{
       StyleBox["\[Psi]", "TI"], 
       StyleBox["(", SpanMaxSize -> 1], 
       StyleBox["t", "TI"], 
       StyleBox[")", SpanMaxSize -> 1]}]},
    "Ket"], "=", 
   RowBox[{
    StyleBox["U", "TI"], 
    RowBox[{
     StyleBox["(",
      SpanMaxSize->1], 
     StyleBox["t", "TI"], 
     StyleBox[")",
      SpanMaxSize->1]}], 
    TemplateBox[{
      RowBox[{
        StyleBox["\[Psi]", "TI"], 
        StyleBox["(", SpanMaxSize -> 1], "0", 
        StyleBox[")", SpanMaxSize -> 1]}]},
     "Ket"]}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "fc2e662f-e92f-4664-87c4-b759001962d2"],
 ", this immediately implies the time-dependent Schr\[ODoubleDot]dinger \
equation, ",
 Cell[BoxData[
  RowBox[{
   RowBox[{
    StyleBox["i", "TI"], 
    StyleBox["d", "TI"], 
    RowBox[{
     TemplateBox[{
       StyleBox["\[Psi]", "TI"]},
      "Ket"], "/", 
     StyleBox["d", "TI"]}], 
    StyleBox["t", "TI"]}], "=", 
   RowBox[{
    StyleBox["H", "TI"], 
    TemplateBox[{
      StyleBox["\[Psi]", "TI"]},
     "Ket"]}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "f1fb9181-4727-4004-8759-4554474e3c2f"],
 "."
}], "Text",ExpressionUUID->"fc7bea4c-97e5-4236-aa13-a9366853132c"],

Cell[TextData[{
 "Note that for simplicity, we have set ",
 Cell[BoxData["\[HBar]"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "53e7c831-804d-44df-abd8-019b8b2c48ff"],
 " as 1, or equivalently, throughout we make the replacement: ",
 Cell[BoxData[
  RowBox[{
   StyleBox["H", "TI"], "\[Rule]", 
   StyleBox["H", "TI"], "/", "\[HBar]"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "6664197c-9723-4448-8fd9-18724a1605b1"],
 ". The direct consequence is that \[OpenCurlyDoubleQuote]energy\
\[CloseCurlyDoubleQuote] is expressed in units of frequency. The constant ",
 Cell[BoxData["\[HBar]"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "482e1405-5e83-41eb-be34-21b56446a8fa"],
 " is called the reduced Planck constant: ",
 Cell[BoxData[
  RowBox[{"\[HBar]", "=", 
   StyleBox["h", "TI"], "/", "2", "\[Pi]"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "44531181-a860-4a33-ac75-c1230c65b458"],
 " with ",
 Cell[BoxData[
  StyleBox["h", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "082bcc0e-c0ea-4cf5-a3fe-1efc0be8757b"],
 " the Planck constant. This is why the Hamiltonian in our equations carries \
units of frequency rather than energy. It is purely a convention, and one can \
always restore standard energy units by reinstating \[HBar]."
}], "Text",ExpressionUUID->"e43cb73d-6daf-46bd-a28a-fc04898cf03a"],

Cell["Show the value of the reduced Planck constant:", "Text",ExpressionUUID->"7ae94041-9999-490a-bc77-586d622973ae"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"Entity", "[", 
    RowBox[{"\"\<PhysicalConstant\>\"", ",", 
     " ", "\"\<ReducedPlanckConstant\>\""}], "]"}], "[", "\n", "  ", 
   RowBox[{"EntityProperty", "[", 
    RowBox[{"\"\<PhysicalConstant\>\"", ",", " ", "\"\<Value\>\""}], "]"}], 
   "]"}], " ", "//", " ", "N"}]], "Input",
 CellLabel->
  "In[229]:= ",ExpressionUUID->"2da59938-85f3-4f87-b009-589f06ab0645"],

Cell[TextData[{
 "Find the eigenvalues (energy levels) for the Hamiltonian ",
 Cell[BoxData[
  RowBox[{
   StyleBox["H", "TI"], "=", 
   SubscriptBox[
    StyleBox["\[Omega]", "TI"], 
    StyleBox["x", "TI"]], 
   SubscriptBox[
    StyleBox["\[Sigma]", "TI"], 
    StyleBox["x", "TI"]]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "c4cb789f-41b9-4d54-a6e6-152af810b939"],
 ":"
}], "Text",ExpressionUUID->"0c12918b-1491-48a0-9909-83576fa73f0a"],

Cell[BoxData[{
 RowBox[{"ClearAll", "[", "\[Omega]x", "]"}], "\n", 
 RowBox[{"Eigenvalues", "[", 
  RowBox[{"\[Omega]x", " ", 
   RowBox[{"PauliMatrix", "[", "1", "]"}]}], "]"}]}], "Input",
 CellLabel->
  "In[230]:= ",ExpressionUUID->"89b61b83-2167-47e6-80e1-e97a53241d7f"],

Cell[TextData[{
 "As we can see, the energy difference between the two eigenlevels (the level \
splitting) is ",
 Cell[BoxData[
  RowBox[{"2", 
   SubscriptBox[
    StyleBox["\[Omega]", "TI"], 
    StyleBox["x", "TI"]]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "0c57c47a-e8d3-47f4-878b-54c49b1b7f4b"],
 ". A more convenient convention for the Hamiltonian is to write it as ",
 Cell[BoxData[
  RowBox[{
   StyleBox["H", "TI"], "=", "1", "/", "2", 
   SubscriptBox[
    StyleBox["\[Omega]", "TI"], 
    StyleBox["x", "TI"]], 
   SubscriptBox[
    StyleBox["\[Sigma]", "TI"], 
    StyleBox["x", "TI"]]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "e1d9e895-cd02-460e-a4d4-434a3679963a"],
 ", so that ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["\[Omega]", "TI"], 
   StyleBox["x", "TI"]]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "4e0169a8-85e8-4370-beaa-4b39a2be22aa"],
 " directly denotes the frequency associated with the level splitting."
}], "Text",ExpressionUUID->"459ae8ef-7dc1-4900-b849-3de855598dce"],

Cell[TextData[{
 "Solve the propagator equation ",
 Cell[BoxData[
  RowBox[{
   StyleBox["d", "TI"], 
   StyleBox["U", "TI"], "/", 
   StyleBox["d", "TI"], 
   StyleBox["t", "TI"], "=", "-", 
   StyleBox["i", "TI"], " ", 
   SubscriptBox[
    StyleBox["\[Omega]", "TI"], 
    StyleBox["x", "TI"]], "/", "2", " ", 
   SubscriptBox[
    StyleBox["\[Sigma]", "TI"], 
    StyleBox["x", "TI"]], 
   StyleBox["U", "TI"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "240b853b-79a9-4aeb-9291-8173cb63a0ab"],
 " for the Hamiltonian ",
 Cell[BoxData[
  RowBox[{
   StyleBox["H", "TI"], "=", "1", "/", "2", 
   SubscriptBox[
    StyleBox["\[Omega]", "TI"], 
    StyleBox["x", "TI"]], 
   SubscriptBox[
    StyleBox["\[Sigma]", "TI"], 
    StyleBox["x", "TI"]]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "b3c51793-1635-4b3d-bcb4-fb506b454509"],
 ":"
}], "Text",ExpressionUUID->"53b85b47-adf3-44d5-a56b-d42552cc5cc0"],

Cell[BoxData[{
 RowBox[{"ClearAll", "[", 
  RowBox[{"u", ",", " ", "\[Omega]x", ",", " ", "t"}], "]"}], "\n", 
 RowBox[{
  RowBox[{"DSolveValue", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{"u", "'"}], "[", "t", "]"}], " ", "==", " ", 
       RowBox[{
        RowBox[{"-", "I"}], " ", 
        RowBox[{"\[Omega]x", "/", "2"}], " ", 
        RowBox[{
         RowBox[{"PauliMatrix", "[", "1", "]"}], " ", ".", " ", 
         RowBox[{"u", "[", "t", "]"}]}]}]}], ",", " ", "\n", "   ", 
      RowBox[{
       RowBox[{"u", "[", "0", "]"}], " ", "==", " ", 
       RowBox[{"IdentityMatrix", "[", "2", "]"}]}]}], "}"}], ",", " ", 
    RowBox[{
     RowBox[{"u", "[", "t", "]"}], " ", "\[Element]", " ", 
     RowBox[{"Matrices", "[", 
      RowBox[{"{", 
       RowBox[{"2", ",", " ", "2"}], "}"}], "]"}]}], ",", " ", "\n", "  ", 
    "t"}], "]"}], " ", "//", " ", "MatrixForm"}]}], "Input",
 CellLabel->
  "In[231]:= ",ExpressionUUID->"fb612c54-75a9-420a-ae1c-01c4b85967ac"],

Cell[TextData[{
 "Verify that this solution agrees with the exponential form ",
 Cell[BoxData[
  SuperscriptBox[
   StyleBox["e", "TI"], 
   RowBox[{"-", 
    StyleBox["i", "TI"], " ", 
    SubscriptBox[
     StyleBox["\[Omega]", "TI"], 
     StyleBox["x", "TI"]], "/", "2", 
    SubscriptBox[
     StyleBox["\[Sigma]", "TI"], 
     StyleBox["x", "TI"]], 
    StyleBox["t", "TI"]}]]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "f244e4c1-abf9-4d53-98fb-e76965dc4df1"],
 " since the Hamiltonian ",
 Cell[BoxData[
  StyleBox["H", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "c4c75f7c-1862-4a7d-a440-735f7132ebc3"],
 " is time-independent:"
}], "Text",ExpressionUUID->"a9084270-7930-48a8-a8f8-8c20526ae927"],

Cell[BoxData[{
 RowBox[{"ClearAll", "[", 
  RowBox[{"u", ",", " ", "\[Omega]x", ",", " ", "t"}], "]"}], "\n", 
 RowBox[{"With", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"u", " ", "=", " ", "\n", "   ", 
     RowBox[{"DSolveValue", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{
          RowBox[{
           RowBox[{"u", "'"}], "[", "t", "]"}], " ", "==", " ", 
          RowBox[{
           RowBox[{"-", "I"}], " ", 
           RowBox[{"\[Omega]x", "/", "2"}], " ", 
           RowBox[{
            RowBox[{"PauliMatrix", "[", "1", "]"}], " ", ".", " ", 
            RowBox[{"u", "[", "t", "]"}]}]}]}], ",", " ", "\n", "     ", 
         RowBox[{
          RowBox[{"u", "[", "0", "]"}], " ", "==", " ", 
          RowBox[{"IdentityMatrix", "[", "2", "]"}]}]}], "}"}], ",", " ", 
       RowBox[{
        RowBox[{"u", "[", "t", "]"}], " ", "\[Element]", " ", 
        RowBox[{"Matrices", "[", 
         RowBox[{"{", 
          RowBox[{"2", ",", " ", "2"}], "}"}], "]"}]}], ",", " ", "t"}], 
      "]"}]}], "}"}], ",", "\n", "  ", 
   RowBox[{"u", " ", "==", " ", 
    RowBox[{"MatrixExp", "[", 
     RowBox[{
      RowBox[{"-", "I"}], " ", 
      RowBox[{"\[Omega]x", "/", "2"}], " ", 
      RowBox[{"PauliMatrix", "[", "1", "]"}], " ", "t"}], "]"}]}]}], 
  "]"}]}], "Input",
 CellLabel->
  "In[232]:= ",ExpressionUUID->"5f1af3b6-02e9-4e66-a430-1ca994e09870"],

Cell[TextData[{
 "Given the propagator in above example, ",
 Cell[BoxData[
  RowBox[{
   StyleBox["U", "TI"], 
   StyleBox["(",
    SpanMaxSize->1], 
   StyleBox["t", "TI"], 
   StyleBox[")",
    SpanMaxSize->1], "=", 
   SuperscriptBox[
    StyleBox["e", "TI"], 
    RowBox[{"-", 
     StyleBox["i", "TI"], " ", 
     SubscriptBox[
      StyleBox["\[Omega]", "TI"], 
      StyleBox["x", "TI"]], "/", "2", 
     SubscriptBox[
      StyleBox["\[Sigma]", "TI"], 
      StyleBox["x", "TI"]], 
     StyleBox["t", "TI"]}]]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "4e8a9be6-0e2d-4e55-bd31-e4339f8a1f15"],
 ", one can find the corresponding rotation in SO(3) ",
 Cell[BoxData[
  RowBox[{
   SubscriptBox["\[ScriptCapitalR]", 
    StyleBox["z", "TI"]], 
   StyleBox["(",
    SpanMaxSize->1], 
   RowBox[{
    SubscriptBox[
     StyleBox["\[Omega]", "TI"], 
     StyleBox["x", "TI"]], 
    StyleBox["t", "TI"]}], 
   StyleBox[")",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "e8101234-b480-4159-a1f3-dc685baac66c"],
 ". The Bloch vector evolves under the rotation as ",
 Cell[BoxData[
  RowBox[{
   OverscriptBox[
    StyleBox["r", "TI"], "\[RightVector]"], 
   StyleBox["(",
    SpanMaxSize->1], 
   StyleBox["t", "TI"], 
   StyleBox[")",
    SpanMaxSize->1], "=", 
   SubscriptBox["\[ScriptCapitalR]", 
    StyleBox["z", "TI"]], 
   StyleBox["(",
    SpanMaxSize->1], 
   RowBox[{
    SubscriptBox[
     StyleBox["\[Omega]", "TI"], 
     StyleBox["x", "TI"]], 
    StyleBox["t", "TI"]}], 
   StyleBox[")",
    SpanMaxSize->1], 
   OverscriptBox[
    StyleBox["r", "TI"], "\[RightVector]"], 
   StyleBox["(",
    SpanMaxSize->1], "0", 
   StyleBox[")",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "cd22865b-2ab2-4387-8a7f-2d3c428cee1e"],
 "."
}], "Text",ExpressionUUID->"95d7087f-78fa-41ef-a08e-e9d03c45024d"],

Cell[TextData[{
 "Compute ",
 Cell[BoxData[
  RowBox[{
   SubscriptBox["\[ScriptCapitalR]", 
    StyleBox["z", "TI"]], 
   StyleBox["(",
    SpanMaxSize->1], 
   RowBox[{
    SubscriptBox[
     StyleBox["\[Omega]", "TI"], 
     StyleBox["x", "TI"]], 
    StyleBox["t", "TI"]}], 
   StyleBox[")",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "472d8007-ddce-4a94-9ac6-c94ac3f6a675"],
 ":"
}], "Text",ExpressionUUID->"aae4ec22-1554-43b2-8913-1e202a5b7373"],

Cell[BoxData[
 RowBox[{
  RowBox[{"RotationMatrix", "[", 
   RowBox[{
    RowBox[{"\[Omega]x", " ", "t"}], ",", " ", 
    RowBox[{"{", 
     RowBox[{"1", ",", " ", "0", ",", " ", "0"}], "}"}]}], "]"}], " ", "//", 
  " ", "MatrixForm"}]], "Input",
 CellLabel->
  "In[233]:= ",ExpressionUUID->"33ecf9b3-e6a9-44b1-8f9b-f5c1f8c57cc4"],

Cell[TextData[{
 "Given ",
 Cell[BoxData[
  RowBox[{
   SubscriptBox["\[ScriptCapitalR]", 
    StyleBox["z", "TI"]], 
   StyleBox["(",
    SpanMaxSize->1], 
   RowBox[{
    SubscriptBox[
     StyleBox["\[Omega]", "TI"], 
     StyleBox["x", "TI"]], 
    StyleBox["t", "TI"]}], 
   StyleBox[")",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "d470ee41-e0e8-42cb-a276-c217c29430a7"],
 ", calculate the time-dependent formula for the Bloch vector when it is \
initially prepared at ",
 Cell[BoxData[
  RowBox[{
   RowBox[{
    OverscriptBox[
     StyleBox["r", "TI"], "\[RightVector]"], 
    StyleBox["(",
     SpanMaxSize->1], "0", 
    StyleBox[")",
     SpanMaxSize->1], "=", "{", "0"}], ",", "0", ",", 
   RowBox[{"1", "}"}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "ff3557ec-e1d7-43fd-92de-5a470036e532"],
 " (corresponding to ",
 Cell[BoxData[
  TemplateBox[{"0"},
   "Ket"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "f7497465-5865-44af-846d-718848b956b4"],
 "):"
}], "Text",ExpressionUUID->"aad4f066-d18a-41f4-8ac7-266ae6639d93"],

Cell[BoxData[
 RowBox[{
  RowBox[{"RotationMatrix", "[", 
   RowBox[{
    RowBox[{"\[Omega]x", " ", "t"}], ",", " ", 
    RowBox[{"{", 
     RowBox[{"1", ",", " ", "0", ",", " ", "0"}], "}"}]}], "]"}], " ", ".", 
  " ", 
  RowBox[{"{", 
   RowBox[{"0", ",", " ", "0", ",", " ", "1"}], "}"}]}]], "Input",
 CellLabel->
  "In[234]:= ",ExpressionUUID->"9a404e7e-064b-4cb1-a50a-5315ec0eebbc"],

Cell[TextData[{
 "For initial state ",
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     RowBox[{
       StyleBox["\[Psi]", "TI"], 
       StyleBox["(", SpanMaxSize -> 1], "0", 
       StyleBox[")", SpanMaxSize -> 1]}]},
    "Ket"], "=", 
   TemplateBox[{"0"},
    "Ket"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "70433adb-7854-4e6a-88e9-9a11794e1de1"],
 " and the Hamiltonian ",
 Cell[BoxData[
  RowBox[{
   StyleBox["H", "TI"], "=", "1", "/", "2", 
   SubscriptBox[
    StyleBox["\[Omega]", "TI"], 
    StyleBox["x", "TI"]], 
   SubscriptBox[
    StyleBox["\[Sigma]", "TI"], 
    StyleBox["x", "TI"]]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "a0771103-f451-4f15-8166-7ecdc1e24013"],
 ", calculate the time-evolved state ",
 Cell[BoxData[
  TemplateBox[{
    RowBox[{
      StyleBox["\[Psi]", "TI"], 
      StyleBox["(", SpanMaxSize -> 1], 
      StyleBox["t", "TI"], 
      StyleBox[")", SpanMaxSize -> 1]}]},
   "Ket"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "4e171b6d-b2ac-408b-a5bc-f4c63512a344"],
 " as ",
 Cell[BoxData[
  RowBox[{
   SuperscriptBox[
    StyleBox["e", "TI"], 
    RowBox[{"-", 
     StyleBox["i", "TI"], " ", 
     StyleBox["H", "TI"], " ", 
     StyleBox["t", "TI"]}]], 
   TemplateBox[{
     RowBox[{
       StyleBox["\[Psi]", "TI"], 
       StyleBox["(", SpanMaxSize -> 1], "0", 
       StyleBox[")", SpanMaxSize -> 1]}]},
    "Ket"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "9fb677fc-b278-44f2-b0f0-360cb86de6c6"],
 ":"
}], "Text",ExpressionUUID->"6013502e-ac65-480c-a0ed-a3308eca6a23"],

Cell[BoxData[
 RowBox[{"MatrixExp", "[", 
  RowBox[{
   RowBox[{
    RowBox[{"-", "I"}], " ", 
    RowBox[{"\[Omega]x", "/", "2"}], " ", 
    RowBox[{"PauliMatrix", "[", "1", "]"}], " ", "t"}], ",", " ", 
   RowBox[{"{", 
    RowBox[{"1", ",", " ", "0"}], "}"}]}], "]"}]], "Input",
 CellLabel->
  "In[235]:= ",ExpressionUUID->"ee816136-54c5-4b4c-bfed-577017521f84"],

Cell["\<\
Calculate the Bloch vector corresponding to the above solution:\
\>", "Text",ExpressionUUID->"7e549018-078b-44cc-bc7d-5b5d7d273cd3"],

Cell[BoxData[
 RowBox[{"FullSimplify", "[", "\n", " ", 
  RowBox[{
   RowBox[{"BlochVector", "[", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"Cos", "[", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{"t", " ", "\[Omega]x"}], ")"}], "/", "\n", "    ", "2"}], 
       "]"}], ",", " ", 
      RowBox[{
       RowBox[{"-", "I"}], " ", 
       RowBox[{"Sin", "[", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{"t", " ", "\[Omega]x"}], ")"}], "/", "2"}], "]"}]}]}], 
     "}"}], "]"}], ",", " ", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{"t", " ", "|", " ", "\[Omega]x"}], ")"}], " ", "\[Element]", " ",
     "Reals"}]}], "]"}]], "Input",
 CellLabel->
  "In[236]:= ",ExpressionUUID->"d1c437fc-3435-4b49-bd54-a51e9bb12c2e"],

Cell["\<\
As expected, the Bloch vector computed via the SU(2) unitary evolution agrees \
exactly with the result obtained from the corresponding SO(3) rotation.\
\>", "Text",ExpressionUUID->"9c2e848e-c0b8-45e9-a7c5-bb543563cb05"],

Cell[TextData[{
 "Visualize the Bloch-vector trajectory for ",
 Cell[BoxData[
  RowBox[{
   StyleBox["H", "TI"], "=", "1", "/", "2", 
   SubscriptBox[
    StyleBox["\[Omega]", "TI"], 
    StyleBox["x", "TI"]], 
   SubscriptBox[
    StyleBox["\[Sigma]", "TI"], 
    StyleBox["x", "TI"]]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "f52f0b0e-f7f4-4414-bf5d-0728a72358df"],
 " and ",
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     RowBox[{
       StyleBox["\[Psi]", "TI"], 
       StyleBox["(", SpanMaxSize -> 1], "0", 
       StyleBox[")", SpanMaxSize -> 1]}]},
    "Ket"], "=", 
   TemplateBox[{"0"},
    "Ket"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "e682445d-7164-4408-928a-eb7a1a0e306f"],
 ":"
}], "Text",ExpressionUUID->"5e8959bd-d453-44d7-b29f-82a01df58670"],

Cell[BoxData[
 RowBox[{"Manipulate", "[", "\n", " ", 
  RowBox[{
   RowBox[{"Show", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"ResourceFunction", "[", "\"\<BlochSpherePlot\>\"", "]"}], "[", 
      
      RowBox[{
       RowBox[{"{", 
        RowBox[{"0", ",", " ", 
         RowBox[{"-", 
          RowBox[{"Sin", "[", "t", "]"}]}], ",", " ", "\n", "    ", 
         RowBox[{"Cos", "[", "t", " ", "]"}]}], "}"}], ",", " ", "\n", "   ", 
       
       RowBox[{"PlotLabel", " ", "->", " ", "\n", "    ", 
        RowBox[{"\"\<Rotation angle is Subscript[\[Omega], x] t = \>\"", " ", 
         "<>", " ", "\n", "     ", 
         RowBox[{"ToString", "[", 
          RowBox[{"t", "/", "\[Pi]"}], "]"}], " ", "<>", 
         " ", "\"\<\[Pi]\>\""}]}], ",", " ", 
       RowBox[{"ImageSize", " ", "->", " ", "200"}]}], "]"}], ",", " ", "\n", 
     "  ", 
     RowBox[{"Graphics3D", "[", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"Opacity", "[", ".5", "]"}], ",", " ", 
        RowBox[{
         RowBox[{"ColorData", "[", "97", "]"}], "[", "2", "]"}], ",", " ", 
        "\n", "    ", 
        RowBox[{"Polygon", "[", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{"0", ",", " ", "0", ",", " ", "0"}], "}"}], ",", " ", 
           RowBox[{
            RowBox[{"{", 
             RowBox[{"0", ",", " ", "0", ",", " ", "1"}], "}"}], "/", "2"}], ",",
            " ", "\n", "      ", 
           RowBox[{"Sequence", " ", "@@", " ", "\n", "       ", 
            RowBox[{"Table", "[", 
             RowBox[{
              RowBox[{
               RowBox[{"{", 
                RowBox[{"0", ",", " ", 
                 RowBox[{"-", 
                  RowBox[{"Sin", "[", "\[Theta]", "]"}]}], ",", " ", 
                 RowBox[{"Cos", "[", "\[Theta]", " ", "]"}]}], "}"}], "/", 
               "2"}], ",", " ", 
              RowBox[{"{", 
               RowBox[{"\[Theta]", ",", " ", "\n", "         ", 
                RowBox[{"Range", "[", 
                 RowBox[{"0", ",", " ", "t", ",", " ", 
                  RowBox[{"t", "/", "100"}]}], "]"}]}], "}"}]}], "]"}]}]}], 
          "}"}], "]"}]}], "}"}], "]"}], ",", " ", 
     RowBox[{"Boxed", " ", "->", " ", "False"}]}], "]"}], ",", " ", "\n", " ", 
   RowBox[{
   "Item", "[", "\"\<Bloch-vector trajectory for \
H=\\!\\(\\*FractionBox[\\(1\\), \
\\(2\\)]\\)\\!\\(\\*SubscriptBox[\\(\[Omega]\\), \
\\(x\\)]\\)\\!\\(\\*SubscriptBox[\\(\[Sigma]\\), \\(x\\)]\\)\>\"", "]"}], ",",
    " ", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
      "t", ",", " ", "0", ",", " ", "\n", 
       "   ", "\"\<\\!\\(\\*SubscriptBox[\\(\[Omega]\\), \\(x\\)]\\)t\>\""}], 
      "}"}], ",", " ", "0", ",", " ", 
     RowBox[{"2", " ", "\[Pi]"}]}], "}"}]}], "]"}]], "Input",
 CellLabel->
  "In[237]:= ",ExpressionUUID->"a3050311-1601-476b-8424-16ac080e8c51"],

Cell[TextData[{
 "As time evolves, the Bloch vector traces out a rotation about the ",
 Cell[BoxData[
  StyleBox["x", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "37a60a11-c733-40d2-8fa9-ab0ff1f058f0"],
 "-axis, with a rotation angle that grows with time as ",
 Cell[BoxData[
  RowBox[{
   SubscriptBox[
    StyleBox["\[Omega]", "TI"], 
    StyleBox["x", "TI"]], 
   StyleBox["t", "TI"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "3ee02986-8720-4993-9ad8-989cdf28a0c4"],
 ". The frequency ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["\[Omega]", "TI"], 
   StyleBox["x", "TI"]]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "14012d59-e0de-4379-ba6d-53ed1d1fe9c4"],
 " in this context is usually called the Rabi frequency."
}], "Text",ExpressionUUID->"e388fee6-4799-4998-8cf8-862d07232114"],

Cell["Time Evolution: Stationary States", "Subsection",ExpressionUUID->"f273304d-9431-4ae1-84a7-ee7997aaf69e"],

Cell[TextData[{
 "Solve Schrodinger equation explicitly for with Hamiltonian ",
 Cell[BoxData[
  RowBox[{
   StyleBox["H", "TI"], "=", "1", "/", "2", 
   SubscriptBox[
    StyleBox["\[Omega]", "TI"], 
    StyleBox["x", "TI"]], 
   SubscriptBox[
    StyleBox["\[Sigma]", "TI"], 
    StyleBox["x", "TI"]]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "fec9e50c-78c9-4fa0-a93e-d47c5294e33a"],
 " and the initial state ",
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     RowBox[{
       StyleBox["\[Psi]", "TI"], 
       StyleBox["(", SpanMaxSize -> 1], "0", 
       StyleBox[")", SpanMaxSize -> 1]}]},
    "Ket"], "=", 
   RowBox[{
    RowBox[{
     SubscriptBox[
      StyleBox["c", "TI"], "0"], 
     TemplateBox[{"0"},
      "Ket"]}], "+", 
    RowBox[{
     SubscriptBox[
      StyleBox["c", "TI"], "1"], 
     TemplateBox[{"1"},
      "Ket"]}]}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "2f8538d2-0a83-4fa7-a265-a34d95ab751f"],
 ":"
}], "Text",ExpressionUUID->"a67e0e9f-b109-40ca-8773-304c98a1cba2"],

Cell[BoxData[{
 RowBox[{"ClearAll", "[", 
  RowBox[{
  "\[Psi]", ",", " ", "\[Omega]x", ",", " ", "\[Omega]y", ",", " ", 
   "\[Omega]z", ",", " ", "c", ",", " ", "t"}], "]"}], "\n", 
 RowBox[{
  RowBox[{"DSolveValue", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{
       RowBox[{"I", " ", 
        RowBox[{
         RowBox[{"\[Psi]", "'"}], "[", "t", "]"}]}], " ", "==", " ", 
       RowBox[{
        RowBox[{"\[Omega]x", "/", "\n", "      ", "2"}], " ", 
        RowBox[{
         RowBox[{"PauliMatrix", "[", "1", "]"}], " ", ".", " ", 
         RowBox[{"\[Psi]", "[", "t", "]"}]}]}]}], ",", " ", 
      RowBox[{
       RowBox[{"\[Psi]", "[", "0", "]"}], " ", "==", " ", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"Subscript", "[", 
          RowBox[{"c", ",", " ", "0"}], "]"}], ",", " ", "\n", "     ", 
         RowBox[{"Subscript", "[", 
          RowBox[{"c", ",", " ", "1"}], "]"}]}], "}"}]}]}], "}"}], ",", " ", 
    RowBox[{
     RowBox[{"\[Psi]", "[", "t", "]"}], " ", "\[Element]", " ", 
     RowBox[{"Vectors", "[", "2", "]"}]}], ",", " ", "\n", "  ", "t"}], "]"}],
   " ", "//", " ", "FullSimplify"}]}], "Input",
 CellLabel->
  "In[238]:= ",ExpressionUUID->"41e26612-1321-4ead-af9b-f0097ee9a841"],

Cell[TextData[{
 "From the expression above, we can identify special choices of ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["c", "TI"], "0"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "65e31d17-c55e-466d-946c-8dc719d4d069"],
 " and ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["c", "TI"], "1"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "8a04248d-7ddd-4659-9289-4634beb1fb1a"],
 " for which the apparent time dependence reduces to a pure global phase. In \
those cases, the state\[CloseCurlyQuote]s physical content does not change in \
time. Let\[CloseCurlyQuote]s examine these cases more carefully."
}], "Text",ExpressionUUID->"11ef3c76-38bd-4275-8710-ef6907c6ebdb"],

Cell["\<\
The qubit\[CloseCurlyQuote]s time evolution affects measurement outcomes \
directly: as the state rotates, the measurement probabilities generally \
become time-dependent and can vary in a measurable way.\
\>", "Text",ExpressionUUID->"fa131fa5-3835-4f6d-9cda-c045687e5f66"],

Cell[TextData[{
 "For different initial state with the Hamiltonian ",
 Cell[BoxData[
  RowBox[{
   StyleBox["H", "TI"], "=", "1", "/", "2", 
   SubscriptBox[
    StyleBox["\[Omega]", "TI"], 
    StyleBox["x", "TI"]], 
   SubscriptBox[
    StyleBox["\[Sigma]", "TI"], 
    StyleBox["x", "TI"]]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "72dff443-5eb3-45c5-b21b-37d471f9c2f4"],
 ", visualize probabilities of getting 0 and 1 in time:"
}], "Text",ExpressionUUID->"41e7cc6f-0813-438f-9212-bc8b2c2fc100"],

Cell[BoxData[
 RowBox[{"Manipulate", "[", "\n", " ", 
  RowBox[{
   RowBox[{
    RowBox[{"prob", " ", "=", " ", 
     RowBox[{
      RowBox[{"Abs", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{
            RowBox[{"Cos", "[", 
             RowBox[{
              RowBox[{"(", 
               RowBox[{"t", " ", "\[Omega]x"}], ")"}], "/", "\n", "        ", 
              "2"}], "]"}], ",", " ", 
            RowBox[{
             RowBox[{"-", "I"}], " ", 
             RowBox[{"Sin", "[", 
              RowBox[{
               RowBox[{"(", 
                RowBox[{"t", " ", "\[Omega]x"}], ")"}], "/", "2"}], "]"}]}]}],
            "}"}], ",", " ", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{
             RowBox[{"-", "I"}], " ", 
             RowBox[{"Sin", "[", 
              RowBox[{
               RowBox[{"(", 
                RowBox[{"t", " ", "\[Omega]x"}], ")"}], "/", "2"}], "]"}]}], ",",
             " ", "\n", "       ", 
            RowBox[{"Cos", "[", 
             RowBox[{
              RowBox[{"(", 
               RowBox[{"t", " ", "\[Omega]x"}], ")"}], "/", "2"}], "]"}]}], 
           "}"}]}], "}"}], " ", ".", " ", "state"}], "]"}], "^", "2"}]}], ";",
     "\n", " ", 
    RowBox[{"Plot", "[", 
     RowBox[{"prob", ",", " ", 
      RowBox[{"{", 
       RowBox[{"t", ",", " ", "0", ",", " ", "10"}], "}"}], ",", " ", "\n", 
      "  ", 
      RowBox[{"PlotLegends", " ", "->", " ", "\n", "   ", 
       RowBox[{"Placed", "[", 
        RowBox[{
         RowBox[{"{", 
          
          RowBox[{"\"\<Probabilty of getting 0\>\"", ",", 
           " ", "\"\<Probabilty of getting 1\>\""}], "}"}], ",", " ", "\n", 
         "    ", "Below"}], "]"}]}], ",", " ", 
      RowBox[{"AxesLabel", " ", "->", " ", 
       RowBox[{"{", 
        RowBox[{"\"\<Time\>\"", ",", " ", "\"\<Prob.\>\""}], "}"}]}], ",", 
      " ", "\n", "  ", 
      RowBox[{"GridLines", " ", "->", " ", "Automatic"}]}], "]"}]}], ",", " ", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
      "\[Omega]x", ",", " ", "1", ",", " ", "\n", 
       "   ", "\"\<Frequency \\!\\(\\*SubscriptBox[\\(\[Omega]\\), \
\\(x\\)]\\) in \\\nH=\\!\\(\\*FractionBox[\\(1\\), \
\\(2\\)]\\)\\!\\(\\*SubscriptBox[\\(\[Omega]\\), \\\n\
\\(x\\)]\\)\\!\\(\\*SubscriptBox[\\(\[Sigma]\\), \\(x\\)]\\) \>\""}], "}"}], ",",
      " ", "1", ",", " ", "\n", "  ", "10"}], "}"}], ",", " ", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"state", ",", " ", 
       RowBox[{"{", 
        RowBox[{"1", ",", " ", "0"}], "}"}], ",", " ", "\n", 
       "   ", "\"\<Initial State\>\""}], "}"}], ",", " ", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{
        RowBox[{"{", 
         RowBox[{"1", ",", " ", "0"}], "}"}], " ", "->", " ", "\n", 
        "    ", "\"\<\\!\\(\\*TemplateBox[{\\\"0\\\"},\\n\\\"Ket\\\"]\\)\>\""}\
], ",", " ", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"0", ",", " ", "1"}], "}"}], " ", "->", " ", "\n", 
        "    ", "\"\<\\!\\(\\*TemplateBox[{\\\"1\\\"},\\n\\\"Ket\\\"]\\)\>\""}\
], ",", " ", 
       RowBox[{
        RowBox[{
         RowBox[{"{", 
          RowBox[{"1", ",", " ", "1"}], "}"}], "/", 
         RowBox[{"Sqrt", "[", "2", "]"}]}], " ", "->", " ", "\n", 
        "    ", "\"\<\\!\\(\\*TemplateBox[{\\nSubscriptBox[\\\"x\\\", \\\"+\\\
\"]},\\n\\\"Ket\\\"]\\)\>\""}], ",", " ", 
       RowBox[{
        RowBox[{
         RowBox[{"\\\n", 
          RowBox[{"{", 
           RowBox[{"1", ",", " ", 
            RowBox[{"-", "1"}]}], "}"}]}], "/", 
         RowBox[{"Sqrt", "[", "2", "]"}]}], " ", "->", " ", "\n", 
        "    ", "\"\<\\!\\(\\*TemplateBox[{\\nSubscriptBox[\\\"x\\\", \\\"-\\\
\"]},\\n\\\"Ket\\\"]\\)\>\""}], ",", " ", 
       RowBox[{
        RowBox[{
         RowBox[{"\\\n", 
          RowBox[{"{", 
           RowBox[{"1", ",", " ", "I"}], "}"}]}], "/", 
         RowBox[{"Sqrt", "[", "2", "]"}]}], " ", "->", " ", "\n", 
        "    ", "\"\<\\!\\(\\*TemplateBox[{\\nSubscriptBox[\\\"y\\\", \\\"+\\\
\"]},\\n\\\"Ket\\\"]\\)\>\""}], ",", " ", 
       RowBox[{
        RowBox[{
         RowBox[{"\\\n", 
          RowBox[{"{", 
           RowBox[{"1", ",", " ", 
            RowBox[{"-", "I"}]}], "}"}]}], "/", 
         RowBox[{"Sqrt", "[", "2", "]"}]}], " ", "->", " ", "\n", 
        "    ", "\"\<\\!\\(\\*TemplateBox[{\\nSubscriptBox[\\\"y\\\", \\\"-\\\
\"]},\\n\\\"Ket\\\"]\\)\>\""}]}], "}"}], ",", " ", "\n", "  ", "SetterBar"}], 
    "}"}], ",", " ", 
   RowBox[{"SaveDefinitions", " ", "->", " ", "True"}]}], "]"}]], "Input",
 CellLabel->
  "In[239]:= ",ExpressionUUID->"dc252f14-e24f-4c4c-9a00-8e9612180c0d"],

Cell[TextData[{
 "As you may have noticed, the probabilities remain flat (time-independent) \
if the initial state is chosen to be ",
 Cell[BoxData[
  TemplateBox[{
    SubscriptBox[
     StyleBox["x", "TI"], "\[PlusMinus]"]},
   "Ket"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "88ced631-0405-4ddd-b16f-b311060d25a4"],
 ". In other words, with the initial state ",
 Cell[BoxData[
  TemplateBox[{
    SubscriptBox[
     StyleBox["x", "TI"], "\[PlusMinus]"]},
   "Ket"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "33be251f-b7fe-44e3-b952-0294668f0211"],
 ", the evolution by the Hamiltonian ",
 Cell[BoxData[
  RowBox[{
   StyleBox["H", "TI"], "=", "1", "/", "2", 
   SubscriptBox[
    StyleBox["\[Omega]", "TI"], 
    StyleBox["x", "TI"]], 
   SubscriptBox[
    StyleBox["\[Sigma]", "TI"], 
    StyleBox["x", "TI"]]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "27c92bc0-83c0-43cd-8158-1ec69a8318c6"],
 " introduces no observable effects. Let\[CloseCurlyQuote]s explore that in \
more detail."
}], "Text",ExpressionUUID->"8aab75d1-a77b-40a7-941d-154554a295b0"],

Cell[TextData[{
 "For the initial state ",
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     RowBox[{
       StyleBox["\[Psi]", "TI"], 
       StyleBox["(", SpanMaxSize -> 1], "0", 
       StyleBox[")", SpanMaxSize -> 1]}]},
    "Ket"], "=", 
   TemplateBox[{
     SubscriptBox[
      StyleBox["x", "TI"], "+"]},
    "Ket"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "3584e5f9-d458-444a-a451-771532f3432a"],
 " and the Hamiltonian ",
 Cell[BoxData[
  RowBox[{
   StyleBox["H", "TI"], "=", "1", "/", "2", 
   SubscriptBox[
    StyleBox["\[Omega]", "TI"], 
    StyleBox["x", "TI"]], 
   SubscriptBox[
    StyleBox["\[Sigma]", "TI"], 
    StyleBox["x", "TI"]]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "51d38e6d-d81b-4196-a14f-1b5afff428ae"],
 ", calculate the time-evolved state:"
}], "Text",ExpressionUUID->"487d2687-2258-47d0-98b8-eeebc23257f0"],

Cell[BoxData[
 RowBox[{
  RowBox[{"MatrixExp", "[", 
   RowBox[{
    RowBox[{
     RowBox[{"-", "I"}], " ", 
     RowBox[{"\[Omega]x", "/", "2"}], " ", 
     RowBox[{"PauliMatrix", "[", "1", "]"}], " ", "t"}], ",", " ", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"1", ",", " ", "1"}], "}"}], "/", 
     RowBox[{"Sqrt", "[", "\n", "   ", "2", "]"}]}]}], "]"}], " ", "//", " ", 
  "FullSimplify"}]], "Input",
 CellLabel->
  "In[240]:= ",ExpressionUUID->"86eecc67-eab4-438e-b353-e8b63475fd91"],

Cell[TextData[{
 "As you may notice, because the initial state is an eigenstate of the \
Hamiltonian (",
 Cell[BoxData[
  RowBox[{
   RowBox[{
    RowBox[{"1", "/", "2"}], 
    SubscriptBox[
     StyleBox["\[Omega]", "TI"], 
     StyleBox["x", "TI"]], 
    SubscriptBox[
     StyleBox["\[Sigma]", "TI"], 
     StyleBox["x", "TI"]], 
    TemplateBox[{
      SubscriptBox[
       StyleBox["x", "TI"], "+"]},
     "Ket"]}], "=", 
   RowBox[{
    RowBox[{"1", "/", "2"}], 
    SubscriptBox[
     StyleBox["\[Omega]", "TI"], 
     StyleBox["x", "TI"]], 
    TemplateBox[{
      SubscriptBox[
       StyleBox["x", "TI"], "+"]},
     "Ket"]}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "512fec99-73e4-438e-b80e-159befd446d4"],
 "), its time evolution only adds an overall phase ",
 Cell[BoxData[
  SuperscriptBox[
   StyleBox["e", "TI"], 
   RowBox[{"-", 
    StyleBox["i", "TI"], " ", 
    StyleBox["E", "TI"], " ", 
    StyleBox["t", "TI"]}]]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "67ed2569-c16c-4c55-91ab-108329656a6b"],
 ", where ",
 Cell[BoxData[
  StyleBox["E", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "efd293a8-46b4-4935-9b99-50da0e58a632"],
 " is the corresponding eigenvalue."
}], "Text",ExpressionUUID->"31d386fd-30cc-4d1b-9701-2926cd3fe251"],

Cell[TextData[{
 "For ",
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     RowBox[{
       StyleBox["\[Psi]", "TI"], 
       StyleBox["(", SpanMaxSize -> 1], "0", 
       StyleBox[")", SpanMaxSize -> 1]}]},
    "Ket"], "=", 
   TemplateBox[{
     SubscriptBox[
      StyleBox["x", "TI"], "+"]},
    "Ket"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "c9ad895e-f2ba-4f83-87ea-16b2651143f7"],
 " and ",
 Cell[BoxData[
  RowBox[{
   StyleBox["H", "TI"], "=", "1", "/", "2", 
   SubscriptBox[
    StyleBox["\[Omega]", "TI"], 
    StyleBox["x", "TI"]], 
   SubscriptBox[
    StyleBox["\[Sigma]", "TI"], 
    StyleBox["x", "TI"]]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "4e41f603-6179-4ca3-8a3a-6c3cb56373ad"],
 ", verify that ",
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     RowBox[{
       StyleBox["\[Psi]", "TI"], 
       StyleBox["(", SpanMaxSize -> 1], 
       StyleBox["t", "TI"], 
       StyleBox[")", SpanMaxSize -> 1]}]},
    "Ket"], "=", 
   RowBox[{
    SuperscriptBox[
     StyleBox["e", "TI"], 
     RowBox[{"-", 
      StyleBox["i", "TI"], " ", 
      SubscriptBox[
       StyleBox["\[Omega]", "TI"], 
       StyleBox["x", "TI"]], "/", "2", 
      StyleBox["t", "TI"]}]], 
    TemplateBox[{
      SubscriptBox[
       StyleBox["x", "TI"], "+"]},
     "Ket"]}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "8d592847-ea6b-4e51-9de9-2f1dfc324255"],
 ":"
}], "Text",ExpressionUUID->"2761baad-fd86-40dd-a34f-0b9111215bee"],

Cell[BoxData[
 RowBox[{
  RowBox[{"With", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"plus", " ", "=", " ", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"1", ",", " ", "1"}], "}"}], "/", 
       RowBox[{"Sqrt", "[", "2", "]"}]}]}], "}"}], ",", " ", "\n", "  ", 
    RowBox[{
     RowBox[{"MatrixExp", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"-", "I"}], " ", 
        RowBox[{"\[Omega]x", "/", "2"}], " ", 
        RowBox[{"PauliMatrix", "[", "1", "]"}], " ", "t"}], ",", " ", 
       "plus"}], "]"}], " ", "==", " ", "\n", "   ", 
     RowBox[{
      RowBox[{"E", "^", 
       RowBox[{"(", 
        RowBox[{
         RowBox[{"-", 
          RowBox[{"(", 
           RowBox[{"1", "/", "2"}], ")"}]}], " ", "I", " ", "t", " ", 
         "\[Omega]x"}], ")"}]}], " ", "plus"}]}]}], "]"}], " ", "//", " ", 
  "FullSimplify"}]], "Input",
 CellLabel->
  "In[241]:= ",ExpressionUUID->"59754fb3-6639-4352-a354-15a0b418d289"],

Cell["\<\
This is why Hamiltonian eigenstates are called stationary states: as time \
evolves, they acquire only a global phase, which is not observable. \
Consequently, the physical state remains unchanged in time, hence \
\[OpenCurlyDoubleQuote]stationary.\[CloseCurlyDoubleQuote]\
\>", "Text",ExpressionUUID->"7c0b20f1-d46d-4822-a420-b42b396d8d09"],

Cell["Time Evolution: the Liouville\[Dash]von Neumann Equation", "Subsection",ExpressionUUID->"eb327abe-6d12-4c5b-92c4-8e52cc317947"],

Cell[TextData[{
 "Given a propagator ",
 Cell[BoxData[
  RowBox[{
   StyleBox["U", "TI"], 
   StyleBox["(",
    SpanMaxSize->1], 
   StyleBox["t", "TI"], 
   StyleBox[")",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "84d70201-f24f-4432-9193-1556cc2ec261"],
 ", the density matrix evolves as ",
 Cell[BoxData[
  RowBox[{
   RowBox[{
    StyleBox["\[Rho]", "TI"], "\[Rule]", 
    StyleBox["U", "TI"]}], ".", 
   StyleBox["\[Rho]", "TI"], ".", 
   SuperscriptBox[
    StyleBox["U", "TI"], "\[Dagger]"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "fcba44b8-ec06-425a-9b94-e7d0990aebef"],
 ". Using the propagator\[CloseCurlyQuote]s equation of motion, ",
 Cell[BoxData[
  RowBox[{
   StyleBox["d", "TI"], 
   StyleBox["U", "TI"], "/", 
   StyleBox["d", "TI"], 
   StyleBox["t", "TI"], "=", "-", 
   StyleBox["i", "TI"], " ", 
   StyleBox["H", "TI"], " ", 
   StyleBox["U", "TI"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "9ef87e11-0c45-4fdf-b8d0-7d40c4b7cb38"],
 ", one can derive the corresponding evolution for the density matrix: ",
 Cell[BoxData[
  RowBox[{
   RowBox[{
    StyleBox["d", "TI"], 
    RowBox[{
     StyleBox["\[Rho]", "TI"], "/", 
     StyleBox["d", "TI"]}], 
    StyleBox["t", "TI"]}], "=", 
   RowBox[{"-", 
    StyleBox["i", "TI"], " "}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "d1833e64-6a34-410d-8fba-819d525ccb06"],
 ", which is known as the Liouville\[Dash]von Neumann equation. Recall from \
our SU(2) discussion that the most general single-qubit Hamiltonian (up to an \
irrelevant global phase) can be written as the traceless Hermitian operator \
",
 Cell[BoxData[
  RowBox[{"1", "/", "2", 
   StyleBox["(",
    SpanMaxSize->1], 
   RowBox[{
    SubscriptBox[
     StyleBox["\[Omega]", "TI"], 
     StyleBox["x", "TI"]], 
    SubscriptBox[
     StyleBox["\[Sigma]", "TI"], 
     StyleBox["x", "TI"]], "+", 
    SubscriptBox[
     StyleBox["\[Omega]", "TI"], 
     StyleBox["y", "TI"]], 
    SubscriptBox[
     StyleBox["\[Sigma]", "TI"], 
     StyleBox["y", "TI"]], "+", 
    SubscriptBox[
     StyleBox["\[Omega]", "TI"], 
     StyleBox["z", "TI"]], 
    SubscriptBox[
     StyleBox["\[Sigma]", "TI"], 
     StyleBox["z", "TI"]]}], 
   StyleBox[")",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "f2d9f762-b89e-43af-a526-f326dc822221"],
 ". We omit the identity term because it only produces a global phase and \
therefore has no observable effect on the qubit\[CloseCurlyQuote]s dynamics. \
In what follows, we will focus on the right-hand side of the \
Liouville\[Dash]von Neumann equation, the commutator ",
 Cell[BoxData[
  RowBox[{"-", 
   StyleBox["i", "TI"], 
   StyleBox["[",
    SpanMaxSize->1], 
   RowBox[{
    StyleBox["H", "TI"], ",", 
    StyleBox["\[Rho]", "TI"]}], 
   StyleBox["]",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "5d9822b5-962b-4cfe-a0bb-1373efe9b8d6"],
 "."
}], "Text",ExpressionUUID->"ced6660e-a734-424e-9089-3be232364611"],

Cell[TextData[{
 "For ",
 Cell[BoxData[
  RowBox[{
   RowBox[{
    StyleBox["H", "TI"], "=", "1", "/", "2", 
    StyleBox["(",
     SpanMaxSize->1], 
    RowBox[{
     SubscriptBox[
      StyleBox["\[Omega]", "TI"], 
      StyleBox["x", "TI"]], 
     SubscriptBox[
      StyleBox["\[Sigma]", "TI"], 
      StyleBox["x", "TI"]], "+", 
     SubscriptBox[
      StyleBox["\[Omega]", "TI"], 
      StyleBox["y", "TI"]], 
     SubscriptBox[
      StyleBox["\[Sigma]", "TI"], 
      StyleBox["y", "TI"]], "+", 
     SubscriptBox[
      StyleBox["\[Omega]", "TI"], 
      StyleBox["z", "TI"]], 
     SubscriptBox[
      StyleBox["\[Sigma]", "TI"], 
      StyleBox["z", "TI"]]}], 
    StyleBox[")",
     SpanMaxSize->1], "=", "1", "/", "2", 
    OverscriptBox[
     StyleBox["\[Omega]", "TI"], "\[RightVector]"]}], ".", 
   OverscriptBox[
    StyleBox["\[Sigma]", "TI"], "\[RightVector]"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "7b1094a0-7cf2-49eb-82ab-092d77cd4ac7"],
 ", verify that ",
 Cell[BoxData[
  RowBox[{"-", 
   StyleBox["i", "TI"], 
   StyleBox["[",
    SpanMaxSize->1], 
   RowBox[{
    StyleBox["H", "TI"], ",", 
    StyleBox["\[Rho]", "TI"]}], 
   StyleBox["]",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "b932e485-1467-4116-b492-0e7204633bb9"],
 " implies the transformation of the Bloch vector as ",
 Cell[BoxData[
  RowBox[{
   OverscriptBox[
    StyleBox["r", "TI"], "\[RightVector]"], "\[Rule]", 
   OverscriptBox[
    StyleBox["\[Omega]", "TI"], "\[RightVector]"], "\[Times]", 
   OverscriptBox[
    StyleBox["r", "TI"], "\[RightVector]"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "d2e94b9d-1b00-4f5a-9b31-afcaf781a3d7"],
 ":"
}], "Text",ExpressionUUID->"095423a1-b655-4126-89b4-bd723de38492"],

Cell[BoxData[{
 RowBox[{"ClearAll", "[", 
  RowBox[{
  "\[Sigma]", ",", " ", "\[Omega]x", ",", " ", "\[Omega]y", ",", " ", 
   "\[Omega]z", ",", " ", "rx", ",", " ", "ry", ",", " ", "rz"}], "]"}], "\n", 
 RowBox[{
  RowBox[{"With", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{"\[Sigma]", " ", "=", " ", "\n", "    ", 
       RowBox[{"Table", "[", 
        RowBox[{
         RowBox[{"PauliMatrix", "[", "j", "]"}], ",", " ", 
         RowBox[{"{", 
          RowBox[{"j", ",", " ", "\n", "      ", "3"}], "}"}]}], "]"}]}], ",",
       " ", 
      RowBox[{"\[Omega]", " ", "=", " ", 
       RowBox[{"{", 
        RowBox[{"\[Omega]x", ",", " ", "\[Omega]y", ",", " ", "\[Omega]z"}], 
        "}"}]}], ",", " ", "\n", "   ", 
      RowBox[{"r", " ", "=", " ", 
       RowBox[{"{", 
        RowBox[{"rx", ",", " ", "ry", ",", " ", "rz"}], "}"}]}]}], "}"}], ",",
     " ", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"h", " ", "=", " ", 
       RowBox[{
        RowBox[{"1", "/", "2"}], " ", 
        RowBox[{"\[Omega]", " ", ".", " ", "\[Sigma]"}]}]}], ",", " ", 
      RowBox[{"\[Rho]", " ", "=", " ", "\n", "    ", 
       RowBox[{"DensityMatrix", "[", "r", "]"}]}]}], "}"}], ",", " ", 
    RowBox[{"{", 
     RowBox[{"icom", " ", "=", " ", 
      RowBox[{
       RowBox[{"-", "I"}], " ", 
       RowBox[{"Commutator", "[", 
        RowBox[{"h", ",", " ", "\[Rho]", ",", " ", "Dot"}], "]"}]}]}], "}"}], 
    ",", " ", "\n", "  ", 
    RowBox[{
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{"Tr", "[", 
        RowBox[{"x", " ", ".", " ", "icom"}], "]"}], ",", " ", 
       RowBox[{"{", 
        RowBox[{"x", ",", " ", "\[Sigma]"}], "}"}]}], "]"}], " ", "==", " ", 
     "\n", "   ", 
     RowBox[{"Cross", "[", 
      RowBox[{"\[Omega]", ",", " ", "r"}], "]"}]}]}], "]"}], " ", "//", " ", 
  "FullSimplify"}]}], "Input",
 CellLabel->
  "In[242]:= ",ExpressionUUID->"77e5842c-324e-4fa8-8034-cd9e6f4624a6"],

Cell[TextData[{
 "Equivalently, the Liouville\[Dash]von Neumann equation can be rewritten as \
an equation of motion for the Bloch vector alone: ",
 Cell[BoxData[
  RowBox[{
   StyleBox["d", "TI"], 
   OverscriptBox[
    StyleBox["r", "TI"], "\[RightVector]"], "/", 
   StyleBox["d", "TI"], 
   StyleBox["t", "TI"], "=", 
   OverscriptBox[
    StyleBox["\[Omega]", "TI"], "\[RightVector]"], "\[Times]", 
   OverscriptBox[
    StyleBox["r", "TI"], "\[RightVector]"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "57f00c2a-4da8-4177-9ed2-3efd2101cc83"],
 ", i.e., the Bloch vector precesses about the effective field ",
 Cell[BoxData[
  OverscriptBox[
   StyleBox["\[Omega]", "TI"], "\[RightVector]"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "35fcd272-5882-4707-bfaf-07b299ea0908"],
 ". Note that ",
 Cell[BoxData[
  RowBox[{
   RowBox[{
    StyleBox["d", "TI"], 
    RowBox[{
     SuperscriptBox[
      TemplateBox[{
        OverscriptBox[
         StyleBox["r", "TI"], "\[RightVector]"]},
       "Abs"], "2"], "/", 
     StyleBox["d", "TI"]}], 
    StyleBox["t", "TI"]}], "=", 
   RowBox[{
    RowBox[{
     StyleBox["d", "TI"], 
     RowBox[{
      RowBox[{
       StyleBox["(",
        SpanMaxSize->1], 
       RowBox[{
        OverscriptBox[
         StyleBox["r", "TI"], "\[RightVector]"], ".", 
        OverscriptBox[
         StyleBox["r", "TI"], "\[RightVector]"]}], 
       StyleBox[")",
        SpanMaxSize->1]}], "/", 
      StyleBox["d", "TI"]}], 
     StyleBox["t", "TI"]}], "=", 
    RowBox[{
     StyleBox["d", "TI"], 
     RowBox[{
      OverscriptBox[
       StyleBox["r", "TI"], "\[RightVector]"], "/", 
      StyleBox["d", "TI"]}], 
     RowBox[{
      StyleBox["t", "TI"], ".", 
      RowBox[{
       OverscriptBox[
        StyleBox["r", "TI"], "\[RightVector]"], "+", 
       OverscriptBox[
        StyleBox["r", "TI"], "\[RightVector]"]}], ".", 
      RowBox[{
       StyleBox["d", "TI"], 
       OverscriptBox[
        StyleBox["r", "TI"], "\[RightVector]"], "/", 
       StyleBox["d", "TI"], 
       StyleBox["t", "TI"], "=", "2", 
       OverscriptBox[
        StyleBox["r", "TI"], "\[RightVector]"]}], ".", 
      RowBox[{
       StyleBox["d", "TI"], 
       OverscriptBox[
        StyleBox["r", "TI"], "\[RightVector]"], "/", 
       StyleBox["d", "TI"], 
       StyleBox["t", "TI"], "=", "2", 
       OverscriptBox[
        StyleBox["r", "TI"], "\[RightVector]"]}], ".", 
      RowBox[{
       StyleBox["(",
        SpanMaxSize->1], 
       RowBox[{
        OverscriptBox[
         StyleBox["\[Omega]", "TI"], "\[RightVector]"], "\[Times]", 
        OverscriptBox[
         StyleBox["r", "TI"], "\[RightVector]"]}], 
       StyleBox[")",
        SpanMaxSize->1], "=", "0"}]}]}]}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "3409e167-6ac9-449f-b8cf-2b700e753699"],
 " because ",
 Cell[BoxData[
  RowBox[{
   OverscriptBox[
    StyleBox["\[Omega]", "TI"], "\[RightVector]"], "\[Times]", 
   OverscriptBox[
    StyleBox["r", "TI"], "\[RightVector]"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "f6f47456-e121-4043-80db-72787d4a0908"],
 " is perpendicular to both ",
 Cell[BoxData[
  OverscriptBox[
   StyleBox["\[Omega]", "TI"], "\[RightVector]"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "b4c87792-1593-44a8-86b9-f2f2b2f22588"],
 " and ",
 Cell[BoxData[
  OverscriptBox[
   StyleBox["r", "TI"], "\[RightVector]"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "18cf8586-7498-4217-ad95-7a210dd7f6bc"],
 ". So the motion preserves ",
 Cell[BoxData[
  TemplateBox[{
    OverscriptBox[
     StyleBox["r", "TI"], "\[RightVector]"]},
   "Abs"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "f2f8cdcf-25d9-4a08-ae1a-5193e9959ef4"],
 " which is what we expected from a unitary transformation, or in the \
language of SO(3), it\[CloseCurlyQuote]s the signature of a rotation. In \
other words, pure precession is the \[OpenCurlyDoubleQuote]cleanest\
\[CloseCurlyDoubleQuote] kind of qubit motion: the Bloch vector behaves like \
a rigid arrow on a sphere, rotating around a fixed (or prescribed) axis with \
no shrinkage and no drift toward equilibrium."
}], "Text",ExpressionUUID->"82a323d9-f7a4-473e-9682-ae3f0f344e43"],

Cell[TextData[{
 "Since ",
 Cell[BoxData[
  RowBox[{
   OverscriptBox[
    StyleBox["\[Omega]", "TI"], "\[RightVector]"], "\[Times]", 
   OverscriptBox[
    StyleBox["r", "TI"], "\[RightVector]"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "0da711dd-9892-4977-86e7-88fb13a8ce57"],
 " is perpendicular to both ",
 Cell[BoxData[
  OverscriptBox[
   StyleBox["\[Omega]", "TI"], "\[RightVector]"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "5ab5b071-ad3e-4d43-9074-c56e2e5c2e69"],
 " and ",
 Cell[BoxData[
  OverscriptBox[
   StyleBox["r", "TI"], "\[RightVector]"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "e6e6b3fe-7701-4d0a-a177-6221963a4ec5"],
 ", it means that ",
 Cell[BoxData[
  RowBox[{
   StyleBox["d", "TI"], 
   OverscriptBox[
    StyleBox["r", "TI"], "\[RightVector]"], "/", 
   StyleBox["d", "TI"], 
   StyleBox["t", "TI"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "ef4cb49d-02bd-4ddc-a8a7-4f91f18d36e1"],
 " is always perpendicular to ",
 Cell[BoxData[
  OverscriptBox[
   StyleBox["r", "TI"], "\[RightVector]"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "e9434fe5-6b22-46a5-b8f7-54979302ea0b"],
 ", implying that ",
 Cell[BoxData[
  OverscriptBox[
   StyleBox["r", "TI"], "\[RightVector]"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "2bda0164-c28f-4b0d-a4ca-e40598dd921b"],
 " is undergoing a steady rotation with angular velocity ",
 Cell[BoxData[
  OverscriptBox[
   StyleBox["\[Omega]", "TI"], "\[RightVector]"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "bde0c877-e81f-460f-af91-bc873149c000"],
 ". If ",
 Cell[BoxData[
  OverscriptBox[
   StyleBox["r", "TI"], "\[RightVector]"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "9d939c57-46a0-4911-a58c-1fd85cd5a125"],
 " starts pointing somewhere, its tip will move in a circle (or on a cone) \
around the axis given by ",
 Cell[BoxData[
  OverscriptBox[
   StyleBox["\[Omega]", "TI"], "\[RightVector]"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "eeec09c9-efc3-40c3-8b97-dd25024cb1f0"],
 ". This is the standard form of a precession: when a \
vector\[CloseCurlyQuote]s direction in space slowly rotates around some axis, \
even though its length stays the same. We shall illustrate with an example."
}], "Text",ExpressionUUID->"2f8bf3a2-d181-4759-bd5c-b14edba9bc14"],

Cell[TextData[{
 "For the Hamiltonian ",
 Cell[BoxData[
  RowBox[{
   StyleBox["H", "TI"], "=", "1", "/", "2", 
   StyleBox["(",
    SpanMaxSize->1], 
   RowBox[{
    SubscriptBox[
     StyleBox["\[Omega]", "TI"], 
     StyleBox["x", "TI"]], 
    SubscriptBox[
     StyleBox["\[Sigma]", "TI"], 
     StyleBox["x", "TI"]], "+", 
    SubscriptBox[
     StyleBox["\[Omega]", "TI"], 
     StyleBox["z", "TI"]], 
    SubscriptBox[
     StyleBox["\[Sigma]", "TI"], 
     StyleBox["z", "TI"]]}], 
   StyleBox[")",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "7b8baba7-012f-413e-a0e8-a9ba26db34d5"],
 ", find the time-dependent Bloch vector for the initial state ",
 Cell[BoxData[
  RowBox[{
   RowBox[{
    OverscriptBox[
     StyleBox["r", "TI"], "\[RightVector]"], "=", "{", "0"}], ",", "0", ",", 
   RowBox[{"1", "}"}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "9982c092-c998-4c84-b505-a430a39dbed8"],
 ":"
}], "Text",ExpressionUUID->"16a3a021-601a-4ced-a507-8b20716048d4"],

Cell[BoxData[{
 RowBox[{"ClearAll", "[", 
  RowBox[{"\[Omega]x", ",", " ", "\[Omega]z", ",", " ", "t", ",", " ", "r"}], 
  "]"}], "\n", 
 RowBox[{
  RowBox[{"With", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"\[Omega]", " ", "=", " ", 
      RowBox[{"{", 
       RowBox[{"\[Omega]x", ",", " ", "0", ",", " ", "\[Omega]z"}], "}"}]}], 
     "}"}], ",", " ", 
    RowBox[{"{", 
     RowBox[{"\[ScriptCapitalL]", " ", "=", " ", "\n", "    ", 
      RowBox[{"Map", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"Cross", "[", 
          RowBox[{"#", ",", " ", "\[Omega]"}], "]"}], " ", "&"}], ",", " ", 
        RowBox[{"IdentityMatrix", "[", "3", "]"}]}], "]"}]}], "}"}], ",", 
    "\n", "  ", 
    RowBox[{
     RowBox[{"DSolveValue", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{
          RowBox[{
           RowBox[{"r", "'"}], "[", "t", "]"}], " ", "==", " ", 
          RowBox[{"\[ScriptCapitalL]", " ", ".", " ", 
           RowBox[{"r", "[", "t", "]"}]}]}], ",", " ", 
         RowBox[{
          RowBox[{"r", "[", "0", "]"}], " ", "==", " ", 
          RowBox[{"{", 
           RowBox[{"0", ",", " ", "0", ",", " ", "1"}], "}"}]}]}], "}"}], ",",
        " ", "\n", "    ", 
       RowBox[{
        RowBox[{"r", "[", "t", "]"}], " ", "\[Element]", " ", 
        RowBox[{"Vectors", "[", "3", "]"}]}], ",", " ", "\n", "    ", "t"}], 
      "]"}], " ", "/.", " ", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{"\[Omega]x", "^", "2"}], " ", "+", " ", 
         RowBox[{"\[Omega]z", "^", "2"}]}], " ", ":>", " ", 
        RowBox[{"\[CapitalOmega]", "^", "2"}]}], ",", " ", "\n", "    ", 
       RowBox[{
        RowBox[{"Sqrt", "[", 
         RowBox[{
          RowBox[{"-", 
           RowBox[{"\[Omega]x", "^", "2"}]}], " ", "-", " ", 
          RowBox[{"\[Omega]z", "^", "2"}]}], "]"}], " ", ":>", " ", "\n", 
        "     ", 
        RowBox[{"I", " ", "\[CapitalOmega]"}]}]}], "}"}]}]}], "]"}], " ", "//",
   " ", "FullSimplify"}]}], "Input",
 CellLabel->
  "In[243]:= ",ExpressionUUID->"bf6b0cdf-e329-45eb-9ade-51de9b8a1314"],

Cell[TextData[{
 "In the above code, first, we expressed the cross product operation as a \
matrix multiplication using an antisymmetric matrix \[ScriptCapitalL], and \
then solved the dynamical equation. The replacement that we used, ",
 Cell[BoxData[
  RowBox[{"\[CapitalOmega]", "=", 
   SqrtBox[
    RowBox[{
     SubsuperscriptBox[
      StyleBox["\[Omega]", "TI"], 
      StyleBox["x", "TI"], "2"], "+", 
     SubsuperscriptBox[
      StyleBox["\[Omega]", "TI"], 
      StyleBox["z", "TI"], "2"]}]]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "2f720f88-4c88-469d-b606-62e3af928db5"],
 ", is not only a cosmetic touch, but also has direction connection with the \
corresponding SO(3) rotation. Given ",
 Cell[BoxData[
  RowBox[{
   RowBox[{
    OverscriptBox[
     StyleBox["\[Omega]", "TI"], "\[RightVector]"], "=", "{", 
    SubscriptBox[
     StyleBox["\[Omega]", "TI"], 
     StyleBox["x", "TI"]]}], ",", "0", ",", 
   RowBox[{
    SubscriptBox[
     StyleBox["\[Omega]", "TI"], 
     StyleBox["z", "TI"]], "}"}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "2e68e3ac-a0b0-4ac1-bb4f-94f55d0cbee9"],
 ", one can find a unit vector ",
 Cell[BoxData[
  RowBox[{
   RowBox[{
    OverscriptBox[
     StyleBox["n", "TI"], "\[RightVector]"], "=", "{", 
    SubscriptBox[
     StyleBox["\[Omega]", "TI"], 
     StyleBox["x", "TI"]]}], ",", "0", ",", 
   RowBox[{
    SubscriptBox[
     StyleBox["\[Omega]", "TI"], 
     StyleBox["z", "TI"]], "}", "/", "\[CapitalOmega]"}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "0eabcaa2-fb96-46d9-acf7-6bf8f0872bea"],
 " such that the above result can be reproduced as ",
 Cell[BoxData[
  RowBox[{
   OverscriptBox[
    StyleBox["r", "TI"], "\[RightVector]"], 
   StyleBox["(",
    SpanMaxSize->1], 
   StyleBox["t", "TI"], 
   StyleBox[")",
    SpanMaxSize->1], "=", 
   SubscriptBox["\[ScriptCapitalR]", 
    OverscriptBox[
     StyleBox["n", "TI"], "\[RightVector]"]], 
   StyleBox["(",
    SpanMaxSize->1], 
   RowBox[{"\[CapitalOmega]", " ", 
    StyleBox["t", "TI"]}], 
   StyleBox[")",
    SpanMaxSize->1], 
   OverscriptBox[
    StyleBox["r", "TI"], "\[RightVector]"], 
   StyleBox["(",
    SpanMaxSize->1], "0", 
   StyleBox[")",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "facfd19c-dd74-4e84-bb16-dc2e42105890"],
 "."
}], "Text",ExpressionUUID->"46267d54-29ec-44b4-861b-d1c4f25a691e"],

Cell[TextData[{
 "Verify that the above result is the same as s ",
 Cell[BoxData[
  RowBox[{
   OverscriptBox[
    StyleBox["r", "TI"], "\[RightVector]"], 
   StyleBox["(",
    SpanMaxSize->1], 
   StyleBox["t", "TI"], 
   StyleBox[")",
    SpanMaxSize->1], "=", 
   SubscriptBox["\[ScriptCapitalR]", 
    OverscriptBox[
     StyleBox["n", "TI"], "\[RightVector]"]], 
   StyleBox["(",
    SpanMaxSize->1], 
   RowBox[{"\[CapitalOmega]", " ", 
    StyleBox["t", "TI"]}], 
   StyleBox[")",
    SpanMaxSize->1], 
   OverscriptBox[
    StyleBox["r", "TI"], "\[RightVector]"], 
   StyleBox["(",
    SpanMaxSize->1], "0", 
   StyleBox[")",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "b1b93c08-dd18-4274-9ca8-0c9b6e0ae065"],
 ":"
}], "Text",ExpressionUUID->"b4d09a83-bd60-4a0d-8c0a-a8ac15d31083"],

Cell[BoxData[
 RowBox[{"FullSimplify", "[", "\n", " ", 
  RowBox[{
   RowBox[{"With", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"\[CapitalOmega]", " ", "=", " ", 
       RowBox[{"Sqrt", "[", 
        RowBox[{
         RowBox[{"\[Omega]x", "^", "2"}], " ", "+", " ", 
         RowBox[{"\[Omega]z", "^", "2"}]}], "]"}]}], "}"}], ",", " ", "\n", 
     "  ", 
     RowBox[{
      RowBox[{
       RowBox[{"RotationMatrix", "[", 
        RowBox[{
         RowBox[{"\[CapitalOmega]", " ", "t"}], ",", " ", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{
           "\[Omega]x", ",", " ", "\n", "      ", "0", ",", " ", 
            "\[Omega]z"}], "}"}], "/", "\[CapitalOmega]"}]}], "]"}], " ", ".",
        " ", 
       RowBox[{"{", 
        RowBox[{"0", ",", " ", "0", ",", " ", "\n", "     ", "1"}], "}"}]}], 
      " ", "==", " ", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"-", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{"(", 
            RowBox[{"\[Omega]x", " ", "\[Omega]z", " ", 
             RowBox[{"(", 
              RowBox[{
               RowBox[{"-", "1"}], " ", "+", " ", "\n", "        ", 
               RowBox[{"Cos", "[", 
                RowBox[{"t", " ", "\[CapitalOmega]"}], "]"}]}], ")"}]}], 
            ")"}], "/", 
           RowBox[{"\[CapitalOmega]", "^", "2"}]}], ")"}]}], ",", " ", 
        RowBox[{"-", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{"(", 
            RowBox[{"\[Omega]x", " ", 
             RowBox[{"Sin", "[", "\n", "       ", 
              RowBox[{"t", " ", "\[CapitalOmega]"}], "]"}]}], ")"}], "/", 
           "\[CapitalOmega]"}], ")"}]}], ",", " ", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{
           RowBox[{"\[Omega]z", "^", "2"}], " ", "+", " ", 
           RowBox[{
            RowBox[{
             RowBox[{"\\\n", "\[Omega]x"}], "^", "2"}], " ", 
            RowBox[{"Cos", "[", "\n", "       ", 
             RowBox[{"t", " ", "\[CapitalOmega]"}], "]"}]}]}], ")"}], "/", 
         RowBox[{"\[CapitalOmega]", "^", "2"}]}]}], "}"}]}]}], "]"}], ",", 
   " ", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{"\[Omega]x", " ", "|", " ", 
      RowBox[{"\\\n", "\[Omega]z"}], " ", "|", " ", "\[CapitalOmega]"}], 
     ")"}], " ", "\[Element]", " ", "Reals"}]}], "]"}]], "Input",
 CellLabel->
  "In[244]:= ",ExpressionUUID->"909aa436-3432-4fa5-8782-a938bc44e021"],

Cell[TextData[{
 "In fact, the Bloch-vector motion admits a clean geometric picture. The \
trajectory is always a circle: it is the intersection of the Bloch sphere \
with the plane that has normal vector ",
 Cell[BoxData[
  RowBox[{
   RowBox[{
    OverscriptBox[
     StyleBox["n", "TI"], "\[RightVector]"], "=", "{", 
    SubscriptBox[
     StyleBox["\[Omega]", "TI"], 
     StyleBox["x", "TI"]]}], ",", "0", ",", 
   RowBox[{
    SubscriptBox[
     StyleBox["\[Omega]", "TI"], 
     StyleBox["z", "TI"]], "}", "/", "\[CapitalOmega]"}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "588cea17-e795-43e6-810b-b9314ffb53fb"],
 " (recall ",
 Cell[BoxData[
  RowBox[{
   RowBox[{
    OverscriptBox[
     StyleBox["\[Omega]", "TI"], "\[RightVector]"], "=", "{", 
    SubscriptBox[
     StyleBox["\[Omega]", "TI"], 
     StyleBox["x", "TI"]]}], ",", "0", ",", 
   RowBox[{
    SubscriptBox[
     StyleBox["\[Omega]", "TI"], 
     StyleBox["z", "TI"]], "}"}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "d969f9ac-ca7a-4f8f-9bce-b8aef39bb541"],
 ") and passes through the initial Bloch vector ",
 Cell[BoxData[
  RowBox[{
   OverscriptBox[
    StyleBox["r", "TI"], "\[RightVector]"], 
   StyleBox["(",
    SpanMaxSize->1], "0", 
   StyleBox[")",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "4b01423c-9264-429b-a259-9527164e6cd1"],
 ". Equivalently, ",
 Cell[BoxData[
  RowBox[{
   OverscriptBox[
    StyleBox["r", "TI"], "\[RightVector]"], 
   StyleBox["(",
    SpanMaxSize->1], 
   StyleBox["t", "TI"], 
   StyleBox[")",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "3569b948-dcc8-4320-be54-6e5911ff3cfe"],
 " precesses around the fixed axis ",
 Cell[BoxData[
  OverscriptBox[
   StyleBox["n", "TI"], "\[RightVector]"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "2ece4baa-4a18-4d33-b4ed-9edebaceb042"],
 ", tracing the circle cut out by that plane on the sphere. This is what we \
mentioned before regarding the dynamical equation ",
 Cell[BoxData[
  RowBox[{
   StyleBox["d", "TI"], 
   OverscriptBox[
    StyleBox["r", "TI"], "\[RightVector]"], "/", 
   StyleBox["d", "TI"], 
   StyleBox["t", "TI"], "=", 
   OverscriptBox[
    StyleBox["\[Omega]", "TI"], "\[RightVector]"], "\[Times]", 
   OverscriptBox[
    StyleBox["r", "TI"], "\[RightVector]"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "b934d7fb-5347-453b-8ea5-0bad1fa35e7b"],
 ": if ",
 Cell[BoxData[
  OverscriptBox[
   StyleBox["r", "TI"], "\[RightVector]"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "55efb88f-f9fb-4a35-b308-7222a5a9c704"],
 " starts pointing somewhere, its tip will move in a circle (or on a cone) \
around the axis given by ",
 Cell[BoxData[
  OverscriptBox[
   StyleBox["\[Omega]", "TI"], "\[RightVector]"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "a9f59af4-0bce-48ca-960c-aaeff983cf37"],
 "."
}], "Text",ExpressionUUID->"0eeed86a-7538-46ea-95ee-93b8c48581c6"],

Cell[BoxData[
 RowBox[{"Manipulate", "[", "\n", " ", 
  RowBox[{
   RowBox[{"With", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"initial", " ", "=", " ", 
       RowBox[{"FromSphericalCoordinates", "[", 
        RowBox[{"{", 
         RowBox[{"1", ",", " ", 
          RowBox[{"\[Pi]", "/", "4"}], ",", " ", "0"}], "}"}], "]"}]}], "}"}],
      ",", "\n", "  ", 
     RowBox[{"Show", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"ResourceFunction", "[", "\"\<BlochSpherePlot\>\"", "]"}], "[",
         "\n", "    ", 
        RowBox[{
         RowBox[{
          RowBox[{"RotationMatrix", "[", "\n", "      ", 
           RowBox[{
            RowBox[{
             RowBox[{"Sqrt", "[", 
              RowBox[{
               RowBox[{"\[Omega]x", "^", "2"}], " ", "+", " ", 
               RowBox[{"\[Omega]z", "^", "2"}]}], "]"}], " ", "tf"}], ",", 
            " ", 
            RowBox[{
             RowBox[{"{", 
              RowBox[{"\[Omega]x", ",", " ", "0", ",", " ", "\[Omega]z"}], 
              "}"}], "/", "\n", "      ", 
             RowBox[{"Sqrt", "[", 
              RowBox[{
               RowBox[{"\[Omega]x", "^", "2"}], " ", "+", " ", 
               RowBox[{"\[Omega]z", "^", "2"}]}], "]"}]}]}], "]"}], " ", ".", 
          " ", "initial"}], ",", " ", "\n", "    ", 
         RowBox[{"\"\<NumberOfGreatCircles\>\"", " ", "->", " ", "5"}], ",", 
         " ", 
         RowBox[{"\"\<NumberOfSmallCircles\>\"", " ", "->", " ", "5"}]}], 
        "]"}], ",", " ", "\n", "   ", 
       RowBox[{"Graphics3D", "[", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{"Green", ",", " ", 
            RowBox[{"PointSize", "[", ".02", "]"}], ",", " ", "\n", "      ", 
            
            RowBox[{"Point", "[", "initial", "]"}]}], "}"}], ",", " ", 
          RowBox[{"{", 
           RowBox[{"Text", "[", "\n", "       ", 
            
            RowBox[{"\"\<{\\!\\(\\*SubscriptBox[\\(\[Omega]\\), \
\\(x\\)]\\),0,\\!\\(\\*SubscriptBox[\\(\[Omega]\\), \\(z\\)]\\)}\>\"", ",", 
             " ", "\n", "       ", 
             RowBox[{"initial", " ", "+", " ", 
              RowBox[{".4", " ", 
               RowBox[{
                RowBox[{"{", 
                 RowBox[{"\[Omega]x", ",", " ", "0", ",", " ", "\[Omega]z"}], 
                 "}"}], "/", "\n", "         ", 
                RowBox[{"Sqrt", "[", 
                 RowBox[{
                  RowBox[{"\[Omega]x", "^", "2"}], " ", "+", " ", 
                  RowBox[{"\[Omega]z", "^", "2"}]}], "]"}]}]}]}]}], "]"}], 
           "}"}], ",", " ", 
          RowBox[{"{", 
           RowBox[{"Thick", ",", " ", "\n", "      ", 
            RowBox[{"Arrow", "[", 
             RowBox[{"{", 
              RowBox[{"initial", ",", " ", "\n", "        ", 
               RowBox[{"initial", " ", "+", " ", 
                RowBox[{".3", " ", 
                 RowBox[{
                  RowBox[{"{", 
                   RowBox[{
                   "\[Omega]x", ",", " ", "0", ",", " ", "\[Omega]z"}], "}"}],
                   "/", "\n", "          ", 
                  RowBox[{"Sqrt", "[", 
                   RowBox[{
                    RowBox[{"\[Omega]x", "^", "2"}], " ", "+", " ", 
                    RowBox[{"\[Omega]z", "^", "2"}]}], "]"}]}]}]}]}], "}"}], 
             "]"}]}], "}"}], ",", " ", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"Opacity", "[", ".5", "]"}], ",", " ", "\n", "      ", 
            RowBox[{
             RowBox[{"ColorData", "[", "97", "]"}], "[", "2", "]"}], ",", " ",
             "\n", "      ", 
            RowBox[{"Hyperplane", "[", 
             RowBox[{
              RowBox[{
               RowBox[{"{", 
                RowBox[{"\[Omega]x", ",", " ", "0", ",", " ", "\[Omega]z"}], 
                "}"}], "/", "\n", "       ", 
               RowBox[{"Sqrt", "[", 
                RowBox[{
                 RowBox[{"\[Omega]x", "^", "2"}], " ", "+", " ", 
                 RowBox[{"\[Omega]z", "^", "2"}]}], "]"}]}], ",", " ", 
              "initial"}], "]"}]}], "}"}]}], "}"}], "]"}], ",", " ", "\n", 
       "   ", 
       RowBox[{"ParametricPlot3D", "[", "\n", "    ", 
        RowBox[{
         RowBox[{
          RowBox[{"RotationMatrix", "[", "\n", "      ", 
           RowBox[{
            RowBox[{
             RowBox[{"Sqrt", "[", 
              RowBox[{
               RowBox[{"\[Omega]x", "^", "2"}], " ", "+", " ", 
               RowBox[{"\[Omega]z", "^", "2"}]}], "]"}], " ", "t"}], ",", " ", 
            RowBox[{
             RowBox[{"{", 
              RowBox[{"\[Omega]x", ",", " ", "0", ",", " ", "\[Omega]z"}], 
              "}"}], "/", "\n", "      ", 
             RowBox[{"Sqrt", "[", 
              RowBox[{
               RowBox[{"\[Omega]x", "^", "2"}], " ", "+", " ", 
               RowBox[{"\[Omega]z", "^", "2"}]}], "]"}]}]}], "]"}], " ", ".", 
          " ", "initial"}], ",", " ", 
         RowBox[{"{", 
          RowBox[{"t", ",", " ", "0", ",", " ", "tf"}], "}"}], ",", " ", "\n",
          "    ", 
         RowBox[{"PlotStyle", " ", "->", " ", "Red"}]}], "]"}], ",", " ", 
       RowBox[{"PlotRange", " ", "->", " ", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{
            RowBox[{"-", "1"}], ",", " ", "1"}], "}"}], ",", " ", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"-", "1"}], ",", " ", "1"}], "}"}], ",", " ", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"-", "1"}], ",", " ", "1"}], "}"}]}], "}"}]}]}], "]"}]}], 
    "]"}], ",", " ", "\n", " ", 
   RowBox[{"Item", "[", 
    RowBox[{"\"\<Bloch-vector trajectory with Hamiltonian 1/\n   2 \
(Subscript[\[Omega], x] Subscript[\[Sigma], x] + \n     Subscript[\[Omega], \
z] Subscript[\[Sigma], z])\>\"", ",", " ", "\n", "  ", 
     RowBox[{"Alignment", " ", "->", " ", "Center"}]}], "]"}], ",", " ", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
      "\[Omega]x", ",", " ", "1", ",", " ", "\n", 
       "   ", "\"\<Rabi rate \\!\\(\\*SubscriptBox[\\(\[Omega]\\), \
\\(x\\)]\\)\>\""}], "}"}], ",", " ", "0", ",", " ", "\n", "  ", 
     RowBox[{"2", " ", "\[Pi]"}]}], "}"}], ",", " ", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
      "\[Omega]z", ",", " ", ".5", ",", " ", "\n", 
       "   ", "\"\<Detuning rate \\!\\(\\*SubscriptBox[\\(\[Omega]\\), \
\\(z\\)]\\)\>\""}], "}"}], ",", " ", "0", ",", " ", "\n", "  ", 
     RowBox[{"2", " ", "\[Pi]"}]}], "}"}], ",", " ", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"tf", ",", " ", "1", ",", " ", "\"\<Time\>\""}], "}"}], ",", 
     " ", 
     RowBox[{"10", "^", 
      RowBox[{"-", "3"}]}], ",", " ", "10"}], "}"}]}], "]"}]], "Input",
 CellLabel->
  "In[245]:= ",ExpressionUUID->"2c852737-7e19-4839-bd76-ab4ab8136254"],

Cell["Time Evolution: Pulses", "Subsection",ExpressionUUID->"7c8b55b6-d449-42de-b881-cab8077ef9cf"],

Cell[TextData[{
 "Recall that any two points on the Bloch sphere can be connected by an SO(3) \
transformation. In other words, for any initial state and any target state, \
there exists a rotation that maps one to the other. However, the existence of \
such a rotation does not mean we can implement it directly in the laboratory: \
hardware constraints typically restrict which control fields we can apply, \
along which axes, and with what timing and strength. This is where pulses \
enter the story. In control language, a pulse is a short, controlled \
interaction that produces a rotation about a fixed, experimentally accessible \
axis. If we cannot rotate about an arbitrary axis ",
 Cell[BoxData[
  OverscriptBox[
   StyleBox["n", "TI"], "\[RightVector]"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "ccc6dd6b-42f5-4efa-ab15-b29a1ad795ef"],
 " on demand, we instead build the desired operation from a sequence of \
simpler rotations about axes we can implement."
}], "Text",ExpressionUUID->"2bd474e8-1e36-4790-92cf-1eb7a3184737"],

Cell[TextData[{
 "A powerful constructive tool for doing this is Euler decomposition: a \
generic rotation about an arbitrary axis can be written as a product of \
rotations about fixed axes. Different Euler conventions are commonly used, \
for example: XYX decomposition ",
 Cell[BoxData[
  RowBox[{
   SubscriptBox["\[ScriptCapitalR]", 
    OverscriptBox[
     StyleBox["n", "TI"], "\[RightVector]"]], 
   StyleBox["(",
    SpanMaxSize->1], 
   StyleBox["\[Theta]", "TI"], 
   StyleBox[")",
    SpanMaxSize->1], "=", 
   SubscriptBox["\[ScriptCapitalR]", 
    StyleBox["x", "TI"]], 
   StyleBox["(",
    SpanMaxSize->1], 
   StyleBox["\[Alpha]", "TI"], 
   StyleBox[")",
    SpanMaxSize->1], 
   SubscriptBox["\[ScriptCapitalR]", 
    StyleBox["y", "TI"]], 
   StyleBox["(",
    SpanMaxSize->1], 
   StyleBox["\[Beta]", "TI"], 
   StyleBox[")",
    SpanMaxSize->1], 
   SubscriptBox["\[ScriptCapitalR]", 
    StyleBox["x", "TI"]], 
   StyleBox["(",
    SpanMaxSize->1], 
   StyleBox["\[Gamma]", "TI"], 
   StyleBox[")",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "73cb72f3-dbb7-4fde-8da3-9bf844ad0b10"],
 ", or ZYZ decomposition ",
 Cell[BoxData[
  RowBox[{
   SubscriptBox["\[ScriptCapitalR]", 
    OverscriptBox[
     StyleBox["n", "TI"], "\[RightVector]"]], 
   StyleBox["(",
    SpanMaxSize->1], 
   StyleBox["\[Theta]", "TI"], 
   StyleBox[")",
    SpanMaxSize->1], "=", 
   SubscriptBox["\[ScriptCapitalR]", 
    StyleBox["z", "TI"]], 
   StyleBox["(",
    SpanMaxSize->1], 
   StyleBox["\[Alpha]", "TI"], 
   StyleBox[")",
    SpanMaxSize->1], 
   SubscriptBox["\[ScriptCapitalR]", 
    StyleBox["y", "TI"]], 
   StyleBox["(",
    SpanMaxSize->1], 
   StyleBox["\[Beta]", "TI"], 
   StyleBox[")",
    SpanMaxSize->1], 
   SubscriptBox["\[ScriptCapitalR]", 
    StyleBox["z", "TI"]], 
   StyleBox["(",
    SpanMaxSize->1], 
   StyleBox["\[Gamma]", "TI"], 
   StyleBox[")",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "1dd67cb5-c3c2-46c6-9f9a-22f40b021d61"],
 "."
}], "Text",ExpressionUUID->"83d19f3b-e0b3-4fbd-ac87-1d7be485851d"],

Cell[TextData[{
 "In the language of qubit control, these elementary rotations about fixed \
axes are precisely what we call pulses. For example, ",
 Cell[BoxData[
  RowBox[{
   SubscriptBox["\[ScriptCapitalR]", 
    StyleBox["x", "TI"]], 
   StyleBox["(",
    SpanMaxSize->1], 
   StyleBox["\[Alpha]", "TI"], 
   StyleBox[")",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "802a3ffe-e45f-4b4b-888d-f253924d95e9"],
 " is an ",
 Cell[BoxData[
  StyleBox["X", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "91d2d87b-42e6-499b-b43b-2dd453af2367"],
 "-pulse of angle \[Alpha], denoted ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["X", "TI"], 
   StyleBox["\[Alpha]", "TI"]]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "e84bd13a-09de-417d-828d-854a2f28fcbd"],
 " (and similarly ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["Y", "TI"], 
   StyleBox["\[Beta]", "TI"]]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "4896a976-de1d-4f7b-a298-d8f631b6952a"],
 " or ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["Z", "TI"], 
   StyleBox["\[Gamma]", "TI"]]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "681e5e40-9a89-4f3f-a3ef-f2b7da807e83"],
 "). By choosing the angles and applying the pulses in the correct order, we \
can synthesize the desired rotation, even when the hardware cannot implement \
it in a single step. A natural next question is: how are these pulses \
actually generated in the lab?"
}], "Text",ExpressionUUID->"b9490835-2065-4b0a-acf4-631d99ae66e8"],

Cell[TextData[{
 "A simple way to model a pulse is to multiply the control term in the \
Hamiltonian by a time-dependent envelope that is nonzero only during the \
pulse window. In the idealized \[OpenCurlyDoubleQuote]square-pulse\
\[CloseCurlyDoubleQuote] model, this envelope equals 1 for the pulse duration \
and 0 otherwise, so the drive is switched on only for a finite time interval \
and off everywhere else. With this model, the pulse affects the qubit only \
during its finite duration, which we denote by \[Tau]. If the control \
Hamiltonian ",
 Cell[BoxData[
  StyleBox["H", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "116fc883-48c5-4da8-87c8-06c8f84e6ba7"],
 " is effectively time-independent throughout that interval, then the net \
action of the pulse is simply the unitary time evolution generated over the \
pulse window: ",
 Cell[BoxData[
  SuperscriptBox[
   StyleBox["e", "TI"], 
   RowBox[{"-", 
    StyleBox["i", "TI"], " ", 
    StyleBox["H", "TI"], " ", 
    StyleBox["\[Tau]", "TI"]}]]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "645f8a48-0b9a-40ed-9c5b-344f3a55aaa6"],
 ". In other words, once the full duration \[Tau] has elapsed, the pulse has \
implemented the rotation encoded by ",
 Cell[BoxData[
  StyleBox["H", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "2b44da9d-5f79-47c5-8287-df7c63b7ff32"],
 " and \[Tau], and its effect is completely captured by this propagator. For \
example, to implement an ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["X", "TI"], 
   RowBox[{"\[Pi]", "/", "2"}]]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "026bec1d-a42c-48c7-84e2-4f1516ec7e24"],
 " pulse, we want the pulse unitary to match ",
 Cell[BoxData[
  RowBox[{
   SubscriptBox[
    StyleBox["X", "TI"], 
    RowBox[{"\[Pi]", "/", "2"}]], "=", 
   SuperscriptBox[
    StyleBox["e", "TI"], 
    RowBox[{"-", 
     StyleBox["i", "TI"], " ", "\[Pi]", "/", "2", "/", "2", 
     SubscriptBox[
      StyleBox["\[Sigma]", "TI"], 
      StyleBox["x", "TI"]]}]]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "fa744df8-214b-4935-9c41-83d3f167fd2f"],
 ". With a Hamiltonian as ",
 Cell[BoxData[
  RowBox[{
   StyleBox["H", "TI"], "=", "1", "/", "2", 
   SubscriptBox[
    StyleBox["\[Omega]", "TI"], 
    StyleBox["x", "TI"]], 
   SubscriptBox[
    StyleBox["\[Sigma]", "TI"], 
    StyleBox["x", "TI"]]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "9ead254e-f16e-4bcb-bd53-c6d0ae0b08a7"],
 ", the pulse implements ",
 Cell[BoxData[
  SuperscriptBox[
   StyleBox["e", "TI"], 
   RowBox[{"-", 
    StyleBox["i", "TI"], " ", 
    StyleBox["\[Tau]", "TI"], " ", 
    SubscriptBox[
     StyleBox["\[Omega]", "TI"], 
     StyleBox["x", "TI"]], "/", "2", 
    SubscriptBox[
     StyleBox["\[Sigma]", "TI"], 
     StyleBox["x", "TI"]]}]]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "6ab835a3-bd08-4c8f-a3fd-e6031e3d86c9"],
 " which corresponds to ",
 Cell[BoxData[
  RowBox[{
   SubscriptBox["\[ScriptCapitalR]", 
    StyleBox["x", "TI"]], 
   StyleBox["(",
    SpanMaxSize->1], 
   RowBox[{
    StyleBox["\[Tau]", "TI"], " ", 
    SubscriptBox[
     StyleBox["\[Omega]", "TI"], 
     StyleBox["x", "TI"]]}], 
   StyleBox[")",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "1b6b68e9-e77d-40b1-88c5-70cf92647e04"],
 ". Equating exponents (or angles) gives ",
 Cell[BoxData[
  RowBox[{
   StyleBox["\[Tau]", "TI"], "=", "\[Pi]", "/", "2", 
   SubscriptBox[
    StyleBox["\[Omega]", "TI"], 
    StyleBox["x", "TI"]]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "7b8c0599-83c5-48b5-abf5-abe39b282e6b"],
 ". If the Hamiltonian is time-dependent such as ",
 Cell[BoxData[
  RowBox[{
   StyleBox["H", "TI"], "=", "1", "/", "2", 
   SubscriptBox[
    StyleBox["\[Omega]", "TI"], 
    StyleBox["x", "TI"]], 
   StyleBox["(",
    SpanMaxSize->1], 
   StyleBox["t", "TI"], 
   StyleBox[")",
    SpanMaxSize->1], 
   SubscriptBox[
    StyleBox["\[Sigma]", "TI"], 
    StyleBox["x", "TI"]]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "b7707fce-e6ef-4df7-b69a-69d435b0fe15"],
 ", because the axis is still fixed, the evolution remains a simple rotation: \
",
 Cell[BoxData[
  RowBox[{
   SubscriptBox["\[ScriptCapitalR]", 
    StyleBox["x", "TI"]], 
   StyleBox["(",
    SpanMaxSize->1], 
   RowBox[{
    UnderoverscriptBox["\[Integral]", "0", 
     StyleBox["\[Tau]", "TI"],
     LimitsPositioning->False], 
    SubscriptBox[
     StyleBox["\[Omega]", "TI"], 
     StyleBox["x", "TI"]], 
    StyleBox["(",
     SpanMaxSize->1], 
    StyleBox["t", "TI"], 
    StyleBox[")",
     SpanMaxSize->1], 
    StyleBox["d", "TI"], 
    StyleBox["t", "TI"]}], 
   StyleBox[")",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "2e1e8a99-4935-44b6-96cb-55697e17f868"],
 " or in SU(2) as ",
 Cell[BoxData[
  SuperscriptBox[
   StyleBox["e", "TI"], 
   RowBox[{"-", 
    StyleBox["i", "TI"], "/", "2", 
    UnderoverscriptBox["\[Integral]", "0", 
     StyleBox["\[Tau]", "TI"],
     LimitsPositioning->False], 
    SubscriptBox[
     StyleBox["\[Omega]", "TI"], 
     StyleBox["x", "TI"]], 
    StyleBox["(",
     SpanMaxSize->1], 
    StyleBox["t", "TI"], 
    StyleBox[")",
     SpanMaxSize->1], 
    StyleBox["d", "TI"], 
    StyleBox["t", "TI"], " ", 
    SubscriptBox[
     StyleBox["\[Sigma]", "TI"], 
     StyleBox["x", "TI"]]}]]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "e3412bcb-f7c3-4afc-ba7f-c1e0b8e353f5"],
 ". So a very interesting takeaway is this: the shape of ",
 Cell[BoxData[
  RowBox[{
   SubscriptBox[
    StyleBox["\[Omega]", "TI"], 
    StyleBox["x", "TI"]], 
   StyleBox["(",
    SpanMaxSize->1], 
   StyleBox["t", "TI"], 
   StyleBox[")",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "84b663e1-a140-4709-b019-9efaaf1422c6"],
 " does not matter for the final rotation as long as the axis stays fixed and \
there are no extra terms. Only the area matters. This is why people can trade \
a square pulse for a Gaussian pulse (for bandwidth/leakage reasons) and still \
implement the same ideal rotation, pure precession makes that possible."
}], "Text",ExpressionUUID->"e897c941-8eb4-4537-9281-113a1ac6d09f"],

Cell["Visualize Gaussian and square pulses:", "Text",ExpressionUUID->"b477a0c3-7688-4156-a37e-e8d219e036c4"],

Cell[BoxData[
 RowBox[{"Manipulate", "[", 
  RowBox[{
   RowBox[{"Quiet", "@", 
    RowBox[{"Plot", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{"\[Piecewise]", " ", 
         RowBox[{"{", "\n", "      ", 
          RowBox[{
           RowBox[{"{", " ", 
            RowBox[{"1.", ",", " ", 
             RowBox[{
              RowBox[{"\[Mu]", " ", "-", " ", 
               RowBox[{
                RowBox[{"Sqrt", "[", 
                 RowBox[{"2", " ", 
                  RowBox[{"Log", "[", "2", "]"}]}], "]"}], " ", 
                "\[Sigma]"}]}], " ", "<=", " ", "\n", "        ", "x", " ", "<",
               " ", 
              RowBox[{"\[Mu]", " ", "+", " ", 
               RowBox[{
                RowBox[{"Sqrt", "[", 
                 RowBox[{"2", " ", 
                  RowBox[{"Log", "[", "2", "]"}]}], "]"}], " ", 
                "\[Sigma]"}]}]}]}], "}"}], ",", "\n", "      ", 
           RowBox[{"{", 
            RowBox[{"0", ",", " ", 
             RowBox[{"\\!", 
              RowBox[{"\\(", "\n", "         ", 
               RowBox[{"TagBox", "[", 
                
                RowBox[{"\"\<True\>\"", ",", "\n", 
                 "          ", "\"\<PiecewiseDefault\>\"", ",", "\n", 
                 "          ", 
                 RowBox[{"DeletionWarning", " ", "->", " ", "True"}], ",", 
                 "\n", "          ", 
                 RowBox[{"AutoDelete", "->", "False"}]}], "]"}], "\\)"}]}]}], 
            "}"}]}], "\n", "     ", "}"}]}], ",", " ", 
        RowBox[{"Exp", "[", 
         RowBox[{
          RowBox[{"-", 
           RowBox[{
            RowBox[{"(", 
             RowBox[{"x", " ", "-", " ", "\[Mu]"}], ")"}], "^", "2"}]}], "/", 
          
          RowBox[{"(", 
           RowBox[{"2", " ", 
            RowBox[{"\[Sigma]", "^", "2"}]}], ")"}]}], "]"}]}], "}"}], ",", 
      " ", 
      RowBox[{"{", 
       RowBox[{"x", ",", " ", 
        RowBox[{"-", ".1"}], ",", " ", "2"}], "}"}], ",", " ", "\n", "   ", 
      RowBox[{
      "PlotLabel", " ", "->", " ", "\"\<Square and Gaussian Pulses\>\""}], ",",
       " ", "\n", "   ", 
      RowBox[{"PlotLegends", " ", "->", " ", 
       RowBox[{"{", 
        RowBox[{"\"\<Gaussian pulse\>\"", ",", " ", "\"\<Square pulse\>\""}], 
        "}"}]}], ",", " ", "\n", "   ", 
      RowBox[{"Exclusions", " ", "->", " ", "None"}], ",", " ", 
      RowBox[{"Filling", " ", "->", " ", "0"}], ",", " ", "\n", "   ", 
      RowBox[{"AxesLabel", " ", "->", " ", 
       RowBox[{"{", " ", 
        RowBox[{"\"\<Time\>\"", ",", " ", "\"\<Pulse magnitude\>\""}], 
        "}"}]}], ",", " ", 
      RowBox[{"PlotRange", " ", "->", " ", "All"}], ",", " ", "\n", "   ", 
      RowBox[{"AspectRatio", " ", "->", " ", 
       RowBox[{"1", "/", "3"}]}], ",", " ", 
      RowBox[{"GridLines", " ", "->", " ", "Automatic"}]}], "]"}]}], ",", " ", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
      "\[Mu]", ",", " ", ".1", ",", " ", "\n", 
       "   ", "\"\<Center of the pulse (max)\>\""}], "}"}], ",", " ", ".1", ",",
      " ", "\n", "  ", "1"}], "}"}], ",", " ", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
      "\[Sigma]", ",", " ", ".03", ",", 
       " ", "\"\<Pulse duration (width)\>\""}], "}"}], ",", " ", ".03", ",", 
     " ", ".5"}], "}"}]}], "]"}]], "Input",
 CellLabel->
  "In[246]:= ",ExpressionUUID->"4588231b-e7e2-4e7b-a9b1-b92be4499862"],

Cell[TextData[{
 "Calculate the total area under a Gaussian pulse with envelop ",
 Cell[BoxData[
  SuperscriptBox[
   StyleBox["e", "TI"], 
   RowBox[{"-", 
    SuperscriptBox[
     RowBox[{
      StyleBox["(",
       SpanMaxSize->1], 
      RowBox[{
       StyleBox["t", "TI"], "-", 
       StyleBox["\[Mu]", "TI"]}], 
      StyleBox[")",
       SpanMaxSize->1]}], "2"], "/", 
    StyleBox["(",
     SpanMaxSize->1], 
    RowBox[{"2", 
     SuperscriptBox[
      StyleBox["\[Tau]", "TI"], "2"]}], 
    StyleBox[")",
     SpanMaxSize->1]}]]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "1c02d025-3a12-40cf-8f96-c6180f6faa0c"],
 ":"
}], "Text",ExpressionUUID->"ba49943b-5337-444d-8683-54ef51821244"],

Cell[BoxData[
 RowBox[{"Integrate", "[", "\n", " ", 
  RowBox[{
   RowBox[{"Exp", "[", 
    RowBox[{
     RowBox[{"-", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{"t", " ", "-", " ", "\[Mu]"}], ")"}], "^", "2"}]}], "/", 
     RowBox[{"(", 
      RowBox[{"2", " ", 
       RowBox[{"\[Tau]", "^", "2"}]}], ")"}]}], "]"}], ",", " ", 
   RowBox[{"{", 
    RowBox[{"t", ",", " ", 
     RowBox[{"-", "\[Infinity]"}], ",", " ", "\[Infinity]"}], "}"}], ",", " ",
    "\n", " ", 
   RowBox[{"Assumptions", " ", "->", " ", 
    RowBox[{"\[Tau]", " ", ">", " ", "0"}]}]}], "]"}]], "Input",
 CellLabel->
  "In[247]:= ",ExpressionUUID->"55a9a691-a990-4626-8ead-a91c70f760b0"],

Cell[TextData[{
 "For a Gaussian pulse, we want the total evolution time to be long enough \
that the entire Gaussian envelope is effectively contained within it. If the \
pulse is turned on at ",
 Cell[BoxData[
  RowBox[{
   StyleBox["t", "TI"], "=", "0"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "3087017b-d394-47d9-a4ed-5e03ae47a284"],
 ", and we describe its envelope by a Gaussian centered at time ",
 Cell[BoxData[
  StyleBox["\[Mu]", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "823a1ada-5f49-4912-b00e-5819f436e40c"],
 " with width ",
 Cell[BoxData[
  StyleBox["\[Tau]", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "d09e7108-830e-432c-aa96-bf023ed9e827"],
 ", then for a clean, well-isolated pulse we choose ",
 Cell[BoxData[
  StyleBox["\[Mu]", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "3bd6e426-bec4-4f9c-9d98-3456392e6920"],
 " larger than its width ",
 Cell[BoxData[
  RowBox[{
   StyleBox["\[Mu]", "TI"], ">", 
   StyleBox["\[Tau]", "TI"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "5269f3cf-d57d-4e5b-a60a-69696e14bf54"],
 ", and we let the evolution run to a final time ",
 Cell[BoxData[
  StyleBox["t", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "e5bfc3df-40f1-4b74-8805-3e9a2a9002a6"],
 " that is also much larger than both \[Mu] and \[Tau]. In this way, the main \
weight of the Gaussian lies well inside the time window ",
 Cell[BoxData[
  RowBox[{
   StyleBox["[",
    SpanMaxSize->1], 
   RowBox[{"0", ",", 
    StyleBox["t", "TI"]}], 
   StyleBox["]",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "7ad232ca-ec33-44fe-bd52-0d2d79e4d9ef"],
 ", and by the time ",
 Cell[BoxData[
  StyleBox["t", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "180e9de6-1fc6-466c-b27b-19da6da9893c"],
 " is reached, the system has effectively \[OpenCurlyDoubleQuote]seen\
\[CloseCurlyDoubleQuote] the full Gaussian pulse."
}], "Text",ExpressionUUID->"8304d86b-fa28-4203-a677-2fa3a22e0645"],

Cell[TextData[{
 "Therefore, for a Hamiltonian as ",
 Cell[BoxData[
  RowBox[{
   StyleBox["H", "TI"], "=", "1", "/", "2", "\[CapitalOmega]", 
   StyleBox["(",
    SpanMaxSize->1], 
   StyleBox["t", "TI"], 
   StyleBox[")",
    SpanMaxSize->1], 
   SubscriptBox[
    StyleBox["\[Sigma]", "TI"], 
    StyleBox["x", "TI"]]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "201229cd-224e-4fa6-b464-f582f9f7571c"],
 " with ",
 Cell[BoxData[
  RowBox[{"\[CapitalOmega]", 
   StyleBox["(",
    SpanMaxSize->1], 
   StyleBox["t", "TI"], 
   StyleBox[")",
    SpanMaxSize->1], "=", 
   SubscriptBox["\[CapitalOmega]", 
    StyleBox[
     RowBox[{"m", "a", "x"}], "TI"]], 
   SuperscriptBox[
    StyleBox["e", "TI"], 
    RowBox[{"-", 
     SuperscriptBox[
      RowBox[{
       StyleBox["(",
        SpanMaxSize->1], 
       RowBox[{
        StyleBox["t", "TI"], "-", 
        StyleBox["\[Mu]", "TI"]}], 
       StyleBox[")",
        SpanMaxSize->1]}], "2"], "/", "2", 
     SuperscriptBox[
      StyleBox["\[Tau]", "TI"], "2"]}]]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "5cf0ad48-a3cf-4089-bfb2-42f6e36a2064"],
 ", the propagator at time ",
 Cell[BoxData[
  StyleBox["t", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "8b28f189-a101-46a1-8412-b04b8f2013c9"],
 " is given by:"
}], "Text",ExpressionUUID->"c9fc33da-da01-4cbd-a8b2-08458529877e"],

Cell[BoxData[{
 RowBox[{"ClearAll", "[", 
  RowBox[{
  "u", ",", " ", "\[CapitalOmega]max", ",", " ", "t", ",", " ", "\[Phi]", ",",
    " ", "f"}], "]"}], "\n", 
 RowBox[{
  RowBox[{"u", " ", "=", " ", 
   RowBox[{
    RowBox[{"DSolveValue", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{"\[FormalU]", "'"}], "[", "\n", "       ", "t", "]"}], " ", 
         "==", " ", 
         RowBox[{
          RowBox[{"-", 
           RowBox[{"(", 
            RowBox[{"I", "/", "2"}], ")"}]}], " ", "\[CapitalOmega]max", " ", 
          
          RowBox[{"Exp", "[", 
           RowBox[{
            RowBox[{"-", 
             RowBox[{
              RowBox[{"(", 
               RowBox[{"t", " ", "-", " ", "\[Mu]"}], ")"}], "^", "2"}]}], "/", 
            RowBox[{"(", "\n", "        ", 
             RowBox[{"2", " ", 
              RowBox[{"\[Tau]", "^", "2"}]}], ")"}]}], "]"}], " ", 
          RowBox[{
           RowBox[{"PauliMatrix", "[", "1", "]"}], " ", ".", " ", 
           RowBox[{"\[FormalU]", "[", "t", "]"}]}]}]}], ",", " ", 
        RowBox[{
         RowBox[{"\[FormalU]", "[", "0", "]"}], " ", "==", " ", "\n", 
         "      ", 
         RowBox[{"IdentityMatrix", "[", "2", "]"}]}]}], "}"}], ",", " ", 
      RowBox[{
       RowBox[{"\[FormalU]", "[", "t", "]"}], " ", "\[Element]", " ", 
       RowBox[{"Matrices", "[", 
        RowBox[{"{", 
         RowBox[{"2", ",", " ", "2"}], "}"}], "]"}]}], ",", " ", "\n", "    ",
       "t", ",", " ", 
      RowBox[{"Assumptions", " ", "->", " ", 
       RowBox[{"\[Tau]", " ", ">", " ", "0"}]}]}], "]"}], " ", "//", " ", 
    "FullSimplify"}]}], ";"}], "\n", 
 RowBox[{"u", " ", "//", " ", "TraditionalForm"}]}], "Input",
 CellLabel->
  "In[248]:= ",ExpressionUUID->"089551e5-2c04-4b27-a6c2-7c9cde11e439"],

Cell[TextData[{
 "where erf is the gives the error function. One can compute a rotation angle \
as ",
 Cell[BoxData[
  RowBox[{
   SubscriptBox[
    StyleBox["\[Theta]", "TI"], 
    StyleBox[
     RowBox[{"g", "a", "u", "s", "s"}], "TI"]], "=", 
   UnderoverscriptBox["\[Integral]", "0", 
    StyleBox["t", "TI"],
    LimitsPositioning->False], "\[CapitalOmega]", 
   StyleBox["(",
    SpanMaxSize->1], 
   StyleBox["s", "TI"], 
   StyleBox[")",
    SpanMaxSize->1], 
   StyleBox["d", "TI"], 
   StyleBox["s", "TI"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "864ed272-bc93-440c-a3a4-9fb0b2094eb2"],
 " which is \[CapitalOmega]max times the area underneath the envelop (i.e. \
pulse area):"
}], "Text",ExpressionUUID->"1e08a908-c173-4d5e-8e69-84da0e2931b3"],

Cell[BoxData[
 RowBox[{"\[Theta]Gaussian", " ", "=", " ", "\n", " ", 
  RowBox[{"Integrate", "[", " ", 
   RowBox[{
    RowBox[{"\[CapitalOmega]max", " ", 
     RowBox[{"Exp", "[", 
      RowBox[{
       RowBox[{"-", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{"s", " ", "-", " ", "\[Mu]"}], ")"}], "^", "2"}]}], "/", 
       RowBox[{"(", 
        RowBox[{"2", " ", 
         RowBox[{"\[Tau]", "^", "2"}]}], ")"}]}], "]"}]}], ",", " ", 
    RowBox[{"{", 
     RowBox[{"s", ",", " ", "\n", "   ", "0", ",", " ", "t"}], "}"}]}], 
   "]"}]}]], "Input",
 CellLabel->
  "In[249]:= ",ExpressionUUID->"053b0059-5661-4998-a220-d127514c7242"],

Cell[TextData[{
 "It can be shown that the above propagator corresponds to an X-pulse with \
the rotation angle ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["\[Theta]", "TI"], 
   StyleBox[
    RowBox[{"g", "a", "u", "s", "s"}], "TI"]]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "b4ea1c52-0c64-44ce-9185-16786616a9ce"],
 ":"
}], "Text",ExpressionUUID->"b410d7b1-f32c-4cdc-b617-75e9fef632b9"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"MatrixExp", "[", 
    RowBox[{
     RowBox[{"-", "I"}], " ", 
     RowBox[{"\[Theta]Gaussian", "/", "2"}], " ", 
     RowBox[{"PauliMatrix", "[", "1", "]"}]}], "]"}], " ", "==", " ", "u"}], 
  " ", "//", " ", "FullSimplify"}]], "Input",
 CellLabel->
  "In[250]:= ",ExpressionUUID->"c8e5ab39-4a16-4e3b-8be9-266489df22ae"],

Cell["\<\
So in simple terms, the pulse area (the time-integral of the drive envelope) \
is what sets the rotation angle: two pulses with the same area implement the \
same rotation, regardless of their shape.\
\>", "Text",ExpressionUUID->"3525a883-0a9c-4d90-ac5d-638f9eac30c0"],

Cell[TextData[{
 "As one can see below, the error function ",
 Cell[BoxData[
  RowBox[{
   StyleBox["Erf",
    FontSlant->"Plain"], 
   StyleBox["[",
    SpanMaxSize->1], 
   StyleBox["x", "TI"], 
   StyleBox["]",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "fba24859-f794-49fa-a03f-627470324ee2"],
 " is ",
 Cell[BoxData[
  RowBox[{"-", "1"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "f8c16f35-3817-4d26-ac9e-cb69fef15275"],
 " when ",
 Cell[BoxData[
  RowBox[{
   StyleBox["x", "TI"], "\[LessLess]", "0"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "e4f133f5-2d23-4887-8d0e-6be14f58aac4"],
 " and it is ",
 Cell[BoxData[
  RowBox[{"+", "1"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "b52e0356-1f68-4096-bcc5-9843d90f5ea0"],
 " for ",
 Cell[BoxData[
  RowBox[{
   StyleBox["x", "TI"], "\[GreaterGreater]", "0"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "30a20e76-b683-4a48-ba97-dd76f5eb4d4b"],
 "."
}], "Text",ExpressionUUID->"6e7ff109-2e98-491c-80eb-1efb0b27d29a"],

Cell[BoxData[
 RowBox[{"Plot", "[", 
  RowBox[{
   RowBox[{"Erf", "[", "x", "]"}], ",", " ", 
   RowBox[{"{", 
    RowBox[{"x", ",", " ", 
     RowBox[{"-", "5"}], ",", " ", "5"}], "}"}], ",", " ", 
   RowBox[{"AspectRatio", " ", "->", " ", 
    RowBox[{"1", "/", "3"}]}], ",", " ", 
   RowBox[{"GridLines", " ", "->", " ", "Automatic"}], ",", " ", "\n", " ", 
   RowBox[{"PlotLabel", " ", "->", " ", "\"\<Error function\>\""}]}], 
  "]"}]], "Input",
 CellLabel->
  "In[251]:= ",ExpressionUUID->"420acff9-7d76-4765-b3b0-d68b7d941305"],

Cell[TextData[{
 "Imposing the condition ",
 Cell[BoxData[
  RowBox[{
   StyleBox["t", "TI"], "\[GreaterGreater]", 
   StyleBox["\[Mu]", "TI"], "\[GreaterGreater]", 
   StyleBox["\[Tau]", "TI"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "2af2e287-4a17-4a8c-b975-170f893b3e9a"],
 " ensures that the error functions in the exact solution saturate: ",
 Cell[BoxData[
  RowBox[{
   StyleBox["E", "TI"], 
   StyleBox["r", "TI"], 
   StyleBox["f", "TI"], 
   StyleBox["[",
    SpanMaxSize->1], 
   RowBox[{
    StyleBox["t", "TI"], "-", 
    StyleBox["\[Mu]", "TI"], "/", 
    SqrtBox["2"], 
    StyleBox["\[Tau]", "TI"]}], 
   StyleBox["]",
    SpanMaxSize->1], "\[Rule]", "1"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "8568523c-19a7-4684-b250-957c30bf0d54"],
 " and ",
 Cell[BoxData[
  RowBox[{
   StyleBox["E", "TI"], 
   StyleBox["r", "TI"], 
   StyleBox["f", "TI"], 
   StyleBox["[",
    SpanMaxSize->1], 
   RowBox[{
    StyleBox["\[Mu]", "TI"], "/", 
    SqrtBox["2"], 
    StyleBox["\[Tau]", "TI"]}], 
   StyleBox["]",
    SpanMaxSize->1], "\[Rule]", "1"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "44cfe748-eee8-420c-b36a-e1ffba3725e5"],
 ". In this limit, the Gaussian pulse is effectively fully-contained in the \
time window ",
 Cell[BoxData[
  RowBox[{
   StyleBox["[",
    SpanMaxSize->1], 
   RowBox[{"0", ",", 
    StyleBox["t", "TI"]}], 
   StyleBox["]",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "e09d74ed-2b0a-4a00-8802-0a3a72b63bfa"],
 ", and the dynamics \[OpenCurlyDoubleQuote]sees\[CloseCurlyDoubleQuote] the \
entire pulse. Therefore, the above solution as be approximated by: ",
 Cell[BoxData[
  RowBox[{
   StyleBox["(",
    SpanMaxSize->1], " ", GridBox[{
     {
      RowBox[{
       StyleBox["c", "TI"], 
       StyleBox["o", "TI"], 
       StyleBox["s", "TI"], 
       StyleBox["(",
        SpanMaxSize->1], 
       RowBox[{
        SqrtBox[
         RowBox[{"\[Pi]", "/", "2"}]], " ", 
        StyleBox["\[Tau]", "TI"], " ", 
        SubscriptBox[
         StyleBox["\[Omega]", "TI"], 
         StyleBox["x", "TI"]]}], 
       StyleBox[")",
        SpanMaxSize->1]}], 
      RowBox[{"-", 
       StyleBox["i", "TI"], " ", 
       StyleBox["s", "TI"], 
       StyleBox["i", "TI"], 
       StyleBox["n", "TI"], 
       StyleBox["(",
        SpanMaxSize->1], 
       RowBox[{
        SqrtBox[
         RowBox[{"\[Pi]", "/", "2"}]], " ", 
        StyleBox["\[Tau]", "TI"], " ", 
        SubscriptBox[
         StyleBox["\[Omega]", "TI"], 
         StyleBox["x", "TI"]]}], 
       StyleBox[")",
        SpanMaxSize->1]}]},
     {
      RowBox[{"-", 
       StyleBox["i", "TI"], " ", 
       StyleBox["s", "TI"], 
       StyleBox["i", "TI"], 
       StyleBox["n", "TI"], 
       StyleBox["(",
        SpanMaxSize->1], 
       RowBox[{
        SqrtBox[
         RowBox[{"\[Pi]", "/", "2"}]], " ", 
        StyleBox["\[Tau]", "TI"], " ", 
        SubscriptBox[
         StyleBox["\[Omega]", "TI"], 
         StyleBox["x", "TI"]]}], 
       StyleBox[")",
        SpanMaxSize->1]}], 
      RowBox[{
       StyleBox["c", "TI"], 
       StyleBox["o", "TI"], 
       StyleBox["s", "TI"], 
       StyleBox["(",
        SpanMaxSize->1], 
       RowBox[{
        SqrtBox[
         RowBox[{"\[Pi]", "/", "2"}]], " ", 
        StyleBox["\[Tau]", "TI"], " ", 
        SubscriptBox[
         StyleBox["\[Omega]", "TI"], 
         StyleBox["x", "TI"]]}], 
       StyleBox[")",
        SpanMaxSize->1]}]}
    }], " ", 
   StyleBox[")",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "fb25e0d5-181e-4517-992a-1f3b5fbfa8c4"],
 ". Using the fact that the area under the Gaussian envelope is ",
 Cell[BoxData[
  RowBox[{
   SqrtBox[
    RowBox[{"2", "\[Pi]"}]], 
   StyleBox["\[Tau]", "TI"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "a3e5bb84-a474-4dd9-bf9f-3ef21ad8b375"],
 ", the unitary generated by the pulse can be approximated as ",
 Cell[BoxData[
  RowBox[{
   SuperscriptBox[
    StyleBox["e", "TI"], 
    RowBox[{"-", 
     StyleBox["i", "TI"], "/", "2", 
     UnderoverscriptBox["\[Integral]", "0", 
      StyleBox["t", "TI"],
      LimitsPositioning->False], 
     SubscriptBox[
      StyleBox["\[Omega]", "TI"], 
      StyleBox["x", "TI"]], 
     StyleBox["(",
      SpanMaxSize->1], 
     StyleBox["s", "TI"], 
     StyleBox[")",
      SpanMaxSize->1], 
     StyleBox["d", "TI"], 
     StyleBox["s", "TI"], " ", 
     SubscriptBox[
      StyleBox["\[Sigma]", "TI"], 
      StyleBox["x", "TI"]]}]], "\[TildeTilde]", 
   SuperscriptBox[
    StyleBox["e", "TI"], 
    RowBox[{"-", 
     StyleBox["i", "TI"], 
     SqrtBox[
      RowBox[{"2", "\[Pi]"}]], 
     StyleBox["\[Tau]", "TI"], " ", 
     SubscriptBox[
      StyleBox["\[Omega]", "TI"], 
      StyleBox["x", "TI"]], "/", "2", " ", 
     SubscriptBox[
      StyleBox["\[Sigma]", "TI"], 
      StyleBox["x", "TI"]]}]]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "d1ed9219-42ba-4c44-b3a1-1cc3c4cf28d3"],
 " which reproduce the same result. So, in this regime, the Gaussian pulse \
behaves like an ",
 Cell[BoxData[
  StyleBox["X", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "dcb9bbac-ab61-4a21-8a07-5f54f0472966"],
 "-pulse whose angle is set by the effective pulse area as ",
 Cell[BoxData[
  RowBox[{
   SqrtBox[
    RowBox[{"2", "\[Pi]"}]], 
   StyleBox["\[Tau]", "TI"], " ", 
   SubscriptBox[
    StyleBox["\[Omega]", "TI"], 
    StyleBox["x", "TI"]]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "26d84b75-72ab-4bfe-8f28-a88936f83331"],
 " ."
}], "Text",ExpressionUUID->"802f92e4-e3b5-4190-b6a8-7831f0ceac32"],

Cell["Part IV: Open Systems and Continuous Measurement", "Section",ExpressionUUID->"6fcbed8c-69c2-46d4-aa2c-da02e54db4a8"],

Cell[TextData[StyleBox["Prerequisite note: this part introduces elementary \
stochastic calculus (Wiener processes, It\[OHat] vs Stratonovich stochastic \
differential equations, It\[OHat]'s lemma, and martingales) from scratch via \
a random-walk analogy. A reader meeting these ideas for the first time may \
want to take the later sections more slowly, or treat them as a guided \
preview rather than a fully self-contained derivation.", "TI"]], "Text",Expres\
sionUUID->"0c669f20-deb4-4ce7-8b11-63dcf6a6e818"],

Cell["Drunken Sailor: Open Quantum Systems", "Subsection",ExpressionUUID->"8f588005-87fd-400c-be06-0f69feab282c"],

Cell["\<\
From the very beginning, when we introduced time evolution, we quietly \
assumed an isolated quantum system: no uncontrolled interactions with \
anything else. In that ideal setting, the dynamics are unitary and governed \
solely by the system\[CloseCurlyQuote]s Hamiltonian. In reality, however, \
almost every quantum system is open: it interacts, often uncontrollably, with \
its surroundings (the \[OpenCurlyDoubleQuote]environment\
\[CloseCurlyDoubleQuote]). Sometimes these environmental couplings are weak \
or occur on energy/time scales that barely affect the dynamics we care about, \
so the isolated-system approximation still works well. In many other \
situations, though, the environment does significantly disturb the system, \
and we can no longer describe the evolution with a simple unitary propagator. \
Instead, we must modify our dynamical equations to incorporate these random, \
uncontrolled influences, this is the central idea behind the theory of open \
quantum systems.\
\>", "Text",ExpressionUUID->"fbbdecb4-8363-4047-8c88-eb05ef5e2686"],

Cell["\<\
How do we model random features in the dynamics? Let\[CloseCurlyQuote]s \
consider a simple example.  Imagine a sailor leaving a pub at night and \
walking along a long, straight dock. Every second, the sailor takes exactly \
one step. Because they are drunk, each step is completely random: with \
probability 1/2 they move one step to the left, and with probability 1/2 they \
move one step to the right.  To describe this more precisely, imagine the \
dock divided into equally spaced markers labeled by integers: \[Ellipsis], \
-2, -1, 0, 1, 2, \[Ellipsis]. The sailor starts at marker 0. After 1 second, \
they are either at marker +1 (one step to the right) or -1 (one step to the \
left). After 2 seconds, depending on the sequence of coin-flip-like choices, \
they might be at +2, 0, or -2. After many steps, their position is some \
random integer that tells us how far they have wandered from the starting \
point and in which direction.  This process is called a random walk. In this \
simple model, time is discrete (1 step, 2 steps, 3 steps, \[Ellipsis]) and \
space is also discrete (the sailor can only stand on integer-labeled \
positions along the dock).\
\>", "Text",ExpressionUUID->"ba4a0e02-5cc4-4637-b6d4-902de1c34cd1"],

Cell["\<\
Define a random walk with probability of 1/2 for moving forward or backward:\
\>", "Text",ExpressionUUID->"35540329-7f9d-4762-8db1-91c9946108b5"],

Cell[BoxData[
 RowBox[{
  RowBox[{"drunkSailorMotion", " ", "=", " ", 
   RowBox[{"RandomWalkProcess", "[", 
    RowBox[{"1", "/", "2"}], "]"}]}], ";"}]], "Input",
 CellLabel->
  "In[252]:= ",ExpressionUUID->"c1b81a74-ff39-4823-be9c-784eac20f524"],

Cell["Simulate random paths:", "Text",ExpressionUUID->"98f4a610-dd90-40a5-b6cb-e781c473dca9"],

Cell[BoxData[
 RowBox[{"Manipulate", "[", "\n", " ", 
  RowBox[{
   RowBox[{"ListLinePlot", "[", 
    RowBox[{
     RowBox[{"RandomFunction", "[", 
      RowBox[{
       RowBox[{"RandomWalkProcess", "[", 
        RowBox[{"1", "/", "2"}], "]"}], ",", " ", 
       RowBox[{"{", 
        RowBox[{"0", ",", " ", "20"}], "}"}], ",", " ", "r"}], "]"}], ",", 
     " ", "\n", "  ", 
     RowBox[{"AxesLabel", " ", "->", " ", 
      RowBox[{"{", 
       RowBox[{"\"\<Steps (time)\>\"", ",", 
        " ", "\"\<Position (markers)\>\""}], "}"}]}], ",", " ", "\n", "  ", 
     RowBox[{"GridLines", " ", "->", " ", "Automatic"}], ",", " ", 
     RowBox[{"PlotMarkers", " ", "->", " ", "Automatic"}], ",", " ", "\n", 
     "  ", 
     RowBox[{"AspectRatio", " ", "->", " ", 
      RowBox[{"1", "/", "2"}]}], ",", " ", "\n", "  ", 
     RowBox[{
     "PlotLabel", " ", "->", 
      " ", "\"\<Trajectory of drunk sailor movement\>\""}]}], "]"}], ",", " ", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
      "r", ",", " ", "1", ",", " ", "\n", "   ", "\"\<Number of paths\>\""}], 
      "}"}], ",", " ", 
     RowBox[{"{", 
      RowBox[{"1", ",", " ", "2", ",", " ", "3", ",", " ", "4"}], "}"}]}], 
    "}"}]}], "]"}]], "Input",
 CellLabel->
  "In[253]:= ",ExpressionUUID->"d2e82d59-0617-442c-9734-592ac71f93ce"],

Cell["\<\
As you can see, each time the sailor walks, the sequence of random steps is \
different, so the trajectory is different and the final position of the drunk \
sailor also changes from one realization to the next. On average, the sailor \
tends to stay around the starting point. But sometimes, purely by chance, \
they drift far to one side. The path is jagged and unpredictable step by \
step, but statistically we can analyze it.\
\>", "Text",ExpressionUUID->"5ed90cc3-6095-4b93-aa8f-d09e3d306b22"],

Cell[TextData[{
 "Denote the number of steps by ",
 Cell[BoxData[
  StyleBox["t", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "d7e3a4e5-1bf7-4e91-ba9c-b13a3e1a4ef6"],
 ", calculate the mean value and also the variance of drunk sailor trajectory:"
}], "Text",ExpressionUUID->"89ded4b5-50ad-4c0d-b171-9fcc38c6452a"],

Cell[BoxData[{
 RowBox[{"Clear", "[", "t", "]"}], "\n", 
 RowBox[{"AssociationThread", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"\"\<Mean\>\"", ",", " ", "\"\<Variance\>\""}], "}"}], ",", " ", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"Mean", "[", 
      RowBox[{"drunkSailorMotion", "[", "t", "]"}], "]"}], ",", " ", "\n", 
     "  ", 
     RowBox[{"Variance", "[", 
      RowBox[{"drunkSailorMotion", "[", "t", "]"}], "]"}]}], "}"}]}], 
  "]"}]}], "Input",
 CellLabel->
  "In[254]:= ",ExpressionUUID->"a13fde33-4cc6-4e1c-9308-4651940a9e26"],

Cell[TextData[{
 "This means that if you look at many such drunken walks and collect the \
final positions after ",
 Cell[BoxData[
  StyleBox["t", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "3c35c01a-b7de-48d4-887f-c732561a369d"],
 " steps, the average position stays near the starting point (0), but the \
typical distance from 0 grows. More precisely, the spread of the positions \
scales like ",
 Cell[BoxData[
  SqrtBox[
   StyleBox["t", "TI"]]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "cfa32e6b-fb08-4364-bae6-09067497e507"],
 ", so the variance (the square of the spread) grows linearly with ",
 Cell[BoxData[
  StyleBox["t", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "95d339db-d0db-4df5-b060-f3699937042d"],
 "."
}], "Text",ExpressionUUID->"91ab18f6-70f6-4c0b-b208-eade06569c10"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"data", " ", "=", " ", 
   RowBox[{"RandomFunction", "[", 
    RowBox[{"drunkSailorMotion", ",", " ", 
     RowBox[{"{", 
      RowBox[{"0", ",", " ", "20"}], "}"}], ",", " ", 
     RowBox[{"10", "^", "5"}]}], "]"}]}], ";"}], "\n", 
 RowBox[{"AssociationThread", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"\"\<Mean\>\"", ",", " ", "\"\<Variance\>\""}], "}"}], ",", " ", 
   "\n", " ", 
   RowBox[{"N", "@", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"Mean", "[", 
       RowBox[{"data", "[", 
        RowBox[{"\"\<SliceData\>\"", ",", " ", "20"}], "]"}], "]"}], ",", " ", 
      RowBox[{"Variance", "[", 
       RowBox[{"data", "[", 
        RowBox[{"\"\<SliceData\>\"", ",", " ", "20"}], "]"}], "]"}]}], 
     "}"}]}]}], "]"}]}], "Input",
 CellLabel->
  "In[255]:= ",ExpressionUUID->"4eb85ff1-0c70-4754-8723-d407bd96a708"],

Cell["\<\
Visualize the histogram of the final position of drunken walks\
\>", "Text",ExpressionUUID->"a324faca-2503-4b61-ac39-fa1153513b0b"],

Cell[BoxData[
 RowBox[{"Module", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"m", ",", " ", "v"}], "}"}], ",", "\n", " ", 
   RowBox[{
    RowBox[{
     RowBox[{"{", 
      RowBox[{"m", ",", " ", "v"}], "}"}], " ", "=", " ", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"Mean", "[", 
        RowBox[{"drunkSailorMotion", "[", "20", "]"}], "]"}], ",", " ", 
       RowBox[{"Variance", "[", 
        RowBox[{"drunkSailorMotion", "[", "20", "]"}], "]"}]}], "}"}]}], ";", 
    "\n", " ", 
    RowBox[{"Histogram", "[", 
     RowBox[{
      RowBox[{"data", "[", 
       RowBox[{"\"\<SliceData\>\"", ",", " ", "20"}], "]"}], ",", " ", 
      "Automatic", ",", " ", "\"\<PDF\>\"", ",", " ", "\n", "  ", 
      RowBox[{"AxesLabel", " ", "->", " ", 
       RowBox[{"{", 
        RowBox[{"\"\<Position\>\"", ",", " ", "\"\<PDF\>\""}], "}"}]}], ",", 
      " ", 
      RowBox[{"GridLinesStyle", " ", "->", " ", "Red"}], ",", " ", "\n", "  ", 
      RowBox[{"GridLines", " ", "->", " ", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{
           RowBox[{"m", " ", "-", " ", 
            RowBox[{"Sqrt", "[", "v", "]"}]}], ",", " ", "m", ",", " ", 
           RowBox[{"m", " ", "+", " ", 
            RowBox[{"Sqrt", "[", "v", "]"}]}]}], "}"}], ",", " ", "None"}], 
        "}"}]}], ",", " ", "\n", "  ", 
      RowBox[{"ChartStyle", " ", "->", " ", 
       RowBox[{"Opacity", "[", ".5", "]"}]}], ",", " ", "\n", "  ", 
      RowBox[{"Ticks", " ", "->", " ", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{
             RowBox[{"m", " ", "-", " ", 
              RowBox[{"Sqrt", "[", "v", "]"}]}], ",", " ", "\n", 
             "      ", "\"\<\[LeftAngleBracket]\\!\\(\\*SubscriptBox[\\(X\\), \
\\(t\\)]\\)\[RightAngleBracket]-\[Sigma]\>\""}], "}"}], ",", " ", 
           RowBox[{"{", 
            RowBox[{
            "m", ",", " ", "\n", 
             "      ", "\"\<\[LeftAngleBracket]\\!\\(\\*SubscriptBox[\\(X\\), \
\\(t\\)]\\)\[RightAngleBracket]\>\""}], "}"}], ",", " ", 
           RowBox[{"{", 
            RowBox[{
             RowBox[{"m", " ", "+", " ", 
              RowBox[{"Sqrt", "[", "v", "]"}]}], ",", " ", "\n", 
             "      ", "\"\<\[LeftAngleBracket]\\!\\(\\*SubscriptBox[\\(X\\), \
\\(t\\)]\\)\[RightAngleBracket]+\[Sigma]\>\""}], "}"}]}], "}"}], ",", " ", 
         "None"}], "}"}]}], ",", " ", 
      RowBox[{"AspectRatio", " ", "->", " ", 
       RowBox[{"1", "/", "3"}]}], ",", " ", "\n", "  ", 
      RowBox[{
      "PlotLabel", " ", "->", 
       " ", "\"\<Histogram of final position of drunken walks\>\""}]}], 
     "]"}]}]}], "]"}]], "Input",
 CellLabel->
  "In[256]:= ",ExpressionUUID->"4a457765-1aa2-4df8-b07c-c39b9cf853b2"],

Cell["From Sailor to Brownian Particle", "Subsection",ExpressionUUID->"e654419c-2f10-4420-87b4-5529d4902498"],

Cell["\<\
Now imagine modifying the drunken sailor\[CloseCurlyQuote]s walk in a \
particular way. You make each step much smaller \[Dash] tiny nudges instead \
of full strides \[Dash] and you make the steps happen much more frequently, \
many times per second. In this limit, the sailor no longer appears to jump \
from marker to marker along the dock. Instead, their position wiggles and \
wobbles almost continuously, with no obvious pauses between steps. The motion \
is still random, but it now looks like a continuous, jittery path rather than \
a sequence of discrete hops. This continuous, randomly fluctuating motion is \
what we call Brownian motion. In other words, one-dimensional Brownian motion \
can be thought of as the continuous-time limit of the drunken sailor\
\[CloseCurlyQuote]s random walk along a line.\
\>", "Text",ExpressionUUID->"40e1f5b4-035b-4db9-b78f-425dadc71cd3"],

Cell["\<\
A classic physical picture of Brownian motion comes from a tiny grain of \
pollen or dust floating on the surface of water. To the naked eye, the water \
seems perfectly still. But under a microscope, the grain does something \
strange: it jitters, jiggles, and wanders in an irregular way. It does not \
glide smoothly in a straight line. Instead, it moves in a constantly \
changing, erratic pattern. The underlying reason is that the water is not \
truly at rest. It is filled with water molecules moving rapidly due to \
thermal motion, and these molecules continuously collide with the larger \
pollen grain from all directions.\
\>", "Text",ExpressionUUID->"9ff8bcd4-1f84-4efb-86f2-92befb70b2f5"],

Cell["\<\
Because the grain is much larger than the water molecules, it feels this \
microscopic bombardment as a sequence of tiny, random kicks. At any instant, \
the kicks are not perfectly balanced: sometimes there is a bit more push from \
the left than from the right, or a slightly stronger push from below than \
from above. As a result, the grain is constantly nudged around in a random \
fashion. This persistent, irregular motion driven by countless unseen \
collisions is what we call Brownian motion.\
\>", "Text",ExpressionUUID->"6949c23b-805d-49ae-86d1-cc1fe4e45639"],

Cell["\<\
The key ideas are: on short time scales and at the microscopic level, the \
motion looks highly irregular and is impossible to predict step by step. \
However, when you look over longer times and across many realizations, the \
average behavior becomes very regular and can be described statistically. \
Importantly, we never try to track every individual collision between water \
molecules and the grain. Instead, we model their combined effect as random \
kicks that produce the observed Brownian motion.\
\>", "Text",ExpressionUUID->"afe32fa8-bdca-449c-81d9-b1c966573296"],

Cell["\<\
In reality, the grain moves in two or three dimensions: on the surface of the \
water or within the fluid. However, to understand the basic idea, it is often \
enough to focus on just one coordinate, for example its horizontal position \
along some line. The full trajectory in space is a wiggly path, but if you \
look only at its projection onto that line, you see a one-dimensional record \
of how it wanders left and right over time. That single coordinate already \
captures the essential randomness and statistical behavior. For this reason, \
we usually start by studying one-dimensional Brownian motion: it is simply a \
description of how far left or right a particle has wandered along a line as \
time goes on.\
\>", "Text",ExpressionUUID->"1300986d-cc8b-4718-a42f-730ecf54f819"],

Cell[TextData[{
 "Mathematically, one-dimensional Brownian motion is often written as a \
stochastic differential equation ",
 Cell[BoxData[
  RowBox[{
   StyleBox["d", "TI"], 
   SubscriptBox[
    StyleBox["x", "TI"], 
    StyleBox["t", "TI"]], "=", 
   SqrtBox[
    RowBox[{"2", "\|01d49f"}]], 
   StyleBox["d", "TI"], 
   SubscriptBox[
    StyleBox["W", "TI"], 
    StyleBox["t", "TI"]]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "c69dd645-db91-43b7-aa07-93abecac926d"],
 " where \|01d49f is the diffusion constant and ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["W", "TI"], 
   StyleBox["t", "TI"]]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "2a60201a-402a-48db-94bf-aa8bca7ede87"],
 " is a Wiener process. A Wiener process is the continuous-time analog of a \
random walk: it has continuous paths, starts at zero, and its increments over \
a time interval of length ",
 Cell[BoxData[
  StyleBox["t", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "61e472d1-f473-4948-952d-9cf7816f2806"],
 " are normally distributed with mean 0 and variance ",
 Cell[BoxData[
  StyleBox["t", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "b7f3868c-f3dd-4eeb-9fd7-9dfa9e36d3b5"],
 ". Equivalently, the position/state ",
 Cell[BoxData[
  StyleBox["x", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "7ddb8112-450c-49f8-95e0-7c214461c07a"],
 " at time ",
 Cell[BoxData[
  StyleBox["t", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "5defca7d-38ab-4e20-80ec-bd86f81c924f"],
 " is a Gaussian random variable whose probability distribution is centered \
at 0 with a spread that grows like the square root of time (the variance is \
proportional to ",
 Cell[BoxData[
  StyleBox["t", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "72781e2a-2904-4a5f-822a-457384843fc5"],
 "). In many soft-matter and biophysics settings, typical diffusion constants \
are on the order of ",
 Cell[BoxData[
  RowBox[{"\|01d49f", "\[NonBreakingSpace]", 
   RowBox[{
    SuperscriptBox["10", 
     RowBox[{"-", "9"}]], " ", 
    SuperscriptBox[
     StyleBox["m", "TI"], "2"], "/", 
    StyleBox["s", "TI"]}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "545981c7-7e9a-445f-a04b-5e58654b2415"],
 " for small ions in water, and about ",
 Cell[BoxData[
  RowBox[{
   SuperscriptBox["10", 
    RowBox[{"-", "13"}]], "-", 
   SuperscriptBox["10", 
    RowBox[{"-", "12"}]], 
   SuperscriptBox[
    StyleBox["m", "TI"], "2"], "/", 
   StyleBox["s", "TI"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "db729250-68ff-4976-b188-0964a5a3a142"],
 " for micron-sized beads in water. Larger particles generally have even \
smaller diffusion constants. The key physical idea is simple: the smaller the \
particle and the less viscous the medium, the larger \|01d49f is, and the \
faster the particle spreads out due to Brownian motion."
}], "Text",ExpressionUUID->"1bb6993d-47d1-497f-a044-ec3c05ac93a1"],

Cell[TextData[{
 "Calculate the mean and variance of Wiener process ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["W", "TI"], 
   StyleBox["t", "TI"]]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "ba4942a7-6cb4-475a-8c99-a47ef1b4bc9e"],
 " (which means a zero drift and one as volatility):"
}], "Text",ExpressionUUID->"a971c02a-b66f-4d85-a864-1731915d7a50"],

Cell[BoxData[
 RowBox[{"With", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"Wt", " ", "=", " ", 
     RowBox[{"WienerProcess", "[", "]"}]}], "}"}], ",", " ", "\n", " ", 
   RowBox[{"AssociationThread", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"\"\<Mean \
\[DoubleStruckCapitalE][\\!\\(\\*SubscriptBox[\\(W\\), \\(t\\)]\\)]\>\"", ",",
        " ", "\n", 
       "   ", "\"\<Variance \
\[DoubleStruckCapitalE][\\!\\(\\*SuperscriptBox[SubscriptBox[\\(W\\), \
\\(t\\)], \\(2\\)]\\)]-\[DoubleStruckCapitalE][\\!\\(\\*SubscriptBox[\\(W\\), \
\\(t\\)]\\)\\!\\(\\*SuperscriptBox[\\(]\\), \\(2\\)]\\)\>\""}], "}"}], ",", 
     " ", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"Mean", "[", 
        RowBox[{"Wt", "[", "t", "]"}], "]"}], ",", " ", "\n", "   ", 
       RowBox[{"Variance", "[", 
        RowBox[{"Wt", "[", "t", "]"}], "]"}]}], "}"}]}], "]"}]}], 
  "]"}]], "Input",
 CellLabel->
  "In[257]:= ",ExpressionUUID->"905004a5-3ea4-4ba2-a70e-1c0e362824d6"],

Cell[TextData[{
 "This means that ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["W", "TI"], 
   StyleBox["t", "TI"]]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "0c2ebdb4-59f4-4a43-9365-a970075a7ee3"],
 " is normally distributed with mean zero and standard deviation ",
 Cell[BoxData[
  SqrtBox[
   StyleBox["t", "TI"]]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "60defb5e-0b6f-4ba4-82f4-d1cecd802d95"],
 ". ",
 Cell[BoxData[
  RowBox[{"\|01d53c", 
   StyleBox["[",
    SpanMaxSize->1], "\[Ellipsis]", 
   StyleBox["]",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "9c1c9dd2-2191-48a6-b03f-5528e861b97f"],
 " means expected value. It\[CloseCurlyQuote]s the operator that takes a \
random variable and returns its average/mean value in the long run (the \
\[OpenCurlyDoubleQuote]probability-weighted average\[CloseCurlyDoubleQuote] \
of all outcomes)."
}], "Text",ExpressionUUID->"45f3b158-2bcd-4cef-9620-1c22ea9c3f1a"],

Cell[TextData[{
 "Calculate the mean value of ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["W", "TI"], 
   StyleBox["t", "TI"]]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "f9c5a912-bf3f-4b44-ad34-705f2bab7f07"],
 " using probability theory:"
}], "Text",ExpressionUUID->"c9cb7cab-f668-4040-9222-959f78b00c76"],

Cell[BoxData[{
 RowBox[{"ClearAll", "[", 
  RowBox[{"Wt", ",", " ", "t"}], "]"}], "\n", 
 RowBox[{"Expectation", "[", 
  RowBox[{"Wt", ",", " ", 
   RowBox[{"Wt", " ", "\[Distributed]", " ", 
    RowBox[{"NormalDistribution", "[", 
     RowBox[{"0", ",", " ", 
      RowBox[{"Sqrt", "[", "t", "]"}]}], "]"}]}]}], "]"}]}], "Input",
 CellLabel->
  "In[258]:= ",ExpressionUUID->"d514ffc6-89b7-46b9-b2ca-91fc88063c38"],

Cell[TextData[{
 "Calculate the variance of ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["W", "TI"], 
   StyleBox["t", "TI"]]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "27e1c9ab-a076-487a-b5cd-d2b8c9527864"],
 " using probability theory ( ",
 Cell[BoxData[
  RowBox[{"\|01d53c", 
   StyleBox["[",
    SpanMaxSize->1], 
   SubsuperscriptBox[
    StyleBox["W", "TI"], 
    StyleBox["t", "TI"], "2"], 
   StyleBox["]",
    SpanMaxSize->1], "-", "\|01d53c", 
   SuperscriptBox[
    RowBox[{
     StyleBox["[",
      SpanMaxSize->1], 
     SubscriptBox[
      StyleBox["W", "TI"], 
      StyleBox["t", "TI"]], 
     StyleBox["]",
      SpanMaxSize->1]}], "2"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "eb8cda46-bbd8-4840-ab79-891a25ba1840"],
 "):"
}], "Text",ExpressionUUID->"8a6bbfb4-0990-4410-9129-68964f3b9a80"],

Cell[BoxData[{
 RowBox[{"ClearAll", "[", 
  RowBox[{"Wt", ",", " ", "t"}], "]"}], "\n", 
 RowBox[{
  RowBox[{"Expectation", "[", 
   RowBox[{
    RowBox[{"Wt", "^", "2"}], ",", " ", 
    RowBox[{"Wt", " ", "\[Distributed]", " ", 
     RowBox[{"NormalDistribution", "[", 
      RowBox[{"0", ",", " ", 
       RowBox[{"Sqrt", "[", "t", "]"}]}], "]"}]}]}], "]"}], " ", "-", " ", 
  "\n", " ", 
  RowBox[{
   RowBox[{"Expectation", "[", 
    RowBox[{"Wt", ",", " ", 
     RowBox[{"Wt", " ", "\[Distributed]", " ", 
      RowBox[{"NormalDistribution", "[", 
       RowBox[{"0", ",", " ", 
        RowBox[{"Sqrt", "[", "t", "]"}]}], "]"}]}]}], "]"}], "^", 
   "2"}]}]}], "Input",
 CellLabel->
  "In[259]:= ",ExpressionUUID->"7700b40f-b311-4807-a04b-baaa6f668da4"],

Cell[TextData[{
 "If we include a nonzero drift \[Mu] and volatility \[Sigma], then after \
time ",
 Cell[BoxData[
  StyleBox["t", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "b6db235c-4fdc-44b1-9dd2-a156fffa8cb7"],
 " the process has mean value ",
 Cell[BoxData[
  RowBox[{
   StyleBox["\[Mu]", "TI"], " ", 
   StyleBox["t", "TI"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "1ccbccfe-8d6b-4198-9db5-d1854f0c3404"],
 " and variance ",
 Cell[BoxData[
  RowBox[{
   StyleBox["t", "TI"], " ", 
   SuperscriptBox[
    StyleBox["\[Sigma]", "TI"], "2"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "c6ae080a-248b-49fe-a10f-817c65c04a3f"],
 ". Equivalently, it is normally distributed with mean ",
 Cell[BoxData[
  RowBox[{
   StyleBox["\[Mu]", "TI"], " ", 
   StyleBox["t", "TI"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "88ae0f40-49a7-41b7-800a-659f8a52fc90"],
 " and standard deviation ",
 Cell[BoxData[
  RowBox[{
   StyleBox["\[Sigma]", "TI"], 
   SqrtBox[
    StyleBox["t", "TI"]]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "bacd26da-0e4b-44fb-871e-834374a44580"],
 "."
}], "Text",ExpressionUUID->"3ee2238c-66fb-482f-9d8c-2e8befb824e3"],

Cell[TextData[{
 "Calculate the mean and variance of a general Wiener process ",
 Cell[BoxData[
  RowBox[{
   SubscriptBox[
    StyleBox["X", "TI"], 
    StyleBox["t", "TI"]], "=", 
   StyleBox["\[Mu]", "TI"], " ", 
   StyleBox["t", "TI"], "+", 
   StyleBox["\[Sigma]", "TI"], " ", 
   SubscriptBox[
    StyleBox["W", "TI"], 
    StyleBox["t", "TI"]]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "99f3869c-8162-46f3-8978-f7fb5fa2ea75"],
 ":"
}], "Text",ExpressionUUID->"fb358171-107d-47ac-8c01-c0b62e782ce8"],

Cell[BoxData[{
 RowBox[{"ClearAll", "[", 
  RowBox[{"\[Mu]", ",", " ", "\[Sigma]"}], "]"}], "\n", 
 RowBox[{"With", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"Wt", " ", "=", " ", 
     RowBox[{"WienerProcess", "[", 
      RowBox[{"\[Mu]", ",", " ", "\[Sigma]"}], "]"}]}], "}"}], ",", " ", "\n",
    " ", 
   RowBox[{"AssociationThread", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"\"\<Mean \
\[DoubleStruckCapitalE][\\!\\(\\*SubscriptBox[\\(W\\), \\(t\\)]\\)]\>\"", ",",
        " ", "\n", 
       "   ", "\"\<Variance \
\[DoubleStruckCapitalE][\\!\\(\\*SuperscriptBox[SubscriptBox[\\(W\\), \
\\(t\\)], \\(2\\)]\\)]-\[DoubleStruckCapitalE][\\!\\(\\*SubscriptBox[\\(W\\), \
\\(t\\)]\\)\\!\\(\\*SuperscriptBox[\\(]\\), \\(2\\)]\\)\>\""}], "}"}], ",", 
     " ", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"Mean", "[", 
        RowBox[{"Wt", "[", "t", "]"}], "]"}], ",", " ", "\n", "   ", 
       RowBox[{"Variance", "[", 
        RowBox[{"Wt", "[", "t", "]"}], "]"}]}], "}"}]}], "]"}]}], 
  "]"}]}], "Input",
 CellLabel->
  "In[260]:= ",ExpressionUUID->"a9a6a168-4e4f-4ff8-8530-ab9c9d81bc02"],

Cell[TextData[{
 "Calculate the mean value of ",
 Cell[BoxData[
  RowBox[{
   SubscriptBox[
    StyleBox["X", "TI"], 
    StyleBox["t", "TI"]], "=", 
   StyleBox["\[Mu]", "TI"], " ", 
   StyleBox["t", "TI"], "+", 
   StyleBox["\[Sigma]", "TI"], " ", 
   SubscriptBox[
    StyleBox["W", "TI"], 
    StyleBox["t", "TI"]]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "603988e5-ff14-45f7-9038-5aed2df0fc0f"],
 " using probability theory:"
}], "Text",ExpressionUUID->"fb7a10df-65c3-42d6-91a6-36ed9119bdc2"],

Cell[BoxData[{
 RowBox[{"ClearAll", "[", 
  RowBox[{"Wt", ",", " ", "\[Sigma]", ",", " ", "\[Mu]", ",", " ", "t"}], 
  "]"}], "\n", 
 RowBox[{"Expectation", "[", 
  RowBox[{
   RowBox[{
    RowBox[{"\[Mu]", " ", "t"}], " ", "+", " ", 
    RowBox[{"\[Sigma]", " ", "Wt"}]}], ",", " ", "\n", " ", 
   RowBox[{"Wt", " ", "\[Distributed]", " ", 
    RowBox[{"NormalDistribution", "[", 
     RowBox[{"0", ",", " ", 
      RowBox[{"Sqrt", "[", "t", "]"}]}], "]"}]}]}], "]"}]}], "Input",
 CellLabel->
  "In[261]:= ",ExpressionUUID->"96b54fc8-f747-42e7-8346-26a003f90217"],

Cell[TextData[{
 "Calculate the variance of ",
 Cell[BoxData[
  RowBox[{
   SubscriptBox[
    StyleBox["X", "TI"], 
    StyleBox["t", "TI"]], "=", 
   StyleBox["\[Mu]", "TI"], " ", 
   StyleBox["t", "TI"], "+", 
   StyleBox["\[Sigma]", "TI"], " ", 
   SubscriptBox[
    StyleBox["W", "TI"], 
    StyleBox["t", "TI"]]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "7e13761a-1cf6-4230-bb4b-b5730fd39f31"],
 " using probability theory:"
}], "Text",ExpressionUUID->"bbe313e2-dffd-4cbe-a04a-765e485d8f63"],

Cell[BoxData[{
 RowBox[{"ClearAll", "[", 
  RowBox[{"Wt", ",", " ", "\[Sigma]", ",", " ", "\[Mu]", ",", " ", "t"}], 
  "]"}], "\n", 
 RowBox[{
  RowBox[{"Expectation", "[", 
   RowBox[{
    RowBox[{
     RowBox[{"(", 
      RowBox[{
       RowBox[{"\[Mu]", " ", "t"}], " ", "+", " ", 
       RowBox[{"\[Sigma]", " ", "Wt"}]}], ")"}], "^", "2"}], ",", " ", "\n", 
    "  ", 
    RowBox[{"Wt", " ", "\[Distributed]", " ", 
     RowBox[{"NormalDistribution", "[", 
      RowBox[{"0", ",", " ", 
       RowBox[{"Sqrt", "[", "t", "]"}]}], "]"}]}]}], "]"}], " ", "-", " ", 
  "\n", " ", 
  RowBox[{
   RowBox[{"Expectation", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"\[Mu]", " ", "t"}], " ", "+", " ", 
      RowBox[{"\[Sigma]", " ", "Wt"}]}], ",", " ", "\n", "   ", 
     RowBox[{"Wt", " ", "\[Distributed]", " ", 
      RowBox[{"NormalDistribution", "[", 
       RowBox[{"0", ",", " ", 
        RowBox[{"Sqrt", "[", "t", "]"}]}], "]"}]}]}], "]"}], "^", 
   "2"}]}]}], "Input",
 CellLabel->
  "In[262]:= ",ExpressionUUID->"01f40f69-39e9-4b7a-856b-54be2c05c559"],

Cell["\<\
Generate an Ito process for a one-dimensional Brownian motion with the \
diffusion constant \|01d49f:\
\>", "Text",ExpressionUUID->"2dd0e75d-36a9-43c9-9856-c7985f9d4784"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"brownian1D", "[", "\[ScriptCapitalD]_", "]"}], " ", ":=", " ", 
   "\n", "  ", 
   RowBox[{"WienerProcess", "[", 
    RowBox[{"0", ",", " ", 
     RowBox[{"Sqrt", "[", 
      RowBox[{"2", " ", "\[ScriptCapitalD]"}], "]"}]}], "]"}]}], 
  ";"}]], "Input",
 CellLabel->
  "In[263]:= ",ExpressionUUID->"b9ff4e84-c189-4b76-9e4e-4b68f060c341"],

Cell[TextData[{
 "Visualize different realization of one-dimensional Brownian motion with ",
 Cell[BoxData[
  RowBox[{"\|01d49f", "=", "1"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "942b40ad-cf9b-4533-8e66-b517ccdb4ad7"],
 ":"
}], "Text",ExpressionUUID->"5e16d8da-2c43-48c3-9e99-a33062166c8c"],

Cell[BoxData[
 RowBox[{"ListLinePlot", "[", 
  RowBox[{
   RowBox[{"RandomFunction", "[", 
    RowBox[{
     RowBox[{"brownian1D", "[", "1", "]"}], ",", " ", 
     RowBox[{"{", 
      RowBox[{"0.", ",", " ", "5.", ",", " ", "0.01"}], "}"}], ",", " ", 
     "4"}], "]"}], ",", " ", "\n", " ", 
   RowBox[{"Frame", " ", "->", " ", "True"}], ",", " ", 
   RowBox[{"AspectRatio", " ", "->", " ", 
    RowBox[{"1", "/", "2"}]}], ",", " ", 
   RowBox[{"GridLines", " ", "->", " ", "Automatic"}], ",", " ", "\n", " ", 
   RowBox[{"FrameLabel", " ", "->", " ", 
    RowBox[{"{", 
     RowBox[{"\"\<Time\>\"", ",", " ", "\"\<Position\>\""}], "}"}]}], ",", 
   " ", "\n", " ", 
   RowBox[{
   "PlotLabel", " ", "->", " ", "\n", 
    "  ", "\"\<Differet paths/realizations of 1D Brownian motion with \
\[ScriptCapitalD]=1\>\""}]}], "]"}]], "Input",
 CellLabel->
  "In[264]:= ",ExpressionUUID->"3c7983f3-df5b-4b45-b8fc-7146f4650c82"],

Cell[TextData[{
 "For a given time ",
 Cell[BoxData[
  StyleBox["t", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "598b7f17-8d08-4157-988c-d18d48c4f000"],
 ", determine the mean value and the variance of the final position of the \
one-dimensional Brownian motion defined above."
}], "Text",ExpressionUUID->"8b47eed0-8b62-4a48-8f56-d8a755bce17c"],

Cell[BoxData[
 RowBox[{"AssociationThread", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"\"\<Mean \[LeftAngleBracket]\\!\\(\\*SubscriptBox[\\(X\\), \
\\(t\\)]\\)\[RightAngleBracket]\>\"", ",", " ", "\n", 
     "  ", "\"\<Variance \
\[LeftAngleBracket]\\!\\(\\*SuperscriptBox[SubscriptBox[\\(X\\), \\(t\\)], \
\\(2\\)]\\)\[RightAngleBracket]-\[LeftAngleBracket]\\!\\(\\*SubscriptBox[\\(X\
\\), \\(t\\)]\\)\\!\\(\\*SuperscriptBox[\\(\[RightAngleBracket]\\), \
\\(2\\)]\\)\>\""}], "}"}], ",", " ", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"Mean", "[", 
      RowBox[{
       RowBox[{"brownian1D", "[", "\[ScriptCapitalD]", "]"}], "[", "t", "]"}],
       "]"}], ",", " ", "\n", "  ", 
     RowBox[{"Variance", "[", 
      RowBox[{
       RowBox[{"brownian1D", "[", "\[ScriptCapitalD]", "]"}], "[", "t", "]"}],
       "]"}]}], "}"}]}], "]"}]], "Input",
 CellLabel->
  "In[265]:= ",ExpressionUUID->"35a5ad3f-66e8-4d59-840d-51824e5d7593"],

Cell["\<\
Note in above we used another common notation for mean and variance.\
\>", "Text",ExpressionUUID->"8d7230bd-e8b2-406c-9008-58f760d9bbef"],

Cell["\<\
Visualize the histogram of the final position of one-dimensional Brownian \
motion:\
\>", "Text",ExpressionUUID->"a3a062a2-e46e-4bed-9256-5bd59d7529f0"],

Cell[BoxData[
 RowBox[{"Module", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{"\[ScriptCapitalD]", " ", "=", " ", "1"}], ",", " ", "m", ",", 
     " ", "v", ",", " ", "data"}], "}"}], ",", "\n", " ", 
   RowBox[{
    RowBox[{"data", " ", "=", " ", 
     RowBox[{
      RowBox[{"RandomFunction", "[", 
       RowBox[{
        RowBox[{"brownian1D", "[", "\[ScriptCapitalD]", "]"}], ",", " ", 
        RowBox[{"{", 
         RowBox[{"0.", ",", " ", "5.", ",", " ", "0.01"}], "}"}], ",", " ", 
        "\n", "    ", "1000"}], "]"}], "[", 
      RowBox[{"\"\<SliceData\>\"", ",", " ", "5"}], "]"}]}], ";", "\n", " ", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"m", ",", " ", "v"}], "}"}], " ", "=", " ", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"Mean", "[", 
        RowBox[{
         RowBox[{"brownian1D", "[", "\[ScriptCapitalD]", "]"}], "[", "5", 
         "]"}], "]"}], ",", " ", "\n", "   ", 
       RowBox[{"Variance", "[", 
        RowBox[{
         RowBox[{"brownian1D", "[", "\[ScriptCapitalD]", "]"}], "[", "5", 
         "]"}], "]"}]}], "}"}]}], ";", "\n", " ", 
    RowBox[{"Histogram", "[", 
     RowBox[{"data", ",", " ", "Automatic", ",", " ", "\"\<PDF\>\"", ",", " ", 
      RowBox[{"AxesLabel", " ", "->", " ", 
       RowBox[{"{", 
        RowBox[{"\"\<Position\>\"", ",", " ", "\"\<PDF\>\""}], "}"}]}], ",", 
      " ", "\n", "  ", 
      RowBox[{"GridLinesStyle", " ", "->", " ", 
       RowBox[{"Directive", "[", 
        RowBox[{"Red", ",", " ", "Thick"}], "]"}]}], ",", " ", "\n", "  ", 
      RowBox[{"GridLines", " ", "->", " ", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{
           RowBox[{"m", " ", "-", " ", 
            RowBox[{"Sqrt", "[", "v", "]"}]}], ",", " ", "m", ",", " ", 
           RowBox[{"m", " ", "+", " ", 
            RowBox[{"Sqrt", "[", "v", "]"}]}]}], "}"}], ",", " ", "None"}], 
        "}"}]}], ",", " ", "\n", "  ", 
      RowBox[{"ChartStyle", " ", "->", " ", 
       RowBox[{"Opacity", "[", ".5", "]"}]}], ",", " ", "\n", "  ", 
      RowBox[{"Ticks", " ", "->", " ", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{
             RowBox[{"m", " ", "-", " ", 
              RowBox[{"Sqrt", "[", "v", "]"}]}], ",", " ", "\n", 
             "      ", "\"\<\[LeftAngleBracket]\\!\\(\\*SubscriptBox[\\(X\\), \
\\(t\\)]\\)\[RightAngleBracket]-\[Sigma]\>\""}], "}"}], ",", " ", 
           RowBox[{"{", 
            RowBox[{
            "m", ",", " ", "\n", 
             "      ", "\"\<\[LeftAngleBracket]\\!\\(\\*SubscriptBox[\\(X\\), \
\\(t\\)]\\)\[RightAngleBracket]\>\""}], "}"}], ",", " ", 
           RowBox[{"{", 
            RowBox[{
             RowBox[{"m", " ", "+", " ", 
              RowBox[{"Sqrt", "[", "v", "]"}]}], ",", " ", "\n", 
             "      ", "\"\<\[LeftAngleBracket]\\!\\(\\*SubscriptBox[\\(X\\), \
\\(t\\)]\\)\[RightAngleBracket]+\[Sigma]\>\""}], "}"}]}], "}"}], ",", " ", 
         "None"}], "}"}]}], ",", " ", 
      RowBox[{"AspectRatio", " ", "->", " ", 
       RowBox[{"1", "/", "3"}]}], ",", " ", "\n", "  ", 
      RowBox[{
      "PlotLabel", " ", "->", 
       " ", "\"\<Histogram of final position of 1D Brownian motion\>\""}]}], 
     "]"}]}]}], "]"}]], "Input",
 CellLabel->
  "In[266]:= ",ExpressionUUID->"df0473fb-4fb7-46c6-8114-fb3a5aabb910"],

Cell["\<\
As expected, the numerical simulations show that the ensemble of final \
positions follows a normal distribution, with mean and standard deviation \
matching the theoretical predictions.\
\>", "Text",ExpressionUUID->"47ba717c-a315-46df-bb3a-b5fe51f8bd60"],

Cell["Noisy Phase of a Laser: Brownian Motion!", "Subsection",ExpressionUUID->"1354fab3-9e94-4948-9c65-d833d4c83730"],

Cell[TextData[{
 "In many textbooks, an ideal laser is pictured as emitting light at a \
single, perfectly sharp frequency ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["\[Nu]", "TI"], "0"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "95ee954c-05c2-419d-b171-93d8fa34f895"],
 ". You can think of its electric field as a perfectly steady wave: constant \
amplitude, fixed frequency, and a phase that never drifts. Mathematically, \
this is written as ",
 Cell[BoxData[
  RowBox[{
   StyleBox["E", "TI"], 
   StyleBox["(",
    SpanMaxSize->1], 
   StyleBox["t", "TI"], 
   StyleBox[")",
    SpanMaxSize->1], "=", 
   SubscriptBox[
    StyleBox["E", "TI"], "0"], 
   SuperscriptBox[
    StyleBox["e", "TI"], 
    RowBox[{"-", 
     StyleBox["i", "TI"], 
     StyleBox["(",
      SpanMaxSize->1], 
     RowBox[{
      SubscriptBox[
       StyleBox["\[Omega]", "TI"], "0"], 
      StyleBox["t", "TI"], "+", 
      SubscriptBox[
       StyleBox["\[Phi]", "TI"], "0"]}], 
     StyleBox[")",
      SpanMaxSize->1]}]]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "94b7277f-082e-43c1-8265-5da8c040503b"],
 " where ",
 Cell[BoxData[
  RowBox[{
   SubscriptBox[
    StyleBox["\[Omega]", "TI"], "0"], "=", "2", "\[Pi]", " ", 
   SubscriptBox[
    StyleBox["\[Nu]", "TI"], "0"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "ed33b3e1-2b18-45e7-b5b9-98fec15b98ca"],
 " is the angular frequency, ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["\[Phi]", "TI"], "0"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "e3e430bc-b35a-4c9b-a975-1cc0c4cde965"],
 " is a fixed phase."
}], "Text",ExpressionUUID->"135207b4-83cb-4aa9-be56-0e4954330e24"],

Cell["Visualize an ideal laser\[CloseCurlyQuote]s electric field:", "Text",ExpressionUUID->"cb065469-3a0f-4ab7-85c9-f2b9dc5c8612"],

Cell[BoxData[
 RowBox[{"Manipulate", "[", "\n", " ", 
  RowBox[{
   RowBox[{"Plot", "[", 
    RowBox[{
     RowBox[{"Cos", "[", 
      RowBox[{
       RowBox[{"\[Omega]", " ", "t"}], " ", "+", " ", "\[Phi]"}], "]"}], ",", 
     " ", 
     RowBox[{"{", 
      RowBox[{"t", ",", " ", "0", ",", " ", "10"}], "}"}], ",", " ", 
     RowBox[{"Frame", " ", "->", " ", "True"}], ",", " ", "\n", "  ", 
     RowBox[{"AspectRatio", " ", "->", " ", 
      RowBox[{"1", "/", "2"}]}], ",", " ", 
     RowBox[{"GridLines", " ", "->", " ", "All"}], ",", " ", "\n", "  ", 
     RowBox[{"FrameLabel", " ", "->", " ", 
      RowBox[{"{", 
       RowBox[{"\"\<Time\>\"", ",", 
        " ", "\"\<Laser's electric field (real part)\>\""}], "}"}]}], ",", 
     " ", "\n", "  ", 
     RowBox[{
     "PlotLabel", " ", "->", 
      " ", "\"\<Perfectly Steady Laser's Electric Field\>\""}]}], "]"}], ",", 
   " ", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
      "\[Omega]", ",", "\n", "    ", "1", ",", 
       " ", "\"\<Angular Frequency \\!\\(\\*SubscriptBox[\\(\[Omega]\\), \\(0\
\\)]\\) \>\""}], "}"}], ",", "\n", "   ", "1", ",", " ", "10"}], "}"}], ",", 
   " ", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
      "\[Phi]", ",", " ", "0", ",", " ", "\n", 
       "   ", "\"\<Phase \\!\\(\\*SubscriptBox[\\(\[Phi]\\), \\(0\\)]\\) \
\>\""}], "}"}], ",", " ", "0", ",", " ", "10"}], "}"}]}], "]"}]], "Input",
 CellLabel->
  "In[267]:= ",ExpressionUUID->"93b07001-b578-4ad0-a34e-8156103af05b"],

Cell["\<\
In the real world, a laser is never perfectly clean. It is driven by noisy \
electronics, mounted on a vibrating table, and coupled to atoms and \
electromagnetic fields in the cavity that are constantly fluctuating. These \
imperfections show up primarily as small, random fluctuations in the laser\
\[CloseCurlyQuote]s phase. The amplitude can remain relatively stable, but \
the phase does not stay fixed; it drifts and jitters in time. Instead of a \
perfectly steady phase, you should picture something like the hand of a clock \
that advances almost uniformly, but is continually given tiny random nudges \
forward and backward. This is the essence of the noisy phase picture.\
\>", "Text",ExpressionUUID->"4eca933f-0635-4ab4-99ff-790e1912ca12"],

Cell[TextData[{
 "We model the random phase ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["\[Phi]", "TI"], 
   StyleBox["t", "TI"]]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "0f4aa3e3-8d75-4e76-8b8a-2e6e4131d6a0"],
 " of the laser as a one-dimensional Brownian motion: ",
 Cell[BoxData[
  RowBox[{
   StyleBox["d", "TI"], 
   SubscriptBox[
    StyleBox["\[Phi]", "TI"], 
    StyleBox["t", "TI"]], "=", 
   SqrtBox[
    RowBox[{"2", 
     StyleBox["\[Kappa]", "TI"]}]], 
   StyleBox["d", "TI"], 
   SubscriptBox[
    StyleBox["W", "TI"], 
    StyleBox["t", "TI"]]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "b6891fea-c7e7-4db3-9f27-7ac580931fff"],
 " where \[Kappa] is the diffusion constant for phase: it tells you how fast \
the laser\[CloseCurlyQuote]s phase wanders, and is directly connected to the \
laser\[CloseCurlyQuote]s linewidth. This stochastic dynamical equation \
implies that ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["\[Phi]", "TI"], 
   StyleBox["t", "TI"]]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "c349a616-dd2b-4e6a-94c0-d2167911acc9"],
 " is a Wiener process with zero mean and variance ",
 Cell[BoxData[
  RowBox[{"2", 
   StyleBox["\[Kappa]", "TI"], " ", 
   StyleBox["t", "TI"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "0fd63da1-14c4-4f0b-8292-03fb0eb31387"],
 ", which can be written as ",
 Cell[BoxData[
  RowBox[{
   StyleBox["\[Phi]", "TI"], 
   StyleBox["(",
    SpanMaxSize->1], 
   StyleBox["t", "TI"], 
   StyleBox[")",
    SpanMaxSize->1], "=", 
   StyleBox["\[Phi]", "TI"], 
   StyleBox["(",
    SpanMaxSize->1], "0", 
   StyleBox[")",
    SpanMaxSize->1], "+", 
   SqrtBox[
    RowBox[{"2", 
     StyleBox["\[Kappa]", "TI"]}]], 
   SubscriptBox[
    StyleBox["W", "TI"], 
    StyleBox["t", "TI"]]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "fe57a008-666a-4be5-bd1e-6bb3242b67d0"],
 "."
}], "Text",ExpressionUUID->"508d8f3a-0a2a-4a38-b51e-cf3762793fe4"],

Cell[TextData[{
 "Generate the real part electric field, ",
 Cell[BoxData[
  RowBox[{
   StyleBox["Cos",
    FontSlant->"Plain"], 
   StyleBox["[",
    SpanMaxSize->1], 
   RowBox[{
    SubscriptBox[
     StyleBox["\[Omega]", "TI"], "0"], 
    StyleBox["t", "TI"], "+", 
    StyleBox["\[Phi]", "TI"], 
    StyleBox["(",
     SpanMaxSize->1], 
    StyleBox["t", "TI"], 
    StyleBox[")",
     SpanMaxSize->1]}], 
   StyleBox["]",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "63585f0d-ffb7-46a0-b523-26221ff1bf53"],
 " with ",
 Cell[BoxData[
  RowBox[{
   SubscriptBox[
    StyleBox["\[Omega]", "TI"], "0"], "=", "1"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "e21ae3e6-90a7-4d72-b9e3-d8ac70bf0100"],
 ", where the phase follows a one-dimensional Brownian motion:"
}], "Text",ExpressionUUID->"fb82dce7-d508-496f-9070-15ee17fab2e3"],

Cell[BoxData[{
 RowBox[{"ClearAll", "[", "electricField", "]"}], "\n", 
 RowBox[{
  RowBox[{"electricField", "[", 
   RowBox[{"\[Omega]_", ",", " ", "\[Kappa]_"}], "]"}], " ", ":=", " ", "\n", 
  " ", 
  RowBox[{"TransformedProcess", "[", "\n", "  ", 
   RowBox[{
    RowBox[{"Cos", "[", 
     RowBox[{
      RowBox[{"\[Omega]", " ", "t"}], " ", "+", " ", 
      RowBox[{"\[Phi]", "[", "t", "]"}]}], "]"}], ",", " ", 
    RowBox[{"\[Phi]", " ", "\[Distributed]", " ", "\n", "   ", 
     RowBox[{"WienerProcess", "[", 
      RowBox[{"0", ",", " ", 
       RowBox[{"Sqrt", "[", 
        RowBox[{"2", " ", "\[Kappa]"}], "]"}]}], "]"}]}], ",", " ", "t"}], 
   "]"}]}]}], "Input",
 CellLabel->
  "In[268]:= ",ExpressionUUID->"6274031b-c7d5-4b3b-ba10-84f951aff7d0"],

Cell[TextData[{
 "Recall that ",
 Cell[BoxData[
  RowBox[{
   StyleBox["W", "TI"], 
   StyleBox["i", "TI"], 
   StyleBox["e", "TI"], 
   StyleBox["n", "TI"], 
   StyleBox["e", "TI"], 
   StyleBox["r", "TI"], 
   StyleBox["P", "TI"], 
   StyleBox["r", "TI"], 
   StyleBox["o", "TI"], 
   StyleBox["c", "TI"], 
   StyleBox["e", "TI"], 
   StyleBox["s", "TI"], 
   StyleBox["s", "TI"], 
   StyleBox["[",
    SpanMaxSize->1], 
   RowBox[{"0", ",", 
    SqrtBox[
     RowBox[{"2", " ", 
      StyleBox["\[Kappa]", "TI"]}]]}], 
   StyleBox["]",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "42996ee4-e591-447a-aee5-db485e77f403"],
 " generates a random process with zero mean and variance ",
 Cell[BoxData[
  RowBox[{"2", 
   StyleBox["\[Kappa]", "TI"], " ", 
   StyleBox["t", "TI"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "a85273d1-f25d-4b7c-a002-768eb638ad4b"],
 "."
}], "Text",ExpressionUUID->"3b86cf92-4fb7-470b-990f-a9c79ea5d74a"],

Cell[TextData[{
 "Compute three realizations of noisy phase, and thus the electric field when \
the diffusion constant is ",
 Cell[BoxData[
  RowBox[{
   StyleBox["\[Kappa]", "TI"], "=", "0.02"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "86b76229-6ffb-433a-a08c-b38b7c247532"],
 " and visualize it:"
}], "Text",ExpressionUUID->"ad102b6f-a792-4862-8c67-170795484795"],

Cell[BoxData[
 RowBox[{"With", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"Et", " ", "=", " ", 
     RowBox[{"electricField", "[", 
      RowBox[{"1", ",", " ", ".02"}], "]"}]}], "}"}], ",", "\n", " ", 
   RowBox[{"ListLinePlot", "[", "\n", "  ", 
    RowBox[{
     RowBox[{"Append", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"RandomFunction", "[", 
         RowBox[{"Et", ",", " ", 
          RowBox[{"{", 
           RowBox[{"0.", ",", " ", "6.", ",", " ", "0.01"}], "}"}], ",", " ", 
          "3"}], "]"}], "[", "\"\<Paths\>\"", "]"}], ",", " ", "\n", "   ", 
       RowBox[{"Table", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"t", ",", " ", 
           RowBox[{"Cos", "[", "t", "]"}]}], "}"}], ",", " ", 
         RowBox[{"{", 
          RowBox[{"t", ",", " ", "0", ",", " ", "6", ",", " ", ".01"}], 
          "}"}]}], "]"}]}], "]"}], ",", " ", "\n", "  ", 
     RowBox[{"PlotStyle", " ", "->", " ", 
      RowBox[{"{", 
       RowBox[{
       "Automatic", ",", " ", "Automatic", ",", " ", "Automatic", ",", " ", 
        "\n", "    ", 
        RowBox[{"Directive", "[", 
         RowBox[{"Thick", ",", " ", "Black"}], "]"}]}], "}"}]}], ",", " ", 
     "\n", "  ", 
     RowBox[{"PlotLegends", " ", "->", " ", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"Sequence", " ", "@@", " ", "\n", "     ", 
         RowBox[{"Table", "[", 
          
          RowBox[{"\"\<A realization of electric field for noisy-phase \
laser\>\"", ",", " ", "3"}], "]"}]}], ",", "\n", 
        "     ", "\"\<Electric field of ideal laser\>\""}], "}"}]}], ",", " ", 
     RowBox[{"AspectRatio", " ", "->", " ", 
      RowBox[{"1", "/", "2"}]}], ",", " ", "\n", "  ", 
     RowBox[{"Frame", " ", "->", " ", "True"}], ",", " ", 
     RowBox[{"FrameLabel", " ", "->", " ", 
      RowBox[{"{", 
       RowBox[{"\"\<Time\>\"", ",", 
        " ", "\"\<Real part of electric field\>\""}], "}"}]}], ",", "\n", 
     "   ", 
     RowBox[{
     "PlotLabel", " ", "->", " ", "\n", 
      "   ", "\"\<Different realization of electric field for a laser with \
noisy phase\n with the diffusion constant set as \[Kappa]=0.02\>\""}]}], 
    "]"}]}], "]"}]], "Input",
 CellLabel->
  "In[269]:= ",ExpressionUUID->"1e95b393-5958-4eab-918c-8740f288bbdc"],

Cell["\<\
As you can see, when the diffusion constant \[Kappa] is small, the noisy \
phase stays very close to the ideal deterministic laser, so the \
Brownian-motion correction to the dynamics is tiny. As \[Kappa] increases, \
the phase diffuses more strongly and the laser field deviates more noticeably \
from the ideal case.\
\>", "Text",ExpressionUUID->"ffd99015-b3c2-4d1f-b326-a1fae4853c16"],

Cell[TextData[{
 "Compute four realizations of noisy phase, and thus the electric field when \
the diffusion constant is ",
 Cell[BoxData[
  RowBox[{
   StyleBox["\[Kappa]", "TI"], "=", "1"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "20d92423-180c-49ac-81f6-5567744c81c7"],
 " and visualize it:"
}], "Text",ExpressionUUID->"f806879e-dbe5-4185-84fc-881a8d99368c"],

Cell[BoxData[
 RowBox[{"With", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"Et", " ", "=", " ", 
     RowBox[{"electricField", "[", 
      RowBox[{"1", ",", " ", "2"}], "]"}]}], "}"}], ",", "\n", " ", 
   RowBox[{"ListLinePlot", "[", "\n", "  ", 
    RowBox[{
     RowBox[{"Append", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"RandomFunction", "[", 
         RowBox[{"Et", ",", " ", 
          RowBox[{"{", 
           RowBox[{"0.", ",", " ", "6.", ",", " ", "0.01"}], "}"}], ",", " ", 
          "3"}], "]"}], "[", "\"\<Paths\>\"", "]"}], ",", " ", "\n", "   ", 
       RowBox[{"Table", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"t", ",", " ", 
           RowBox[{"Cos", "[", "t", "]"}]}], "}"}], ",", " ", 
         RowBox[{"{", 
          RowBox[{"t", ",", " ", "0", ",", " ", "6", ",", " ", ".01"}], 
          "}"}]}], "]"}]}], "]"}], ",", " ", "\n", "  ", 
     RowBox[{"PlotStyle", " ", "->", " ", 
      RowBox[{"{", 
       RowBox[{
       "Automatic", ",", " ", "Automatic", ",", " ", "Automatic", ",", " ", 
        "\n", "    ", 
        RowBox[{"Directive", "[", 
         RowBox[{"Thick", ",", " ", "Black"}], "]"}]}], "}"}]}], ",", " ", 
     "\n", "  ", 
     RowBox[{"PlotLegends", " ", "->", " ", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"Sequence", " ", "@@", " ", "\n", "     ", 
         RowBox[{"Table", "[", 
          
          RowBox[{"\"\<A realization of electric field for noisy-phase \
laser\>\"", ",", " ", "3"}], "]"}]}], ",", "\n", 
        "     ", "\"\<Electric field of ideal laser\>\""}], "}"}]}], ",", " ", 
     RowBox[{"AspectRatio", " ", "->", " ", 
      RowBox[{"1", "/", "2"}]}], ",", " ", "\n", "  ", 
     RowBox[{"Frame", " ", "->", " ", "True"}], ",", " ", 
     RowBox[{"FrameLabel", " ", "->", " ", 
      RowBox[{"{", 
       RowBox[{"\"\<Time\>\"", ",", 
        " ", "\"\<Real part of electric field\>\""}], "}"}]}], ",", "\n", 
     "   ", 
     RowBox[{
     "PlotLabel", " ", "->", " ", "\n", 
      "   ", "\"\<Different realization of electric field for a laser with \
noisy phase\n with the diffusion constant set as \[Kappa]=2\>\""}]}], "]"}]}],
   "]"}]], "Input",
 CellLabel->
  "In[270]:= ",ExpressionUUID->"106cb6b5-8326-45aa-86c7-5e609056f1b8"],

Cell[TextData[{
 "When the diffusion constant is large, the electric field starts to look \
more like a sequence of random jumps. It tends to linger near ",
 Cell[BoxData[
  RowBox[{"+", "1"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "24218991-6d22-4209-95bb-fa020e25c78e"],
 " or ",
 Cell[BoxData[
  RowBox[{"-", "1"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "08495bbd-9151-4e64-8969-b5a8355cbfe5"],
 " for a while and then suddenly flip from one to the other. Keep this \
\[OpenCurlyDoubleQuote]jumping between plateaus\[CloseCurlyDoubleQuote] \
picture in mind; we will return to the same behavior when we discuss random \
quantum dynamics for the Bloch vector."
}], "Text",ExpressionUUID->"2c5b35df-bb68-4562-a24f-5784d196b4e5"],

Cell["\<\
Now imagine generating a large ensemble of noisy laser traces, each one a \
different realization of the fluctuating phase. By averaging the electric \
field over all these realizations at each instant of time, we obtain the \
noise-averaged behavior of the laser field: the underlying coherent \
oscillation with the damping effect of phase noise washed into a smooth, \
averaged signal.\
\>", "Text",ExpressionUUID->"8354de1f-c9dd-4f51-95b1-e98fe13575b1"],

Cell["\<\
Compute the mean value of electric field (i.e., noise-averaged), given its \
Ito process:\
\>", "Text",ExpressionUUID->"64ad5b76-4a11-4dce-9c2c-45b0bd1867a8"],

Cell[BoxData[{
 RowBox[{"ClearAll", "[", 
  RowBox[{"\[Omega]", ",", " ", "\[Kappa]", ",", " ", "t"}], "]"}], "\n", 
 RowBox[{"FullSimplify", "[", 
  RowBox[{
   RowBox[{"Mean", "[", 
    RowBox[{
     RowBox[{"electricField", "[", 
      RowBox[{"\[Omega]", ",", " ", "\[Kappa]"}], "]"}], "[", "t", "]"}], 
    "]"}], ",", " ", 
   RowBox[{"t", " ", ">", " ", "0"}]}], "]"}]}], "Input",
 CellLabel->
  "In[271]:= ",ExpressionUUID->"2d7e306c-a065-4dff-870b-acbf9dddab49"],

Cell["\<\
As you can see, the noisy phase effectively shows up as an exponential \
damping of the electric field when you look at it over time. To make this \
more concrete, we can confirm it numerically: generate many different \
realizations of the laser\[CloseCurlyQuote]s electric field with the same \
noise statistics, and then compute the average field at each time. This \
ensemble average will reveal how the coherent oscillation decays due to phase \
diffusion.\
\>", "Text",ExpressionUUID->"58c080b9-8e8f-4a53-8fba-8cb7ee169398"],

Cell[BoxData[
 RowBox[{"With", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"\[Kappa]", " ", "=", " ", ".2"}], "}"}], ",", " ", 
   RowBox[{"{", 
    RowBox[{"data", " ", "=", " ", "\n", "   ", 
     RowBox[{"RandomFunction", "[", 
      RowBox[{
       RowBox[{"electricField", "[", 
        RowBox[{"1", ",", " ", "\[Kappa]"}], "]"}], ",", " ", 
       RowBox[{"{", 
        RowBox[{"0", ",", " ", "10", ",", " ", ".01"}], "}"}], ",", " ", 
       RowBox[{"10", "^", "3"}]}], "]"}]}], "}"}], ",", " ", "\n", " ", 
   RowBox[{"Plot", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"Cos", "[", "t", "]"}], ",", " ", 
       RowBox[{
        RowBox[{"E", "^", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{"-", "t"}], " ", "\[Kappa]"}], ")"}]}], " ", 
        RowBox[{"Cos", "[", "t", "]"}]}], ",", " ", 
       RowBox[{"Mean", "[", 
        RowBox[{"data", "[", "t", "]"}], "]"}]}], "}"}], ",", " ", 
     RowBox[{"{", 
      RowBox[{"t", ",", " ", "0", ",", " ", "10"}], "}"}], ",", " ", "\n", 
     "  ", 
     RowBox[{"PlotRange", " ", "->", " ", "All"}], ",", " ", "\n", "  ", 
     RowBox[{"PlotLegends", " ", "->", " ", 
      RowBox[{"{", 
       RowBox[{"\"\<No noise case\>\"", ",", 
        " ", "\"\<Exact noise-averaged data\>\"", ",", " ", "\n", 
        "    ", "\"\<Numerical averaging over noise\>\""}], "}"}]}], ",", " ", 
     RowBox[{"AspectRatio", " ", "->", " ", 
      RowBox[{"1", "/", "2"}]}], ",", " ", "\n", "  ", 
     RowBox[{"GridLines", " ", "->", " ", "Automatic"}], ",", " ", "\n", "  ", 
     RowBox[{
     "PlotLabel", " ", "->", " ", "\n", 
      "   ", "\"\<No noise, vs noisy electric field, after averaging over \
noise\n \[Kappa]=0.2 and \[Omega]=1\>\""}], ",", " ", 
     RowBox[{"FrameLabel", " ", "->", " ", 
      RowBox[{"{", 
       RowBox[{"\"\<Time\>\"", ",", " ", "\"\<Electric Field\>\""}], "}"}]}], 
     ",", "\n", "   ", 
     RowBox[{"Frame", " ", "->", " ", "True"}]}], "]"}]}], "]"}]], "Input",
 CellLabel->
  "In[272]:= ",ExpressionUUID->"077b1769-bda0-40b0-af0c-46c008ee4d6c"],

Cell["\<\
So let\[CloseCurlyQuote]s rephrase what our simple model is describing. \
Imagine that at time zero you line up a huge number of microscopic \
oscillators (e.g., atoms) all with exactly the same phase. In that instant \
they behave like one big classical arrow/dipole: all the little arrows on the \
complex plane point the same way and add up to a large net arrow. The \
electromagnetic field radiated by this ensemble is essentially proportional \
to that net arrow, i.e. to the ensemble-averaged electric field. So, at the \
beginning, the \[OpenCurlyDoubleQuote]signal\[CloseCurlyDoubleQuote] you care \
about really is the mean field of this collection of oscillators.\
\>", "Text",ExpressionUUID->"32a71415-d724-40c6-9c77-c1ade0c1413b"],

Cell["\<\
As phase diffusion progresses, the individual microscopic oscillators wander \
in phase and partially cancel, so the mean field decays in time. In our \
model, that decay is an exponentially damped oscillation. Now given this \
mechanism, how much power does this thing emit at each frequency? This is \
what we call as the spectral density. When you ask for the spectral density, \
you\[CloseCurlyQuote]re really asking, \[OpenCurlyDoubleQuote]What is the \
frequency content of this coherent transient emitted by the decaying dipole?\
\[CloseCurlyDoubleQuote] The appropriate object to Fourier transform is the \
time-dependent field produced by that dipole, i.e. the mean electric field \
itself. Because its envelope decays exponentially, its spectrum is \
Lorentzian, with the linewidth set by the same rate that controls the loss of \
coherence.\
\>", "Text",ExpressionUUID->"9e93e942-44a4-4c3c-88e2-e82eff1a8bc5"],

Cell["\<\
Calculate the spectral density by computing the Fourier transform of the mean \
electric field:\
\>", "Text",ExpressionUUID->"d4d0337a-0540-4246-86a2-f7624e724fa0"],

Cell[BoxData[
 RowBox[{
  RowBox[{"\[ScriptCapitalS]", "[", 
   RowBox[{"\[Omega]_", ",", " ", "\[Kappa]_", ",", " ", "\[Omega]0_"}], 
   "]"}], " ", "=", " ", "\n", " ", 
  RowBox[{
   RowBox[{"FourierTransform", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"E", "^", 
       RowBox[{"(", 
        RowBox[{
         RowBox[{"-", 
          RowBox[{"Abs", "[", "t", "]"}]}], " ", "\[Kappa]"}], ")"}]}], " ", 
      RowBox[{"Cos", "[", 
       RowBox[{"t", " ", "\[Omega]0"}], "]"}]}], ",", " ", "\n", "   ", "t", ",",
      " ", "\[Omega]"}], "]"}], " ", "//", " ", "FullSimplify"}]}]], "Input",
 CellLabel->
  "In[273]:= ",ExpressionUUID->"1da4b313-4fb4-4bbe-9b10-2eeda8b9bee5"],

Cell["Visualize the spectral density:", "Text",ExpressionUUID->"35a6601c-12d6-44f0-9934-92200ffe7b5c"],

Cell[BoxData[
 RowBox[{"Manipulate", "[", "\n", " ", 
  RowBox[{
   RowBox[{"Plot", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"(", 
       RowBox[{
        RowBox[{"Sqrt", "[", "\n", "   ", 
         RowBox[{"2", "/", "\[Pi]"}], "]"}], " ", "\[Kappa]", " ", 
        RowBox[{"(", 
         RowBox[{
          RowBox[{"\[Kappa]", "^", "2"}], " ", "+", " ", 
          RowBox[{"\[Omega]", "^", "2"}], " ", "+", " ", 
          RowBox[{"\[Omega]0", "^", "2"}]}], ")"}]}], ")"}], "/", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{"\\\n", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{"\[Kappa]", "^", "2"}], " ", "+", " ", 
           RowBox[{
            RowBox[{"(", 
             RowBox[{"\[Omega]", " ", "-", " ", "\[Omega]0"}], ")"}], "^", 
            "2"}]}], ")"}]}], " ", 
        RowBox[{"(", 
         RowBox[{
          RowBox[{"\[Kappa]", "^", "2"}], " ", "+", " ", 
          RowBox[{
           RowBox[{"(", 
            RowBox[{"\[Omega]", " ", "+", " ", 
             RowBox[{"\\\n", "\[Omega]0"}]}], ")"}], "^", "2"}]}], ")"}]}], 
       ")"}]}], ",", " ", 
     RowBox[{"{", 
      RowBox[{"\[Omega]", ",", " ", 
       RowBox[{"-", "10"}], ",", " ", "10"}], "}"}], ",", " ", 
     RowBox[{"PlotRange", " ", "->", " ", "All"}], ",", " ", "\n", "  ", 
     RowBox[{"Ticks", " ", "->", " ", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{
           "\[Omega]0", ",", " ", "\n", 
            "      ", "\"\<\\!\\(\\*SubscriptBox[\\(\[Omega]\\), \
\\(0\\)]\\)\>\""}], "}"}], ",", " ", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"-", "\[Omega]0"}], ",", " ", "\n", 
            "      ", "\"\<-\\!\\(\\*SubscriptBox[\\(\[Omega]\\), \\(0\\)]\\)\
\>\""}], "}"}]}], "}"}], ",", " ", "None"}], "}"}]}], ",", " ", "\n", "  ", 
     RowBox[{
     "PlotLabel", " ", "->", 
      " ", "\"\<Spectral density of a stochastic phase laser\>\""}], ",", " ",
      "\n", "  ", 
     RowBox[{"AspectRatio", " ", "->", " ", 
      RowBox[{"1", "/", "3"}]}], ",", " ", "\n", "  ", 
     RowBox[{"AxesLabel", " ", "->", " ", 
      RowBox[{"{", 
       RowBox[{"\"\<\[Omega]\>\"", ",", " ", "None"}], "}"}]}]}], "]"}], ",", 
   " ", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
      "\[Kappa]", ",", " ", ".1", ",", " ", "\n", 
       "   ", "\"\<Diffusion constant \[Kappa]\>\""}], "}"}], ",", " ", 
     RowBox[{"10", "^", 
      RowBox[{"-", "3"}]}], ",", " ", "\n", "  ", "1"}], "}"}], ",", " ", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
      "\[Omega]0", ",", " ", "4", ",", " ", "\n", 
       "   ", "\"\<Angular frequency \\!\\(\\*SubscriptBox[\\(\[Omega]\\), \
\\(0\\)]\\)\>\""}], "}"}], ",", " ", "1", ",", " ", "\n", "  ", "5"}], 
    "}"}]}], "]"}]], "Input",
 CellLabel->
  "In[274]:= ",ExpressionUUID->"10b9b609-6b44-4664-a236-9613185b28e7"],

Cell[TextData[{
 "Please note that for any general case, the spectral density should be \
calculated from two-point correlation functions ",
 Cell[BoxData[
  RowBox[{
   StyleBox["\[LeftAngleBracket]",
    SpanMaxSize->1], 
   RowBox[{
    StyleBox["E", "TI"], 
    StyleBox["(",
     SpanMaxSize->1], 
    StyleBox["t", "TI"], 
    StyleBox[")",
     SpanMaxSize->1], 
    StyleBox["E", "TI"], 
    StyleBox["(",
     SpanMaxSize->1], 
    RowBox[{
     StyleBox["t", "TI"], "+", 
     StyleBox["\[Tau]", "TI"]}], 
    StyleBox[")",
     SpanMaxSize->1]}], 
   StyleBox["\[RightAngleBracket]",
    SpanMaxSize->1], "=", "\|01d53c", 
   StyleBox["(",
    SpanMaxSize->1], 
   RowBox[{
    StyleBox["C", "TI"], 
    StyleBox["o", "TI"], 
    StyleBox["s", "TI"], 
    StyleBox["[",
     SpanMaxSize->1], 
    RowBox[{
     StyleBox["\[Omega]", "TI"], "0", " ", 
     StyleBox["(",
      SpanMaxSize->1], 
     RowBox[{
      StyleBox["t", "TI"], "+", 
      StyleBox["\[Tau]", "TI"]}], 
     StyleBox[")",
      SpanMaxSize->1], "+", "\[CapitalPhi]", "2"}], 
    StyleBox["]",
     SpanMaxSize->1], " ", 
    StyleBox["C", "TI"], 
    StyleBox["o", "TI"], 
    StyleBox["s", "TI"], 
    StyleBox["[",
     SpanMaxSize->1], 
    RowBox[{
     StyleBox["\[Omega]", "TI"], "0", " ", 
     StyleBox["t", "TI"], "+", "\[CapitalPhi]", "1"}], 
    StyleBox["]",
     SpanMaxSize->1]}], 
   StyleBox[")",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "d6ee10bb-e5c4-4915-b71b-cfe690e9190d"],
 " with ",
 Cell[BoxData[
  SubscriptBox["\[CapitalPhi]", 
   RowBox[{"1", ",", "2"}]]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "2360311e-d89f-498a-b4ed-4edd05faa3ad"],
 " random phases. For a two-time correlation you care about a random quantity \
at one time and the same quantity at another time, and how those two are \
linked. The covariance matrix is just the compact way to encode that link.  \
For two times, it has three essential pieces of information: how much the \
variable fluctuates at the first time, how much it fluctuates at the second \
time, and how much of those fluctuations are shared between the two times. \
The shared part is the covariance: if it is large and positive, knowing the \
value at the first time strongly constrains the likely value at the second \
time; if it is zero, the two times are effectively independent.  When you \
compute a two-time correlation function, you are averaging a product that \
depends on the variable at both times. That average is entirely determined by \
the joint statistics of the pair, and for a Gaussian process those joint \
statistics are fully fixed by the covariance matrix. So in practice: the \
diagonal entries set the \[OpenCurlyDoubleQuote]strength\
\[CloseCurlyDoubleQuote] of fluctuations at each time, and the off-diagonal \
entry encodes the memory between them; together they determine how big the \
two-time correlation is and how it decays with the time difference."
}], "Text",ExpressionUUID->"c32c3fe3-627e-42cc-85a1-5ec628e13176"],

Cell[TextData[{
 "Calculate the covariance matrix ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["\[Phi]", "TI"], 
   StyleBox["t", "TI"]]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "0b1888aa-d4ba-4551-bcfd-f8f5a9038359"],
 " and ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["\[Phi]", "TI"], 
   RowBox[{
    StyleBox["t", "TI"], "+", 
    StyleBox["\[Tau]", "TI"]}]]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "5d73aa05-7bba-44b4-976d-84bbaefba0a5"],
 " which is ",
 Cell[BoxData[
  RowBox[{"\[CapitalSigma]", "=", "(", GridBox[{
     {
      RowBox[{
       StyleBox["C", "TI"], 
       StyleBox["o", "TI"], 
       StyleBox["v", "TI"], 
       StyleBox["[",
        SpanMaxSize->1], 
       RowBox[{
        SubscriptBox[
         StyleBox["\[Phi]", "TI"], 
         StyleBox["t", "TI"]], ",", 
        SubscriptBox[
         StyleBox["\[Phi]", "TI"], 
         StyleBox["t", "TI"]]}], 
       StyleBox["]",
        SpanMaxSize->1]}], 
      RowBox[{
       StyleBox["C", "TI"], 
       StyleBox["o", "TI"], 
       StyleBox["v", "TI"], 
       StyleBox["[",
        SpanMaxSize->1], 
       RowBox[{
        SubscriptBox[
         StyleBox["\[Phi]", "TI"], 
         StyleBox["t", "TI"]], ",", 
        SubscriptBox[
         StyleBox["\[Phi]", "TI"], 
         RowBox[{
          StyleBox["t", "TI"], "+", 
          StyleBox["\[Tau]", "TI"]}]]}], 
       StyleBox["]",
        SpanMaxSize->1]}]},
     {
      RowBox[{
       StyleBox["C", "TI"], 
       StyleBox["o", "TI"], 
       StyleBox["v", "TI"], 
       StyleBox["[",
        SpanMaxSize->1], 
       RowBox[{
        SubscriptBox[
         StyleBox["\[Phi]", "TI"], 
         RowBox[{
          StyleBox["t", "TI"], "+", 
          StyleBox["\[Tau]", "TI"]}]], ",", 
        SubscriptBox[
         StyleBox["\[Phi]", "TI"], 
         StyleBox["t", "TI"]]}], 
       StyleBox["]",
        SpanMaxSize->1]}], 
      RowBox[{
       StyleBox["C", "TI"], 
       StyleBox["o", "TI"], 
       StyleBox["v", "TI"], 
       StyleBox["[",
        SpanMaxSize->1], 
       RowBox[{
        SubscriptBox[
         StyleBox["\[Phi]", "TI"], 
         RowBox[{
          StyleBox["t", "TI"], "+", 
          StyleBox["\[Tau]", "TI"]}]], ",", 
        SubscriptBox[
         StyleBox["\[Phi]", "TI"], 
         RowBox[{
          StyleBox["t", "TI"], "+", 
          StyleBox["\[Tau]", "TI"]}]]}], 
       StyleBox["]",
        SpanMaxSize->1]}]}
    }], ")"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "9ce79877-6688-41c7-9aeb-dda68e065be8"],
 " with ",
 Cell[BoxData[
  RowBox[{
   StyleBox["Cov",
    FontSlant->"Plain"], 
   StyleBox["[",
    SpanMaxSize->1], "\[Ellipsis]", 
   StyleBox["]",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "aad1a707-8541-4b23-8493-4ae6fed51baa"],
 " the covariance function:"
}], "Text",ExpressionUUID->"bf5d3b34-6908-42c8-b07a-14328c635774"],

Cell[BoxData[
 RowBox[{"\[CapitalSigma]", " ", "=", " ", "\n", " ", 
  RowBox[{"FullSimplify", "[", "\n", "  ", 
   RowBox[{
    RowBox[{"Table", "[", 
     RowBox[{
      RowBox[{"CovarianceFunction", "[", 
       RowBox[{
        RowBox[{"WienerProcess", "[", 
         RowBox[{"0", ",", " ", 
          RowBox[{"Sqrt", "[", 
           RowBox[{"2", " ", "\[Kappa]"}], "]"}]}], "]"}], ",", " ", "t1", ",",
         " ", "\n", "    ", "t2"}], "]"}], ",", " ", 
      RowBox[{"{", 
       RowBox[{"t1", ",", " ", 
        RowBox[{"{", 
         RowBox[{"t", ",", " ", 
          RowBox[{"t", " ", "+", " ", "\[Tau]"}]}], "}"}]}], "}"}], ",", " ", 
      
      RowBox[{"{", 
       RowBox[{"t2", ",", " ", 
        RowBox[{"{", 
         RowBox[{"t", ",", " ", 
          RowBox[{"t", " ", "+", " ", "\[Tau]"}]}], "}"}]}], "}"}]}], "]"}], ",",
     " ", 
    RowBox[{"\[Tau]", " ", ">", " ", "0"}]}], "]"}]}]], "Input",
 CellLabel->
  "In[275]:= ",ExpressionUUID->"3f801fac-3138-4245-b838-2f6dcc86b535"],

Cell[TextData[{
 "Given the covariance matrix \[CapitalSigma], calculate the two-time \
correlation function ",
 Cell[BoxData[
  RowBox[{
   StyleBox["\[LeftAngleBracket]",
    SpanMaxSize->1], 
   RowBox[{
    StyleBox["E", "TI"], 
    StyleBox["(",
     SpanMaxSize->1], 
    StyleBox["t", "TI"], 
    StyleBox[")",
     SpanMaxSize->1], 
    StyleBox["E", "TI"], 
    StyleBox["(",
     SpanMaxSize->1], 
    RowBox[{
     StyleBox["t", "TI"], "+", 
     StyleBox["\[Tau]", "TI"]}], 
    StyleBox[")",
     SpanMaxSize->1]}], 
   StyleBox["\[RightAngleBracket]",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "d3f8f443-6e8f-4e4e-a739-b143b033c150"],
 ":"
}], "Text",ExpressionUUID->"6793e36b-7560-40f6-9c87-608044f4cc12"],

Cell[BoxData[
 RowBox[{
  RowBox[{"\[ScriptCapitalC]", "[", 
   RowBox[{
   "\[Omega]0_", ",", " ", "\[Kappa]_", ",", " ", "t_", ",", " ", "\[Tau]_"}],
    "]"}], " ", "=", " ", "\n", " ", 
  RowBox[{
   RowBox[{"Expectation", "[", "\n", "   ", 
    RowBox[{
     RowBox[{
      RowBox[{"Cos", "[", 
       RowBox[{
        RowBox[{"\[Omega]0", " ", 
         RowBox[{"(", 
          RowBox[{"t", " ", "+", " ", "\[Tau]"}], ")"}]}], " ", "+", " ", 
        "\[CapitalPhi]2"}], "]"}], " ", 
      RowBox[{"Cos", "[", 
       RowBox[{
        RowBox[{"\[Omega]0", " ", "t"}], " ", "+", " ", 
        RowBox[{"\\\n", "\[CapitalPhi]1"}]}], "]"}]}], ",", " ", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"\[CapitalPhi]1", ",", " ", "\[CapitalPhi]2"}], "}"}], " ", "\[Distributed]",
        " ", "\n", "     ", 
       RowBox[{"MultinormalDistribution", "[", "\[CapitalSigma]", "]"}]}], 
      "}"}]}], "]"}], " ", "//", " ", "FullSimplify"}]}]], "Input",
 CellLabel->
  "In[276]:= ",ExpressionUUID->"4ade4630-e12f-4f19-94b7-78d98eeace40"],

Cell["Visualize the two-time correlation functions:", "Text",ExpressionUUID->"06c9d7fb-d851-4807-8c66-9f6d65cab2c7"],

Cell[BoxData[
 RowBox[{"Manipulate", "[", "\n", " ", 
  RowBox[{
   RowBox[{"Plot", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{
        RowBox[{"1", "/", "4"}], " ", 
        RowBox[{"E", "^", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{
            RowBox[{"-", "\[Kappa]"}], " ", 
            RowBox[{"(", 
             RowBox[{
              RowBox[{"4", " ", "t"}], " ", "+", " ", "\[Tau]"}], ")"}]}], 
           " ", "-", " ", "\n", "     ", 
           RowBox[{"I", " ", 
            RowBox[{"(", 
             RowBox[{
              RowBox[{"2", " ", "t"}], " ", "+", " ", "\[Tau]"}], ")"}], " ", 
            "\[Omega]0"}]}], ")"}]}], " ", 
        RowBox[{"(", 
         RowBox[{"1", " ", "+", " ", 
          RowBox[{"E", "^", 
           RowBox[{"(", "\n", "      ", 
            RowBox[{"2", " ", "I", " ", 
             RowBox[{"(", 
              RowBox[{
               RowBox[{"2", " ", "t"}], " ", "+", " ", "\[Tau]"}], ")"}], " ",
              "\[Omega]0"}], ")"}]}], " ", "+", " ", "\n", "      ", 
          RowBox[{
           RowBox[{"E", "^", 
            RowBox[{"(", 
             RowBox[{
              RowBox[{"4", " ", "t", " ", "\[Kappa]"}], " ", "+", " ", "\n", 
              "        ", 
              RowBox[{"2", " ", "I", " ", "t", " ", "\[Omega]0"}]}], ")"}]}], 
           " ", 
           RowBox[{"(", 
            RowBox[{"1", " ", "+", " ", 
             RowBox[{"E", "^", 
              RowBox[{"(", 
               RowBox[{"2", " ", "I", " ", "\[Tau]", " ", "\[Omega]0"}], 
               ")"}]}]}], ")"}]}]}], ")"}]}], ",", " ", "\n", "   ", 
       RowBox[{
        RowBox[{"1", "/", "2"}], " ", 
        RowBox[{"E", "^", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{"-", "\[Kappa]"}], " ", "\[Tau]"}], ")"}]}], " ", 
        RowBox[{"Cos", "[", 
         RowBox[{"\[Omega]0", " ", "\[Tau]"}], "]"}]}]}], "}"}], ",", " ", 
     RowBox[{"{", 
      RowBox[{"\[Tau]", ",", " ", "0", ",", " ", "10"}], "}"}], ",", " ", 
     "\n", "  ", 
     RowBox[{"PlotRange", " ", "->", " ", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"-", "1.1"}], ",", " ", "1.1"}], "}"}]}], ",", " ", 
     RowBox[{"GridLines", " ", "->", " ", "Automatic"}], ",", " ", 
     RowBox[{"Frame", " ", "->", " ", "True"}], ",", " ", "\n", "  ", 
     RowBox[{"PlotPoints", " ", "->", " ", "50"}], ",", " ", "\n", "  ", 
     RowBox[{"PlotLegends", " ", "->", " ", 
      RowBox[{"{", 
       RowBox[{"\"\<\\!\\(\\*FormBox[\\(Two\:f88c\:f88c - time\\\\ \
correlation\\\\ \[LeftAngleBracket]\\(E(t)\\) \\(E(t\:f88c\:f88c + \[Tau])\\)\
\[RightAngleBracket]\\),\nTraditionalForm]\\)\>\"", ",", " ", "\n", 
        "    ", "\"\<Stationary limit of two-time correlation\n \
\\!\\(\\*SubscriptBox[\\(Limit\\), \\(t\:f88c -> \[Infinity]\\)]\\) \
\\!\\(\\*FormBox[\\(\[LeftAngleBracket]\\(E(t)\\) \\(E(t\:f88c\:f88c + \
\[Tau])\\)\[RightAngleBracket]\\),\nTraditionalForm]\\)=\\!\\(\\*FormBox[\\(\
\[LeftAngleBracket]\\(E(0)\\) \\(E(\[Tau])\\)\[RightAngleBracket]\\),\n\
TraditionalForm]\\)\>\""}], "}"}]}], ",", " ", "\n", "  ", 
     RowBox[{
     "PlotLabel", " ", "->", " ", "\n", 
      "   ", "\"\<Two-time correlation function \[LeftAngleBracket]E(t)E(t+\
\[Tau])\[RightAngleBracket]\>\""}], ",", "\n", "   ", 
     RowBox[{"AspectRatio", " ", "->", " ", 
      RowBox[{"1", "/", "2"}]}], ",", " ", "\n", "  ", 
     RowBox[{"FrameLabel", " ", "->", " ", 
      RowBox[{"{", 
       RowBox[{"\"\<\[Tau]\>\"", ",", 
        " ", "\"\<\[LeftAngleBracket]E(t)E(t+\[Tau])\[RightAngleBracket]\>\""}\
], "}"}]}]}], "]"}], ",", "\n", " ", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
      "\[Omega]0", ",", " ", "2.75", ",", " ", "\n", 
       "   ", "\"\<Laser's angular frequency \
\\!\\(\\*SubscriptBox[\\(\[Omega]\\), \\(0\\)]\\)\>\""}], "}"}], ",", " ", 
     "1", ",", " ", "\n", "  ", "10"}], "}"}], ",", " ", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
      "\[Kappa]", ",", " ", ".212", ",", " ", "\n", 
       "   ", "\"\<Laser's phase diffusion constant \[Kappa]\>\""}], "}"}], ",",
      " ", ".1", ",", " ", "\n", "  ", "2"}], "}"}], ",", " ", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"t", ",", " ", ".1", ",", " ", "\"\<Time t\>\""}], "}"}], ",", 
     " ", "0", ",", " ", "10"}], "}"}]}], "]"}]], "Input",
 CellLabel->
  "In[277]:= ",ExpressionUUID->"5749c76b-6087-45e0-9c8f-7e53a23d4fb7"],

Cell[TextData[{
 "As you can see, for sufficiently large time ",
 Cell[BoxData[
  StyleBox["t", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "717a75ca-b807-41ea-af8f-132e339234d7"],
 ", the two-time correlation function becomes stationary: it no longer \
depends on ",
 Cell[BoxData[
  StyleBox["t", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "990ded54-6a96-4534-a7c1-53c47281898e"],
 " itself, only on the time difference \[Tau]. In this long-time limit we \
have: ",
 Cell[BoxData[
  RowBox[{
   StyleBox["l", "TI"], 
   StyleBox["i", "TI"], 
   SubscriptBox[
    StyleBox["m", "TI"], 
    RowBox[{
     StyleBox["t", "TI"], "\[Rule]", "\[Infinity]"}]], 
   StyleBox["\[LeftAngleBracket]",
    SpanMaxSize->1], 
   RowBox[{
    StyleBox["E", "TI"], 
    StyleBox["(",
     SpanMaxSize->1], 
    StyleBox["t", "TI"], 
    StyleBox[")",
     SpanMaxSize->1], 
    StyleBox["E", "TI"], 
    StyleBox["(",
     SpanMaxSize->1], 
    RowBox[{
     StyleBox["t", "TI"], "+", 
     StyleBox["\[Tau]", "TI"]}], 
    StyleBox[")",
     SpanMaxSize->1]}], 
   StyleBox["\[RightAngleBracket]",
    SpanMaxSize->1], "=", "1", "/", "2", 
   SuperscriptBox[
    StyleBox["e", "TI"], 
    RowBox[{"-", 
     StyleBox["\[Kappa]", "TI"], " ", 
     StyleBox["\[Tau]", "TI"]}]], 
   StyleBox["C", "TI"], 
   StyleBox["o", "TI"], 
   StyleBox["s", "TI"], 
   StyleBox["[",
    SpanMaxSize->1], 
   RowBox[{
    SubscriptBox[
     StyleBox["\[Omega]", "TI"], "0"], 
    StyleBox["\[Tau]", "TI"]}], 
   StyleBox["]",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "0407fe08-b211-4f3b-9325-ed537e630594"],
 ". So the correlations decay exponentially in \[Tau] with rate \[Kappa], \
while oscillating at the carrier frequency ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["\[Omega]", "TI"], "0"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "afbe96d6-e9cc-4b07-b8be-000cd78ad89a"],
 "; which is exactly the same as the mean value of the electric field we had \
calculated before."
}], "Text",ExpressionUUID->"b1d9e44f-3f07-4320-9511-193b4aa13444"],

Cell["White Noise: Stratonovich Viewpoint", "Subsection",ExpressionUUID->"c2618ceb-85cb-40a6-9b8f-be66d5cf0ded"],

Cell[TextData[{
 "Now consider a Hamiltonian as ",
 Cell[BoxData[
  RowBox[{
   StyleBox["H", "TI"], "=", "1", "/", "2", 
   SubscriptBox[
    StyleBox["\[Omega]", "TI"], 
    StyleBox["x", "TI"]], 
   SubscriptBox[
    StyleBox["\[Sigma]", "TI"], 
    StyleBox["x", "TI"]], "+", 
   SqrtBox[
    StyleBox["\[Gamma]", "TI"]], 
   StyleBox["\[Xi]", "TI"], 
   StyleBox["(",
    SpanMaxSize->1], 
   StyleBox["t", "TI"], 
   StyleBox[")",
    SpanMaxSize->1], 
   SubscriptBox[
    StyleBox["\[Sigma]", "TI"], 
    StyleBox["z", "TI"]]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "9167f39b-4f30-4b70-be27-497396d263b3"],
 " where ",
 Cell[BoxData[
  RowBox[{
   StyleBox["\[Xi]", "TI"], 
   StyleBox["(",
    SpanMaxSize->1], 
   StyleBox["t", "TI"], 
   StyleBox[")",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "e4093b53-52ab-4549-9776-29013d3e10f4"],
 " is white noise, heuristically ",
 Cell[BoxData[
  RowBox[{
   StyleBox["\[Xi]", "TI"], 
   StyleBox["(",
    SpanMaxSize->1], 
   StyleBox["t", "TI"], 
   StyleBox[")",
    SpanMaxSize->1], "=", 
   StyleBox["d", "TI"], 
   SubscriptBox[
    StyleBox["W", "TI"], 
    StyleBox["t", "TI"]], "/", 
   StyleBox["d", "TI"], 
   StyleBox["t", "TI"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "646bafdf-e6d9-429f-9fd8-f65aa473e386"],
 " with ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["W", "TI"], 
   StyleBox["t", "TI"]]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "77dd1e7c-9100-4ec5-9dcf-31b4e3e24de6"],
 " a Wiener process. Mathematically, ",
 Cell[BoxData[
  RowBox[{
   StyleBox["\[Xi]", "TI"], 
   StyleBox["(",
    SpanMaxSize->1], 
   StyleBox["t", "TI"], 
   StyleBox[")",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "45ed0abd-3351-41ee-b4d3-bf9d863bba80"],
 " is not an ordinary function, it\[CloseCurlyQuote]s a distribution with \
zero mean ",
 Cell[BoxData[
  RowBox[{
   StyleBox["\[LeftAngleBracket]",
    SpanMaxSize->1], 
   RowBox[{
    StyleBox["\[Xi]", "TI"], 
    StyleBox["(",
     SpanMaxSize->1], 
    StyleBox["t", "TI"], 
    StyleBox[")",
     SpanMaxSize->1]}], 
   StyleBox["\[RightAngleBracket]",
    SpanMaxSize->1], "=", "0"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "0358d9a7-cf6e-4484-afc6-a38630f76eca"],
 " and no time correlation ",
 Cell[BoxData[
  RowBox[{
   StyleBox["\[LeftAngleBracket]",
    SpanMaxSize->1], 
   RowBox[{
    StyleBox["\[Xi]", "TI"], 
    StyleBox["(",
     SpanMaxSize->1], 
    StyleBox["t", "TI"], 
    StyleBox[")",
     SpanMaxSize->1], 
    StyleBox["\[Xi]", "TI"], 
    StyleBox["(",
     SpanMaxSize->1], 
    StyleBox["s", "TI"], 
    StyleBox[")",
     SpanMaxSize->1]}], 
   StyleBox["\[RightAngleBracket]",
    SpanMaxSize->1], "=", 
   StyleBox["\[Delta]", "TI"], 
   StyleBox["(",
    SpanMaxSize->1], 
   RowBox[{
    StyleBox["t", "TI"], "-", 
    StyleBox["s", "TI"]}], 
   StyleBox[")",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "ef1a3ecc-6da1-45f1-bb18-15180284806f"],
 ". So a white noise \[OpenCurlyDoubleQuote]kicks\[CloseCurlyDoubleQuote] the \
system at each instant, but kicks at different instants are independent. Keep \
in mind white noise is not a normal function of time, but only a \
distribution. You never really use ",
 Cell[BoxData[
  RowBox[{
   StyleBox["\[Xi]", "TI"], 
   StyleBox["(",
    SpanMaxSize->1], 
   StyleBox["t", "TI"], 
   StyleBox[")",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "76f257ea-d372-44b9-a1e8-ce3b530feff4"],
 " directly; you always use its integral over time."
}], "Text",ExpressionUUID->"6a01e33b-7f81-4757-b0ca-e79eae1cf169"],

Cell["\<\
Verify that the two-time correlation function of a white noise is Dirac delta:\
\>", "Text",ExpressionUUID->"c469d61c-78fb-4a26-a37b-d2acb3d85711"],

Cell[BoxData[
 RowBox[{"CorrelationFunction", "[", 
  RowBox[{
   RowBox[{"WhiteNoiseProcess", "[", "]"}], ",", " ", "s", ",", " ", "t"}], 
  "]"}]], "Input",
 CellLabel->
  "In[278]:= ",ExpressionUUID->"5de74605-9a7a-476e-b277-5ec4eb4c3115"],

Cell["\<\
Confirm that the spectral density of a white noise (i.e., Fourier transform \
of its two-time correlation) is constant/flat:\
\>", "Text",ExpressionUUID->"0a4eaf19-d5ae-4fcc-b750-afe2553595e6"],

Cell[BoxData[
 RowBox[{"FourierTransform", "[", 
  RowBox[{
   RowBox[{"DiracDelta", "[", "t", "]"}], ",", " ", "t", ",", " ", 
   "\[Omega]"}], "]"}]], "Input",
 CellLabel->
  "In[279]:= ",ExpressionUUID->"664a6568-d3b6-44ae-a774-30e8ddca4387"],

Cell[TextData[{
 "Now let\[CloseCurlyQuote]s focus on the stochastic Schr\[ODoubleDot]dinger \
equation. We take a qubit with the above random Hamiltonian ",
 Cell[BoxData[
  RowBox[{
   RowBox[{
    StyleBox["d", "TI"], 
    RowBox[{
     TemplateBox[{
       RowBox[{
         StyleBox["\[Psi]", "TI"], 
         StyleBox["(", SpanMaxSize -> 1], 
         StyleBox["t", "TI"], 
         StyleBox[")", SpanMaxSize -> 1]}]},
      "Ket"], "/", 
     StyleBox["d", "TI"]}], 
    StyleBox["t", "TI"]}], "=", 
   RowBox[{
    RowBox[{"-", 
     StyleBox["i", "TI"]}], 
    RowBox[{
     StyleBox["(",
      SpanMaxSize->1], 
     RowBox[{
      RowBox[{
       RowBox[{"1", "/", "2"}], 
       SubscriptBox[
        StyleBox["\[Omega]", "TI"], 
        StyleBox["x", "TI"]], 
       SubscriptBox[
        StyleBox["\[Sigma]", "TI"], 
        StyleBox["x", "TI"]]}], "+", 
      RowBox[{
       SqrtBox[
        StyleBox["\[Gamma]", "TI"]], 
       SubscriptBox[
        StyleBox["\[Sigma]", "TI"], 
        StyleBox["z", "TI"]], 
       StyleBox["\[Xi]", "TI"], 
       RowBox[{
        StyleBox["(",
         SpanMaxSize->1], 
        StyleBox["t", "TI"], 
        StyleBox[")",
         SpanMaxSize->1]}]}]}], 
     StyleBox[")",
      SpanMaxSize->1]}], 
    TemplateBox[{
      SubscriptBox[
       StyleBox["\[Psi]", "TI"], 
       StyleBox["t", "TI"]]},
     "Ket"]}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "ced33d70-61f8-47b9-a4f1-90f31c2313f2"],
 ". If the noise ",
 Cell[BoxData[
  RowBox[{
   StyleBox["\[Xi]", "TI"], 
   StyleBox["(",
    SpanMaxSize->1], 
   StyleBox["t", "TI"], 
   StyleBox[")",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "193775c9-0377-4487-a495-72491dd85839"],
 " were an ordinary smooth function of time, this would just be a standard \
time-dependent Schr\[ODoubleDot]dinger equation: ",
 Cell[BoxData[
  RowBox[{
   RowBox[{
    StyleBox["d", "TI"], 
    RowBox[{
     TemplateBox[{
       RowBox[{
         StyleBox["\[Psi]", "TI"], 
         StyleBox["(", SpanMaxSize -> 1], 
         StyleBox["t", "TI"], 
         StyleBox[")", SpanMaxSize -> 1]}]},
      "Ket"], "/", 
     StyleBox["d", "TI"]}], 
    StyleBox["t", "TI"]}], "=", 
   RowBox[{
    RowBox[{"-", 
     StyleBox["i", "TI"]}], 
    StyleBox["H", "TI"], 
    RowBox[{
     StyleBox["(",
      SpanMaxSize->1], 
     StyleBox["t", "TI"], 
     StyleBox[")",
      SpanMaxSize->1]}], 
    TemplateBox[{
      RowBox[{
        StyleBox["\[Psi]", "TI"], 
        StyleBox["(", SpanMaxSize -> 1], 
        StyleBox["t", "TI"], 
        StyleBox[")", SpanMaxSize -> 1]}]},
     "Ket"]}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "81267d1e-a159-410a-97e3-8f4ebfcaf8fb"],
 " with ",
 Cell[BoxData[
  RowBox[{
   StyleBox["H", "TI"], 
   StyleBox["(",
    SpanMaxSize->1], 
   StyleBox["t", "TI"], 
   StyleBox[")",
    SpanMaxSize->1], "=", "1", "/", "2", 
   SubscriptBox[
    StyleBox["\[Omega]", "TI"], 
    StyleBox["x", "TI"]], 
   SubscriptBox[
    StyleBox["\[Sigma]", "TI"], 
    StyleBox["x", "TI"]], "+", 
   SqrtBox[
    StyleBox["\[Gamma]", "TI"]], 
   SubscriptBox[
    StyleBox["\[Sigma]", "TI"], 
    StyleBox["z", "TI"]], " ", 
   StyleBox["\[Xi]", "TI"], 
   StyleBox["(",
    SpanMaxSize->1], 
   StyleBox["t", "TI"], 
   StyleBox[")",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "8e0cc702-f023-45e1-a63f-b14eb3c63edd"],
 ", i.e. an ordinary differential equation (ODE) with a time-dependent \
Hamiltonian. For each fixed realization of ",
 Cell[BoxData[
  RowBox[{
   StyleBox["\[Xi]", "TI"], 
   StyleBox["(",
    SpanMaxSize->1], 
   StyleBox["t", "TI"], 
   StyleBox[")",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "8b13708a-d8bf-4843-b7dc-b2f4b33f321a"],
 ", the Hamiltonian ",
 Cell[BoxData[
  RowBox[{
   StyleBox["H", "TI"], 
   StyleBox["(",
    SpanMaxSize->1], 
   StyleBox["t", "TI"], 
   StyleBox[")",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "b0671966-04da-4fff-8631-2574aa3b2385"],
 " is Hermitian, so the evolution operator is unitary and the inner product \
",
 Cell[BoxData[
  TemplateBox[{
    RowBox[{
      StyleBox["\[Psi]", "TI"], 
      StyleBox["(", SpanMaxSize -> 1], 
      StyleBox["t", "TI"], 
      StyleBox[")", SpanMaxSize -> 1]}], 
    RowBox[{
      StyleBox["\[Psi]", "TI"], 
      StyleBox["(", SpanMaxSize -> 1], 
      StyleBox["t", "TI"], 
      StyleBox[")", SpanMaxSize -> 1]}]},
   "BraKet"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "6ba4d91c-576a-4aca-8af6-d93268919947"],
 " is preserved."
}], "Text",ExpressionUUID->"234bf000-2861-4d64-a88a-dcd4571a5216"],

Cell[TextData[{
 "Now we idealize the noise: we think of ",
 Cell[BoxData[
  RowBox[{
   StyleBox["\[Xi]", "TI"], 
   StyleBox["(",
    SpanMaxSize->1], 
   StyleBox["t", "TI"], 
   StyleBox[")",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "bb71bb91-f9ad-4097-8736-184407a25538"],
 " as the limit of a very fast, very jagged random signal (correlation time \
approaches 0). Mathematically, this limit is described using a Wiener process \
",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["W", "TI"], 
   StyleBox["t", "TI"]]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "377b58ed-d3d4-446e-81c3-511a4399236a"],
 " (Brownian motion), whose increment over a small time step is ",
 Cell[BoxData[
  RowBox[{
   StyleBox["d", "TI"], 
   SubscriptBox[
    StyleBox["W", "TI"], 
    StyleBox["t", "TI"]], "=", 
   SubscriptBox[
    StyleBox["W", "TI"], 
    RowBox[{
     StyleBox["t", "TI"], "+", 
     StyleBox["d", "TI"], 
     StyleBox["t", "TI"]}]], "-", 
   SubscriptBox[
    StyleBox["W", "TI"], 
    StyleBox["t", "TI"]]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "a316ccb2-ae1e-42ee-a48a-a7f44a24b653"],
 ". The increment ",
 Cell[BoxData[
  RowBox[{
   StyleBox["d", "TI"], 
   SubscriptBox[
    StyleBox["W", "TI"], 
    StyleBox["t", "TI"]]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "0c18d2c1-d071-48ca-b36f-72a834fc1e62"],
 " is a random variable with mean zero and variance ",
 Cell[BoxData[
  StyleBox[
   RowBox[{"d", "t"}], "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "601f1e64-e2b3-412d-92dd-9cfac54fceac"],
 ": ",
 Cell[BoxData[
  RowBox[{"\|01d53c", 
   StyleBox["(",
    SpanMaxSize->1], 
   RowBox[{
    StyleBox["d", "TI"], 
    SubscriptBox[
     StyleBox["W", "TI"], 
     StyleBox["t", "TI"]]}], 
   StyleBox[")",
    SpanMaxSize->1], "=", "0"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "34ee7468-7c80-4271-ace6-3751499df405"],
 " and ",
 Cell[BoxData[
  RowBox[{"\|01d53c", 
   StyleBox["(",
    SpanMaxSize->1], 
   RowBox[{
    StyleBox["d", "TI"], 
    SubsuperscriptBox[
     StyleBox["W", "TI"], 
     StyleBox["t", "TI"], "2"]}], 
   StyleBox[")",
    SpanMaxSize->1], "=", 
   StyleBox["d", "TI"], 
   StyleBox["t", "TI"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "d87db469-a4e7-442a-939f-922a5ef41b62"],
 ". This means the typical size of ",
 Cell[BoxData[
  RowBox[{
   StyleBox["d", "TI"], 
   SubscriptBox[
    StyleBox["W", "TI"], 
    StyleBox["t", "TI"]]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "41815c96-fdbe-4957-98dc-e5e4cbff48d9"],
 " is of order",
 Cell[BoxData[
  SqrtBox[
   StyleBox[
    RowBox[{"d", "t"}], "TI"]]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "cc3f373c-79fd-45fd-8b66-d98454af9656"],
 ". Symbolically you can think ",
 Cell[BoxData[
  RowBox[{
   RowBox[{
    StyleBox["d", "TI"], 
    SubscriptBox[
     StyleBox["W", "TI"], 
     StyleBox["t", "TI"]]}], "\[NonBreakingSpace]", 
   SqrtBox[
    StyleBox[
     RowBox[{"d", "t"}], "TI"]]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "5a320076-47db-4b55-9bb9-24a3e76acb68"],
 " and ",
 Cell[BoxData[
  RowBox[{
   RowBox[{
    StyleBox["d", "TI"], 
    SubsuperscriptBox[
     StyleBox["W", "TI"], 
     StyleBox["t", "TI"], "2"]}], "\[NonBreakingSpace]", 
   StyleBox[
    RowBox[{"d", "t"}], "TI"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "623d8d38-8bb5-483c-923b-143721d2259f"]
}], "Text",ExpressionUUID->"402fa4f1-286b-41f1-9fb1-525da5723252"],

Cell[TextData[{
 "If we want to keep the rules of ordinary differential equation, then the \
corresponding dynamical equation is called Stratonovich stochastic \
differential equation. In Stratonovich form the stochastic \
Schr\[ODoubleDot]dinger equation is written as: ",
 Cell[BoxData[
  RowBox[{
   RowBox[{
    StyleBox["d", "TI"], 
    TemplateBox[{
      RowBox[{
        StyleBox["\[Psi]", "TI"], 
        StyleBox["(", SpanMaxSize -> 1], 
        StyleBox["t", "TI"], 
        StyleBox[")", SpanMaxSize -> 1]}]},
     "Ket"]}], "=", 
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{"-", 
       StyleBox["i", "TI"]}], "/", "2"}], 
     SubscriptBox[
      StyleBox["\[Omega]", "TI"], 
      StyleBox["x", "TI"]], 
     SubscriptBox[
      StyleBox["\[Sigma]", "TI"], 
      StyleBox["x", "TI"]], 
     TemplateBox[{
       SubscriptBox[
        StyleBox["\[Psi]", "TI"], 
        StyleBox["t", "TI"]]},
      "Ket"], 
     StyleBox["d", "TI"], 
     StyleBox["t", "TI"]}], "-", 
    RowBox[{
     StyleBox["i", "TI"], 
     SqrtBox[
      StyleBox["\[Gamma]", "TI"]], 
     SubscriptBox[
      StyleBox["\[Sigma]", "TI"], 
      StyleBox["z", "TI"]], 
     RowBox[{
      TemplateBox[{
        SubscriptBox[
         StyleBox["\[Psi]", "TI"], 
         StyleBox["t", "TI"]]},
       "Ket"], "\[SmallCircle]", 
      StyleBox["d", "TI"]}], 
     SubscriptBox[
      StyleBox["W", "TI"], 
      StyleBox["t", "TI"]]}]}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "168ea164-1c10-408b-b842-7ad034fcc3b9"],
 " where ",
 Cell[BoxData[
  RowBox[{"\[SmallCircle]", 
   StyleBox["d", "TI"], 
   SubscriptBox[
    StyleBox["W", "TI"], 
    StyleBox["t", "TI"]]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "a11c367c-a08c-42a2-8229-af9c09d7115a"],
 " is called Stratonovich differential. It encodes the fact that, in the \
underlying discrete picture, the noise term is evaluated in a symmetric \
(midpoint) way inside each short time interval, which is exactly what you get \
if you start from a smooth noisy Hamiltonian and then let the correlation \
time of the noise go to zero. With this interpretation, we can formally use \
the usual rules of calculus (chain rule, change of variables). This is why \
physicists often like Stratonovich form: it \[OpenCurlyDoubleQuote]feels\
\[CloseCurlyDoubleQuote] like ordinary differential equations with a noisy \
input. There is another, closely related formulation of stochastic \
differential equations, called the It\[OHat] form, which uses a slightly \
different convention and leads to extra drift terms when we rewrite the \
equation; we will comment on that later. So in short, when we deal with \
stochastic differential equations (SDE), one has to always pay attention if \
SDE is written in Stratonovich or It\[OHat] form. We shall start with \
Stratonovich form and show how the usual algebraic and chain rules of ODE is \
also applicable here. Later, we will discuss It\[OHat] form and you will see \
much more care needed for, e.g., variable changes."
}], "Text",ExpressionUUID->"e19aa493-4896-4591-8a8d-5d63ab6c6c00"],

Cell[TextData[{
 "Since we can use the usual algebra and calculus of ODE in Stratonovich \
form, we can write the SDE for the density matrix given the random \
Hamiltonian above as: ",
 Cell[BoxData[
  RowBox[{
   StyleBox["d", "TI"], 
   StyleBox["\[Rho]", "TI"], "=", "-", 
   StyleBox["i", "TI"], "/", "2", 
   SubscriptBox[
    StyleBox["\[Omega]", "TI"], 
    StyleBox["x", "TI"]], 
   StyleBox["[",
    SpanMaxSize->1], 
   RowBox[{
    SubscriptBox[
     StyleBox["\[Sigma]", "TI"], 
     StyleBox["x", "TI"]], ",", 
    StyleBox["\[Rho]", "TI"]}], 
   StyleBox["]",
    SpanMaxSize->1], 
   StyleBox["d", "TI"], 
   StyleBox["t", "TI"], "-", 
   StyleBox["i", "TI"], 
   SqrtBox[
    StyleBox["\[Gamma]", "TI"]], 
   StyleBox["[",
    SpanMaxSize->1], 
   RowBox[{
    SubscriptBox[
     StyleBox["\[Sigma]", "TI"], 
     StyleBox["z", "TI"]], ",", 
    StyleBox["\[Rho]", "TI"]}], 
   StyleBox["]",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "2e8d6ce4-2270-4816-80a6-703d1afc7e42"],
 "\[SmallCircle]d",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["W", "TI"], 
   StyleBox["t", "TI"]]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "828a7625-d79b-43c7-8efd-19bf4aa3ff0b"],
 ". Let\[CloseCurlyQuote]s write the density matrix as ",
 Cell[BoxData[
  RowBox[{
   StyleBox["\[Rho]", "TI"], "=", "1", "/", "2", 
   StyleBox["(",
    SpanMaxSize->1], 
   RowBox[{
    RowBox[{"\|01d540", "+", 
     OverscriptBox[
      StyleBox["v", "TI"], "\[RightVector]"]}], ".", 
    OverscriptBox[
     StyleBox["\[Sigma]", "TI"], "\[RightVector]"]}], 
   StyleBox[")",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "001c47ec-3a25-4475-bdb6-2359636b2ae0"],
 " with ",
 Cell[BoxData[
  OverscriptBox[
   StyleBox["v", "TI"], "\[RightVector]"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "944e801e-ecec-4eab-a7c0-530d75b8b447"],
 " the Bloch vector ",
 Cell[BoxData[
  RowBox[{
   RowBox[{
    StyleBox["r", "TI"], "{", 
    StyleBox["C", "TI"], 
    StyleBox["o", "TI"], 
    StyleBox["s", "TI"], 
    StyleBox["[",
     SpanMaxSize->1], 
    StyleBox["\[Phi]", "TI"], 
    StyleBox["]",
     SpanMaxSize->1], 
    StyleBox["S", "TI"], 
    StyleBox["i", "TI"], 
    StyleBox["n", "TI"], 
    StyleBox["[",
     SpanMaxSize->1], 
    StyleBox["\[Theta]", "TI"], 
    StyleBox["]",
     SpanMaxSize->1]}], ",", 
   RowBox[{
    StyleBox["S", "TI"], 
    StyleBox["i", "TI"], 
    StyleBox["n", "TI"], 
    StyleBox["[",
     SpanMaxSize->1], 
    StyleBox["\[Phi]", "TI"], 
    StyleBox["]",
     SpanMaxSize->1], 
    StyleBox["S", "TI"], 
    StyleBox["i", "TI"], 
    StyleBox["n", "TI"], 
    StyleBox["[",
     SpanMaxSize->1], 
    StyleBox["\[Theta]", "TI"], 
    StyleBox["]",
     SpanMaxSize->1]}], ",", 
   RowBox[{
    StyleBox["C", "TI"], 
    StyleBox["o", "TI"], 
    StyleBox["s", "TI"], 
    StyleBox["[",
     SpanMaxSize->1], 
    StyleBox["\[Theta]", "TI"], 
    StyleBox["]",
     SpanMaxSize->1], "}"}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "c0487d4d-b64f-432c-8b70-3e002c2bf82e"],
 " and find the stochastic dynamical equation of ",
 Cell[BoxData[
  RowBox[{
   RowBox[{"{", 
    StyleBox["r", "TI"]}], ",", 
   StyleBox["\[Theta]", "TI"], ",", 
   RowBox[{
    StyleBox["\[Phi]", "TI"], "}"}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "a55f6e08-1b25-4920-bb0a-5732f6b172ab"],
 " in Stratonovich form. As said before, we can use the usual rules of ODE \
for variable changes."
}], "Text",ExpressionUUID->"125c3743-b003-4e1c-8b3c-e94f5a458f68"],

Cell[TextData[{
 "Calculate the Jacobian matrix ",
 Cell[BoxData[
  RowBox[{"\[PartialD]", 
   StyleBox["(",
    SpanMaxSize->1], 
   RowBox[{
    StyleBox["r", "TI"], ",", 
    StyleBox["\[Theta]", "TI"], ",", 
    StyleBox["\[Phi]", "TI"]}], 
   StyleBox[")",
    SpanMaxSize->1], "/", "\[PartialD]", 
   StyleBox["(",
    SpanMaxSize->1], 
   RowBox[{
    StyleBox["x", "TI"], ",", 
    StyleBox["y", "TI"], ",", 
    StyleBox["z", "TI"]}], 
   StyleBox[")",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "a8130ebe-0c5e-4bf9-9086-f776cb9f7231"],
 " for the mapping from Cartesian to Spherical coordinate for the Bloch \
vector:"
}], "Text",ExpressionUUID->"cbbfd725-6d92-4cbc-ad50-fe71002ac613"],

Cell[BoxData[{
 RowBox[{"ClearAll", "[", 
  RowBox[{
  "rx", ",", " ", "ry", ",", " ", "rz", ",", " ", "r", ",", " ", "\[Theta]", ",",
    " ", "\[Phi]"}], "]"}], "\n", 
 RowBox[{
  RowBox[{"jacobian", " ", "=", " ", "\n", "  ", 
   RowBox[{"FullSimplify", "[", "\n", "   ", 
    RowBox[{
     RowBox[{
      RowBox[{"CoordinateTransformData", "[", 
       RowBox[{
        RowBox[{"\"\<Cartesian\>\"", " ", "->", " ", "\"\<Spherical\>\""}], ",",
         " ", "\n", "     ", "\"\<MappingJacobian\>\"", ",", " ", 
        RowBox[{"{", 
         RowBox[{"rx", ",", " ", "ry", ",", " ", "rz"}], "}"}]}], "]"}], " ", 
      "/.", " ", "\n", "    ", 
      RowBox[{"Thread", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"rx", ",", " ", "ry", ",", " ", "rz"}], "}"}], " ", "->", 
        " ", "\n", "      ", 
        RowBox[{"FromSphericalCoordinates", "[", 
         RowBox[{"{", 
          RowBox[{"r", ",", " ", "\[Theta]", ",", " ", "\[Phi]"}], "}"}], 
         "]"}]}], "]"}]}], ",", " ", "\n", "   ", 
     RowBox[{
      RowBox[{"0", " ", "<=", " ", "r"}], " ", "&&", " ", 
      RowBox[{"0", " ", "<=", " ", "\[Theta]", " ", "<=", " ", "\[Pi]"}], " ",
       "&&", " ", 
      RowBox[{"0", " ", "<=", " ", "\[Phi]", " ", "<=", " ", 
       RowBox[{"2", " ", "\[Pi]"}]}]}]}], "]"}]}], ";"}], "\n", 
 RowBox[{"jacobian", " ", "//", " ", "MatrixForm"}]}], "Input",
 CellLabel->
  "In[280]:= ",ExpressionUUID->"17a59c65-7fcb-4a2f-923b-8cceecabb694"],

Cell[TextData[{
 "Calculate terms with ",
 Cell[BoxData[
  StyleBox[
   RowBox[{"d", "t"}], "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "6b3ee98d-ac1d-4b9e-aaf5-ed751b5feba8"],
 " in the stochastic dynamical equation:"
}], "Text",ExpressionUUID->"48f0c3e5-8a1f-478a-8aa5-c904c6bcd106"],

Cell[BoxData[
 RowBox[{"nonRandomTermsSDE", " ", "=", " ", "\n", " ", 
  RowBox[{"FullSimplify", "[", 
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{"-", "I"}], " ", 
      RowBox[{"Commutator", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"1", "/", "2"}], " ", "\[Omega]x", " ", 
         RowBox[{"PauliMatrix", "[", "1", "]"}]}], ",", " ", "\n", "     ", 
        RowBox[{"DensityMatrix", "[", 
         RowBox[{"{", 
          RowBox[{"x", ",", " ", "y", ",", " ", "z"}], "}"}], "]"}], ",", " ",
         "Dot"}], "]"}]}], " ", "//", " ", "\n", "   ", "BlochVector"}], ",", 
    " ", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
      "\[Omega]x", " ", "|", " ", "\[Gamma]", " ", "|", " ", "x", " ", "|", 
       " ", "y", " ", "|", " ", "z"}], "}"}], " ", "\[Element]", " ", 
     "Reals"}]}], "]"}]}]], "Input",
 CellLabel->
  "In[281]:= ",ExpressionUUID->"99cb59e7-c193-4024-a24c-0ddffcfc7024"],

Cell[TextData[{
 "Calculate terms with ",
 Cell[BoxData[
  RowBox[{"\[SmallCircle]", 
   StyleBox["d", "TI"], 
   SubscriptBox[
    StyleBox["W", "TI"], 
    StyleBox["t", "TI"]]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "cfad81d1-fb70-462b-8825-0e8c61f2bbd2"],
 " in the stochastic dynamical equation:"
}], "Text",ExpressionUUID->"ec023b40-55a1-40a0-b254-b0b9c1f99f9d"],

Cell[BoxData[
 RowBox[{"randomTermsSDE", " ", "=", " ", "\n", " ", 
  RowBox[{"FullSimplify", "[", 
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{"-", "I"}], " ", 
      RowBox[{"Commutator", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"Sqrt", "[", "\[Gamma]", "]"}], " ", 
         RowBox[{"PauliMatrix", "[", "3", "]"}]}], ",", " ", "\n", "     ", 
        RowBox[{"DensityMatrix", "[", 
         RowBox[{"{", 
          RowBox[{"x", ",", " ", "y", ",", " ", "z"}], "}"}], "]"}], ",", " ",
         "Dot"}], "]"}]}], " ", "//", " ", "\n", "   ", "BlochVector"}], ",", 
    " ", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
      "\[Omega]x", " ", "|", " ", "\[Gamma]", " ", "|", " ", "x", " ", "|", 
       " ", "y", " ", "|", " ", "z"}], "}"}], " ", "\[Element]", " ", 
     "Reals"}]}], "]"}]}]], "Input",
 CellLabel->
  "In[282]:= ",ExpressionUUID->"b8822a0f-b336-40fb-ac77-cff7de093591"],

Cell["\<\
Both of the expressions we derived above are written in terms of the \
Cartesian components of the Bloch vector. However, our goal is to describe \
the dynamics in spherical coordinates. To do that, we need two additional \
steps: first, use the Jacobian of the coordinate transformation to rewrite \
the results in spherical coordinates; second, wherever Cartesian components \
still appear, replace them with their explicit expressions in terms of the \
spherical variables.\
\>", "Text",ExpressionUUID->"76cad463-5ee3-4b6f-9665-50543a54c6fe"],

Cell[TextData[{
 "We now introduce the replacement rules that map Cartesian components of the \
Bloch vector to spherical coordinates. Whenever ",
 Cell[BoxData[
  RowBox[{
   RowBox[{"{", 
    StyleBox["x", "TI"]}], ",", 
   StyleBox["y", "TI"], ",", 
   RowBox[{
    StyleBox["z", "TI"], "}"}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "7c9f5260-7eb8-4b1f-bf59-3390c6b4a2cf"],
 " appear, we will substitute them using these relations to express \
everything in terms of the spherical angles ",
 Cell[BoxData[
  RowBox[{
   RowBox[{"{", 
    StyleBox["r", "TI"]}], ",", 
   StyleBox["\[Theta]", "TI"], ",", 
   RowBox[{
    StyleBox["\[Phi]", "TI"], "}"}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "4a4a6df1-1e24-414e-8941-dd5e5f1ac8ea"],
 "."
}], "Text",ExpressionUUID->"ccc07072-1304-451c-830d-4fe2c41f8cbe"],

Cell[BoxData[
 RowBox[{"repl", " ", "=", " ", 
  RowBox[{"Thread", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"x", ",", " ", "y", ",", " ", "z"}], "}"}], " ", "->", " ", "\n",
     "   ", 
    RowBox[{"FromSphericalCoordinates", "[", 
     RowBox[{"{", 
      RowBox[{"r", ",", " ", "\[Theta]", ",", " ", "\[Phi]"}], "}"}], "]"}]}],
    "]"}]}]], "Input",
 CellLabel->
  "In[283]:= ",ExpressionUUID->"8815f811-da57-4846-a627-9c53efeb9f81"],

Cell[TextData[{
 "Apply these coordinate transformations to rewrite the dynamics in spherical \
variables, and obtain the Stratonovich-form stochastic equations for the \
Bloch vector starting from the initial state ",
 Cell[BoxData[
  RowBox[{
   RowBox[{"{", 
    SubscriptBox[
     StyleBox["r", "TI"], "0"]}], ",", 
   SubscriptBox[
    StyleBox["\[Theta]", "TI"], "0"], ",", 
   RowBox[{
    SubscriptBox[
     StyleBox["\[Phi]", "TI"], "0"], "}"}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "c9b2c868-78ba-47fd-8c71-7981ef473a48"],
 " for given ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["\[Omega]", "TI"], 
   StyleBox["x", "TI"]]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "1eb29408-ec7e-4721-9456-db9959716b0a"],
 " and \[Gamma]:"
}], "Text",ExpressionUUID->"ec0a4336-10f0-40a9-aaea-15c2aea1a978"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"ClearAll", "[", "\[Rho]StratonovichSDE", "]"}], ";"}], "\n", 
 RowBox[{
  RowBox[{"\[Rho]StratonovichSDE", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"\[Omega]x_", ",", " ", "\[Gamma]_"}], "}"}], ",", " ", 
    RowBox[{"{", 
     RowBox[{"r0_", ",", " ", "\[Theta]0_", ",", " ", 
      RowBox[{"\\\n", "\[Phi]0_"}]}], "}"}]}], "]"}], " ", "=", " ", "\n", 
  " ", 
  RowBox[{
   RowBox[{"StratonovichProcess", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{"jacobian", " ", ".", " ", "nonRandomTermsSDE"}], ",", " ", 
        "\n", "     ", 
        RowBox[{"List", " ", "/@", " ", 
         RowBox[{"(", 
          RowBox[{"jacobian", " ", ".", " ", "randomTermsSDE"}], ")"}]}], ",",
         " ", 
        RowBox[{"{", 
         RowBox[{"r", ",", " ", "\[Theta]", ",", " ", "\[Phi]"}], "}"}]}], 
       "}"}], " ", "/.", " ", "\n", "    ", "repl"}], ",", " ", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"r", ",", " ", "\[Theta]", ",", " ", "\[Phi]"}], "}"}], ",", 
       " ", 
       RowBox[{"{", 
        RowBox[{"r0", ",", " ", "\[Theta]0", ",", " ", "\[Phi]0"}], "}"}]}], 
      "}"}], ",", " ", 
     RowBox[{"{", 
      RowBox[{"t", ",", " ", "0"}], "}"}]}], "]"}], " ", "//", "\n", "   ", 
   "FullSimplify"}]}]}], "Input",
 CellLabel->
  "In[284]:= ",ExpressionUUID->"7838f2cb-37c8-466c-9c17-b7146da40b77"],

Cell[TextData[{
 "For the spherical coordinates of the Bloch vector, the stochastic dynamics \
in Stratonovich form can be written as ",
 Cell[BoxData[
  RowBox[{
   StyleBox["d", "TI"], "(", GridBox[{
     {
      StyleBox["r", "TI"]},
     {
      StyleBox["\[Theta]", "TI"]},
     {
      StyleBox["\[Phi]", "TI"]}
    }], ")", "=", "(", GridBox[{
     {"0"},
     {
      RowBox[{"-", 
       SubscriptBox[
        StyleBox["\[Omega]", "TI"], 
        StyleBox["x", "TI"]], 
       StyleBox["S", "TI"], 
       StyleBox["i", "TI"], 
       StyleBox["n", "TI"], 
       StyleBox["[",
        SpanMaxSize->1], 
       StyleBox["\[Phi]", "TI"], 
       StyleBox["]",
        SpanMaxSize->1]}]},
     {
      RowBox[{"-", 
       SubscriptBox[
        StyleBox["\[Omega]", "TI"], 
        StyleBox["x", "TI"]], 
       StyleBox["C", "TI"], 
       StyleBox["o", "TI"], 
       StyleBox["s", "TI"], 
       StyleBox["[",
        SpanMaxSize->1], 
       StyleBox["\[Phi]", "TI"], 
       StyleBox["]",
        SpanMaxSize->1], 
       StyleBox["C", "TI"], 
       StyleBox["o", "TI"], 
       StyleBox["t", "TI"], 
       StyleBox["[",
        SpanMaxSize->1], 
       StyleBox["\[Theta]", "TI"], 
       StyleBox["]",
        SpanMaxSize->1]}]}
    }], ")", 
   StyleBox["d", "TI"], 
   StyleBox["t", "TI"], "+", "(", GridBox[{
     {"0"},
     {"0"},
     {
      RowBox[{"2", 
       SqrtBox[
        StyleBox["\[Gamma]", "TI"]]}]}
    }], ")", "\[SmallCircle]", 
   StyleBox["d", "TI"], 
   SubscriptBox[
    StyleBox["W", "TI"], 
    StyleBox["t", "TI"]]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "e7763b4e-102c-4e4d-a52a-d375db81e5b3"],
 ". In words: the radius ",
 Cell[BoxData[
  StyleBox["r", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "ec6b245f-b765-40be-9d9e-f57b4128aca6"],
 " stays constant, \[Theta] evolves deterministically under the coherent \
drive ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["\[Omega]", "TI"], 
   StyleBox["x", "TI"]]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "e872ed4e-2317-49d7-9cd3-a68e2dd07b79"],
 ", and \[Phi] has both a deterministic part from the drive and a stochastic \
part from the noise term with strength ",
 Cell[BoxData[
  RowBox[{"2", 
   SqrtBox[
    StyleBox["\[Gamma]", "TI"]]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "29bee99c-1edc-4a7d-9c6e-8268d34119de"],
 " \:200b."
}], "Text",ExpressionUUID->"d9a7241c-7b9c-4299-9fb6-c3a9708ff2eb"],

Cell["Generate 1,000 realization of SDE for the density matrix:", "Text",ExpressionUUID->"64597f24-aa6c-497f-978c-531f8d89c3cc"],

Cell[BoxData[
 RowBox[{"trajectories", " ", "=", " ", "\n", " ", 
  RowBox[{"RandomFunction", "[", 
   RowBox[{
    RowBox[{"\[Rho]StratonovichSDE", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"2", ",", " ", ".2"}], "}"}], ",", " ", 
      RowBox[{"{", 
       RowBox[{"1", ",", " ", 
        RowBox[{"\[Pi]", "/", "4"}], ",", " ", "0"}], "}"}]}], "]"}], ",", 
    " ", 
    RowBox[{"{", 
     RowBox[{"0", ",", " ", "\n", "   ", "10", ",", " ", ".001"}], "}"}], ",",
     " ", "1000"}], "]"}]}]], "Input",
 CellLabel->
  "In[285]:= ",ExpressionUUID->"e8ea8361-42ed-4596-9243-36203b85f58a"],

Cell[TextData[{
 "Transform ",
 Cell[BoxData[
  RowBox[{
   RowBox[{"{", 
    StyleBox["r", "TI"]}], ",", 
   StyleBox["\[Theta]", "TI"], ",", 
   RowBox[{
    StyleBox["\[Phi]", "TI"], "}"}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "d6e50844-b32c-45c0-b6f1-cbe3608cee81"],
 " to ",
 Cell[BoxData[
  RowBox[{
   RowBox[{"{", 
    StyleBox["x", "TI"]}], ",", 
   StyleBox["y", "TI"], ",", 
   RowBox[{
    StyleBox["z", "TI"], "}"}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "2f552b9b-5781-4f2d-bf41-6c620a52d79c"],
 ":"
}], "Text",ExpressionUUID->"389c9761-7908-44a3-af80-329606d54953"],

Cell[BoxData[
 RowBox[{
  RowBox[{"blochVectorTrajectories", " ", "=", " ", "\n", "  ", 
   RowBox[{"MapAt", "[", 
    RowBox[{
     RowBox[{"Apply", "[", 
      RowBox[{
       RowBox[{"#1", " ", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{
           RowBox[{"Cos", "[", "#3", "]"}], " ", 
           RowBox[{"Sin", "[", "#2", "]"}]}], ",", " ", 
          RowBox[{
           RowBox[{"Sin", "[", "#3", "]"}], " ", 
           RowBox[{"Sin", "[", "#2", "]"}]}], ",", " ", 
          RowBox[{"Cos", "[", "#2", "]"}]}], "}"}]}], " ", "&"}], "]"}], ",", 
     " ", "\n", "   ", 
     RowBox[{"trajectories", "[", "\"\<ValueList\>\"", "]"}], ",", " ", 
     RowBox[{"{", 
      RowBox[{"All", ",", " ", "All"}], "}"}]}], "]"}]}], ";"}]], "Input",
 CellLabel->
  "In[286]:= ",ExpressionUUID->"2ca26772-775a-4aea-b1cf-f748963eabf9"],

Cell["\<\
Visualize Cartesian component of Bloch vector for two realizations of random \
trajectory:\
\>", "Text",ExpressionUUID->"22c63c92-f767-4087-94d1-4b630daa5baa"],

Cell[BoxData[
 RowBox[{"Legended", "[", "\n", " ", 
  RowBox[{
   RowBox[{"Row", "@", 
    RowBox[{"MapIndexed", "[", "\n", "   ", 
     RowBox[{
      RowBox[{
       RowBox[{"ListLinePlot", "[", 
        RowBox[{"#1", ",", " ", 
         RowBox[{"PlotRange", " ", "->", " ", "All"}], ",", " ", 
         RowBox[{"DataRange", " ", "->", " ", 
          RowBox[{"{", 
           RowBox[{"0", ",", " ", "10"}], "}"}]}], ",", " ", "\n", "     ", 
         RowBox[{"GridLines", " ", "->", " ", "Automatic"}], ",", " ", "\n", 
         "     ", 
         RowBox[{"PlotLabel", " ", "->", " ", "\n", "      ", 
          RowBox[{"StringJoin", "[", 
           RowBox[{
            RowBox[{
             RowBox[{"{", 
              
              RowBox[{"\"\<x\>\"", ",", " ", "\"\<y\>\"", ",", 
               " ", "\"\<z\>\""}], "}"}], "[", 
             RowBox[{"[", 
              RowBox[{"#2", "[", 
               RowBox[{"[", "1", "]"}], "]"}], "]"}], "]"}], " ", "<>", " ", 
            "\n", "        ", "\"\<-component of Bloch vector\>\""}], "]"}]}],
          ",", " ", 
         RowBox[{"ImageSize", " ", "->", " ", "250"}]}], "]"}], " ", "&"}], ",",
       " ", "\n", "   ", 
      RowBox[{"Transpose", "[", 
       RowBox[{
        RowBox[{"blochVectorTrajectories", "[", 
         RowBox[{"[", 
          RowBox[{";;", " ", "2"}], "]"}], "]"}], ",", " ", 
        RowBox[{"Cycles", "[", 
         RowBox[{"{", 
          RowBox[{"{", 
           RowBox[{"3", ",", " ", "1", ",", " ", "2"}], "}"}], "}"}], "]"}]}],
        "]"}]}], "]"}]}], ",", " ", "\n", " ", 
   RowBox[{"SwatchLegend", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{
        RowBox[{"ColorData", "[", "97", "]"}], "[", "1", "]"}], ",", " ", 
       "\n", "   ", 
       RowBox[{
        RowBox[{"ColorData", "[", "97", "]"}], "[", "2", "]"}]}], "}"}], ",", 
     " ", 
     RowBox[{"{", 
      RowBox[{"\"\<One realization of random trajectory\>\"", ",", " ", "\n", 
       "   ", "\"\<Another realization of random trajectory\>\""}], "}"}]}], 
    "]"}]}], "]"}]], "Input",
 CellLabel->
  "In[287]:= ",ExpressionUUID->"80f0084c-181e-4e40-9b95-4f2df948dcf9"],

Cell["\<\
Visualize Bloch vector for two realizations of random trajectory on the Bloch \
sphere:\
\>", "Text",ExpressionUUID->"c25ab548-0d94-4e5b-91f3-32df3a787c74"],

Cell[BoxData[
 RowBox[{"Show", "[", 
  RowBox[{
   RowBox[{
    RowBox[{"ResourceFunction", "[", "\"\<BlochSpherePlot\>\"", "]"}], "[", 
    "]"}], ",", " ", "\n", " ", 
   RowBox[{"ListLinePlot3D", "[", 
    RowBox[{"blochVectorTrajectories", "[", 
     RowBox[{"[", 
      RowBox[{";;", " ", "2"}], "]"}], "]"}], "]"}], ",", " ", "\n", " ", 
   RowBox[{
   "PlotLabel", " ", "->", " ", "\n", 
    "  ", "\"\<Two realization of random dynamics with\n \
H=\\!\\(\\*FractionBox[\\(1\\), \
\\(2\\)]\\)\\!\\(\\*SubscriptBox[\\(\[Omega]\\), \
\\(x\\)]\\)\\!\\(\\*SubscriptBox[\\(\[Sigma]\\), \
\\(x\\)]\\)+\\!\\(\\*SqrtBox[\\(\[Gamma]\\)]\\)\[Xi](t)\\!\\(\\*SubscriptBox[\
\\(\[Sigma]\\), \\(z\\)]\\)\>\""}]}], "]"}]], "Input",
 CellLabel->
  "In[288]:= ",ExpressionUUID->"736e8884-88e8-4f32-ac9f-d874e223a54f"],

Cell["\<\
In analogy with our earlier random-process simulations, a natural question \
is: what does the density matrix do on average? In other words, if we average \
over the stochastic fluctuations and keep only the deterministic part, what \
effective dynamical equation governs the noise-averaged density matrix? Let\
\[CloseCurlyQuote]s now work this out and see what form that equation takes.\
\>", "Text",ExpressionUUID->"738a55ab-65df-4831-a474-49fd3f0a352f"],

Cell["From Noise-Averaging to the Lindbald Equation", "Subsection",ExpressionUUID->"ea97c1f7-afcc-4a48-8ba6-2211ff02ed83"],

Cell["\<\
Let us first examine the many individual realizations we have generated and \
study their average behavior. This average defines an effective trajectory on \
the Bloch sphere that represents the ensemble of qubits governed by the \
random Hamiltonian we are considering. In other words, instead of following a \
single noisy Bloch vector, we now look at the mean Bloch vector, which \
captures how the ensemble as a whole evolves under the stochastic dynamics.\
\>", "Text",ExpressionUUID->"402ecfea-3c8e-4f66-a17a-586c7cd15019"],

Cell["\<\
Show the noise-averaged trajectory of the Cartesian components of the Bloch \
vector (the time evolution of the ensemble-averaged qubit state as it moves \
on the Bloch sphere:\
\>", "Text",ExpressionUUID->"9c83ff1a-dfdc-4902-8c75-4dc020adf36e"],

Cell[BoxData[
 RowBox[{"ListLinePlot", "[", 
  RowBox[{
   RowBox[{"Transpose", "@", 
    RowBox[{"Mean", "@", "blochVectorTrajectories"}]}], ",", " ", "\n", " ", 
   RowBox[{"PlotRange", " ", "->", " ", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"-", "1"}], ",", " ", "1"}], "}"}]}], ",", " ", 
   RowBox[{"DataRange", " ", "->", " ", 
    RowBox[{"{", 
     RowBox[{"0", ",", " ", "10"}], "}"}]}], ",", " ", "\n", " ", 
   RowBox[{"PlotLegends", " ", "->", " ", 
    RowBox[{"{", 
     RowBox[{"\"\<x\>\"", ",", " ", "\"\<y\>\"", ",", " ", "\"\<z\>\""}], 
     "}"}]}], ",", " ", "\n", " ", 
   RowBox[{
   "PlotLabel", " ", "->", " ", "\n", 
    "  ", "\"\<The ensemble-averaged Cartesian components of\n the Bloch \
vector \n\\!\\(\\*OverscriptBox[\\(r\\), \\(\[RightVector]\\)]\\)={\
\[LeftAngleBracket]Subscript[\[Sigma], \n    x]\[RightAngleBracket],\
\[LeftAngleBracket]Subscript[\[Sigma], \n   y]\[RightAngleBracket],\
\[LeftAngleBracket]Subscript[\[Sigma], \n   z]\[RightAngleBracket]}\>\""}], ",",
    " ", 
   RowBox[{"GridLines", " ", "->", " ", "Automatic"}], ",", " ", 
   RowBox[{"Frame", " ", "->", " ", "True"}], ",", " ", "\n", " ", 
   RowBox[{"FrameLabel", " ", "->", " ", 
    RowBox[{"{", 
     RowBox[{"\"\<Time\>\"", ",", " ", "\n", 
      "   ", "\"\<\\!\\(\\*FormBox[\\(\[LeftAngleBracket]\\*SubscriptBox[\\(\
\[Sigma]\\), \\(j\\)]\[RightAngleBracket]\\),\nTraditionalForm]\\)\>\""}], 
     "}"}]}]}], "]"}]], "Input",
 CellLabel->
  "In[289]:= ",ExpressionUUID->"73996c0c-b555-4c21-8a2f-55581ffabf2b"],

Cell["Visualize the noise-averaged trajectory in the Bloch sphere:", "Text",ExpressionUUID->"5ae58db9-76fa-48d9-ab56-119027e61e37"],

Cell[BoxData[
 RowBox[{"Show", "[", 
  RowBox[{
   RowBox[{
    RowBox[{"ResourceFunction", "[", "\"\<BlochSpherePlot\>\"", "]"}], "[", 
    RowBox[{"ImageSize", " ", "->", " ", "250"}], "]"}], ",", "\n", "  ", 
   RowBox[{"ListLinePlot3D", "[", 
    RowBox[{
     RowBox[{"Mean", "@", "blochVectorTrajectories"}], ",", " ", 
     RowBox[{"PlotRange", " ", "->", " ", "All"}]}], "]"}], ",", " ", "\n", 
   " ", 
   RowBox[{
   "PlotLabel", " ", "->", 
    " ", "\"\<Ensemble-averaged qubit state\n on the Bloch sphere\>\""}]}], 
  "]"}]], "Input",
 CellLabel->
  "In[290]:= ",ExpressionUUID->"ed976f90-dc48-498e-9688-0758617de80c"],

Cell[TextData[{
 "As you can see, the averaged trajectory precesses around the x-axis, \
reflecting the coherent rotation generated by the ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["\[Sigma]", "TI"], 
   StyleBox["x", "TI"]]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "10c9913e-10a9-496e-b8fa-8bea33f0b2cb"],
 " term in the random Hamiltonian ",
 Cell[BoxData[
  RowBox[{
   StyleBox["H", "TI"], "=", "1", "/", "2", 
   SubscriptBox[
    StyleBox["\[Omega]", "TI"], 
    StyleBox["x", "TI"]], 
   SubscriptBox[
    StyleBox["\[Sigma]", "TI"], 
    StyleBox["x", "TI"]], "+", 
   SqrtBox[
    StyleBox["\[Gamma]", "TI"]], 
   StyleBox["\[Xi]", "TI"], 
   StyleBox["(",
    SpanMaxSize->1], 
   StyleBox["t", "TI"], 
   StyleBox[")",
    SpanMaxSize->1], 
   SubscriptBox[
    StyleBox["\[Sigma]", "TI"], 
    StyleBox["z", "TI"]]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "41e18636-94fd-429a-8895-55b9dd8ef0e3"],
 ". At the same time, it spirals inward toward the center of the Bloch \
sphere, indicating that the state is becoming mixed. This loss of purity is \
caused by the random ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["\[Sigma]", "TI"], 
   StyleBox["z", "TI"]]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "f2ba0185-8c1a-4403-b569-00ac743497cf"],
 " term, which continuously kicks the Bloch vector in a stochastic way."
}], "Text",ExpressionUUID->"95b5913a-ef18-46de-9bcf-d770c38b8bcf"],

Cell[TextData[{
 "Recall the basic statistical properties of Wiener increments: the mean is \
zero, ",
 Cell[BoxData[
  RowBox[{"\|01d53c", 
   StyleBox["(",
    SpanMaxSize->1], 
   RowBox[{
    StyleBox["d", "TI"], 
    SubscriptBox[
     StyleBox["W", "TI"], 
     StyleBox["t", "TI"]]}], 
   StyleBox[")",
    SpanMaxSize->1], "=", "0"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "744f1cc5-dfc4-4d40-a720-a7af90cd7a05"],
 ", and the second moment is ",
 Cell[BoxData[
  RowBox[{"\|01d53c", 
   StyleBox["(",
    SpanMaxSize->1], 
   RowBox[{
    StyleBox["d", "TI"], 
    SubsuperscriptBox[
     StyleBox["W", "TI"], 
     StyleBox["t", "TI"], "2"]}], 
   StyleBox[")",
    SpanMaxSize->1], "=", 
   StyleBox["d", "TI"], 
   StyleBox["t", "TI"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "4b3ef7ca-f1a1-4eaa-9e0d-9f7f25d9be78"],
 ". However, we cannot apply these rules directly to the Stratonovich-form \
equation, because there the noise appears in terms like ",
 Cell[BoxData[
  RowBox[{"\[SmallCircle]", 
   StyleBox["d", "TI"], 
   SubscriptBox[
    StyleBox["W", "TI"], 
    StyleBox["t", "TI"]]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "7bcf3904-32c6-4df4-8cc8-932db3f66771"],
 " (Stratonovich differential), not plain ",
 Cell[BoxData[
  RowBox[{
   StyleBox["d", "TI"], 
   SubscriptBox[
    StyleBox["W", "TI"], 
    StyleBox["t", "TI"]]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "3fcf278c-ca0e-47a8-a2b9-fd1929ebfbbc"],
 ". To perform a stochastic average of the dynamics, we must first convert \
the Stratonovich equation into its equivalent It\[OHat] form, and only then \
take the noise average."
}], "Text",ExpressionUUID->"e5666ede-8c4b-410a-bbbb-a8287ad5fecc"],

Cell["\<\
Transform the Stratonovich-form stochastic dynamical equation into its \
equivalent It\[OHat] form, so that the noise terms are written with standard \
Wiener increments and can be averaged using the usual It\[OHat] rules:\
\>", "Text",ExpressionUUID->"796f0eec-0f0f-46ad-b829-bc1c8447ca3b"],

Cell[BoxData[
 RowBox[{"\[Rho]ItoSDE", " ", "=", " ", "\n", " ", 
  RowBox[{"ItoProcess", "@", "\n", "  ", 
   RowBox[{"StratonovichProcess", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"nonRandomTermsSDE", ",", " ", "\n", "    ", 
       RowBox[{"List", " ", "/@", " ", "randomTermsSDE"}], ",", " ", 
       RowBox[{"{", 
        RowBox[{"x", ",", " ", "y", ",", " ", "z"}], "}"}]}], "}"}], ",", " ", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"x", ",", " ", "y", ",", " ", "z"}], "}"}], ",", " ", 
       RowBox[{"{", 
        RowBox[{"x0", ",", " ", "y0", ",", " ", "z0"}], "}"}]}], "}"}], ",", 
     " ", 
     RowBox[{"{", 
      RowBox[{"t", ",", "\n", "     ", "0"}], "}"}]}], "]"}]}]}]], "Input",
 CellLabel->
  "In[291]:= ",ExpressionUUID->"2ad45979-4b26-4ec2-a3d0-74a0080f6f5a"],

Cell[TextData[{
 "In Mathematica, an It\[OHat] process is written in the generic form ",
 Cell[BoxData[
  RowBox[{
   StyleBox["ItoProcess",
    FontSlant->"Plain"], 
   StyleBox["[",
    SpanMaxSize->1], 
   RowBox[{
    RowBox[{"{", 
     StyleBox["a", "TI"]}], ",", 
    StyleBox["b", "TI"], ",", 
    RowBox[{
     SubscriptBox[
      StyleBox["r", "TI"], 
      StyleBox["t", "TI"]], "}"}], ",", 
    RowBox[{"{", 
     StyleBox["r", "TI"]}], ",", 
    RowBox[{
     SubscriptBox[
      StyleBox["r", "TI"], "0"], "}"}], ",", 
    StyleBox["t", "TI"]}], 
   StyleBox["]",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "3ee59651-5608-49da-a383-529efd1bf2c4"],
 " where ",
 Cell[BoxData[
  StyleBox["a", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "7338cc14-73b2-44fb-a32b-ba7d916821b2"],
 " collects the deterministic (non-random) terms, ",
 Cell[BoxData[
  StyleBox["b", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "9c7fdd9a-1724-482a-84e9-426c520b1845"],
 " collects the stochastic (noise) terms, and ",
 Cell[BoxData[
  StyleBox["r", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "b0f99029-2ad4-4dc4-a0d3-e04d9236b034"],
 " denotes the variables of the process. In our example, ",
 Cell[BoxData[
  StyleBox["r", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "fa95349d-7ecc-4252-97b2-3553a79237b9"],
 " is the Bloch vector. In continuous-time notation, this corresponds to a \
stochastic differential equation of the form ",
 Cell[BoxData[
  RowBox[{
   StyleBox["d", "TI"], 
   SubscriptBox[
    StyleBox["r", "TI"], 
    StyleBox["i", "TI"]], 
   StyleBox["(",
    SpanMaxSize->1], 
   StyleBox["t", "TI"], 
   StyleBox[")",
    SpanMaxSize->1], "=", " ", 
   SubscriptBox[
    StyleBox["a", "TI"], 
    StyleBox["i", "TI"]], 
   StyleBox["(",
    SpanMaxSize->1], 
   RowBox[{
    StyleBox["t", "TI"], ",", 
    RowBox[{
     StyleBox["r", "TI"], 
     StyleBox["(",
      SpanMaxSize->1], 
     StyleBox["t", "TI"], 
     StyleBox[")",
      SpanMaxSize->1]}]}], 
   StyleBox[")",
    SpanMaxSize->1], 
   StyleBox["d", "TI"], 
   StyleBox["t", "TI"], "+", 
   SubscriptBox[
    StyleBox["b", "TI"], 
    StyleBox["i", "TI"]], 
   StyleBox["(",
    SpanMaxSize->1], 
   RowBox[{
    StyleBox["t", "TI"], ",", 
    RowBox[{
     StyleBox["r", "TI"], 
     StyleBox["(",
      SpanMaxSize->1], 
     StyleBox["t", "TI"], 
     StyleBox[")",
      SpanMaxSize->1]}]}], 
   StyleBox[")",
    SpanMaxSize->1], 
   StyleBox["d", "TI"], 
   StyleBox["w", "TI"], 
   StyleBox["(",
    SpanMaxSize->1], 
   StyleBox["t", "TI"], 
   StyleBox[")",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "5c0989df-bc9f-4b6b-8b05-1bb492cfd1a6"],
 ". When we perform a stochastic (noise) average, the random increment ",
 Cell[BoxData[
  RowBox[{
   StyleBox["d", "TI"], 
   SubscriptBox[
    StyleBox["W", "TI"], 
    StyleBox["t", "TI"]]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "a413457f-a0bb-4c42-8a8d-be0a371e1a72"],
 " has zero mean, so the contribution from the noise term averages to zero. \
As a result, the evolution of the noise-averaged quantity is governed solely \
by the drift part ",
 Cell[BoxData[
  StyleBox["a", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "d914ec2e-da2f-4381-b8ed-2a6d647a14f3"],
 ": after averaging, only the deterministic drift survives in the equation \
for the mean."
}], "Text",ExpressionUUID->"58747c9a-7c2a-4c0c-9cb6-378a2cfa1224"],

Cell[TextData[{
 "Show ",
 Cell[BoxData[
  StyleBox["a", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "ffa27466-f697-4258-99fd-f975bb32cf26"],
 " (the drift) in ",
 Cell[BoxData[
  RowBox[{
   StyleBox["d", "TI"], 
   SubscriptBox[
    StyleBox["r", "TI"], 
    StyleBox["i", "TI"]], 
   StyleBox["(",
    SpanMaxSize->1], 
   StyleBox["t", "TI"], 
   StyleBox[")",
    SpanMaxSize->1], "=", " ", 
   SubscriptBox[
    StyleBox["a", "TI"], 
    StyleBox["i", "TI"]], 
   StyleBox["(",
    SpanMaxSize->1], 
   RowBox[{
    StyleBox["t", "TI"], ",", 
    RowBox[{
     StyleBox["r", "TI"], 
     StyleBox["(",
      SpanMaxSize->1], 
     StyleBox["t", "TI"], 
     StyleBox[")",
      SpanMaxSize->1]}]}], 
   StyleBox[")",
    SpanMaxSize->1], 
   StyleBox["d", "TI"], 
   StyleBox["t", "TI"], "+", 
   SubscriptBox[
    StyleBox["b", "TI"], 
    StyleBox["i", "TI"]], 
   StyleBox["(",
    SpanMaxSize->1], 
   RowBox[{
    StyleBox["t", "TI"], ",", 
    RowBox[{
     StyleBox["r", "TI"], 
     StyleBox["(",
      SpanMaxSize->1], 
     StyleBox["t", "TI"], 
     StyleBox[")",
      SpanMaxSize->1]}]}], 
   StyleBox[")",
    SpanMaxSize->1], 
   StyleBox["d", "TI"], 
   StyleBox["w", "TI"], 
   StyleBox["(",
    SpanMaxSize->1], 
   StyleBox["t", "TI"], 
   StyleBox[")",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "ce6e3f53-1458-4d9a-a784-5eaaba7b09e2"],
 " in the case we studied above:"
}], "Text",ExpressionUUID->"a9f28f43-155c-4c86-9cba-3e29e44bd989"],

Cell[BoxData[
 RowBox[{
  RowBox[{"\[Rho]ItoSDE", "[", "\"\<Drift\>\"", "]"}], " ", "//", " ", 
  "MatrixForm"}]], "Input",
 CellLabel->
  "In[292]:= ",ExpressionUUID->"c23068dc-97d2-4c06-8c3f-3a7ce8d7cf0a"],

Cell[TextData[{
 "Show ",
 Cell[BoxData[
  StyleBox["b", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "c1a231c4-2753-40b7-999e-58aa5b3d87c6"],
 " (diffusion) in ",
 Cell[BoxData[
  RowBox[{
   StyleBox["d", "TI"], 
   SubscriptBox[
    StyleBox["r", "TI"], 
    StyleBox["i", "TI"]], 
   StyleBox["(",
    SpanMaxSize->1], 
   StyleBox["t", "TI"], 
   StyleBox[")",
    SpanMaxSize->1], "=", " ", 
   SubscriptBox[
    StyleBox["a", "TI"], 
    StyleBox["i", "TI"]], 
   StyleBox["(",
    SpanMaxSize->1], 
   RowBox[{
    StyleBox["t", "TI"], ",", 
    RowBox[{
     StyleBox["r", "TI"], 
     StyleBox["(",
      SpanMaxSize->1], 
     StyleBox["t", "TI"], 
     StyleBox[")",
      SpanMaxSize->1]}]}], 
   StyleBox[")",
    SpanMaxSize->1], 
   StyleBox["d", "TI"], 
   StyleBox["t", "TI"], "+", 
   SubscriptBox[
    StyleBox["b", "TI"], 
    StyleBox["i", "TI"]], 
   StyleBox["(",
    SpanMaxSize->1], 
   RowBox[{
    StyleBox["t", "TI"], ",", 
    RowBox[{
     StyleBox["r", "TI"], 
     StyleBox["(",
      SpanMaxSize->1], 
     StyleBox["t", "TI"], 
     StyleBox[")",
      SpanMaxSize->1]}]}], 
   StyleBox[")",
    SpanMaxSize->1], 
   StyleBox["d", "TI"], 
   StyleBox["w", "TI"], 
   StyleBox["(",
    SpanMaxSize->1], 
   StyleBox["t", "TI"], 
   StyleBox[")",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "000051d9-90d9-4301-bd00-53d1b385fe80"],
 " in the case we studied above:"
}], "Text",ExpressionUUID->"98a4878a-c821-406e-b330-0d812a76b03b"],

Cell[BoxData[
 RowBox[{
  RowBox[{"\[Rho]ItoSDE", "[", "\"\<Diffusion\>\"", "]"}], " ", "//", " ", 
  "MatrixForm"}]], "Input",
 CellLabel->
  "In[293]:= ",ExpressionUUID->"3d3b9f9f-f193-42a8-ad24-e3ed96d6b7fe"],

Cell[TextData[{
 "We will not go into the details of deriving the noise-averaged master \
equation, but we can summarize the main result. Suppose the Hamiltonian has a \
random part of the form ",
 Cell[BoxData[
  RowBox[{
   StyleBox["H", "TI"], "=", 
   SubscriptBox[
    StyleBox["H", "TI"], "0"], "+", 
   StyleBox["\[Xi]", "TI"], 
   StyleBox["(",
    SpanMaxSize->1], 
   StyleBox["t", "TI"], 
   StyleBox[")",
    SpanMaxSize->1], 
   StyleBox["L", "TI"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "4b906b00-6525-4e94-8c45-d7acf91d95b5"],
 " where ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["H", "TI"], "0"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "7d1bd226-de96-474b-b973-fbd4bd957023"],
 " is the deterministic (non-random) contribution and ",
 Cell[BoxData[
  RowBox[{
   StyleBox["\[Xi]", "TI"], 
   StyleBox["(",
    SpanMaxSize->1], 
   StyleBox["t", "TI"], 
   StyleBox[")",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "02daa81c-258e-4ceb-a22d-619a47c0ffa6"],
 " is a white-noise process. After averaging over the noise, the density \
matrix obeys the master equation ",
 Cell[BoxData[
  RowBox[{
   StyleBox["d", "TI"], 
   StyleBox["\[Rho]", "TI"], "/", 
   StyleBox["d", "TI"], 
   StyleBox["t", "TI"], "=", "-", 
   StyleBox["i", "TI"], 
   StyleBox["[",
    SpanMaxSize->1], 
   RowBox[{
    SubscriptBox[
     StyleBox["H", "TI"], "0"], ",", 
    StyleBox["\[Rho]", "TI"]}], 
   StyleBox["]",
    SpanMaxSize->1], "+", 
   StyleBox["(",
    SpanMaxSize->1], 
   RowBox[{
    RowBox[{
     StyleBox["L", "TI"], " ", 
     StyleBox["\[Rho]", "TI"], " ", 
     SuperscriptBox[
      StyleBox["L", "TI"], "\[Dagger]"], "-", "1", "/", "2", "{", 
     SuperscriptBox[
      StyleBox["L", "TI"], "\[Dagger]"], 
     StyleBox["L", "TI"]}], ",", 
    RowBox[{
     StyleBox["\[Rho]", "TI"], "}"}]}], 
   StyleBox[")",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "5bba08af-101a-4a48-82f4-5f8dd1139787"],
 " which is the standard Lindblad form. If the operator ",
 Cell[BoxData[
  StyleBox["L", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "e64a61bc-a406-4cbb-8032-04bbe50bc27d"],
 " is Hermitian, this dissipative part can be written more compactly as a \
double commutator, ",
 Cell[BoxData[
  RowBox[{
   StyleBox["d", "TI"], 
   StyleBox["\[Rho]", "TI"], "/", 
   StyleBox["d", "TI"], 
   StyleBox["t", "TI"], "=", "-", 
   StyleBox["i", "TI"], 
   StyleBox["[",
    SpanMaxSize->1], 
   RowBox[{
    SubscriptBox[
     StyleBox["H", "TI"], "0"], ",", 
    StyleBox["\[Rho]", "TI"]}], 
   StyleBox["]",
    SpanMaxSize->1], "-", "1", "/", "2", 
   StyleBox["[",
    SpanMaxSize->1], 
   RowBox[{
    StyleBox["L", "TI"], ",", 
    RowBox[{
     StyleBox["[",
      SpanMaxSize->1], 
     RowBox[{
      StyleBox["L", "TI"], ",", 
      StyleBox["\[Rho]", "TI"]}], 
     StyleBox["]",
      SpanMaxSize->1]}]}], 
   StyleBox["]",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "688b9141-55a9-4cec-be51-571c8bdd586b"],
 ". In the specific example we studied, the Hamiltonian was ",
 Cell[BoxData[
  RowBox[{
   StyleBox["H", "TI"], "=", "1", "/", "2", 
   SubscriptBox[
    StyleBox["\[Omega]", "TI"], 
    StyleBox["x", "TI"]], 
   SubscriptBox[
    StyleBox["\[Sigma]", "TI"], 
    StyleBox["x", "TI"]], "+", 
   SqrtBox[
    StyleBox["\[Gamma]", "TI"]], 
   StyleBox["\[Xi]", "TI"], 
   StyleBox["(",
    SpanMaxSize->1], 
   StyleBox["t", "TI"], 
   StyleBox[")",
    SpanMaxSize->1], 
   SubscriptBox[
    StyleBox["\[Sigma]", "TI"], 
    StyleBox["z", "TI"]]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "820812f8-531c-42d4-839d-38c1435ea63b"],
 " with ",
 Cell[BoxData[
  RowBox[{
   StyleBox["L", "TI"], "=", 
   SqrtBox[
    StyleBox["\[Gamma]", "TI"]], 
   SubscriptBox[
    StyleBox["\[Sigma]", "TI"], 
    StyleBox["z", "TI"]]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "508e335b-8bea-4486-8055-6b9fcade1713"],
 ". So the noise-averaged dynamics is described by ",
 Cell[BoxData[
  RowBox[{
   StyleBox["d", "TI"], 
   StyleBox["\[Rho]", "TI"], "/", 
   StyleBox["d", "TI"], 
   StyleBox["t", "TI"], "=", "-", 
   StyleBox["i", "TI"], 
   StyleBox["[",
    SpanMaxSize->1], 
   RowBox[{
    RowBox[{"1", "/", "2", 
     SubscriptBox[
      StyleBox["\[Omega]", "TI"], 
      StyleBox["x", "TI"]], 
     SubscriptBox[
      StyleBox["\[Sigma]", "TI"], 
      StyleBox["x", "TI"]]}], ",", 
    StyleBox["\[Rho]", "TI"]}], 
   StyleBox["]",
    SpanMaxSize->1], "-", 
   StyleBox["\[Gamma]", "TI"], "/", "2", 
   StyleBox["[",
    SpanMaxSize->1], 
   RowBox[{
    SubscriptBox[
     StyleBox["\[Sigma]", "TI"], 
     StyleBox["z", "TI"]], ",", 
    RowBox[{
     StyleBox["[",
      SpanMaxSize->1], 
     RowBox[{
      SubscriptBox[
       StyleBox["\[Sigma]", "TI"], 
       StyleBox["z", "TI"]], ",", 
      StyleBox["\[Rho]", "TI"]}], 
     StyleBox["]",
      SpanMaxSize->1]}]}], 
   StyleBox["]",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "00058811-cf1b-4460-ab9e-38487f7ce58f"],
 "."
}], "Text",ExpressionUUID->"d027f9b4-58b4-4651-abda-e3949bee606f"],

Cell[TextData[{
 "For the dissipative part of Lindblad equation verify that ",
 Cell[BoxData[
  RowBox[{
   RowBox[{
    StyleBox["L", "TI"], " ", 
    StyleBox["\[Rho]", "TI"], " ", 
    SuperscriptBox[
     StyleBox["L", "TI"], "\[Dagger]"], "-", "1", "/", "2", "{", 
    SuperscriptBox[
     StyleBox["L", "TI"], "\[Dagger]"], 
    StyleBox["L", "TI"]}], ",", 
   RowBox[{
    StyleBox["\[Rho]", "TI"], "}", "=", "-", "1", "/", "2", 
    StyleBox["[",
     SpanMaxSize->1], 
    RowBox[{
     StyleBox["L", "TI"], ",", 
     RowBox[{
      StyleBox["[",
       SpanMaxSize->1], 
      RowBox[{
       StyleBox["L", "TI"], ",", 
       StyleBox["\[Rho]", "TI"]}], 
      StyleBox["]",
       SpanMaxSize->1]}]}], 
    StyleBox["]",
     SpanMaxSize->1]}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "ebab1492-faf7-497d-90e3-4ba98707b442"],
 " if ",
 Cell[BoxData[
  StyleBox["L", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "b54ac1db-e2ae-4254-aa45-872d1dbcafa0"],
 " is Hermitian:"
}], "Text",ExpressionUUID->"1fe1a6fc-afdb-4658-bff1-e9a604a0fe95"],

Cell[BoxData[
 RowBox[{"FullSimplify", "[", "\n", " ", 
  RowBox[{
   RowBox[{"With", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"\[Rho]", " ", "=", " ", 
        RowBox[{"Array", "[", 
         RowBox[{"\[FormalR]", ",", " ", 
          RowBox[{"{", 
           RowBox[{"2", ",", " ", "2"}], "}"}]}], "]"}]}], ",", " ", "\n", 
       "   ", 
       RowBox[{"l", " ", "=", " ", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{"\[FormalA]", ",", " ", "\[FormalB]"}], "}"}], ",", " ", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"Conjugate", "[", "\[FormalB]", "]"}], ",", " ", "\n", 
            "      ", 
            RowBox[{"1", " ", "-", " ", "\[FormalA]"}]}], "}"}]}], "}"}]}]}], 
      "}"}], ",", "\n", "  ", 
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{"-", "1"}], "/", "2"}], " ", 
       RowBox[{"Commutator", "[", 
        RowBox[{"l", ",", " ", 
         RowBox[{"Commutator", "[", 
          RowBox[{"l", ",", " ", "r", ",", " ", "Dot"}], "]"}], ",", " ", 
         "Dot"}], "]"}]}], " ", "==", "\n", "   ", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{"l", " ", ".", " ", "r", " ", ".", " ", 
         RowBox[{"ConjugateTranspose", "[", "l", "]"}]}], " ", "-", " ", "\n",
         "     ", 
        RowBox[{
         RowBox[{"1", "/", "2"}], " ", 
         RowBox[{"Anticommutator", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"ConjugateTranspose", "[", "l", "]"}], " ", ".", " ", 
            "l"}], ",", " ", "r", ",", " ", "\n", "       ", "Dot"}], 
          "]"}]}]}], ")"}]}]}], "]"}], ",", " ", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{"\[FormalA]", " ", "|", " ", "\[FormalB]"}], ")"}], " ", "\[Element]",
     " ", "Reals"}]}], "]"}]], "Input",
 CellLabel->
  "In[294]:= ",ExpressionUUID->"1239764b-ec08-4b3f-bdb9-143446438c16"],

Cell[TextData[{
 "If there is more than one Lindblad (jump) operator, the dissipative part of \
the master equation is just the sum of their individual contributions. The \
noise-averaged dynamics then takes the form ",
 Cell[BoxData[
  RowBox[{
   StyleBox["d", "TI"], 
   StyleBox["\[Rho]", "TI"], "/", 
   StyleBox["d", "TI"], 
   StyleBox["t", "TI"], "=", "-", 
   StyleBox["i", "TI"], 
   StyleBox["[",
    SpanMaxSize->1], 
   RowBox[{
    SubscriptBox[
     StyleBox["H", "TI"], "0"], ",", 
    StyleBox["\[Rho]", "TI"]}], 
   StyleBox["]",
    SpanMaxSize->1], "+", 
   UnderscriptBox["\[Sum]", 
    StyleBox["k", "TI"],
    LimitsPositioning->False], 
   StyleBox["(",
    SpanMaxSize->1], 
   RowBox[{
    RowBox[{
     SubscriptBox[
      StyleBox["L", "TI"], 
      StyleBox["k", "TI"]], " ", 
     StyleBox["\[Rho]", "TI"], " ", 
     SubsuperscriptBox[
      StyleBox["L", "TI"], 
      StyleBox["k", "TI"], "\[Dagger]"], "-", "1", "/", "2", "{", 
     SubsuperscriptBox[
      StyleBox["L", "TI"], 
      StyleBox["k", "TI"], "\[Dagger]"], 
     SubscriptBox[
      StyleBox["L", "TI"], 
      StyleBox["k", "TI"]]}], ",", 
    RowBox[{
     StyleBox["\[Rho]", "TI"], "}"}]}], 
   StyleBox[")",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "9a103b6f-dd63-497b-bb75-3908a912482e"],
 ". In Wolfram Mathematica, you can solve this Lindblad master equation \
numerically using the resource function ",
 ButtonBox["LindbladSolve",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://resources.wolframcloud.com/FunctionRepository/resources/\
LindbladSolve"], None}],
 " which takes as input the Hamiltonian, the list of Lindblad operators, the \
initial state, and the time interval, and returns the time-evolved density \
matrix symbolically or numerically."
}], "Text",ExpressionUUID->"38f3157c-c98e-4c69-8710-05216068064f"],

Cell[TextData[{
 "For values of ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["\[Omega]", "TI"], 
   StyleBox["x", "TI"]]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "5ae63ed6-4eea-4f05-8ce6-9e55a0cc5b5e"],
 " and \[Gamma] we used in above simulations, solve the Lindblad equation \
numerically:"
}], "Text",ExpressionUUID->"7ebcc0b1-c2b9-44a8-b57c-5b18049e9baf"],

Cell[BoxData[
 RowBox[{"\[Rho]t", " ", "=", " ", 
  RowBox[{"With", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{"\[Omega]x", " ", "=", " ", "2"}], ",", " ", 
      RowBox[{"\[Gamma]", " ", "=", " ", ".2"}]}], "}"}], ",", " ", 
    RowBox[{
     RowBox[{"ResourceFunction", "[", "\n", 
      RowBox[{"ResourceObject", "[", 
       RowBox[{
        RowBox[{"<|", 
         RowBox[{
          RowBox[{"\"\<Name\>\"", " ", "->", " ", "\"\<LindbladSolve\>\""}], ",",
           " ", "\n", "      ", 
          
          RowBox[{"\"\<ShortName\>\"", " ", "->", 
           " ", "\"\<LindbladSolve\>\""}], ",", " ", "\n", "      ", 
          
          RowBox[{"\"\<UUID\>\"", " ", "->", 
           " ", "\"\<2fb9b1f8-48b5-4683-8965-99b71d387bf2\>\""}], ",", " ", 
          "\n", "      ", 
          
          RowBox[{"\"\<ResourceType\>\"", " ", "->", 
           " ", "\"\<Function\>\""}], ",", " ", 
          RowBox[{"\"\<Version\>\"", " ", "->", " ", "\"\<1.0.0\>\""}], ",", 
          " ", "\n", "      ", 
          
          RowBox[{"\"\<Description\>\"", " ", "->", 
           " ", "\"\<Solve the Lindblad master equation\>\""}], ",", " ", 
          "\n", "      ", 
          RowBox[{"\"\<RepositoryLocation\>\"", " ", "->", " ", 
           RowBox[{
           "URL", "[", "\n", 
            "       ", \
"\"\<https://www.wolframcloud.com/obj/resourcesystem/api/1.0\>\"", "]"}]}], ",",
           " ", "\n", "      ", 
          
          RowBox[{"\"\<SymbolName\>\"", " ", "->", 
           " ", "\"\<FunctionRepository`$d7deeb19fe0d4b10a065b53823858cf0`\
LindbladSolve\>\""}], ",", " ", "\n", "      ", 
          RowBox[{"\"\<FunctionLocation\>\"", " ", "->", " ", 
           RowBox[{
           "CloudObject", "[", "\n", 
            "       ", \
"\"\<https://www.wolframcloud.com/obj/d69ea1bb-70ba-41dd-a54f-17256089991f\>\"\
", "]"}]}]}], "|>"}], ",", " ", 
        RowBox[{"ResourceSystemBase", " ", "->", " ", "Automatic"}]}], "]"}], 
      "]"}], "[", "\n", "   ", 
     RowBox[{
      RowBox[{
       RowBox[{"1", "/", "2"}], " ", "\[Omega]x", " ", 
       RowBox[{"PauliMatrix", "[", "1", "]"}]}], ",", " ", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"Sqrt", "[", "\[Gamma]", "]"}], " ", 
        RowBox[{"PauliMatrix", "[", "3", "]"}]}], "}"}], ",", " ", "\n", 
      "   ", 
      RowBox[{"DensityMatrix", "[", 
       RowBox[{"FromSphericalCoordinates", "[", 
        RowBox[{"{", 
         RowBox[{"1", ",", " ", 
          RowBox[{"\[Pi]", "/", "4"}], ",", " ", "0"}], "}"}], "]"}], "]"}], ",",
       " ", 
      RowBox[{"{", 
       RowBox[{"t", ",", " ", "0", ",", " ", "\n", "    ", "10"}], "}"}]}], 
     "]"}]}], "]"}]}]], "Input",
 CellLabel->
  "In[295]:= ",ExpressionUUID->"0732741a-6c42-4424-8b5c-35239e2f2818"],

Cell["\<\
Plot the time-evolution of the Bloch vector in Cartesian coordinate:\
\>", "Text",ExpressionUUID->"66af642a-1036-448f-8808-2996ef477e2a"],

Cell[BoxData[
 RowBox[{"Plot", "[", 
  RowBox[{
   RowBox[{"Evaluate", "@", 
    RowBox[{"Re", "@", 
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{"Tr", "[", 
        RowBox[{
         RowBox[{"\[Rho]t", "[", "t", "]"}], " ", ".", " ", 
         RowBox[{"PauliMatrix", "[", "j", "]"}]}], "]"}], ",", " ", 
       RowBox[{"{", 
        RowBox[{"j", ",", " ", "3"}], "}"}]}], "]"}]}]}], ",", " ", 
   RowBox[{"{", 
    RowBox[{"t", ",", " ", "\n", "  ", "0", ",", " ", "10"}], "}"}], ",", " ", 
   RowBox[{"PlotRange", " ", "->", " ", "All"}], ",", " ", 
   RowBox[{"PlotLegends", " ", "->", " ", 
    RowBox[{"{", 
     RowBox[{"\"\<x\>\"", ",", " ", "\"\<y\>\"", ",", " ", "\"\<z\>\""}], 
     "}"}]}], ",", " ", "\n", " ", 
   RowBox[{
   "PlotLabel", " ", "->", " ", "\n", 
    "  ", "\"\<Lindblad DE for Cartesian components of\n the Bloch vector \n\
\\!\\(\\*OverscriptBox[\\(r\\), \
\\(\[RightVector]\\)]\\)={\[LeftAngleBracket]Subscript[\[Sigma], \n    x]\
\[RightAngleBracket],\[LeftAngleBracket]Subscript[\[Sigma], \n   y]\
\[RightAngleBracket],\[LeftAngleBracket]Subscript[\[Sigma], \n   z]\
\[RightAngleBracket]}\>\""}], ",", " ", 
   RowBox[{"Frame", " ", "->", " ", "True"}], ",", " ", "\n", " ", 
   RowBox[{"FrameLabel", " ", "->", " ", 
    RowBox[{"{", 
     RowBox[{"\"\<Time\>\"", ",", " ", "\n", 
      "   ", "\"\<\[LeftAngleBracket]\\!\\(\\*SubscriptBox[\\(\[Sigma]\\), \
\\(j\\)]\\)\[RightAngleBracket]\>\""}], "}"}]}], ",", "\n", "  ", 
   RowBox[{"GridLines", " ", "->", " ", "Automatic"}], ",", " ", 
   RowBox[{"PlotRange", " ", "->", " ", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"-", "1"}], ",", " ", "1"}], "}"}]}]}], "]"}]], "Input",
 CellLabel->
  "In[296]:= ",ExpressionUUID->"f6190e12-c36f-4918-bb2e-fa3c0613d16e"],

Cell["\<\
As you can see, this agrees with the result we found earlier by numerically \
averaging over 1,000 noise realizations, up to the small discrepancies \
expected from numerical error and the finite number of samples.\
\>", "Text",ExpressionUUID->"b64fe7b2-8f56-4bcb-bd3b-614d6fc03968"],

Cell[BoxData[
 RowBox[{"Legended", "[", 
  RowBox[{
   RowBox[{"Show", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"ResourceFunction", "[", "\"\<BlochSpherePlot\>\"", "]"}], "[", 
      
      RowBox[{"ImageSize", " ", "->", " ", "200"}], "]"}], ",", "\n", "   ", 
     RowBox[{"ParametricPlot3D", "[", 
      RowBox[{
       RowBox[{"Re", "@", 
        RowBox[{"BlochVector", "[", 
         RowBox[{"\[Rho]t", "[", "t", "]"}], "]"}]}], ",", " ", 
