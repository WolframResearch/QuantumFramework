          RowBox[{"(", 
           RowBox[{"I", " ", "\[Phi]"}], ")"}]}]}], " ", 
        RowBox[{"Cos", "[", 
         RowBox[{"\[Theta]", "/", "2"}], "]"}]}]}], "}"}]}], "}"}], ",", " ", 
   "\n", " ", 
