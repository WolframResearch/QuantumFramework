Cell[BoxData[
 RowBox[{
  RowBox[{"With", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{"v1", " ", "=", " ", 
       RowBox[{"Array", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"Subscript", "[", 
           RowBox[{"\[FormalA]", ",", " ", "##"}], "]"}], " ", "&"}], ",", 
         " ", "3"}], "]"}]}], ",", " ", "\n", "   ", 
      RowBox[{"v2", " ", "=", " ", 
       RowBox[{"Array", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"Subscript", "[", 
           RowBox[{"\[FormalB]", ",", " ", "##"}], "]"}], " ", "&"}], ",", 
         " ", "3"}], "]"}]}], ",", " ", "\n", "   ", 
      RowBox[{"v3", " ", "=", " ", 
       RowBox[{"Array", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"Subscript", "[", 
           RowBox[{"\[FormalC]", ",", " ", "##"}], "]"}], " ", "&"}], ",", 
         " ", "3"}], "]"}]}]}], "}"}], ",", " ", "\n", "  ", 
    RowBox[{
     RowBox[{"v1", " ", ".", " ", 
      RowBox[{"Cross", "[", 
       RowBox[{"v2", ",", " ", "v3"}], "]"}]}], " ", "==", " ", "\n", "   ", 
     RowBox[{"TensorContract", "[", "\n", "    ", 
      RowBox[{
       RowBox[{"TensorProduct", "[", 
        RowBox[{
         RowBox[{"LeviCivitaTensor", "[", "3", "]"}], ",", " ", "v1", ",", 
         " ", "v2", ",", " ", "\n", "     ", "v3"}], "]"}], ",", " ", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"1", ",", " ", "4"}], "}"}], ",", " ", 
         RowBox[{"{", 
          RowBox[{"2", ",", " ", "5"}], "}"}], ",", " ", 
         RowBox[{"{", 
          RowBox[{"3", ",", " ", "6"}], "}"}]}], "}"}]}], "]"}]}]}], "]"}], 
  " ", "//", " ", "FullSimplify"}]], "Input",
 CellLabel->
  "In[155]:= ",ExpressionUUID->"1b34a594-1c44-4db6-b4e9-ec13dfdc4584"],

Cell[TextData[{
 "Verify that ",
 Cell[BoxData[
  RowBox[{
   OverscriptBox[
    StyleBox["a", "TI"], "\[RightVector]"], ".", 
   RowBox[{
    StyleBox["(",
     SpanMaxSize->1], 
    RowBox[{
     OverscriptBox[
      StyleBox["b", "TI"], "\[RightVector]"], "\[Times]", 
     OverscriptBox[
      StyleBox["c", "TI"], "\[RightVector]"]}], 
    StyleBox[")",
