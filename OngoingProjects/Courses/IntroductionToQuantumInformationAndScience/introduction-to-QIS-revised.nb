Cell[BoxData[
 RowBox[{"With", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{"y", " ", "=", " ", 
      RowBox[{"RotationMatrix", "[", 
       RowBox[{"\[Pi]", ",", " ", 
        RowBox[{"{", 
         RowBox[{"0", ",", " ", "1", ",", " ", "0"}], "}"}]}], "]"}]}], ",", 
     " ", "\n", "  ", 
     RowBox[{"x", " ", "=", " ", 
      RowBox[{"RotationMatrix", "[", 
       RowBox[{
        RowBox[{"\[Pi]", "/", "3"}], ",", " ", 
        RowBox[{"{", 
         RowBox[{"1", ",", " ", "0", ",", " ", "0"}], "}"}]}], "]"}]}]}], 
    "}"}], ",", "\n", " ", 
   RowBox[{"Row", "[", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{
       RowBox[{"ResourceFunction", "[", "\"\<BlochSpherePlot\>\"", "]"}], "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{"0", ",", " ", "0", ",", " ", "1"}], "}"}], ",", " ", "\n",
           "     ", 
          RowBox[{"y", " ", ".", " ", "x", " ", ".", " ", 
           RowBox[{"{", 
            RowBox[{"0", ",", " ", "0", ",", " ", "1"}], "}"}]}]}], "}"}], ",",
         " ", 
        RowBox[{"ImageSize", " ", "->", " ", "150"}], ",", " ", "\n", "    ", 
        
        RowBox[{
        "PlotLabel", " ", "->", " ", "\n", 
         "     ", "\"\<First \\!\\(\\*SubscriptBox[\\(X\\), \
\\(\[Pi]/2\\)]\\), then \\!\\(\\*SubscriptBox[\\(Y\\), \\(\[Pi]/2\\)]\\)\n\
\>\""}]}], "]"}], ",", " ", "\"\<  \>\"", ",", " ", 
      RowBox[{
       RowBox[{"ResourceFunction", "[", "\"\<BlochSpherePlot\>\"", "]"}], "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{"0", ",", " ", "0", ",", " ", "1"}], "}"}], ",", " ", "\n",
           "     ", 
          RowBox[{"x", " ", ".", " ", "y", " ", ".", " ", 
           RowBox[{"{", 
            RowBox[{"0", ",", " ", "0", ",", " ", "1"}], "}"}]}]}], "}"}], ",",
         " ", 
        RowBox[{"ImageSize", " ", "->", " ", "150"}], ",", " ", "\n", "    ", 
        
        RowBox[{
        "PlotLabel", " ", "->", " ", "\n", 
         "     ", "\"\<First \\!\\(\\*SubscriptBox[\\(Y\\), \
\\(\[Pi]/2\\)]\\), then \\!\\(\\*SubscriptBox[\\(X\\), \\(\[Pi]/2\\)]\\)\n\
\>\""}]}], "]"}]}], "}"}], "]"}]}], "]"}]], "Input",
 CellLabel->
  "In[185]:= ",ExpressionUUID->"da6de855-ce3f-4d13-b55b-69ef042f8ff9"],

Cell[TextData[{
 "As one can see in above example, the order in which the control pulses are \
applied is crucial because the corresponding rotation operators (matrices) \
generally do not commute. As one can see, in a quantum system, this \
non-commutativity means that applying pulse ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["X", "TI"], 
   RowBox[{"\[Pi]", "/", "3"}]]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "e8495e49-06d8-460a-82eb-d4bfbe9770ed"],
 " followed by pulse ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["Y", "TI"], "\[Pi]"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "4f904921-e66c-4693-a5f9-7791da48c2bc"],
 " produces a different overall state rotation than applying ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["Y", "TI"], "\[Pi]"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "26364b33-5d36-41c9-a646-fd0254e3fcb4"],
 " followed by ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["X", "TI"], 
   RowBox[{"\[Pi]", "/", "3"}]]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "1835b426-e076-4154-8d3f-b69a4e3867ec"],
 "."
}], "Text",ExpressionUUID->"55390fd6-b8c6-4eaf-908c-4324d468636a"],

Cell[TextData[{
 "Verify that ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["X", "TI"], 
   RowBox[{"\[Pi]", "/", "3"}]]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "a77d0d6d-dc30-46a4-a255-209f3d33e09a"],
 " and ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["Y", "TI"], "\[Pi]"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "c95ad00d-c43e-4b47-add9-f6f2bc68c751"],
 " do not commute:"
}], "Text",ExpressionUUID->"7f27d710-af5b-4472-9685-95f5b7e55224"],

Cell[BoxData[
 RowBox[{
  RowBox[{"Commutator", "[", 
   RowBox[{
    RowBox[{"RotationMatrix", "[", 
     RowBox[{
      RowBox[{"\[Pi]", "/", "3"}], ",", " ", 
      RowBox[{"{", 
       RowBox[{"1", ",", " ", "0", ",", " ", "0"}], "}"}]}], "]"}], ",", " ", 
    "\n", "  ", 
    RowBox[{"RotationMatrix", "[", 
     RowBox[{"\[Pi]", ",", " ", 
      RowBox[{"{", 
       RowBox[{"0", ",", " ", "1", ",", " ", "0"}], "}"}]}], "]"}], ",", " ", 
    "Dot"}], "]"}], " ", "!=", " ", 
  RowBox[{"{", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"0", ",", " ", "0"}], "}"}], ",", " ", 
    RowBox[{"{", 
     RowBox[{"0", ",", " ", "0"}], "}"}]}], "}"}]}]], "Input",
 CellLabel->
  "In[186]:= ",ExpressionUUID->"8a8f3f12-7692-4c03-a30a-e45d31c69007"],

Cell[TextData[{
 "Assume the initial qubit state is represented by the Bloch vector ",
 Cell[BoxData[
  SubscriptBox[
   OverscriptBox[
    StyleBox["r", "TI"], "\[RightVector]"], "1"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "d6804b91-2d87-46d4-b502-965d41359194"],
 ". We now seek a rotation that maps ",
 Cell[BoxData[
  RowBox[{
   SubscriptBox[
    OverscriptBox[
     StyleBox["r", "TI"], "\[RightVector]"], "1"], "\[Rule]", 
   SubscriptBox[
    OverscriptBox[
     StyleBox["r", "TI"], "\[RightVector]"], "2"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "1788518c-0aea-4b01-a7f6-a5b83f12e78d"],
 ". Geometrically, this is a rigid rotation in the plane spanned by ",
 Cell[BoxData[
  SubscriptBox[
   OverscriptBox[
    StyleBox["r", "TI"], "\[RightVector]"], "1"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "e65c6fef-685e-4f8a-9a4e-7d2e14dada04"],
 " and ",
 Cell[BoxData[
  SubscriptBox[
   OverscriptBox[
    StyleBox["r", "TI"], "\[RightVector]"], "2"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "ffc0ece3-e5f0-4eba-9f51-9e5c87e50ae0"],
 ", through the angle between the two vectors. The plane spanned by ",
 Cell[BoxData[
  SubscriptBox[
   OverscriptBox[
    StyleBox["r", "TI"], "\[RightVector]"], "1"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "bf738100-c627-4f62-9ad2-d0eaf07814cc"],
 " and ",
 Cell[BoxData[
  SubscriptBox[
   OverscriptBox[
    StyleBox["r", "TI"], "\[RightVector]"], "2"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "feba8d12-1c70-46ac-ad26-31b9f4e19b46"],
 " is also fully specified by the the vector cross product ",
 Cell[BoxData[
  SubscriptBox[
   OverscriptBox[
    StyleBox["r", "TI"], "\[RightVector]"], "1"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "6cfa331c-e6e0-4a4f-8158-f1658b76ab32"],
 " and ",
 Cell[BoxData[
  SubscriptBox[
   OverscriptBox[
    StyleBox["r", "TI"], "\[RightVector]"], "2"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "75f7ae8f-a02a-40a0-b998-9c80bcb2a1a8"],
 ". In short, the rotation is given by ",
 Cell[BoxData[
  RowBox[{
   SubscriptBox["\[ScriptCapitalR]", 
    RowBox[{
     SubscriptBox[
      OverscriptBox[
       StyleBox["n", "TI"], "\[RightVector]"], "1"], "\[Times]", 
     SubscriptBox[
      OverscriptBox[
       StyleBox["n", "TI"], "\[RightVector]"], "2"]}]], 
   StyleBox["(",
    SpanMaxSize->1], 
   RowBox[{
    StyleBox["A", "TI"], 
    StyleBox["r", "TI"], 
    StyleBox["c", "TI"], 
    StyleBox["C", "TI"], 
    StyleBox["o", "TI"], 
    StyleBox["s", "TI"], 
    StyleBox["[",
     SpanMaxSize->1], 
    RowBox[{
     SubscriptBox[
      OverscriptBox[
       StyleBox["n", "TI"], "\[RightVector]"], "1"], ".", 
     SubscriptBox[
      OverscriptBox[
       StyleBox["n", "TI"], "\[RightVector]"], "2"]}], 
    StyleBox["]",
     SpanMaxSize->1]}], 
   StyleBox[")",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "69f7346e-13a9-410d-a7c3-88e9aae8402e"],
 " with unit vectors ",
 Cell[BoxData[
  RowBox[{
   SubscriptBox[
    OverscriptBox[
     StyleBox["n", "TI"], "\[RightVector]"], 
    StyleBox["j", "TI"]], "=", 
   SubscriptBox[
    OverscriptBox[
     StyleBox["r", "TI"], "\[RightVector]"], 
    StyleBox["j", "TI"]], "/", "\[LeftBracketingBar]", 
   SubscriptBox[
    OverscriptBox[
     StyleBox["r", "TI"], "\[RightVector]"], 
    StyleBox["j", "TI"]], "\[RightBracketingBar]"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "af4424f3-0b03-467b-a689-c838f871e016"],
 "."
}], "Text",ExpressionUUID->"d09abb94-ba30-42b0-9417-c627b90e87f4"],

Cell["\<\
For two Bloch vectors, visualize the plane spanned by them and also the \
perpendicular vector defining it:\
\>", "Text",ExpressionUUID->"a75c19ab-9994-46d5-9adc-45714b28d2f7"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"{", 
    RowBox[{"r1", ",", " ", "r2"}], "}"}], " ", "=", " ", 
   RowBox[{"Normalize", " ", "/@", " ", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{"-", "0.37"}], ",", " ", 
        RowBox[{"-", "0.88"}], ",", " ", 
        RowBox[{"-", "0.3"}]}], "}"}], ",", " ", 
      RowBox[{"{", 
       RowBox[{"0.6", ",", " ", 
        RowBox[{"-", "0.66"}], ",", " ", "0.45"}], "}"}]}], "}"}]}]}], 
  ";"}], "\n", 
 RowBox[{"With", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{"\[Theta]", " ", "=", " ", 
      RowBox[{"VectorAngle", "[", 
       RowBox[{"r1", ",", " ", "r2"}], "]"}]}], ",", " ", 
     RowBox[{"n", " ", "=", " ", 
      RowBox[{"Cross", "[", 
       RowBox[{"r1", ",", " ", "r2"}], "]"}]}]}], "}"}], ",", " ", 
   RowBox[{"{", "\n", "  ", 
    RowBox[{"\[ScriptCapitalR]", " ", "=", " ", "\n", "   ", 
     RowBox[{"ImplicitRegion", "[", "\n", "    ", 
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{"n", " ", ".", " ", 
          RowBox[{"{", 
           RowBox[{"x", ",", " ", "y", ",", " ", "z"}], "}"}]}], " ", "==", 
         " ", "0"}], " ", "&&", " ", 
        RowBox[{
         RowBox[{
          RowBox[{"x", "^", "2"}], " ", "+", " ", 
          RowBox[{"y", "^", "2"}], " ", "+", " ", 
          RowBox[{"z", "^", "2"}]}], " ", "<=", " ", 
         RowBox[{"1", "/", "2"}]}], " ", "&&", " ", "\n", "     ", 
        RowBox[{
         RowBox[{
          RowBox[{"Cross", "[", 
           RowBox[{"r1", ",", " ", 
            RowBox[{"{", 
             RowBox[{"x", ",", " ", "y", ",", " ", "z"}], "}"}]}], "]"}], " ",
           ".", " ", "n"}], " ", ">=", " ", "0"}], " ", "&&", " ", "\n", 
        "     ", 
        RowBox[{
         RowBox[{
          RowBox[{"Cross", "[", 
           RowBox[{
            RowBox[{"{", 
             RowBox[{"x", ",", " ", "y", ",", " ", "z"}], "}"}], ",", " ", 
            "r2"}], "]"}], " ", ".", " ", "n"}], " ", ">=", " ", "0"}]}], ",",
        " ", 
       RowBox[{"{", 
        RowBox[{"x", ",", " ", "y", ",", " ", "z"}], "}"}]}], "]"}]}], "}"}], 
   ",", "\n", " ", 
   RowBox[{"Legended", "[", 
    RowBox[{
     RowBox[{"Show", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"ResourceFunction", "[", "\"\<BlochSpherePlot\>\"", "]"}], "[", 
        RowBox[{"{", 
         RowBox[{"r1", ",", " ", "r2", ",", " ", "n"}], "}"}], "]"}], ",", 
       " ", "\n", "   ", 
       RowBox[{"Region", "@", "\[ScriptCapitalR]"}], ",", " ", "\n", "   ", 
       RowBox[{"Graphics3D", "[", 
        RowBox[{"{", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{"Opacity", "[", ".5", "]"}], ",", " ", 
           RowBox[{"InfinitePlane", "[", 
            RowBox[{
             RowBox[{"{", 
              RowBox[{"0", ",", " ", "0", ",", " ", "0"}], "}"}], ",", " ", 
             RowBox[{"{", 
              RowBox[{"r1", ",", " ", "r2"}], "}"}]}], " ", "]"}]}], "}"}], 
         "}"}], "]"}], ",", " ", "\n", "   ", 
       RowBox[{"PlotRange", " ", "->", " ", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{
            RowBox[{"-", "1"}], ",", " ", "1"}], "}"}], ",", " ", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"-", "1"}], ",", " ", "1"}], "}"}], ",", " ", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"-", "1"}], ",", " ", "1"}], "}"}]}], "}"}]}], ",", " ", 
       RowBox[{"Boxed", " ", "->", " ", "False"}]}], "]"}], ",", " ", "\n", 
     "  ", 
     RowBox[{"SwatchLegend", "[", "\n", "   ", 
      RowBox[{
       RowBox[{"Table", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"ColorData", "[", "97", "]"}], "[", "j", "]"}], ",", " ", 
         RowBox[{"{", 
          RowBox[{"j", ",", " ", "\n", "     ", "3"}], "}"}]}], "]"}], ",", 
       " ", 
       RowBox[{"{", 
        RowBox[{"\"\<\\!\\(\\*FormBox[SubscriptBox[OverscriptBox[\\(r\\), \\(\
\[RightVector]\\)], \\(1\\)],\nTraditionalForm]\\)\>\"", ",", " ", "\n", 
         "    ", "\"\<\\!\\(\\*FormBox[SubscriptBox[OverscriptBox[\\(r\\), \
\\(\[RightVector]\\)], \\(2\\)],\nTraditionalForm]\\)\>\"", ",", " ", "\n", 
         "    ", "\"\<\\!\\(\\*FormBox[SubscriptBox[OverscriptBox[\\(r\\), \
\\(\[RightVector]\\)], \\(1\\)],\n\
TraditionalForm]\\)\[Times]\\!\\(\\*FormBox[SubscriptBox[OverscriptBox[\\(r\\)\
, \\(\[RightVector]\\)], \\(2\\)],\nTraditionalForm]\\)\>\""}], "}"}]}], 
      "]"}]}], "]"}]}], "]"}]}], "Input",
 CellLabel->
  "In[187]:= ",ExpressionUUID->"70d5c9cc-de9f-47f8-a7ad-0dc610532348"],

Cell[TextData[{
 "Given two vectors above (",
 Cell[BoxData[
  SubscriptBox[
   OverscriptBox[
    StyleBox["r", "TI"], "\[RightVector]"], "1"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "0e529fa0-3b63-4c44-827f-3fc6fbe02dec"],
 " and ",
 Cell[BoxData[
  SubscriptBox[
   OverscriptBox[
    StyleBox["r", "TI"], "\[RightVector]"], "2"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "66c4d9ec-4a24-483e-bd3d-2a2f5f2e3f89"],
 "), generate the rotation matrix that rotates by the angle between vectors, \
in the plane spanned by vectors:"
}], "Text",ExpressionUUID->"a9bcf844-318a-42c7-a197-f7c6b6445dc2"],

Cell[BoxData[
 RowBox[{
  RowBox[{"RotationMatrix", "[", 
   RowBox[{
    RowBox[{"VectorAngle", "[", 
     RowBox[{"r1", ",", " ", "r2"}], "]"}], ",", " ", 
    RowBox[{"Cross", "[", 
     RowBox[{"r1", ",", " ", "r2"}], "]"}]}], "]"}], " ", "//", " ", 
  "MatrixForm"}]], "Input",
 CellLabel->
  "In[188]:= ",ExpressionUUID->"2ec51a04-cc0a-47e4-b272-111d83a0ece9"],

Cell[TextData[{
 "Verify that above rotation transform ",
 Cell[BoxData[
  SubscriptBox[
   OverscriptBox[
    StyleBox["r", "TI"], "\[RightVector]"], "1"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "405dc6c2-a01e-46fd-9507-4b437d5a94b0"],
 " into ",
 Cell[BoxData[
  SubscriptBox[
   OverscriptBox[
    StyleBox["r", "TI"], "\[RightVector]"], "2"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "d84fd7c1-d576-456f-9a01-ab4c8d9c3868"],
 ":"
}], "Text",ExpressionUUID->"4de98aa3-0a8c-41b8-bffc-993af77b4ba5"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"RotationMatrix", "[", 
    RowBox[{
     RowBox[{"VectorAngle", "[", 
      RowBox[{"r1", ",", " ", "r2"}], "]"}], ",", " ", 
     RowBox[{"Cross", "[", 
      RowBox[{"r1", ",", " ", "r2"}], "]"}]}], "]"}], " ", ".", " ", "r1"}], 
  " ", "==", " ", "r2"}]], "Input",
 CellLabel->
  "In[189]:= ",ExpressionUUID->"d8b72399-aba7-4e57-aedb-d773e2168e89"],

Cell[TextData[{
 "Perform the same transformation in SU(2) and verify that ",
 Cell[BoxData[
  RowBox[{
   RowBox[{
    SubscriptBox[
     StyleBox["\[Rho]", "TI"], "2"], "=", 
    StyleBox["U", "TI"]}], ".", 
   SubscriptBox[
    StyleBox["\[Rho]", "TI"], "1"], ".", 
   SuperscriptBox[
    StyleBox["U", "TI"], "\[Dagger]"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "f69cde26-4066-4524-a434-055a1a0ac2c7"],
 " with ",
 Cell[BoxData[
  RowBox[{
   SubscriptBox[
    StyleBox["\[Rho]", "TI"], 
    StyleBox["j", "TI"]], "=", "1", "/", "2", 
   StyleBox["(",
    SpanMaxSize->1], 
   RowBox[{
    RowBox[{"\|01d540", "+", 
     SubscriptBox[
      OverscriptBox[
       StyleBox["r", "TI"], "\[RightVector]"], 
      StyleBox["j", "TI"]]}], ".", 
    OverscriptBox[
     StyleBox["\[Sigma]", "TI"], "\[RightVector]"]}], 
   StyleBox[")",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "6a403c44-b3b5-486f-9f89-8e2c3de0e1f8"],
 " and ",
 Cell[BoxData[
  RowBox[{
   StyleBox["U", "TI"], "=", 
   SuperscriptBox[
    StyleBox["e", "TI"], 
    RowBox[{
     RowBox[{"-", 
      StyleBox["i", "TI"], " ", 
      StyleBox["\[Theta]", "TI"], " ", 
      OverscriptBox[
       StyleBox["n", "TI"], "\[RightVector]"]}], ".", 
     OverscriptBox[
      StyleBox["\[Sigma]", "TI"], "\[RightVector]"]}]]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "4fc3b420-0bde-468c-85cb-f3865675342f"],
 " where ",
 Cell[BoxData[
  StyleBox["\[Theta]", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "60ffc29c-c926-4f96-84f2-a2c2e803804a"],
 " is the angle between ",
 Cell[BoxData[
  SubscriptBox[
   OverscriptBox[
    StyleBox["r", "TI"], "\[RightVector]"], "1"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "75c55e35-3497-4139-aaa6-03f78a7b52e6"],
 " and ",
 Cell[BoxData[
  SubscriptBox[
   OverscriptBox[
    StyleBox["r", "TI"], "\[RightVector]"], "2"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "cf43df89-def0-4977-ac93-6bd151e6e4a0"],
 " and ",
 Cell[BoxData[
  RowBox[{
   OverscriptBox[
    StyleBox["n", "TI"], "\[RightVector]"], "=", 
   SubscriptBox[
    OverscriptBox[
     StyleBox["r", "TI"], "\[RightVector]"], "1"], "\[Times]", 
   SubscriptBox[
    OverscriptBox[
     StyleBox["r", "TI"], "\[RightVector]"], "2"], "/", "\[LeftBracketingBar]", 
   RowBox[{
    SubscriptBox[
     OverscriptBox[
      StyleBox["r", "TI"], "\[RightVector]"], "1"], "\[Times]", 
    SubscriptBox[
     OverscriptBox[
      StyleBox["r", "TI"], "\[RightVector]"], "2"]}], 
   "\[RightBracketingBar]"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "a64a9621-c2c4-4996-855b-8ddfeea89f17"],
 ":"
}], "Text",ExpressionUUID->"5536305a-6662-49ce-9ec0-97dbd2e1bf63"],

Cell[BoxData[
 RowBox[{"With", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{"\[Sigma]", " ", "=", " ", 
      RowBox[{"Table", "[", 
       RowBox[{
        RowBox[{"PauliMatrix", "[", "j", "]"}], ",", " ", 
        RowBox[{"{", 
         RowBox[{"j", ",", " ", "3"}], "}"}]}], "]"}]}], ",", " ", 
     RowBox[{"\[Theta]", " ", "=", " ", "\n", "   ", 
      RowBox[{"VectorAngle", "[", 
       RowBox[{"r1", ",", " ", "r2"}], "]"}]}], ",", " ", "\n", "  ", 
     RowBox[{"n", " ", "=", " ", 
      RowBox[{"Normalize", "[", 
       RowBox[{"Cross", "[", 
        RowBox[{"r1", ",", " ", "r2"}], "]"}], "]"}]}]}], "}"}], ",", " ", 
   RowBox[{"{", 
    RowBox[{"u", " ", "=", " ", "\n", "   ", 
     RowBox[{"MatrixExp", "[", 
      RowBox[{
       RowBox[{"-", "I"}], " ", 
       RowBox[{"\[Theta]", "/", "2"}], " ", 
       RowBox[{"n", " ", ".", " ", "\[Sigma]"}]}], "]"}]}], "}"}], ",", " ", 
   "\n", " ", 
   RowBox[{
    RowBox[{"Chop", "[", 
     RowBox[{"u", " ", ".", " ", 
      RowBox[{"DensityMatrix", "[", "r1", "]"}], " ", ".", " ", 
      RowBox[{"ConjugateTranspose", "[", "u", "]"}]}], "]"}], " ", "==", " ", 
    "\n", "  ", 
    RowBox[{"DensityMatrix", "[", "r2", "]"}]}]}], "]"}]], "Input",
 CellLabel->
  "In[190]:= ",ExpressionUUID->"2f269c81-d472-4d79-ab61-0c8dc56e7ac9"],

Cell[TextData[{
 "Therefore, given any initial qubit state (represented by a Bloch vector), \
one can find a proper transformation (a unitary operator) that maps it into \
any desired qubit state (represented by another Bloch vector). So the problem \
\[OpenCurlyDoubleQuote]how do I implement an arbitrary single-qubit \
unitary/gate?\[CloseCurlyDoubleQuote] is in practice \
\[OpenCurlyDoubleQuote]how do I build an arbitrary 3D rotation?\
\[CloseCurlyDoubleQuote] However, transformation by angle \[Theta] around a \
desired unit vector ",
 Cell[BoxData[
  OverscriptBox[
   StyleBox["n", "TI"], "\[RightVector]"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "1463313d-f876-48b0-b45d-e36850ff4b1d"],
 " is not usually easy to implement experimentally. Because hardware rarely \
says, \[OpenCurlyDoubleQuote]Sure, pick any axis ",
 Cell[BoxData[
  OverscriptBox[
   StyleBox["n", "TI"], "\[RightVector]"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "d2a8966d-ae64-44fc-a0dd-a4ba7ef384a5"],
 " in 3D and rotate about it.\[CloseCurlyDoubleQuote] Hardware is more like: \
\[OpenCurlyDoubleQuote]I can rotate around these axes very well (fast), and \
around that axis in a special way (cheap or virtual).\[CloseCurlyDoubleQuote] \
So the real need is not just to describe a rotation, but to factor it into \
rotations about axes your system can actually perform cleanly. That is \
exactly what Euler decomposition does."
}], "Text",ExpressionUUID->"1eee3454-caea-4079-9326-3c2e33f7f6d8"],

Cell[TextData[{
 "Euler decomposition states that any 3D rotation can be expressed as a \
product of three rotations about fixed axes: ",
 Cell[BoxData[
  RowBox[{
   SubscriptBox["\[ScriptCapitalR]", 
    OverscriptBox[
     StyleBox["n", "TI"], "\[RightVector]"]], 
   StyleBox["(",
    SpanMaxSize->1], 
   StyleBox["\[Theta]", "TI"], 
   StyleBox[")",
    SpanMaxSize->1], "=", 
   SubscriptBox["\[ScriptCapitalR]", 
    SubscriptBox[
     OverscriptBox[
      StyleBox["n", "TI"], "\[RightVector]"], "1"]], 
   StyleBox["(",
    SpanMaxSize->1], 
   StyleBox["\[Alpha]", "TI"], 
   StyleBox[")",
    SpanMaxSize->1], 
   SubscriptBox["\[ScriptCapitalR]", 
    SubscriptBox[
     OverscriptBox[
      StyleBox["n", "TI"], "\[RightVector]"], "2"]], 
   StyleBox["(",
    SpanMaxSize->1], 
   StyleBox["\[Beta]", "TI"], 
   StyleBox[")",
    SpanMaxSize->1], 
   SubscriptBox["\[ScriptCapitalR]", 
    SubscriptBox[
     OverscriptBox[
      StyleBox["n", "TI"], "\[RightVector]"], "3"]], 
   StyleBox["(",
    SpanMaxSize->1], 
   StyleBox["\[Gamma]", "TI"], 
   StyleBox[")",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "4965e3d9-b37c-461c-99d4-d1699a40b8cc"],
 ". In other words, it provides a constructive recipe: by choosing the angles \
\[Alpha], \[Beta], and \[Gamma] and applying these three elementary rotations \
in the correct order, one can reproduce any desired rotation."
}], "Text",ExpressionUUID->"3093f97d-7dae-4aa1-bd71-9afa5e0dc60c"],

Cell[TextData[{
 "Compute Euler angles \[Alpha], \[Beta], and \[Gamma] in the \
Euler-decomposed 3D rotation ",
 Cell[BoxData[
  RowBox[{
   SubscriptBox["\[ScriptCapitalR]", 
    OverscriptBox[
     StyleBox["n", "TI"], "\[RightVector]"]], 
   StyleBox["(",
    SpanMaxSize->1], 
   RowBox[{"\[Pi]", "/", "3"}], 
   StyleBox[")",
    SpanMaxSize->1], "=", 
   SubscriptBox["\[ScriptCapitalR]", 
    StyleBox["z", "TI"]], 
   StyleBox["(",
    SpanMaxSize->1], 
   StyleBox["\[Alpha]", "TI"], 
   StyleBox[")",
    SpanMaxSize->1], 
   SubscriptBox["\[ScriptCapitalR]", 
    StyleBox["y", "TI"]], 
   StyleBox["(",
    SpanMaxSize->1], 
   StyleBox["\[Beta]", "TI"], 
   StyleBox[")",
    SpanMaxSize->1], 
   SubscriptBox["\[ScriptCapitalR]", 
    StyleBox["z", "TI"]], 
   StyleBox["(",
    SpanMaxSize->1], 
   StyleBox["\[Gamma]", "TI"], 
   StyleBox[")",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "a9993da4-a208-4b07-80cc-0db2e963a0bc"],
 " with ",
 Cell[BoxData[
  RowBox[{
   RowBox[{
    OverscriptBox[
     StyleBox["n", "TI"], "\[RightVector]"], "=", "{", 
    StyleBox["C", "TI"], 
    StyleBox["o", "TI"], 
    StyleBox["s", "TI"], 
    StyleBox["[",
     SpanMaxSize->1], 
    RowBox[{"\[Pi]", "/", "8"}], 
    StyleBox["]",
     SpanMaxSize->1]}], ",", 
   RowBox[{
    StyleBox["S", "TI"], 
    StyleBox["i", "TI"], 
    StyleBox["n", "TI"], 
    StyleBox["[",
     SpanMaxSize->1], 
    RowBox[{"\[Pi]", "/", "8"}], 
    StyleBox["]",
     SpanMaxSize->1]}], ",", 
   RowBox[{"0", "}"}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "eae6b7fe-5459-4c80-be67-6595c55f15ab"],
 ":"
}], "Text",ExpressionUUID->"6c3e5996-0675-465f-8267-997dd2cb43d8"],

Cell[BoxData[
 RowBox[{
  RowBox[{"EulerAngles", "[", "\n", "  ", 
   RowBox[{"RotationMatrix", "[", 
    RowBox[{
     RowBox[{"\[Pi]", "/", "3"}], ",", " ", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"Cos", "[", 
        RowBox[{"\[Pi]", "/", "8"}], "]"}], ",", " ", 
       RowBox[{"Sin", "[", 
        RowBox[{"\[Pi]", "/", "8"}], "]"}], ",", " ", "\n", "    ", "0"}], 
      "}"}]}], "]"}], "]"}], " ", "//", " ", "FullSimplify"}]], "Input",
 CellLabel->
  "In[191]:= ",ExpressionUUID->"6e369e70-3cd0-468a-a43f-91d9d9189fdb"],

Cell[TextData[{
 "The decomposition above uses the standard ZYZ Euler convention. In \
pulse-language, it says that a rotation by ",
 Cell[BoxData[
  RowBox[{"\[Pi]", "/", "3"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "e8738486-37d4-4c9a-96f4-d2f530330ba3"],
 " around ",
 Cell[BoxData[
  OverscriptBox[
   StyleBox["n", "TI"], "\[RightVector]"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "f2bd3c0e-0e86-4f6f-ad68-fc6b3609fd89"],
 " can be implemented as the ordered sequence a ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["Z", "TI"], 
   RowBox[{"3", "\[Pi]", "/", "8"}]]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "3e510d8a-256c-489c-8602-203b374da32d"],
 ", followed by ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["Y", "TI"], 
   RowBox[{"\[Pi]", "/", "3"}]]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "85109b13-92da-4d02-962f-e1a34f4a08b2"],
 " and then ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["Z", "TI"], 
   RowBox[{"-", "3", "\[Pi]", "/", "8"}]]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "838c3181-fd9a-4e70-b757-833452554010"],
 "."
}], "Text",ExpressionUUID->"bac11209-e22a-40bf-8b2b-4801e378be48"],

Cell[TextData[{
 "Verify that ",
 Cell[BoxData[
  RowBox[{
   SubscriptBox["\[ScriptCapitalR]", 
    StyleBox["z", "TI"]], 
   StyleBox["(",
    SpanMaxSize->1], 
   StyleBox["\[Alpha]", "TI"], 
   StyleBox[")",
    SpanMaxSize->1], 
   SubscriptBox["\[ScriptCapitalR]", 
    StyleBox["y", "TI"]], 
   StyleBox["(",
    SpanMaxSize->1], 
   StyleBox["\[Beta]", "TI"], 
   StyleBox[")",
    SpanMaxSize->1], 
   SubscriptBox["\[ScriptCapitalR]", 
    StyleBox["z", "TI"]], 
   StyleBox["(",
    SpanMaxSize->1], 
   StyleBox["\[Gamma]", "TI"], 
   StyleBox[")",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "f87e478f-70a6-4b0d-9727-72f02d87e6f8"],
 " with \[Alpha], \[Beta] and \[Gamma] computed above returns the same \
rotation as ",
 Cell[BoxData[
  RowBox[{
   SubscriptBox["\[ScriptCapitalR]", 
    OverscriptBox[
     StyleBox["n", "TI"], "\[RightVector]"]], 
   StyleBox["(",
    SpanMaxSize->1], 
   RowBox[{"\[Pi]", "/", "3"}], 
   StyleBox[")",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "b8ab8040-08fd-436d-9453-75cdbf22bb55"],
 ":"
}], "Text",ExpressionUUID->"9436fdab-73b9-4b2e-ade6-ca2f6d2c214b"],

Cell[BoxData[
 RowBox[{
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"\[Alpha]", ",", " ", "\[Beta]", ",", " ", "\[Gamma]"}], "}"}], ",",
     "\n", "  ", 
    RowBox[{
     RowBox[{
      RowBox[{"{", 
       RowBox[{"\[Alpha]", ",", " ", "\[Beta]", ",", " ", "\[Gamma]"}], "}"}],
       " ", "=", " ", "\n", "   ", 
      RowBox[{"EulerAngles", "[", 
       RowBox[{"RotationMatrix", "[", 
        RowBox[{
         RowBox[{"\[Pi]", "/", "3"}], ",", " ", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{"Cos", "[", 
            RowBox[{"\[Pi]", "/", "8"}], "]"}], ",", " ", 
           RowBox[{"Sin", "[", 
            RowBox[{"\[Pi]", "/", "8"}], "]"}], ",", " ", "0"}], "}"}]}], 
        "]"}], "]"}]}], ";", "\n", "  ", 
     RowBox[{
      RowBox[{
       RowBox[{"RotationMatrix", "[", 
        RowBox[{"\[Alpha]", ",", " ", 
         RowBox[{"{", 
          RowBox[{"0", ",", " ", "0", ",", " ", "1"}], "}"}]}], "]"}], " ", ".",
        " ", "\n", "    ", 
       RowBox[{"RotationMatrix", "[", 
        RowBox[{"\[Beta]", ",", " ", 
         RowBox[{"{", 
          RowBox[{"0", ",", " ", "1", ",", " ", "0"}], "}"}]}], "]"}], " ", ".",
        " ", "\n", "    ", 
       RowBox[{"RotationMatrix", "[", 
        RowBox[{"\[Gamma]", ",", " ", 
         RowBox[{"{", 
          RowBox[{"0", ",", " ", "0", ",", " ", "1"}], "}"}]}], "]"}]}], " ", 
      "==", " ", "\n", "   ", 
      RowBox[{"RotationMatrix", "[", 
       RowBox[{
        RowBox[{"\[Pi]", "/", "3"}], ",", " ", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"Cos", "[", 
           RowBox[{"\[Pi]", "/", "8"}], "]"}], ",", " ", 
          RowBox[{"Sin", "[", 
           RowBox[{"\[Pi]", "/", "8"}], "]"}], ",", " ", "\n", "     ", "0"}],
          "}"}]}], "]"}]}]}]}], "]"}], " ", "//", " ", 
  "FullSimplify"}]], "Input",
 CellLabel->
  "In[192]:= ",ExpressionUUID->"1ead80cb-f331-4ddf-b451-9da6e98f8bed"],

Cell[TextData[{
 "We can translate the Euler decomposition from SO(3) to SU(2) just as \
naturally. In SU(2) the same rotation is implemented by the Euler-product \
unitary ",
 Cell[BoxData[
  RowBox[{
   SuperscriptBox[
    StyleBox["e", "TI"], 
    RowBox[{"-", 
     StyleBox["i", "TI"], " ", 
     StyleBox["\[Alpha]", "TI"], "/", "2", 
     SubscriptBox[
      StyleBox["\[Sigma]", "TI"], 
      StyleBox["z", "TI"]]}]], 
   SuperscriptBox[
    StyleBox["e", "TI"], 
    RowBox[{"-", 
     StyleBox["i", "TI"], " ", 
     StyleBox["\[Beta]", "TI"], "/", "2", 
     SubscriptBox[
      StyleBox["\[Sigma]", "TI"], 
      StyleBox["y", "TI"]]}]], 
   SuperscriptBox[
    StyleBox["e", "TI"], 
    RowBox[{"-", 
     StyleBox["i", "TI"], " ", 
     StyleBox["\[Gamma]", "TI"], "/", "2", 
     SubscriptBox[
      StyleBox["\[Sigma]", "TI"], 
      StyleBox["z", "TI"]]}]]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "8d043eb7-ab65-4166-bd9b-80cf21ed3ecc"],
 " with \[Alpha], \[Beta] and \[Gamma] are the angles obtained above. One can \
verify that this unitary is equivalent to the axis-angle form ",
 Cell[BoxData[
  SuperscriptBox[
   StyleBox["e", "TI"], 
   RowBox[{
    RowBox[{"-", 
     StyleBox["i", "TI"], " ", "\[Pi]", "/", "3", "/", "2", 
     OverscriptBox[
      StyleBox["n", "TI"], "\[RightVector]"]}], ".", 
    OverscriptBox[
     StyleBox["\[Sigma]", "TI"], "\[RightVector]"]}]]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "85b4c3bb-0c46-49ed-bea5-e7035e6461b4"],
 " with ",
 Cell[BoxData[
  RowBox[{
   RowBox[{
    OverscriptBox[
     StyleBox["n", "TI"], "\[RightVector]"], "=", "{", 
    StyleBox["C", "TI"], 
    StyleBox["o", "TI"], 
    StyleBox["s", "TI"], 
    StyleBox["[",
     SpanMaxSize->1], 
    RowBox[{"\[Pi]", "/", "8"}], 
    StyleBox["]",
     SpanMaxSize->1]}], ",", 
   RowBox[{
    StyleBox["S", "TI"], 
    StyleBox["i", "TI"], 
    StyleBox["n", "TI"], 
    StyleBox["[",
     SpanMaxSize->1], 
    RowBox[{"\[Pi]", "/", "8"}], 
    StyleBox["]",
     SpanMaxSize->1]}], ",", 
   RowBox[{"0", "}"}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "e46cb264-d39e-43d0-9750-3df628e7ec31"],
 "."
}], "Text",ExpressionUUID->"fc1b87fa-da5f-4f31-bc5b-3b99ae48e55f"],

Cell[TextData[{
 "Confirm SU(2) version of above rotation which means ",
 Cell[BoxData[
  RowBox[{
   SubscriptBox["\[ScriptCapitalR]", 
    OverscriptBox[
     StyleBox["n", "TI"], "\[RightVector]"]], 
   StyleBox["(",
    SpanMaxSize->1], 
   RowBox[{"\[Pi]", "/", "3"}], 
   StyleBox[")",
    SpanMaxSize->1], "=", 
   SubscriptBox["\[ScriptCapitalR]", 
    StyleBox["z", "TI"]], 
   StyleBox["(",
    SpanMaxSize->1], 
   StyleBox["\[Alpha]", "TI"], 
   StyleBox[")",
    SpanMaxSize->1], 
   SubscriptBox["\[ScriptCapitalR]", 
    StyleBox["y", "TI"]], 
   StyleBox["(",
    SpanMaxSize->1], 
   StyleBox["\[Beta]", "TI"], 
   StyleBox[")",
    SpanMaxSize->1], 
   SubscriptBox["\[ScriptCapitalR]", 
    StyleBox["z", "TI"]], 
   StyleBox["(",
    SpanMaxSize->1], 
   StyleBox["\[Gamma]", "TI"], 
   StyleBox[")",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "c0280dae-0bdd-444f-9807-863f74aeb9ec"],
 " has a SU(2) counterpart as ",
 Cell[BoxData[
  RowBox[{
   SuperscriptBox[
    StyleBox["e", "TI"], 
    RowBox[{
     RowBox[{"-", 
      StyleBox["i", "TI"], "\[Pi]", "/", "3", "/", "2", 
      OverscriptBox[
       StyleBox["n", "TI"], "\[RightVector]"]}], ".", 
     OverscriptBox[
      StyleBox["\[Sigma]", "TI"], "\[RightVector]"]}]], "=", 
   SuperscriptBox[
    StyleBox["e", "TI"], 
    RowBox[{"-", 
     StyleBox["i", "TI"], " ", 
     StyleBox["\[Alpha]", "TI"], "/", "2", 
     SubscriptBox[
      StyleBox["\[Sigma]", "TI"], 
      StyleBox["z", "TI"]]}]], 
   SuperscriptBox[
    StyleBox["e", "TI"], 
    RowBox[{"-", 
     StyleBox["i", "TI"], " ", 
     StyleBox["\[Beta]", "TI"], "/", "2", 
     SubscriptBox[
      StyleBox["\[Sigma]", "TI"], 
      StyleBox["y", "TI"]]}]], 
   SuperscriptBox[
    StyleBox["e", "TI"], 
    RowBox[{"-", 
     StyleBox["i", "TI"], " ", 
     StyleBox["\[Gamma]", "TI"], "/", "2", 
     SubscriptBox[
      StyleBox["\[Sigma]", "TI"], 
      StyleBox["z", "TI"]]}]]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "024df1d3-b8a7-495f-9081-80c0f72cf60e"],
 ":"
}], "Text",ExpressionUUID->"582a0f0d-7d71-48cc-a25f-258d64fd5789"],

Cell[BoxData[
 RowBox[{
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
     "n", ",", " ", "\[Sigma]", ",", " ", "\[Alpha]", ",", " ", "\[Beta]", ",",
       " ", "\[Gamma]"}], "}"}], ",", "\n", "  ", 
    RowBox[{
     RowBox[{
      RowBox[{"{", 
       RowBox[{"\[Alpha]", ",", " ", "\[Beta]", ",", " ", "\[Gamma]"}], "}"}],
       " ", "=", " ", "\n", "   ", 
      RowBox[{"EulerAngles", "[", 
       RowBox[{"RotationMatrix", "[", 
        RowBox[{
         RowBox[{"\[Pi]", "/", "3"}], ",", " ", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{"Cos", "[", 
            RowBox[{"\[Pi]", "/", "8"}], "]"}], ",", " ", 
           RowBox[{"Sin", "[", 
            RowBox[{"\[Pi]", "/", "8"}], "]"}], ",", " ", "0"}], "}"}]}], 
        "]"}], "]"}]}], ";", "\n", "  ", 
     RowBox[{"\[Sigma]", " ", "=", " ", 
      RowBox[{"Table", "[", 
       RowBox[{
        RowBox[{"PauliMatrix", "[", "j", "]"}], ",", " ", 
        RowBox[{"{", 
         RowBox[{"j", ",", " ", "3"}], "}"}]}], "]"}]}], ";", "\n", "  ", 
     RowBox[{"n", " ", "=", " ", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"Cos", "[", 
         RowBox[{"\[Pi]", "/", "8"}], "]"}], ",", " ", 
        RowBox[{"Sin", "[", 
         RowBox[{"\[Pi]", "/", "8"}], "]"}], ",", " ", "0"}], "}"}]}], ";", 
     "\n", "  ", 
     RowBox[{
      RowBox[{
       RowBox[{"MatrixExp", "[", 
        RowBox[{
         RowBox[{"-", "I"}], " ", 
         RowBox[{"\[Alpha]", "/", "2"}], " ", 
         RowBox[{"PauliMatrix", "[", "3", "]"}]}], "]"}], " ", ".", " ", "\n",
        "    ", 
       RowBox[{"MatrixExp", "[", 
        RowBox[{
         RowBox[{"-", "I"}], " ", 
         RowBox[{"\[Beta]", "/", "2"}], " ", 
         RowBox[{"PauliMatrix", "[", "2", "]"}]}], "]"}], " ", ".", " ", "\n",
        "    ", 
       RowBox[{"MatrixExp", "[", 
        RowBox[{
         RowBox[{"-", "I"}], " ", 
         RowBox[{"\[Gamma]", "/", "2"}], " ", 
         RowBox[{"PauliMatrix", "[", "3", "]"}]}], "]"}]}], " ", "==", " ", 
      "\n", "   ", 
      RowBox[{"MatrixExp", "[", 
       RowBox[{
        RowBox[{"-", "I"}], " ", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{"\[Pi]", "/", "3"}], ")"}], "/", "2"}], " ", 
        RowBox[{"n", " ", ".", " ", "\[Sigma]"}]}], "]"}]}]}]}], "\n", "  ", 
   "]"}], " ", "//", " ", "FullSimplify"}]], "Input",
 CellLabel->
  "In[193]:= ",ExpressionUUID->"fcbae708-5a3c-4c47-96cb-94ec628063f4"],

Cell[TextData[{
 "Now let\[CloseCurlyQuote]s compute ",
 Cell[BoxData[
  RowBox[{
   SubscriptBox["\[ScriptCapitalR]", 
    OverscriptBox[
     StyleBox["n", "TI"], "\[RightVector]"]], 
   StyleBox["(",
    SpanMaxSize->1], 
   RowBox[{"\[Pi]", "/", "3"}], 
   StyleBox[")",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "dd0bba73-c648-4e31-8149-5f9e9fc48abe"],
 " with ",
 Cell[BoxData[
  RowBox[{
   RowBox[{
    OverscriptBox[
     StyleBox["n", "TI"], "\[RightVector]"], "=", "{", 
    StyleBox["C", "TI"], 
    StyleBox["o", "TI"], 
    StyleBox["s", "TI"], 
    StyleBox["[",
     SpanMaxSize->1], 
    RowBox[{"\[Pi]", "/", "8"}], 
    StyleBox["]",
     SpanMaxSize->1]}], ",", 
   RowBox[{
    StyleBox["S", "TI"], 
    StyleBox["i", "TI"], 
    StyleBox["n", "TI"], 
    StyleBox["[",
     SpanMaxSize->1], 
    RowBox[{"\[Pi]", "/", "8"}], 
    StyleBox["]",
     SpanMaxSize->1]}], ",", 
   RowBox[{"0", "}"}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "d5ddb611-4d4b-4576-82e8-83c4d6629148"],
 " in different convention of Euler angels, for example XYX: ",
 Cell[BoxData[
  RowBox[{" ", 
   RowBox[{
    RowBox[{
     SubscriptBox["\[ScriptCapitalR]", 
      OverscriptBox[
       StyleBox["n", "TI"], "\[RightVector]"]], 
     RowBox[{
      StyleBox["(",
       SpanMaxSize->1], 
      RowBox[{"\[Pi]", "/", "3"}], 
      StyleBox[")",
       SpanMaxSize->1]}]}], "=", 
    RowBox[{
     SubscriptBox["\[ScriptCapitalR]", 
      StyleBox["x", "TI"]], 
     RowBox[{
      StyleBox["(",
       SpanMaxSize->1], 
      StyleBox["\[Alpha]", "TI"], 
      StyleBox[")",
       SpanMaxSize->1]}], 
     SubscriptBox["\[ScriptCapitalR]", 
      StyleBox["y", "TI"]], 
     RowBox[{
      StyleBox["(",
       SpanMaxSize->1], 
      StyleBox["\[Beta]", "TI"], 
      StyleBox[")",
       SpanMaxSize->1]}], 
     SubscriptBox["\[ScriptCapitalR]", 
      StyleBox["x", "TI"]], 
     RowBox[{
      RowBox[{
       StyleBox["(",
        SpanMaxSize->1], 
       StyleBox["\[Gamma]", "TI"], 
       StyleBox[")",
        SpanMaxSize->1]}], "."}]}]}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "03fa2ad5-1452-4b1d-8f9f-2d58c48689b9"]
}], "Text",ExpressionUUID->"cf0d6195-6729-43b4-9c52-39f94a586abb"],

Cell[TextData[{
 "Compute Euler angles \[Alpha], \[Beta], and \[Gamma] in the XYX \
Euler-decomposed 3D rotation ",
 Cell[BoxData[
  RowBox[{
   SubscriptBox["\[ScriptCapitalR]", 
    OverscriptBox[
     StyleBox["n", "TI"], "\[RightVector]"]], 
   StyleBox["(",
    SpanMaxSize->1], 
   RowBox[{"\[Pi]", "/", "3"}], 
   StyleBox[")",
    SpanMaxSize->1], "=", 
   SubscriptBox["\[ScriptCapitalR]", 
    StyleBox["x", "TI"]], 
   StyleBox["(",
    SpanMaxSize->1], 
   StyleBox["\[Alpha]", "TI"], 
   StyleBox[")",
    SpanMaxSize->1], 
   SubscriptBox["\[ScriptCapitalR]", 
    StyleBox["y", "TI"]], 
   StyleBox["(",
    SpanMaxSize->1], 
   StyleBox["\[Beta]", "TI"], 
   StyleBox[")",
    SpanMaxSize->1], 
   SubscriptBox["\[ScriptCapitalR]", 
    StyleBox["x", "TI"]], 
   StyleBox["(",
    SpanMaxSize->1], 
   StyleBox["\[Gamma]", "TI"], 
   StyleBox[")",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "22703c44-8b43-4368-9b20-e76500305a72"],
 " with ",
 Cell[BoxData[
  RowBox[{
   RowBox[{
    OverscriptBox[
     StyleBox["n", "TI"], "\[RightVector]"], "=", "{", 
    StyleBox["C", "TI"], 
    StyleBox["o", "TI"], 
    StyleBox["s", "TI"], 
    StyleBox["[",
     SpanMaxSize->1], 
    RowBox[{"\[Pi]", "/", "8"}], 
    StyleBox["]",
     SpanMaxSize->1]}], ",", 
   RowBox[{
    StyleBox["S", "TI"], 
    StyleBox["i", "TI"], 
    StyleBox["n", "TI"], 
    StyleBox["[",
     SpanMaxSize->1], 
    RowBox[{"\[Pi]", "/", "8"}], 
    StyleBox["]",
     SpanMaxSize->1]}], ",", 
   RowBox[{"0", "}"}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "201aea4f-7091-4856-9254-79bc6a48753d"],
 ":"
}], "Text",ExpressionUUID->"60a19138-8d68-4b6c-9084-7afcd7c1cf5e"],

Cell[BoxData[
 RowBox[{
  RowBox[{"EulerAngles", "[", "\n", "  ", 
   RowBox[{
    RowBox[{"RotationMatrix", "[", 
     RowBox[{
      RowBox[{"\[Pi]", "/", "3"}], ",", " ", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"Cos", "[", 
         RowBox[{"\[Pi]", "/", "8"}], "]"}], ",", " ", 
        RowBox[{"Sin", "[", 
         RowBox[{"\[Pi]", "/", "8"}], "]"}], ",", " ", "0"}], "}"}]}], "]"}], 
    ",", " ", 
    RowBox[{"{", 
     RowBox[{"1", ",", " ", "2", ",", " ", "\n", "   ", "1"}], "}"}]}], "]"}],
   " ", "//", " ", "FullSimplify"}]], "Input",
 CellLabel->
  "In[194]:= ",ExpressionUUID->"2c0078ea-7c59-4fb3-a47f-30f1de4dba99"],

Cell["Make the above results numeric:", "Text",ExpressionUUID->"e61295bf-ce80-432a-9230-eff381912421"],

Cell[BoxData[
 RowBox[{
  RowBox[{"EulerAngles", "[", "\n", "  ", 
   RowBox[{
    RowBox[{"RotationMatrix", "[", 
     RowBox[{
      RowBox[{"\[Pi]", "/", "3"}], ",", " ", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"Cos", "[", 
         RowBox[{"\[Pi]", "/", "8"}], "]"}], ",", " ", 
        RowBox[{"Sin", "[", 
         RowBox[{"\[Pi]", "/", "8"}], "]"}], ",", " ", "0"}], "}"}]}], "]"}], 
    ",", " ", 
    RowBox[{"{", 
     RowBox[{"1", ",", " ", "2", ",", " ", "\n", "   ", "1"}], "}"}]}], "]"}],
   " ", "//", " ", "N"}]], "Input",
 CellLabel->
  "In[195]:= ",ExpressionUUID->"4504d94b-f265-4119-a64b-cc79d294776e"],

Cell[TextData[{
 "Therefore, in the language of control pulses, a rotation by ",
 Cell[BoxData[
  RowBox[{"\[Pi]", "/", "3"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "755b454e-9512-4432-b003-108514e6e891"],
 " around ",
 Cell[BoxData[
  OverscriptBox[
   StyleBox["n", "TI"], "\[RightVector]"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "fe02c5c7-12bb-48bb-994d-6655ec2929a1"],
 " can be synthesized as an ordered pulse sequence: ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["X", "TI"], "0.490"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "c20f777a-8320-4745-8dc3-a675dea719ba"],
 ", followed by ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["Y", "TI"], "0.385"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "0f71bf7f-7e9c-419c-91b9-21ce3c5c279a"],
 " and then ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["X", "TI"], "0.490"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "3060c2c3-9eca-4214-8958-ef4b0c3059d9"],
 "."
}], "Text",ExpressionUUID->"3622108f-639b-488c-95b8-07f865626944"],

Cell["Part III: Measurement", "Section",ExpressionUUID->"b1e81d75-f826-4267-948f-fc23a7407769"],

Cell["\<\
Projectors as Measurements: Yes/No Questions and State Filtering\
\>", "Subsection",ExpressionUUID->"7330cb28-22dc-4ade-b6ce-bcfd6646e191"],

Cell[TextData[{
 "Now let\[CloseCurlyQuote]s shift our focus on measurement and start by \
introducing the idea of projectors. For a single qubit, a projector is the \
mathematical object that represents a yes/no measurement question, and it \
also captures the corresponding state update when the answer is \
\[OpenCurlyDoubleQuote]yes.\[CloseCurlyDoubleQuote] A projector \|01d4ab is a \
2\[Times]2 matrix that satisfies ",
 Cell[BoxData[
  RowBox[{
   SuperscriptBox["\|01d4ab", "2"], "=", "\|01d4ab"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "fbdfe3bc-24af-49b0-9baa-5ba0e8a00b61"],
 " (idempotent: applying it twice is the same as applying it once), and ",
 Cell[BoxData[
  RowBox[{"\|01d4ab", "=", 
   SuperscriptBox["\|01d4ab", "\[Dagger]"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "5880a932-079f-4c41-854a-e8f629425b48"],
 " (Hermitian: so measurement probabilities are real).  These properties \
imply that the eigenvalues of a projector can only be 0 or 1, corresponding \
to \[OpenCurlyDoubleQuote]reject\[CloseCurlyDoubleQuote] or \
\[OpenCurlyDoubleQuote]accept.\[CloseCurlyDoubleQuote] Geometrically, a \
projector keeps the component of a state lying in a particular subspace and \
discards the rest. For a single qubit, these subspaces are the \
one-dimensional eigenspaces associated with a specific measurement outcome."
}], "Text",ExpressionUUID->"a2e4bc18-72bc-443f-afbd-48f4e3b79f02"],

Cell[TextData[{
 "For example, let\[CloseCurlyQuote]s define two projectors onto ",
 Cell[BoxData[
  TemplateBox[{"0"},
   "Ket"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "cbffd5ea-fc8c-4ece-866c-d8fd5369f6cb"],
 " and ",
 Cell[BoxData[
  TemplateBox[{"1"},
   "Ket"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "9d6456a7-390f-49cd-bbf3-1e9b9316fc05"],
 ": ",
 Cell[BoxData[
  RowBox[{
   SubscriptBox["\|01d4ab", "0"], "=", 
   RowBox[{
