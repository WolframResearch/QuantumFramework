   OverscriptBox[
    StyleBox["\[Sigma]", "TI"], "\[RightVector]"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "9513986c-7423-4186-928f-e8d3c04adcd0"],
 ":"
}], "Text",ExpressionUUID->"999bbfec-06e8-4f49-afb4-15b955d1f32a"],

Cell[BoxData[
 RowBox[{
  RowBox[{"With", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"n", " ", "=", " ", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{
         RowBox[{"Cos", "[", "\[Phi]", "]"}], " ", 
         RowBox[{"Sin", "[", "\[Theta]", "]"}]}], ",", " ", 
        RowBox[{
         RowBox[{"Sin", "[", "\[Phi]", "]"}], " ", 
         RowBox[{"Sin", "[", "\[Theta]", "]"}]}], ",", " ", "\n", "     ", 
        RowBox[{"Cos", "[", "\[Theta]", "]"}]}], "}"}]}], "}"}], ",", " ", 
    RowBox[{"{", 
     RowBox[{"\[Sigma]", " ", "=", " ", 
      RowBox[{"Table", "[", 
       RowBox[{
        RowBox[{"PauliMatrix", "[", "j", "]"}], ",", " ", 
        RowBox[{"{", 
         RowBox[{"j", ",", " ", "3"}], "}"}]}], "]"}]}], "}"}], ",", " ", 
    RowBox[{"{", 
     RowBox[{"u", " ", "=", "\n", "     ", 
      RowBox[{"FullSimplify", "@", 
       RowBox[{"MatrixExp", "[", 
        RowBox[{
         RowBox[{"-", "I"}], " ", 
         RowBox[{"\[Alpha]", "/", "2"}], " ", 
         RowBox[{"n", " ", ".", " ", "\[Sigma]"}]}], "]"}]}]}], "}"}], ",", 
    " ", "\n", "  ", 
    RowBox[{"u", " ", "==", " ", 
     RowBox[{
      RowBox[{
       RowBox[{"Cos", "[", 
        RowBox[{"\[Alpha]", "/", "2"}], "]"}], " ", 
       RowBox[{"IdentityMatrix", "[", "2", "]"}]}], " ", "-", " ", "\n", 
      "    ", 
      RowBox[{"I", " ", 
       RowBox[{"Sin", "[", 
        RowBox[{"\[Alpha]", "/", "2"}], "]"}], " ", 
       RowBox[{"n", " ", ".", " ", "\[Sigma]"}]}]}]}]}], "]"}], " ", "//", 
  " ", "FullSimplify"}]], "Input",
 CellLabel->
  "In[167]:= ",ExpressionUUID->"2ce1d9b8-90cd-4a47-ab7c-1594bec2577c"],

Cell[TextData[{
 "Verify that ",
 Cell[BoxData[
  SuperscriptBox[
   StyleBox["e", "TI"], 
   RowBox[{
    RowBox[{"-", 
     StyleBox["i", "TI"], " ", 
     StyleBox["\[Alpha]", "TI"], "/", "2", " ", 
     OverscriptBox[
      StyleBox["n", "TI"], "\[RightVector]"]}], ".", 
    OverscriptBox[
     StyleBox["\[Sigma]", "TI"], "\[RightVector]"]}]]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "c623b4f0-c02f-4790-b4be-ec85e18ebd77"],
 " is unitary:"
}], "Text",ExpressionUUID->"a6317d3f-6c51-43f8-a9be-9110d40c30de"],

Cell[BoxData[
 RowBox[{"With", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"n", " ", "=", " ", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{
        RowBox[{"Cos", "[", "\[Phi]", "]"}], " ", 
        RowBox[{"Sin", "[", "\[Theta]", "]"}]}], ",", " ", 
       RowBox[{
        RowBox[{"Sin", "[", "\[Phi]", "]"}], " ", 
        RowBox[{"Sin", "[", "\[Theta]", "]"}]}], ",", " ", "\n", "    ", 
       RowBox[{"Cos", "[", "\[Theta]", "]"}]}], "}"}]}], "}"}], ",", " ", 
   RowBox[{"{", 
    RowBox[{"\[Sigma]", " ", "=", " ", 
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{"PauliMatrix", "[", "j", "]"}], ",", " ", 
       RowBox[{"{", 
        RowBox[{"j", ",", " ", "3"}], "}"}]}], "]"}]}], "}"}], ",", " ", 
   RowBox[{"{", 
    RowBox[{"u", " ", "=", " ", "\n", "   ", 
     RowBox[{"FullSimplify", "@", 
      RowBox[{"MatrixExp", "[", 
       RowBox[{
        RowBox[{"-", "I"}], " ", 
        RowBox[{"\[Alpha]", "/", "2"}], " ", 
        RowBox[{"n", " ", ".", " ", "\[Sigma]"}]}], "]"}]}]}], "}"}], ",", 
   " ", "\n", " ", 
   RowBox[{"FullSimplify", "[", "\n", "  ", 
    RowBox[{
     RowBox[{
      RowBox[{"u", " ", ".", " ", 
       RowBox[{"ConjugateTranspose", "[", "u", "]"}]}], " ", "==", " ", 
      RowBox[{
       RowBox[{"ConjugateTranspose", "[", "u", "]"}], " ", ".", " ", "u"}], 
      " ", "==", " ", "\n", "   ", 
      RowBox[{"IdentityMatrix", "[", "2", "]"}]}], ",", " ", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{
       "\[Theta]", " ", "|", " ", "\[Phi]", " ", "|", " ", "\[Alpha]"}], 
       ")"}], " ", "\[Element]", " ", "Reals"}]}], "]"}]}], "]"}]], "Input",
 CellLabel->
  "In[168]:= ",ExpressionUUID->"3fde128c-8cad-48cf-aa12-406ee18a6723"],

Cell[TextData[{
 "Verify that ",
 Cell[BoxData[
  RowBox[{
   StyleBox["d", "TI"], 
   StyleBox["e", "TI"], 
   StyleBox["t", "TI"], 
   StyleBox["[",
    SpanMaxSize->1], 
   SuperscriptBox[
    StyleBox["e", "TI"], 
    RowBox[{
     RowBox[{"-", 
      StyleBox["i", "TI"], " ", 
      StyleBox["\[Alpha]", "TI"], "/", "2", " ", 
      OverscriptBox[
       StyleBox["n", "TI"], "\[RightVector]"]}], ".", 
     OverscriptBox[
      StyleBox["\[Sigma]", "TI"], "\[RightVector]"]}]], 
   StyleBox["]",
    SpanMaxSize->1], "=", "1"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "ea1a1c01-d731-4a2d-b3c4-3be8b02c058e"],
 ":"
}], "Text",ExpressionUUID->"d2cdc503-305f-411c-b4ec-8375f41e30f5"],

Cell[BoxData[
 RowBox[{"With", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"n", " ", "=", " ", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{
        RowBox[{"Cos", "[", "\[Phi]", "]"}], " ", 
        RowBox[{"Sin", "[", "\[Theta]", "]"}]}], ",", " ", 
       RowBox[{
        RowBox[{"Sin", "[", "\[Phi]", "]"}], " ", 
        RowBox[{"Sin", "[", "\[Theta]", "]"}]}], ",", " ", "\n", "    ", 
       RowBox[{"Cos", "[", "\[Theta]", "]"}]}], "}"}]}], "}"}], ",", " ", 
   RowBox[{"{", 
    RowBox[{"\[Sigma]", " ", "=", " ", 
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{"PauliMatrix", "[", "j", "]"}], ",", " ", 
       RowBox[{"{", 
        RowBox[{"j", ",", " ", "3"}], "}"}]}], "]"}]}], "}"}], ",", " ", 
   RowBox[{"{", 
    RowBox[{"u", " ", "=", " ", "\n", "   ", 
     RowBox[{"FullSimplify", "@", 
      RowBox[{"MatrixExp", "[", 
       RowBox[{
        RowBox[{"-", "I"}], " ", 
        RowBox[{"\[Alpha]", "/", "2"}], " ", 
        RowBox[{"n", " ", ".", " ", "\[Sigma]"}]}], "]"}]}]}], "}"}], ",", 
   " ", "\n", " ", 
   RowBox[{"FullSimplify", "[", 
    RowBox[{
     RowBox[{"Det", "[", "u", "]"}], ",", " ", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{
       "\[Theta]", " ", "|", " ", "\[Phi]", " ", "|", " ", "\[Alpha]"}], 
       ")"}], " ", "\[Element]", " ", "Reals"}]}], "]"}]}], "]"}]], "Input",
 CellLabel->
  "In[169]:= ",ExpressionUUID->"5769c36f-04c0-414b-927d-dacffcf8d834"],

Cell[TextData[{
 "Therefore, ",
 Cell[BoxData[
  SuperscriptBox[
   StyleBox["e", "TI"], 
   RowBox[{
    RowBox[{"-", 
     StyleBox["i", "TI"], " ", 
     StyleBox["\[Alpha]", "TI"], "/", "2", " ", 
     OverscriptBox[
      StyleBox["n", "TI"], "\[RightVector]"]}], ".", 
    OverscriptBox[
     StyleBox["\[Sigma]", "TI"], "\[RightVector]"]}]]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "cd3395b4-cbc9-4393-9cab-af9aeb82c3f2"],
 " satisfies two conditions of SU(2): it is unitary with the determinant 1."
}], "Text",ExpressionUUID->"05d6af0e-6e24-474c-9465-aaed431deb50"],

Cell[TextData[{
 "Let\[CloseCurlyQuote]s recall why we dove into the algebraic properties of \
the Pauli operators. The transformation of a qubit state is described (up to \
an irrelevant global phase) by unitary operators in SU(2), the set of ",
 Cell[BoxData[
  RowBox[{"2", "\[Times]", "2"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "f4bd6faf-6440-4083-a0d5-aa60e3c7cf7a"],
 " unitary matrices with determinant 1. To understand these finite \
transformations, it is often useful to study the associated Lie algebra \
\|01d530\|01d532(2), which captures the \[OpenCurlyDoubleQuote]infinitesimal \
moves\[CloseCurlyDoubleQuote] around the identity.  The Lie algebra \|01d530\
\|01d532(2) consists of ",
 Cell[BoxData[
  RowBox[{"2", "\[Times]", "2"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "363dc36f-2f7c-4a18-9874-67e38ea56156"],
 " matrices ",
 Cell[BoxData[
  StyleBox["X", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "1964aee3-5cf2-4ef0-870b-d634b21cbcf7"],
 " that are anti-Hermitian (",
 Cell[BoxData[
  RowBox[{
   SuperscriptBox[
    StyleBox["X", "TI"], "\[Dagger]"], "=", "-", 
   StyleBox["X", "TI"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "1df31459-a9aa-4447-8a29-fe92e6e55282"],
 ") and traceless (",
 Cell[BoxData[
  RowBox[{
   StyleBox["T", "TI"], 
   StyleBox["r", "TI"], 
   StyleBox["[",
    SpanMaxSize->1], 
   StyleBox["X", "TI"], 
   StyleBox["]",
    SpanMaxSize->1], "=", "0"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "31493c56-0213-4833-887f-8cb2a6482220"],
 "). This matters because exponentiation turns infinitesimal generators into \
finite group elements: if ",
 Cell[BoxData[
  RowBox[{
   StyleBox["X", "TI"], "\[Element]", "\|01d530", "\|01d532", 
   StyleBox["(",
    SpanMaxSize->1], "2", 
   StyleBox[")",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "732b4d7d-c997-4166-a18a-3c527cfe307f"],
 ", then ",
 Cell[BoxData[
  RowBox[{
   SuperscriptBox[
    StyleBox["e", "TI"], 
    StyleBox["X", "TI"]], "\[Element]", 
   StyleBox["S", "TI"], 
   StyleBox["U", "TI"], 
   StyleBox["(",
    SpanMaxSize->1], "2", 
   StyleBox[")",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "25fcfa1a-5a9e-4f5c-b02a-090ec9782149"],
 ". The anti-Hermitian implies that ",
 Cell[BoxData[
  RowBox[{
   SuperscriptBox[
    RowBox[{
     StyleBox["(",
      SpanMaxSize->1], 
     SuperscriptBox[
      StyleBox["e", "TI"], 
      StyleBox["X", "TI"]], 
     StyleBox[")",
      SpanMaxSize->1]}], "\[Dagger]"], "=", 
   SuperscriptBox[
    StyleBox["e", "TI"], 
    SuperscriptBox[
     StyleBox["X", "TI"], "\[Dagger]"]], "=", 
   SuperscriptBox[
    StyleBox["e", "TI"], 
    RowBox[{"-", 
     StyleBox["X", "TI"]}]]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "6de41a70-851e-4cdf-8752-158128d653c6"],
 ". Since ",
 Cell[BoxData[
  SuperscriptBox[
   StyleBox["e", "TI"], 
   RowBox[{"-", 
    StyleBox["X", "TI"]}]]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "590efc27-c6bd-4869-897c-e4b1dd7e3e8a"],
 " is the inverse of ",
 Cell[BoxData[
  SuperscriptBox[
   StyleBox["e", "TI"], 
   StyleBox["X", "TI"]]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "e69ac945-bc04-4ddc-84c9-81342fae32b9"],
 ", so one finds: ",
 Cell[BoxData[
  RowBox[{
   SuperscriptBox[
    RowBox[{
     StyleBox["(",
      SpanMaxSize->1], 
     SuperscriptBox[
      StyleBox["e", "TI"], 
      StyleBox["X", "TI"]], 
     StyleBox[")",
      SpanMaxSize->1]}], "\[Dagger]"], 
   SuperscriptBox[
    StyleBox["e", "TI"], 
    StyleBox["X", "TI"]], "=", 
   SuperscriptBox[
    StyleBox["e", "TI"], 
    RowBox[{"-", 
     StyleBox["X", "TI"]}]], 
   SuperscriptBox[
    StyleBox["e", "TI"], 
    StyleBox["X", "TI"]], "=", "\|01d540"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "e467f08e-d17d-45c2-affd-8b827acdbe8b"],
 ". Therefore, ",
 Cell[BoxData[
  SuperscriptBox[
   StyleBox["e", "TI"], 
   StyleBox["X", "TI"]]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "9ae6cd53-472d-47e2-824d-da5f45f46d56"],
 " is unitary. A standard identity from linear algebra is: ",
 Cell[BoxData[
  RowBox[{
   StyleBox["d", "TI"], 
   StyleBox["e", "TI"], 
   StyleBox["t", "TI"], 
   StyleBox["[",
    SpanMaxSize->1], 
   SuperscriptBox[
    StyleBox["e", "TI"], 
    StyleBox["X", "TI"]], 
   StyleBox["]",
    SpanMaxSize->1], "=", 
   SuperscriptBox[
    StyleBox["e", "TI"], 
    RowBox[{
     StyleBox["T", "TI"], 
     StyleBox["r", "TI"], 
     StyleBox["[",
      SpanMaxSize->1], 
     StyleBox["X", "TI"], 
     StyleBox["]",
      SpanMaxSize->1]}]]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "0f67bc33-4b01-4133-9251-5e92ac42fd0b"],
 ". If ",
 Cell[BoxData[
  RowBox[{
   StyleBox["T", "TI"], 
   StyleBox["r", "TI"], 
   StyleBox["[",
    SpanMaxSize->1], 
   StyleBox["X", "TI"], 
   StyleBox["]",
    SpanMaxSize->1], "=", "0"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "eccd9730-6476-440b-b757-51fd72067a7a"],
 ", then ",
 Cell[BoxData[
  RowBox[{
   StyleBox["d", "TI"], 
   StyleBox["e", "TI"], 
   StyleBox["t", "TI"], 
   StyleBox["[",
    SpanMaxSize->1], 
   SuperscriptBox[
    StyleBox["e", "TI"], 
    StyleBox["X", "TI"]], 
   StyleBox["]",
    SpanMaxSize->1], "=", "1"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "2fd66886-e9a1-4c0b-8e8b-11f1531e57d1"],
 ". So both SU(2) conditions hold for ",
 Cell[BoxData[
  SuperscriptBox[
   StyleBox["e", "TI"], 
   StyleBox["X", "TI"]]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "69fd032b-e470-4754-9b1c-367264f2e114"],
 "."
}], "Text",ExpressionUUID->"62f147d2-7d81-4bbf-8fa7-1e72119250cc"],

Cell[TextData[{
 "For a ",
 Cell[BoxData[
  RowBox[{"2", "\[Times]", "2"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "a35ece08-1e80-422d-b0da-45fdf979c670"],
 " matrix, verify that ",
 Cell[BoxData[
  RowBox[{
   StyleBox["d", "TI"], 
   StyleBox["e", "TI"], 
   StyleBox["t", "TI"], 
   StyleBox["[",
    SpanMaxSize->1], 
   SuperscriptBox[
    StyleBox["e", "TI"], 
    StyleBox["X", "TI"]], 
   StyleBox["]",
    SpanMaxSize->1], "=", 
   SuperscriptBox[
    StyleBox["e", "TI"], 
    RowBox[{
     StyleBox["T", "TI"], 
     StyleBox["r", "TI"], 
     StyleBox["[",
      SpanMaxSize->1], 
     StyleBox["X", "TI"], 
     StyleBox["]",
      SpanMaxSize->1]}]]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "96efaac3-5c4e-4d89-87bf-3102311cd310"],
 ":"
}], "Text",ExpressionUUID->"d7eae1f8-f463-46b0-ac37-7661424c39ca"],

Cell[BoxData[
 RowBox[{"With", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"m", " ", "=", " ", 
     RowBox[{"Array", "[", 
      RowBox[{"\[FormalA]", ",", " ", 
       RowBox[{"{", 
        RowBox[{"2", ",", " ", "2"}], "}"}]}], "]"}]}], "}"}], ",", " ", "\n",
    " ", 
   RowBox[{
    RowBox[{
     RowBox[{"Det", "[", 
      RowBox[{"MatrixExp", "[", "m", "]"}], "]"}], " ", "==", " ", 
     RowBox[{"Exp", "[", 
      RowBox[{"Tr", "[", "m", "]"}], "]"}]}], " ", "//", " ", 
    "FullSimplify"}]}], "]"}]], "Input",
 CellLabel->
  "In[170]:= ",ExpressionUUID->"99f2d85b-c09e-4129-bc86-7ed1c1b3043c"],

Cell[TextData[{
 "Recall that ",
 Cell[BoxData[
  RowBox[{
   OverscriptBox[
    StyleBox["a", "TI"], "\[RightVector]"], ".", 
   OverscriptBox[
    StyleBox["\[Sigma]", "TI"], "\[RightVector]"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "5db29de5-f77e-4767-a336-b2d48e74b3f7"],
 " is a Hermitian traceless operator. But elements of \|01d530\|01d532(2) are \
anti-Hermitian traceless, so they\[CloseCurlyQuote]re ",
 Cell[BoxData[
  RowBox[{
   RowBox[{
    StyleBox["X", "TI"], "=", "-", 
    StyleBox["i", "TI"], " ", 
    OverscriptBox[
     StyleBox["a", "TI"], "\[RightVector]"]}], ".", 
   OverscriptBox[
    StyleBox["\[Sigma]", "TI"], "\[RightVector]"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "006309f4-4db5-4236-9b59-c000c8a707f9"],
 ". Splitting ",
 Cell[BoxData[
  OverscriptBox[
   StyleBox["a", "TI"], "\[RightVector]"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "8e2e1226-d769-4593-8094-3d2c0b3e6375"],
 " into \[OpenCurlyDoubleQuote]magnitude \[Times] direction\
\[CloseCurlyDoubleQuote], one gets: ",
 Cell[BoxData[
  RowBox[{
   RowBox[{
    StyleBox["X", "TI"], "=", "-", 
    StyleBox["i", "TI"], " ", 
    StyleBox["\[Alpha]", "TI"], " ", 
    OverscriptBox[
     StyleBox["n", "TI"], "\[RightVector]"]}], ".", 
   OverscriptBox[
    StyleBox["\[Sigma]", "TI"], "\[RightVector]"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "c6015273-b792-401c-af7c-aaa78463ca4b"],
 " with ",
 Cell[BoxData[
  OverscriptBox[
   StyleBox["n", "TI"], "\[RightVector]"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "eae46792-552e-4c5f-98dc-2a85e7b3fe24"],
 " a unit vector. You may have noticed we could have chosen ",
 Cell[BoxData[
  RowBox[{"+", 
   StyleBox["i", "TI"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "bb911d3b-15d0-48da-b475-3203bd25ab69"],
 " instead of ",
 Cell[BoxData[
  RowBox[{"-", 
   StyleBox["i", "TI"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "5c9c4078-1b04-4984-aff2-2c05502257ec"],
 ". Switching the sign is just a convention: it corresponds to reversing the \
sense of the generated rotation (equivalently, replacing the unitary by its \
inverse). Geometrically, it\[CloseCurlyQuote]s clockwise versus \
counterclockwise rotation about the same axis, depending on your sign \
convention. Importantly, the choice ",
 Cell[BoxData[
  RowBox[{
   StyleBox["X", "TI"], " ", "=", " ", "-", 
   StyleBox["i", "TI"], 
   StyleBox["(",
    SpanMaxSize->1], "\[Ellipsis]", 
   StyleBox[")",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "c9eb3349-dd6c-42ab-b020-ec83e5b3e138"],
 " matches the standard convention in the time-dependent \
Schr\[ODoubleDot]dinger equation for the time-evolution operator, and we will \
return to these details later."
}], "Text",ExpressionUUID->"e4c96418-88f0-4f53-8bb1-183cdbb6d55b"],

Cell[TextData[{
 "Verify that both ",
 Cell[BoxData[
  RowBox[{
   StyleBox["i", "TI"], " ", 
   SubscriptBox[
    StyleBox["\[Sigma]", "TI"], 
    StyleBox["j", "TI"]]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "1cf66432-d611-46f8-a023-82f07be93589"],
 " and ",
 Cell[BoxData[
  RowBox[{"-", 
   StyleBox["i", "TI"], " ", 
   SubscriptBox[
    StyleBox["\[Sigma]", "TI"], 
    StyleBox["j", "TI"]]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "1ec7ead4-2e2f-406c-9f67-c5d91a678698"],
 " are anti-Hermitian and traceless:"
}], "Text",ExpressionUUID->"cdda5292-0c14-4a07-b85e-b470a6afef88"],

Cell[BoxData[
 RowBox[{"With", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"\[Sigma]", " ", "=", " ", "\n", "   ", 
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{"PauliMatrix", "[", "j", "]"}], ",", " ", 
       RowBox[{"{", 
        RowBox[{"j", ",", " ", "\n", "     ", "3"}], "}"}]}], "]"}]}], "}"}], 
   ",", " ", 
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{"(", 
        RowBox[{
         RowBox[{"-", "I"}], " ", "#"}], ")"}], " ", "==", " ", 
       RowBox[{"-", 
        RowBox[{"ConjugateTranspose", "[", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{"-", "I"}], " ", "#"}], ")"}], "]"}]}]}], " ", "&&", " ", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{"I", " ", "#"}], ")"}], " ", "==", " ", 
       RowBox[{"\\\n", 
        RowBox[{"-", 
         RowBox[{"ConjugateTranspose", "[", 
          RowBox[{"(", 
           RowBox[{"I", " ", "#"}], ")"}], "]"}]}]}]}]}], " ", "&"}], " ", "/@",
     " ", "\[Sigma]"}]}], "]"}]], "Input",
 CellLabel->
  "In[171]:= ",ExpressionUUID->"03366a66-fc58-4284-b8d5-42f57187e437"],

Cell["SU(2) Acts as SO(3) on the Bloch Vector", "Subsection",ExpressionUUID->"023136cd-ef0d-4f6c-9ede-c147202e660c"],

Cell[TextData[{
 "Another important convention we should clarify is the factor of 1/2 in the \
generator: ",
 Cell[BoxData[
  RowBox[{
   RowBox[{
    StyleBox["X", "TI"], "=", "-", 
    StyleBox["i", "TI"], " ", 
    StyleBox["\[Alpha]", "TI"], "/", "2", " ", 
    OverscriptBox[
     StyleBox["n", "TI"], "\[RightVector]"]}], ".", 
   OverscriptBox[
    StyleBox["\[Sigma]", "TI"], "\[RightVector]"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "1760a015-39b9-4b4b-a8eb-d9005aa8344d"],
 ". This factor is chosen so that the symbol \[Alpha] equals the actual \
physical rotation angle on the Bloch sphere. In other words, the \
corresponding SU(2) unitary is ",
 Cell[BoxData[
  RowBox[{
   StyleBox["U", "TI"], "=", 
   SuperscriptBox[
    StyleBox["e", "TI"], 
    RowBox[{
     RowBox[{"-", 
      StyleBox["i", "TI"], " ", 
      StyleBox["\[Alpha]", "TI"], "/", "2", " ", 
      OverscriptBox[
       StyleBox["n", "TI"], "\[RightVector]"]}], ".", 
     OverscriptBox[
      StyleBox["\[Sigma]", "TI"], "\[RightVector]"]}]]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "2b0865b1-47f0-44c9-81cd-9f34a1d7091f"],
 " and it acts on a qubit state (written as a density matrix) by: ",
 Cell[BoxData[
  RowBox[{
   RowBox[{
    StyleBox["\[Rho]", "TI"], "\[Rule]", 
    StyleBox["U", "TI"]}], ".", 
   StyleBox["\[Rho]", "TI"], ".", 
   SuperscriptBox[
    StyleBox["U", "TI"], "\[Dagger]"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "43d91b24-6968-4e7d-89f8-3d96a0917f81"],
 " with ",
 Cell[BoxData[
  RowBox[{
   StyleBox["\[Rho]", "TI"], "=", "1", "/", "2", 
   StyleBox["(",
    SpanMaxSize->1], 
   RowBox[{
    RowBox[{"\|01d540", "+", 
     OverscriptBox[
      StyleBox["r", "TI"], "\[RightVector]"]}], ".", 
    OverscriptBox[
     StyleBox["\[Sigma]", "TI"], "\[RightVector]"]}], 
   StyleBox[")",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "a9ba67eb-6ba6-48bd-90cb-2b7453b06417"],
 " and ",
 Cell[BoxData[
  OverscriptBox[
   StyleBox["r", "TI"], "\[RightVector]"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "4abafa8e-6c2f-4f6c-ac70-0e45f9e37116"],
 " the Bloch vector. If we write the transformed state as ",
 Cell[BoxData[
  RowBox[{
   StyleBox["U", "TI"], ".", 
   StyleBox["\[Rho]", "TI"], ".", 
   RowBox[{
    SuperscriptBox[
     StyleBox["U", "TI"], "\[Dagger]"], "=", "1", "/", "2", 
    StyleBox["(",
     SpanMaxSize->1], 
    RowBox[{
     RowBox[{"\|01d540", "+", 
      OverscriptBox[
       StyleBox["v", "TI"], "\[RightVector]"]}], ".", 
     OverscriptBox[
      StyleBox["\[Sigma]", "TI"], "\[RightVector]"]}], 
    StyleBox[")",
     SpanMaxSize->1]}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "a53a28cf-f1e2-4db7-b871-3e0afe4c9568"],
 ", then the new Bloch vector is ",
 Cell[BoxData[
  RowBox[{
   RowBox[{
    OverscriptBox[
     StyleBox["v", "TI"], "\[RightVector]"], "=", 
    SubscriptBox["\[ScriptCapitalR]", 
     StyleBox["n", "TI"]], 
    StyleBox["(",
     SpanMaxSize->1], 
    StyleBox["\[Alpha]", "TI"], 
    StyleBox[")",
     SpanMaxSize->1]}], ".", 
   OverscriptBox[
    StyleBox["r", "TI"], "\[RightVector]"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "45e74e18-8a92-4cdf-affa-359d50258e66"],
 " where ",
 Cell[BoxData[
  RowBox[{
   SubscriptBox["\[ScriptCapitalR]", 
    StyleBox["n", "TI"]], 
   StyleBox["(",
    SpanMaxSize->1], 
   StyleBox["\[Alpha]", "TI"], 
   StyleBox[")",
    SpanMaxSize->1], "\[Element]", 
   StyleBox["S", "TI"], 
   StyleBox["O", "TI"], 
   StyleBox["(",
    SpanMaxSize->1], "3", 
   StyleBox[")",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "21735bb9-102e-425a-a5a8-8d03f629a2ef"],
 " is an ordinary 3D rotation of the Bloch sphere about the axis ",
 Cell[BoxData[
  OverscriptBox[
   StyleBox["n", "TI"], "\[RightVector]"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "1b52a12e-8d68-4e2a-ab4d-29f0346768de"],
 " by the angle \[Alpha]. Recall SO(3) is the set of all ",
 Cell[BoxData[
  RowBox[{"3", "\[Times]", "3"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "24b79335-176f-45a9-bba1-788dc682b674"],
 " real matrices ",
 Cell[BoxData["\[ScriptCapitalR]"], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "efce3b10-6aa3-472c-a95b-2c9ddfafdc04"],
 " that rotate vectors in 3D. Also note that ",
 Cell[BoxData[
  RowBox[{"-", 
   StyleBox["u", "TI"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "9b31b3c0-03fb-414a-9486-788cd806d61c"],
 " also produces the same 3D rotation (i.e., the same transformed state)."
}], "Text",ExpressionUUID->"fc54e2b2-d195-4fa8-9525-7a47a7638c92"],

Cell[TextData[{
 "For ",
 Cell[BoxData[
  RowBox[{
   StyleBox["U", "TI"], "=", 
   SuperscriptBox[
    StyleBox["e", "TI"], 
    RowBox[{
     RowBox[{"-", 
      StyleBox["i", "TI"], " ", 
      StyleBox["\[Alpha]", "TI"], "/", "2", " ", 
      OverscriptBox[
       StyleBox["n", "TI"], "\[RightVector]"]}], ".", 
     OverscriptBox[
      StyleBox["\[Sigma]", "TI"], "\[RightVector]"]}]]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "edf81dc2-004f-4ffb-a890-426d8ad46ae4"],
 " and ",
 Cell[BoxData[
  RowBox[{
   StyleBox["\[Rho]", "TI"], "=", "1", "/", "2", 
   StyleBox["(",
    SpanMaxSize->1], 
   RowBox[{
    RowBox[{"\|01d540", "+", 
     OverscriptBox[
      StyleBox["r", "TI"], "\[RightVector]"]}], ".", 
    OverscriptBox[
     StyleBox["\[Sigma]", "TI"], "\[RightVector]"]}], 
   StyleBox[")",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "0be61513-83f1-49a8-bbf7-62c2eb6efa8d"],
 ", calculate the new Bloch sphere ",
 Cell[BoxData[
  RowBox[{
   StyleBox["U", "TI"], ".", 
   StyleBox["\[Rho]", "TI"], ".", 
   RowBox[{
    SuperscriptBox[
     StyleBox["U", "TI"], "\[Dagger]"], "=", "1", "/", "2", 
    StyleBox["(",
     SpanMaxSize->1], 
    RowBox[{
     RowBox[{"\|01d540", "+", 
      OverscriptBox[
       StyleBox["v", "TI"], "\[RightVector]"]}], ".", 
     OverscriptBox[
      StyleBox["\[Sigma]", "TI"], "\[RightVector]"]}], 
    StyleBox[")",
     SpanMaxSize->1]}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "2e51e246-9e15-465d-9819-8bdcccbc8e94"],
 ":"
}], "Text",ExpressionUUID->"1af66cf3-6c71-44ef-954c-4e454c565d4a"],

Cell[BoxData[{
 RowBox[{"ClearAll", "[", 
  RowBox[{
  "\[Alpha]", ",", " ", "\[Phi]", ",", " ", "\[Theta]", ",", " ", "rx", ",", 
   " ", "ry", ",", " ", "rz"}], "]"}], "\n", 
 RowBox[{"vSU2", " ", "=", " ", 
  RowBox[{"With", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"n", " ", "=", " ", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{
         RowBox[{"Cos", "[", "\[Phi]", "]"}], " ", 
         RowBox[{"Sin", "[", "\[Theta]", "]"}]}], ",", " ", 
        RowBox[{
         RowBox[{"Sin", "[", "\[Phi]", "]"}], " ", 
         RowBox[{"Sin", "[", "\[Theta]", "]"}]}], ",", "\n", "      ", 
        RowBox[{"Cos", "[", "\[Theta]", "]"}]}], "}"}]}], "}"}], ",", " ", 
    RowBox[{"{", 
     RowBox[{"\[Sigma]", " ", "=", " ", "\n", "    ", 
      RowBox[{"Table", "[", 
       RowBox[{
        RowBox[{"PauliMatrix", "[", "j", "]"}], ",", " ", 
        RowBox[{"{", 
         RowBox[{"j", ",", " ", "3"}], "}"}]}], "]"}]}], "}"}], ",", " ", 
    RowBox[{"{", 
     RowBox[{"u", " ", "=", " ", "\n", "    ", 
      RowBox[{"FullSimplify", "@", 
       RowBox[{"MatrixExp", "[", 
        RowBox[{
         RowBox[{"-", "I"}], " ", 
         RowBox[{"\[Alpha]", "/", "2"}], " ", 
         RowBox[{"n", " ", ".", " ", "\[Sigma]"}]}], "]"}]}]}], "}"}], ",", 
    " ", 
    RowBox[{"{", 
     RowBox[{"\[Rho]", " ", "=", " ", "\n", "    ", 
      RowBox[{"DensityMatrix", "[", 
       RowBox[{"{", 
        RowBox[{"rx", ",", " ", "ry", ",", " ", "rz"}], "}"}], "]"}]}], "}"}],
     ",", " ", "\n", "  ", 
    RowBox[{"FullSimplify", "[", "\n", "   ", 
     RowBox[{
      RowBox[{"BlochVector", "[", "\n", "    ", 
       RowBox[{"u", " ", ".", " ", "\[Rho]", " ", ".", " ", "\n", "     ", 
        RowBox[{"ConjugateTranspose", "[", "u", "]"}]}], "]"}], ",", " ", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{
        "\[Theta]", " ", "|", " ", "\[Phi]", " ", "|", " ", "\[Alpha]", " ", "|",
          " ", "rx", " ", "|", " ", "ry", " ", "|", "\n", "       ", "rz"}], 
        ")"}], " ", "\[Element]", " ", "Reals"}]}], "]"}]}], 
   "]"}]}]}], "Input",
 CellLabel->
  "In[172]:= ",ExpressionUUID->"b730400b-56bb-462d-9047-9237f3d02f74"],

Cell[TextData[{
 "Calculate ",
 Cell[BoxData[
  RowBox[{
   RowBox[{
    SubscriptBox["\[ScriptCapitalR]", 
     StyleBox["n", "TI"]], 
    StyleBox["(",
     SpanMaxSize->1], 
    StyleBox["\[Alpha]", "TI"], 
    StyleBox[")",
     SpanMaxSize->1]}], ".", 
   OverscriptBox[
    StyleBox["r", "TI"], "\[RightVector]"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "c8c24612-adb8-4d62-a0b7-4bd3a8ddf2c7"],
 ":"
}], "Text",ExpressionUUID->"5f209495-a203-4de9-9b44-a9ea315a964c"],

Cell[BoxData[{
 RowBox[{"ClearAll", "[", 
  RowBox[{
  "\[Alpha]", ",", " ", "\[Phi]", ",", " ", "\[Theta]", ",", " ", "rx", ",", 
   " ", "ry", ",", " ", "rz"}], "]"}], "\n", 
 RowBox[{"vSO3", " ", "=", " ", 
  RowBox[{"With", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"n", " ", "=", " ", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{
         RowBox[{"Cos", "[", "\[Phi]", "]"}], " ", 
         RowBox[{"Sin", "[", "\[Theta]", "]"}]}], ",", " ", 
        RowBox[{
         RowBox[{"Sin", "[", "\[Phi]", "]"}], " ", 
         RowBox[{"Sin", "[", "\[Theta]", "]"}]}], ",", "\n", "      ", 
        RowBox[{"Cos", "[", "\[Theta]", "]"}]}], "}"}]}], "}"}], ",", " ", 
    "\n", "  ", 
    RowBox[{"FullSimplify", "[", "\n", "   ", 
     RowBox[{
      RowBox[{
       RowBox[{"RotationTransform", "[", 
        RowBox[{"\[Alpha]", ",", " ", "n"}], "]"}], "[", 
       RowBox[{"{", 
        RowBox[{"rx", ",", " ", "ry", ",", " ", "\n", "     ", "rz"}], "}"}], 
       "]"}], ",", " ", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{
        "\[Theta]", " ", "|", " ", "\[Phi]", " ", "|", " ", "\[Alpha]", " ", "|",
          " ", "rx", " ", "|", " ", "ry", " ", "|", " ", "rz"}], ")"}], " ", "\[Element]",
        " ", "\n", "    ", "Reals"}]}], "]"}]}], "]"}]}]}], "Input",
 CellLabel->
  "In[173]:= ",ExpressionUUID->"a1b2e393-9339-4f08-9046-c04ac0f4953b"],

Cell["Show two results are the same:", "Text",ExpressionUUID->"c4600f4f-ecbe-4b38-a29a-c1aac168ba79"],

Cell[BoxData[
 RowBox[{
  RowBox[{"vSU2", " ", "==", " ", "vSO3"}], " ", "//", " ", 
  "FullSimplify"}]], "Input",
 CellLabel->
  "In[174]:= ",ExpressionUUID->"7936ff15-4b04-4bdf-9985-da9efe598c31"],

Cell[TextData[{
 "So we showed that SU(2) unitary ",
 Cell[BoxData[
  SuperscriptBox[
   StyleBox["e", "TI"], 
   RowBox[{
    RowBox[{"-", 
     StyleBox["i", "TI"], " ", 
     StyleBox["\[Alpha]", "TI"], "/", "2", " ", 
     OverscriptBox[
      StyleBox["n", "TI"], "\[RightVector]"]}], ".", 
    OverscriptBox[
     StyleBox["\[Sigma]", "TI"], "\[RightVector]"]}]]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "7b0e518e-1971-47e2-ae21-e02a1ff9ea26"],
 " is reproduced by SO(3) rotation ",
 Cell[BoxData[
  RowBox[{
   SubscriptBox["\[ScriptCapitalR]", 
    StyleBox["n", "TI"]], 
   StyleBox["(",
    SpanMaxSize->1], 
   StyleBox["\[Alpha]", "TI"], 
   StyleBox[")",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "54e8ba92-dea3-4c9d-a821-04e24de55193"],
 "."
}], "Text",ExpressionUUID->"88ecd5e8-402e-47c6-834e-09e3a916a874"],

Cell["\<\
In short, a single qubit can be pictured as a point on the Bloch sphere, and \
unitary transformations of qubit state act like rotations of that sphere. \
SO(3) is the mathematical name for ordinary 3D rotations of that Bloch-sphere \
\[OpenCurlyDoubleQuote]arrow,\[CloseCurlyDoubleQuote] the same kind of \
rotations you\[CloseCurlyQuote]d apply to a rigid object in space.  SU(2) is \
the mathematical home of the actual qubit operations themselves (again, \
focusing on the \[OpenCurlyDoubleQuote]pure rotation\[CloseCurlyDoubleQuote] \
part and ignoring overall global phase). When you apply an SU(2) operation to \
the qubit\[CloseCurlyQuote]s state, its visible effect on the Bloch sphere is \
an SO(3) rotation. The Lie algebra \|01d530\|01d532(2) is the \
\[OpenCurlyDoubleQuote]infinitesimal\[CloseCurlyDoubleQuote] version of \
SU(2): it describes the instantaneous, tiny rotation tendencies you can apply \
at the identity operation. Practically, \|01d530\|01d532(2) is where the \
generators live (the basic rotation directions you can turn on for a short \
time), and exponentiating those infinitesimal generators produces the finite \
SU(2) unitaries you use on a qubit.\
\>", "Text",ExpressionUUID->"1dec214e-09c3-41a2-aa16-22b0ffe4395a"],

Cell["\<\
The Double Cover: Why 2\[Pi] Looks Like Identity on the Sphere but Not in \
SU(2)\
\>", "Subsection",ExpressionUUID->"015dc574-d5a3-4cf1-b10d-a44eb102613b"],

Cell["\<\
That said, there is a subtlety worth some discussion. SU(2) contains more \
information than the Bloch arrow shows: two different SU(2) operations can \
produce the exact same SO(3) rotation on the Bloch sphere, differing only by \
an overall sign on the underlying state. That\[CloseCurlyQuote]s why a 360\
\[Degree] rotation returns the Bloch arrow to itself but does not fully \
return the underlying SU(2) description; you need 720\[Degree] to come back \
exactly.\
\>", "Text",ExpressionUUID->"3f5013f1-2d1a-4447-8a08-6d969e4b4c61"],

Cell[TextData[{
 "Calculate ",
 Cell[BoxData[
  SuperscriptBox[
   StyleBox["e", "TI"], 
   RowBox[{
    RowBox[{"-", 
     StyleBox["i", "TI"], " ", 
     StyleBox["\[Alpha]", "TI"], "/", "2", " ", 
     OverscriptBox[
      StyleBox["n", "TI"], "\[RightVector]"]}], ".", 
    OverscriptBox[
     StyleBox["\[Sigma]", "TI"], "\[RightVector]"]}]]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "7fbfd0a9-0e6b-4ff4-90a3-c89a295bd1c9"],
 " for ",
 Cell[BoxData[
  RowBox[{
   StyleBox["\[Alpha]", "TI"], "=", "2", "\[Pi]"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "a67dfb77-0f58-4387-a983-fc79be37e8bf"],
 ":"
}], "Text",ExpressionUUID->"a94f52af-cd7d-49bb-b234-bba6b59f1c4f"],

Cell[BoxData[{
 RowBox[{"ClearAll", "[", 
  RowBox[{"\[Phi]", ",", " ", "\[Theta]"}], "]"}], "\n", 
 RowBox[{
  RowBox[{"With", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{"n", " ", "=", " ", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{
          RowBox[{"Cos", "[", "\[Phi]", "]"}], " ", 
          RowBox[{"Sin", "[", "\[Theta]", "]"}]}], ",", " ", 
         RowBox[{
          RowBox[{"Sin", "[", "\[Phi]", "]"}], " ", 
          RowBox[{"Sin", "[", "\[Theta]", "]"}]}], ",", " ", "\n", "     ", 
         RowBox[{"Cos", "[", "\[Theta]", "]"}]}], "}"}]}], ",", " ", 
      RowBox[{"\[Sigma]", " ", "=", " ", "\n", "    ", 
       RowBox[{"Table", "[", 
        RowBox[{
         RowBox[{"PauliMatrix", "[", "j", "]"}], ",", " ", 
         RowBox[{"{", 
          RowBox[{"j", ",", " ", "3"}], "}"}]}], "]"}]}], ",", " ", 
      RowBox[{"\[Alpha]", " ", "=", " ", 
       RowBox[{"2", " ", "\[Pi]"}]}]}], "}"}], ",", " ", "\n", "  ", 
    RowBox[{"FullSimplify", "@", 
     RowBox[{"MatrixExp", "[", 
      RowBox[{
       RowBox[{"-", "I"}], " ", 
       RowBox[{"\[Alpha]", "/", "2"}], " ", 
       RowBox[{"n", " ", ".", " ", "\[Sigma]"}]}], "]"}]}]}], "]"}], " ", "//",
   " ", "MatrixForm"}]}], "Input",
 CellLabel->
  "In[175]:= ",ExpressionUUID->"3449d011-bb67-4f63-8334-97ddb63c334e"],

Cell[TextData[{
 "Calculate ",
 Cell[BoxData[
  RowBox[{
   SubscriptBox["\[ScriptCapitalR]", 
    StyleBox["n", "TI"]], 
   StyleBox["(",
    SpanMaxSize->1], 
   StyleBox["\[Alpha]", "TI"], 
   StyleBox[")",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "45aae418-d5db-4c08-8a85-0f5029f89624"],
 " for ",
 Cell[BoxData[
  RowBox[{
   StyleBox["\[Alpha]", "TI"], "=", "2", "\[Pi]"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "91ad5bec-c587-49bc-8a93-ff7cfe33c306"],
 ":"
}], "Text",ExpressionUUID->"3a6d2f46-3e86-4865-a52d-ac3c8d5485c4"],

Cell[BoxData[{
 RowBox[{"ClearAll", "[", 
  RowBox[{"\[Phi]", ",", " ", "\[Theta]"}], "]"}], "\n", 
 RowBox[{
  RowBox[{"With", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{"n", " ", "=", " ", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{
          RowBox[{"Cos", "[", "\[Phi]", "]"}], " ", 
          RowBox[{"Sin", "[", "\[Theta]", "]"}]}], ",", " ", 
         RowBox[{
          RowBox[{"Sin", "[", "\[Phi]", "]"}], " ", 
          RowBox[{"Sin", "[", "\[Theta]", "]"}]}], ",", " ", "\n", "     ", 
         RowBox[{"Cos", "[", "\[Theta]", "]"}]}], "}"}]}], ",", " ", 
      RowBox[{"\[Alpha]", " ", "=", " ", 
       RowBox[{"2", " ", "\[Pi]"}]}]}], "}"}], ",", " ", "\n", "  ", 
    RowBox[{"FullSimplify", "[", "\n", "   ", 
     RowBox[{
      RowBox[{"RotationMatrix", "[", 
       RowBox[{"\[Alpha]", ",", " ", "n"}], "]"}], ",", " ", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{"\[Theta]", " ", "|", " ", "\[Phi]"}], ")"}], " ", "\[Element]",
        " ", "\n", "    ", "Reals"}]}], "]"}]}], "]"}], " ", "//", " ", 
  "MatrixForm"}]}], "Input",
 CellLabel->
  "In[176]:= ",ExpressionUUID->"c51827bb-3805-47a9-a3be-160a65585223"],

Cell[TextData[{
 "As one can see, ",
 Cell[BoxData[
  RowBox[{
   SuperscriptBox[
    StyleBox["e", "TI"], 
    RowBox[{
     RowBox[{"-", 
      StyleBox["i", "TI"], " ", "2", "\[Pi]", "/", "2", " ", 
      OverscriptBox[
       StyleBox["n", "TI"], "\[RightVector]"]}], ".", 
     OverscriptBox[
      StyleBox["\[Sigma]", "TI"], "\[RightVector]"]}]], "=", "-", 
   SubscriptBox["\|01d540", "2"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "8bb0bd05-35be-469c-be88-413ce026ac94"],
 " but ",
 Cell[BoxData[
  RowBox[{
   SubscriptBox["\[ScriptCapitalR]", 
    StyleBox["n", "TI"]], 
   StyleBox["(",
    SpanMaxSize->1], 
   RowBox[{"2", "\[Pi]"}], 
   StyleBox[")",
    SpanMaxSize->1], "=", 
   SubscriptBox["\|01d540", "3"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "4fa55f8c-61db-4362-825d-673673957bca"],
 " (",
 Cell[BoxData[
  SubscriptBox["\|01d540", 
   StyleBox["n", "TI"]]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "fd496715-c712-4a34-8f91-b9eadf36bd4f"],
 " means ",
 Cell[BoxData[
  RowBox[{
   StyleBox["n", "TI"], "\[Times]", 
   StyleBox["n", "TI"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "bb691de0-e844-4790-8420-d9c5573b160e"],
 " identity matrix). That extra minus sign is a global phase of \[Pi] ",
 Cell[BoxData[
  RowBox[{"(", 
   RowBox[{
    SuperscriptBox[
     StyleBox["e", "TI"], 
     RowBox[{
      StyleBox["i", "TI"], "\[Pi]"}]], "=", "-", "1"}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "98ddf019-5fb4-4b8d-9055-04222a9ea503"],
 "): it multiplies the whole state by the same complex factor. Global phase \
has no effect on qubit measurement probabilities, so the Bloch sphere doesn\
\[CloseCurlyQuote]t change. In other words, ",
 Cell[BoxData[
  SuperscriptBox[
   StyleBox["e", "TI"], 
   RowBox[{
    RowBox[{"-", 
     StyleBox["i", "TI"], " ", 
     StyleBox["\[Alpha]", "TI"], "/", "2", " ", 
     OverscriptBox[
      StyleBox["n", "TI"], "\[RightVector]"]}], ".", 
    OverscriptBox[
     StyleBox["\[Sigma]", "TI"], "\[RightVector]"]}]]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "7270ed87-f560-48f1-9079-5321ff77a339"],
 " and ",
 Cell[BoxData[
  RowBox[{"-", 
   SuperscriptBox[
    StyleBox["e", "TI"], 
    RowBox[{
     RowBox[{"-", 
      StyleBox["i", "TI"], " ", 
      StyleBox["\[Alpha]", "TI"], "/", "2", " ", 
      OverscriptBox[
       StyleBox["n", "TI"], "\[RightVector]"]}], ".", 
     OverscriptBox[
      StyleBox["\[Sigma]", "TI"], "\[RightVector]"]}]]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "3f92c711-1408-400a-9121-9bcb85d77c56"],
 " produce the same movement of the Bloch vector, hence the same SO(3) \
rotation. That\[CloseCurlyQuote]s the \[OpenCurlyDoubleQuote]two-to-one\
\[CloseCurlyDoubleQuote] relationship: each visible 3D rotation corresponds \
to two SU(2) matrices, ",
 Cell[BoxData[
  SuperscriptBox[
   StyleBox["e", "TI"], 
   RowBox[{
    RowBox[{"-", 
     StyleBox["i", "TI"], " ", 
     StyleBox["\[Alpha]", "TI"], "/", "2", " ", 
     OverscriptBox[
      StyleBox["n", "TI"], "\[RightVector]"]}], ".", 
    OverscriptBox[
     StyleBox["\[Sigma]", "TI"], "\[RightVector]"]}]]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "c0eed872-5085-4720-93f6-309ff7a06d9f"],
 " and ",
 Cell[BoxData[
  RowBox[{"-", 
   SuperscriptBox[
    StyleBox["e", "TI"], 
    RowBox[{
     RowBox[{"-", 
      StyleBox["i", "TI"], " ", 
      StyleBox["\[Alpha]", "TI"], "/", "2", " ", 
      OverscriptBox[
       StyleBox["n", "TI"], "\[RightVector]"]}], ".", 
     OverscriptBox[
      StyleBox["\[Sigma]", "TI"], "\[RightVector]"]}]]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "74a8f889-fa1b-4424-97b4-744753d52ceb"],
 "."
}], "Text",ExpressionUUID->"8f1fe3d2-547c-4360-b51b-df8f80c30ec0"],

Cell[TextData[{
 "Yet we can press the question: how do we render this invisible sign \
observable? The answer lies in interferometry, we divide the quantum system \
into two paths so that only one experiences the ",
 Cell[BoxData[
  RowBox[{"2", "\[Pi]"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "bd669bc7-4078-49e2-adcd-a4d950f33508"],
 " rotation, and then recombine them. The resulting relative phase manifests \
as a measurable interference effect. To explore this computationally, \
however, we must first discuss time evolution. We will therefore return to \
this important question later. For now, let us take a closer look at the \
algebraic properties of some of those exponential matrices we discussed above."
}], "Text",ExpressionUUID->"1805c9a1-b86a-4f78-add5-ea8fc00f5406"],

Cell[TextData[{
 "As you may recall from our discussion of matrix bases, the identity \
together with the Pauli matrices provides a basis for ",
 Cell[BoxData[
  RowBox[{"2", "\[Times]", "2"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "f8a13bf1-89a0-4b5f-a13c-6443d7a11034"],
 " operators. This means any operator can be written as a linear combination ",
 Cell[BoxData[
  RowBox[{
   StyleBox["A", "TI"], "=", 
   UnderoverscriptBox["\[Sum]", 
    RowBox[{
     StyleBox["\[Mu]", "TI"], "=", "0"}], "3",
    LimitsPositioning->False], 
   SubscriptBox[
    StyleBox["a", "TI"], 
    StyleBox["\[Mu]", "TI"]], 
   SubscriptBox[
    StyleBox["\[Sigma]", "TI"], 
    StyleBox["\[Mu]", "TI"]]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "fc1760fa-5ecc-4ce4-b37d-d9bc4798ae19"],
 " where ",
 Cell[BoxData[
  RowBox[{
   SubscriptBox[
    StyleBox["\[Sigma]", "TI"], "0"], "=", "\|01d540"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "b067fac2-668c-4774-ad25-ecea24fb740f"],
 " and ",
 Cell[BoxData[
  RowBox[{
   SubscriptBox[
    StyleBox["\[Sigma]", "TI"], 
    RowBox[{"1", ",", "2", ",", "3"}]], "=", 
   SubscriptBox[
    StyleBox["\[Sigma]", "TI"], 
    RowBox[{
     StyleBox["x", "TI"], ",", 
     StyleBox["y", "TI"], ",", 
     StyleBox["z", "TI"]}]]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "e2b2479c-51ab-40bd-933f-2d54378f63b9"],
 ". For Hermitian operators, the coefficients ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["a", "TI"], 
   StyleBox["\[Mu]", "TI"]]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "0989d202-b787-4022-a21c-17a07571f9b0"],
 " are real.  We then noted that, when we use such operators as generators of \
unitaries, we can often ignore the identity contribution and focus on the \
traceless part ",
 Cell[BoxData[
  RowBox[{
   RowBox[{
    UnderoverscriptBox["\[Sum]", 
     RowBox[{
      StyleBox["j", "TI"], "=", "1"}], "3",
     LimitsPositioning->False], 
    SubscriptBox[
     StyleBox["a", "TI"], 
     StyleBox["j", "TI"]], 
    SubscriptBox[
     StyleBox["\[Sigma]", "TI"], 
     StyleBox["j", "TI"]], "=", 
    OverscriptBox[
     StyleBox["a", "TI"], "\[RightVector]"]}], ".", 
   OverscriptBox[
    StyleBox["\[Sigma]", "TI"], "\[RightVector]"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "10f192fd-f01b-4b72-93f2-61c221f052e1"],
 ". The reason is that an identity term in the generator only produces an \
overall global phase in the unitary, which does not affect a single-qubit \
state. Still, this feature deserves a bit more discussion, and we will \
clarify precisely when and why the identity part can be dropped."
}], "Text",ExpressionUUID->"142467b6-1733-4d3b-849b-3bb2359a9eb3"],

Cell["\<\
Splitting Exponentials and Ignoring the Identity Term (Zassenhaus Insight)\
\>", "Subsection",ExpressionUUID->"6c8321db-61f0-4afa-9596-799876cb3675"],

Cell[TextData[{
 "Let\[CloseCurlyQuote]s start by looking at exponentials of two or more \
operators, in the form ",
 Cell[BoxData[
  SuperscriptBox[
   StyleBox["e", "TI"], 
   RowBox[{
    StyleBox["A", "TI"], "+", 
    StyleBox["B", "TI"]}]]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "aa5983a9-ec65-40d1-9f4a-843ff60d01c7"],
 ". Operator exponentials do not behave like exponentials of numbers. For \
ordinary numbers, we can split cleanly: ",
 Cell[BoxData[
  RowBox[{
   SuperscriptBox[
    StyleBox["e", "TI"], 
    RowBox[{
     StyleBox["a", "TI"], "+", 
     StyleBox["b", "TI"]}]], "=", 
   SuperscriptBox[
    StyleBox["e", "TI"], 
    StyleBox["a", "TI"]], 
   SuperscriptBox[
    StyleBox["e", "TI"], 
    StyleBox["b", "TI"]]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "4ce31652-7936-4fc9-af39-34a8a7a248d8"],
 " with ",
 Cell[BoxData[
  RowBox[{
   RowBox[{"{", 
    StyleBox["a", "TI"]}], ",", 
   RowBox[{
    StyleBox["b", "TI"], "}", "\[Element]", "\:2102"}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "c742e138-986d-47aa-9f33-791246df9173"],
 ". But for operators, order matters, and in general ",
 Cell[BoxData[
  RowBox[{
   SuperscriptBox[
    StyleBox["e", "TI"], 
    RowBox[{
     StyleBox["A", "TI"], "+", 
     StyleBox["B", "TI"]}]], "\[NotEqual]", 
   SuperscriptBox[
    StyleBox["e", "TI"], 
    StyleBox["A", "TI"]], 
   SuperscriptBox[
    StyleBox["e", "TI"], 
    StyleBox["B", "TI"]]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "de733c22-9da8-4d2b-ad8d-e4e8196dd268"],
 " when ",
 Cell[BoxData[
  RowBox[{
   StyleBox["[",
    SpanMaxSize->1], 
   RowBox[{
    StyleBox["A", "TI"], ",", 
    StyleBox["B", "TI"]}], 
   StyleBox["]",
    SpanMaxSize->1], "\[NotEqual]", "0"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "834b3ac3-023b-461b-a5bc-983de0bdc5a8"],
 ". The \[OpenCurlyDoubleQuote]price\[CloseCurlyDoubleQuote] we pay for \
noncommutativity is a structured collection of correction terms built from \
commutators. One way to write this is the Zassenhaus formula: ",
 Cell[BoxData[
  RowBox[{
   SuperscriptBox[
    StyleBox["e", "TI"], 
    RowBox[{
     StyleBox["A", "TI"], "+", 
     StyleBox["B", "TI"]}]], "=", 
   SuperscriptBox[
    StyleBox["e", "TI"], 
    StyleBox["A", "TI"]], 
   SuperscriptBox[
    StyleBox["e", "TI"], 
    StyleBox["B", "TI"]], 
   UnderoverscriptBox["\[Product]", 
    RowBox[{
     StyleBox["k", "TI"], "=", "2"}], "\[Infinity]",
    LimitsPositioning->False], 
   SuperscriptBox[
    StyleBox["e", "TI"], 
    SubscriptBox["\|01d4b2", 
     StyleBox["k", "TI"]]]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "13375d61-0466-49c4-b272-612780e02d02"],
 ". Each ",
 Cell[BoxData[
  SubscriptBox["\|01d4b2", 
   StyleBox["k", "TI"]]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "5f43cc9c-19da-4ab9-9a7a-2c94b28fff4d"],
 " is a correction of order ",
 Cell[BoxData[
  StyleBox["k", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "82002fea-5722-4903-a2ca-3fb83d6f41b3"],
 ", meaning it is made from ",
 Cell[BoxData[
  StyleBox["k", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "bfcfa9ec-8164-4e29-bf0d-ade39ba41a1f"],
 " operator factors overall. Moreover, each ",
 Cell[BoxData[
  SubscriptBox["\|01d4b2", 
   StyleBox["k", "TI"]]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "bee7050b-36f3-4d68-b1d3-438e2ba9151b"],
 " is built from nested commutators (also called Lie monomials), such as ",
 Cell[BoxData[
  RowBox[{
   StyleBox["[",
    SpanMaxSize->1], 
   RowBox[{
    StyleBox["A", "TI"], ",", 
    RowBox[{
     StyleBox["[",
      SpanMaxSize->1], 
     RowBox[{
      StyleBox["A", "TI"], ",", 
      StyleBox["B", "TI"]}], 
     StyleBox["]",
      SpanMaxSize->1]}]}], 
   StyleBox["]",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "7f3efb02-a2c0-4c81-9b18-1021fa3f94e7"],
 " or ",
 Cell[BoxData[
  RowBox[{
   StyleBox["[",
    SpanMaxSize->1], 
   RowBox[{
    StyleBox["B", "TI"], ",", 
    RowBox[{
     StyleBox["[",
      SpanMaxSize->1], 
     RowBox[{
      StyleBox["A", "TI"], ",", 
      RowBox[{
       StyleBox["[",
        SpanMaxSize->1], 
       RowBox[{
        StyleBox["A", "TI"], ",", 
        StyleBox["B", "TI"]}], 
       StyleBox["]",
        SpanMaxSize->1]}]}], 
     StyleBox["]",
      SpanMaxSize->1]}]}], 
   StyleBox["]",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "7361ecc1-cdd3-4336-b655-a58625d793f5"],
 ". With more operators, the same idea appears: ",
 Cell[BoxData[
  RowBox[{
   SuperscriptBox[
    StyleBox["e", "TI"], 
    RowBox[{
     SubscriptBox[
      StyleBox["A", "TI"], "1"], "+", "\[Ellipsis]", "+", 
     SubscriptBox[
      StyleBox["A", "TI"], 
      StyleBox["n", "TI"]]}]], "=", 
   SuperscriptBox[
    StyleBox["e", "TI"], 
    SubscriptBox[
     StyleBox["A", "TI"], "1"]], "\[Ellipsis]", " ", 
   SuperscriptBox[
    StyleBox["e", "TI"], 
    SubscriptBox[
     StyleBox["A", "TI"], 
     StyleBox["n", "TI"]]], 
   UnderoverscriptBox["\[Product]", 
    RowBox[{
     StyleBox["k", "TI"], "=", "2"}], "\[Infinity]",
    LimitsPositioning->False], 
   SuperscriptBox[
    StyleBox["e", "TI"], 
    SubscriptBox["\|01d4b2", 
     StyleBox["k", "TI"]]]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "6c63c881-acba-4d39-8a74-409346043e4d"],
 " where each ",
 Cell[BoxData[
  SubscriptBox["\|01d4b2", 
   StyleBox["k", "TI"]]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "c1528b13-7aeb-41ac-a692-05ef8427db4e"],
 " is a sum of all the independent nested-commutator \
\[OpenCurlyDoubleQuote]shapes\[CloseCurlyDoubleQuote] of total degree ",
 Cell[BoxData[
  StyleBox["k", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "c1ac4064-4405-4e90-8873-2989929c991a"],
 ", with coefficients chosen so that the product equals the original \
exponential exactly. For example, ",
 Cell[BoxData[
  SubscriptBox["\|01d4b2", "3"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "f0c21bcb-3f15-47fc-acdf-7d1dd75b6a9f"],
 " contains degree-3 commutators like ",
 Cell[BoxData[
  RowBox[{
   StyleBox["[",
    SpanMaxSize->1], 
   RowBox[{
    SubscriptBox[
     StyleBox["A", "TI"], 
     StyleBox["i", "TI"]], ",", 
    RowBox[{
     StyleBox["[",
      SpanMaxSize->1], 
     RowBox[{
      SubscriptBox[
       StyleBox["A", "TI"], 
       StyleBox["j", "TI"]], ",", 
      SubscriptBox[
       StyleBox["A", "TI"], 
       StyleBox["k", "TI"]]}], 
     StyleBox["]",
      SpanMaxSize->1]}]}], 
   StyleBox["]",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "07ed5de8-b107-4dc9-af3f-38b29f7c5e7d"],
 ". This structure is especially important because commutators of elements in \
a Lie algebra stay in the same Lie algebra. So every ",
 Cell[BoxData[
  SubscriptBox["\|01d4b2", 
   StyleBox["k", "TI"]]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "9e4ca9ed-361c-465e-9798-b1cba251ac86"],
 " remains in the same Lie algebra generated by the original operators. In \
practice, the Zassenhaus formula is a disciplined way to replace one \
complicated exponential of a sum by a product of simpler exponentials, \
together with an orderly hierarchy of commutator-built correction \
exponentials."
}], "Text",ExpressionUUID->"14e2fbcd-7bb0-4b1f-ab37-c91be1317569"],

Cell[TextData[{
 "Show a few terms in the Zassenhaus formula for ",
 Cell[BoxData[
  RowBox[{
   SuperscriptBox[
    StyleBox["e", "TI"], 
    RowBox[{
     StyleBox["A", "TI"], "+", 
     StyleBox["B", "TI"]}]], "=", 
   SuperscriptBox[
    StyleBox["e", "TI"], 
    StyleBox["A", "TI"]], 
   SuperscriptBox[
    StyleBox["e", "TI"], 
    StyleBox["B", "TI"]], 
   UnderscriptBox["\[Product]", 
    RowBox[{
     StyleBox["k", "TI"], "=", "2"}],
    LimitsPositioning->False], 
   SuperscriptBox[
    StyleBox["e", "TI"], 
    SubscriptBox["\|01d4b2", 
     StyleBox["k", "TI"]]]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "c9de3d5c-a162-4050-8fc6-b1031567ed2c"],
 ":"
}], "Text",ExpressionUUID->"6011c053-7953-4548-bc60-e1f7675f5857"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"ClearAll", "[", 
   RowBox[{"A", ",", " ", "B"}], "]"}], ";"}], "\n", 
 RowBox[{"Grid", "[", 
  RowBox[{
   RowBox[{"Table", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"Subscript", "[", 
        RowBox[{"\"\<\[ScriptCapitalW]\>\"", ",", " ", "n"}], "]"}], ",", " ",
        "\n", "   ", 
       RowBox[{"TraditionalForm", "@", 
        RowBox[{
         RowBox[{"ResourceFunction", "[", "\n", 
          RowBox[{"ResourceObject", "[", 
           RowBox[{
            RowBox[{"<|", 
             RowBox[{
              
              RowBox[{"\"\<Name\>\"", " ", "->", 
               " ", "\"\<ZassenhausTerms\>\""}], ",", " ", "\n", "        ", 
              
              RowBox[{"\"\<ShortName\>\"", " ", "->", 
               " ", "\"\<ZassenhausTerms\>\""}], ",", " ", "\n", "        ", 
              
              RowBox[{"\"\<UUID\>\"", " ", "->", 
               " ", "\"\<2f3af1fe-2038-454d-928f-8f9a68dfdbfc\>\""}], ",", 
              " ", "\n", "        ", 
              
              RowBox[{"\"\<ResourceType\>\"", " ", "->", 
               " ", "\"\<Function\>\""}], ",", " ", 
              RowBox[{"\"\<Version\>\"", " ", "->", " ", "\"\<1.1.0\>\""}], ",",
               " ", "\n", "        ", 
              
              RowBox[{"\"\<Description\>\"", " ", "->", 
               " ", "\"\<Generate terms in the Zassenhaus formula\>\""}], ",",
               " ", "\n", "        ", 
              RowBox[{"\"\<RepositoryLocation\>\"", " ", "->", " ", 
               RowBox[{
               "URL", "[", "\n", 
                "         ", \
"\"\<https://www.wolframcloud.com/obj/resourcesystem/api/1.0\>\"", "]"}]}], ",",
               " ", "\n", "        ", 
              
              RowBox[{"\"\<SymbolName\>\"", " ", "->", 
               " ", "\"\<FunctionRepository`$f824943f857d4d28a1db4ee6b8cc9d97`\
ZassenhausTerms\>\""}], ",", " ", "\n", "        ", 
              RowBox[{"\"\<FunctionLocation\>\"", " ", "->", " ", 
               RowBox[{
               "CloudObject", "[", "\n", 
                "         ", \
"\"\<https://www.wolframcloud.com/obj/9a598a1b-b5bb-4f2f-8405-2e5b258da354\>\"\
", "]"}]}]}], "|>"}], ",", " ", 
            RowBox[{"ResourceSystemBase", " ", "->", " ", "Automatic"}]}], 
           "]"}], "]"}], "[", 
         RowBox[{
          RowBox[{"{", " ", 
           RowBox[{"A", ",", " ", "B"}], "}"}], ",", " ", "n", ",", " ", "\n",
           "     ", 
          RowBox[{"\"\<CommutatorForm\>\"", " ", "->", " ", "True"}]}], 
         "]"}]}]}], "}"}], ",", " ", 
     RowBox[{"{", 
      RowBox[{"n", ",", " ", "2", ",", " ", "4"}], "}"}]}], "]"}], ",", " ", 
   RowBox[{"Frame", " ", "->", " ", "All"}], ",", " ", "\n", " ", 
   RowBox[{"Alignment", " ", "->", " ", "Left"}]}], "]"}]}], "Input",
 CellLabel->
  "In[177]:= ",ExpressionUUID->"ed3a68d2-2d7e-4b94-9618-8b5e6c62b906"],

Cell[TextData[{
 "For example, consider the operator exponential ",
 Cell[BoxData[
  SuperscriptBox[
   StyleBox["e", "TI"], 
   RowBox[{"-", 
    StyleBox["i", "TI"], "/", "2", 
    StyleBox["(",
     SpanMaxSize->1], 
    RowBox[{
     SubscriptBox[
      StyleBox["\[Theta]", "TI"], "3"], " ", 
     SubscriptBox[
      StyleBox["\[Sigma]", "TI"], "3"], "+", 
     SubscriptBox[
      StyleBox["\[Theta]", "TI"], "2"], 
     SubscriptBox[
      StyleBox["\[Sigma]", "TI"], "2"]}], 
    StyleBox[")",
     SpanMaxSize->1]}]]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "0955cb0b-69af-4e7e-9117-8d797b05d367"],
 ". Because ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["\[Sigma]", "TI"], "3"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "6cc08c0b-20cd-4891-9316-088515190df9"],
 " and ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["\[Sigma]", "TI"], "2"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "b5ff774a-649b-46e3-b73f-193457e0f673"],
 " do not commute (",
 Cell[BoxData[
  RowBox[{
   StyleBox["[",
    SpanMaxSize->1], 
   RowBox[{
    SubscriptBox[
     StyleBox["\[Sigma]", "TI"], "2"], ",", 
    SubscriptBox[
     StyleBox["\[Sigma]", "TI"], "3"]}], 
   StyleBox["]",
    SpanMaxSize->1], "=", "2", 
   StyleBox["i", "TI"], 
   SubscriptBox[
    StyleBox["\[Sigma]", "TI"], "1"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "ec15f2f2-b0a1-4dd3-b128-83ecebb73646"],
 "), we can use the Zassenhaus formula to split it into a product of simpler \
exponentials plus a commutator correction. Keeping only the first correction \
term, we obtain: ",
 Cell[BoxData[
  RowBox[{
   SuperscriptBox[
    StyleBox["e", "TI"], 
    RowBox[{"-", 
     StyleBox["i", "TI"], "/", "2", 
     StyleBox["(",
      SpanMaxSize->1], 
     RowBox[{
      SubscriptBox[
       StyleBox["\[Theta]", "TI"], "3"], " ", 
      SubscriptBox[
       StyleBox["\[Sigma]", "TI"], "3"], "+", 
      SubscriptBox[
       StyleBox["\[Theta]", "TI"], "2"], 
      SubscriptBox[
       StyleBox["\[Sigma]", "TI"], "2"]}], 
     StyleBox[")",
      SpanMaxSize->1]}]], "\[TildeTilde]", 
   SuperscriptBox[
    StyleBox["e", "TI"], 
    RowBox[{"-", 
     StyleBox["i", "TI"], "/", "2", 
     SubscriptBox[
      StyleBox["\[Theta]", "TI"], "3"], " ", 
     SubscriptBox[
      StyleBox["\[Sigma]", "TI"], "3"]}]], 
   SuperscriptBox[
    StyleBox["e", "TI"], 
    RowBox[{"-", 
     StyleBox["i", "TI"], "/", "2", 
     SubscriptBox[
      StyleBox["\[Theta]", "TI"], "2"], 
     SubscriptBox[
      StyleBox["\[Sigma]", "TI"], "2"]}]], 
   SuperscriptBox[
    StyleBox["e", "TI"], 
    RowBox[{"-", 
     StyleBox["i", "TI"], "/", "4", 
     SubscriptBox[
      StyleBox["\[Theta]", "TI"], "2"], " ", 
     SubscriptBox[
      StyleBox["\[Theta]", "TI"], "3"], 
     SubscriptBox[
      StyleBox["\[Sigma]", "TI"], "1"]}]]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "aa28ef71-b91f-41b7-a792-5bf5d932d60f"],
 ". Note that this approximation depends on the ordering. If we start instead \
with the exponential of ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["\[Sigma]", "TI"], "2"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "6cd78e79-f0ef-435b-971e-1e719b1419e9"],
 ", we get: ",
 Cell[BoxData[
  RowBox[{
   SuperscriptBox[
    StyleBox["e", "TI"], 
    RowBox[{"-", 
     StyleBox["i", "TI"], "/", "2", 
     StyleBox["(",
      SpanMaxSize->1], 
     RowBox[{
      SubscriptBox[
       StyleBox["\[Theta]", "TI"], "3"], " ", 
      SubscriptBox[
       StyleBox["\[Sigma]", "TI"], "3"], "+", 
      SubscriptBox[
       StyleBox["\[Theta]", "TI"], "2"], 
      SubscriptBox[
       StyleBox["\[Sigma]", "TI"], "2"]}], 
     StyleBox[")",
      SpanMaxSize->1]}]], "\[TildeTilde]", 
   SuperscriptBox[
    StyleBox["e", "TI"], 
    RowBox[{"-", 
     StyleBox["i", "TI"], "/", "2", 
     SubscriptBox[
      StyleBox["\[Theta]", "TI"], "2"], " ", 
     SubscriptBox[
      StyleBox["\[Sigma]", "TI"], "2"]}]], 
   SuperscriptBox[
    StyleBox["e", "TI"], 
    RowBox[{"-", 
     StyleBox["i", "TI"], "/", "2", 
     SubscriptBox[
      StyleBox["\[Theta]", "TI"], "3"], 
     SubscriptBox[
      StyleBox["\[Sigma]", "TI"], "3"]}]], 
   SuperscriptBox[
    StyleBox["e", "TI"], 
    RowBox[{
     StyleBox["i", "TI"], "/", "4", 
     SubscriptBox[
      StyleBox["\[Theta]", "TI"], "2"], " ", 
     SubscriptBox[
      StyleBox["\[Theta]", "TI"], "3"], 
     SubscriptBox[
      StyleBox["\[Sigma]", "TI"], "1"]}]]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
