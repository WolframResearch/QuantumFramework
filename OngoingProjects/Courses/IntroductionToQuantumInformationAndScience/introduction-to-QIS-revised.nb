Cell[992490, 16382, 202, 4, 70, "Input",ExpressionUUID->"385de761-b488-4860-8913-9b12fb135fc2"],
Cell[992695, 16388, 1748, 52, 70, "Text",ExpressionUUID->"864ad4e3-202b-4985-8a56-3d8c280f6042"],
Cell[994446, 16442, 158, 2, 70, "Subsection",ExpressionUUID->"099c8820-5315-44f4-b559-e4af4c751099"],
Cell[994607, 16446, 2835, 85, 70, "Text",ExpressionUUID->"0d835b8c-9494-4b8d-9f97-93c27a110479"],
Cell[997445, 16533, 371, 11, 70, "Text",ExpressionUUID->"0a96fd55-e133-4775-aed4-fa320226e1b4"],
Cell[997819, 16546, 281, 8, 70, "Input",ExpressionUUID->"0d7f5a25-ea0a-45f3-b5eb-42704e8e6a04"],
Cell[998103, 16556, 354, 11, 70, "Text",ExpressionUUID->"297b9e0e-5c5e-447e-b922-ce05504efcba"],
