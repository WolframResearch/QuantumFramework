        RowBox[{"ColorData", "[", "97", "]"}], "[", "2", "]"}]}], "}"}], ",", 
     " ", 
     RowBox[{"{", 
      RowBox[{"\"\<Lindblad DE\>\"", ",", " ", "\n", 
       "   ", "\"\<Numerically noise-averaged\>\""}], "}"}]}], "]"}]}], 
  "]"}]], "Input",
 CellLabel->
  "In[297]:= ",ExpressionUUID->"48db0c23-fe9a-408f-bf2b-91ccffb3d66d"],

Cell[TextData[{
 "Visualize Bloch vector dynamics for different values of ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["\[Omega]", "TI"], 
   StyleBox["x", "TI"]]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "54d2eb03-bdbc-458b-9b79-a906cec35260"],
 " and \[Gamma]:"
}], "Text",ExpressionUUID->"b069e15d-21a6-4201-b42a-e06476257d32"],

Cell[BoxData[
 RowBox[{"Manipulate", "[", 
  RowBox[{
   RowBox[{
    RowBox[{"state", " ", "=", " ", 
     RowBox[{
      RowBox[{"ResourceFunction", "[", "\n", 
       RowBox[{"ResourceObject", "[", 
        RowBox[{
         RowBox[{"<|", 
          RowBox[{
           RowBox[{"\"\<Name\>\"", " ", "->", " ", "\"\<LindbladSolve\>\""}], 
           ",", " ", "\n", "      ", 
           
           RowBox[{"\"\<ShortName\>\"", " ", "->", 
            " ", "\"\<LindbladSolve\>\""}], ",", " ", "\n", "      ", 
           
           RowBox[{"\"\<UUID\>\"", " ", "->", 
            " ", "\"\<2fb9b1f8-48b5-4683-8965-99b71d387bf2\>\""}], ",", " ", 
           "\n", "      ", 
           
           RowBox[{"\"\<ResourceType\>\"", " ", "->", 
            " ", "\"\<Function\>\""}], ",", " ", 
           RowBox[{"\"\<Version\>\"", " ", "->", " ", "\"\<1.0.0\>\""}], ",", 
           " ", "\n", "      ", 
           
           RowBox[{"\"\<Description\>\"", " ", "->", 
            " ", "\"\<Solve the Lindblad master equation\>\""}], ",", " ", 
           "\n", "      ", 
           RowBox[{"\"\<RepositoryLocation\>\"", " ", "->", " ", 
            RowBox[{
            "URL", "[", "\n", 
             "       ", \
"\"\<https://www.wolframcloud.com/obj/resourcesystem/api/1.0\>\"", "]"}]}], ",",
            " ", "\n", "      ", 
           
           RowBox[{"\"\<SymbolName\>\"", " ", "->", 
            " ", "\"\<FunctionRepository`$d7deeb19fe0d4b10a065b53823858cf0`\
LindbladSolve\>\""}], ",", " ", "\n", "      ", 
           RowBox[{"\"\<FunctionLocation\>\"", " ", "->", " ", 
            RowBox[{
            "CloudObject", "[", "\n", 
             "       ", \
"\"\<https://www.wolframcloud.com/obj/d69ea1bb-70ba-41dd-a54f-17256089991f\>\"\
", "]"}]}]}], "|>"}], ",", " ", 
         RowBox[{"ResourceSystemBase", " ", "->", " ", "Automatic"}]}], "]"}],
        "]"}], "[", "\n", "   ", 
      RowBox[{
       RowBox[{
        RowBox[{"1", "/", "2"}], " ", "\[Omega]x", " ", 
        RowBox[{"PauliMatrix", "[", "1", "]"}]}], ",", " ", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"Sqrt", "[", "\[Gamma]", "]"}], " ", 
         RowBox[{"PauliMatrix", "[", "3", "]"}]}], "}"}], ",", " ", "\n", 
       "   ", 
       RowBox[{
        RowBox[{"1", "/", "2"}], " ", 
        RowBox[{"(", 
         RowBox[{
          RowBox[{"IdentityMatrix", "[", "2", "]"}], " ", "+", " ", "\n", 
          "      ", 
          RowBox[{
           RowBox[{"FromSphericalCoordinates", "[", 
            RowBox[{"{", 
             RowBox[{"1", ",", " ", 
              RowBox[{"\[Pi]", "/", "4"}], ",", " ", "0"}], "}"}], "]"}], " ",
            ".", " ", "\n", "       ", 
           RowBox[{"Table", "[", 
            RowBox[{
             RowBox[{"PauliMatrix", "[", "j", "]"}], ",", " ", 
             RowBox[{"{", 
              RowBox[{"j", ",", " ", "3"}], "}"}]}], "]"}]}]}], ")"}]}], ",", 
       " ", 
       RowBox[{"{", 
        RowBox[{"t", ",", " ", "0", ",", " ", "10"}], "}"}]}], "]"}]}], ";", 
    "\n", " ", 
    RowBox[{"Show", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"ResourceFunction", "[", "\"\<BlochSpherePlot\>\"", "]"}], "[", 
       RowBox[{"ImageSize", " ", "->", " ", "250"}], "]"}], ",", "\n", "   ", 
      
      RowBox[{"ParametricPlot3D", "[", "\n", "   ", 
       RowBox[{
        RowBox[{"Re", "@", 
         RowBox[{"Table", "[", 
          RowBox[{
           RowBox[{"Tr", "[", 
            RowBox[{
             RowBox[{"state", "[", "t", "]"}], " ", ".", " ", 
             RowBox[{"PauliMatrix", "[", "j", "]"}]}], "]"}], ",", " ", 
           RowBox[{"{", 
            RowBox[{"j", ",", " ", "3"}], "}"}]}], "]"}]}], ",", " ", 
        RowBox[{"{", 
         RowBox[{"t", ",", " ", "0", ",", " ", "10"}], "}"}], ",", " ", "\n", 
        "   ", 
        RowBox[{"PlotRange", " ", "->", " ", "All"}]}], "]"}], ",", " ", "\n",
       "  ", 
      RowBox[{
      "PlotLabel", " ", "->", " ", "\n", 
       "   ", "\"\<Lindbladian Evolution with H = \n    1/2 \
Subscript[\[Omega], x] Subscript[\[Sigma], x]\n and L = \n    Sqrt[\[Gamma]] \
Subscript[\[Sigma], z]\n      for a fixed time duration\>\""}]}], "]"}]}], ",",
    " ", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
      "\[Omega]x", ",", " ", "2", ",", " ", "\n", 
       "   ", "\"\<Coherent drive \\!\\(\\*SubscriptBox[\\(\[Omega]\\), \
\\(x\\)]\\)\>\""}], "}"}], ",", " ", "1", ",", " ", "\n", "  ", "10"}], "}"}],
    ",", " ", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
      "\[Gamma]", ",", " ", ".2", ",", " ", "\"\<Jump rate \[Gamma]\>\""}], 
      "}"}], ",", " ", "0", ",", " ", "1"}], "}"}]}], "]"}]], "Input",
 CellLabel->
  "In[298]:= ",ExpressionUUID->"5da1a6d4-8216-42ad-ab3a-809399518124"],

Cell[TextData[{
 "As mentioned before, the key feature of this Lindblad dynamics is that the \
ensemble of qubits continues to oscillate due to the coherent drive generated \
by ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["\[Sigma]", "TI"], 
   StyleBox["x", "TI"]]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "29eae07e-1807-4351-a023-322cf86ae04f"],
 ", but at the same time it gradually loses coherence because of the jump \
operator ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["\[Sigma]", "TI"], 
   StyleBox["z", "TI"]]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "ded0995e-f7dc-4127-9e72-67c95eff6ef1"],
 " and the state drifts toward the center of the Bloch sphere (a fully mixed \
state). The rate of this coherence loss is set by \[Gamma]: the larger \
\[Gamma] is, the faster the Bloch vector collapses toward the center, i.e., \
the faster the decoherence proceeds."
}], "Text",ExpressionUUID->"0a9a94d6-0773-4f10-afaa-a2e00a1df01a"],

Cell["\<\
For 1,000 noise realizations, evaluate the norm of the difference between the \
numerically noise-averaged Bloch vector and the Bloch vector predicted by the \
Lindblad equation, over time:\
\>", "Text",ExpressionUUID->"950d1735-6f86-4f93-9856-e5ae64874ba3"],

Cell[BoxData[
 RowBox[{"ListLinePlot", "[", "\n", " ", 
  RowBox[{
   RowBox[{"Norm", " ", "/@", " ", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"Mean", "@", "blochVectorTrajectories"}], " ", "-", " ", "\n", 
      "    ", 
      RowBox[{"Table", "[", 
       RowBox[{
        RowBox[{"Re", "@", 
         RowBox[{"Table", "[", 
          RowBox[{
           RowBox[{"Tr", "[", 
            RowBox[{
             RowBox[{"\[Rho]t", "[", "t", "]"}], " ", ".", " ", 
             RowBox[{"PauliMatrix", "[", "j", "]"}]}], "]"}], ",", " ", 
           RowBox[{"{", 
            RowBox[{"j", ",", " ", "3"}], "}"}]}], "]"}]}], ",", " ", 
        RowBox[{"{", 
         RowBox[{
         "t", ",", " ", "0", ",", " ", "\n", "      ", "10", ",", " ", 
          ".001"}], "}"}]}], "]"}]}], ")"}]}], ",", " ", 
   RowBox[{"DataRange", " ", "->", " ", 
    RowBox[{"{", 
     RowBox[{"0", ",", " ", "10"}], "}"}]}], ",", " ", 
   RowBox[{"Frame", " ", "->", " ", "True"}], ",", " ", "\n", " ", 
   RowBox[{"FrameLabel", " ", "->", " ", 
    RowBox[{"{", 
     RowBox[{"\"\<Time\>\"", ",", " ", "\"\<Norm difference\>\""}], "}"}]}], ",",
    " ", "\n", " ", 
   RowBox[{
   "PlotLabel", " ", "->", " ", "\n", 
    "  ", "\"\<Norm difference between the numerically noise-averaged\n Bloch \
vector and the one obtained from the Lindblad equation.\>\""}]}], 
  "]"}]], "Input",
 CellLabel->
  "In[299]:= ",ExpressionUUID->"5b1db1d0-d695-430a-9205-7b978f666b73"],

Cell["\<\
Collapse as Dynamics: Continuous Measurement and the Born Rule\
\>", "Subsection",ExpressionUUID->"df820cdd-6781-4897-b217-2ce462de728f"],

Cell[TextData[{
 "In our discussion of quantum measurement, state change was introduced as an \
extra axiom, the collapse postulate: ",
 Cell[BoxData[
  RowBox[{
   StyleBox["\[Rho]", "TI"], "\[Rule]", 
   SuperscriptBox["\[ScriptCapitalM]", "\[Dagger]"], 
   StyleBox["\[Rho]", "TI"], " ", "\[ScriptCapitalM]"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "23136d98-bc50-46ff-a282-ba88f8638a9c"],
 ". A natural question is whether this \[OpenCurlyDoubleQuote]collapse\
\[CloseCurlyDoubleQuote] can instead be understood as the outcome of \
continuous dynamics. Collapse models provide a principled route: they posit a \
fundamental, space\[Dash]time\[Dash]filling noise that couples nonlinearly to \
quantum systems, producing stochastic (Brownian) corrections to Schr\
\[ODoubleDot]dinger evolution. For microscopic systems these corrections are \
negligible, but they become dominant during measurement, or more generally \
for large, composite systems through an amplification mechanism, thereby \
driving a dynamical localization (effective wave-function collapse)."
}], "Text",ExpressionUUID->"4ee6fb74-962b-46bd-86f6-1d9ee5cf7206"],

Cell[TextData[{
 "A particularly useful framework is Quantum State Diffusion (QSD), which \
formulates this idea as a stochastic, nonlinear evolution closely connected \
to open-quantum-system dynamics and continuous monitoring. In QSD, the \
density matrix obeys the It\[OHat] Stochastic Dynamical Equation (SDE): ",
 Cell[BoxData[
  RowBox[{
   StyleBox["d", "TI"], 
   StyleBox["\[Rho]", "TI"], "=", 
   StyleBox["d", "TI"], 
   StyleBox["t", "TI"], 
   StyleBox["(",
    SpanMaxSize->1], 
   RowBox[{"-", 
    StyleBox["i", "TI"], 
    StyleBox["[",
     SpanMaxSize->1], 
    RowBox[{
     StyleBox["H", "TI"], ",", 
     StyleBox["\[Rho]", "TI"]}], 
    StyleBox["]",
     SpanMaxSize->1], "+", 
    StyleBox["\[Gamma]", "TI"], 
    StyleBox["(",
     SpanMaxSize->1], 
    RowBox[{
     RowBox[{
      StyleBox["L", "TI"], " ", 
      StyleBox["\[Rho]", "TI"], " ", 
      SuperscriptBox[
       StyleBox["L", "TI"], "\[Dagger]"], "-", "1", "/", "2", "{", 
      SuperscriptBox[
       StyleBox["L", "TI"], "\[Dagger]"], 
      StyleBox["L", "TI"]}], ",", 
     RowBox[{
      StyleBox["\[Rho]", "TI"], "}"}]}], 
    StyleBox[")",
     SpanMaxSize->1]}], 
   StyleBox[")",
    SpanMaxSize->1], "+", 
   StyleBox["d", "TI"], 
   SubscriptBox[
    StyleBox["W", "TI"], 
    StyleBox["t", "TI"]], 
   SqrtBox[
    StyleBox["\[Gamma]", "TI"]], 
   StyleBox["(",
    SpanMaxSize->1], 
   RowBox[{
    StyleBox["L", "TI"], " ", 
    StyleBox["\[Rho]", "TI"], "+", 
    StyleBox["\[Rho]", "TI"], " ", 
    SuperscriptBox[
     StyleBox["L", "TI"], "\[Dagger]"], "-", 
    StyleBox["T", "TI"], 
    StyleBox["r", "TI"], 
    StyleBox["[",
     SpanMaxSize->1], 
    RowBox[{
     StyleBox["L", "TI"], " ", 
     StyleBox["\[Rho]", "TI"], "+", 
     StyleBox["\[Rho]", "TI"], " ", 
     SuperscriptBox[
      StyleBox["L", "TI"], "\[Dagger]"]}], 
    StyleBox["]",
     SpanMaxSize->1], 
    StyleBox["\[Rho]", "TI"]}], 
   StyleBox[")",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "b8719cad-da1e-42f4-9382-81279b16df44"],
 " where ",
 Cell[BoxData[
  StyleBox["H", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "496d31bc-d9a2-4e1b-9afb-113147f459e6"],
 " is the Hamiltonian, ",
 Cell[BoxData[
  StyleBox["L", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "fdb39ddd-867e-4e8f-94b2-9f7218faed26"],
 " the measurement (Lindblad) operator, \[Gamma] the coupling/measurement \
strength, and ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["W", "TI"], 
   StyleBox["t", "TI"]]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "6c844a29-cf07-4a2d-a7d9-45d6f6104e24"],
 " a Wiener process. The increment ",
 Cell[BoxData[
  StyleBox[
   RowBox[{"d", "\[Rho]"}], "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "aa8af29c-1c0a-49ed-b858-6761eb36c76d"],
 " splits into a deterministic drift proportional to ",
 Cell[BoxData[
  StyleBox[
   RowBox[{"d", "t"}], "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "8a0b0d2a-91ce-41e8-bd1e-19758a06f801"],
 " and a stochastic fluctuation proportional to ",
 Cell[BoxData[
  RowBox[{
   StyleBox["d", "TI"], 
   SubscriptBox[
    StyleBox["W", "TI"], 
    StyleBox["t", "TI"]]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "813cbf47-1e58-4503-a6a8-102953e86a97"],
 ". The term ",
 Cell[BoxData[
  RowBox[{"-", 
   StyleBox["i", "TI"], 
   StyleBox["[",
    SpanMaxSize->1], 
   RowBox[{
    StyleBox["H", "TI"], ",", 
    StyleBox["\[Rho]", "TI"]}], 
   StyleBox["]",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "94989f3d-c54f-4deb-9522-9518240fdd8b"],
 " is the usual unitary Schr\[ODoubleDot]dinger (von Neumann) evolution \
generated by the Hamiltonian ",
 Cell[BoxData[
  StyleBox["H", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "bd460ec6-5b2e-4c0d-8090-fb2c88bc6322"],
 ". It preserves purity and entropy in isolation and simply rotates the state \
in Hilbert space; by itself it never collapses anything, it only mixes \
populations and coherences according to the system\[CloseCurlyQuote]s \
intrinsic dynamics.  The ",
 Cell[BoxData[
  StyleBox[
   RowBox[{"d", "t"}], "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "45983049-c858-4eb1-97e2-c5c96d375c46"],
 " term multiplied by \[Gamma] is the dissipative Lindblad drift, ",
 Cell[BoxData[
  RowBox[{
   StyleBox["\[Gamma]", "TI"], 
   StyleBox["(",
    SpanMaxSize->1], 
   RowBox[{
    RowBox[{
     StyleBox["L", "TI"], " ", 
     StyleBox["\[Rho]", "TI"], " ", 
     SuperscriptBox[
      StyleBox["L", "TI"], "\[Dagger]"], " ", "-", " ", "1", "/", "2", "{", 
     SuperscriptBox[
      StyleBox["L", "TI"], "\[Dagger]"], 
     StyleBox["L", "TI"]}], ",", 
    RowBox[{
     StyleBox["\[Rho]", "TI"], "}"}]}], 
   StyleBox[")",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "7b6a61ac-c875-46a2-8164-4a811baa8026"],
 ". The \[OpenCurlyDoubleQuote]jump\[CloseCurlyDoubleQuote] part ",
 Cell[BoxData[
  RowBox[{
   StyleBox["L", "TI"], " ", 
   StyleBox["\[Rho]", "TI"], " ", 
   SuperscriptBox[
    StyleBox["L", "TI"], "\[Dagger]"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "c74fea72-c9dc-465f-9d11-879294f1a13c"],
 " is the state-update associated with the measurement channel or \
environmental coupling: it transfers weight toward components favored by the \
operator ",
 Cell[BoxData[
  StyleBox["L", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "a6434295-4210-4368-830d-1fa331d766ac"],
 ". The anticommutator subtraction ",
 Cell[BoxData[
  RowBox[{" ", 
   RowBox[{
    RowBox[{"1", "/", "2"}], 
    RowBox[{"{", 
     RowBox[{
      RowBox[{
       SuperscriptBox[
        StyleBox["L", "TI"], "\[Dagger]"], 
       StyleBox["L", "TI"]}], ",", 
      RowBox[{
       StyleBox["\[Rho]", "TI"], "}"}]}]}]}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "4e98e2e6-e781-4170-8a99-ae25947d4c05"],
 " is the compensating damping needed to keep ",
 Cell[BoxData[
  RowBox[{
   StyleBox["T", "TI"], 
   StyleBox["r", "TI"], 
   StyleBox["(",
    SpanMaxSize->1], 
   StyleBox["\[Rho]", "TI"], 
   StyleBox[")",
    SpanMaxSize->1], "=", "1"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "7f145a05-77fc-4dde-8498-a9354fee6038"],
 " and maintain complete positivity; physically it attenuates coherences in \
the eigenbasis picked out by ",
 Cell[BoxData[
  RowBox[{
   SuperscriptBox[
    StyleBox["L", "TI"], "\[Dagger]"], 
   StyleBox["L", "TI"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "7d528a4e-03fd-428d-90eb-a7a0e8ed800d"],
 " and sets the average decoherence/relaxation rate. Together these two \
pieces are exactly the unconditional open-system evolution you would get \
after averaging over all measurement outcomes (i.e., the Lindblad equation): \
they describe systematic decoherence and dissipation but do not select a \
specific outcome in a single run.  The noise term ",
 Cell[BoxData[
  RowBox[{
   RowBox[{
    StyleBox["d", "TI"], 
    SubscriptBox[
     StyleBox["W", "TI"], 
     StyleBox["t", "TI"]], 
    SqrtBox[
     StyleBox["\[Gamma]", "TI"]]}], "(", 
   RowBox[{
    StyleBox["L", "TI"], " ", 
    StyleBox["\[Rho]", "TI"], "+", 
    StyleBox["\[Rho]", "TI"], " ", 
    SuperscriptBox[
     StyleBox["L", "TI"], "\[Dagger]"], "-", 
    StyleBox["T", "TI"], 
    StyleBox["r", "TI"], 
    StyleBox["[",
     SpanMaxSize->1], 
    RowBox[{
     StyleBox["L", "TI"], " ", 
     StyleBox["\[Rho]", "TI"], "+", 
     StyleBox["\[Rho]", "TI"], " ", 
     SuperscriptBox[
      StyleBox["L", "TI"], "\[Dagger]"]}], 
    StyleBox["]",
     SpanMaxSize->1], 
    StyleBox["\[Rho]", "TI"]}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "c89568de-b820-4e36-9823-daf3eecb5bf0"],
 " is the conditional, outcome-dependent backaction. The factor ",
 Cell[BoxData[
  SqrtBox[
   StyleBox["\[Gamma]", "TI"]]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "06d16d61-921c-42e5-a6c8-9f47af66b3e8"],
 " sets the strength of fluctuations relative to the drift, so stronger \
monitoring makes the state respond more sharply to the measurement record. \
The combination ",
 Cell[BoxData[
  RowBox[{
   StyleBox["L", "TI"], " ", 
   StyleBox["\[Rho]", "TI"], "+", 
   StyleBox["\[Rho]", "TI"], " ", 
   SuperscriptBox[
    StyleBox["L", "TI"], "\[Dagger]"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "965f805a-ec0f-4cff-9bf0-a748f02112a9"],
 " is the instantaneous \[OpenCurlyDoubleQuote]innovation\
\[CloseCurlyDoubleQuote] that tries to push the state toward eigenstates \
associated with ",
 Cell[BoxData[
  StyleBox["L", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "a9401d41-2657-4c66-9b6c-81f8a01d6cea"],
 " (more precisely, toward states with definite values of the measured \
observable when ",
 Cell[BoxData[
  StyleBox["L", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "fe520b7b-ff23-4753-8c0b-97eb55ecc9e2"],
 " is Hermitian). The subtraction of ",
 Cell[BoxData[
  RowBox[{
   StyleBox["T", "TI"], 
   StyleBox["r", "TI"], 
   StyleBox["[",
    SpanMaxSize->1], 
   RowBox[{
    StyleBox["L", "TI"], " ", 
    StyleBox["\[Rho]", "TI"], "+", 
    StyleBox["\[Rho]", "TI"], " ", 
    SuperscriptBox[
     StyleBox["L", "TI"], "\[Dagger]"]}], 
   StyleBox["]",
    SpanMaxSize->1], 
   StyleBox["\[Rho]", "TI"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "09393a83-52aa-4a25-a37b-27dc9154c2d8"],
 " removes the mean component of that push, ensuring the stochastic term is \
trace-free and centered so that, on average, it vanishes; this is what makes \
the ensemble average recover the deterministic Lindblad equation while each \
individual trajectory undergoes random diffusion. Dynamically, this \
stochastic part continuously amplifies small differences in the state\
\[CloseCurlyQuote]s overlap with the preferred eigenstates and drives \
purification: in a single realization it tends to sharpen the state toward a \
definite measurement outcome, while the Hamiltonian term competes by rotating \
the state and the Lindblad drift sets the baseline decoherence scale."
}], "Text",ExpressionUUID->"b6f2413a-2ddc-4b43-aeba-e932e446a393"],

Cell[TextData[{
 "Set the density matrix ",
 Cell[BoxData[
  RowBox[{
   StyleBox["\[Rho]", "TI"], "=", "1", "/", "2", 
   StyleBox["(",
    SpanMaxSize->1], 
   RowBox[{
    RowBox[{"\|01d540", "+", 
     OverscriptBox[
      StyleBox["r", "TI"], "\[RightVector]"]}], ".", 
    OverscriptBox[
     StyleBox["\[Sigma]", "TI"], "\[RightVector]"]}], 
   StyleBox[")",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "408e2967-a917-495e-a153-c471fa124240"],
 ", Hamiltonian ",
 Cell[BoxData[
  RowBox[{
   StyleBox["H", "TI"], "=", "1", "/", "2", 
   SubscriptBox[
    StyleBox["\[Omega]", "TI"], 
    StyleBox["x", "TI"]], 
   SubscriptBox[
    StyleBox["\[Sigma]", "TI"], 
    StyleBox["x", "TI"]]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "52e6cabf-56a9-4f03-a7b1-1a2619f80ea6"],
 " and the Lindblad/jump operator ",
 Cell[BoxData[
  RowBox[{
   StyleBox["L", "TI"], "=", 
   SubscriptBox[
    StyleBox["\[Sigma]", "TI"], 
    StyleBox["z", "TI"]]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "0274c756-3a2f-459e-97b5-b440840b7888"],
 ":"
}], "Text",ExpressionUUID->"a5f1e2cb-8e12-451c-bf0a-4d828d3af122"],

Cell[BoxData[{
 RowBox[{"ClearAll", "[", 
  RowBox[{
  "x", ",", " ", "y", ",", " ", "z", ",", " ", "\[Gamma]", ",", " ", 
   "\[Omega]x", ",", " ", "\[Rho]"}], "]"}], "\n", 
 RowBox[{
  RowBox[{"\[Rho]", " ", "=", " ", 
   RowBox[{"DensityMatrix", "[", 
    RowBox[{"{", 
     RowBox[{"x", ",", " ", "y", ",", " ", "z"}], "}"}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"jumpOperator", " ", "=", " ", 
   RowBox[{"PauliMatrix", "[", "3", "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"hamiltonianOperator", " ", "=", " ", 
   RowBox[{
    RowBox[{"1", "/", "2"}], " ", "\[Omega]x", " ", 
    RowBox[{"PauliMatrix", "[", "1", "]"}]}]}], ";"}]}], "Input",
 CellLabel->
  "In[300]:= ",ExpressionUUID->"9aad8260-3a5a-4a50-8e2d-de53a7520f2b"],

Cell["Compute the non-random terms in the SDE:", "Text",ExpressionUUID->"cebf6c7b-b370-4083-abb6-79f851dd4f24"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"nonRandomTermsCollapseSDE", " ", "=", " ", 
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{"-", "I"}], " ", 
       RowBox[{"Commutator", "[", 
        RowBox[{
        "hamiltonianOperator", ",", " ", "\[Rho]", ",", "\n", "        ", 
         "Dot"}], "]"}]}], " ", "+", " ", 
      RowBox[{"\[Gamma]", " ", 
       RowBox[{"(", 
        RowBox[{
         RowBox[{
         "jumpOperator", " ", ".", " ", "\[Rho]", " ", ".", " ", "\n", 
          "         ", 
          RowBox[{"ConjugateTranspose", "[", "jumpOperator", "]"}]}], " ", "-",
          " ", "\n", "        ", 
         RowBox[{
          RowBox[{"1", "/", "2"}], " ", 
          RowBox[{"Anticommutator", "[", "\n", "          ", 
           RowBox[{
            RowBox[{
             RowBox[{"ConjugateTranspose", "[", "jumpOperator", "]"}], " ", ".",
              " ", "jumpOperator"}], ",", " ", "\[Rho]", ",", " ", "\n", 
            "          ", "Dot"}], "]"}]}]}], ")"}]}]}], " ", "//", " ", 
     "BlochVector"}], " ", "//", " ", "FullSimplify"}]}], ";"}], "\n", 
 RowBox[{"nonRandomTermsCollapseSDE", " ", "//", " ", 
  "MatrixForm"}]}], "Input",
 CellLabel->
  "In[301]:= ",ExpressionUUID->"e3c19b45-3dfd-4f5e-b79f-6a151ac4cdd7"],

Cell["Compute the random terms in the SDE:", "Text",ExpressionUUID->"e8183eb1-a8ae-43b1-820a-537bfa78f1c0"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"randomTermsCollapseSDE", " ", "=", " ", "\n", "  ", 
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{"Sqrt", "[", "\[Gamma]", "]"}], " ", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{"jumpOperator", " ", ".", " ", "\[Rho]"}], " ", "+", " ", 
        RowBox[{"\[Rho]", " ", ".", " ", "\n", "        ", 
         RowBox[{"ConjugateTranspose", "[", "jumpOperator", "]"}]}], " ", "-",
         " ", "\n", "       ", 
        RowBox[{
         RowBox[{"Tr", "[", 
          RowBox[{
           RowBox[{"jumpOperator", " ", ".", " ", "\[Rho]"}], " ", "+", " ", 
           RowBox[{"\[Rho]", " ", ".", " ", "\n", "           ", 
            RowBox[{"ConjugateTranspose", "[", "jumpOperator", "]"}]}]}], 
          "]"}], " ", "\[Rho]"}]}], ")"}]}], " ", "//", " ", "BlochVector"}], 
    " ", "//", "\n", "    ", "FullSimplify"}]}], ";"}], "\n", 
 RowBox[{"randomTermsCollapseSDE", " ", "//", " ", "MatrixForm"}]}], "Input",
 CellLabel->
  "In[302]:= ",ExpressionUUID->"8a262692-c3b4-4880-a391-457e96dc401e"],

Cell[TextData[{
 "Therefore, the Bloch-vector components in Cartesian coordinates obey the It\
\[OHat] SDE: ",
 Cell[BoxData[
  RowBox[{
   RowBox[{
    StyleBox["d", "TI"], 
    RowBox[{"(", GridBox[{
       {
        StyleBox["x", "TI"]},
       {
        StyleBox["y", "TI"]},
       {
        StyleBox["z", "TI"]}
      }], ")"}]}], "=", 
   RowBox[{
    RowBox[{
     RowBox[{
      StyleBox["(",
       SpanMaxSize->1], " ", GridBox[{
        {
         RowBox[{"-", "2", " ", 
          StyleBox["x", "TI"], " ", 
          StyleBox["\[Gamma]", "TI"]}]},
        {
         RowBox[{"-", "2", " ", 
          StyleBox["y", "TI"], " ", 
          StyleBox["\[Gamma]", "TI"], "-", 
          StyleBox["z", "TI"], " ", 
          SubscriptBox[
           StyleBox["\[Omega]", "TI"], 
           StyleBox["x", "TI"]]}]},
        {
         RowBox[{
          StyleBox["y", "TI"], " ", 
          SubscriptBox[
           StyleBox["\[Omega]", "TI"], 
           StyleBox["x", "TI"]]}]}
       }], " ", 
      StyleBox[")",
       SpanMaxSize->1]}], 
     StyleBox["d", "TI"], 
     StyleBox["t", "TI"]}], "+", 
    RowBox[{
     SqrtBox[
      StyleBox["\[Gamma]", "TI"]], 
     RowBox[{
      StyleBox["(",
       SpanMaxSize->1], " ", GridBox[{
        {
         RowBox[{
          RowBox[{"-", "2"}], " ", 
          StyleBox["x", "TI"], " ", 
          StyleBox["z", "TI"], " "}]},
        {
         RowBox[{
          RowBox[{"-", "2"}], " ", 
          StyleBox["y", "TI"], " ", 
          StyleBox["z", "TI"], " "}]},
        {
         RowBox[{"2", " ", 
          RowBox[{
           StyleBox["(",
            SpanMaxSize->1], 
           RowBox[{"1", "-", 
            SuperscriptBox[
             StyleBox["z", "TI"], "2"]}], 
           StyleBox[")",
            SpanMaxSize->1]}], " "}]}
       }], " ", 
      StyleBox[")",
       SpanMaxSize->1]}], 
     StyleBox["d", "TI"], 
     SubscriptBox[
      StyleBox["W", "TI"], 
      StyleBox["t", "TI"]]}]}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "33750bdd-93ac-40f0-b03c-5b85088306e2"],
 " where the drift captures the deterministic decay and Hamiltonian rotation, \
and the noise term encodes measurement backaction as a state-dependent \
diffusion on the Bloch ball. For numerical work, Cartesian coordinates are \
often poorly behaved: discretization can push the trajectory outside the \
Bloch sphere, producing Bloch vectors with length greater than one and hence \
unphysical density matrices. To suppress these artifacts, it is preferable to \
switch to a coordinate system (such as spherical coordinates) whose variables \
more directly respect the geometric constraints of state space. The key \
technical step is then to transform this It\[OHat] SDE from ",
 Cell[BoxData[
  RowBox[{
   RowBox[{"{", 
    StyleBox["x", "TI"]}], ",", 
   StyleBox["y", "TI"], ",", 
   RowBox[{
    StyleBox["z", "TI"], "}"}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "5cd7e6f0-5cb5-463a-9751-02cff904a5a7"],
 " to ",
 Cell[BoxData[
  RowBox[{
   RowBox[{"{", 
    StyleBox["r", "TI"]}], ",", 
   StyleBox["\[Theta]", "TI"], ",", 
   RowBox[{
    StyleBox["\[Phi]", "TI"], "}"}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "8fea53f6-a2af-4465-a725-350af09b420c"],
 ", noting that ordinary chain rules do not apply in It\[OHat] calculus and \
the transformation must be carried out using It\[OHat]\[CloseCurlyQuote]s \
lemma, which includes the second-order correction terms generated by the \
noise. For this task, we will need both the ",
 ButtonBox["Jacobian",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://mathworld.wolfram.com/Jacobian.html"], None}],
 " matrix and the ",
 ButtonBox["Hessian",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://mathworld.wolfram.com/Hessian.html"], None}],
 " tensor. We already computed the Jacobian earlier, but this time let\
\[CloseCurlyQuote]s rederive it using a different approach."
}], "Text",ExpressionUUID->"56122c03-55af-4492-8dd1-1d502690b951"],

Cell[TextData[{
 "Compute Jacobian ",
 Cell[BoxData[
  RowBox[{"\|01d4a5", "=", "\[PartialD]", 
   StyleBox["(",
    SpanMaxSize->1], 
   RowBox[{
    StyleBox["r", "TI"], ",", 
    StyleBox["\[Theta]", "TI"], ",", 
    StyleBox["\[Phi]", "TI"]}], 
   StyleBox[")",
    SpanMaxSize->1], "/", "\[PartialD]", 
   StyleBox["(",
    SpanMaxSize->1], 
   RowBox[{
    StyleBox["x", "TI"], ",", 
    StyleBox["y", "TI"], ",", 
    StyleBox["z", "TI"]}], 
   StyleBox[")",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "6150f1f1-c1a9-42b8-81e7-dc97a3ac5f97"],
 ":"
}], "Text",ExpressionUUID->"4b3e416e-b028-44d7-abd0-06908849deaf"],

Cell[BoxData[{
 RowBox[{"ClearAll", "[", 
  RowBox[{"x", ",", " ", "y", ",", " ", "z"}], "]"}], "\n", 
 RowBox[{
  RowBox[{"jacobian", " ", "=", " ", "\n", "  ", 
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{"Grad", "[", 
       RowBox[{"#", ",", " ", 
        RowBox[{"{", 
         RowBox[{"x", ",", " ", "y", ",", " ", "z"}], "}"}]}], "]"}], " ", 
      "&"}], " ", "/@", " ", 
     RowBox[{"ToSphericalCoordinates", "[", 
      RowBox[{"{", 
       RowBox[{"x", ",", " ", "y", ",", " ", "z"}], "}"}], "]"}]}], " ", "//",
     " ", "\n", "   ", "FullSimplify"}]}], ";"}], "\n", 
 RowBox[{"jacobian", " ", "//", " ", "MatrixForm"}]}], "Input",
 CellLabel->
  "In[303]:= ",ExpressionUUID->"eb298df9-9e85-4177-b276-4f0b2d671a36"],

Cell["Dimensions of Jacobian:", "Text",ExpressionUUID->"757c1f9e-3b42-4b77-a3ec-8d3ad3fcca30"],

Cell[BoxData[
 RowBox[{"Dimensions", "@", "jacobian"}]], "Input",
 CellLabel->
  "In[304]:= ",ExpressionUUID->"95272597-3f21-4b69-84e0-35ccbb8c854a"],

Cell[TextData[{
 "Compute Hessian tensor ",
 Cell[BoxData[
  RowBox[{"\[ScriptCapitalH]", "=", 
   SuperscriptBox["\[PartialD]", "2"], 
   StyleBox["(",
    SpanMaxSize->1], 
   RowBox[{
    StyleBox["r", "TI"], ",", 
    StyleBox["\[Theta]", "TI"], ",", 
    StyleBox["\[Phi]", "TI"]}], 
   StyleBox[")",
    SpanMaxSize->1], "/", "\[PartialD]", 
   StyleBox["(",
    SpanMaxSize->1], 
   RowBox[{
    StyleBox["x", "TI"], ",", 
    StyleBox["y", "TI"], ",", 
    StyleBox["z", "TI"]}], 
   StyleBox[")",
    SpanMaxSize->1], "\[PartialD]", 
   StyleBox["(",
    SpanMaxSize->1], 
   RowBox[{
    StyleBox["x", "TI"], ",", 
    StyleBox["y", "TI"], ",", 
    StyleBox["z", "TI"]}], 
   StyleBox[")",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "bf7fdd0d-d69f-4be1-9458-cf148514937e"],
 ":"
}], "Text",ExpressionUUID->"406f5aff-a05f-47f8-8c70-eb0e91db98c5"],

Cell[BoxData[{
 RowBox[{"ClearAll", "[", 
  RowBox[{"x", ",", " ", "y", ",", " ", "z"}], "]"}], "\n", 
 RowBox[{
  RowBox[{"hessian", " ", "=", " ", "\n", "  ", 
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{"Grad", "[", 
       RowBox[{
        RowBox[{"Grad", "[", 
         RowBox[{"#", ",", " ", 
          RowBox[{"{", 
           RowBox[{"x", ",", " ", "y", ",", " ", "z"}], "}"}]}], "]"}], ",", 
        " ", 
        RowBox[{"{", 
         RowBox[{"x", ",", " ", "y", ",", " ", "z"}], "}"}]}], "]"}], " ", 
      "&"}], " ", "/@", " ", "\n", "    ", 
     RowBox[{"ToSphericalCoordinates", "[", 
      RowBox[{"{", 
       RowBox[{"x", ",", " ", "y", ",", " ", "z"}], "}"}], "]"}]}], " ", "//",
     " ", "FullSimplify"}]}], ";"}]}], "Input",
 CellLabel->
  "In[305]:= ",ExpressionUUID->"b10e7509-a848-4ac5-8986-6507add9a357"],

Cell["Dimensions of Hessian:", "Text",ExpressionUUID->"9b8a074f-6692-4b88-9afe-ee3070c0958f"],

Cell[BoxData[
 RowBox[{"Dimensions", "@", "hessian"}]], "Input",
 CellLabel->
  "In[306]:= ",ExpressionUUID->"fc4557ec-e0ba-4f3c-bae9-75eb4cd10ad6"],

Cell[TextData[{
 "Let\[CloseCurlyQuote]s write the Cartesian Bloch-vector SDE in compact It\
\[OHat] form as ",
 Cell[BoxData[
  RowBox[{
   StyleBox["d", "TI"], 
   StyleBox["r", "TI"], "=", 
   StyleBox["a", "TI"], 
   StyleBox["d", "TI"], 
   StyleBox["t", "TI"], "+", 
   StyleBox["b", "TI"], 
   StyleBox["d", "TI"], 
   SubscriptBox[
    StyleBox["W", "TI"], 
    StyleBox["t", "TI"]]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "10e394ff-c498-49ca-a537-3e882501ec2e"],
 " where ",
 Cell[BoxData[
  StyleBox["r", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "3480abc3-7b36-4ef7-928b-f32e07b6170e"],
 " is a 3\[Times]1 state vector, ",
 Cell[BoxData[
  StyleBox["a", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "a04f8273-68f2-4fbd-9fd4-ea1bf2c4e82e"],
 " is the 3\[Times]1 drift field, and ",
 Cell[BoxData[
  StyleBox["b", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "d55bb2b0-a4c7-4445-a1ac-a9155b2b2065"],
 " is the 3\[Times]1 diffusion field multiplying a single real Wiener \
increment ",
 Cell[BoxData[
  RowBox[{
   StyleBox["d", "TI"], 
   SubscriptBox[
    StyleBox["W", "TI"], 
    StyleBox["t", "TI"]]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "d64d6879-5079-4456-bf58-5b532728ff48"],
 ". Now introduce spherical coordinates through a smooth map ",
 Cell[BoxData[
  RowBox[{
   StyleBox["u", "TI"], " ", "=", " ", 
   StyleBox["f", "TI"], 
   StyleBox["(",
    SpanMaxSize->1], 
   StyleBox["r", "TI"], 
   StyleBox[")",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "d2b34042-2a93-4f38-89aa-bb759fc0091b"],
 ". The goal is to obtain an SDE directly for u(t) that is equivalent to the \
Cartesian one, but expressed in the new variables."
}], "Text",ExpressionUUID->"352214a6-3ae3-47c1-a942-637bf95a6289"],

Cell[TextData[{
 "Because the driving noise is Brownian, ",
 Cell[BoxData[
  RowBox[{
   StyleBox["u", "TI"], 
   StyleBox["(",
    SpanMaxSize->1], 
   StyleBox["t", "TI"], 
   StyleBox[")",
    SpanMaxSize->1], "=", 
   StyleBox["f", "TI"], 
   StyleBox["(",
    SpanMaxSize->1], 
   RowBox[{
    StyleBox["r", "TI"], 
    StyleBox["(",
     SpanMaxSize->1], 
    StyleBox["t", "TI"], 
    StyleBox[")",
     SpanMaxSize->1]}], 
   StyleBox[")",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "fb46d529-b95f-4384-9e0d-d355d748da1f"],
 " is itself an It\[OHat] process, and its differential is not given by the \
ordinary chain rule. Instead It\[OHat]\[CloseCurlyQuote]s lemma adds a \
second-order correction coming from the quadratic variation ",
 Cell[BoxData[
  RowBox[{
   StyleBox["d", "TI"], 
   SubsuperscriptBox[
    StyleBox["W", "TI"], 
    StyleBox["t", "TI"], "2"], "=", 
   StyleBox["d", "TI"], 
   StyleBox["t", "TI"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "c59d71dd-56b9-4f08-8ded-c2dc98871f97"],
 ". Concretely, the Jacobian \|01d4a5 is the 3\[Times]3 matrix of first \
derivatives, ",
 Cell[BoxData[
  RowBox[{
   SubscriptBox["\|01d4a5", 
    StyleBox[
     RowBox[{"i", "j"}], "TI"]], "=", "\[PartialD]", 
   SubscriptBox[
    StyleBox["f", "TI"], 
    StyleBox["i", "TI"]], "/", "\[PartialD]", 
   SubscriptBox[
    StyleBox["r", "TI"], 
    StyleBox["j", "TI"]]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "41f7b12b-6207-456a-b5c2-f5df2863ad8a"],
 ", and the Hessian \[ScriptCapitalH] is the 3\[Times]3\[Times]3 tensor of \
second derivatives, ",
 Cell[BoxData[
  RowBox[{
   SubscriptBox["\[ScriptCapitalH]", 
    StyleBox[
     RowBox[{"i", "j", "k"}], "TI"]], "=", 
   SuperscriptBox["\[PartialD]", "2"], 
   SubscriptBox[
    StyleBox["f", "TI"], 
    StyleBox["i", "TI"]], "/", "\[PartialD]", 
   SubscriptBox[
    StyleBox["r", "TI"], 
    StyleBox["j", "TI"]], "\[PartialD]", 
   SubscriptBox[
    StyleBox["r", "TI"], 
    StyleBox["k", "TI"]]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "38cd3d1a-3dcb-4cab-9714-275ebe0f759e"],
 ". It\[OHat]\[CloseCurlyQuote]s lemma then gives, componentwise, ",
 Cell[BoxData[
  RowBox[{
   RowBox[{
    StyleBox["d", "TI"], 
    SubscriptBox[
     StyleBox["u", "TI"], 
     StyleBox["i", "TI"]], " ", "=", " ", 
    StyleBox["(",
     SpanMaxSize->1], 
    RowBox[{"\[Del]", 
     SubscriptBox[
      StyleBox["f", "TI"], 
      StyleBox["i", "TI"]], " ", "\[CenterDot]", " ", 
     StyleBox["a", "TI"]}], 
    StyleBox[")",
     SpanMaxSize->1], " ", 
    StyleBox["d", "TI"], 
    StyleBox["t", "TI"], " ", "+", " ", 
    StyleBox["(",
     SpanMaxSize->1], 
    RowBox[{"\[Del]", 
     SubscriptBox[
      StyleBox["f", "TI"], 
      StyleBox["i", "TI"]], " ", "\[CenterDot]", " ", 
     StyleBox["b", "TI"]}], 
    StyleBox[")",
     SpanMaxSize->1], " ", 
    StyleBox["d", "TI"], 
    SubscriptBox[
     StyleBox["W", "TI"], 
     StyleBox["t", "TI"]], " ", "+", " ", "1", "/", "2", " ", 
    StyleBox["(",
     SpanMaxSize->1], 
    RowBox[{
     SuperscriptBox[
      StyleBox["b", "TI"], 
      StyleBox["T", "TI"]], " ", 
     SubscriptBox["\[ScriptCapitalH]", 
      StyleBox["i", "TI"]], " ", 
     StyleBox["b", "TI"]}], 
    StyleBox[")",
     SpanMaxSize->1], " ", 
    StyleBox["d", "TI"], 
    StyleBox["t", "TI"]}], "."}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "04b4aa6d-9c01-4e02-9079-fccc474dc958"],
 " This shows exactly how the drift changes: it is the Jacobian acting on the \
original drift plus an extra term that depends on the curvature of the \
coordinate map and on the diffusion direction ",
 Cell[BoxData[
  StyleBox["b", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "a77dcf69-967d-4c5a-9141-d6a0a64a8fcb"],
 ". That extra ",
 Cell[BoxData[
  RowBox[{"1", "/", "2", " ", 
   StyleBox["(",
    SpanMaxSize->1], 
   RowBox[{
    SuperscriptBox[
     StyleBox["b", "TI"], 
     StyleBox["T", "TI"]], " ", 
    SubscriptBox["\[ScriptCapitalH]", 
     StyleBox["i", "TI"]], " ", 
    StyleBox["b", "TI"]}], 
   StyleBox[")",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "a97e7300-c5e9-410f-b6d3-3c785a966852"],
 " term is the It\[OHat] correction; it is zero only when ",
 Cell[BoxData[
  StyleBox["f", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "b7a7d310-252d-4ff0-bea1-480defa8c4dc"],
 " is linear, and it is the price paid for expressing multiplicative noise in \
curved coordinates."
}], "Text",ExpressionUUID->"9d4534e3-91be-4a3b-9fb5-42e59a566308"],

Cell[TextData[{
 "Packing the three components together yields ",
 Cell[BoxData[
  RowBox[{
   RowBox[{
    StyleBox["b", "TI"], "\[Rule]", "\|01d4a5"}], ".", 
   StyleBox["b", "TI"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "9ec22e05-fcbf-40bf-8cbb-98eca9aac195"],
 ", because diffusion transforms like the first derivative; likewise, the new \
drift is ",
 Cell[BoxData[
  RowBox[{
   RowBox[{
    StyleBox["a", "TI"], "\[Rule]", "\|01d4a5"}], ".", 
   RowBox[{
    StyleBox["a", "TI"], "+", "1", "/", "2", 
    SuperscriptBox[
     StyleBox["b", "TI"], 
     StyleBox["T", "TI"]]}], ".", 
   SuperscriptBox["\[ScriptCapitalH]", 
    StyleBox["T", "TI"]], ".", 
   StyleBox["b", "TI"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "7e004a54-9fc1-4e81-bf9d-e67a32c2b09e"],
 ". In this measurement-driven Bloch dynamics, this correction is not a \
cosmetic detail: it is what prevents you from applying naive calculus and \
getting the wrong deterministic terms in ",
 Cell[BoxData[
  RowBox[{
   RowBox[{"{", 
    StyleBox["r", "TI"]}], ",", 
   StyleBox["\[Theta]", "TI"], ",", 
   RowBox[{"\[CurlyPhi]", "}"}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "e80f6b7d-9455-474c-aeae-16751a915323"],
 ", and it can materially affect whether the transformed SDE respects the \
intended geometry of the state space under discretization."
}], "Text",ExpressionUUID->"dead6148-ce40-42d2-be87-49e89dc2e2a1"],

Cell[TextData[{
 "Implement the transformations ",
 Cell[BoxData[
  RowBox[{
   RowBox[{
    StyleBox["a", "TI"], "\[Rule]", "\|01d4a5"}], ".", 
   RowBox[{
    StyleBox["a", "TI"], "+", "1", "/", "2", 
    SuperscriptBox[
     StyleBox["b", "TI"], 
     StyleBox["T", "TI"]]}], ".", 
   SuperscriptBox["\[ScriptCapitalH]", 
    StyleBox["T", "TI"]], ".", 
   StyleBox["b", "TI"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "dc44e7bc-c20f-4806-94f5-93e90c8e6c63"],
 " and ",
 Cell[BoxData[
  RowBox[{
   RowBox[{
    StyleBox["b", "TI"], "\[Rule]", "\|01d4a5"}], ".", 
   StyleBox["b", "TI"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "7442c8ff-0e1f-457f-a56b-c568f0283883"],
 ":"
}], "Text",ExpressionUUID->"11e0b02a-19a8-403b-a8fb-907db085b3a3"],

Cell[BoxData[
 RowBox[{
  RowBox[{"newABForIto", " ", "=", " ", "\n", "  ", 
   RowBox[{"FullSimplify", "[", "\n", "   ", 
    RowBox[{
     RowBox[{
      RowBox[{"With", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{
          RowBox[{"a", " ", "=", " ", "nonRandomTermsCollapseSDE"}], ",", " ",
           "\n", "      ", 
          RowBox[{"b", " ", "=", " ", "randomTermsCollapseSDE"}]}], "}"}], ",",
         " ", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{
           RowBox[{"jacobian", " ", ".", " ", "a"}], " ", "+", " ", "\n", 
           "       ", 
           RowBox[{
            RowBox[{
             RowBox[{"Transpose", "[", "b", "]"}], " ", ".", " ", 
             RowBox[{"Transpose", "[", "hessian", "]"}], " ", ".", " ", "b"}],
             "/", "2"}]}], ",", " ", 
          RowBox[{"jacobian", " ", ".", " ", "b"}]}], "}"}]}], "]"}], " ", "/.",
       " ", "\n", "    ", 
      RowBox[{"Thread", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"x", ",", " ", "y", ",", " ", "z"}], "}"}], " ", "->", " ", 
        RowBox[{"FromSphericalCoordinates", "[", 
         RowBox[{"{", 
          RowBox[{"r", ",", " ", "\[Theta]", ",", " ", "\[Phi]"}], "}"}], 
         "]"}]}], "]"}]}], ",", "\n", "    ", 
     RowBox[{
      RowBox[{"0", " ", "<=", " ", "r", " ", "<=", " ", "1"}], " ", "&&", " ", 
      RowBox[{"0", " ", "<=", " ", "\[Theta]", " ", "<=", " ", "\[Pi]"}], " ",
       "&&", " ", 
      RowBox[{"0", " ", "<=", " ", "\[Phi]", " ", "<=", " ", 
       RowBox[{"2", " ", "\[Pi]"}]}]}]}], "]"}]}], ";"}]], "Input",
 CellLabel->
  "In[307]:= ",ExpressionUUID->"5f39fc29-8da6-4f85-a443-6f4a716d4e20"],

Cell["\<\
Use the result to obtain the It\[OHat]-form SDE for the spherical coordinates:\
\>", "Text",ExpressionUUID->"62f6b7e2-d376-42a5-849f-38945d6d4ae9"],

Cell[BoxData[
 RowBox[{"\[Rho]CollapseSDESpherical", " ", "=", " ", "\n", " ", 
  RowBox[{"ItoProcess", "[", "\n", "  ", 
   RowBox[{"newABForIto", ",", " ", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"r", ",", " ", "\[Theta]", ",", " ", "\[Phi]"}], "}"}], ",", 
      " ", 
      RowBox[{"{", 
       RowBox[{"r0", ",", " ", "\[Theta]0", ",", " ", "\[Phi]0"}], "}"}]}], 
     "}"}], ",", " ", "t"}], "]"}]}]], "Input",
 CellLabel->
  "In[308]:= ",ExpressionUUID->"266dbaf9-1694-4542-8a03-bc20cac8de8d"],

Cell["Check if the new process is a valid random process:", "Text",ExpressionUUID->"6b160b40-760b-4df5-8683-fcbe363673b2"],

Cell[BoxData[
 RowBox[{"\[Rho]CollapseSDESpherical", " ", "//", " ", 
  "ProcessParameterQ"}]], "Input",
 CellLabel->
  "In[309]:= ",ExpressionUUID->"557ea69d-50ee-4aa1-b0da-34373594b3db"],

Cell[TextData[{
 "Therefore, the It\[OHat]-form SDE for the spherical coordinates reads as:  ",
 Cell[BoxData[
  RowBox[{
   RowBox[{
    StyleBox["(",
     SpanMaxSize->1], " ", GridBox[{
      {
       StyleBox[
        RowBox[{"d", "r"}], "TI"]},
      {
       StyleBox[
        RowBox[{"d", "\[Theta]"}], "TI"]},
      {
       StyleBox[
        RowBox[{"d", "\[Phi]"}], "TI"]}
     }], " ", 
    StyleBox[")",
     SpanMaxSize->1]}], "=", 
   RowBox[{
    RowBox[{
     RowBox[{
      StyleBox["(",
       SpanMaxSize->1], " ", GridBox[{
        {
         RowBox[{"-", "2", " ", 
          StyleBox["\[Gamma]", "TI"], " ", 
          StyleBox["(",
           SpanMaxSize->1], 
          RowBox[{
           SuperscriptBox[
            StyleBox["r", "TI"], "2"], "-", "1"}], 
          StyleBox[")",
           SpanMaxSize->1], " ", 
          StyleBox["s", "TI"], 
          StyleBox["i", "TI"], 
          SuperscriptBox[
           StyleBox["n", "TI"], "2"], 
          StyleBox["(",
           SpanMaxSize->1], 
          StyleBox["\[Theta]", "TI"], 
          StyleBox[")",
           SpanMaxSize->1], "/", 
          StyleBox["r", "TI"]}]},
        {
         RowBox[{
          StyleBox["\[Gamma]", "TI"], " ", 
          StyleBox["(",
           SpanMaxSize->1], 
          RowBox[{"2", "/", 
           SuperscriptBox[
            StyleBox["r", "TI"], "2"], "-", "3"}], 
          StyleBox[")",
           SpanMaxSize->1], " ", 
          StyleBox["s", "TI"], 
          StyleBox["i", "TI"], 
          StyleBox["n", "TI"], 
          StyleBox["(",
           SpanMaxSize->1], 
          RowBox[{"2", " ", 
           StyleBox["\[Theta]", "TI"]}], 
          StyleBox[")",
           SpanMaxSize->1], "-", 
          SubscriptBox[
           StyleBox["\[Omega]", "TI"], 
           StyleBox["x", "TI"]], " ", 
          StyleBox["s", "TI"], 
          StyleBox["i", "TI"], 
          StyleBox["n", "TI"], 
          StyleBox["(",
           SpanMaxSize->1], 
          StyleBox["\[Phi]", "TI"], 
          StyleBox[")",
           SpanMaxSize->1]}]},
        {
         RowBox[{"-", 
          SubscriptBox[
           StyleBox["\[Omega]", "TI"], 
           StyleBox["x", "TI"]], " ", 
          StyleBox["c", "TI"], 
          StyleBox["o", "TI"], 
          StyleBox["t", "TI"], 
          StyleBox["(",
           SpanMaxSize->1], 
          StyleBox["\[Theta]", "TI"], 
          StyleBox[")",
           SpanMaxSize->1], " ", 
          StyleBox["c", "TI"], 
          StyleBox["o", "TI"], 
          StyleBox["s", "TI"], 
          StyleBox["(",
           SpanMaxSize->1], 
          StyleBox["\[Phi]", "TI"], 
          StyleBox[")",
           SpanMaxSize->1]}]}
       }], " ", 
      StyleBox[")",
       SpanMaxSize->1]}], 
     StyleBox["d", "TI"], 
     StyleBox["t", "TI"]}], "+", 
    RowBox[{
     RowBox[{
      StyleBox["(",
       SpanMaxSize->1], " ", GridBox[{
        {
         RowBox[{"-", "2", " ", 
          SqrtBox[
           StyleBox["\[Gamma]", "TI"]], " ", 
          StyleBox["(",
           SpanMaxSize->1], 
          RowBox[{
           SuperscriptBox[
            StyleBox["r", "TI"], "2"], "-", "1"}], 
          StyleBox[")",
           SpanMaxSize->1], " ", 
          StyleBox["c", "TI"], 
          StyleBox["o", "TI"], 
          StyleBox["s", "TI"], 
          StyleBox["(",
           SpanMaxSize->1], 
          StyleBox["\[Theta]", "TI"], 
          StyleBox[")",
           SpanMaxSize->1]}]},
        {
         RowBox[{"-", "2", " ", 
          SqrtBox[
           StyleBox["\[Gamma]", "TI"]], " ", 
          StyleBox["s", "TI"], 
          StyleBox["i", "TI"], 
          StyleBox["n", "TI"], 
          StyleBox["(",
           SpanMaxSize->1], 
          StyleBox["\[Theta]", "TI"], 
          StyleBox[")",
           SpanMaxSize->1], "/", 
          StyleBox["r", "TI"]}]},
        {"0"}
       }], " ", 
      StyleBox[")",
       SpanMaxSize->1]}], 
     StyleBox["d", "TI"], 
     SubscriptBox[
      StyleBox["W", "TI"], 
      StyleBox["t", "TI"]]}]}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "76235e0f-4bed-4ff0-9240-d89832e30d53"],
 ". In this SDE, gamma sets how fast information about the Pauli-Z eigenvalue \
is acquired, and ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["\[Omega]", "TI"], 
   StyleBox["x", "TI"]]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "53f27387-44c2-4e0f-93c4-230140121315"],
 " sets how fast the Hamiltonian tries to rotate population out of the \
Pauli-Z eigenbasis. The competition is controlled almost entirely by the \
dimensionless ratio ",
 Cell[BoxData[
  RowBox[{
   SubscriptBox[
    StyleBox["\[Omega]", "TI"], 
    StyleBox["x", "TI"]], "/", 
   StyleBox["\[Gamma]", "TI"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "42fbd8a3-05fa-4b55-bfa9-804108886e6d"],
 ". When \[Gamma] dominates (",
 Cell[BoxData[
  RowBox[{
   StyleBox["\[Gamma]", "TI"], "\[GreaterGreater]", 
   SubscriptBox[
    StyleBox["\[Omega]", "TI"], 
    StyleBox["x", "TI"]]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "e7b393b4-8351-4fb3-8e52-623fe3aaa811"],
 "), the measurement rapidly purifies and localizes the state. This is \
already visible directly in ",
 Cell[BoxData[
  StyleBox[
   RowBox[{"d", "r"}], "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "5d1ad3e3-354f-4a78-8d43-26a57d31b7d0"],
 " equation because every term is multiplied by ",
 Cell[BoxData[
  RowBox[{
   SuperscriptBox[
    StyleBox["r", "TI"], "2"], "-", "1"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "57e83066-3652-413e-b025-7b9542147bae"],
 ": when ",
 Cell[BoxData[
  RowBox[{
   StyleBox["r", "TI"], "=", "1"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "f5add688-4e30-4a36-a29f-2276a987d2c1"],
 " the radius is frozen (pure states stay pure), while for ",
 Cell[BoxData[
  RowBox[{
   StyleBox["r", "TI"], "<", "1"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "0c49a104-438d-4a31-9eec-2cc1c8afaf87"],
 " the dynamics drives ",
 Cell[BoxData[
  StyleBox["r", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "724c3f61-2669-4bff-84ab-1f601a76c143"],
 " upward toward 1 on a timescale set by ",
 Cell[BoxData[
  RowBox[{"1", "/", 
   StyleBox["\[Gamma]", "TI"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "e38fcc17-708a-4fe9-8ed6-a4d2340bcd14"],
 ". At the same time, the angular dynamics pushes theta toward 0 or \[Pi], \
meaning the state localizes near the measurement eigenstates ",
 Cell[BoxData[
  RowBox[{
   StyleBox["z", "TI"], "\[TildeTilde]", "+", "1"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "cad85968-a2d3-43ff-97b6-ae60c6333351"],
 " or ",
 Cell[BoxData[
  RowBox[{
   StyleBox["z", "TI"], "\[TildeTilde]", "-", "1"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "ba209dae-bc66-4593-a2b8-2e18393eb65e"],
 ". Once it is near a pole, the stochastic term in ",
 Cell[BoxData[
  StyleBox[
   RowBox[{"d", "\[Theta]"}], "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "32bd37cb-3704-42a8-94b1-85a43f5730b6"],
 " becomes weak because it is proportional to ",
 Cell[BoxData[
  RowBox[{
   StyleBox["s", "TI"], 
   StyleBox["i", "TI"], 
   StyleBox["n", "TI"], 
   StyleBox["(",
    SpanMaxSize->1], 
   StyleBox["\[Theta]", "TI"], 
   StyleBox[")",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "ddc8bc17-9faa-414b-91e8-ca124549db50"],
 ", so the poles are effectively stable endpoints: that is what \
\[OpenCurlyDoubleQuote]collapse\[CloseCurlyDoubleQuote] looks like in single \
trajectories, long plateaus near ",
 Cell[BoxData[
  RowBox[{
   StyleBox["z", "TI"], "=", "\[PlusMinus]", "1"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "69e59af1-5445-4b07-a79f-129905ef3322"],
 " after a short transient."
}], "Text",ExpressionUUID->"807592d3-022d-4bd5-b1c1-d98c54fd6027"],

Cell[TextData[{
 "Set the parameters for the random process in the strong-measurement regime \
(",
 Cell[BoxData[
  RowBox[{
   StyleBox["\[Gamma]", "TI"], "\[GreaterGreater]", 
   SubscriptBox[
    StyleBox["\[Omega]", "TI"], 
    StyleBox["x", "TI"]]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "bb8e6aa1-72a1-4bdf-a164-5aea4abe67ba"],
 "):"
}], "Text",ExpressionUUID->"7f661aa2-014a-4984-921a-9a0f410bc27e"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"\[CapitalOmega]", " ", "=", " ", "0.3"}], ";"}], 
  RowBox[{"(*", 
   RowBox[{
   "to", " ", "set", " ", "the", " ", "value", " ", "of", " ", "\[Omega]x"}], 
   "*)"}]}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"\[CapitalGamma]", " ", "=", " ", "1"}], ";"}], 
  RowBox[{"(*", 
   RowBox[{
   "to", " ", "set", " ", "the", " ", "value", " ", "of", " ", "\[Gamma]"}], 
   "*)"}]}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"initialRThetaPhi", " ", "=", " ", 
    RowBox[{"{", 
     RowBox[{"1", ",", " ", 
      RowBox[{"\[Pi]", "/", "3"}], ",", " ", 
      RowBox[{"\[Pi]", "/", "\n", "    ", "3"}]}], "}"}]}], ";"}], 
  RowBox[{"(*", 
   RowBox[{
   "initial", " ", "spherical", " ", "coordiante", " ", "of", " ", "Bloch", " ",
     "vector"}], "*)"}]}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"tf", " ", "=", " ", "3"}], ";"}], 
  RowBox[{"(*", 
   RowBox[{"time", " ", "duration", " ", "of", " ", "simulation"}], 
   "*)"}]}]}], "Input",
 CellLabel->
  "In[310]:= ",ExpressionUUID->"4661b063-1f95-4239-9c9f-53d79f8bb312"],

Cell["\<\
Generate 100 different realization (trajectories) of the random process:\
\>", "Text",ExpressionUUID->"23222083-0296-47c7-9939-7876fad8655e"],

Cell[BoxData[
 RowBox[{"trajectoriesCollapseSpherical", " ", "=", " ", "\n", " ", 
  RowBox[{"RandomFunction", "[", 
   RowBox[{
    RowBox[{"\[Rho]CollapseSDESpherical", " ", "/.", " ", "\n", "   ", 
     RowBox[{"Join", "[", 
      RowBox[{
       RowBox[{"Thread", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"\[Omega]x", ",", " ", "\[Gamma]"}], "}"}], " ", "->", " ", 
         
         RowBox[{"{", 
          RowBox[{"\[CapitalOmega]", ",", " ", 
           RowBox[{"\\\n", "\[CapitalGamma]"}]}], "}"}]}], "]"}], ",", " ", 
       "\n", "    ", 
       RowBox[{"Thread", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"r0", ",", " ", "\[Theta]0", ",", " ", "\[Phi]0"}], "}"}], 
         " ", "->", " ", "initialRThetaPhi"}], "]"}]}], "]"}]}], ",", " ", 
    RowBox[{"{", 
     RowBox[{"0", ",", " ", "tf", ",", " ", "\n", "   ", 
      RowBox[{"tf", "/", "1000"}]}], "}"}], ",", " ", "100"}], 
   "]"}]}]], "Input",
 CellLabel->
  "In[311]:= ",ExpressionUUID->"900bf3fc-c891-4667-b828-99809a2d949c"],

Cell[TextData[{
 "Recall quantum probabilities are given by ",
 Cell[BoxData[
  RowBox[{
   StyleBox["T", "TI"], 
   StyleBox["r", "TI"], 
   RowBox[{"(", 
    RowBox[{
     TemplateBox[{
       StyleBox["n", "TI"]},
      "Ket"], 
     TemplateBox[{
       StyleBox["n", "TI"]},
      "Bra"], 
     StyleBox["\[Rho]", "TI"]}], ")"}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "fb04332b-e458-47d1-a43e-3abfe17ab7c7"],
 ". Calculate them for ",
 Cell[BoxData[
  TemplateBox[{"0"},
   "Ket"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "e3e3133c-719e-4f0c-bd4b-f1e3b797af7f"],
 " and ",
 Cell[BoxData[
  TemplateBox[{"1"},
   "Ket"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "e6129a1c-d159-49fb-95dc-5fb05bb11b01"],
 ":"
}], "Text",ExpressionUUID->"32f93d6a-4ad3-46b3-90f6-15c39a80a6f4"],

Cell[BoxData[
 RowBox[{"AssociationThread", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"\"\<\\!\\(\\*SubscriptBox[\\(p\\), \\(0\\)]\\)\>\"", ",", " ", 
     "\n", "  ", "\"\<\\!\\(\\*SubscriptBox[\\(p\\), \\(1\\)]\\)\>\""}], 
    "}"}], ",", " ", "\n", " ", 
   RowBox[{
    RowBox[{
     RowBox[{"Tr", "[", 
      RowBox[{"#", " ", ".", " ", 
       RowBox[{"DensityMatrix", "[", "\n", "      ", 
        RowBox[{"FromSphericalCoordinates", "@", "initialRThetaPhi"}], 
        "]"}]}], "]"}], " ", "&"}], " ", "/@", " ", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"1", ",", " ", "0"}], "}"}], ",", " ", 
        RowBox[{"{", 
         RowBox[{"0", ",", " ", "\n", "     ", "0"}], "}"}]}], "}"}], ",", 
      " ", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"0", ",", " ", "0"}], "}"}], ",", " ", 
        RowBox[{"{", 
         RowBox[{"0", ",", " ", "1"}], "}"}]}], "}"}]}], "}"}]}]}], 
  "]"}]], "Input",
 CellLabel->
  "In[312]:= ",ExpressionUUID->"63de91ba-d64e-4b5b-ad34-a58609320283"],

Cell[BoxData[
 RowBox[{"AssociationThread", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"\"\<\\!\\(\\*SubscriptBox[\\(p\\), \\(0\\)]\\)\>\"", ",", " ", 
     "\n", "  ", "\"\<\\!\\(\\*SubscriptBox[\\(p\\), \\(1\\)]\\)\>\""}], 
    "}"}], ",", " ", "\n", " ", 
   RowBox[{
    RowBox[{
     RowBox[{"Tr", "[", 
      RowBox[{"#", " ", ".", " ", 
       RowBox[{"DensityMatrix", "[", "\n", "      ", 
        RowBox[{"FromSphericalCoordinates", "@", 
         RowBox[{"{", 
          RowBox[{"r", ",", " ", "\[Theta]", ",", " ", "\[Phi]"}], "}"}]}], 
        "]"}]}], "]"}], " ", "&"}], " ", "/@", " ", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"1", ",", " ", "\n", "     ", "0"}], "}"}], ",", " ", 
        RowBox[{"{", 
         RowBox[{"0", ",", " ", "0"}], "}"}]}], "}"}], ",", " ", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"0", ",", " ", "0"}], "}"}], ",", " ", 
        RowBox[{"{", 
         RowBox[{"0", ",", " ", "1"}], "}"}]}], "}"}]}], "}"}]}]}], 
  "]"}]], "Input",
 CellLabel->
  "In[313]:= ",ExpressionUUID->"6d50d2a2-5781-4f41-bacf-03e399dbf66c"],

Cell["Given 100 different realization, compute Bloch trajectories:", "Text",ExpressionUUID->"e9e6a752-7b2a-4030-92ea-e40238606f47"],

Cell[BoxData[
 RowBox[{
  RowBox[{"blochVectorTrajectoriesCollapse", " ", "=", " ", "\n", "  ", 
   RowBox[{"MapAt", "[", 
    RowBox[{
     RowBox[{"Apply", "[", 
      RowBox[{
       RowBox[{"#1", " ", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{
           RowBox[{"Cos", "[", "#3", "]"}], " ", 
           RowBox[{"Sin", "[", "#2", "]"}]}], ",", " ", 
          RowBox[{
           RowBox[{"Sin", "[", "#3", "]"}], " ", 
           RowBox[{"Sin", "[", "#2", "]"}]}], ",", " ", 
          RowBox[{"Cos", "[", "#2", "]"}]}], "}"}]}], " ", "&"}], "]"}], ",", 
     " ", "\n", "   ", 
     RowBox[{"trajectoriesCollapseSpherical", "[", "\"\<ValueList\>\"", "]"}],
      ",", " ", 
     RowBox[{"{", 
      RowBox[{"All", ",", " ", "All"}], "}"}]}], "]"}]}], ";"}]], "Input",
 CellLabel->
  "In[314]:= ",ExpressionUUID->"36c983dd-868f-42f3-b986-465ef08fcf3a"],

Cell[TextData[{
 "Given the population of ",
 Cell[BoxData[
  TemplateBox[{"0"},
   "Ket"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "bdced851-5b34-4e47-8f43-bfdf37cbd393"],
 " which is ",
 Cell[BoxData[
  RowBox[{"1", "/", "2", 
   StyleBox["(",
    SpanMaxSize->1], 
   RowBox[{"1", "+", 
    StyleBox["z", "TI"], 
    StyleBox["(",
     SpanMaxSize->1], 
    StyleBox["t", "TI"], 
    StyleBox[")",
     SpanMaxSize->1]}], 
   StyleBox[")",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "958611e2-f86a-4ab0-8144-8d4d38ca4beb"],
 " with ",
 Cell[BoxData[
  RowBox[{
   StyleBox["z", "TI"], 
   StyleBox["(",
    SpanMaxSize->1], 
   StyleBox["t", "TI"], 
   StyleBox[")",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "63b1c1f8-5641-4c70-9e0b-f296c7d4be32"],
 " the z-component of Bloch vector, visualize it for a few trajectories:"
}], "Text",ExpressionUUID->"65fe93e4-6b47-4548-94da-32c4fa8cb4ed"],

Cell[BoxData[
 RowBox[{"ListLinePlot", "[", 
  RowBox[{
   RowBox[{
    RowBox[{"(", 
     RowBox[{"1", " ", "+", " ", 
      RowBox[{"blochVectorTrajectoriesCollapse", "[", 
       RowBox[{"[", 
        RowBox[{
         RowBox[{";;", " ", "50"}], ",", " ", "All", ",", " ", "3"}], "]"}], 
       "]"}]}], ")"}], "/", "2"}], ",", "\n", "  ", 
   RowBox[{"PlotRange", " ", "->", " ", 
    RowBox[{"{", 
     RowBox[{"0", ",", " ", "1"}], "}"}]}], ",", " ", 
   RowBox[{"AspectRatio", " ", "->", " ", 
    RowBox[{"1", "/", "2"}]}], ",", " ", 
   RowBox[{"Frame", " ", "->", " ", "True"}], ",", " ", "\n", " ", 
   RowBox[{"GridLines", " ", "->", " ", "Automatic"}], ",", " ", 
   RowBox[{"PlotStyle", " ", "->", " ", "Thin"}], ",", " ", 
   RowBox[{"DataRange", " ", "->", " ", 
    RowBox[{"{", 
     RowBox[{"0", ",", " ", "tf"}], "}"}]}], ",", " ", "\n", " ", 
   RowBox[{"FrameLabel", " ", "->", " ", 
    RowBox[{"{", 
     RowBox[{"\"\<Time\>\"", ",", " ", "\n", 
      "   ", "\"\<Population of \\!\\(\\*TemplateBox[{\\\"0\\\"},\n\
\\\"Ket\\\"]\\)\>\""}], "}"}]}], ",", " ", "\n", " ", 
   RowBox[{
   "PlotLabel", " ", "->", " ", "\n", 
    "  ", "\"\<Population of \\!\\(\\*TemplateBox[{\\\"0\\\"},\n\
\\\"Ket\\\"]\\) vs time for different trajectories\>\""}]}], "]"}]], "Input",
 CellLabel->
  "In[315]:= ",ExpressionUUID->"82b513ac-4d95-491c-816a-9ad9dd4cce04"],

Cell[TextData[{
 "After a time of order ",
 Cell[BoxData[
  RowBox[{"1", "/", 
   StyleBox["\[Gamma]", "TI"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "387fe26f-5a8f-4a49-ae14-ac4b90a6f8c6"],
 ", you can clearly see a \[OpenCurlyDoubleQuote]collapse-to-eigenstates\
\[CloseCurlyDoubleQuote] behavior: for each realization, the population in \
the ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["\[Sigma]", "TI"], 
   StyleBox["z", "TI"]]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "687d0c7d-eb25-463d-bf87-8024f93bdb10"],
 " eigenbasis tends toward either 0 or 1. In the visualization above, we have \
plotted the population of the state ",
 Cell[BoxData[
  TemplateBox[{"0"},
   "Ket"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "4e2a40e9-24cc-4a25-8220-74eafc4afd47"],
 " for a few individual trajectories, showing how each one eventually gets \
pinned close to 0 or close to 1. But why is this random \
\[OpenCurlyDoubleQuote]choice\[CloseCurlyDoubleQuote] consistent with the \
Born rule? The martingale connection is the clean mathematical way to see it. \
Let\[CloseCurlyQuote]s check that: after a time of order 1/\[Gamma], the \
statistics of the outcomes match the expected quantum probabilities. \
Concretely, we can take a large ensemble of realizations and, at various \
times, plot the histogram of the z component of the Bloch vector. This tells \
us how often the qubit ends up near the north pole (state ",
 Cell[BoxData[
  TemplateBox[{"0"},
   "Ket"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "40a04938-401e-4c8c-8339-5dc8706eae7c"],
 ") or the south pole (state ",
 Cell[BoxData[
  TemplateBox[{"1"},
   "Ket"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "723d972c-34c7-4c44-aca5-495d6175d380"],
 "). The expected behavior is that, after waiting long enough (but not too \
long if ",
 Cell[BoxData[
  RowBox[{
   StyleBox["H", "TI"], "\[NotEqual]", "0"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "0f78ae89-5f14-40ca-ac61-ad7df60770b4"],
 "), this histogram approaches the distribution predicted by the initial \
quantum probabilities."
}], "Text",ExpressionUUID->"9b1d8309-6bc3-49f2-a959-0aef7c2fd8b9"],

Cell["\<\
For all simulated trajectories (ensemble), extract the z-component of the \
Bloch vector at a chosen time and plot its histogram:\
\>", "Text",ExpressionUUID->"d3cde06f-6c2e-4856-ba5a-b235a2ab5149"],

Cell[BoxData[
 RowBox[{
  RowBox[{"histogramOfResults", " ", "=", " ", "\n", "  ", 
   RowBox[{"MapIndexed", "[", "\n", "   ", 
    RowBox[{
     RowBox[{
      RowBox[{"Histogram", "[", 
       RowBox[{
       "#1", ",", " ", "10", ",", " ", "\"\<Probability\>\"", ",", " ", 
        RowBox[{"PlotRange", " ", "->", " ", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{
             RowBox[{"-", "1"}], ",", " ", "1"}], "}"}], ",", " ", 
           RowBox[{"{", 
            RowBox[{"0", ",", " ", "1"}], "}"}]}], "}"}]}], ",", " ", "\n", 
        "     ", 
        RowBox[{"AxesOrigin", " ", "->", " ", 
         RowBox[{"{", 
          RowBox[{"0", ",", " ", "0"}], "}"}]}], ",", " ", 
        RowBox[{"GridLines", " ", "->", " ", 
         RowBox[{"{", 
          RowBox[{"Automatic", ",", " ", 
           RowBox[{"{", 
            RowBox[{
             RowBox[{"3", "/", "4"}], ",", " ", 
             RowBox[{"1", "/", "4"}]}], "}"}]}], "}"}]}], ",", " ", "\n", 
        "     ", 
        RowBox[{"AspectRatio", " ", "->", " ", 
         RowBox[{"1", "/", "2"}]}], ",", " ", "\n", "     ", 
        RowBox[{"PlotLabel", " ", "->", " ", "\n", "      ", 
         RowBox[{"\"\<Histogram of z-component of\n Bloch vector at time \>\"",
           " ", "<>", " ", "\n", "       ", 
          RowBox[{"ToString", "[", 
           RowBox[{"0.002", " ", 
            RowBox[{"#2", "[", 
             RowBox[{"[", "1", "]"}], "]"}]}], "]"}], " ", "<>", 
          " ", "\"\</\[Gamma]\>\""}]}], ",", " ", 
        RowBox[{"ImageSize", " ", "->", " ", "Small"}]}], "]"}], " ", "&"}], ",",
      " ", "\n", "   ", 
     RowBox[{"Transpose", "[", 
      RowBox[{"blochVectorTrajectoriesCollapse", "[", 
       RowBox[{"[", 
        RowBox[{"All", ",", " ", "All", ",", " ", "3"}], "]"}], "]"}], 
      "]"}]}], "]"}]}], ";"}]], "Input",
 CellLabel->
  "In[316]:= ",ExpressionUUID->"cd989d4a-1538-472d-9eb4-f70c1cffdebf"],

Cell["Visualize histograms:", "Text",ExpressionUUID->"da36d303-d00e-492e-be21-04c90ebd18ea"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
    RowBox[{"you", " ", "can", " ", "run", " ", "this", " ", "code"}], ",", 
    " ", 
    RowBox[{
    "but", " ", "it", " ", "works", " ", "good", " ", "locally", " ", "and", " ",
      "not", " ", "on", " ", "cloud"}]}], "*)"}], "\n", 
  RowBox[{"(*", 
   RowBox[{"ListAnimate", "[", 
    RowBox[{"histogramOfResults", ",", 
     RowBox[{"AnimationRunning", "->", "False"}]}], "]"}], "*)"}], "\n", 
  RowBox[{"(*", 
   RowBox[{
    RowBox[{
    "you", " ", "can", " ", "export", " ", "visualizations", " ", "into", " ",
      "a", " ", "GIF", " ", "and", " ", "then", " ", "pull", " ", "in", " ", 
     "the", " ", "GIF", " ", 
     RowBox[{"as", "\\\n", " ", "a"}], " ", "video"}], ",", " ", 
    RowBox[{
    "which", " ", "usually", " ", "works", " ", "better", " ", "for", " ", 
     "cloud"}]}], "*)"}], "\n", 
  RowBox[{"(*", 
   RowBox[{"Export", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"NotebookDirectory", "[", "]"}], 
      "<>", "\"\<histogram-SDE-collapse.GIF\>\""}], ",", 
     RowBox[{"\\\n", "histogramOfResults"}], ",", "\"\<GIF\>\""}], "]"}], 
   "*)"}], "\n", 
  RowBox[{
  "Video", "[", \
"\"\<https://www.wolframcloud.com/obj/246ac6c5-b0df-4ab5-bed3-4cc226d5e0bd\>\"\
", "]"}]}]], "Input",
 CellLabel->
  "In[317]:= ",ExpressionUUID->"e5a26a42-3de1-41ed-a4db-773ab9be1bf0"],

Cell[TextData[{
 "As expected, once the evolution time is of the order ",
 Cell[BoxData[
  RowBox[{"1", "/", 
   StyleBox["\[Gamma]", "TI"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "94fc508b-0471-45a1-b49a-8bb54d8e9648"],
 " or more, the frequencies observed in the ensemble histograms approach the \
quantum probabilities predicted from the initial state."
}], "Text",ExpressionUUID->"252042f5-591e-46ca-9ecc-46e6fc13368e"],

Cell[TextData[{
 "In that strong-measurement regime, the Hamiltonian ",
 Cell[BoxData[
  RowBox[{
   StyleBox["H", "TI"], "=", "1", "/", "2", 
   SubscriptBox[
    StyleBox["\[Omega]", "TI"], 
    StyleBox["x", "TI"]], 
   SubscriptBox[
    StyleBox["\[Sigma]", "TI"], 
    StyleBox["x", "TI"]]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "b0e8c7e2-eec7-442d-9c97-beb8d511df68"],
 " does not disappear, but it is Zeno-suppressed: instead of smoothly driving \
Rabi oscillations, it mostly produces rare transitions between the two \
collapsed poles. The qualitative picture is \[OpenCurlyDoubleQuote]stick near \
",
 Cell[BoxData[
  TemplateBox[{"0"},
   "Ket"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "8d263fef-6be6-41e6-bc4b-486ec4fe3b60"],
 " or ",
 Cell[BoxData[
  TemplateBox[{"1"},
   "Ket"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "30f60e79-8942-47e5-bf04-953096436ea5"],
 ", then occasionally switch,\[CloseCurlyDoubleQuote] and the switching \
becomes much rarer as \[Gamma] increases."
}], "Text",ExpressionUUID->"89acfc89-6a49-4bda-bc3a-e170b933ff9b"],

Cell[BoxData[
 RowBox[{
  RowBox[{"stickSwitch", " ", "=", " ", 
   RowBox[{"With", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"bs", " ", "=", " ", 
       RowBox[{
        RowBox[{"ResourceFunction", "[", "\"\<BlochSpherePlot\>\"", "]"}], "[",
         "]"}]}], "}"}], ",", " ", "\n", "   ", 
     RowBox[{
      RowBox[{
       RowBox[{"Show", "[", 
        RowBox[{"bs", ",", " ", "\n", "      ", 
         RowBox[{"Graphics3D", "[", "\n", "       ", 
          RowBox[{"Table", "[", 
           RowBox[{
            RowBox[{"{", 
             RowBox[{
              RowBox[{
               RowBox[{"ColorData", "[", "97", "]"}], "[", "j", "]"}], ",", 
              " ", "\n", "         ", 
              RowBox[{"Arrow", "@", 
               RowBox[{"Tube", "[", 
                RowBox[{
                 RowBox[{"{", 
                  RowBox[{
                   RowBox[{"{", 
                    RowBox[{"0", ",", " ", "0", ",", " ", "0"}], "}"}], ",", 
                   " ", 
                   RowBox[{"#", "[", 
                    RowBox[{"[", "j", "]"}], "]"}]}], "}"}], ",", " ", 
                 ".02"}], "]"}]}]}], "}"}], ",", " ", 
            RowBox[{"{", 
             RowBox[{"j", ",", " ", "30"}], "}"}]}], "]"}], "]"}], ",", " ", 
         "\n", "      ", 
         RowBox[{"ImageSize", " ", "->", " ", "Small"}], ",", " ", "\n", 
         "      ", 
         RowBox[{
         "PlotLabel", " ", "->", 
          " ", "\"\<Trajectories in Bloch Sphere\>\""}]}], "]"}], " ", "&"}], 
      " ", "/@", " ", "\n", "    ", 
      RowBox[{"Transpose", "[", 
       RowBox[{"blochVectorTrajectoriesCollapse", ",", " ", 
        RowBox[{"{", 
         RowBox[{"2", ",", " ", "1", ",", " ", "3"}], "}"}]}], "]"}]}]}], 
    "]"}]}], ";"}]], "Input",
 CellLabel->
  "In[318]:= ",ExpressionUUID->"6649eeaa-5b87-4c28-8e9f-c2d8b09279dd"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
    RowBox[{"you", " ", "can", " ", "run", " ", "this", " ", "code"}], ",", 
    " ", 
    RowBox[{
    "but", " ", "it", " ", "works", " ", "good", " ", "locally", " ", "and", " ",
      "not", " ", "on", " ", "cloud"}]}], "*)"}], "\n", 
  RowBox[{"(*", 
   RowBox[{"ListAnimate", "[", 
    RowBox[{"stickSwitch", ",", 
     RowBox[{"AnimationRunning", "->", "False"}]}], "]"}], "*)"}], "\n", 
  RowBox[{"(*", 
   RowBox[{
    RowBox[{
    "you", " ", "can", " ", "export", " ", "visualizations", " ", "into", " ",
      "a", " ", "GIF", " ", "and", " ", "then", " ", "pull", " ", "in", " ", 
     "the", " ", "GIF", " ", 
     RowBox[{"as", "\\\n", " ", "a"}], " ", "video"}], ",", " ", 
    RowBox[{
    "which", " ", "usually", " ", "works", " ", "better", " ", "for", " ", 
     "cloud"}]}], "*)"}], "\n", 
  RowBox[{"(*", 
   RowBox[{"Export", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"NotebookDirectory", "[", "]"}], 
      "<>", "\"\<stickSwitch-SDE-collapse.GIF\>\""}], ",", 
     RowBox[{"\\\n", "stickSwitch"}], ",", "\"\<GIF\>\""}], "]"}], "*)"}], 
  "\n", 
  RowBox[{
  "Video", "[", \
"\"\<https://www.wolframcloud.com/obj/c04bcfb5-3a1b-4ae2-817a-15c3cbe87674\>\"\
", "]"}]}]], "Input",
 CellLabel->
  "In[319]:= ",ExpressionUUID->"a5f8f02d-f9aa-40e8-a25e-58e131fcc3a2"],

Cell[TextData[{
 "As one can see in above video, in the strong-measurement regime, the \
measurement continually projects the state toward the z-eigenstates, so a \
trajectory quickly localizes near ",
 Cell[BoxData[
  TemplateBox[{"0"},
   "Ket"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "4075b39e-3d21-429d-bc88-33f356542146"],
 " or ",
 Cell[BoxData[
  TemplateBox[{"1"},
   "Ket"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "474f7041-d0a0-4a90-8780-14e3050328f4"],
 " and then sits there in a long plateau. The ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["\[Omega]", "TI"], 
   StyleBox["x", "TI"]]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "622eb94d-cbef-46c3-9123-a869b8e5e134"],
 "-drive still tries to rotate the state away from that pole, but any small \
coherent tilt it creates is immediately \[OpenCurlyDoubleQuote]noticed\
\[CloseCurlyDoubleQuote] by the measurement, whose backaction pulls the state \
back toward an eigenstate. That is the quantum Zeno effect: frequent \
measurement prevents coherent Rabi motion from developing (look at the video, \
and how Bloch vectors are giggle around poles).  A switch occurs only when \
the drive manages to build a small but nonzero admixture of the opposite \
eigenstate and, during that brief excursion, the noisy measurement record \
happens to accumulate in favor of the other outcome, after which the state \
rapidly re-localizes at the opposite pole (watch 00:50 in the video). Because \
strong measurement keeps the admixture tiny, such successful excursions are \
rare, so transitions look like sudden jumps between long plateaus."
}], "Text",ExpressionUUID->"948cd90c-75d4-4664-9667-9868b0a0f761"],

Cell[TextData[{
 "As mentioned before, the martingale connection is the clean mathematical \
way to see why the random \[OpenCurlyDoubleQuote]choice\
\[CloseCurlyDoubleQuote] toward state ",
 Cell[BoxData[
  TemplateBox[{"0"},
   "Ket"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "c8cc2cf0-c427-4cdd-9ec4-ee55c754b467"],
 " or ",
 Cell[BoxData[
  TemplateBox[{"1"},
   "Ket"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "55db6550-cc9e-49ea-b180-17289bc226a8"],
 " is consistent with the Born rule. It is worth being precise about what is \
and is not being shown: the diffusive measurement model already encodes the \
Born rule in the structure of its back-action term, so what follows is a \
self-consistency result, not a derivation of the Born rule from nothing. \
Here, probabilities wander randomly but they do not drift on average toward \
any outcome. Let\[CloseCurlyQuote]s show this explicitly. Recall that quantum \
probabilities, ",
 Cell[BoxData[
  RowBox[{
   SubscriptBox[
    StyleBox["p", "TI"], "0"], "=", 
   RowBox[{
    TemplateBox[{"0"},
     "Bra"], 
    StyleBox["\[Rho]", "TI"], 
    TemplateBox[{"0"},
     "Ket"]}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "523b0e42-bab2-47a3-b04d-f994666d7b77"],
 " and ",
 Cell[BoxData[
  RowBox[{
   SubscriptBox[
    StyleBox["p", "TI"], "1"], "=", 
   RowBox[{
    TemplateBox[{"1"},
     "Bra"], 
    StyleBox["\[Rho]", "TI"], 
    TemplateBox[{"1"},
     "Ket"]}]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "68e2e98b-3985-4e71-a8cb-8f0722dd075a"],
 ", are ",
 Cell[BoxData[
  RowBox[{"1", "/", "2", 
   StyleBox["(",
    SpanMaxSize->1], 
   RowBox[{"1", "\[PlusMinus]", 
    StyleBox["r", "TI"], " ", 
    StyleBox["c", "TI"], 
    StyleBox["o", "TI"], 
    StyleBox["s", "TI"], 
    StyleBox["(",
     SpanMaxSize->1], 
    StyleBox["\[Theta]", "TI"], 
    StyleBox[")",
     SpanMaxSize->1]}], 
   StyleBox[")",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "453b0654-9768-4db6-aa40-f2da78c4f3a5"],
 ". Given SDE for the spherical components of Bloch vector, one finds: ",
 Cell[BoxData[
  RowBox[{
   StyleBox["d", "TI"], 
   SubscriptBox[
    StyleBox["p", "TI"], "0"], "=", "1", "/", "2", 
   StyleBox["(",
    SpanMaxSize->1], 
   RowBox[{
    SubscriptBox[
     StyleBox["\[Omega]", "TI"], 
     StyleBox["x", "TI"]], 
    StyleBox["r", "TI"], " ", 
    StyleBox["s", "TI"], 
    StyleBox["i", "TI"], 
    StyleBox["n", "TI"], 
    StyleBox["(",
     SpanMaxSize->1], 
    StyleBox["\[Theta]", "TI"], 
    StyleBox[")",
     SpanMaxSize->1], 
    StyleBox["s", "TI"], 
    StyleBox["i", "TI"], 
    StyleBox["n", "TI"], 
    StyleBox["(",
     SpanMaxSize->1], 
    StyleBox["\[Phi]", "TI"], 
    StyleBox[")",
     SpanMaxSize->1], 
    StyleBox["d", "TI"], 
    StyleBox["t", "TI"], "+", "2", 
    SqrtBox[
     StyleBox["\[Gamma]", "TI"]], 
    StyleBox["(",
     SpanMaxSize->1], 
    RowBox[{"1", "-", 
     SuperscriptBox[
      StyleBox["z", "TI"], "2"]}], 
    StyleBox[")",
     SpanMaxSize->1], 
    StyleBox["d", "TI"], 
    SubscriptBox[
     StyleBox["W", "TI"], 
     StyleBox["t", "TI"]]}], 
   StyleBox[")",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "2e34f4b2-3334-461a-b679-f88c955f9167"],
 " and ",
 Cell[BoxData[
  RowBox[{
   StyleBox["d", "TI"], 
   SubscriptBox[
    StyleBox["p", "TI"], "1"], "=", "-", 
   StyleBox["d", "TI"], 
   SubscriptBox[
    StyleBox["p", "TI"], "0"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "720aa6ab-2518-4cd2-bce9-82d2590e40de"],
 ". The diffusion coefficient ",
 Cell[BoxData[
  RowBox[{"1", "-", 
   SuperscriptBox[
    StyleBox["z", "TI"], "2"], "=", "4", 
   SubscriptBox[
    StyleBox["p", "TI"], "0"], 
   SubscriptBox[
    StyleBox["p", "TI"], "1"]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "dcb20800-ed24-44e5-834d-8301d842d5bd"],
 " vanishes at both poles (",
 Cell[BoxData[
  RowBox[{
   SubscriptBox[
    StyleBox["p", "TI"], "0"], "=", "0"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "a7180996-e1d9-497d-a49f-19b846ebc378"],
 " and ",
 Cell[BoxData[
  RowBox[{
   SubscriptBox[
    StyleBox["p", "TI"], "0"], "=", "1"}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "4a719b1a-c13d-4f6f-be64-e31fa0cfe6fd"],
 "), reflecting that those eigenstates are absorbing. For ",
 Cell[BoxData[
  RowBox[{
   StyleBox["\[Gamma]", "TI"], "\[GreaterGreater]", 
   SubscriptBox[
    StyleBox["\[Omega]", "TI"], 
    StyleBox["x", "TI"]]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "abd7879f-66b3-466c-ba79-a29b5d64cd41"],
 ", the drift term (with ",
 Cell[BoxData[
  StyleBox[
   RowBox[{"d", "t"}], "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "7bf0325b-d121-4cf7-84cd-0d0a2701b4c8"],
 ") is negligible, thus It\[OHat] SDE for probabilities has no deterministic \
drift term. That is exactly the martingale property. The Born rule then drops \
out from one very deep but very simple martingale fact: martingales preserve \
expectation, even at stopping times. Mathematically, it means ",
 Cell[BoxData[
  RowBox[{"\|01d53c", 
   StyleBox["(",
    SpanMaxSize->1], 
   RowBox[{
    SubscriptBox[
     StyleBox["p", "TI"], "0"], 
    StyleBox["(",
     SpanMaxSize->1], 
    StyleBox["t", "TI"], 
    StyleBox[")",
     SpanMaxSize->1]}], 
   StyleBox[")",
    SpanMaxSize->1], "=", 
   SubscriptBox[
    StyleBox["p", "TI"], "0"], 
   StyleBox["(",
    SpanMaxSize->1], "0", 
   StyleBox[")",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "c6a2246f-a263-4a93-a156-fcd6e5421693"],
 " and ",
 Cell[BoxData[
  RowBox[{"\|01d53c", 
   StyleBox["(",
    SpanMaxSize->1], 
   RowBox[{
    SubscriptBox[
     StyleBox["p", "TI"], "1"], 
    StyleBox["(",
     SpanMaxSize->1], 
    StyleBox["t", "TI"], 
    StyleBox[")",
     SpanMaxSize->1]}], 
   StyleBox[")",
    SpanMaxSize->1], "=", 
   SubscriptBox[
    StyleBox["p", "TI"], "1"], 
   StyleBox["(",
    SpanMaxSize->1], "0", 
   StyleBox[")",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "f35eba6b-37ba-4777-80d1-ff62dc888270"],
 " which is exactly the Born rule: the probability of ending in an eigenstate \
equals the initial population of that eigenstate. This is what people mean by \
\[OpenCurlyDoubleQuote]Born rule from martingales\[CloseCurlyDoubleQuote]: \
collapse is the almost-sure convergence to 0/1, and the martingale property \
makes manifest that continuous monitoring is consistent with the Born \
weights, pinning the endpoint probabilities to the initial populations."
}], "Text",ExpressionUUID->"d0785e0d-3004-49d4-a25e-780531cb223e"],

Cell["Where This Leaves Us (and What Comes Next)", "Subsection",ExpressionUUID->"3c67d24f-53f9-410f-8024-bedfbf3fe8a2"],

Cell["\<\
You now have a complete, computation-first toolkit for understanding a single \
qubit from multiple, consistent viewpoints: state vectors and bases, the \
Bloch-sphere and Bloch-ball geometry, how measurement probabilities and \
expectation values are extracted, why density matrices are necessary for \
ensembles and mixedness, how unitary dynamics are built from the Pauli \
algebra and organized by the SU(2) to SO(3) relationship (including the \
subtle double-cover point), how those unitaries can be implemented \
dynamically based on Schrodinger equation, and how noise makes everything \
messy and what to make of it. With these ideas unified, the notebook\
\[CloseCurlyQuote]s core message becomes practical: prepare a state, change \
representation when it helps, evolve it, and read predictions directly from \
the appropriate measurement operators, always able to cross-check algebra \
with geometry. From here, the most natural continuations are to move beyond \
ideal projective measurements into more general measurement models, and to \
treat realistic dynamics such as noise and decoherence, which turn \
isolated-system rotations into open-system evolution and make the Bloch-ball \
picture even more valuable.\
\>", "Text",ExpressionUUID->"6c08e8b3-fddd-401c-8a9e-61f24c0ccc0d"],

Cell["Acknowledgment", "Subsection",ExpressionUUID->"43109544-66eb-4dfe-90b8-c00dcc820925"],

Cell["\<\
Special thanks to Wolfram Research, especially Stephen Wolfram and our R&D \
team, for their constant support. The tools developed at Wolfram Research \
continue to empower researchers and computational explorers to discover new \
ideas and navigate uncharted territories in the vast landscape of \
computation.  I am deeply grateful to my dear friend and mentor, Michael \
Trott, who sadly passed away before I completed this draft.\
\>", "Text",ExpressionUUID->"d6d3b710-64b9-4c02-907d-0a2e6fcda8ca"]
},
