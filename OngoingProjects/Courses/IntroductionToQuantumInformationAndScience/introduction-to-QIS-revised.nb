Cell[BoxData[
 RowBox[{
  RowBox[{"With", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{"\[Sigma]", " ", "=", " ", 
       RowBox[{"Table", "[", 
        RowBox[{
         RowBox[{"PauliMatrix", "[", "j", "]"}], ",", " ", 
         RowBox[{"{", 
          RowBox[{"j", ",", " ", "3"}], "}"}]}], "]"}]}], ",", " ", "\n", 
      "   ", 
      RowBox[{"vec1", " ", "=", " ", 
       RowBox[{"Array", "[", 
        RowBox[{"\[FormalA]", ",", " ", "3"}], "]"}]}], ",", " ", 
      RowBox[{"vec2", " ", "=", " ", 
       RowBox[{"Array", "[", 
        RowBox[{"\[FormalB]", ",", " ", "3"}], "]"}]}]}], "}"}], ",", " ", 
    "\n", "  ", 
    RowBox[{
     RowBox[{"Commutator", "[", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{"vec1", " ", ".", " ", "\[Sigma]"}], ")"}], ",", " ", 
       RowBox[{"(", 
        RowBox[{"vec2", " ", ".", " ", "\[Sigma]"}], ")"}], ",", " ", "Dot"}],
       "]"}], " ", "==", " ", "\n", "   ", 
     RowBox[{"2", " ", "I", "  ", 
      RowBox[{
       RowBox[{"Cross", "[", 
        RowBox[{"vec1", ",", " ", "vec2"}], "]"}], " ", ".", " ", 
       "\[Sigma]"}]}]}]}], "]"}], " ", "//", " ", "FullSimplify"}]], "Input",
 CellLabel->
  "In[165]:= ",ExpressionUUID->"412a5090-850d-4e82-a63e-160a96e9453e"],

Cell[TextData[{
