        RowBox[{"Cos", "[", "\[Theta]", "]"}]}], "}"}]}], ",", " ", 
     RowBox[{"\[Sigma]", " ", "=", " ", "\n", "   ", 
      RowBox[{"Table", "[", 
       RowBox[{
        RowBox[{"PauliMatrix", "[", "j", "]"}], ",", " ", 
        RowBox[{"{", 
         RowBox[{"j", ",", " ", "\n", "     ", "3"}], "}"}]}], "]"}]}]}], 
    "}"}], ",", " ", 
   RowBox[{"{", 
    RowBox[{"vecM", " ", "=", " ", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"Sin", "[", 
