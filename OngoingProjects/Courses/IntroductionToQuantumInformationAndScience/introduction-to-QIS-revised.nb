       RowBox[{"PlotStyle", " ", "->", " ", 
        RowBox[{"Directive", "[", 
         RowBox[{
          RowBox[{"Opacity", "[", ".6", "]"}], ",", " ", 
          RowBox[{
           RowBox[{"ColorData", "[", "97", "]"}], "[", "2", "]"}]}], 
         "]"}]}]}], "]"}], ",", " ", "\n", "  ", 
     RowBox[{
     "PlotLabel", " ", "->", 
      " ", "\"\<Averaged qubit state on\n the Bloch sphere\>\""}]}], "]"}], ",",
    " ", "\n", " ", 
   RowBox[{"SwatchLegend", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{
        RowBox[{"ColorData", "[", "97", "]"}], "[", "1", "]"}], ",", " ", 
