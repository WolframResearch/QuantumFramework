Cell[BoxData[
 RowBox[{"Manipulate", "[", 
  RowBox[{
   RowBox[{"Show", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"ResourceFunction", "[", "\"\<BlochSpherePlot\>\"", "]"}], "[", 
      
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"1", ",", " ", "0", ",", " ", "0"}], "}"}], ",", " ", "\n", 
         "    ", 
         RowBox[{
          RowBox[{"RotationMatrix", "[", 
           RowBox[{"\[Theta]", ",", " ", 
            RowBox[{"{", 
             RowBox[{"0", ",", " ", "0", ",", " ", "1"}], "}"}]}], "]"}], " ",
           ".", " ", 
          RowBox[{"{", 
           RowBox[{"1", ",", " ", "0", ",", " ", "0"}], "}"}]}]}], "}"}], ",",
        " ", "\n", "   ", 
       RowBox[{"ImageSize", " ", "->", " ", "270"}], ",", " ", "\n", "   ", 
       RowBox[{
       "PlotLabel", " ", "->", 
        " ", "\"\<Rotation around z-axis by angle \[Theta]\n\>\""}]}], "]"}], 
     ",", " ", "\n", "  ", 
     RowBox[{"Graphics3D", "[", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"Opacity", "[", ".5", "]"}], ",", " ", "\n", "    ", 
        RowBox[{"Polygon", "[", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{"0", ",", " ", "0", ",", " ", "0"}], "}"}], ",", " ", 
           "\n", "      ", 
           RowBox[{"Sequence", " ", "@@", " ", "\n", "       ", 
            RowBox[{"Table", "[", 
             RowBox[{
              RowBox[{"{", 
               RowBox[{
                RowBox[{"Cos", "[", "th", "]"}], ",", " ", 
                RowBox[{"Sin", "[", "th", "]"}], ",", " ", "0"}], "}"}], ",", 
              " ", 
              RowBox[{"{", 
               RowBox[{"th", ",", " ", "\n", "         ", 
                RowBox[{"Range", "[", 
                 RowBox[{"0", ",", " ", "\[Theta]", ",", " ", 
                  RowBox[{"\[Theta]", "/", "100"}]}], "]"}]}], "}"}]}], 
             "]"}]}]}], "}"}], "]"}]}], "}"}], "]"}]}], "]"}], ",", " ", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
      "\[Theta]", ",", " ", "1", ",", " ", "\n", 
       "   ", "\"\<Rotation angle \[Theta]\>\""}], "}"}], ",", " ", "0", ",", 
     " ", 
     RowBox[{"2", " ", "\[Pi]"}]}], "}"}]}], "]"}]], "Input",
 CellLabel->
  "In[183]:= ",ExpressionUUID->"1490a55d-23d9-41f0-a562-89d0915bc617"],

Cell[TextData[{
 "In several experimental settings especially nuclear magnetic resonance \
(NMR) and optical/quantum control, these abstract rotation operators aren\
\[CloseCurlyQuote]t treated as just matrices. They\[CloseCurlyQuote]re spoken \
about as physical control actions you apply to the system. So a rotation like \
",
 Cell[BoxData[
  RowBox[{
   SubscriptBox["\[ScriptCapitalR]", 
    StyleBox["z", "TI"]], 
   StyleBox["(",
    SpanMaxSize->1], 
   StyleBox["\[Theta]", "TI"], 
   StyleBox[")",
    SpanMaxSize->1]}]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "ca598248-2959-4451-ad18-866d3a7028dc"],
 " is naturally described in the language of the lab: it\[CloseCurlyQuote]s a \
",
 Cell[BoxData[
  StyleBox["z", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "0665784d-cb19-46a0-b7b4-921df0ad20e0"],
 "-axis rotation by an angle \[Theta], commonly referred to as a \
\[OpenCurlyDoubleQuote]Z pulse\[CloseCurlyDoubleQuote] of strength (or phase) \
\[Theta]. You\[CloseCurlyQuote]ll often hear it called a ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["Z", "TI"], 
   StyleBox["\[Theta]", "TI"]]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "af7de3ab-3b2c-4010-8a56-f3503c0557b2"],
 " pulse, and in some communities it\[CloseCurlyQuote]s described \
directionally as ",
 Cell[BoxData[
  SuperscriptBox[
   StyleBox["Z", "TI"], "+"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "8d24687a-1bd9-4e89-92b6-e2a26b4bdf49"],
 " to emphasize a positive (right-hand) rotation about the ",
 Cell[BoxData[
  StyleBox["z", "TI"]], "InlineFormula",
  FontSize->0.9 Inherited,ExpressionUUID->
  "2d7bc1b1-d497-48f5-a398-d21f93ecfb66"],
 "-axis, with \[Theta] specifying how far you rotate."
}], "Text",ExpressionUUID->"d482038f-7f94-4f96-8533-61c103ac89b1"],

