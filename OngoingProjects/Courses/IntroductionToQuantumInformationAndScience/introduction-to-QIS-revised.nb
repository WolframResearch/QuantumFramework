Cell[BoxData[{
 RowBox[{"ClearAll", "[", 
  RowBox[{"r", ",", " ", "\[Phi]", ",", " ", "\[Theta]"}], "]"}], "\n", 
 RowBox[{"Module", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"zero", ",", " ", "P0", ",", " ", "\n", "  ", 
     RowBox[{"vec", " ", "=", " ", 
      RowBox[{"r", " ", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{
          RowBox[{"Cos", "[", "\[Phi]", "]"}], " ", 
          RowBox[{"Sin", "[", "\[Theta]", "]"}]}], ",", " ", 
         RowBox[{
          RowBox[{"Sin", "[", "\[Phi]", "]"}], " ", 
          RowBox[{"Sin", "[", "\[Theta]", "]"}]}], ",", " ", "\n", "     ", 
         RowBox[{"Cos", "[", "\[Theta]", "]"}]}], "}"}]}]}], ",", " ", 
     RowBox[{"\[Sigma]", " ", "=", " ", 
      RowBox[{"Table", "[", 
       RowBox[{
        RowBox[{"PauliMatrix", "[", "j", "]"}], ",", " ", 
        RowBox[{"{", 
         RowBox[{"j", ",", " ", "3"}], "}"}]}], "]"}]}], ",", " ", "\[Rho]"}],
     "}"}], ",", "\n", " ", 
   RowBox[{
    RowBox[{"\[Rho]", " ", "=", " ", 
     RowBox[{
      RowBox[{"1", "/", "2"}], " ", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{"IdentityMatrix", "[", "2", "]"}], " ", "+", " ", 
        RowBox[{"vec", " ", ".", " ", "\[Sigma]"}]}], ")"}]}]}], ";", "\n", 
    " ", 
    RowBox[{"zero", " ", "=", " ", 
     RowBox[{"{", 
      RowBox[{"1", ",", " ", "0"}], "}"}]}], ";", "\n", " ", 
    RowBox[{"P0", " ", "=", " ", 
     RowBox[{"TensorProduct", "[", 
      RowBox[{"zero", ",", " ", 
       RowBox[{"Conjugate", "@", "zero"}]}], "]"}]}], ";", "\n", " ", 
    RowBox[{"FullSimplify", "[", "\n", "  ", 
     RowBox[{
      RowBox[{
       RowBox[{"Tr", "[", 
        RowBox[{"P0", " ", ".", " ", "\[Rho]"}], "]"}], " ", "==", " ", "\n", 
       "   ", 
       RowBox[{
        RowBox[{"Conjugate", "[", "zero", "]"}], " ", ".", " ", "\[Rho]", " ",
         ".", " ", "zero"}]}], ",", " ", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{"\[Theta]", " ", "|", " ", "\[Phi]"}], ")"}], " ", "\[Element]",
        " ", "\n", "   ", "Reals"}]}], "]"}]}]}], "]"}]}], "Input",
 CellLabel->
  "In[199]:= ",ExpressionUUID->"f4d22f53-12fa-48d3-bda8-52552679594a"],

