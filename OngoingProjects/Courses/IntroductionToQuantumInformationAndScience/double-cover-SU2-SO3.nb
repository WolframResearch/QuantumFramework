Cell[BoxData[{
 RowBox[{
  RowBox[{"ClearAll", "[", 
   RowBox[{
   "\[CapitalOmega]", ",", "\[Theta]", ",", "T", ",", "\[CapitalLambda]", ",",
     "t", ",", "\[Omega]"}], "]"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"$Assumptions", "=", 
   RowBox[{
    RowBox[{"\[CapitalOmega]", ">", "0"}], "&&", 
    RowBox[{"\[Omega]", ">", "0"}], "&&", 
    RowBox[{"\[Theta]", "\[Element]", "Reals"}], "&&", 
    RowBox[{"T", ">", "0"}], "&&", 
    RowBox[{"\[CapitalLambda]", ">", "0"}]}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{"ham", "=", 
