}, Open  ]],

Cell[TextData[{
 "The second term  ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["\[ExponentialE]", 
    RowBox[{
     RowBox[{"-", "\[ImaginaryI]"}], " ", 
     FractionBox["T", "2"], 
     RowBox[{"(", 
      RowBox[{
       RowBox[{"\[CapitalOmega]", " ", "sin", " ", "\[Theta]", " ", 
        SubscriptBox["\[Sigma]", "x"]}], " ", "+", " ", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{
          RowBox[{"\[CapitalOmega]", " ", "cos", " ", "\[Theta]"}], " ", "-", 
          "\[Omega]"}], ")"}], 
        SubscriptBox["\[Sigma]", "z"]}]}], ")"}]}]], TraditionalForm]],
  ExpressionUUID->"fc5b5cea-b8ea-4ed6-875d-de813e3b662a"],
 " in the unitary operator ",
 Cell[BoxData[
  FormBox[
   RowBox[{"U", "(", "T", ")"}], TraditionalForm]],ExpressionUUID->
  "e4f51b2b-de96-4b5d-a471-b8ddbed64128"],
 " is a rotation about the fixed axis ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    OverscriptBox["m", "\[RightVector]"], "=", 
    RowBox[{
     FractionBox["1", "\[CapitalLambda]"], 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"\[CapitalOmega]", " ", "sin", " ", "\[Theta]"}], ",", "0", ",", 
       RowBox[{
        RowBox[{"\[CapitalOmega]", " ", "cos", " ", "\[Theta]"}], "-", 
        "\[Omega]"}]}], "}"}]}]}], TraditionalForm]],ExpressionUUID->
  "3f97c53e-f4e8-458e-ac0d-eaa7a9f4a628"],
 " by angle ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[CapitalLambda]", " ", "T"}], TraditionalForm]],ExpressionUUID->
  "71ea8d25-1b40-4052-9bd0-8a1c6d953f3e"],
 ". \nCross-check the above statement:"
}], "Text",
 CellChangeTimes->{{3.980595550660919*^9, 3.9805955924968977`*^9}, {
  3.980595790334445*^9, 3.9805958398221397`*^9}, {3.980596456468811*^9, 
  3.980596456469035*^9}, {3.980596511595358*^9, 3.980596511595541*^9}, {
