  3.980598763242887*^9}},ExpressionUUID->"1fa330d4-1b7f-45da-9715-\
7cddb1d20a28"],

Cell[TextData[{
 "Calculate the rotation matrix transforming the unit vector ",
 Cell[BoxData[
  FormBox[
   OverscriptBox["m", "\[RightVector]"], TraditionalForm]],ExpressionUUID->
  "0133f424-4c53-4dcd-a126-b0e041146da9"],
 " into the unit vector along ",
 Cell[BoxData[
  FormBox["z", TraditionalForm]],ExpressionUUID->
  "f87b9352-adce-4c6c-b337-d03b285cba57"],
 "-axis ",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", 
    RowBox[{"0", ",", "0", ",", "1"}], "}"}], TraditionalForm]],
  ExpressionUUID->"34a9059d-dca0-4097-91e9-a948f0aa5026"],
 ":"
}], "Text",
 CellChangeTimes->{{3.980598134617695*^9, 
  3.980598184569426*^9}},ExpressionUUID->"ca4e5d57-9d88-40ab-99bd-\
c5c68c8fdf53"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"FullSimplify", "@", 
   RowBox[{"With", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"\[CapitalLambda]", "=", 
       SqrtBox[
        RowBox[{
         SuperscriptBox["\[CapitalOmega]", "2"], "+", 
         SuperscriptBox["\[Omega]", "2"], "-", 
         RowBox[{"2", "\[CapitalOmega]", " ", "\[Omega]", " ", 
          RowBox[{"Cos", "[", "\[Theta]", "]"}]}]}]]}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"m", "=", 
       FractionBox[
        RowBox[{"{", 
         RowBox[{
          RowBox[{"\[CapitalOmega]", " ", 
           RowBox[{"Sin", "[", "\[Theta]", "]"}]}], ",", "0", ",", 
          RowBox[{
           RowBox[{"\[CapitalOmega]", " ", 
            RowBox[{"Cos", "[", "\[Theta]", "]"}]}], "-", "\[Omega]"}]}], 
         "}"}], "\[CapitalLambda]"]}], "}"}], ",", 
     RowBox[{"RotationMatrix", "[", 
      RowBox[{"{", 
       RowBox[{"m", ",", 
        RowBox[{"{", 
         RowBox[{"0", ",", "0", ",", "1"}], "}"}]}], "}"}], "]"}]}], "]"}]}], 
  "//", "MatrixForm"}]], "Input",
 CellChangeTimes->{{3.980597435764525*^9, 3.9805974818466463`*^9}, {
   3.980597758281418*^9, 3.980597759277397*^9}, 3.980597889130473*^9, {
   3.980598188924018*^9, 3.98059819016245*^9}},
 CellLabel->"In[24]:=",ExpressionUUID->"2a720a64-4b5b-4ddb-be58-785a5379e23f"],

Cell[BoxData[
 TagBox[
  RowBox[{"(", "\[NoBreak]", GridBox[{
     {
      FractionBox[
       RowBox[{
        RowBox[{"-", "\[Omega]"}], "+", 
        RowBox[{"\[CapitalOmega]", " ", 
         RowBox[{"Cos", "[", "\[Theta]", "]"}]}]}], 
       SqrtBox[
        RowBox[{
         SuperscriptBox["\[Omega]", "2"], "+", 
         SuperscriptBox["\[CapitalOmega]", "2"], "-", 
         RowBox[{"2", " ", "\[Omega]", " ", "\[CapitalOmega]", " ", 
          RowBox[{"Cos", "[", "\[Theta]", "]"}]}]}]]], "0", 
      RowBox[{"-", 
       FractionBox[
        RowBox[{"\[CapitalOmega]", " ", 
         RowBox[{"Sin", "[", "\[Theta]", "]"}]}], 
        SqrtBox[
         RowBox[{
          SuperscriptBox["\[Omega]", "2"], "+", 
          SuperscriptBox["\[CapitalOmega]", "2"], "-", 
          RowBox[{"2", " ", "\[Omega]", " ", "\[CapitalOmega]", " ", 
           RowBox[{"Cos", "[", "\[Theta]", "]"}]}]}]]]}]},
     {"0", "1", "0"},
     {
      FractionBox[
       RowBox[{"\[CapitalOmega]", " ", 
        RowBox[{"Sin", "[", "\[Theta]", "]"}]}], 
       SqrtBox[
        RowBox[{
         SuperscriptBox["\[Omega]", "2"], "+", 
         SuperscriptBox["\[CapitalOmega]", "2"], "-", 
         RowBox[{"2", " ", "\[Omega]", " ", "\[CapitalOmega]", " ", 
          RowBox[{"Cos", "[", "\[Theta]", "]"}]}]}]]], "0", 
      FractionBox[
       RowBox[{
        RowBox[{"-", "\[Omega]"}], "+", 
        RowBox[{"\[CapitalOmega]", " ", 
         RowBox[{"Cos", "[", "\[Theta]", "]"}]}]}], 
       SqrtBox[
        RowBox[{
         SuperscriptBox["\[Omega]", "2"], "+", 
         SuperscriptBox["\[CapitalOmega]", "2"], "-", 
         RowBox[{"2", " ", "\[Omega]", " ", "\[CapitalOmega]", " ", 
          RowBox[{"Cos", "[", "\[Theta]", "]"}]}]}]]]}
    },
    GridBoxAlignment->{"Columns" -> {{Center}}, "Rows" -> {{Baseline}}},
    GridBoxSpacings->{"Columns" -> {
        Offset[0.27999999999999997`], {
         Offset[0.7]}, 
        Offset[0.27999999999999997`]}, "Rows" -> {
        Offset[0.2], {
         Offset[0.4]}, 
        Offset[0.2]}}], "\[NoBreak]", ")"}],
  Function[BoxForm`e$, 
   MatrixForm[BoxForm`e$]]]], "Output",
 CellChangeTimes->{{3.9805974593476133`*^9, 3.980597476646916*^9}, 
   3.980597562820198*^9, 3.980597774319615*^9, 3.980597895903288*^9, 
   3.980598190487236*^9},
 CellLabel->
  "Out[24]//MatrixForm=",ExpressionUUID->"d351c2f8-5d70-498c-9b24-\
b97100fc4a61"]
}, Open  ]],

Cell["\<\
As you may have recognized, this is a rotation around y by an angle:\
\>", "Text",
 CellChangeTimes->{{3.980598197238653*^9, 
  3.9805982172990417`*^9}},ExpressionUUID->"1defd4db-09c3-48a9-a27f-\
b1a5cd6a792f"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"MatrixForm", "@", 
  RowBox[{"RotationMatrix", "[", 
   RowBox[{
    RowBox[{"-", "\[Beta]"}], ",", 
    RowBox[{"{", 
     RowBox[{"0", ",", "1", ",", "0"}], "}"}]}], "]"}]}]], "Input",
 CellChangeTimes->{{3.980598219799048*^9, 3.980598228467568*^9}, 
   3.980598259612232*^9},
 CellLabel->"In[26]:=",ExpressionUUID->"3e163b7a-5961-4c78-aaf1-45eeb1e4ff22"],

Cell[BoxData[
 TagBox[
  RowBox[{"(", "\[NoBreak]", GridBox[{
     {
      RowBox[{"Cos", "[", "\[Beta]", "]"}], "0", 
      RowBox[{"-", 
       RowBox[{"Sin", "[", "\[Beta]", "]"}]}]},
     {"0", "1", "0"},
     {
      RowBox[{"Sin", "[", "\[Beta]", "]"}], "0", 
      RowBox[{"Cos", "[", "\[Beta]", "]"}]}
    },
    GridBoxAlignment->{"Columns" -> {{Center}}, "Rows" -> {{Baseline}}},
    GridBoxSpacings->{"Columns" -> {
        Offset[0.27999999999999997`], {
         Offset[0.7]}, 
        Offset[0.27999999999999997`]}, "Rows" -> {
        Offset[0.2], {
         Offset[0.4]}, 
        Offset[0.2]}}], "\[NoBreak]", ")"}],
  Function[BoxForm`e$, 
   MatrixForm[BoxForm`e$]]]], "Output",
 CellChangeTimes->{3.980598228825267*^9, 3.980598260223399*^9},
 CellLabel->
  "Out[26]//MatrixForm=",ExpressionUUID->"ae348d01-ca42-4746-988a-\
e0389c7dace3"]
}, Open  ]],

Cell[TextData[{
 "where ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"tan", " ", "\[Beta]"}], "=", 
    FractionBox[
     RowBox[{"\[CapitalOmega]", " ", "sin", " ", "\[Theta]"}], 
     RowBox[{
      RowBox[{"\[CapitalOmega]", " ", "cos", " ", "\[Theta]"}], " ", "-", 
      "\[Omega]"}]]}], TraditionalForm]],ExpressionUUID->
  "1cb2423f-b4a5-443f-a5db-2e78af2a9747"],
 ". In other words, one can rotate ",
 Cell[BoxData[
  FormBox[
   RowBox[{"U", "(", "T", ")"}], TraditionalForm]],ExpressionUUID->
  "c6c1448c-1c8b-4b1c-b180-8bef0a73a143"],
 " along ",
 Cell[BoxData[
  FormBox["y", TraditionalForm]],ExpressionUUID->
  "433226dc-a6d5-4657-b104-0a9616c1cae7"],
 "-axis with a properly chosen angle such that the result becomes a ",
 Cell[BoxData[
  FormBox["z", TraditionalForm]],ExpressionUUID->
  "870ac529-4915-463d-9546-ffcae820362b"],
 "-pulse. The axis-alignment pulses ensure the loop contributes only a phase \
rotation about ",
 Cell[BoxData[
  FormBox["z", TraditionalForm]],ExpressionUUID->
  "e60d2c53-d575-4683-b2f2-29a63dcc216d"],
 " in the lab basis.  In other words, the unitary operator ",
 Cell[BoxData[
  FormBox[
   RowBox[{"U", "(", "T", ")"}], TraditionalForm]],ExpressionUUID->
  "93a448b5-8937-4bdf-9aa7-d7cbb2823002"],
 " can be written as ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"U", "(", "T", ")"}], "=", 
    RowBox[{
     RowBox[{"-", "\[DoubleStruckCapitalI]"}], " ", 
     SubscriptBox["Y", "\[Beta]"], 
     SubscriptBox["Z", "\[Gamma]"], 
     SubscriptBox["Y", 
      RowBox[{"-", "\[Beta]"}]]}]}], TraditionalForm]],ExpressionUUID->
  "a5f9451f-476a-4ba9-957b-5b78db15822f"],
 " where ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Gamma]", "=", 
    RowBox[{"\[CapitalLambda]", " ", "T"}]}], TraditionalForm]],
  ExpressionUUID->"c9b0e003-f7c5-4980-b185-c88c1b1fbcd1"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"tan", " ", "\[Beta]"}], "=", 
    FractionBox[
     RowBox[{"\[CapitalOmega]", " ", "sin", " ", "\[Theta]"}], 
     RowBox[{
      RowBox[{"\[CapitalOmega]", " ", "cos", " ", "\[Theta]"}], " ", "-", 
      "\[Omega]"}]]}], TraditionalForm]],ExpressionUUID->
  "62700934-ec1d-4c7b-9d1c-f2a80e0f67ae"],
 ". Of course having ",
 Cell[BoxData[
  FormBox[
   RowBox[{"-", "\[DoubleStruckCapitalI]"}], TraditionalForm]],ExpressionUUID->
  "77d957f3-d730-4603-af22-a571e8ca479f"],
 " is redundant in this formula, but we include it there for clarity."
}], "Text",
 CellChangeTimes->{{3.980598233291772*^9, 3.9805982399598*^9}, {
  3.980598323947484*^9, 3.980598375882031*^9}, {3.980599626299748*^9, 
  3.980599650630006*^9}},ExpressionUUID->"5bd9fee8-7e63-4a79-a863-\
b3527c04c1f3"],

Cell[TextData[{
 "So, ignoring ",
 Cell[BoxData[
  FormBox[
   RowBox[{"-", "\[DoubleStruckCapitalI]"}], TraditionalForm]],ExpressionUUID->
  "3a4310d6-bacf-46f8-821b-d311a63e64f8"],
 " factor (which is not observable for 1-qubit scenarios, but one can see its \
effect for 2-qubit cases which are beyond our scope for now), the one-loop \
unitary can be written as ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"U", "(", "T", ")"}], "=", 
    RowBox[{
     SubscriptBox["Y", "\[Beta]"], 
     SubscriptBox["Z", "\[Gamma]"], 
     SubscriptBox["Y", 
      RowBox[{"-", "\[Beta]"}]]}]}], TraditionalForm]],ExpressionUUID->
  "c5f568c8-fd74-4574-bab9-2ccfc69a4aef"],
 ". So if one designs sequence pulses as ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["X", 
     RowBox[{"\[Pi]", "/", "2"}]], "->", 
    RowBox[{
     SubscriptBox["Y", "\[Beta]"], "->", 
     RowBox[{
      RowBox[{"U", "(", "T", ")"}], "->", 
      RowBox[{
       SubscriptBox["Y", 
        RowBox[{"-", "\[Beta]"}]], "->", 
       SubscriptBox["X", 
        RowBox[{
         RowBox[{"-", "\[Pi]"}], "/", "2"}]]}]}]}]}], TraditionalForm]],
  ExpressionUUID->"6e33cf87-92ab-48d1-846a-dde87ec733a8"],
 ", with properly chosen ",
 Cell[BoxData[
  FormBox["\[Beta]", TraditionalForm]],ExpressionUUID->
  "5367fd8b-d0d4-471a-9c14-fca39f76d17b"],
 ", the sequence would be effectively ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["X", 
     RowBox[{"\[Pi]", "/", "2"}]], "->", 
    RowBox[{
     SubscriptBox["Z", "\[Gamma]"], "->", 
     SubscriptBox["X", 
      RowBox[{
       RowBox[{"-", "\[Pi]"}], "/", "2"}]]}]}], TraditionalForm]],
  ExpressionUUID->"cf94f5f0-4da2-4b0b-914f-62ff7581877e"],
 ". We have shown that this seqeunce gives the proabbiltity of ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{"1"},
    "Ket"], TraditionalForm]],ExpressionUUID->
  "7d0832c2-888f-4f3b-be06-f36521199dfe"],
 " as ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["P", 
     TemplateBox[{"1"},
      "Ket"]], "=", 
    RowBox[{
     SuperscriptBox["sin", "2"], "(", 
     RowBox[{"\[Gamma]", "/", "2"}], ")"}]}], TraditionalForm]],
  ExpressionUUID->"b402e720-28ac-4f13-9082-f4e253a8fc67"],
 ". Pluggin ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Gamma]", "=", 
    RowBox[{"\[CapitalLambda]", " ", "T"}]}], TraditionalForm]],
  ExpressionUUID->"7476bc42-a37f-4c70-8af1-486569540522"],
 " gives ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["P", 
     TemplateBox[{"1"},
      "Ket"]], "=", 
    RowBox[{
     SuperscriptBox["sin", "2"], "(", 
     RowBox[{
      FractionBox["T", "2"], 
      SqrtBox[
       RowBox[{
        SuperscriptBox["\[CapitalOmega]", "2"], "+", 
        FractionBox[
         RowBox[{"4", 
          SuperscriptBox["\[Pi]", "2"]}], 
         SuperscriptBox["T", "2"]], "-", 
        RowBox[{
         FractionBox[
          RowBox[{"4", "\[Pi]"}], "T"], " ", "\[CapitalOmega]", " ", "cos", " ",
          "\[Theta]"}]}]]}], ")"}]}], TraditionalForm]],ExpressionUUID->
  "1c2c6467-f019-42e1-8f5f-fcf556f8f547"]
}], "Text",
 CellChangeTimes->{{3.980599156571436*^9, 3.9805993354716253`*^9}, {
  3.980599431311482*^9, 
  3.980599587199239*^9}},ExpressionUUID->"e70bdace-d3c6-4efc-9953-\
4b8bb56d29ac"],

Cell[TextData[{
 "The Ramsey\[Dash]Berry protocol uses a qubit as a built-in two-path \
interferometer. A ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Pi]", "/", "2"}], TraditionalForm]],ExpressionUUID->
  "616678f3-a2d7-42df-a195-4ba7dd8080dc"],
 " pulse creates a superposition, then an adiabatic parameter sweep traces a \
closed loop on the Bloch sphere, accumulating a geometric (Berry) phase. A \
second ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Pi]", "/", "2"}], TraditionalForm]],ExpressionUUID->
  "d0854d31-60e7-48fb-839c-bfdddbd3b253"],
 " pulse converts this phase into a measurable population difference."
}], "Text",
 CellChangeTimes->{{3.980521392445228*^9, 
  3.980521452404587*^9}},ExpressionUUID->"cd84cd28-9c2b-442e-9aea-\
c39f959c17a8"]
}, Closed]]
},
