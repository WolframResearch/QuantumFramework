Cell[TextData[{
 "In the formula of the unitary operator ",
 Cell[BoxData[
  FormBox[
   RowBox[{"U", "(", "t", ")"}], TraditionalForm]],ExpressionUUID->
  "54c8b89f-07ed-4335-b7cc-8e1cd6b8159d"],
 ", replace ",
 Cell[BoxData[
  FormBox[
   SqrtBox[
    RowBox[{
     SuperscriptBox["\[Omega]", "2"], "+", 
     SuperscriptBox["\[CapitalOmega]", "2"], "-", 
     RowBox[{
     "2", "\[Omega]", " ", "\[CapitalOmega]", " ", "cos", " ", 
      "\[Theta]"}]}]], TraditionalForm]],ExpressionUUID->
  "9353293e-e813-48ed-9385-a9f4851d7c8d"],
 " by \[CapitalLambda], for simplicity of formulas:"
}], "Text",
 CellChangeTimes->{{3.980553017514955*^9, 3.9805530454196587`*^9}, {
  3.98059858879025*^9, 
  3.980598624251253*^9}},ExpressionUUID->"3b29b5f7-aebe-4569-b7b2-\
c22b79d7808f"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"unitary", "=", 
  RowBox[{
   RowBox[{"unitary", "/.", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{
       SqrtBox[
        RowBox[{
         RowBox[{"-", 
          SuperscriptBox["\[Omega]", "2"]}], "-", 
         SuperscriptBox["\[CapitalOmega]", "2"], "+", 
         RowBox[{"2", " ", "\[Omega]", " ", "\[CapitalOmega]", " ", 
          RowBox[{"Cos", "[", "\[Theta]", "]"}]}]}]], ":>", 
       RowBox[{"\[ImaginaryI]", " ", "\[CapitalLambda]"}]}], ",", 
      RowBox[{
       FractionBox["1", 
        SqrtBox[
         RowBox[{
          RowBox[{"-", 
           SuperscriptBox["\[Omega]", "2"]}], "-", 
          SuperscriptBox["\[CapitalOmega]", "2"], "+", 
          RowBox[{"2", " ", "\[Omega]", " ", "\[CapitalOmega]", " ", 
           RowBox[{"Cos", "[", "\[Theta]", "]"}]}]}]]], ":>", 
       FractionBox["1", 
        RowBox[{"\[ImaginaryI]", " ", "\[CapitalLambda]"}]]}]}], "}"}]}], "//",
    "FullSimplify"}]}]], "Input",
 CellChangeTimes->{{3.980536691390738*^9, 3.980536790147818*^9}, {
  3.980539594021196*^9, 3.9805395966722603`*^9}, {3.980539629731853*^9, 
  3.980539635212039*^9}},
 CellLabel->"In[42]:=",ExpressionUUID->"780147b9-8c6d-4fe5-817d-681ad90b8653"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{
      SuperscriptBox["\[ExponentialE]", 
       RowBox[{
        RowBox[{"-", 
         FractionBox["1", "2"]}], " ", "\[ImaginaryI]", " ", "t", " ", 
        "\[Omega]"}]], " ", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{"Cos", "[", 
         FractionBox[
          RowBox[{"t", " ", "\[CapitalLambda]"}], "2"], "]"}], "+", 
        FractionBox[
         RowBox[{"\[ImaginaryI]", " ", 
          RowBox[{"(", 
           RowBox[{"\[Omega]", "-", 
            RowBox[{"\[CapitalOmega]", " ", 
             RowBox[{"Cos", "[", "\[Theta]", "]"}]}]}], ")"}], " ", 
          RowBox[{"Sin", "[", 
           FractionBox[
            RowBox[{"t", " ", "\[CapitalLambda]"}], "2"], "]"}]}], 
         "\[CapitalLambda]"]}], ")"}]}], ",", 
     RowBox[{"-", 
      FractionBox[
       RowBox[{"\[ImaginaryI]", " ", 
        SuperscriptBox["\[ExponentialE]", 
         RowBox[{
          RowBox[{"-", 
           FractionBox["1", "2"]}], " ", "\[ImaginaryI]", " ", "t", " ", 
          "\[Omega]"}]], " ", "\[CapitalOmega]", " ", 
        RowBox[{"Sin", "[", "\[Theta]", "]"}], " ", 
        RowBox[{"Sin", "[", 
         FractionBox[
          RowBox[{"t", " ", "\[CapitalLambda]"}], "2"], "]"}]}], 
       "\[CapitalLambda]"]}]}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"-", 
      FractionBox[
       RowBox[{"\[ImaginaryI]", " ", 
        SuperscriptBox["\[ExponentialE]", 
         FractionBox[
          RowBox[{"\[ImaginaryI]", " ", "t", " ", "\[Omega]"}], "2"]], " ", 
        "\[CapitalOmega]", " ", 
        RowBox[{"Sin", "[", "\[Theta]", "]"}], " ", 
        RowBox[{"Sin", "[", 
         FractionBox[
          RowBox[{"t", " ", "\[CapitalLambda]"}], "2"], "]"}]}], 
       "\[CapitalLambda]"]}], ",", 
     RowBox[{
      SuperscriptBox["\[ExponentialE]", 
       FractionBox[
        RowBox[{"\[ImaginaryI]", " ", "t", " ", "\[Omega]"}], "2"]], " ", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{"Cos", "[", 
         FractionBox[
          RowBox[{"t", " ", "\[CapitalLambda]"}], "2"], "]"}], "-", 
        FractionBox[
         RowBox[{"\[ImaginaryI]", " ", 
          RowBox[{"(", 
           RowBox[{"\[Omega]", "-", 
            RowBox[{"\[CapitalOmega]", " ", 
             RowBox[{"Cos", "[", "\[Theta]", "]"}]}]}], ")"}], " ", 
          RowBox[{"Sin", "[", 
           FractionBox[
            RowBox[{"t", " ", "\[CapitalLambda]"}], "2"], "]"}]}], 
         "\[CapitalLambda]"]}], ")"}]}]}], "}"}]}], "}"}]], "Output",
 CellChangeTimes->{{3.98053669511475*^9, 3.980536719092289*^9}, {
   3.9805367566628733`*^9, 3.980536810659183*^9}, 3.980536886291901*^9, 
   3.980538074007073*^9, 3.980539296749814*^9, 3.98053959818783*^9, 
   3.980539654639756*^9, 3.980539708468648*^9, 3.980553181414569*^9, 
   3.9805986363819923`*^9, 3.980601298251501*^9},
 CellLabel->"Out[42]=",ExpressionUUID->"7c84a159-1a51-44db-b259-1d9d2180afe8"]
}, Open  ]],

Cell[TextData[{
 "Cross-check that the unitary operator is the same as ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"U", "(", "t", ")"}], "=", 
    RowBox[{
     SuperscriptBox["\[ExponentialE]", 
      RowBox[{
       RowBox[{"-", "\[ImaginaryI]"}], " ", 
       FractionBox[
        RowBox[{"\[Omega]", " ", "t"}], "2"], 
       SubscriptBox["\[Sigma]", "z"]}]], 
     SuperscriptBox["\[ExponentialE]", 
      RowBox[{
       RowBox[{"-", "\[ImaginaryI]"}], " ", 
       FractionBox["t", "2"], 
       RowBox[{"(", 
        RowBox[{
         RowBox[{"\[CapitalOmega]", " ", "sin", " ", "\[Theta]", " ", 
          SubscriptBox["\[Sigma]", "x"]}], " ", "+", " ", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{
            RowBox[{"\[CapitalOmega]", " ", "cos", " ", "\[Theta]"}], " ", "-",
             "\[Omega]"}], ")"}], 
          SubscriptBox["\[Sigma]", "z"]}]}], ")"}]}]]}]}], TraditionalForm]],
  ExpressionUUID->"4d2870f2-6249-4668-a681-437cfddb9ac7"],
 ":"
}], "Text",
 CellChangeTimes->{{3.9805530608694468`*^9, 
  3.980553142012506*^9}},ExpressionUUID->"2fd8d9e8-c9a0-4263-b691-\
8ab4b39ff60f"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"FullSimplify", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"MatrixExp", "[", 
       RowBox[{
        RowBox[{"-", "\[ImaginaryI]"}], " ", "\[Omega]", " ", 
        RowBox[{"t", "/", "2"}], 
        RowBox[{"PauliMatrix", "[", "3", "]"}]}], "]"}], ".", 
      RowBox[{"MatrixExp", "[", 
       RowBox[{
        RowBox[{"-", "\[ImaginaryI]"}], " ", 
        RowBox[{"t", "/", "2"}], 
        RowBox[{"(", 
         RowBox[{
          RowBox[{"\[CapitalOmega]", " ", 
           RowBox[{"Sin", "[", "\[Theta]", "]"}], 
           RowBox[{"PauliMatrix", "[", "1", "]"}]}], "+", 
          RowBox[{
           RowBox[{"(", 
            RowBox[{
             RowBox[{"\[CapitalOmega]", " ", 
              RowBox[{"Cos", "[", "\[Theta]", "]"}]}], "-", "\[Omega]"}], 
            ")"}], 
           RowBox[{"PauliMatrix", "[", "3", "]"}]}]}], ")"}]}], "]"}]}], "/.", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{
        SqrtBox[
         RowBox[{
          SuperscriptBox["\[Omega]", "2"], "+", 
          SuperscriptBox["\[CapitalOmega]", "2"], "-", 
          RowBox[{"2", " ", "\[Omega]", " ", "\[CapitalOmega]", " ", 
           RowBox[{"Cos", "[", "\[Theta]", "]"}]}]}]], ":>", " ", 
        "\[CapitalLambda]"}], ",", 
       RowBox[{
        FractionBox["1", 
         SqrtBox[
          RowBox[{
           SuperscriptBox["\[Omega]", "2"], "+", 
           SuperscriptBox["\[CapitalOmega]", "2"], "-", 
           RowBox[{"2", " ", "\[Omega]", " ", "\[CapitalOmega]", " ", 
            RowBox[{"Cos", "[", "\[Theta]", "]"}]}]}]]], ":>", 
        FractionBox["1", "\[CapitalLambda]"]}]}], "}"}]}], "]"}], "-", 
   "unitary"}], "//", "FullSimplify"}]], "Input",
 CellChangeTimes->{{3.9805393371866503`*^9, 3.980539445014956*^9}, {
  3.98053954855515*^9, 3.980539551124763*^9}, {3.98053958718734*^9, 
  3.9805395873602037`*^9}, {3.9805396414173927`*^9, 3.98053965238518*^9}, {
  3.980553146638124*^9, 3.9805531700684137`*^9}},
 CellLabel->"In[43]:=",ExpressionUUID->"e88d92fc-a833-4eda-81ee-f16ed223d471"],

