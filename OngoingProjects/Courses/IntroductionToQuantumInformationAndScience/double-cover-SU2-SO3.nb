Cell[TextData[{
 "Define the loop Hamiltonian ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"H", "(", "t", ")"}], "=", 
    RowBox[{
     FractionBox["1", "2"], "\[CapitalOmega]", " ", 
     RowBox[{
      RowBox[{
       OverscriptBox["n", "\[RightVector]"], "(", "t", ")"}], ".", 
      OverscriptBox["\[Sigma]", "\[RightVector]"]}]}]}], TraditionalForm]],
  ExpressionUUID->"bade315f-3a52-432e-bb3f-2784ab45a711"],
 " with ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     OverscriptBox["n", "\[RightVector]"], "(", "t", ")"}], "=", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"sin", " ", "\[Theta]", " ", "cos", " ", 
       RowBox[{"\[Phi]", "(", "t", ")"}]}], ",", 
      RowBox[{"sin", " ", "\[Theta]", " ", "sin", " ", 
       RowBox[{"\[Phi]", "(", "t", ")"}]}], ",", 
      RowBox[{"cos", " ", "\[Theta]"}]}], "}"}]}], TraditionalForm]],
  ExpressionUUID->"7d799f51-2803-4259-a348-85d28a0b20f7"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"\[Phi]", "(", "t", ")"}], "=", 
    RowBox[{
     RowBox[{"2", "\[Pi]", " ", 
      RowBox[{"t", "/", "T"}]}], "=", 
     RowBox[{"\[Omega]", " ", "t"}]}]}], TraditionalForm]],ExpressionUUID->
  "7f3f16cc-d484-4fae-b1af-ef36cf99789f"],
 " where ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Omega]", "=", 
    RowBox[{"2", 
     RowBox[{"\[Pi]", "/", "T"}]}]}], TraditionalForm]],ExpressionUUID->
  "f589cf08-52ca-4067-9d60-62091caf08db"],
 ": "
}], "Text",
 CellChangeTimes->{{3.980552889334187*^9, 
  3.9805529494883432`*^9}},ExpressionUUID->"a6c78126-dbd8-4690-9f38-\
bf5daac63bb9"],

