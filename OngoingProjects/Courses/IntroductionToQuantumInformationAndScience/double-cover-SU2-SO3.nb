Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"MatrixExp", "[", 
   RowBox[{
    RowBox[{"-", "\[ImaginaryI]"}], " ", 
    RowBox[{"T", "/", "2"}], 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"\[CapitalOmega]", " ", 
       RowBox[{"Sin", "[", "\[Theta]", "]"}], 
       RowBox[{"PauliMatrix", "[", "1", "]"}]}], "+", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{
         RowBox[{"\[CapitalOmega]", " ", 
          RowBox[{"Cos", "[", "\[Theta]", "]"}]}], "-", "\[Omega]"}], ")"}], 
       RowBox[{"PauliMatrix", "[", "3", "]"}]}]}], ")"}]}], "]"}], "-", 
  RowBox[{"With", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"\[CapitalLambda]", "=", 
      SqrtBox[
       RowBox[{
        SuperscriptBox["\[CapitalOmega]", "2"], "+", 
        SuperscriptBox["\[Omega]", "2"], "-", 
        RowBox[{"2", "\[CapitalOmega]", " ", "\[Omega]", " ", 
         RowBox[{"Cos", "[", "\[Theta]", "]"}]}]}]]}], "}"}], ",", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"m", "=", 
       FractionBox[
        RowBox[{"{", 
         RowBox[{
          RowBox[{"\[CapitalOmega]", " ", 
           RowBox[{"Sin", "[", "\[Theta]", "]"}]}], ",", "0", ",", 
          RowBox[{
           RowBox[{"\[CapitalOmega]", " ", 
            RowBox[{"Cos", "[", "\[Theta]", "]"}]}], "-", "\[Omega]"}]}], 
         "}"}], "\[CapitalLambda]"]}], ",", 
      RowBox[{"\[Sigma]", "=", 
       RowBox[{"Table", "[", 
        RowBox[{
         RowBox[{"PauliMatrix", "[", "j", "]"}], ",", 
         RowBox[{"{", 
          RowBox[{"j", ",", "3"}], "}"}]}], "]"}]}]}], "}"}], ",", 
    RowBox[{"MatrixExp", "[", 
     RowBox[{
      RowBox[{"-", "\[ImaginaryI]"}], " ", "T", " ", 
      RowBox[{"\[CapitalLambda]", "/", "2"}], " ", 
      RowBox[{"m", ".", "\[Sigma]"}]}], "]"}]}], "]"}]}]], "Input",
 CellChangeTimes->{{3.980595630961595*^9, 3.980595780131754*^9}, {
  3.9805964593904943`*^9, 3.9805964638889112`*^9}, {3.980596515145906*^9, 
  3.9805965183676043`*^9}},
 CellLabel->"In[16]:=",ExpressionUUID->"1049f611-7374-4086-9876-1a94eaa6a239"],

