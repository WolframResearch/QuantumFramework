         RowBox[{"ColorData", "[", "97", "]"}], "[", "2", "]"}], ",", 
        RowBox[{"Opacity", "[", ".2", "]"}], ",", 
        RowBox[{"Cone", "[", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{
            RowBox[{"{", 
             RowBox[{"0", ",", "0", ",", 
              RowBox[{"Cos", "[", "\[Theta]", "]"}]}], "}"}], ",", 
            RowBox[{"{", 
             RowBox[{"0", ",", "0", ",", "0"}], "}"}]}], "}"}], ",", 
          RowBox[{"Sin", "[", "\[Theta]", "]"}]}], "]"}]}], "}"}], "]"}], ",", 
     RowBox[{"ParametricPlot3D", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{
          RowBox[{"Sin", "[", "\[Theta]", "]"}], 
          RowBox[{"Cos", "[", 
           RowBox[{"2", "\[Pi]", " ", "t"}], "]"}]}], ",", 
         RowBox[{
          RowBox[{"Sin", "[", "\[Theta]", "]"}], " ", 
          RowBox[{"Sin", "[", 
           RowBox[{"2", "\[Pi]", " ", "t"}], "]"}]}], ",", 
         RowBox[{"Cos", "[", "\[Theta]", "]"}]}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"t", ",", "0", ",", "tf"}], "}"}]}], "]"}]}], "]"}], ",", 
   RowBox[{"Item", "[", 
    RowBox[{"\"\<\!\(\*OverscriptBox[\(n\), \(\[RightVector]\)]\)(t)={sin \
\[Theta] cos \[Phi](t),sin \[Theta] sin \[Phi](t),cos \[Theta]}\>\"", ",", 
     RowBox[{"Alignment", "\[Rule]", "Center"}]}], "]"}], ",", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"\[Theta]", ",", 
       RowBox[{"\[Pi]", "/", "4"}], ",", "\"\<Polar angle \[Theta]\>\""}], 
      "}"}], ",", "0", ",", "\[Pi]"}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"tf", ",", 
       RowBox[{"10", "^", 
