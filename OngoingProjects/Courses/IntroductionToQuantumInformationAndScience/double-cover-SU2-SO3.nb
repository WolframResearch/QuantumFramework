Cell[BoxData[
 RowBox[{"unitary", "=", 
  RowBox[{"FullSimplify", "[", 
   RowBox[{"DSolveValue", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{
        RowBox[{"\[ImaginaryI]", " ", 
         RowBox[{"D", "[", 
          RowBox[{
           RowBox[{"u", "[", "t", "]"}], ",", "t"}], "]"}]}], "==", 
        RowBox[{"ham", ".", 
         RowBox[{"u", "[", "t", "]"}]}]}], ",", 
       RowBox[{
        RowBox[{"u", "[", "0", "]"}], "==", 
        RowBox[{"IdentityMatrix", "[", "2", "]"}]}]}], "}"}], ",", 
     RowBox[{
      RowBox[{"u", "[", "t", "]"}], "\[Element]", 
      RowBox[{"Matrices", "[", 
       RowBox[{"{", 
        RowBox[{"2", ",", "2"}], "}"}], "]"}]}], ",", "t"}], "]"}], 
   "]"}]}]], "Input",
