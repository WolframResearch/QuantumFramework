Cell[TextData[{
 "Solve dynamical equation for the corresponding unitary ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"\[ImaginaryI]", " ", 
     FractionBox[
      RowBox[{"\[DifferentialD]", "U"}], 
      RowBox[{"\[DifferentialD]", "t"}]]}], "=", 
    RowBox[{
     RowBox[{"H", "(", "t", ")"}], "U"}]}], TraditionalForm]],ExpressionUUID->
