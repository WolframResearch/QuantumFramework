Cell[TextData[{
 "After one loop (",
 Cell[BoxData[
  FormBox[
   RowBox[{"t", "=", "T"}], TraditionalForm]],ExpressionUUID->
  "c45c6d47-5722-4f48-a633-27153557caba"],
 "), the first term ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["\[ExponentialE]", 
    RowBox[{
     RowBox[{"-", "\[ImaginaryI]"}], " ", 
     FractionBox[
      RowBox[{"\[Omega]", " ", "t"}], "2"], 
     SubscriptBox["\[Sigma]", "z"]}]], TraditionalForm]],ExpressionUUID->
  "a35ae3bd-5e2f-4fb5-8aa6-b7c221cef4af"],
 " in the unitary operator ",
 Cell[BoxData[
  FormBox[
   RowBox[{"U", "(", "T", ")"}], TraditionalForm]],ExpressionUUID->
  "1cf0b3a5-f1ba-4e8c-98ef-12e3f482593b"],
 " becomes ",
 Cell[BoxData[
  FormBox[
   RowBox[{"-", "\[DoubleStruckCapitalI]"}], TraditionalForm]],ExpressionUUID->
  "9a82ae57-3675-4893-b64a-179169243afe"],
 ":"
}], "Text",
