Notebook[{

Cell[CellGroupData[{
Cell["\<\
Experimental Test of the Double Cover: Ramsey\[Dash]Berry Interferometric \
Protocol\
\>", "Subsubsection",
 CellChangeTimes->{{3.9805213594381104`*^9, 
  3.980521381106855*^9}},ExpressionUUID->"5cc0eb5f-c961-44a2-985a-\
2f85a0438578"],

Cell[TextData[{
 "In SU(2), a rotation around ",
 Cell[BoxData[
  FormBox["z", TraditionalForm]],ExpressionUUID->
  "853d9b70-de1c-458b-a446-33b5957eab80"],
 " corresponds to ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["\[ExponentialE]", 
    RowBox[{
     RowBox[{"-", "\[ImaginaryI]"}], " ", 
     FractionBox["\[CapitalOmega]", "2"], 
     SubscriptBox["\[Sigma]", "z"]}]], TraditionalForm]],ExpressionUUID->
  "a3d6a65c-683f-4813-96ce-49ab38c0b6f8"],
 ". This implies ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox["\[ExponentialE]", 
     RowBox[{
      RowBox[{"-", "\[ImaginaryI]"}], " ", 
      FractionBox[
       RowBox[{"2", "\[Pi]"}], "2"], 
      SubscriptBox["\[Sigma]", "z"]}]], "=", 
    RowBox[{"-", "\[DoubleStruckCapitalI]"}]}], TraditionalForm]],
  ExpressionUUID->"7e35d146-f8c0-44c3-a09a-106758bf4936"],
 " while ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox["\[ExponentialE]", 
     RowBox[{
      RowBox[{"-", "\[ImaginaryI]"}], " ", 
      FractionBox[
       RowBox[{"4", "\[Pi]"}], "2"], 
      SubscriptBox["\[Sigma]", "z"]}]], "=", "\[DoubleStruckCapitalI]"}], 
   TraditionalForm]],ExpressionUUID->"ba7a9b5b-9dfa-4d02-a0c5-40240ba3f1a5"],
 "."
}], "Text",
 CellChangeTimes->{{3.980524652450007*^9, 3.980524759937119*^9}, {
  3.9805252419133987`*^9, 
  3.9805252426156263`*^9}},ExpressionUUID->"5a9d1a75-16eb-477f-86f2-\
23c7996e938d"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"MatrixForm", "[", 
    RowBox[{"MatrixExp", "[", 
     RowBox[{
      RowBox[{"-", "\[ImaginaryI]"}], " ", 
      FractionBox["#", "2"], 
      RowBox[{"PauliMatrix", "[", "3", "]"}]}], "]"}], "]"}], "&"}], "/@", 
  RowBox[{"{", 
   RowBox[{
    RowBox[{"2", "\[Pi]"}], ",", 
    RowBox[{"4", "\[Pi]"}]}], "}"}]}]], "Input",
 CellChangeTimes->{{3.980524606613227*^9, 3.9805246441743183`*^9}},
 CellLabel->"In[60]:=",ExpressionUUID->"1f5bca74-71f3-4566-bf8c-36ce17dc5880"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   TagBox[
    RowBox[{"(", "\[NoBreak]", GridBox[{
       {
        RowBox[{"-", "1"}], "0"},
       {"0", 
        RowBox[{"-", "1"}]}
      },
      GridBoxAlignment->{"Columns" -> {{Center}}, "Rows" -> {{Baseline}}},
      GridBoxSpacings->{"Columns" -> {
          Offset[0.27999999999999997`], {
           Offset[0.7]}, 
          Offset[0.27999999999999997`]}, "Rows" -> {
          Offset[0.2], {
           Offset[0.4]}, 
          Offset[0.2]}}], "\[NoBreak]", ")"}],
    Function[BoxForm`e$, 
     MatrixForm[BoxForm`e$]]], ",", 
   TagBox[
    RowBox[{"(", "\[NoBreak]", GridBox[{
       {"1", "0"},
       {"0", "1"}
      },
      GridBoxAlignment->{"Columns" -> {{Center}}, "Rows" -> {{Baseline}}},
      GridBoxSpacings->{"Columns" -> {
          Offset[0.27999999999999997`], {
           Offset[0.7]}, 
          Offset[0.27999999999999997`]}, "Rows" -> {
          Offset[0.2], {
           Offset[0.4]}, 
          Offset[0.2]}}], "\[NoBreak]", ")"}],
    Function[BoxForm`e$, 
     MatrixForm[BoxForm`e$]]]}], "}"}]], "Output",
 CellChangeTimes->{{3.9805246089938173`*^9, 3.980524644543154*^9}},
 CellLabel->"Out[60]=",ExpressionUUID->"57f7187d-0324-4371-8d53-d0788f0f4dd2"]
}, Open  ]],

Cell[TextData[{
 "On the other hand, in SO(3) the ",
 Cell[BoxData[
  FormBox["z", TraditionalForm]],ExpressionUUID->
  "fd89b3dc-37be-44d7-a068-863e9632e70a"],
 "-rotation by the angle ",
 Cell[BoxData[
  FormBox[
   RowBox[{"2", "\[Pi]"}], TraditionalForm]],ExpressionUUID->
  "2fa97ef5-0688-4ad7-ba3c-b27097360b69"],
 " reproduces identify:"
}], "Text",
 CellChangeTimes->{{3.980525273672521*^9, 3.980525317193757*^9}, {
  3.9805258081701202`*^9, 
  3.980525813958611*^9}},ExpressionUUID->"3acc25ce-bea6-4b23-b703-\
25852879ee66"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"RotationMatrix", "[", 
   RowBox[{
    RowBox[{"2", "\[Pi]"}], ",", 
    RowBox[{"{", 
     RowBox[{"0", ",", "0", ",", "1"}], "}"}]}], "]"}], "//", 
  "MatrixForm"}]], "Input",
 CellChangeTimes->{{3.9805252591164417`*^9, 3.98052527175194*^9}},
 CellLabel->"In[69]:=",ExpressionUUID->"ef81fcda-4ef1-4bdb-9546-df2aca1bcdf8"],

Cell[BoxData[
 TagBox[
  RowBox[{"(", "\[NoBreak]", GridBox[{
     {"1", "0", "0"},
     {"0", "1", "0"},
     {"0", "0", "1"}
    },
    GridBoxAlignment->{"Columns" -> {{Center}}, "Rows" -> {{Baseline}}},
    GridBoxSpacings->{"Columns" -> {
        Offset[0.27999999999999997`], {
         Offset[0.7]}, 
        Offset[0.27999999999999997`]}, "Rows" -> {
        Offset[0.2], {
         Offset[0.4]}, 
        Offset[0.2]}}], "\[NoBreak]", ")"}],
  Function[BoxForm`e$, 
   MatrixForm[BoxForm`e$]]]], "Output",
 CellChangeTimes->{{3.980525268680717*^9, 3.980525271955895*^9}},
 CellLabel->
  "Out[69]//MatrixForm=",ExpressionUUID->"052f18fe-a58d-46ae-8b59-\
e8c22e0910ec"]
}, Open  ]],

Cell["That\[CloseCurlyQuote]s the double-cover statement. ", "Text",
 CellChangeTimes->{
  3.980524768540299*^9, {3.980599048901449*^9, 
   3.980599049389308*^9}},ExpressionUUID->"2075a31b-d6e4-4ada-a9d5-\
009666075bf6"],

Cell[TextData[{
 "Consider a sequence of pulses as ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["X", 
     RowBox[{"\[Pi]", "/", "2"}]], "->", 
    RowBox[{
     SubscriptBox["Z", "\[Gamma]"], "->", 
     SubscriptBox["X", 
      RowBox[{
       RowBox[{"-", "\[Pi]"}], "/", "2"}]]}]}], TraditionalForm]],
  ExpressionUUID->"776ff1c1-f76e-462f-8462-7300acc9e155"],
 " which corresponds to textbook Ramsey interferometer. Assuming a qubit is \
prepared in an initial state ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{"0"},
    "Ket"], TraditionalForm]],ExpressionUUID->
  "fffc6f46-1b04-4ce4-a9b2-8d95e3860a15"],
 ", the final state vector after this sequence of pulses given by:"
}], "Text",
 CellChangeTimes->{{3.980594950572753*^9, 3.980594981166017*^9}, {
  3.9805950273629932`*^9, 3.980595034958926*^9}, {3.980595080793747*^9, 
  3.980595095454702*^9}, {3.9805951578126783`*^9, 3.980595221466599*^9}, {
  3.980596031172536*^9, 3.980596044597664*^9}, {3.9805960943919888`*^9, 
  3.980596117730899*^9}, {3.980596294790875*^9, 3.980596298283332*^9}, {
  3.980596370655286*^9, 
  3.980596380614393*^9}},ExpressionUUID->"e60de36e-6d6d-49e2-8adb-\
301b402ff544"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"FullSimplify", "@", 
  RowBox[{"Fold", "[", 
   RowBox[{
    RowBox[{
     RowBox[{"#2", ".", "#1"}], "&"}], ",", 
    RowBox[{"{", 
     RowBox[{"1", ",", "0"}], "}"}], ",", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"MatrixExp", "[", 
       RowBox[{
        RowBox[{"-", "\[ImaginaryI]"}], 
        FractionBox[
         RowBox[{"\[Pi]", "/", "2"}], "2"], 
        RowBox[{"PauliMatrix", "[", "1", "]"}]}], "]"}], ",", 
      RowBox[{"MatrixExp", "[", 
       RowBox[{
        RowBox[{"-", "\[ImaginaryI]"}], 
        FractionBox["\[Gamma]", "2"], 
        RowBox[{"PauliMatrix", "[", "3", "]"}]}], "]"}], ",", 
      RowBox[{"MatrixExp", "[", 
       RowBox[{
        RowBox[{"-", "\[ImaginaryI]"}], 
        FractionBox[
         RowBox[{
          RowBox[{"-", "\[Pi]"}], "/", "2"}], "2"], 
        RowBox[{"PauliMatrix", "[", "1", "]"}]}], "]"}]}], "}"}]}], 
   "]"}]}]], "Input",
 CellChangeTimes->{{3.980595000310629*^9, 3.980595024893821*^9}, {
  3.980595099290798*^9, 3.9805951404125032`*^9}, {3.980596062337446*^9, 
  3.980596092083808*^9}, {3.980596300389002*^9, 3.980596305703157*^9}, {
  3.980596383024891*^9, 3.980596385123682*^9}},
 CellLabel->"In[60]:=",ExpressionUUID->"c51005aa-7ca0-40c1-a327-225d16bb17a1"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{"Cos", "[", 
    FractionBox["\[Gamma]", "2"], "]"}], ",", 
   RowBox[{"Sin", "[", 
    FractionBox["\[Gamma]", "2"], "]"}]}], "}"}]], "Output",
 CellChangeTimes->{{3.9805951283807096`*^9, 3.980595140670446*^9}, 
   3.980596122250537*^9, 3.9805963065411263`*^9, 3.980596385693182*^9},
 CellLabel->"Out[60]=",ExpressionUUID->"231b0abb-e4f2-4a49-a6ef-57073036a32c"]
}, Open  ]],

Cell[TextData[{
 "The above formula implies that the probability of observing ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{"1"},
    "Ket"], TraditionalForm]],ExpressionUUID->
  "31b3250c-5acc-4c9d-9f06-356643cc2f80"],
 " is ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["P", 
     TemplateBox[{"1"},
      "Ket"]], "=", 
    RowBox[{
     SuperscriptBox["sin", "2"], "(", 
     RowBox[{"\[Gamma]", "/", "2"}], ")"}]}], TraditionalForm]],
  ExpressionUUID->"99a3853d-7f61-4e83-bf53-81cccc51fb7f"],
 ". So as a function of the SU(2) rotation angle \[Gamma], you will see a 2\
\[Pi] periodic signal in single-qubit populations, as shown below."
}], "Text",
 CellChangeTimes->{{3.980595225822029*^9, 3.980595268994602*^9}, {
  3.980599838215707*^9, 
  3.980599864018351*^9}},ExpressionUUID->"83d58b43-5bf0-4463-a954-\
fbbd3d23782a"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Plot", "[", 
  RowBox[{
   RowBox[{
    RowBox[{"Sin", "[", 
     RowBox[{"\[Gamma]", "/", "2"}], "]"}], "^", "2"}], ",", 
   RowBox[{"{", 
    RowBox[{"\[Gamma]", ",", "0", ",", 
     RowBox[{"4", "\[Pi]"}]}], "}"}], ",", 
   RowBox[{
   "PlotLabel", 
    "->", "\"\<Probability of \!\(\*TemplateBox[{\"1\"},\"Ket\"]\) vs SU(2) \
Rotation Angle\>\""}], ",", 
   RowBox[{"AspectRatio", "->", 
    RowBox[{"1", "/", "2"}]}], ",", 
   RowBox[{"Frame", "->", "True"}], ",", 
   RowBox[{"FrameLabel", "->", 
    RowBox[{"{", 
     RowBox[{"\"\<\[Gamma]\>\"", ",", 
      " ", "\"\<Probability of \!\(\*TemplateBox[{\"1\"},\"Ket\"]\)\>\""}], 
     "}"}]}], ",", 
   RowBox[{"FrameTicks", "->", 
    RowBox[{"{", 
     RowBox[{"Automatic", ",", " ", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"Range", "[", 
         RowBox[{"0", ",", 
          RowBox[{"4", "\[Pi]"}], ",", 
          RowBox[{"\[Pi]", "/", "2"}]}], "]"}], ",", " ", "None"}], "}"}]}], 
     "}"}]}], ",", 
   RowBox[{"GridLines", "->", "All"}]}], "]"}]], "Input",
 CellChangeTimes->{{3.980524823796878*^9, 3.980524849790024*^9}, {
  3.980524925730748*^9, 3.9805249462881927`*^9}, {3.980525208875568*^9, 
  3.980525211617695*^9}, {3.9805997346355667`*^9, 3.980599816316559*^9}, {
  3.980599873360076*^9, 3.980599898469631*^9}},
 CellLabel->"In[27]:=",ExpressionUUID->"e3b4c9f3-55bc-4be4-a49f-7a296a3d5980"],

