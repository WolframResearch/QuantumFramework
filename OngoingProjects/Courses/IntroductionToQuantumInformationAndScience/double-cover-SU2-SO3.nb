48d690e76f59"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"MatrixExp", "[", 
   RowBox[{
    RowBox[{"-", "\[ImaginaryI]"}], " ", 
    FractionBox[
     RowBox[{"\[Omega]", " ", "t"}], "2"], " ", 
    RowBox[{"PauliMatrix", "[", "3", "]"}]}], "]"}], "/.", 
  RowBox[{"{", 
   RowBox[{
    RowBox[{"\[Omega]", "->", 
