Cell[BoxData[{
 RowBox[{"ClearAll", "[", 
  RowBox[{
  "\[Alpha]", ",", " ", "\[Phi]", ",", " ", "\[Theta]", ",", " ", "rx", ",", 
   " ", "ry", ",", " ", "rz"}], "]"}], "\n", 
 RowBox[{"vSU2", " ", "=", " ", 
  RowBox[{"With", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"n", " ", "=", " ", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{
         RowBox[{"Cos", "[", "\[Phi]", "]"}], " ", 
         RowBox[{"Sin", "[", "\[Theta]", "]"}]}], ",", " ", 
        RowBox[{
         RowBox[{"Sin", "[", "\[Phi]", "]"}], " ", 
         RowBox[{"Sin", "[", "\[Theta]", "]"}]}], ",", "\n", "      ", 
        RowBox[{"Cos", "[", "\[Theta]", "]"}]}], "}"}]}], "}"}], ",", " ", 
    RowBox[{"{", 
     RowBox[{"\[Sigma]", " ", "=", " ", "\n", "    ", 
      RowBox[{"Table", "[", 
       RowBox[{
        RowBox[{"PauliMatrix", "[", "j", "]"}], ",", " ", 
        RowBox[{"{", 
         RowBox[{"j", ",", " ", "3"}], "}"}]}], "]"}]}], "}"}], ",", " ", 
    RowBox[{"{", 
     RowBox[{"u", " ", "=", " ", "\n", "    ", 
      RowBox[{"FullSimplify", "@", 
       RowBox[{"MatrixExp", "[", 
        RowBox[{
         RowBox[{"-", "I"}], " ", 
         RowBox[{"\[Alpha]", "/", "2"}], " ", 
         RowBox[{"n", " ", ".", " ", "\[Sigma]"}]}], "]"}]}]}], "}"}], ",", 
    " ", 
    RowBox[{"{", 
     RowBox[{"\[Rho]", " ", "=", " ", "\n", "    ", 
      RowBox[{"DensityMatrix", "[", 
       RowBox[{"{", 
        RowBox[{"rx", ",", " ", "ry", ",", " ", "rz"}], "}"}], "]"}]}], "}"}],
     ",", " ", "\n", "  ", 
    RowBox[{"FullSimplify", "[", "\n", "   ", 
     RowBox[{
      RowBox[{"BlochVector", "[", "\n", "    ", 
       RowBox[{"u", " ", ".", " ", "\[Rho]", " ", ".", " ", "\n", "     ", 
        RowBox[{"ConjugateTranspose", "[", "u", "]"}]}], "]"}], ",", " ", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{
        "\[Theta]", " ", "|", " ", "\[Phi]", " ", "|", " ", "\[Alpha]", " ", "|",
          " ", "rx", " ", "|", " ", "ry", " ", "|", "\n", "       ", "rz"}], 
        ")"}], " ", "\[Element]", " ", "Reals"}]}], "]"}]}], 
   "]"}]}]}], "Input",
 CellLabel->
  "In[172]:= ",ExpressionUUID->"8a16c499-5d66-4485-add4-f4e372291380"],

