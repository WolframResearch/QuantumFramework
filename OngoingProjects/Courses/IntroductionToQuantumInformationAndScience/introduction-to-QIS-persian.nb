Cell[BoxData[
 RowBox[{"Manipulate", "[", "\n", " ", 
  RowBox[{
   RowBox[{"Show", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"ResourceFunction", "[", "\"\<BlochSpherePlot\>\"", "]"}], "[", 
      
      RowBox[{
       RowBox[{"{", 
        RowBox[{"0", ",", " ", 
         RowBox[{"-", 
          RowBox[{"Sin", "[", "t", "]"}]}], ",", " ", "\n", "    ", 
         RowBox[{"Cos", "[", "t", " ", "]"}]}], "}"}], ",", " ", "\n", "   ", 
       
       RowBox[{"PlotLabel", " ", "->", " ", "\n", "    ", 
        RowBox[{"\"\<Rotation angle is Subscript[\[Omega], x] t = \>\"", " ", 
         "<>", " ", "\n", "     ", 
         RowBox[{"ToString", "[", 
          RowBox[{"t", "/", "\[Pi]"}], "]"}], " ", "<>", 
         " ", "\"\<\[Pi]\>\""}]}], ",", " ", 
       RowBox[{"ImageSize", " ", "->", " ", "200"}]}], "]"}], ",", " ", "\n", 
     "  ", 
     RowBox[{"Graphics3D", "[", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"Opacity", "[", ".5", "]"}], ",", " ", 
        RowBox[{
         RowBox[{"ColorData", "[", "97", "]"}], "[", "2", "]"}], ",", " ", 
        "\n", "    ", 
        RowBox[{"Polygon", "[", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{"0", ",", " ", "0", ",", " ", "0"}], "}"}], ",", " ", 
           RowBox[{
            RowBox[{"{", 
             RowBox[{"0", ",", " ", "0", ",", " ", "1"}], "}"}], "/", "2"}], ",",
            " ", "\n", "      ", 
           RowBox[{"Sequence", " ", "@@", " ", "\n", "       ", 
            RowBox[{"Table", "[", 
             RowBox[{
              RowBox[{
               RowBox[{"{", 
                RowBox[{"0", ",", " ", 
                 RowBox[{"-", 
                  RowBox[{"Sin", "[", "\[Theta]", "]"}]}], ",", " ", 
                 RowBox[{"Cos", "[", "\[Theta]", " ", "]"}]}], "}"}], "/", 
               "2"}], ",", " ", 
              RowBox[{"{", 
               RowBox[{"\[Theta]", ",", " ", "\n", "         ", 
                RowBox[{"Range", "[", 
                 RowBox[{"0", ",", " ", "t", ",", " ", 
                  RowBox[{"t", "/", "100"}]}], "]"}]}], "}"}]}], "]"}]}]}], 
          "}"}], "]"}]}], "}"}], "]"}], ",", " ", 
     RowBox[{"Boxed", " ", "->", " ", "False"}]}], "]"}], ",", " ", "\n", " ", 
   RowBox[{
   "Item", "[", "\"\<Bloch-vector trajectory for \
H=\\!\\(\\*FractionBox[\\(1\\), \
\\(2\\)]\\)\\!\\(\\*SubscriptBox[\\(\[Omega]\\), \
\\(x\\)]\\)\\!\\(\\*SubscriptBox[\\(\[Sigma]\\), \\(x\\)]\\)\>\"", "]"}], ",",
    " ", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
      "t", ",", " ", "0", ",", " ", "\n", 
       "   ", "\"\<\\!\\(\\*SubscriptBox[\\(\[Omega]\\), \\(x\\)]\\)t\>\""}], 
      "}"}], ",", " ", "0", ",", " ", 
     RowBox[{"2", " ", "\[Pi]"}]}], "}"}]}], "]"}]], "Input",
 CellLabel->
  "In[237]:= ",ExpressionUUID->"a8e93d45-d5da-4547-b739-885ba6c3b4ba"],

