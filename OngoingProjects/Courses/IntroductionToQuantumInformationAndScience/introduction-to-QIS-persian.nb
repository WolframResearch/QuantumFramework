Cell[BoxData[
 RowBox[{"Manipulate", "[", 
  RowBox[{
   RowBox[{"Show", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"ResourceFunction", "[", "\"\<BlochSpherePlot\>\"", "]"}], "[", 
      
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"1", ",", " ", "0", ",", " ", "0"}], "}"}], ",", " ", "\n", 
         "    ", 
         RowBox[{
          RowBox[{"RotationMatrix", "[", 
           RowBox[{"\[Theta]", ",", " ", 
            RowBox[{"{", 
             RowBox[{"0", ",", " ", "0", ",", " ", "1"}], "}"}]}], "]"}], " ",
           ".", " ", 
          RowBox[{"{", 
           RowBox[{"1", ",", " ", "0", ",", " ", "0"}], "}"}]}]}], "}"}], ",",
        " ", "\n", "   ", 
       RowBox[{"ImageSize", " ", "->", " ", "270"}], ",", " ", "\n", "   ", 
       RowBox[{
       "PlotLabel", " ", "->", 
        " ", "\"\<Rotation around z-axis by angle \[Theta]\n\>\""}]}], "]"}], 
     ",", " ", "\n", "  ", 
     RowBox[{"Graphics3D", "[", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"Opacity", "[", ".5", "]"}], ",", " ", "\n", "    ", 
        RowBox[{"Polygon", "[", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{"0", ",", " ", "0", ",", " ", "0"}], "}"}], ",", " ", 
           "\n", "      ", 
           RowBox[{"Sequence", " ", "@@", " ", "\n", "       ", 
            RowBox[{"Table", "[", 
             RowBox[{
              RowBox[{"{", 
               RowBox[{
                RowBox[{"Cos", "[", "th", "]"}], ",", " ", 
                RowBox[{"Sin", "[", "th", "]"}], ",", " ", "0"}], "}"}], ",", 
              " ", 
              RowBox[{"{", 
               RowBox[{"th", ",", " ", "\n", "         ", 
                RowBox[{"Range", "[", 
                 RowBox[{"0", ",", " ", "\[Theta]", ",", " ", 
                  RowBox[{"\[Theta]", "/", "100"}]}], "]"}]}], "}"}]}], 
             "]"}]}]}], "}"}], "]"}]}], "}"}], "]"}]}], "]"}], ",", " ", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
      "\[Theta]", ",", " ", "1", ",", " ", "\n", 
       "   ", "\"\<Rotation angle \[Theta]\>\""}], "}"}], ",", " ", "0", ",", 
     " ", 
     RowBox[{"2", " ", "\[Pi]"}]}], "}"}]}], "]"}]], "Input",
 CellLabel->
  "In[183]:= ",ExpressionUUID->"8d7ac7d4-117b-4ee2-97cd-cc5ab7d5dd5e"],

