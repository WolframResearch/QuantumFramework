             RowBox[{"m", " ", "-", " ", 
              RowBox[{"Sqrt", "[", "v", "]"}]}], ",", " ", "\n", 
             "      ", "\"\<\[LeftAngleBracket]\\!\\(\\*SubscriptBox[\\(X\\), \
\\(t\\)]\\)\[RightAngleBracket]-\[Sigma]\>\""}], "}"}], ",", " ", 
           RowBox[{"{", 
