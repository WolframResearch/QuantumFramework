      RowBox[{
       RowBox[{"Cos", "[", 
        RowBox[{"\[Alpha]", "/", "2"}], "]"}], " ", 
       RowBox[{"IdentityMatrix", "[", "2", "]"}]}], " ", "-", " ", "\n", 
      "    ", 
      RowBox[{"I", " ", 
       RowBox[{"Sin", "[", 
        RowBox[{"\[Alpha]", "/", "2"}], "]"}], " ", 
