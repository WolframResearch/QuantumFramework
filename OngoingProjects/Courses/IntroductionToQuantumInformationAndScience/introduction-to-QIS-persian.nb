Cell[BoxData[
 RowBox[{"FullSimplify", "[", "\n", " ", 
  RowBox[{
   RowBox[{"With", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"\[CapitalOmega]", " ", "=", " ", 
       RowBox[{"Sqrt", "[", 
        RowBox[{
         RowBox[{"\[Omega]x", "^", "2"}], " ", "+", " ", 
         RowBox[{"\[Omega]z", "^", "2"}]}], "]"}]}], "}"}], ",", " ", "\n", 
     "  ", 
     RowBox[{
      RowBox[{
       RowBox[{"RotationMatrix", "[", 
        RowBox[{
         RowBox[{"\[CapitalOmega]", " ", "t"}], ",", " ", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{
           "\[Omega]x", ",", " ", "\n", "      ", "0", ",", " ", 
            "\[Omega]z"}], "}"}], "/", "\[CapitalOmega]"}]}], "]"}], " ", ".",
        " ", 
       RowBox[{"{", 
        RowBox[{"0", ",", " ", "0", ",", " ", "\n", "     ", "1"}], "}"}]}], 
      " ", "==", " ", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"-", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{"(", 
            RowBox[{"\[Omega]x", " ", "\[Omega]z", " ", 
             RowBox[{"(", 
              RowBox[{
               RowBox[{"-", "1"}], " ", "+", " ", "\n", "        ", 
               RowBox[{"Cos", "[", 
                RowBox[{"t", " ", "\[CapitalOmega]"}], "]"}]}], ")"}]}], 
            ")"}], "/", 
           RowBox[{"\[CapitalOmega]", "^", "2"}]}], ")"}]}], ",", " ", 
        RowBox[{"-", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{"(", 
            RowBox[{"\[Omega]x", " ", 
             RowBox[{"Sin", "[", "\n", "       ", 
              RowBox[{"t", " ", "\[CapitalOmega]"}], "]"}]}], ")"}], "/", 
           "\[CapitalOmega]"}], ")"}]}], ",", " ", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{
           RowBox[{"\[Omega]z", "^", "2"}], " ", "+", " ", 
           RowBox[{
            RowBox[{
             RowBox[{"\\\n", "\[Omega]x"}], "^", "2"}], " ", 
            RowBox[{"Cos", "[", "\n", "       ", 
             RowBox[{"t", " ", "\[CapitalOmega]"}], "]"}]}]}], ")"}], "/", 
         RowBox[{"\[CapitalOmega]", "^", "2"}]}]}], "}"}]}]}], "]"}], ",", 
   " ", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{"\[Omega]x", " ", "|", " ", 
      RowBox[{"\\\n", "\[Omega]z"}], " ", "|", " ", "\[CapitalOmega]"}], 
     ")"}], " ", "\[Element]", " ", "Reals"}]}], "]"}]], "Input",
 CellLabel->
  "In[244]:= ",ExpressionUUID->"f8b6f7b5-af1f-4e25-b472-d62be1a3da3d"],

