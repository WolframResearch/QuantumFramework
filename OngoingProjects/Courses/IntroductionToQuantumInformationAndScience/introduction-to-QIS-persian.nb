Cell[BoxData[
 RowBox[{
  RowBox[{"newABForIto", " ", "=", " ", "\n", "  ", 
   RowBox[{"FullSimplify", "[", "\n", "   ", 
    RowBox[{
     RowBox[{
      RowBox[{"With", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{
          RowBox[{"a", " ", "=", " ", "nonRandomTermsCollapseSDE"}], ",", " ",
           "\n", "      ", 
          RowBox[{"b", " ", "=", " ", "randomTermsCollapseSDE"}]}], "}"}], ",",
         " ", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{
           RowBox[{"jacobian", " ", ".", " ", "a"}], " ", "+", " ", "\n", 
           "       ", 
           RowBox[{
            RowBox[{
             RowBox[{"Transpose", "[", "b", "]"}], " ", ".", " ", 
             RowBox[{"Transpose", "[", "hessian", "]"}], " ", ".", " ", "b"}],
             "/", "2"}]}], ",", " ", 
          RowBox[{"jacobian", " ", ".", " ", "b"}]}], "}"}]}], "]"}], " ", "/.",
       " ", "\n", "    ", 
      RowBox[{"Thread", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"x", ",", " ", "y", ",", " ", "z"}], "}"}], " ", "->", " ", 
        RowBox[{"FromSphericalCoordinates", "[", 
         RowBox[{"{", 
          RowBox[{"r", ",", " ", "\[Theta]", ",", " ", "\[Phi]"}], "}"}], 
         "]"}]}], "]"}]}], ",", "\n", "    ", 
     RowBox[{
      RowBox[{"0", " ", "<=", " ", "r", " ", "<=", " ", "1"}], " ", "&&", " ", 
      RowBox[{"0", " ", "<=", " ", "\[Theta]", " ", "<=", " ", "\[Pi]"}], " ",
       "&&", " ", 
      RowBox[{"0", " ", "<=", " ", "\[Phi]", " ", "<=", " ", 
       RowBox[{"2", " ", "\[Pi]"}]}]}]}], "]"}]}], ";"}]], "Input",
 CellLabel->
  "In[307]:= ",ExpressionUUID->"239a87ae-51f8-4aa3-b01a-3775b85cbc2d"],

