Cell[BoxData[
 RowBox[{"With", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"\[Eta]", " ", "=", " ", ".75"}], "}"}], ",", " ", 
   RowBox[{"Show", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"ResourceFunction", "[", "\"\<BlochSpherePlot\>\"", "]"}], "[", 
      
      RowBox[{"ImageSize", " ", "->", " ", "250"}], "]"}], ",", "\n", "   ", 
     RowBox[{"ParametricPlot3D", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{
          RowBox[{"Cos", "[", "\[Phi]", "]"}], " ", 
          RowBox[{"Sin", "[", "\[Theta]", "]"}]}], ",", " ", "\n", "    ", 
         RowBox[{
          RowBox[{"Sin", "[", "\[Phi]", "]"}], " ", 
          RowBox[{"Sin", "[", "\[Theta]", "]"}], " ", 
          RowBox[{"Sqrt", "[", 
           RowBox[{"1", " ", "-", " ", 
            RowBox[{"\[Eta]", "^", "2"}]}], "]"}]}], ",", " ", "\n", "    ", 
         RowBox[{
          RowBox[{"Cos", "[", "\[Theta]", "]"}], " ", 
          RowBox[{"Sqrt", "[", 
           RowBox[{"1", " ", "-", " ", 
            RowBox[{"\[Eta]", "^", "2"}]}], "]"}]}]}], "}"}], ",", " ", 
       RowBox[{"{", 
        RowBox[{"\[Theta]", ",", " ", "0", ",", " ", "\[Pi]"}], "}"}], ",", 
       " ", 
       RowBox[{"{", 
        RowBox[{"\[Phi]", ",", " ", "\n", "    ", "0", ",", " ", 
         RowBox[{"2", " ", "\[Pi]"}]}], "}"}], ",", " ", 
       RowBox[{"Boxed", " ", "->", " ", "False"}], ",", " ", 
       RowBox[{"Axes", " ", "->", " ", "False"}], ",", " ", 
       RowBox[{"PlotPoints", " ", "->", " ", "25"}], ",", " ", "\n", "   ", 
       RowBox[{"PlotStyle", " ", "->", " ", 
        RowBox[{"Opacity", "[", ".5", "]"}]}]}], "]"}], ",", " ", "\n", "  ", 
     
     RowBox[{
     "PlotLabel", " ", "->", " ", "\n", 
      "   ", "\"\<Transformed space of states due to\n unsharpe/weak Pauli-X \
measurement\n with the sharpness/strength \[Eta]=0.75\>\""}]}], "]"}]}], 
  "]"}]], "Input",
 CellLabel->
  "In[224]:= ",ExpressionUUID->"70710534-6e3d-4f6c-a8a4-ab3efba10b14"],

