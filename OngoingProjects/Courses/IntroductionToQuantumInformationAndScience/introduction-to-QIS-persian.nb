Cell[BoxData[
 RowBox[{"Manipulate", "[", "\n", " ", 
  RowBox[{
   RowBox[{"Plot", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{
        RowBox[{"1", "/", "4"}], " ", 
        RowBox[{"E", "^", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{
            RowBox[{"-", "\[Kappa]"}], " ", 
            RowBox[{"(", 
             RowBox[{
              RowBox[{"4", " ", "t"}], " ", "+", " ", "\[Tau]"}], ")"}]}], 
           " ", "-", " ", "\n", "     ", 
           RowBox[{"I", " ", 
            RowBox[{"(", 
             RowBox[{
              RowBox[{"2", " ", "t"}], " ", "+", " ", "\[Tau]"}], ")"}], " ", 
            "\[Omega]0"}]}], ")"}]}], " ", 
        RowBox[{"(", 
         RowBox[{"1", " ", "+", " ", 
          RowBox[{"E", "^", 
           RowBox[{"(", "\n", "      ", 
            RowBox[{"2", " ", "I", " ", 
             RowBox[{"(", 
              RowBox[{
               RowBox[{"2", " ", "t"}], " ", "+", " ", "\[Tau]"}], ")"}], " ",
              "\[Omega]0"}], ")"}]}], " ", "+", " ", "\n", "      ", 
          RowBox[{
           RowBox[{"E", "^", 
            RowBox[{"(", 
             RowBox[{
              RowBox[{"4", " ", "t", " ", "\[Kappa]"}], " ", "+", " ", "\n", 
              "        ", 
              RowBox[{"2", " ", "I", " ", "t", " ", "\[Omega]0"}]}], ")"}]}], 
           " ", 
           RowBox[{"(", 
            RowBox[{"1", " ", "+", " ", 
             RowBox[{"E", "^", 
              RowBox[{"(", 
               RowBox[{"2", " ", "I", " ", "\[Tau]", " ", "\[Omega]0"}], 
               ")"}]}]}], ")"}]}]}], ")"}]}], ",", " ", "\n", "   ", 
       RowBox[{
        RowBox[{"1", "/", "2"}], " ", 
        RowBox[{"E", "^", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{"-", "\[Kappa]"}], " ", "\[Tau]"}], ")"}]}], " ", 
        RowBox[{"Cos", "[", 
         RowBox[{"\[Omega]0", " ", "\[Tau]"}], "]"}]}]}], "}"}], ",", " ", 
     RowBox[{"{", 
      RowBox[{"\[Tau]", ",", " ", "0", ",", " ", "10"}], "}"}], ",", " ", 
     "\n", "  ", 
     RowBox[{"PlotRange", " ", "->", " ", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"-", "1.1"}], ",", " ", "1.1"}], "}"}]}], ",", " ", 
     RowBox[{"GridLines", " ", "->", " ", "Automatic"}], ",", " ", 
     RowBox[{"Frame", " ", "->", " ", "True"}], ",", " ", "\n", "  ", 
     RowBox[{"PlotPoints", " ", "->", " ", "50"}], ",", " ", "\n", "  ", 
     RowBox[{"PlotLegends", " ", "->", " ", 
      RowBox[{"{", 
       RowBox[{"\"\<\\!\\(\\*FormBox[\\(Two\:f88c\:f88c - time\\\\ \
correlation\\\\ \[LeftAngleBracket]\\(E(t)\\) \\(E(t\:f88c\:f88c + \[Tau])\\)\
\[RightAngleBracket]\\),\nTraditionalForm]\\)\>\"", ",", " ", "\n", 
        "    ", "\"\<Stationary limit of two-time correlation\n \
\\!\\(\\*SubscriptBox[\\(Limit\\), \\(t\:f88c -> \[Infinity]\\)]\\) \
\\!\\(\\*FormBox[\\(\[LeftAngleBracket]\\(E(t)\\) \\(E(t\:f88c\:f88c + \
\[Tau])\\)\[RightAngleBracket]\\),\nTraditionalForm]\\)=\\!\\(\\*FormBox[\\(\
\[LeftAngleBracket]\\(E(0)\\) \\(E(\[Tau])\\)\[RightAngleBracket]\\),\n\
TraditionalForm]\\)\>\""}], "}"}]}], ",", " ", "\n", "  ", 
     RowBox[{
     "PlotLabel", " ", "->", " ", "\n", 
      "   ", "\"\<Two-time correlation function \[LeftAngleBracket]E(t)E(t+\
\[Tau])\[RightAngleBracket]\>\""}], ",", "\n", "   ", 
     RowBox[{"AspectRatio", " ", "->", " ", 
      RowBox[{"1", "/", "2"}]}], ",", " ", "\n", "  ", 
