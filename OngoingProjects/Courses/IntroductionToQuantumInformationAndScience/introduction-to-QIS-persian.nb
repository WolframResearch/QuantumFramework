         RowBox[{"-", "I"}], " ", 
         RowBox[{"\[Alpha]", "/", "2"}], " ", 
         RowBox[{"n", " ", ".", " ", "\[Sigma]"}]}], "]"}]}]}], "}"}], ",", 
