Cell[BoxData[
 RowBox[{"Manipulate", "[", 
  RowBox[{
   RowBox[{"Quiet", "@", 
    RowBox[{"Plot", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{"\[Piecewise]", " ", 
         RowBox[{"{", "\n", "      ", 
          RowBox[{
           RowBox[{"{", " ", 
            RowBox[{"1.", ",", " ", 
             RowBox[{
              RowBox[{"\[Mu]", " ", "-", " ", 
               RowBox[{
                RowBox[{"Sqrt", "[", 
                 RowBox[{"2", " ", 
                  RowBox[{"Log", "[", "2", "]"}]}], "]"}], " ", 
                "\[Sigma]"}]}], " ", "<=", " ", "\n", "        ", "x", " ", "<",
               " ", 
              RowBox[{"\[Mu]", " ", "+", " ", 
               RowBox[{
                RowBox[{"Sqrt", "[", 
                 RowBox[{"2", " ", 
                  RowBox[{"Log", "[", "2", "]"}]}], "]"}], " ", 
                "\[Sigma]"}]}]}]}], "}"}], ",", "\n", "      ", 
           RowBox[{"{", 
            RowBox[{"0", ",", " ", 
             RowBox[{"\\!", 
              RowBox[{"\\(", "\n", "         ", 
               RowBox[{"TagBox", "[", 
                
                RowBox[{"\"\<True\>\"", ",", "\n", 
                 "          ", "\"\<PiecewiseDefault\>\"", ",", "\n", 
                 "          ", 
                 RowBox[{"DeletionWarning", " ", "->", " ", "True"}], ",", 
                 "\n", "          ", 
                 RowBox[{"AutoDelete", "->", "False"}]}], "]"}], "\\)"}]}]}], 
            "}"}]}], "\n", "     ", "}"}]}], ",", " ", 
        RowBox[{"Exp", "[", 
         RowBox[{
          RowBox[{"-", 
           RowBox[{
            RowBox[{"(", 
             RowBox[{"x", " ", "-", " ", "\[Mu]"}], ")"}], "^", "2"}]}], "/", 
          
          RowBox[{"(", 
           RowBox[{"2", " ", 
            RowBox[{"\[Sigma]", "^", "2"}]}], ")"}]}], "]"}]}], "}"}], ",", 
      " ", 
      RowBox[{"{", 
       RowBox[{"x", ",", " ", 
        RowBox[{"-", ".1"}], ",", " ", "2"}], "}"}], ",", " ", "\n", "   ", 
      RowBox[{
      "PlotLabel", " ", "->", " ", "\"\<Square and Gaussian Pulses\>\""}], ",",
       " ", "\n", "   ", 
      RowBox[{"PlotLegends", " ", "->", " ", 
       RowBox[{"{", 
