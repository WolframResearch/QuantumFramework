Cell[BoxData[
 RowBox[{"Manipulate", "[", "\n", " ", 
  RowBox[{
   RowBox[{"Plot", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"(", 
       RowBox[{
        RowBox[{"Sqrt", "[", "\n", "   ", 
         RowBox[{"2", "/", "\[Pi]"}], "]"}], " ", "\[Kappa]", " ", 
        RowBox[{"(", 
         RowBox[{
          RowBox[{"\[Kappa]", "^", "2"}], " ", "+", " ", 
          RowBox[{"\[Omega]", "^", "2"}], " ", "+", " ", 
          RowBox[{"\[Omega]0", "^", "2"}]}], ")"}]}], ")"}], "/", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{"\\\n", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{"\[Kappa]", "^", "2"}], " ", "+", " ", 
           RowBox[{
            RowBox[{"(", 
             RowBox[{"\[Omega]", " ", "-", " ", "\[Omega]0"}], ")"}], "^", 
            "2"}]}], ")"}]}], " ", 
        RowBox[{"(", 
         RowBox[{
          RowBox[{"\[Kappa]", "^", "2"}], " ", "+", " ", 
          RowBox[{
           RowBox[{"(", 
            RowBox[{"\[Omega]", " ", "+", " ", 
             RowBox[{"\\\n", "\[Omega]0"}]}], ")"}], "^", "2"}]}], ")"}]}], 
       ")"}]}], ",", " ", 
     RowBox[{"{", 
      RowBox[{"\[Omega]", ",", " ", 
       RowBox[{"-", "10"}], ",", " ", "10"}], "}"}], ",", " ", 
     RowBox[{"PlotRange", " ", "->", " ", "All"}], ",", " ", "\n", "  ", 
     RowBox[{"Ticks", " ", "->", " ", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{
           "\[Omega]0", ",", " ", "\n", 
            "      ", "\"\<\\!\\(\\*SubscriptBox[\\(\[Omega]\\), \
\\(0\\)]\\)\>\""}], "}"}], ",", " ", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"-", "\[Omega]0"}], ",", " ", "\n", 
            "      ", "\"\<-\\!\\(\\*SubscriptBox[\\(\[Omega]\\), \\(0\\)]\\)\
\>\""}], "}"}]}], "}"}], ",", " ", "None"}], "}"}]}], ",", " ", "\n", "  ", 
     RowBox[{
     "PlotLabel", " ", "->", 
      " ", "\"\<Spectral density of a stochastic phase laser\>\""}], ",", " ",
      "\n", "  ", 
     RowBox[{"AspectRatio", " ", "->", " ", 
      RowBox[{"1", "/", "3"}]}], ",", " ", "\n", "  ", 
     RowBox[{"AxesLabel", " ", "->", " ", 
      RowBox[{"{", 
       RowBox[{"\"\<\[Omega]\>\"", ",", " ", "None"}], "}"}]}]}], "]"}], ",", 
   " ", 
