Cell[BoxData[{
 RowBox[{"ClearAll", "[", 
  RowBox[{"\[Omega]x", ",", " ", "\[Omega]z", ",", " ", "t", ",", " ", "r"}], 
  "]"}], "\n", 
 RowBox[{
  RowBox[{"With", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"\[Omega]", " ", "=", " ", 
      RowBox[{"{", 
       RowBox[{"\[Omega]x", ",", " ", "0", ",", " ", "\[Omega]z"}], "}"}]}], 
     "}"}], ",", " ", 
    RowBox[{"{", 
     RowBox[{"\[ScriptCapitalL]", " ", "=", " ", "\n", "    ", 
      RowBox[{"Map", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"Cross", "[", 
          RowBox[{"#", ",", " ", "\[Omega]"}], "]"}], " ", "&"}], ",", " ", 
        RowBox[{"IdentityMatrix", "[", "3", "]"}]}], "]"}]}], "}"}], ",", 
    "\n", "  ", 
    RowBox[{
     RowBox[{"DSolveValue", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{
          RowBox[{
           RowBox[{"r", "'"}], "[", "t", "]"}], " ", "==", " ", 
          RowBox[{"\[ScriptCapitalL]", " ", ".", " ", 
           RowBox[{"r", "[", "t", "]"}]}]}], ",", " ", 
         RowBox[{
          RowBox[{"r", "[", "0", "]"}], " ", "==", " ", 
          RowBox[{"{", 
           RowBox[{"0", ",", " ", "0", ",", " ", "1"}], "}"}]}]}], "}"}], ",",
        " ", "\n", "    ", 
       RowBox[{
        RowBox[{"r", "[", "t", "]"}], " ", "\[Element]", " ", 
        RowBox[{"Vectors", "[", "3", "]"}]}], ",", " ", "\n", "    ", "t"}], 
      "]"}], " ", "/.", " ", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{"\[Omega]x", "^", "2"}], " ", "+", " ", 
         RowBox[{"\[Omega]z", "^", "2"}]}], " ", ":>", " ", 
        RowBox[{"\[CapitalOmega]", "^", "2"}]}], ",", " ", "\n", "    ", 
       RowBox[{
        RowBox[{"Sqrt", "[", 
         RowBox[{
          RowBox[{"-", 
           RowBox[{"\[Omega]x", "^", "2"}]}], " ", "-", " ", 
          RowBox[{"\[Omega]z", "^", "2"}]}], "]"}], " ", ":>", " ", "\n", 
        "     ", 
        RowBox[{"I", " ", "\[CapitalOmega]"}]}]}], "}"}]}]}], "]"}], " ", "//",
   " ", "FullSimplify"}]}], "Input",
 CellLabel->
  "In[243]:= ",ExpressionUUID->"cf8ef19a-b50d-437c-a34d-00306c91d07d"],

