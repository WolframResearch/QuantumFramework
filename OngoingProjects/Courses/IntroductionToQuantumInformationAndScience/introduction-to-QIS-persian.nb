Cell[BoxData[{
 RowBox[{"ClearAll", "[", 
  RowBox[{
  "u", ",", " ", "\[CapitalOmega]max", ",", " ", "t", ",", " ", "\[Phi]", ",",
    " ", "f"}], "]"}], "\n", 
 RowBox[{
  RowBox[{"u", " ", "=", " ", 
   RowBox[{
    RowBox[{"DSolveValue", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{"\[FormalU]", "'"}], "[", "\n", "       ", "t", "]"}], " ", 
         "==", " ", 
         RowBox[{
          RowBox[{"-", 
           RowBox[{"(", 
            RowBox[{"I", "/", "2"}], ")"}]}], " ", "\[CapitalOmega]max", " ", 
          
          RowBox[{"Exp", "[", 
           RowBox[{
            RowBox[{"-", 
             RowBox[{
              RowBox[{"(", 
               RowBox[{"t", " ", "-", " ", "\[Mu]"}], ")"}], "^", "2"}]}], "/", 
            RowBox[{"(", "\n", "        ", 
             RowBox[{"2", " ", 
              RowBox[{"\[Tau]", "^", "2"}]}], ")"}]}], "]"}], " ", 
          RowBox[{
           RowBox[{"PauliMatrix", "[", "1", "]"}], " ", ".", " ", 
           RowBox[{"\[FormalU]", "[", "t", "]"}]}]}]}], ",", " ", 
        RowBox[{
         RowBox[{"\[FormalU]", "[", "0", "]"}], " ", "==", " ", "\n", 
         "      ", 
         RowBox[{"IdentityMatrix", "[", "2", "]"}]}]}], "}"}], ",", " ", 
      RowBox[{
       RowBox[{"\[FormalU]", "[", "t", "]"}], " ", "\[Element]", " ", 
       RowBox[{"Matrices", "[", 
        RowBox[{"{", 
         RowBox[{"2", ",", " ", "2"}], "}"}], "]"}]}], ",", " ", "\n", "    ",
       "t", ",", " ", 
      RowBox[{"Assumptions", " ", "->", " ", 
       RowBox[{"\[Tau]", " ", ">", " ", "0"}]}]}], "]"}], " ", "//", " ", 
    "FullSimplify"}]}], ";"}], "\n", 
 RowBox[{"u", " ", "//", " ", "TraditionalForm"}]}], "Input",
 CellLabel->
  "In[248]:= ",ExpressionUUID->"83dc1074-1de0-4c2d-897c-51c2f62d16d6"],

