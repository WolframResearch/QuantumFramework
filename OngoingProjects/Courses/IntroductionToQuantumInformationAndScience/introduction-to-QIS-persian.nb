      RowBox[{"AxesLabel", " ", "->", " ", 
       RowBox[{"{", 
        RowBox[{"\"\<Position\>\"", ",", " ", "\"\<PDF\>\""}], "}"}]}], ",", 
      " ", 
      RowBox[{"GridLinesStyle", " ", "->", " ", "Red"}], ",", " ", "\n", "  ", 
      RowBox[{"GridLines", " ", "->", " ", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{
           RowBox[{"m", " ", "-", " ", 
            RowBox[{"Sqrt", "[", "v", "]"}]}], ",", " ", "m", ",", " ", 
           RowBox[{"m", " ", "+", " ", 
            RowBox[{"Sqrt", "[", "v", "]"}]}]}], "}"}], ",", " ", "None"}], 
        "}"}]}], ",", " ", "\n", "  ", 
      RowBox[{"ChartStyle", " ", "->", " ", 
       RowBox[{"Opacity", "[", ".5", "]"}]}], ",", " ", "\n", "  ", 
      RowBox[{"Ticks", " ", "->", " ", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{
           RowBox[{"{", 
