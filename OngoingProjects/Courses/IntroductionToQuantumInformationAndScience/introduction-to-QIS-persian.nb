         RowBox[{"Subscript", "[", 
          RowBox[{"c", ",", " ", "0"}], "]"}], ",", " ", "\n", "     ", 
         RowBox[{"Subscript", "[", 
          RowBox[{"c", ",", " ", "1"}], "]"}]}], "}"}]}]}], "}"}], ",", " ", 
