Cell[BoxData[{
 RowBox[{"ClearAll", "[", 
  RowBox[{
  "\[Phi]", ",", " ", "\[Theta]", ",", " ", "r", ",", " ", "\[Phi]r", ",", 
   " ", "\[Theta]r"}], "]"}], "\n", 
 RowBox[{"Module", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
    "n", ",", " ", "blochvector", ",", " ", "\[Sigma]", ",", " ", "Pplus", ",",
      " ", "\[Rho]"}], "}"}], ",", "\n", " ", 
   RowBox[{"(*", 
    RowBox[{"define", " ", "Pauli", " ", "vector"}], "*)"}], "\n", " ", 
   RowBox[{
    RowBox[{"\[Sigma]", " ", "=", " ", 
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{"PauliMatrix", "[", "j", "]"}], ",", " ", 
       RowBox[{"{", 
        RowBox[{"j", ",", " ", "3"}], "}"}]}], "]"}]}], ";", "\n", " ", 
    RowBox[{"(*", 
     RowBox[{"define", " ", "a", " ", "Bloch", " ", "vector"}], "*)"}], "\n", 
    " ", 
    RowBox[{"blochvector", " ", "=", " ", "\n", "  ", 
     RowBox[{"r", " ", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{
         RowBox[{"Cos", "[", "\[Phi]r", "]"}], " ", 
         RowBox[{"Sin", "[", "\[Theta]r", "]"}]}], ",", " ", 
        RowBox[{
         RowBox[{"Sin", "[", "\[Phi]r", "]"}], " ", 
         RowBox[{"Sin", "[", "\[Theta]r", "]"}]}], ",", " ", "\n", "    ", 
        RowBox[{"Cos", "[", "\[Theta]r", "]"}]}], "}"}]}]}], ";", "\n", " ", 
    RowBox[{"(*", 
     RowBox[{"define", " ", "the", " ", "density", " ", "matrix"}], "*)"}], 
    "\n", " ", 
    RowBox[{"\[Rho]", " ", "=", " ", 
     RowBox[{"DensityMatrix", "[", "blochvector", "]"}]}], ";", "\n", " ", 
    RowBox[{"(*", 
     RowBox[{"define", " ", "a", " ", "unit", " ", "vector"}], "*)"}], "\n", 
    " ", 
    RowBox[{"n", " ", "=", " ", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{
        RowBox[{"Cos", "[", "\[Phi]", "]"}], " ", 
        RowBox[{"Sin", "[", "\[Theta]", "]"}]}], ",", " ", 
       RowBox[{
        RowBox[{"Sin", "[", "\[Phi]", "]"}], " ", 
        RowBox[{"Sin", "[", "\[Theta]", "]"}]}], ",", " ", "\n", "   ", 
       RowBox[{"Cos", "[", "\[Theta]", "]"}]}], "}"}]}], ";", "\n", " ", 
    RowBox[{"(*", 
     RowBox[{"confirm", " ", "identity"}], "*)"}], "\n", " ", 
    RowBox[{"FullSimplify", "[", "\n", "  ", 
     RowBox[{
      RowBox[{
       RowBox[{"Tr", "[", 
        RowBox[{"n", " ", ".", " ", "\[Sigma]", " ", ".", " ", "\[Rho]"}], 
        "]"}], " ", "==", " ", "\n", "   ", 
       RowBox[{"n", " ", ".", " ", "blochvector"}]}], ",", " ", 
      RowBox[{
       RowBox[{
        RowBox[{"(", 
         RowBox[{
         "r", " ", "|", " ", "\[Theta]r", " ", "|", " ", "\[Phi]r", " ", "|", 
          " ", "\[Theta]", " ", "|", " ", "\[Phi]"}], ")"}], " ", "\\\n"}], "\[Element]",
        " ", "Reals"}]}], "]"}]}]}], "]"}]}], "Input",
 CellLabel->
  "In[212]:= ",ExpressionUUID->"a67dc30f-65c7-412c-895f-97d09dbcb658"],

