        " ", "\n", "      ", 
        RowBox[{"FromSphericalCoordinates", "[", 
         RowBox[{"{", 
          RowBox[{"r", ",", " ", "\[Theta]", ",", " ", "\[Phi]"}], "}"}], 
         "]"}]}], "]"}]}], ",", " ", "\n", "   ", 
     RowBox[{
      RowBox[{"0", " ", "<=", " ", "r"}], " ", "&&", " ", 
      RowBox[{"0", " ", "<=", " ", "\[Theta]", " ", "<=", " ", "\[Pi]"}], " ",
       "&&", " ", 
      RowBox[{"0", " ", "<=", " ", "\[Phi]", " ", "<=", " ", 
       RowBox[{"2", " ", "\[Pi]"}]}]}]}], "]"}]}], ";"}], "\n", 
 RowBox[{"jacobian", " ", "//", " ", "MatrixForm"}]}], "Input",
