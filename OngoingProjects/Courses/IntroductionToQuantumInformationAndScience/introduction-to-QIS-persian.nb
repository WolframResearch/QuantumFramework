Cell[BoxData[
 RowBox[{
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"\[Alpha]", ",", " ", "\[Beta]", ",", " ", "\[Gamma]"}], "}"}], ",",
     "\n", "  ", 
    RowBox[{
     RowBox[{
      RowBox[{"{", 
       RowBox[{"\[Alpha]", ",", " ", "\[Beta]", ",", " ", "\[Gamma]"}], "}"}],
       " ", "=", " ", "\n", "   ", 
      RowBox[{"EulerAngles", "[", 
       RowBox[{"RotationMatrix", "[", 
        RowBox[{
         RowBox[{"\[Pi]", "/", "3"}], ",", " ", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{"Cos", "[", 
            RowBox[{"\[Pi]", "/", "8"}], "]"}], ",", " ", 
           RowBox[{"Sin", "[", 
            RowBox[{"\[Pi]", "/", "8"}], "]"}], ",", " ", "0"}], "}"}]}], 
        "]"}], "]"}]}], ";", "\n", "  ", 
     RowBox[{
      RowBox[{
       RowBox[{"RotationMatrix", "[", 
        RowBox[{"\[Alpha]", ",", " ", 
         RowBox[{"{", 
          RowBox[{"0", ",", " ", "0", ",", " ", "1"}], "}"}]}], "]"}], " ", ".",
        " ", "\n", "    ", 
       RowBox[{"RotationMatrix", "[", 
        RowBox[{"\[Beta]", ",", " ", 
         RowBox[{"{", 
          RowBox[{"0", ",", " ", "1", ",", " ", "0"}], "}"}]}], "]"}], " ", ".",
        " ", "\n", "    ", 
       RowBox[{"RotationMatrix", "[", 
        RowBox[{"\[Gamma]", ",", " ", 
         RowBox[{"{", 
          RowBox[{"0", ",", " ", "0", ",", " ", "1"}], "}"}]}], "]"}]}], " ", 
      "==", " ", "\n", "   ", 
      RowBox[{"RotationMatrix", "[", 
       RowBox[{
        RowBox[{"\[Pi]", "/", "3"}], ",", " ", 
