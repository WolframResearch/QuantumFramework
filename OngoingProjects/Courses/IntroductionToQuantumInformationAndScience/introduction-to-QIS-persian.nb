   "]"}], " ", "=", " ", "\n", " ", 
  RowBox[{
   RowBox[{"FourierTransform", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"E", "^", 
       RowBox[{"(", 
        RowBox[{
         RowBox[{"-", 
          RowBox[{"Abs", "[", "t", "]"}]}], " ", "\[Kappa]"}], ")"}]}], " ", 
      RowBox[{"Cos", "[", 
       RowBox[{"t", " ", "\[Omega]0"}], "]"}]}], ",", " ", "\n", "   ", "t", ",",
      " ", "\[Omega]"}], "]"}], " ", "//", " ", "FullSimplify"}]}]], "Input",
