  "rx", ",", " ", "ry", ",", " ", "rz", ",", " ", "r", ",", " ", "\[Theta]", ",",
    " ", "\[Phi]"}], "]"}], "\n", 
 RowBox[{
  RowBox[{"jacobian", " ", "=", " ", "\n", "  ", 
   RowBox[{"FullSimplify", "[", "\n", "   ", 
    RowBox[{
