Cell[BoxData[
 RowBox[{"With", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"\[Kappa]", " ", "=", " ", ".2"}], "}"}], ",", " ", 
   RowBox[{"{", 
    RowBox[{"data", " ", "=", " ", "\n", "   ", 
     RowBox[{"RandomFunction", "[", 
      RowBox[{
       RowBox[{"electricField", "[", 
        RowBox[{"1", ",", " ", "\[Kappa]"}], "]"}], ",", " ", 
       RowBox[{"{", 
        RowBox[{"0", ",", " ", "10", ",", " ", ".01"}], "}"}], ",", " ", 
       RowBox[{"10", "^", "3"}]}], "]"}]}], "}"}], ",", " ", "\n", " ", 
   RowBox[{"Plot", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"Cos", "[", "t", "]"}], ",", " ", 
       RowBox[{
        RowBox[{"E", "^", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{"-", "t"}], " ", "\[Kappa]"}], ")"}]}], " ", 
        RowBox[{"Cos", "[", "t", "]"}]}], ",", " ", 
       RowBox[{"Mean", "[", 
        RowBox[{"data", "[", "t", "]"}], "]"}]}], "}"}], ",", " ", 
     RowBox[{"{", 
      RowBox[{"t", ",", " ", "0", ",", " ", "10"}], "}"}], ",", " ", "\n", 
     "  ", 
     RowBox[{"PlotRange", " ", "->", " ", "All"}], ",", " ", "\n", "  ", 
     RowBox[{"PlotLegends", " ", "->", " ", 
      RowBox[{"{", 
       RowBox[{"\"\<No noise case\>\"", ",", 
        " ", "\"\<Exact noise-averaged data\>\"", ",", " ", "\n", 
        "    ", "\"\<Numerical averaging over noise\>\""}], "}"}]}], ",", " ", 
     RowBox[{"AspectRatio", " ", "->", " ", 
      RowBox[{"1", "/", "2"}]}], ",", " ", "\n", "  ", 
     RowBox[{"GridLines", " ", "->", " ", "Automatic"}], ",", " ", "\n", "  ", 
     RowBox[{
     "PlotLabel", " ", "->", " ", "\n", 
      "   ", "\"\<No noise, vs noisy electric field, after averaging over \
noise\n \[Kappa]=0.2 and \[Omega]=1\>\""}], ",", " ", 
     RowBox[{"FrameLabel", " ", "->", " ", 
      RowBox[{"{", 
       RowBox[{"\"\<Time\>\"", ",", " ", "\"\<Electric Field\>\""}], "}"}]}], 
     ",", "\n", "   ", 
     RowBox[{"Frame", " ", "->", " ", "True"}]}], "]"}]}], "]"}]], "Input",
 CellLabel->
  "In[272]:= ",ExpressionUUID->"871e421d-d3bb-4c38-9839-aaa509a15c61"],

