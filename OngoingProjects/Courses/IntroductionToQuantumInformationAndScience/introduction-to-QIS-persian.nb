Cell[BoxData[
 RowBox[{"Manipulate", "[", "\n", " ", 
  RowBox[{
   RowBox[{"With", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"initial", " ", "=", " ", 
       RowBox[{"FromSphericalCoordinates", "[", 
        RowBox[{"{", 
         RowBox[{"1", ",", " ", 
          RowBox[{"\[Pi]", "/", "4"}], ",", " ", "0"}], "}"}], "]"}]}], "}"}],
      ",", "\n", "  ", 
     RowBox[{"Show", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"ResourceFunction", "[", "\"\<BlochSpherePlot\>\"", "]"}], "[",
         "\n", "    ", 
        RowBox[{
         RowBox[{
          RowBox[{"RotationMatrix", "[", "\n", "      ", 
           RowBox[{
            RowBox[{
             RowBox[{"Sqrt", "[", 
              RowBox[{
               RowBox[{"\[Omega]x", "^", "2"}], " ", "+", " ", 
               RowBox[{"\[Omega]z", "^", "2"}]}], "]"}], " ", "tf"}], ",", 
            " ", 
            RowBox[{
             RowBox[{"{", 
              RowBox[{"\[Omega]x", ",", " ", "0", ",", " ", "\[Omega]z"}], 
              "}"}], "/", "\n", "      ", 
             RowBox[{"Sqrt", "[", 
              RowBox[{
               RowBox[{"\[Omega]x", "^", "2"}], " ", "+", " ", 
               RowBox[{"\[Omega]z", "^", "2"}]}], "]"}]}]}], "]"}], " ", ".", 
          " ", "initial"}], ",", " ", "\n", "    ", 
         RowBox[{"\"\<NumberOfGreatCircles\>\"", " ", "->", " ", "5"}], ",", 
         " ", 
         RowBox[{"\"\<NumberOfSmallCircles\>\"", " ", "->", " ", "5"}]}], 
        "]"}], ",", " ", "\n", "   ", 
       RowBox[{"Graphics3D", "[", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{"Green", ",", " ", 
            RowBox[{"PointSize", "[", ".02", "]"}], ",", " ", "\n", "      ", 
            
            RowBox[{"Point", "[", "initial", "]"}]}], "}"}], ",", " ", 
          RowBox[{"{", 
           RowBox[{"Text", "[", "\n", "       ", 
            
            RowBox[{"\"\<{\\!\\(\\*SubscriptBox[\\(\[Omega]\\), \
\\(x\\)]\\),0,\\!\\(\\*SubscriptBox[\\(\[Omega]\\), \\(z\\)]\\)}\>\"", ",", 
             " ", "\n", "       ", 
             RowBox[{"initial", " ", "+", " ", 
              RowBox[{".4", " ", 
               RowBox[{
                RowBox[{"{", 
                 RowBox[{"\[Omega]x", ",", " ", "0", ",", " ", "\[Omega]z"}], 
                 "}"}], "/", "\n", "         ", 
                RowBox[{"Sqrt", "[", 
                 RowBox[{
                  RowBox[{"\[Omega]x", "^", "2"}], " ", "+", " ", 
                  RowBox[{"\[Omega]z", "^", "2"}]}], "]"}]}]}]}]}], "]"}], 
           "}"}], ",", " ", 
          RowBox[{"{", 
           RowBox[{"Thick", ",", " ", "\n", "      ", 
            RowBox[{"Arrow", "[", 
             RowBox[{"{", 
              RowBox[{"initial", ",", " ", "\n", "        ", 
               RowBox[{"initial", " ", "+", " ", 
                RowBox[{".3", " ", 
                 RowBox[{
                  RowBox[{"{", 
                   RowBox[{
                   "\[Omega]x", ",", " ", "0", ",", " ", "\[Omega]z"}], "}"}],
                   "/", "\n", "          ", 
                  RowBox[{"Sqrt", "[", 
                   RowBox[{
                    RowBox[{"\[Omega]x", "^", "2"}], " ", "+", " ", 
                    RowBox[{"\[Omega]z", "^", "2"}]}], "]"}]}]}]}]}], "}"}], 
             "]"}]}], "}"}], ",", " ", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"Opacity", "[", ".5", "]"}], ",", " ", "\n", "      ", 
            RowBox[{
             RowBox[{"ColorData", "[", "97", "]"}], "[", "2", "]"}], ",", " ",
             "\n", "      ", 
            RowBox[{"Hyperplane", "[", 
             RowBox[{
              RowBox[{
               RowBox[{"{", 
                RowBox[{"\[Omega]x", ",", " ", "0", ",", " ", "\[Omega]z"}], 
                "}"}], "/", "\n", "       ", 
               RowBox[{"Sqrt", "[", 
                RowBox[{
                 RowBox[{"\[Omega]x", "^", "2"}], " ", "+", " ", 
                 RowBox[{"\[Omega]z", "^", "2"}]}], "]"}]}], ",", " ", 
              "initial"}], "]"}]}], "}"}]}], "}"}], "]"}], ",", " ", "\n", 
       "   ", 
       RowBox[{"ParametricPlot3D", "[", "\n", "    ", 
        RowBox[{
         RowBox[{
          RowBox[{"RotationMatrix", "[", "\n", "      ", 
           RowBox[{
            RowBox[{
             RowBox[{"Sqrt", "[", 
              RowBox[{
               RowBox[{"\[Omega]x", "^", "2"}], " ", "+", " ", 
               RowBox[{"\[Omega]z", "^", "2"}]}], "]"}], " ", "t"}], ",", " ", 
            RowBox[{
             RowBox[{"{", 
              RowBox[{"\[Omega]x", ",", " ", "0", ",", " ", "\[Omega]z"}], 
              "}"}], "/", "\n", "      ", 
             RowBox[{"Sqrt", "[", 
              RowBox[{
               RowBox[{"\[Omega]x", "^", "2"}], " ", "+", " ", 
               RowBox[{"\[Omega]z", "^", "2"}]}], "]"}]}]}], "]"}], " ", ".", 
          " ", "initial"}], ",", " ", 
         RowBox[{"{", 
          RowBox[{"t", ",", " ", "0", ",", " ", "tf"}], "}"}], ",", " ", "\n",
          "    ", 
         RowBox[{"PlotStyle", " ", "->", " ", "Red"}]}], "]"}], ",", " ", 
       RowBox[{"PlotRange", " ", "->", " ", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{
            RowBox[{"-", "1"}], ",", " ", "1"}], "}"}], ",", " ", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"-", "1"}], ",", " ", "1"}], "}"}], ",", " ", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"-", "1"}], ",", " ", "1"}], "}"}]}], "}"}]}]}], "]"}]}], 
    "]"}], ",", " ", "\n", " ", 
   RowBox[{"Item", "[", 
    RowBox[{"\"\<Bloch-vector trajectory with Hamiltonian 1/\n   2 \
(Subscript[\[Omega], x] Subscript[\[Sigma], x] + \n     Subscript[\[Omega], \
z] Subscript[\[Sigma], z])\>\"", ",", " ", "\n", "  ", 
     RowBox[{"Alignment", " ", "->", " ", "Center"}]}], "]"}], ",", " ", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
      "\[Omega]x", ",", " ", "1", ",", " ", "\n", 
       "   ", "\"\<Rabi rate \\!\\(\\*SubscriptBox[\\(\[Omega]\\), \
\\(x\\)]\\)\>\""}], "}"}], ",", " ", "0", ",", " ", "\n", "  ", 
     RowBox[{"2", " ", "\[Pi]"}]}], "}"}], ",", " ", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
      "\[Omega]z", ",", " ", ".5", ",", " ", "\n", 
       "   ", "\"\<Detuning rate \\!\\(\\*SubscriptBox[\\(\[Omega]\\), \
\\(z\\)]\\)\>\""}], "}"}], ",", " ", "0", ",", " ", "\n", "  ", 
     RowBox[{"2", " ", "\[Pi]"}]}], "}"}], ",", " ", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"tf", ",", " ", "1", ",", " ", "\"\<Time\>\""}], "}"}], ",", 
     " ", 
     RowBox[{"10", "^", 
      RowBox[{"-", "3"}]}], ",", " ", "10"}], "}"}]}], "]"}]], "Input",
 CellLabel->
  "In[245]:= ",ExpressionUUID->"67c58bf7-30d6-4332-88bc-806bceadb2b4"],

