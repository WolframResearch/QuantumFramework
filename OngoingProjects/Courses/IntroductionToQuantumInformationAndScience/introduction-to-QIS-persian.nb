Cell[BoxData[
 RowBox[{"With", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"Et", " ", "=", " ", 
     RowBox[{"electricField", "[", 
      RowBox[{"1", ",", " ", ".02"}], "]"}]}], "}"}], ",", "\n", " ", 
   RowBox[{"ListLinePlot", "[", "\n", "  ", 
    RowBox[{
     RowBox[{"Append", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"RandomFunction", "[", 
         RowBox[{"Et", ",", " ", 
          RowBox[{"{", 
           RowBox[{"0.", ",", " ", "6.", ",", " ", "0.01"}], "}"}], ",", " ", 
          "3"}], "]"}], "[", "\"\<Paths\>\"", "]"}], ",", " ", "\n", "   ", 
       RowBox[{"Table", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"t", ",", " ", 
           RowBox[{"Cos", "[", "t", "]"}]}], "}"}], ",", " ", 
         RowBox[{"{", 
          RowBox[{"t", ",", " ", "0", ",", " ", "6", ",", " ", ".01"}], 
          "}"}]}], "]"}]}], "]"}], ",", " ", "\n", "  ", 
     RowBox[{"PlotStyle", " ", "->", " ", 
      RowBox[{"{", 
       RowBox[{
       "Automatic", ",", " ", "Automatic", ",", " ", "Automatic", ",", " ", 
        "\n", "    ", 
        RowBox[{"Directive", "[", 
         RowBox[{"Thick", ",", " ", "Black"}], "]"}]}], "}"}]}], ",", " ", 
     "\n", "  ", 
     RowBox[{"PlotLegends", " ", "->", " ", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"Sequence", " ", "@@", " ", "\n", "     ", 
         RowBox[{"Table", "[", 
          
          RowBox[{"\"\<A realization of electric field for noisy-phase \
laser\>\"", ",", " ", "3"}], "]"}]}], ",", "\n", 
        "     ", "\"\<Electric field of ideal laser\>\""}], "}"}]}], ",", " ", 
     RowBox[{"AspectRatio", " ", "->", " ", 
      RowBox[{"1", "/", "2"}]}], ",", " ", "\n", "  ", 
     RowBox[{"Frame", " ", "->", " ", "True"}], ",", " ", 
     RowBox[{"FrameLabel", " ", "->", " ", 
      RowBox[{"{", 
       RowBox[{"\"\<Time\>\"", ",", 
        " ", "\"\<Real part of electric field\>\""}], "}"}]}], ",", "\n", 
     "   ", 
     RowBox[{
     "PlotLabel", " ", "->", " ", "\n", 
      "   ", "\"\<Different realization of electric field for a laser with \
noisy phase\n with the diffusion constant set as \[Kappa]=0.02\>\""}]}], 
    "]"}]}], "]"}]], "Input",
