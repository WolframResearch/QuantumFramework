Cell[BoxData[{
 RowBox[{"ClearAll", "[", 
  RowBox[{
  "x", ",", " ", "y", ",", " ", "z", ",", " ", "\[Gamma]", ",", " ", 
   "\[Omega]x", ",", " ", "\[Rho]"}], "]"}], "\n", 
 RowBox[{
  RowBox[{"\[Rho]", " ", "=", " ", 
   RowBox[{"DensityMatrix", "[", 
    RowBox[{"{", 
     RowBox[{"x", ",", " ", "y", ",", " ", "z"}], "}"}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"jumpOperator", " ", "=", " ", 
   RowBox[{"PauliMatrix", "[", "3", "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"hamiltonianOperator", " ", "=", " ", 
   RowBox[{
    RowBox[{"1", "/", "2"}], " ", "\[Omega]x", " ", 
    RowBox[{"PauliMatrix", "[", "1", "]"}]}]}], ";"}]}], "Input",
