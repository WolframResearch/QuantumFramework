  "\[Phi]", ",", " ", "\[Theta]", ",", " ", "r", ",", " ", "\[Phi]r", ",", 
   " ", "\[Theta]r"}], "]"}], "\n", 
 RowBox[{"Module", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
    "n", ",", " ", "blochvector", ",", " ", "\[Sigma]", ",", " ", "proj", ",",
      " ", "\[Rho]"}], "}"}], ",", "\n", " ", 
   RowBox[{"(*", 
    RowBox[{"define", " ", "Pauli", " ", "vector"}], "*)"}], "\n", " ", 
   RowBox[{
    RowBox[{"\[Sigma]", " ", "=", " ", 
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{"PauliMatrix", "[", "j", "]"}], ",", " ", 
       RowBox[{"{", 
        RowBox[{"j", ",", " ", "3"}], "}"}]}], "]"}]}], ";", "\n", " ", 
    RowBox[{"(*", 
     RowBox[{"define", " ", "a", " ", "Bloch", " ", "vector"}], "*)"}], "\n", 
    " ", 
    RowBox[{"blochvector", " ", "=", " ", "\n", "  ", 
     RowBox[{"r", " ", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{
         RowBox[{"Cos", "[", "\[Phi]r", "]"}], " ", 
         RowBox[{"Sin", "[", "\[Theta]r", "]"}]}], ",", " ", 
        RowBox[{
         RowBox[{"Sin", "[", "\[Phi]r", "]"}], " ", 
         RowBox[{"Sin", "[", "\[Theta]r", "]"}]}], ",", " ", "\n", "    ", 
        RowBox[{"Cos", "[", "\[Theta]r", "]"}]}], "}"}]}]}], ";", "\n", " ", 
    RowBox[{"(*", 
     RowBox[{"define", " ", "the", " ", "density", " ", "matrix"}], "*)"}], 
    "\n", " ", 
    RowBox[{"\[Rho]", " ", "=", " ", 
     RowBox[{"DensityMatrix", "[", "blochvector", "]"}]}], ";", "\n", " ", 
    RowBox[{"(*", 
     RowBox[{"define", " ", "a", " ", "unit", " ", "vector"}], "*)"}], "\n", 
    " ", 
    RowBox[{"n", " ", "=", " ", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{
        RowBox[{"Cos", "[", "\[Phi]", "]"}], " ", 
        RowBox[{"Sin", "[", "\[Theta]", "]"}]}], ",", " ", 
       RowBox[{
        RowBox[{"Sin", "[", "\[Phi]", "]"}], " ", 
        RowBox[{"Sin", "[", "\[Theta]", "]"}]}], ",", " ", "\n", "   ", 
       RowBox[{"Cos", "[", "\[Theta]", "]"}]}], "}"}]}], ";", "\n", " ", 
    RowBox[{"(*", 
     RowBox[{
     "define", " ", "the", " ", "projector", " ", "to", " ", "positive", " ", 
      "eigenstate"}], "*)"}], "\n", " ", 
    RowBox[{"proj", " ", "=", " ", 
     RowBox[{"DensityMatrix", "[", "n", "]"}]}], ";", "\n", " ", 
    RowBox[{"(*", 
     RowBox[{"confirm", " ", "identity"}], "*)"}], "\n", " ", 
    RowBox[{"FullSimplify", "[", "\n", "  ", 
