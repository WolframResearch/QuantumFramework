        "}"}]}], ",", " ", "\n", "   ", 
      RowBox[{"Exclusions", " ", "->", " ", "None"}], ",", " ", 
      RowBox[{"Filling", " ", "->", " ", "0"}], ",", " ", "\n", "   ", 
      RowBox[{"AxesLabel", " ", "->", " ", 
       RowBox[{"{", " ", 
        RowBox[{"\"\<Time\>\"", ",", " ", "\"\<Pulse magnitude\>\""}], 
        "}"}]}], ",", " ", 
      RowBox[{"PlotRange", " ", "->", " ", "All"}], ",", " ", "\n", "   ", 
      RowBox[{"AspectRatio", " ", "->", " ", 
       RowBox[{"1", "/", "3"}]}], ",", " ", 
      RowBox[{"GridLines", " ", "->", " ", "Automatic"}]}], "]"}]}], ",", " ", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
      "\[Mu]", ",", " ", ".1", ",", " ", "\n", 
       "   ", "\"\<Center of the pulse (max)\>\""}], "}"}], ",", " ", ".1", ",",
      " ", "\n", "  ", "1"}], "}"}], ",", " ", 
