Cell[BoxData[
 RowBox[{
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
     "n", ",", " ", "\[Sigma]", ",", " ", "\[Alpha]", ",", " ", "\[Beta]", ",",
       " ", "\[Gamma]"}], "}"}], ",", "\n", "  ", 
    RowBox[{
     RowBox[{
      RowBox[{"{", 
       RowBox[{"\[Alpha]", ",", " ", "\[Beta]", ",", " ", "\[Gamma]"}], "}"}],
       " ", "=", " ", "\n", "   ", 
      RowBox[{"EulerAngles", "[", 
       RowBox[{"RotationMatrix", "[", 
        RowBox[{
         RowBox[{"\[Pi]", "/", "3"}], ",", " ", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{"Cos", "[", 
            RowBox[{"\[Pi]", "/", "8"}], "]"}], ",", " ", 
           RowBox[{"Sin", "[", 
            RowBox[{"\[Pi]", "/", "8"}], "]"}], ",", " ", "0"}], "}"}]}], 
        "]"}], "]"}]}], ";", "\n", "  ", 
     RowBox[{"\[Sigma]", " ", "=", " ", 
      RowBox[{"Table", "[", 
       RowBox[{
        RowBox[{"PauliMatrix", "[", "j", "]"}], ",", " ", 
        RowBox[{"{", 
         RowBox[{"j", ",", " ", "3"}], "}"}]}], "]"}]}], ";", "\n", "  ", 
     RowBox[{"n", " ", "=", " ", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"Cos", "[", 
         RowBox[{"\[Pi]", "/", "8"}], "]"}], ",", " ", 
        RowBox[{"Sin", "[", 
         RowBox[{"\[Pi]", "/", "8"}], "]"}], ",", " ", "0"}], "}"}]}], ";", 
     "\n", "  ", 
     RowBox[{
      RowBox[{
       RowBox[{"MatrixExp", "[", 
        RowBox[{
         RowBox[{"-", "I"}], " ", 
         RowBox[{"\[Alpha]", "/", "2"}], " ", 
         RowBox[{"PauliMatrix", "[", "3", "]"}]}], "]"}], " ", ".", " ", "\n",
        "    ", 
       RowBox[{"MatrixExp", "[", 
        RowBox[{
         RowBox[{"-", "I"}], " ", 
         RowBox[{"\[Beta]", "/", "2"}], " ", 
         RowBox[{"PauliMatrix", "[", "2", "]"}]}], "]"}], " ", ".", " ", "\n",
        "    ", 
       RowBox[{"MatrixExp", "[", 
        RowBox[{
         RowBox[{"-", "I"}], " ", 
         RowBox[{"\[Gamma]", "/", "2"}], " ", 
         RowBox[{"PauliMatrix", "[", "3", "]"}]}], "]"}]}], " ", "==", " ", 
      "\n", "   ", 
      RowBox[{"MatrixExp", "[", 
       RowBox[{
        RowBox[{"-", "I"}], " ", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{"\[Pi]", "/", "3"}], ")"}], "/", "2"}], " ", 
        RowBox[{"n", " ", ".", " ", "\[Sigma]"}]}], "]"}]}]}]}], "\n", "  ", 
   "]"}], " ", "//", " ", "FullSimplify"}]], "Input",
 CellLabel->
  "In[193]:= ",ExpressionUUID->"23710181-9b0f-4572-8719-55e187940438"],

