        RowBox[{"{", 
         RowBox[{"j", ",", " ", "3"}], "}"}]}], "]"}]}], "}"}], ",", " ", 
    RowBox[{"{", 
     RowBox[{"u", " ", "=", "\n", "     ", 
      RowBox[{"FullSimplify", "@", 
       RowBox[{"MatrixExp", "[", 
