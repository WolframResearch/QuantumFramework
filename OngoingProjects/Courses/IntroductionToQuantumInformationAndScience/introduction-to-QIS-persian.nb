Cell[BoxData[{
 RowBox[{"ClearAll", "[", "BlochVector", "]"}], "\n", 
 RowBox[{
  RowBox[{"BlochVector", "[", 
   RowBox[{"stateVector_", "?", "VectorQ"}], "]"}], " ", ":=", " ", "\n", " ", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"\[Alpha]", ",", " ", "\[Beta]"}], "}"}], ",", " ", 
    RowBox[{
     RowBox[{
      RowBox[{"{", 
       RowBox[{"\[Alpha]", ",", " ", "\[Beta]"}], "}"}], " ", "=", " ", "\n", 
      "   ", "stateVector"}], ";", " ", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"2", " ", 
        RowBox[{"Re", "[", 
         RowBox[{"\[Beta]", " ", 
          RowBox[{"Conjugate", "@", "\[Alpha]"}]}], "]"}]}], ",", " ", "\n", 
       "   ", 
       RowBox[{"2", " ", 
        RowBox[{"Im", "[", 
         RowBox[{"\[Beta]", " ", 
          RowBox[{"Conjugate", "@", "\[Alpha]"}]}], "]"}]}], ",", " ", 
       RowBox[{
        RowBox[{
         RowBox[{"Abs", "[", "\[Alpha]", "]"}], "^", "2"}], " ", "-", " ", 
        RowBox[{
         RowBox[{"Abs", "[", "\[Beta]", "]"}], "^", "2"}]}]}], "}"}]}]}], 
   "]"}]}]}], "Input",
 CellLabel->
  "In[20]:= ",ExpressionUUID->"d8b911c4-6177-4646-94ed-10437497eabb"],

