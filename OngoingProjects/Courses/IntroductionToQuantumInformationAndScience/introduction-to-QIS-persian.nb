Cell[BoxData[
 RowBox[{"FullSimplify", "[", "\n", " ", 
  RowBox[{
   RowBox[{"With", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"\[Rho]", " ", "=", " ", 
        RowBox[{"Array", "[", 
         RowBox[{"\[FormalR]", ",", " ", 
          RowBox[{"{", 
           RowBox[{"2", ",", " ", "2"}], "}"}]}], "]"}]}], ",", " ", "\n", 
       "   ", 
       RowBox[{"l", " ", "=", " ", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{"\[FormalA]", ",", " ", "\[FormalB]"}], "}"}], ",", " ", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"Conjugate", "[", "\[FormalB]", "]"}], ",", " ", "\n", 
            "      ", 
            RowBox[{"1", " ", "-", " ", "\[FormalA]"}]}], "}"}]}], "}"}]}]}], 
      "}"}], ",", "\n", "  ", 
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{"-", "1"}], "/", "2"}], " ", 
       RowBox[{"Commutator", "[", 
        RowBox[{"l", ",", " ", 
         RowBox[{"Commutator", "[", 
          RowBox[{"l", ",", " ", "r", ",", " ", "Dot"}], "]"}], ",", " ", 
         "Dot"}], "]"}]}], " ", "==", "\n", "   ", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{"l", " ", ".", " ", "r", " ", ".", " ", 
         RowBox[{"ConjugateTranspose", "[", "l", "]"}]}], " ", "-", " ", "\n",
         "     ", 
        RowBox[{
         RowBox[{"1", "/", "2"}], " ", 
         RowBox[{"Anticommutator", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"ConjugateTranspose", "[", "l", "]"}], " ", ".", " ", 
            "l"}], ",", " ", "r", ",", " ", "\n", "       ", "Dot"}], 
          "]"}]}]}], ")"}]}]}], "]"}], ",", " ", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{"\[FormalA]", " ", "|", " ", "\[FormalB]"}], ")"}], " ", "\[Element]",
     " ", "Reals"}]}], "]"}]], "Input",
 CellLabel->
  "In[294]:= ",ExpressionUUID->"fffe55da-e6d3-49df-8699-affa2825dfdb"],

