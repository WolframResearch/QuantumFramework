         RowBox[{"PauliMatrix", "[", "j", "]"}]}]}]}], "}"}], ",", " ", "\n", 
     "  ", 
     RowBox[{
      RowBox[{
       RowBox[{"ConjugateTranspose", "[", "x", "]"}], " ", "==", " ", 
       RowBox[{"-", "x"}]}], " ", "&&", " ", 
      RowBox[{
       RowBox[{"ConjugateTranspose", "[", "y", "]"}], " ", "==", " ", 
       RowBox[{"-", "y"}]}]}]}], "]"}], ",", " ", 
