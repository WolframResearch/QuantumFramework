  RowBox[{"\[Phi]", ",", " ", "\[Theta]"}], "]"}], "\n", 
 RowBox[{
  RowBox[{"With", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{"n", " ", "=", " ", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{
          RowBox[{"Cos", "[", "\[Phi]", "]"}], " ", 
          RowBox[{"Sin", "[", "\[Theta]", "]"}]}], ",", " ", 
         RowBox[{
          RowBox[{"Sin", "[", "\[Phi]", "]"}], " ", 
          RowBox[{"Sin", "[", "\[Theta]", "]"}]}], ",", " ", "\n", "     ", 
         RowBox[{"Cos", "[", "\[Theta]", "]"}]}], "}"}]}], ",", " ", 
      RowBox[{"\[Sigma]", " ", "=", " ", "\n", "    ", 
       RowBox[{"Table", "[", 
        RowBox[{
         RowBox[{"PauliMatrix", "[", "j", "]"}], ",", " ", 
         RowBox[{"{", 
          RowBox[{"j", ",", " ", "3"}], "}"}]}], "]"}]}], ",", " ", 
      RowBox[{"\[Alpha]", " ", "=", " ", 
       RowBox[{"2", " ", "\[Pi]"}]}]}], "}"}], ",", " ", "\n", "  ", 
    RowBox[{"FullSimplify", "@", 
     RowBox[{"MatrixExp", "[", 
      RowBox[{
       RowBox[{"-", "I"}], " ", 
       RowBox[{"\[Alpha]", "/", "2"}], " ", 
       RowBox[{"n", " ", ".", " ", "\[Sigma]"}]}], "]"}]}]}], "]"}], " ", "//",
   " ", "MatrixForm"}]}], "Input",
