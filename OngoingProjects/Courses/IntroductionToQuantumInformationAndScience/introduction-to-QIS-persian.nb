Cell[BoxData[
 RowBox[{"Legended", "[", 
  RowBox[{
   RowBox[{"With", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"\[Eta]", " ", "=", " ", ".75"}], "}"}], ",", " ", 
     RowBox[{"Show", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"ResourceFunction", "[", "\"\<BlochSpherePlot\>\"", "]"}], "[", 
        RowBox[{"ImageSize", " ", "->", " ", "250"}], "]"}], ",", "\n", "   ", 
       RowBox[{"ParametricPlot3D", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{
           RowBox[{
            RowBox[{"Cos", "[", "\[Phi]", "]"}], " ", 
            RowBox[{"Sin", "[", "\[Theta]", "]"}]}], ",", " ", "\n", "     ", 
           
           RowBox[{
            RowBox[{"Sin", "[", "\[Phi]", "]"}], " ", 
            RowBox[{"Sin", "[", "\[Theta]", "]"}], " ", 
            RowBox[{"Sqrt", "[", 
             RowBox[{"1", " ", "-", " ", 
              RowBox[{"\[Eta]", "^", "2"}]}], "]"}]}], ",", " ", "\n", 
           "     ", 
           RowBox[{
            RowBox[{"Cos", "[", "\[Theta]", "]"}], " ", 
            RowBox[{"Sqrt", "[", 
             RowBox[{"1", " ", "-", " ", 
              RowBox[{"\[Eta]", "^", "2"}]}], "]"}]}]}], "}"}], ",", " ", 
         RowBox[{"{", 
          RowBox[{"\[Theta]", ",", " ", "0", ",", " ", "\[Pi]"}], "}"}], ",", 
         " ", 
         RowBox[{"{", 
          RowBox[{"\[Phi]", ",", "\n", "      ", "0", ",", " ", 
           RowBox[{"2", " ", "\[Pi]"}]}], "}"}], ",", " ", 
         RowBox[{"Boxed", " ", "->", " ", "False"}], ",", " ", 
         RowBox[{"Axes", " ", "->", " ", "False"}], ",", " ", 
         RowBox[{"PlotPoints", " ", "->", " ", "25"}], ",", " ", "\n", "    ", 
         RowBox[{"PlotStyle", " ", "->", " ", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{
             RowBox[{"ColorData", "[", "97", "]"}], "[", "1", "]"}], ",", " ", 
            RowBox[{"Opacity", "[", ".5", "]"}]}], "}"}]}]}], "]"}], ",", " ",
        "\n", "   ", 
       RowBox[{"ParametricPlot3D", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{
           RowBox[{
            RowBox[{"1", "/", "\n", "      ", "2"}], " ", 
            RowBox[{"(", 
             RowBox[{
              RowBox[{"-", "\[Eta]"}], " ", "+", " ", 
              RowBox[{
               RowBox[{"Cos", "[", "\[Phi]", "]"}], " ", 
               RowBox[{"Sin", "[", "\[Theta]", "]"}]}], " ", "-", " ", "\n", 
              "        ", 
              RowBox[{
               RowBox[{"Sqrt", "[", 
                RowBox[{"1", " ", "-", " ", 
                 RowBox[{"\[Eta]", "^", "2"}]}], "]"}], " ", 
               RowBox[{"Sin", "[", "\[Theta]", "]"}], " ", 
               RowBox[{"Sin", "[", "\[Phi]", "]"}]}]}], ")"}]}], ",", " ", 
           "\n", "     ", 
           RowBox[{
            RowBox[{"1", "/", "2"}], " ", 
            RowBox[{"(", 
             RowBox[{"\[Eta]", " ", "+", " ", 
              RowBox[{
               RowBox[{"Cos", "[", "\[Phi]", "]"}], " ", 
               RowBox[{"Sin", "[", "\[Theta]", "]"}]}], " ", "+", " ", "\n", 
              "        ", 
              RowBox[{
               RowBox[{"Sqrt", "[", 
                RowBox[{"1", " ", "-", " ", 
                 RowBox[{"\[Eta]", "^", "2"}]}], "]"}], " ", 
               RowBox[{"Sin", "[", "\[Theta]", "]"}], " ", 
               RowBox[{"Sin", "[", "\[Phi]", "]"}]}]}], ")"}]}], ",", " ", 
           "\n", "     ", 
           RowBox[{
            RowBox[{"Sqrt", "[", 
             RowBox[{"1", " ", "-", " ", 
              RowBox[{"\[Eta]", "^", "2"}]}], "]"}], " ", 
            RowBox[{"Cos", "[", "\[Theta]", "]"}]}]}], "}"}], ",", " ", 
         RowBox[{"{", 
          RowBox[{"\[Theta]", ",", " ", "0", ",", " ", "\[Pi]"}], "}"}], ",", 
         " ", 
         RowBox[{"{", 
          RowBox[{"\[Phi]", ",", "\n", "      ", "0", ",", " ", 
