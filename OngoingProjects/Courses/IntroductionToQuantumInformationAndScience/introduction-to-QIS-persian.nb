 RowBox[{"Plot", "[", 
  RowBox[{
   RowBox[{"Evaluate", "@", 
    RowBox[{"Re", "@", 
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{"Tr", "[", 
        RowBox[{
         RowBox[{"\[Rho]t", "[", "t", "]"}], " ", ".", " ", 
