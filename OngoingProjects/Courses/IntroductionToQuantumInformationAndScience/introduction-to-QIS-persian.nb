          RowBox[{"\[FormalB]", ",", " ", "##"}], "]"}], " ", "&"}], ",", " ",
         "3"}], "]"}]}]}], "}"}], ",", " ", "\n", " ", 
   RowBox[{
    RowBox[{"Cross", "[", 
