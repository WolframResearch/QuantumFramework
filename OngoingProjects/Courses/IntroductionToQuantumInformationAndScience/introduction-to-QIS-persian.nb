Cell[BoxData[{
 RowBox[{"ClearAll", "[", 
  RowBox[{
  "\[Sigma]", ",", " ", "\[Omega]x", ",", " ", "\[Omega]y", ",", " ", 
   "\[Omega]z", ",", " ", "rx", ",", " ", "ry", ",", " ", "rz"}], "]"}], "\n", 
 RowBox[{
  RowBox[{"With", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{"\[Sigma]", " ", "=", " ", "\n", "    ", 
       RowBox[{"Table", "[", 
        RowBox[{
         RowBox[{"PauliMatrix", "[", "j", "]"}], ",", " ", 
         RowBox[{"{", 
          RowBox[{"j", ",", " ", "\n", "      ", "3"}], "}"}]}], "]"}]}], ",",
       " ", 
      RowBox[{"\[Omega]", " ", "=", " ", 
       RowBox[{"{", 
        RowBox[{"\[Omega]x", ",", " ", "\[Omega]y", ",", " ", "\[Omega]z"}], 
        "}"}]}], ",", " ", "\n", "   ", 
      RowBox[{"r", " ", "=", " ", 
       RowBox[{"{", 
        RowBox[{"rx", ",", " ", "ry", ",", " ", "rz"}], "}"}]}]}], "}"}], ",",
     " ", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"h", " ", "=", " ", 
       RowBox[{
        RowBox[{"1", "/", "2"}], " ", 
        RowBox[{"\[Omega]", " ", ".", " ", "\[Sigma]"}]}]}], ",", " ", 
      RowBox[{"\[Rho]", " ", "=", " ", "\n", "    ", 
       RowBox[{"DensityMatrix", "[", "r", "]"}]}]}], "}"}], ",", " ", 
    RowBox[{"{", 
     RowBox[{"icom", " ", "=", " ", 
      RowBox[{
       RowBox[{"-", "I"}], " ", 
       RowBox[{"Commutator", "[", 
        RowBox[{"h", ",", " ", "\[Rho]", ",", " ", "Dot"}], "]"}]}]}], "}"}], 
    ",", " ", "\n", "  ", 
    RowBox[{
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{"Tr", "[", 
        RowBox[{"x", " ", ".", " ", "icom"}], "]"}], ",", " ", 
       RowBox[{"{", 
        RowBox[{"x", ",", " ", "\[Sigma]"}], "}"}]}], "]"}], " ", "==", " ", 
     "\n", "   ", 
     RowBox[{"Cross", "[", 
      RowBox[{"\[Omega]", ",", " ", "r"}], "]"}]}]}], "]"}], " ", "//", " ", 
  "FullSimplify"}]}], "Input",
 CellLabel->
  "In[242]:= ",ExpressionUUID->"46d10a2d-4a0a-474b-a704-7ee7b2dfacc1"],

