        " ", "\"\<\[LeftAngleBracket]E(t)E(t+\[Tau])\[RightAngleBracket]\>\""}\
], "}"}]}]}], "]"}], ",", "\n", " ", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
      "\[Omega]0", ",", " ", "2.75", ",", " ", "\n", 
       "   ", "\"\<Laser's angular frequency \
\\!\\(\\*SubscriptBox[\\(\[Omega]\\), \\(0\\)]\\)\>\""}], "}"}], ",", " ", 
     "1", ",", " ", "\n", "  ", "10"}], "}"}], ",", " ", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
      "\[Kappa]", ",", " ", ".212", ",", " ", "\n", 
       "   ", "\"\<Laser's phase diffusion constant \[Kappa]\>\""}], "}"}], ",",
      " ", ".1", ",", " ", "\n", "  ", "2"}], "}"}], ",", " ", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"{", 
