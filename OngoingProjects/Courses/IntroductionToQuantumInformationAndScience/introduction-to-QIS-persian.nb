     RowBox[{
      RowBox[{
       RowBox[{"RotationTransform", "[", 
        RowBox[{"\[Alpha]", ",", " ", "n"}], "]"}], "[", 
       RowBox[{"{", 
        RowBox[{"rx", ",", " ", "ry", ",", " ", "\n", "     ", "rz"}], "}"}], 
       "]"}], ",", " ", 
