Cell[BoxData[{
 RowBox[{
  RowBox[{"randomTermsCollapseSDE", " ", "=", " ", "\n", "  ", 
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{"Sqrt", "[", "\[Gamma]", "]"}], " ", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{"jumpOperator", " ", ".", " ", "\[Rho]"}], " ", "+", " ", 
        RowBox[{"\[Rho]", " ", ".", " ", "\n", "        ", 
         RowBox[{"ConjugateTranspose", "[", "jumpOperator", "]"}]}], " ", "-",
         " ", "\n", "       ", 
        RowBox[{
         RowBox[{"Tr", "[", 
          RowBox[{
           RowBox[{"jumpOperator", " ", ".", " ", "\[Rho]"}], " ", "+", " ", 
           RowBox[{"\[Rho]", " ", ".", " ", "\n", "           ", 
            RowBox[{"ConjugateTranspose", "[", "jumpOperator", "]"}]}]}], 
          "]"}], " ", "\[Rho]"}]}], ")"}]}], " ", "//", " ", "BlochVector"}], 
    " ", "//", "\n", "    ", "FullSimplify"}]}], ";"}], "\n", 
 RowBox[{"randomTermsCollapseSDE", " ", "//", " ", "MatrixForm"}]}], "Input",
 CellLabel->
  "In[302]:= ",ExpressionUUID->"71b3b01d-20be-414c-85cf-b27503195f11"],

