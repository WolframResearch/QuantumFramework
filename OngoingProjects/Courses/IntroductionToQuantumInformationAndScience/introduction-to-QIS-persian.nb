Cell[BoxData[{
 RowBox[{
  RowBox[{"nonRandomTermsCollapseSDE", " ", "=", " ", 
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{"-", "I"}], " ", 
       RowBox[{"Commutator", "[", 
        RowBox[{
        "hamiltonianOperator", ",", " ", "\[Rho]", ",", "\n", "        ", 
         "Dot"}], "]"}]}], " ", "+", " ", 
      RowBox[{"\[Gamma]", " ", 
       RowBox[{"(", 
        RowBox[{
         RowBox[{
         "jumpOperator", " ", ".", " ", "\[Rho]", " ", ".", " ", "\n", 
          "         ", 
          RowBox[{"ConjugateTranspose", "[", "jumpOperator", "]"}]}], " ", "-",
          " ", "\n", "        ", 
         RowBox[{
          RowBox[{"1", "/", "2"}], " ", 
          RowBox[{"Anticommutator", "[", "\n", "          ", 
           RowBox[{
            RowBox[{
             RowBox[{"ConjugateTranspose", "[", "jumpOperator", "]"}], " ", ".",
              " ", "jumpOperator"}], ",", " ", "\[Rho]", ",", " ", "\n", 
            "          ", "Dot"}], "]"}]}]}], ")"}]}]}], " ", "//", " ", 
     "BlochVector"}], " ", "//", " ", "FullSimplify"}]}], ";"}], "\n", 
 RowBox[{"nonRandomTermsCollapseSDE", " ", "//", " ", 
  "MatrixForm"}]}], "Input",
 CellLabel->
  "In[301]:= ",ExpressionUUID->"2d89ee56-43a3-4167-9d3a-702daa5f1fb5"],

