        RowBox[{
         RowBox[{"PauliMatrix", "[", "1", "]"}], " ", ".", " ", 
         RowBox[{"\[Psi]", "[", "t", "]"}]}]}]}], ",", " ", 
      RowBox[{
       RowBox[{"\[Psi]", "[", "0", "]"}], " ", "==", " ", 
