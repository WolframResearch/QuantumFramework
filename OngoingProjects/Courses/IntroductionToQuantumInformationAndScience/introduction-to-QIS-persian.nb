            "m", ",", " ", "\n", 
             "      ", "\"\<\[LeftAngleBracket]\\!\\(\\*SubscriptBox[\\(X\\), \
\\(t\\)]\\)\[RightAngleBracket]\>\""}], "}"}], ",", " ", 
           RowBox[{"{", 
            RowBox[{
             RowBox[{"m", " ", "+", " ", 
              RowBox[{"Sqrt", "[", "v", "]"}]}], ",", " ", "\n", 
             "      ", "\"\<\[LeftAngleBracket]\\!\\(\\*SubscriptBox[\\(X\\), \
\\(t\\)]\\)\[RightAngleBracket]+\[Sigma]\>\""}], "}"}]}], "}"}], ",", " ", 
         "None"}], "}"}]}], ",", " ", 
      RowBox[{"AspectRatio", " ", "->", " ", 
       RowBox[{"1", "/", "3"}]}], ",", " ", "\n", "  ", 
      RowBox[{
