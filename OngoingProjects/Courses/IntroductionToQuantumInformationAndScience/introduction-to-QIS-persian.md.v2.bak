c3107cef60fb"]|>, ResourceSystemBase -> Automatic]][{{0, 0, 1}, 
    pulse . {0, 0, 1}}, ImageSize -> 150], 
  SwatchLegend[{ColorData[97][1], 
    ColorData[97][2]}, {"\!\(\*TemplateBox[{\"0\"},\n\"Ket\"]\)", 
